---
import { MAIN_PHONE, MAIN_PHONE_TEL } from '../data/branches';
import BrandBranchesGrid from './BrandBranchesGrid.astro';

export interface Props {
  brandName: string;
  brandSlug: string;
  categories: { label: string; url: string }[];
  /**
   * Marker for placeholder noindex mode. The component itself does NOT emit a
   * <meta name="robots"> tag (it doesn't render Layout). Pages using this component
   * should pass the same value to their own <Layout noindex={...}> when they want the
   * placeholder excluded from search indexes. Default false — per-page decision.
   * Wired up by SSOT cleanup PR (refactor/brands-ssot-cleanup, 2026-04-28).
   */
  noindex?: boolean;
}

const { brandName, brandSlug, categories, noindex = false } = Astro.props;
---

<!-- ── HERO ── -->
<section class="hero">
  <div class="hero-inner">
    <div class="hero-content">
      <p class="hero-eyebrow">Serving 5 SoCal Counties · 8 Branches</p>
      <h1>{brandName} Appliance Repair</h1>
      <p class="hero-sub">We service all {brandName} appliances across Los Angeles, Orange, Ventura, San Bernardino, and Riverside counties. Repair scope expanding.</p>
      <div class="hero-ctas">
        <a href={`tel:${MAIN_PHONE_TEL}`} class="btn-primary">☎ {MAIN_PHONE}</a>
        <a href="/contact/" class="btn-outline">Book Online</a>
      </div>
    </div>
    <div class="hero-img-wrap">
      <div class="hero-img-placeholder">
        <p>{brandName}</p>
        <p>Los Angeles</p>
      </div>
    </div>
  </div>
</section>

<!-- ── TRUST BAR ── -->
<div class="trust-bar">
  <div class="trust-bar-inner">
    <div class="trust-item"><span class="trust-icon">🏅</span> BHGS #A49573</div>
    <div class="trust-item"><span class="trust-icon">🛡️</span> Fully Insured</div>
    <div class="trust-item"><span class="trust-icon">⚡</span> Same Day Available</div>
    <div class="trust-item"><span class="trust-icon">🔩</span> OEM Parts on Truck</div>
    <div class="trust-item"><span class="trust-icon">💬</span> $89 Diagnostic — Waived With Repair</div>
  </div>
</div>

<BrandBranchesGrid />

<!-- ── CATEGORIES ── -->
<section class="cats">
  <div class="container">
    <p class="cats-eyebrow">Categories We Service</p>
    <h2>{brandName} Appliances We Repair</h2>
    <div class="cat-grid">
      {categories.map(c => (
        <a href={c.url} class="cat-card">
          <span class="cat-label">{c.label}</span>
          <span class="cat-arrow">→</span>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- ── FOOTER NOTE ── -->
<section class="foot-note">
  <div class="container">
    <p>Detailed {brandName} pages coming soon. In the meantime, see <a href="/services/">all appliance repair services</a> or call <a href={`tel:${MAIN_PHONE_TEL}`}>{MAIN_PHONE}</a> for same-day service.</p>
  </div>
</section>

<style>
  .hero {
    background: var(--black);
    color: #fff;
    padding: 72px 24px;
  }
  .hero-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }
  .hero-eyebrow {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 16px;
  }
  .hero h1 {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 46px);
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: 20px;
    letter-spacing: -.02em;
    color: #fff;
  }
  .hero-sub {
    font-size: 17px;
    color: rgba(255,255,255,.72);
    margin-bottom: 32px;
    line-height: 1.6;
  }
  .hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; }
  .btn-primary {
    background: var(--red);
    color: #fff;
    padding: 14px 28px;
    border-radius: 6px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
  }
  .btn-outline {
    border: 1.5px solid rgba(255,255,255,.35);
    color: #fff;
    padding: 14px 28px;
    border-radius: 6px;
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
  }
  .hero-img-wrap {
    border-radius: 12px;
    overflow: hidden;
    background: #1a1a1a;
    aspect-ratio: 4/3;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hero-img-placeholder {
    color: rgba(255,255,255,.2);
    font-size: 14px;
    text-align: center;
    line-height: 1.6;
  }

  .trust-bar {
    background: var(--red);
    color: #fff;
    padding: 16px 24px;
  }
  .trust-bar-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .trust-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 500;
  }
  .trust-icon { font-size: 16px; }

  .cats { padding: 72px 24px; background: #fff; }
  .container { max-width: 1100px; margin: 0 auto; }
  .cats-eyebrow {
    font-size: 12px; font-weight: 700; letter-spacing: .18em;
    text-transform: uppercase; color: var(--red); margin-bottom: 10px;
  }
  .cats h2 {
    font-family: var(--font-display);
    font-size: clamp(26px, 3.5vw, 36px);
    margin-bottom: 32px;
  }
  .cat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 14px;
  }
  .cat-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 22px;
    border: 1px solid var(--border);
    border-radius: 6px;
    text-decoration: none;
    color: var(--black);
    background: #fff;
    transition: all .15s var(--ease);
  }
  .cat-card:hover {
    border-color: var(--red);
    color: var(--red);
    transform: translateY(-2px);
  }
  .cat-label { font-size: 16px; font-weight: 600; }
  .cat-arrow { font-size: 18px; color: var(--red); }

  .foot-note {
    background: var(--gray);
    padding: 48px 24px;
    text-align: center;
  }
  .foot-note p {
    font-size: 15px;
    color: var(--muted);
    line-height: 1.6;
    max-width: 720px;
    margin: 0 auto;
  }
  .foot-note a { color: var(--red); font-weight: 600; text-decoration: none; }
  .foot-note a:hover { text-decoration: underline; }

  @media (max-width: 768px) {
    .hero-inner { grid-template-columns: 1fr; gap: 32px; }
    .hero-img-wrap { display: none; }
  }
</style>
