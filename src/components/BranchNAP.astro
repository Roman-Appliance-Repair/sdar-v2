---
/**
 * BranchNAP — site-wide reusable NAP (Name + Phone + Address-or-disclaimer) block.
 *
 * Renders a unified, indivisible NAP for one branch so every visible mention
 * matches the LocalBusiness JSON-LD schema word-for-word. Adds an optional
 * human-readable heading "Our [City] Location" + extension fields (email,
 * service-area cities) after the NAP.
 *
 * Source of truth: src/data/branches.ts (gbpName + displayCity + isServiceArea
 * + address + phone + email + displayAreas). NEVER hardcode NAP elements in
 * consumers — always pass a Branch object.
 *
 * Schema sync: schema reads branch.gbpName via HomepageSchema.buildLocalBusiness,
 * visible UI <h3 class="branch-name"> reads same branch.gbpName here. Both
 * therefore identical to the GMB-registered legal name (post-2026-05-07
 * canonical: "Same Day Appliance Repair[, City], CA Location").
 *
 * Service-area branches (7 of 8): WeHo is physical_pin + has address, others
 * render a disclaimer "We are a service-area business..." instead of street
 * address per Google SAB rules.
 */

import type { Branch } from '../data/branches';

export interface Props {
  branch: Branch;
  /** Render "Our [City] Location" heading above NAP block. Default true. */
  showHeading?: boolean;
  /** Render email line after address/disclaimer. Default true. */
  showEmail?: boolean;
  /** Render "Service area: city · city · ..." line at the bottom. Default true. */
  showCities?: boolean;
}

const {
  branch,
  showHeading = true,
  showEmail = true,
  showCities = true
} = Astro.props;

const phoneRaw = '+1' + branch.phone.replace(/\D/g, '');
---

{showHeading && (
  <p class="branch-heading">Our {branch.displayCity} Location</p>
)}

<div class="branch-nap">
  <h3 class="branch-name">{branch.gbpName}</h3>

  <a href={`tel:${phoneRaw}`} class="branch-phone">{branch.phone}</a>

  {branch.isServiceArea ? (
    <p class="service-area-note">
      <span>We are a service-area business. We serve customers on-site across the area.</span>
      <svg class="service-van-icon"
           width="20"
           height="20"
           viewBox="0 0 24 24"
           fill="none"
           stroke="currentColor"
           stroke-width="1.8"
           stroke-linecap="round"
           stroke-linejoin="round"
           aria-hidden="true">
        <path d="M14 17h-3M3 17h2M21 17h-2"/>
        <path d="M14 6H3a1 1 0 0 0-1 1v9a1 1 0 0 0 1 1h1"/>
        <path d="M14 17V6"/>
        <path d="M14 9h4l3 4v4h-2"/>
        <circle cx="7" cy="17" r="2"/>
        <circle cx="17" cy="17" r="2"/>
      </svg>
    </p>
  ) : (
    branch.address && (
      <address class="branch-address">
        {branch.address.street}, {branch.address.city}, {branch.address.state} {branch.address.zip}
      </address>
    )
  )}

  {showEmail && branch.email && (
    <a href={`mailto:${branch.email}`} class="branch-email">{branch.email}</a>
  )}

  {showCities && branch.displayAreas && branch.displayAreas.length > 0 && (
    <p class="branch-areas">
      <span class="areas-label">Service area:</span>
      {' '}{branch.displayAreas.join(' · ')}
    </p>
  )}
</div>

<style>
  .branch-heading {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--red, #C8102E);
    font-weight: 600;
    margin: 0 0 0.5rem 0;
  }
  .branch-nap {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .branch-name {
    font-size: 1.05rem;
    font-weight: 700;
    margin: 0 0 0.4rem 0;
    line-height: 1.3;
  }
  .branch-phone {
    display: block;
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--red, #C8102E);
    text-decoration: none;
    margin-bottom: 0.5rem;
  }
  .branch-phone:hover { text-decoration: underline; }
  .service-area-note {
    font-size: 0.85rem;
    color: inherit;
    margin: 0 0 0.5rem 0;
    line-height: 1.5;
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .service-van-icon {
    display: inline-block;
    vertical-align: middle;
    flex-shrink: 0;
    color: inherit;
  }
  .branch-address {
    font-size: 0.95rem;
    font-style: normal;
    margin: 0 0 0.5rem 0;
    line-height: 1.5;
  }
  .branch-email {
    display: block;
    font-size: 0.9rem;
    color: var(--muted, #6b6b6b);
    text-decoration: none;
    margin-bottom: 0.6rem;
  }
  .branch-email:hover { text-decoration: underline; color: var(--red, #C8102E); }
  .branch-areas {
    font-size: 0.85rem;
    color: var(--muted, #6b6b6b);
    margin: 0.5rem 0 0 0;
    line-height: 1.5;
  }
  .areas-label { font-weight: 600; }

  /* Dark-background adaptation (footer, dark hero variants).
     Triggered by ancestor element setting a dark surface — consumer wraps
     <BranchNAP /> in a class "branch-nap--dark" or applies inside
     .footer / .hero-section. */
  :global(.footer) .branch-heading,
  :global(.hero-section) .branch-heading,
  .branch-nap--dark .branch-heading {
    color: rgba(220, 53, 69, 0.95);
  }
  :global(.footer) .branch-name,
  :global(.hero-section) .branch-name,
  .branch-nap--dark .branch-name {
    color: rgba(255, 255, 255, 0.95);
  }
  :global(.footer) .branch-phone,
  :global(.hero-section) .branch-phone,
  .branch-nap--dark .branch-phone {
    color: rgba(255, 255, 255, 1);
  }
  :global(.footer) .branch-phone:hover,
  :global(.hero-section) .branch-phone:hover,
  .branch-nap--dark .branch-phone:hover {
    color: var(--red, #C8102E);
  }
  :global(.footer) .service-area-note,
  :global(.hero-section) .service-area-note,
  .branch-nap--dark .service-area-note {
    color: rgba(255, 255, 255, 0.95);
  }
  :global(.footer) .branch-address,
  :global(.hero-section) .branch-address,
  .branch-nap--dark .branch-address {
    color: rgba(255, 255, 255, 0.85);
  }
  :global(.footer) .branch-email,
  :global(.hero-section) .branch-email,
  .branch-nap--dark .branch-email {
    color: rgba(255, 255, 255, 0.65);
  }
  :global(.footer) .branch-email:hover,
  :global(.hero-section) .branch-email:hover,
  .branch-nap--dark .branch-email:hover {
    color: rgba(255, 255, 255, 1);
  }
  :global(.footer) .branch-areas,
  :global(.hero-section) .branch-areas,
  .branch-nap--dark .branch-areas {
    color: rgba(255, 255, 255, 0.55);
  }
</style>
