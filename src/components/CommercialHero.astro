---
/**
 * CommercialHero.astro
 * Unified hero block for /commercial/* pages.
 *
 * Default posture: NEUTRAL multi-county, B2B-tweaked. $120 diagnostic, 24/7,
 * COI, NSF — and the same 8-branch list available via showBranches=true.
 * NAP-compliant per branch-types-and-public-nap-rules.md.
 */

import BranchesBlock from './BranchesBlock.astro';
import { MAIN_PHONE } from '../data/branches';

const MAIN_PHONE_HREF = 'tel:+1' + MAIN_PHONE.replace(/\D/g, '');

export interface Props {
  eyebrow?: string;
  title: string;
  subtitle: string;
  phone?: string;
  phoneHref?: string;
  requestUrl?: string;
  requestLabel?: string;
  heroImageTitle?: string;
  heroImageLocation?: string;
  imageSrc?: string;
  imageAlt?: string;
  glassOverlay?: boolean;
  trustBarItems?: string[];
  /** When true, render the 8-branch list inside the hero content column.
   *  Default true for the new neutral-hub posture. */
  showBranches?: boolean;
}

const {
  eyebrow = 'Commercial · LA · Orange · Ventura · San Bernardino · Riverside Counties',
  title,
  subtitle,
  phone = MAIN_PHONE,
  phoneHref = MAIN_PHONE_HREF,
  requestUrl = '/contact/',
  requestLabel = 'Request Service',
  heroImageTitle = title,
  heroImageLocation = 'Southern California',
  imageSrc,
  imageAlt,
  glassOverlay = false,
  trustBarItems = [
    '🏅 BHGS #A49573',
    '⚡ 24/7 Emergency Service',
    '📄 COI Available On Request',
    '✅ NSF-Certified Repairs',
    '💬 $120 Diagnostic — Waived With Repair'
  ],
  showBranches = true
} = Astro.props;
---

<section class={`hero ${glassOverlay ? 'commercial-hero--glass' : ''}`}>
  {glassOverlay && imageSrc && (
    <div class="hero-bg-image">
      <img
        src={imageSrc}
        alt={imageAlt || heroImageTitle}
        width="1600"
        height="800"
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
    </div>
  )}
  <div class="hero-inner">
    <div class="hero-content">
      <p class="hero-eyebrow">{eyebrow}</p>
      <h1>{title}</h1>
      <p class="hero-sub">{subtitle}</p>
      <div class="hero-ctas">
        <a href={phoneHref} class="btn-primary">☎ {phone}</a>
        <a href={requestUrl} class="btn-outline">{requestLabel}</a>
      </div>
      {showBranches && (
        <div class="hero-branches-wrap">
          <BranchesBlock title="Our Branches" layout="grid" showCount={true} />
        </div>
      )}
    </div>
    {!glassOverlay && (
      <div class="hero-img-wrap">
        {imageSrc ? (
          <img
            src={imageSrc}
            alt={imageAlt || heroImageTitle}
            width="1600"
            height="800"
            loading="eager"
            fetchpriority="high"
            decoding="async"
          />
        ) : (
          <div class="hero-img-placeholder">
            <p>{heroImageTitle}</p>
            <p>{heroImageLocation}</p>
          </div>
        )}
      </div>
    )}
  </div>
</section>

<div class="trust-bar">
  <div class="trust-bar-inner">
    {trustBarItems.map((item) => {
      const match = item.match(/^(\S+)\s+(.*)$/);
      const icon = match ? match[1] : '';
      const text = match ? match[2] : item;
      return (
        <div class="trust-item"><span class="trust-icon">{icon}</span> {text}</div>
      );
    })}
  </div>
</div>

<style>
  .hero {
    background: #0a0a0a;
    color: #fff;
    padding: 80px 24px 72px;
  }
  .hero-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }
  .hero-eyebrow {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: #C8102E;
    margin-bottom: 16px;
  }
  .hero h1 {
    font-size: clamp(28px, 4vw, 46px);
    font-weight: 700;
    line-height: 1.15;
    margin: 0 0 20px;
    letter-spacing: -.02em;
    color: #fff;
    max-width: none;
  }
  .hero-sub {
    font-size: 17px;
    color: rgba(255, 255, 255, .72);
    margin: 0 0 32px;
    line-height: 1.6;
  }
  .hero-ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .btn-primary {
    background: #C8102E;
    color: #fff;
    padding: 14px 28px;
    border-radius: 6px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
    display: inline-block;
  }
  .btn-outline {
    border: 1.5px solid rgba(255, 255, 255, .35);
    color: #fff;
    padding: 14px 28px;
    border-radius: 6px;
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
    display: inline-block;
  }
  .hero-branches-wrap {
    margin-top: 28px;
    padding-top: 24px;
    border-top: 1px solid rgba(255, 255, 255, .08);
  }

  .hero-img-wrap {
    border-radius: 12px;
    overflow: hidden;
    background: #1a1a1a;
    aspect-ratio: 2 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
    align-self: start;
  }
  .hero-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .hero-img-placeholder {
    color: rgba(255, 255, 255, .2);
    font-size: 13px;
    text-align: center;
  }
  .hero-img-placeholder p {
    margin: 0;
  }

  .trust-bar {
    background: #C8102E;
    color: #fff;
    padding: 16px 24px;
  }
  .trust-bar-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .trust-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 500;
  }
  .trust-icon {
    font-size: 16px;
  }

  @media (max-width: 768px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }
    .hero-img-wrap {
      display: none;
    }
  }

  /* Glass overlay variant — full-bleed bg + frosted content card */
  .commercial-hero--glass {
    position: relative;
    overflow: hidden;
  }
  .commercial-hero--glass .hero-bg-image {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .commercial-hero--glass .hero-bg-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: right center;
    display: block;
  }
  .commercial-hero--glass .hero-bg-image::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg,
      rgba(10, 10, 10, 0.65) 0%,
      rgba(10, 10, 10, 0.35) 50%,
      rgba(10, 10, 10, 0.15) 100%);
    pointer-events: none;
  }
  .commercial-hero--glass .hero-inner {
    position: relative;
    z-index: 1;
  }
  .commercial-hero--glass .hero-content {
    background: rgba(20, 20, 20, 0.55);
    backdrop-filter: blur(16px) saturate(140%);
    -webkit-backdrop-filter: blur(16px) saturate(140%);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    padding: 48px 40px;
    max-width: 620px;
  }
  @media (max-width: 768px) {
    .commercial-hero--glass .hero-bg-image img {
      object-position: 70% center;
    }
    .commercial-hero--glass .hero-content {
      padding: 32px 24px;
      background: rgba(20, 20, 20, 0.70);
    }
  }
</style>
