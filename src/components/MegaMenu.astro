---
/**
 * MegaMenu — full-width frosted-glass multi-column panels.
 * Hover on a top-level item opens a 100vw panel pinned under the navbar.
 * Links generated dynamically from src/pages/* via import.meta.glob.
 */

const ACRONYMS = new Set([
  'bbb', 'oem', 'epa', 'osha', 'bbq', 'cslb', 'hvac', 'ac', 'la', 'ca', 'cma', 'ge', 'lg', 'sks', 'zline',
]);

function pathToSlug(path: string): string {
  return (path.split('/').pop() ?? '').replace(/\.astro$/, '');
}

function slugToLabel(slug: string): string {
  return slug.split('-').map((w) =>
    ACRONYMS.has(w.toLowerCase())
      ? w.toUpperCase()
      : w.charAt(0).toUpperCase() + w.slice(1)
  ).join(' ');
}

function toLinks(glob: Record<string, unknown>, hrefPrefix: string) {
  return Object.keys(glob)
    .map(pathToSlug)
    .filter((slug) => slug !== 'index')
    .sort()
    .map((slug) => ({
      label: slugToLabel(slug),
      href: `${hrefPrefix}${slug}/`,
    }));
}

const services    = toLinks(import.meta.glob('../pages/services/*.astro'),    '/services/');
const commercial  = toLinks(import.meta.glob('../pages/commercial/*.astro'),  '/commercial/');
const credentials = toLinks(import.meta.glob('../pages/credentials/*.astro'), '/credentials/');
const forBusiness = toLinks(import.meta.glob('../pages/for-business/*.astro'),'/for-business/');
const priceList   = toLinks(import.meta.glob('../pages/price-list/*.astro'),  '/price-list/');

// Root pages: counties + cities
const rootSlugs = Object.keys(import.meta.glob('../pages/*.astro'))
  .map(pathToSlug)
  .filter((slug) => slug !== 'index')
  .sort();

const counties = rootSlugs
  .filter((s) => s.endsWith('-county'))
  .map((slug) => ({ label: slugToLabel(slug), href: `/${slug}/` }));

const citiesAll = rootSlugs
  .filter((s) => !s.endsWith('-county'))
  .map((slug) => ({ label: slugToLabel(slug), href: `/${slug}/` }));

// Split cities alphabetically into two columns
const citiesHalf = Math.ceil(citiesAll.length / 2);
const citiesA = citiesAll.slice(0, citiesHalf);
const citiesB = citiesAll.slice(citiesHalf);

// Price list — strip "Cost" suffix for cleaner labels and split res/com
const stripCost = (label: string) => label.replace(/\s+Cost$/i, '');
const priceCommercial  = priceList
  .filter((l) => l.label.startsWith('Commercial'))
  .map((l) => ({ ...l, label: stripCost(l.label).replace(/^Commercial\s+/, '') }));
const priceResidential = priceList
  .filter((l) => !l.label.startsWith('Commercial'))
  .map((l) => ({ ...l, label: stripCost(l.label) }));

// Credentials split for two columns
const credHalf = Math.ceil(credentials.length / 2);
const credA = credentials.slice(0, credHalf);
const credB = credentials.slice(credHalf);

const mainPhone = '(323) 870-4790';
const mainPhoneTel = '+13238704790';

type Link = { label: string; href: string };
type Column = { title?: string; links?: Link[]; html?: string };
type Panel =
  | { kind: 'flow'; links: Link[] }
  | { kind: 'grouped'; columns: Column[]; align?: 'center' };

const menu: Array<{ label: string; href: string; panel: Panel }> = [
  {
    label: 'Services',
    href: '/services/',
    panel: { kind: 'flow', links: services },
  },
  {
    label: 'Commercial',
    href: '/commercial/',
    panel: { kind: 'flow', links: commercial },
  },
  {
    label: 'Brands',
    href: '/brands/',
    panel: {
      kind: 'grouped',
      align: 'center',
      columns: [
        {
          title: 'Brand Pages',
          html: 'Dedicated pages for Sub-Zero, Wolf, Viking, Thermador and more — coming soon. <br/>Browse all <a href="/services/">appliance services</a> in the meantime.',
        },
      ],
    },
  },
  {
    label: 'For Business',
    href: '/for-business/',
    panel: { kind: 'flow', links: forBusiness },
  },
  {
    label: 'Price List',
    href: '/price-list/',
    panel: {
      kind: 'grouped',
      columns: [
        { title: 'Residential', links: priceResidential },
        { title: 'Commercial',  links: priceCommercial  },
        {
          title: 'Transparent Pricing',
          html: '<strong>$89 diagnostic</strong> — waived with repair.<br/>OEM parts, 90-day warranty, no hidden fees.<br/><br/><a href="/price-list/">View full price list →</a>',
        },
      ],
    },
  },
  {
    label: 'Areas',
    href: '/areas/',
    panel: {
      kind: 'grouped',
      columns: [
        { title: 'By County', links: counties },
        { title: 'Cities A–M', links: citiesA },
        { title: 'Cities N–Z', links: citiesB },
      ],
    },
  },
  {
    label: 'About',
    href: '/credentials/',
    panel: {
      kind: 'grouped',
      columns: [
        { title: 'Credentials', links: credA },
        { title: 'Trust & Quality', links: credB },
        {
          title: 'Contact Us',
          html: `<a href="tel:${mainPhoneTel}" class="panel-phone">${mainPhone}</a>Same-day service across LA, Orange &amp; Ventura counties.<br/><br/><a href="/credentials/">All credentials →</a>`,
        },
      ],
    },
  },
];
---

<nav class="mega-menu" aria-label="Main navigation">
  <ul class="mega-menu-list">
    {menu.map((item) => (
      <li class="mega-menu-item" data-has-panel>
        <a href={item.href} class="mega-menu-trigger">
          <span class="trigger-label">{item.label}</span>
          <span class="trigger-underline" aria-hidden="true"></span>
        </a>
        <div class="mega-panel" role="region" aria-label={`${item.label} menu`}>
          {item.panel.kind === 'flow' ? (
            <div class="mega-panel-inner">
              <ul class="panel-flow">
                {item.panel.links.map((link) => (
                  <li><a href={link.href}>{link.label}</a></li>
                ))}
              </ul>
            </div>
          ) : (
            <div class={`mega-panel-inner mega-panel-grid ${item.panel.align === 'center' ? 'is-center' : ''}`}>
              {item.panel.columns.map((col) => (
                <div class="panel-col">
                  {col.title && <h4>{col.title}</h4>}
                  {col.links && (
                    <ul class="panel-list">
                      {col.links.map((link) => (
                        <li><a href={link.href}>{link.label}</a></li>
                      ))}
                    </ul>
                  )}
                  {col.html && <div class="panel-message" set:html={col.html} />}
                </div>
              ))}
            </div>
          )}
        </div>
      </li>
    ))}
  </ul>
</nav>

<script is:inline>
  (function () {
    const items = Array.from(document.querySelectorAll('.mega-menu-item[data-has-panel]'));
    const isMobile = () => window.matchMedia('(max-width: 1024px)').matches;
    let closeTimer = null;

    function closeAll() {
      items.forEach((i) => i.classList.remove('is-open'));
    }

    items.forEach((item) => {
      item.addEventListener('mouseenter', () => {
        if (isMobile()) return;
        clearTimeout(closeTimer);
        items.forEach((i) => { if (i !== item) i.classList.remove('is-open'); });
        item.classList.add('is-open');
      });
      item.addEventListener('mouseleave', () => {
        if (isMobile()) return;
        clearTimeout(closeTimer);
        closeTimer = setTimeout(() => item.classList.remove('is-open'), 150);
      });

      // Mobile accordion: tap trigger to toggle, prevent navigation on first tap
      const trigger = item.querySelector('.mega-menu-trigger');
      if (trigger) {
        trigger.addEventListener('click', (e) => {
          if (!isMobile()) return;
          if (!item.classList.contains('is-open')) {
            e.preventDefault();
            items.forEach((i) => { if (i !== item) i.classList.remove('is-open'); });
            item.classList.add('is-open');
          }
        });
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeAll();
    });
    document.addEventListener('click', (e) => {
      if (isMobile()) return;
      if (!e.target.closest('.mega-menu-item')) closeAll();
    });
  })();
</script>

<style>
  /* ===================== Top-level nav ===================== */
  .mega-menu {
    flex: 1;
    display: flex;
    justify-content: center;
  }

  .mega-menu-list {
    display: flex;
    list-style: none;
    gap: 4px;
    margin: 0;
    padding: 0;
  }

  .mega-menu-item {
    /* No position: relative — let .mega-panel position relative to the sticky .navbar */
  }

  .mega-menu-trigger {
    position: relative;
    display: inline-flex;
    align-items: center;
    padding: 10px 14px;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 500;
    color: var(--text);
    text-decoration: none;
    transition: color 0.2s var(--ease);
  }
  .mega-menu-trigger:hover { color: var(--black); }

  .trigger-underline {
    position: absolute;
    left: 14px;
    right: 14px;
    bottom: 4px;
    height: 2px;
    background: var(--red);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 0.25s var(--ease);
    pointer-events: none;
  }
  .mega-menu-item:hover .trigger-underline,
  .mega-menu-item:focus-within .trigger-underline,
  .mega-menu-item.is-open .trigger-underline {
    transform: scaleX(1);
  }

  /* ===================== Full-width panel ===================== */
  .mega-panel {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    width: 100%;
    background: rgba(10, 10, 10, 0.85);
    -webkit-backdrop-filter: blur(20px) saturate(1.8);
    backdrop-filter: blur(20px) saturate(1.8);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.4);
    color: #ffffff;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    transition:
      opacity 0.25s ease-out,
      transform 0.25s ease-out,
      visibility 0s linear 0.25s;
    z-index: 5;
  }

  /* Fallback when backdrop-filter is unsupported */
  @supports not ((backdrop-filter: blur(1px)) or (-webkit-backdrop-filter: blur(1px))) {
    .mega-panel { background: rgba(10, 10, 10, 0.95); }
  }

  /* Invisible hover bridge between trigger and panel */
  .mega-panel::before {
    content: '';
    position: absolute;
    top: -8px;
    left: 0;
    right: 0;
    height: 8px;
  }

  .mega-menu-item:hover .mega-panel,
  .mega-menu-item:focus-within .mega-panel,
  .mega-menu-item.is-open .mega-panel {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    transition:
      opacity 0.25s ease-out,
      transform 0.25s ease-out,
      visibility 0s linear 0s;
  }

  .mega-panel-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 48px 64px;
  }

  /* ===================== Flow layout (auto vertical columns) ===================== */
  .panel-flow {
    list-style: none;
    margin: 0;
    padding: 0;
    column-count: 3;
    column-gap: 64px;
  }
  .panel-flow li {
    break-inside: avoid;
  }

  /* ===================== Grid layout (explicit columns) ===================== */
  .mega-panel-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px 64px;
  }
  .mega-panel-grid.is-center {
    grid-template-columns: minmax(0, 560px);
    justify-content: center;
    text-align: center;
  }

  .panel-col h4 {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--red);
    margin: 0 0 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid rgba(200, 16, 46, 0.2);
  }

  .panel-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* Shared link styling for both layouts */
  .panel-flow a,
  .panel-list a {
    display: block;
    padding: 10px 0;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: 400;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.85);
    text-decoration: none;
    transition: color 0.2s ease, padding-left 0.2s ease;
  }
  .panel-flow a:hover,
  .panel-list a:hover {
    color: #ffffff;
    padding-left: 4px;
  }

  /* Rich-content message blocks */
  .panel-message {
    font-size: 14px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.7);
  }
  .panel-message strong { color: #ffffff; font-weight: 600; }
  .panel-message a {
    color: #ffffff;
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: rgba(255, 255, 255, 0.3);
    transition: text-decoration-color 0.2s ease, color 0.2s ease;
  }
  .panel-message a:hover {
    color: var(--red);
    text-decoration-color: var(--red);
  }
  .panel-message .panel-phone {
    display: block;
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 700;
    color: #ffffff;
    text-decoration: none;
    margin-bottom: 12px;
    letter-spacing: -0.01em;
  }
  .panel-message .panel-phone:hover { color: var(--red); }

  .mega-panel-grid.is-center .panel-col h4 {
    border-bottom: none;
    padding-bottom: 0;
  }

  /* ===================== Mobile (≤1024px): accordion ===================== */
  @media (max-width: 1024px) {
    .mega-menu {
      position: fixed;
      top: calc(var(--trust-bar-height) + var(--nav-height));
      left: 0;
      right: 0;
      bottom: 0;
      background: var(--white);
      overflow-y: auto;
      padding: 24px;
      transform: translateX(100%);
      transition: transform 0.3s var(--ease);
      z-index: 99;
      display: block;
    }
    .mega-menu.is-open { transform: translateX(0); }

    .mega-menu-list {
      flex-direction: column;
      gap: 0;
    }
    .mega-menu-item {
      border-bottom: 1px solid var(--border);
    }
    .mega-menu-trigger {
      width: 100%;
      padding: 16px 0;
      font-size: 17px;
      font-weight: 600;
      color: var(--black);
      justify-content: space-between;
    }
    .trigger-underline { display: none; }

    .mega-panel {
      position: static;
      background: transparent;
      box-shadow: none;
      border-top: none;
      color: var(--text);
      -webkit-backdrop-filter: none;
      backdrop-filter: none;
      opacity: 1;
      visibility: visible;
      transform: none;
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s var(--ease);
      z-index: auto;
    }
    .mega-panel::before { display: none; }
    .mega-menu-item.is-open .mega-panel,
    .mega-menu-item:focus-within .mega-panel {
      max-height: 6000px;
    }
    .mega-panel-inner {
      padding: 0 0 16px;
      max-width: none;
    }
    .mega-panel-grid,
    .mega-panel-grid.is-center {
      grid-template-columns: 1fr;
      gap: 20px;
      justify-content: stretch;
      text-align: left;
    }
    .panel-flow {
      column-count: 1;
    }
    .panel-flow a,
    .panel-list a {
      color: var(--text);
      font-size: 15px;
      padding: 8px 0;
    }
    .panel-flow a:hover,
    .panel-list a:hover {
      color: var(--red);
      padding-left: 4px;
    }
    .panel-col h4 {
      color: var(--red);
      border-bottom-color: rgba(200, 16, 46, 0.2);
    }
    .panel-message {
      color: var(--muted);
    }
    .panel-message strong { color: var(--black); }
    .panel-message a { color: var(--red); }
    .panel-message .panel-phone { color: var(--black); font-size: 22px; }
  }
</style>
