---
/**
 * CountyMap.astro — Leaflet-based interactive map of cities served in a given county.
 *
 * Usage:  <CountyMap county="los-angeles-county" height="420px" />
 *
 * Loads Leaflet 1.9.4 from CDN. Uses OpenStreetMap tiles (no API key).
 * Markers in site --red. Click a marker → city page. Hover → tooltip with city name.
 */

export interface Props {
  county: string;
  height?: string;
}

const { county, height = '400px' } = Astro.props;

interface CityPin { name: string; lat: number; lng: number; url: string; }
interface CountyData { center: [number, number]; zoom: number; cities: CityPin[]; markerType?: 'city' | 'branch'; }

