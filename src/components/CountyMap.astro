const data = COUNTIES[county];
if (!data) {
  throw new Error(`CountyMap: unknown county "${county}". Add it to COUNTIES in CountyMap.astro.`);
}

const containerId = `county-map-${county}`;
---

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" crossorigin="" />
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js" crossorigin="" defer></script>

<div class="county-map-wrap">
  <div id={containerId} class="county-map" style={`height: ${height};`} role="img" aria-label="Map of cities served"></div>
</div>

<script is:inline define:vars={{ containerId, data }}>
  (function () {
    function initMap() {
      if (typeof L === 'undefined') {
        return setTimeout(initMap, 60);
      }
      const el = document.getElementById(containerId);
      if (!el || el.dataset.cmInit === '1') return;
      el.dataset.cmInit = '1';

      const map = L.map(containerId, { scrollWheelZoom: false }).setView(data.center, data.zoom);
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 18,
        attribution: '&copy; OpenStreetMap contributors'
      }).addTo(map);

      const isBranch = data.markerType === 'branch';
      const size = isBranch ? 28 : 20;
      const icon = L.divIcon({
        className: 'county-map-marker' + (isBranch ? ' county-map-marker--branch' : ''),
        html: '<div class="cmm-pin' + (isBranch ? ' cmm-pin--branch' : '') + '" aria-hidden="true"></div>',
        iconSize: [size, size],
        iconAnchor: [size / 2, size / 2]
      });

      data.cities.forEach(function (c) {
        const m = L.marker([c.lat, c.lng], { icon: icon, title: c.name }).addTo(map);
        const tip = isBranch ? (c.name + ' &mdash; click for service area') : c.name;
        m.bindTooltip(tip, { direction: 'top', offset: [0, -8] });
        m.on('click', function () { window.location.href = c.url; });
      });
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initMap);
    } else {
      initMap();
    }
  })();
</script>

<style is:global>
  .county-map-marker .cmm-pin {
    width: 20px;
    height: 20px;
    background: #C8102E;
    border: 2px solid #fff;
    border-radius: 50%;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.4);
    cursor: pointer;
    transition: transform 0.15s ease, background 0.15s ease;
  }
  .county-map-marker:hover .cmm-pin {
    background: #ff1f47;
    transform: scale(1.18);
  }
  .county-map-marker--branch .cmm-pin--branch {
    width: 28px;
    height: 28px;
    border-width: 3px;
    box-shadow: 0 3px 10px rgba(0, 0, 0, 0.5), 0 0 0 4px rgba(200, 16, 46, 0.18);
  }
  .county-map-marker--branch:hover .cmm-pin--branch {
    box-shadow: 0 4px 14px rgba(0, 0, 0, 0.55), 0 0 0 6px rgba(200, 16, 46, 0.28);
  }
</style>

<style>
  .county-map-wrap {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .county-map {
    width: 100%;
    border: 1px solid var(--border, #e2e2e2);
    border-radius: 10px;
    overflow: hidden;
    z-index: 1;
  }
</style>
