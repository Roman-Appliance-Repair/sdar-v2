<div class="ai-diagnostic-banner">
  <div class="ai-diagnostic-banner__inner">
    <span class="ai-diagnostic-banner__icon">🤖</span>
    <div class="ai-diagnostic-banner__text">
      <strong>Not sure what's wrong with your appliance?</strong>
      <span>Get a free AI-powered diagnosis in 60 seconds — no obligation.</span>
    </div>
    <a href="/ai-diagnostic/" class="ai-diagnostic-banner__cta">
      Free Diagnostic →
    </a>
  </div>
</div>

<style>
.ai-diagnostic-banner {
  background: #0a0a0a;
  border-top: 3px solid #C8102E;
  border-bottom: 3px solid #C8102E;
  padding: 1rem 0;
}
.ai-diagnostic-banner__inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 1rem;
  display: flex;
  align-items: center;
  gap: 1rem;
  flex-wrap: wrap;
}
.ai-diagnostic-banner__icon {
  font-size: 2rem;
  flex-shrink: 0;
}
.ai-diagnostic-banner__text {
  flex: 1;
  min-width: 200px;
}
.ai-diagnostic-banner__text strong {
  display: block;
  color: #ffffff;
  font-size: 1rem;
  font-weight: 700;
  margin-bottom: 2px;
}
.ai-diagnostic-banner__text span {
  color: #a0a0a0;
  font-size: 0.875rem;
}
.ai-diagnostic-banner__cta {
  display: inline-block;
  background: #C8102E;
  color: #ffffff;
  padding: 0.6rem 1.5rem;
  border-radius: 6px;
  font-weight: 600;
  font-size: 0.9rem;
  text-decoration: none;
  white-space: nowrap;
  flex-shrink: 0;
}
.ai-diagnostic-banner__cta:hover {
  background: #a50d26;
}
@media (max-width: 640px) {
  .ai-diagnostic-banner__inner {
    justify-content: center;
    text-align: center;
  }
  .ai-diagnostic-banner__cta {
    width: 100%;
    text-align: center;
  }
}
</style>
