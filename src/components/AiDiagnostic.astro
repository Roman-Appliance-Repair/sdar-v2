---
/**
 * AiDiagnostic — Special Block on homepage.
 *
 * Flow:
 *   1. User picks Residential/Commercial tab
 *   2. Selects Category → Equipment (cascading dropdown)
 *   3. Optional: brand + model + optional phone
 *   4. Describes problem → POST /api/diagnose → AI response
 *   5. Three CTA cards appear: PDF · Call Back · Book Visit
 *
 * Backend: functions/api/diagnose.js (Anthropic proxy)
 *          functions/api/contact.js (Telegram + Resend logger)
 * PDF: generated client-side with jsPDF (CDN), attached to email on server via base64.
 */

// Residential equipment catalog (mirrors /services/ + /price-list/ from SDAR sitemap)
const residential = [
  {
    category: 'Cooking',
    items: [
      { label: 'Oven', value: 'oven' },
      { label: 'Range', value: 'range' },
      { label: 'Stove', value: 'stove' },
      { label: 'Cooktop', value: 'cooktop' },
      { label: 'Induction Cooktop', value: 'induction-cooktop' },
      { label: 'Wall Oven', value: 'wall-oven' },
      { label: 'Range Hood', value: 'range-hood' },
      { label: 'Microwave', value: 'microwave' }
    ]
  },
  {
    category: 'Cooling',
    items: [
      { label: 'Refrigerator', value: 'refrigerator' },
      { label: 'Built-in Refrigerator', value: 'built-in-refrigerator' },
      { label: 'Freezer', value: 'freezer' },
      { label: 'Wine Cooler', value: 'wine-cooler' },
      { label: 'Wine Cellar', value: 'wine-cellar' },
      { label: 'Ice Maker', value: 'ice-maker' }
    ]
  },
  {
