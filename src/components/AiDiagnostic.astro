// Pass data to client-side script via data attribute (JSON-safe)
const catalogJson = JSON.stringify({ residential, commercial });
---

<section class="ai-diag section-black" id="ai-diagnostic" aria-labelledby="ai-diag-title">
  <div class="container">
    <!-- Header -->
    <div class="ai-diag-header">
      <p class="eyebrow">AI Diagnostic · Free · No signup</p>
      <h2 id="ai-diag-title">Not sure what's wrong? Describe it.</h2>
      <p class="lede">
        Tell us what your appliance is doing. Our AI technician — trained on 15+ years
        of repair data — will give you a likely cause, realistic cost range, and the
        next step. Takes 30 seconds. Keep the PDF, or have a real C-20 tech call you in 10.
      </p>
    </div>

    <!-- Form card -->
    <div class="ai-diag-card" data-catalog={catalogJson}>
      <!-- Sector toggle -->
      <div class="sector-toggle" role="tablist" aria-label="Service type">
        <button type="button" class="sector-btn is-active" data-sector="residential" role="tab" aria-selected="true">
          Residential
        </button>
        <button type="button" class="sector-btn" data-sector="commercial" role="tab" aria-selected="false">
          Commercial
        </button>
      </div>

      <!-- Step 1: Category + Equipment -->
      <div class="field-row">
        <div class="field">
          <label for="ai-category">Category</label>
          <select id="ai-category" name="category" required>
            <option value="">Choose a category…</option>
          </select>
        </div>
        <div class="field">
          <label for="ai-equipment">Equipment</label>
          <select id="ai-equipment" name="equipment" required disabled>
            <option value="">Select a category first</option>
          </select>
        </div>
      </div>

      <!-- Step 2: Optional brand/model -->
      <div class="field-row">
        <div class="field">
          <label for="ai-brand">Brand <span class="optional">(optional, improves accuracy)</span></label>
          <input type="text" id="ai-brand" name="brand" placeholder="e.g. Sub-Zero, LG, Whirlpool" autocomplete="off" />
        </div>
        <div class="field">
          <label for="ai-model">Model # <span class="optional">(optional)</span></label>
          <input type="text" id="ai-model" name="model" placeholder="e.g. DLE7300WE" autocomplete="off" />
        </div>
      </div>

      <!-- Step 3: Description -->
      <div class="field">
        <label for="ai-description">What's happening? <span class="req">*</span></label>
        <textarea id="ai-description" name="description" rows="4" required
          placeholder="Example: My fridge stopped cooling overnight. Lights work but compressor won't kick in. Started with a humming sound yesterday."></textarea>
        <div class="char-count"><span id="ai-char-count">0</span> / 1000</div>
      </div>

      <!-- Submit -->
      <button type="button" class="btn-diagnose" id="ai-submit">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 2a10 10 0 1 0 10 10"/><path d="M12 6v6l4 2"/>
        </svg>
        <span>Get AI Diagnosis</span>
      </button>

      <p class="disclaimer">
        AI-generated guidance based on symptom patterns — not a final diagnosis.
        For confirmation, a C-20 tech inspects on site.
      </p>
    </div>

    <!-- ============ Result zone (hidden until we have a response) ============ -->
    <div class="ai-diag-result" id="ai-result" hidden>
      <div class="result-header">
        <div class="result-badge">Preliminary Diagnosis</div>
        <button type="button" class="result-reset" id="ai-reset" aria-label="Start over">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 12a9 9 0 1 0 9-9"/><path d="M3 3v6h6"/></svg>
          New diagnosis
        </button>
      </div>

      <div class="result-text" id="ai-result-text"></div>

      <!-- Three CTA cards -->
      <div class="cta-grid">
        <!-- Card 1: PDF -->
        <div class="cta-card cta-pdf">
          <div class="cta-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          </div>
          <h3>Save Your Diagnosis</h3>
          <p>Download a PDF with your results, our direct phone, and a 15% savings code for first-time repair.</p>
          <div class="cta-form">
            <input type="email" id="pdf-email" placeholder="you@email.com" autocomplete="email" />
            <button type="button" class="btn-cta" id="pdf-submit">
              <span>Send PDF</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </button>
          </div>
          <div class="cta-status" id="pdf-status" hidden></div>
        </div>

        <!-- Card 2: Call Back -->
        <div class="cta-card cta-call">
          <div class="cta-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <h3>Call Back in 10 Min</h3>
          <p>Licensed C-20 technician calls you with real pricing, parts availability, and earliest slot.</p>
          <div class="cta-form">
            <input type="tel" id="call-phone" placeholder="(323) 870-4790" autocomplete="tel" />
            <button type="button" class="btn-cta btn-red-cta" id="call-submit">
              <span>Call Me Back</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </button>
          </div>
          <div class="cta-status" id="call-status" hidden></div>
        </div>

        <!-- Card 3: Book Visit -->
        <div class="cta-card cta-book">
          <div class="cta-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </div>
          <h3>Book a Tech Today</h3>
          <p>Same-day visit with common parts on the truck. $89 diagnostic waived with repair.</p>
          <div class="cta-form cta-form-book">
            <input type="tel" id="book-phone" placeholder="Phone" autocomplete="tel" />
            <input type="text" id="book-address" placeholder="Address or ZIP" autocomplete="street-address" />
            <select id="book-time">
              <option value="asap">As soon as possible</option>
              <option value="morning">This morning (8 AM – 12 PM)</option>
              <option value="afternoon">This afternoon (12 – 5 PM)</option>
              <option value="evening">This evening (5 – 8 PM)</option>
              <option value="tomorrow">Tomorrow</option>
            </select>
            <button type="button" class="btn-cta btn-red-cta" id="book-submit">
              <span>Book Visit</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </button>
          </div>
          <div class="cta-status" id="book-status" hidden></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- jsPDF for client-side PDF generation -->
<script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js" defer></script>

<script is:inline>
  (function() {
    document.addEventListener('DOMContentLoaded', init);

    function init() {
      const root = document.querySelector('.ai-diag-card');
      if (!root) return;
      const catalog = JSON.parse(root.dataset.catalog);
      const state = {
        sector: 'residential',
        category: '',
        equipment: '',
        equipmentLabel: '',
        brand: '',
        model: '',
        description: '',
        diagnosis: ''
      };

      const $ = (id) => document.getElementById(id);
      const sectorBtns = document.querySelectorAll('.sector-btn');
      const catSelect = $('ai-category');
      const eqSelect = $('ai-equipment');
      const brandInput = $('ai-brand');
      const modelInput = $('ai-model');
      const descInput = $('ai-description');
      const charCount = $('ai-char-count');
      const submitBtn = $('ai-submit');
      const resultZone = $('ai-result');
      const resultText = $('ai-result-text');
      const resetBtn = $('ai-reset');

      // --- Sector toggle ---
      sectorBtns.forEach((btn) => {
        btn.addEventListener('click', () => {
          sectorBtns.forEach((b) => {
            b.classList.remove('is-active');
            b.setAttribute('aria-selected', 'false');
          });
          btn.classList.add('is-active');
          btn.setAttribute('aria-selected', 'true');
          state.sector = btn.dataset.sector;
          state.category = '';
          state.equipment = '';
          populateCategories();
        });
      });

      // --- Populate categories for current sector ---
      function populateCategories() {
        const list = catalog[state.sector];
        catSelect.innerHTML = '<option value="">Choose a category…</option>';
        list.forEach((cat) => {
          const opt = document.createElement('option');
          opt.value = cat.category;
          opt.textContent = cat.category;
          catSelect.appendChild(opt);
        });
        eqSelect.innerHTML = '<option value="">Select a category first</option>';
        eqSelect.disabled = true;
      }

      // --- Category change → populate equipment ---
      catSelect.addEventListener('change', () => {
        state.category = catSelect.value;
        const list = catalog[state.sector];
        const cat = list.find((c) => c.category === state.category);
        if (!cat) {
          eqSelect.innerHTML = '<option value="">Select a category first</option>';
          eqSelect.disabled = true;
          return;
        }
        eqSelect.innerHTML = '<option value="">Choose equipment…</option>';
        cat.items.forEach((item) => {
          const opt = document.createElement('option');
          opt.value = item.value;
          opt.textContent = item.label;
          eqSelect.appendChild(opt);
        });
        eqSelect.disabled = false;
      });

      eqSelect.addEventListener('change', () => {
        state.equipment = eqSelect.value;
        state.equipmentLabel = eqSelect.options[eqSelect.selectedIndex]?.text || '';
      });

      // --- Char counter ---
      descInput.addEventListener('input', () => {
        const len = descInput.value.length;
        charCount.textContent = len;
        if (len > 1000) descInput.value = descInput.value.slice(0, 1000);
      });

      // --- Submit ---
      submitBtn.addEventListener('click', async () => {
        state.brand = brandInput.value.trim();
        state.model = modelInput.value.trim();
        state.description = descInput.value.trim();

        if (!state.equipment) { alert('Please select the equipment type.'); return; }
        if (!state.description || state.description.length < 10) {
          alert('Please describe the problem (at least 10 characters).');
          return;
        }

        submitBtn.disabled = true;
        submitBtn.innerHTML = '<span>Analyzing…</span>';

        try {
          const res = await fetch('/api/diagnose', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              sector: state.sector,
              category: state.category,
              equipment: state.equipment,
              equipmentLabel: state.equipmentLabel,
              brand: state.brand,
              model: state.model,
              description: state.description
            })
          });
          const data = await res.json();
          state.diagnosis = data.result || 'Unable to generate diagnosis. Please call (323) 870-4790.';
          showResult(state.diagnosis);
          logEvent({ type: 'ai_diagnostic', ...state });
        } catch (err) {
          console.error(err);
          state.diagnosis = 'We hit a snag — please call (323) 870-4790 for a free phone diagnosis.';
          showResult(state.diagnosis);
        } finally {
          submitBtn.disabled = false;
          submitBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2a10 10 0 1 0 10 10"/><path d="M12 6v6l4 2"/></svg><span>Get AI Diagnosis</span>';
        }
      });

      function showResult(text) {
        resultText.textContent = text;
        resultZone.hidden = false;
        resultZone.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }

      resetBtn.addEventListener('click', () => {
        resultZone.hidden = true;
        descInput.value = '';
        brandInput.value = '';
        modelInput.value = '';
        charCount.textContent = '0';
        window.scrollTo({ top: root.offsetTop - 80, behavior: 'smooth' });
      });

      // --- Logging helper (fire-and-forget) ---
      function logEvent(payload) {
        try {
          fetch('/api/contact', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              name: '🤖 AI Diagnostics',
              ...payload
            }),
            keepalive: true
          }).catch(() => {});
        } catch (e) {}
      }

      // ========== CTA: PDF ==========
      $('pdf-submit').addEventListener('click', async () => {
        const email = $('pdf-email').value.trim();
        const status = $('pdf-status');
        if (!email || !/^\S+@\S+\.\S+$/.test(email)) {
          status.hidden = false; status.textContent = '✗ Please enter a valid email.';
          status.className = 'cta-status is-error'; return;
        }
        status.hidden = false; status.textContent = 'Building your PDF…';
        status.className = 'cta-status';

        // Build PDF client-side
        const pdfBase64 = await buildPdf(state);

        // Trigger download immediately
        const link = document.createElement('a');
        link.href = 'data:application/pdf;base64,' + pdfBase64;
        link.download = `SDAR-Diagnosis-${Date.now()}.pdf`;
        link.click();

        // Send to server (email + log)
        try {
          await fetch('/api/contact', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              name: '📄 PDF Request',
              type: 'pdf',
              email,
              equipment: state.equipmentLabel,
              brand: state.brand,
              diagnosis: state.diagnosis,
              pdfBase64
            })
          });
          status.textContent = '✓ PDF downloaded + emailed to ' + email;
          status.className = 'cta-status is-success';
        } catch (err) {
          status.textContent = '✓ PDF downloaded (email delivery may be delayed).';
          status.className = 'cta-status is-success';
        }
      });

      // ========== CTA: Call Back ==========
      $('call-submit').addEventListener('click', async () => {
        const phone = $('call-phone').value.trim();
        const status = $('call-status');
        if (!phone || phone.length < 7) {
          status.hidden = false; status.textContent = '✗ Please enter a valid phone number.';
          status.className = 'cta-status is-error'; return;
        }
        status.hidden = false; status.textContent = 'Sending to dispatch…';
        status.className = 'cta-status';

        try {
          await fetch('/api/contact', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              name: '📞 Call Back Request',
              type: 'callback',
              phone,
              equipment: state.equipmentLabel,
              brand: state.brand,
              model: state.model,
              diagnosis: state.diagnosis
            })
          });
          status.textContent = '✓ Got it — a C-20 tech will call within 10 minutes.';
          status.className = 'cta-status is-success';
        } catch (err) {
          status.textContent = '✗ Failed to send. Please call (323) 870-4790.';
          status.className = 'cta-status is-error';
        }
      });

      // ========== CTA: Book Visit ==========
      $('book-submit').addEventListener('click', async () => {
        const phone = $('book-phone').value.trim();
        const address = $('book-address').value.trim();
        const time = $('book-time').value;
        const status = $('book-status');
        if (!phone || phone.length < 7) {
          status.hidden = false; status.textContent = '✗ Please enter a valid phone number.';
          status.className = 'cta-status is-error'; return;
        }
        if (!address) {
          status.hidden = false; status.textContent = '✗ Please enter an address or ZIP.';
          status.className = 'cta-status is-error'; return;
        }
        status.hidden = false; status.textContent = 'Booking…';
        status.className = 'cta-status';

        try {
          await fetch('/api/contact', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              name: '📅 Booking Request',
              type: 'booking',
              phone,
              address,
              time,
              equipment: state.equipmentLabel,
              brand: state.brand,
              model: state.model,
              diagnosis: state.diagnosis
            })
          });
          status.textContent = '✓ Booked — dispatcher will confirm within 10 minutes.';
          status.className = 'cta-status is-success';
        } catch (err) {
          status.textContent = '✗ Failed to send. Please call (323) 870-4790.';
          status.className = 'cta-status is-error';
        }
      });

      // ========== PDF Builder (jsPDF) ==========
      async function buildPdf(s) {
        // Wait for jsPDF to load if not yet
        let tries = 0;
        while (!window.jspdf && tries < 30) {
          await new Promise((r) => setTimeout(r, 100));
          tries++;
        }
        if (!window.jspdf) throw new Error('PDF lib failed to load');

        const { jsPDF } = window.jspdf;
        const doc = new jsPDF({ unit: 'pt', format: 'letter' });
        const W = 612, M = 48;

        // Header bar (black)
        doc.setFillColor(10, 10, 10);
        doc.rect(0, 0, W, 80, 'F');
        doc.setTextColor(255, 255, 255);
        doc.setFont('helvetica', 'bold');
        doc.setFontSize(22);
        doc.text('SAME DAY', M, 34);
        doc.setFontSize(10);
        doc.setTextColor(200, 16, 46);
        doc.text('APPLIANCE REPAIR', M, 50);
        doc.setTextColor(255, 255, 255);
        doc.setFont('helvetica', 'normal');
        doc.setFontSize(9);
        doc.text('Preliminary Diagnosis Report', W - M, 34, { align: 'right' });
        doc.text(new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }), W - M, 50, { align: 'right' });

        // Title
        let y = 120;
        doc.setTextColor(10, 10, 10);
        doc.setFont('times', 'bold');
        doc.setFontSize(20);
        doc.text('Your Preliminary Diagnosis', M, y);

        y += 30;
        // Equipment summary
        doc.setFont('helvetica', 'bold');
        doc.setFontSize(10);
        doc.setTextColor(200, 16, 46);
        doc.text('EQUIPMENT', M, y);
        doc.setTextColor(10, 10, 10);
        doc.setFont('helvetica', 'normal');
        doc.setFontSize(11);
        const equipLine = [s.sector === 'residential' ? 'Residential' : 'Commercial', s.equipmentLabel, s.brand, s.model].filter(Boolean).join(' · ');
        doc.text(equipLine || '—', M, y + 14);

        y += 42;
        doc.setFont('helvetica', 'bold');
        doc.setFontSize(10);
        doc.setTextColor(200, 16, 46);
        doc.text('REPORTED ISSUE', M, y);
        doc.setTextColor(60, 60, 60);
        doc.setFont('helvetica', 'italic');
        doc.setFontSize(10);
        const descLines = doc.splitTextToSize(s.description || '—', W - M * 2);
        doc.text(descLines, M, y + 14);
        y += 14 + descLines.length * 12 + 20;

        // Diagnosis box
        doc.setFillColor(245, 245, 245);
        const diagLines = doc.splitTextToSize(s.diagnosis || '—', W - M * 2 - 24);
        const diagHeight = 20 + diagLines.length * 14 + 20;
        doc.rect(M, y, W - M * 2, diagHeight, 'F');
        doc.setTextColor(200, 16, 46);
        doc.setFont('helvetica', 'bold');
        doc.setFontSize(10);
        doc.text('AI DIAGNOSIS', M + 12, y + 20);
        doc.setTextColor(10, 10, 10);
        doc.setFont('times', 'normal');
        doc.setFontSize(11);
        doc.text(diagLines, M + 12, y + 38);
        y += diagHeight + 24;

        // Why us
        doc.setTextColor(10, 10, 10);
        doc.setFont('helvetica', 'bold');
        doc.setFontSize(12);
        doc.text('Why Homeowners Pick Same Day', M, y);
        y += 18;
        doc.setFont('helvetica', 'normal');
        doc.setFontSize(10);
        const bullets = [
          '• BHGS #A49573 — most handyman shops aren\'t',
          '• BBB A+ accredited, fully insured, EPA 608 Universal certified (#1346255700410)',
          '• $89 diagnostic — waived when you approve the repair',
          '• Same-day service Monday–Saturday · phone answered 24/7',
          '• Most common parts stocked on trucks — fixed in one visit'
        ];
        bullets.forEach((line, i) => { doc.text(line, M, y + i * 14); });
        y += bullets.length * 14 + 20;

        // Footer — NAP + branches
        doc.setFillColor(10, 10, 10);
        doc.rect(0, 720, W, 72, 'F');
        doc.setTextColor(255, 255, 255);
        doc.setFont('helvetica', 'bold');
        doc.setFontSize(10);
        doc.text('Call us now — dispatcher answers 24/7', M, 738);
        doc.setFont('helvetica', 'normal');
        doc.setFontSize(9);
        doc.setTextColor(200, 200, 200);
        doc.text('West Hollywood (323) 870-4790   ·   Los Angeles (424) 325-0520   ·   Thousand Oaks (424) 208-0228', M, 754);
        doc.text('Pasadena (626) 376-4458   ·   Irvine (213) 401-9019', M, 766);
        doc.setTextColor(150, 150, 150);
        doc.setFontSize(8);
        doc.text('HVAC 777 LLC dba Same Day Appliance Repair · BHGS #A49573 · ', M, 782);

        // Return base64 (strip data: prefix)
        return doc.output('datauristring').split(',')[1];
      }

      // Initial populate
      populateCategories();
    }
  })();
</script>

