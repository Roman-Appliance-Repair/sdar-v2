// Commercial catalog (mirrors /commercial/ from SDAR sitemap)
const commercial = [
  {
    category: 'Refrigeration',
    items: [
      { label: 'Walk-in Cooler', value: 'walk-in-cooler' },
      { label: 'Walk-in Freezer', value: 'walk-in-freezer' },
      { label: 'Reach-in Refrigerator', value: 'reach-in-refrigerator' },
      { label: 'Reach-in Freezer', value: 'reach-in-freezer' },
      { label: 'Bar Refrigerator', value: 'bar-refrigerator' },
      { label: 'Showcase Refrigerator', value: 'showcase-refrigerator' },
      { label: 'Ice Machine', value: 'ice-machine' }
    ]
  },
  {
    category: 'Cooking',
    items: [
      { label: 'Commercial Oven', value: 'commercial-oven' },
      { label: 'Commercial Range', value: 'commercial-range' },
      { label: 'Commercial Stove', value: 'commercial-stove' },
      { label: 'Pizza Oven', value: 'commercial-pizza-oven' },
      { label: 'Fryer', value: 'fryer' },
      { label: 'Exhaust Hood', value: 'exhaust-hood' }
    ]
  },
  {
    category: 'Cleaning',
    items: [
      { label: 'Commercial Dishwasher', value: 'commercial-dishwasher' }
    ]
  },
  {
