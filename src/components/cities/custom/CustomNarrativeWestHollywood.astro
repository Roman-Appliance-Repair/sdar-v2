---
/**
 * West Hollywood — Airbnb / Property Manager block.
 * Verbatim from wiki/migration/content-dumps/west-hollywood.md (.wh-property block).
 * Variant A integration — uses gold/cream/black tokens.
 */

import SectionHeader from '../shared/SectionHeader.astro';
import { BRANCHES } from '../../../data/branches.ts';

export interface Props {
  number: string;
}

const { number } = Astro.props;
const branch = BRANCHES.find((b) => b.slug === 'west-hollywood')!;
const phone = branch.phone;
const phoneTel = `+1${phone.replace(/\D/g, '')}`;

const features = [
  'Coordinate with building management & concierge',
  'Key fob, smart lock & keybox access — no problem',
  'Certificate of Insurance (COI) available on request',
  'We leave units clean and guest-ready',
  'Same-day emergency service available for urgent situations',
];
---

<section class="va-section va-section--cream va-weho-property">
  <div class="va-container">
    <SectionHeader
      number={number}
      eyebrow="For Hosts & Property Managers"
      headline="Airbnb hosts &amp; property managers —"
      headlineAccent="we know how WeHo works"
    />

    <div class="va-weho-property__grid">
      <div class="va-weho-property__copy">
        <p class="va-body">
          A significant part of our West Hollywood calls come from hosts and property managers.
          We get it — a fridge that stops cooling in a rental unit the night before a guest checks in
          is a genuine emergency, not a "we'll be there Tuesday" situation. Our technicians have been
          navigating WeHo buildings for years: the concierge buildings on Sunset, the older walk-ups
          off Melrose, the smart-lock units where you text us an access code.
        </p>
        <p class="va-body">
          We work around your schedule, not ours. Tell us the check-in time and we'll make sure
          we're done before then. We leave the unit clean, appliance running, and we can send
          you a service confirmation for your records.
        </p>
        <ul class="va-weho-property__features">
          {features.map((f) => (
            <li>
              <span class="va-diamond" aria-hidden="true">◆</span>
              <span>{f}</span>
            </li>
          ))}
        </ul>
      </div>

      <aside class="va-weho-property__cta">
        <div class="va-weho-property__cta-eyebrow va-eyebrow-gold">Property Managers &amp; Hosts</div>
        <p class="va-body va-body--muted">
          Call to discuss service agreements and priority scheduling.
        </p>
        <a href={`tel:${phoneTel}`} class="va-btn-primary">Call {phone}</a>
        <p class="va-weho-property__hours">
          Available Mon–Fri 7am–9pm · Sat 8am–7pm · Sun 9am–5pm
        </p>
      </aside>
    </div>
  </div>
</section>

<style>
  .va-weho-property__grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 48px;
    align-items: start;
  }
  .va-weho-property__copy p { margin-bottom: 18px; }
  .va-weho-property__features {
    list-style: none;
    margin: 24px 0 0;
    padding: 0;
    display: grid;
    gap: 10px;
  }
  .va-weho-property__features li {
    display: flex;
    gap: 10px;
    align-items: baseline;
    font-size: 16px;
    color: var(--va-text);
  }
  .va-weho-property__cta {
    background: var(--va-white);
    border: 1px solid var(--va-border);
    border-radius: 4px;
    padding: 32px 28px;
    position: sticky;
    top: 96px;
  }
  .va-weho-property__cta-eyebrow { margin-bottom: 12px; }
  .va-weho-property__cta p { margin: 0 0 18px; font-size: 15px; }
  .va-weho-property__cta .va-btn-primary {
    width: 100%;
    justify-content: center;
    margin-bottom: 14px;
  }
  .va-weho-property__hours {
    margin: 0;
    font-size: 12px;
    color: var(--va-muted);
    text-align: center;
  }
  @media (max-width: 900px) {
    .va-weho-property__grid { grid-template-columns: 1fr; gap: 32px; }
    .va-weho-property__cta { position: static; }
  }
</style>
