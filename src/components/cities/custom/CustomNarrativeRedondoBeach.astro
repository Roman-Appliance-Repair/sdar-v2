---
/**
 * Redondo Beach — Two Beaches custom narrative.
 * Two zone cards (red-tinted coastal / white-tinted inland) on black bg, plus
 * a unique salt-air gradient `.zone-tip` callout below.
 * Content verbatim from wiki/migration/content-dumps/redondo-beach.md
 * (.rb-zones block + .zone-tip).
 */

import SectionHeader from '../shared/SectionHeader.astro';

export interface Props {
  number: string;
}

const { number } = Astro.props;
---

<section class="va-section va-section--black va-rb-zones">
  <div class="va-container">
    <SectionHeader
      number={number}
      eyebrow="Two Redondo Beaches · One Service"
      headline="Two Redondo Beaches —"
      headlineAccent="one service"
      subheadline="The coastal/inland split matters for appliances. Here's what it means for each zone."
      white={true}
    />

    <div class="va-rb-zones__grid">
      <article class="va-rb-zones__card va-rb-zones__card--coastal">
        <div class="va-rb-zones__eyebrow">Coastal · Salt Air</div>
        <h3 class="va-h3 va-rb-zones__name">South Redondo</h3>
        <p class="va-rb-zones__sub">The Strand · Riviera Village · Hollywood Riviera</p>
        <p class="va-rb-zones__body">
          Homes on or near The Strand and the ocean-facing blocks of South Redondo see real salt
          air — not just "beach proximity" but actual salt particulate that loads condenser coils
          and corrodes igniter electrodes faster than anywhere else in the South Bay except Malibu.
          Strand-adjacent homes may need coil cleaning every <strong>3-5 months</strong>. We
          inspect for salt corrosion on every coastal Redondo Beach refrigerator and range call.
        </p>
        <div class="va-rb-zones__zip">ZIP 90277</div>
      </article>

      <article class="va-rb-zones__card va-rb-zones__card--inland">
        <div class="va-rb-zones__eyebrow">Inland · Standard</div>
        <h3 class="va-h3 va-rb-zones__name">North Redondo</h3>
        <p class="va-rb-zones__sub">Aviation Corridor · Artesia area</p>
        <p class="va-rb-zones__body">
          North Redondo (90278) inland of Artesia Blvd has essentially no meaningful salt air
          factor. The appliance profile here is standard South Bay — LG, Samsung, GE, Whirlpool in
          well-maintained townhomes and single-family homes. Reliable same-day service, honest
          estimate, 90-day warranty. No coastal maintenance surcharges or upsells.
        </p>
        <div class="va-rb-zones__zip">ZIP 90278</div>
      </article>
    </div>

    <div class="va-rb-zones__tip">
      <div class="va-rb-zones__tip-icon" aria-hidden="true">🌊</div>
      <div class="va-rb-zones__tip-text">
        <strong>Redondo Beach salt air guide:</strong> The closer to The Strand, the more
        aggressive the exposure. A home on the water in South Redondo needs condenser coil
        cleaning every 3-5 months. A home three blocks inland in Riviera Village — every 6
        months. A home in North Redondo near Artesia — standard 12-month cycle. We calibrate our
        maintenance recommendations to your actual distance from the water, not a blanket coastal
        policy.
      </div>
    </div>
  </div>
</section>

<style>
  .va-rb-zones__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-bottom: 28px;
  }
  .va-rb-zones__card {
    border-radius: 4px;
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    border: 1px solid rgba(201, 169, 97, 0.22);
  }
  .va-rb-zones__card--coastal {
    background: rgba(200, 16, 46, 0.10);
    border-color: rgba(200, 16, 46, 0.4);
  }
  .va-rb-zones__card--inland {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.18);
  }
  .va-rb-zones__eyebrow {
    font-family: var(--va-font-body);
    font-size: 12px;
    color: var(--va-gold);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 600;
  }
  .va-rb-zones__name {
    margin: 0;
    color: var(--va-white);
    font-size: 26px;
    letter-spacing: -0.01em;
  }
  .va-rb-zones__sub {
    margin: 0;
    font-family: var(--va-font-body);
    font-size: 13px;
    color: rgba(255, 255, 255, 0.65);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .va-rb-zones__body {
    margin: 8px 0 0;
    font-size: 15px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.85);
    font-family: var(--va-font-body);
  }
  .va-rb-zones__body strong { color: var(--va-gold); }
  .va-rb-zones__zip {
    margin-top: auto;
    padding-top: 14px;
    font-family: var(--va-font-body);
    font-size: 12px;
    color: var(--va-gold);
    font-weight: 600;
    letter-spacing: 0.06em;
  }
  .va-rb-zones__tip {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    background: linear-gradient(
      90deg,
      rgba(0, 120, 200, 0.14) 0%,
      rgba(0, 120, 200, 0.04) 100%
    );
    border: 1px solid rgba(0, 140, 220, 0.3);
    border-radius: 4px;
    padding: 22px 26px;
  }
  .va-rb-zones__tip-icon {
    font-size: 24px;
    flex-shrink: 0;
    line-height: 1;
  }
  .va-rb-zones__tip-text {
    font-family: var(--va-font-body);
    font-size: 14px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.88);
  }
  .va-rb-zones__tip-text strong { color: var(--va-gold); }
  @media (max-width: 900px) {
    .va-rb-zones__grid { grid-template-columns: 1fr; }
  }
</style>
