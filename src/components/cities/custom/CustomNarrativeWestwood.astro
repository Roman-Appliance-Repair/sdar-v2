---
/**
 * Westwood — `.ww-two-worlds` Two Worlds editorial block.
 * Campus (blue-tinted) vs Estates (red-tinted) two-zone split with 4-bullet
 * detail rows per zone. On black bg.
 * Pattern: structurally similar to CustomNarrativeEncino.astro but with
 * blue campus / red estates color coding and bulleted detail lists.
 * Verbatim content from wiki/migration/content-dumps/westwood.md (.ww-two-worlds).
 */

import SectionHeader from '../shared/SectionHeader.astro';

export interface Props {
  number: string;
}

const { number } = Astro.props;

const campusBullets = [
  'Compact kitchen appliances',
  'Stackable washer/dryer units',
  'Building manager coordination',
  'Tenant & landlord calls both welcome',
];

const estatesBullets = [
  'Sub-Zero / Wolf / Thermador',
  'Built-in & panel-ready',
  'Estate & property manager ready',
  'OEM parts only',
];
---

<section class="va-section va-section--black va-ww-two-worlds">
  <div class="va-container">
    <SectionHeader
      number={number}
      eyebrow="Two Worlds · One ZIP Code"
      headline="Westwood is two neighborhoods —"
      headlineAccent="in one ZIP code"
      subheadline="Our technicians work in both. Same day, same quality, different situations."
      white={true}
    />

    <div class="va-ww-two-worlds__grid">
      <article class="va-ww-two-worlds__card va-ww-two-worlds__card--campus">
        <div class="va-ww-two-worlds__eyebrow">The Campus Corridor</div>
        <h3 class="va-h3 va-ww-two-worlds__name">Apartments, condos, and buildings along Gayley, Levering, Landfair &amp; Wilshire</h3>
        <p class="va-ww-two-worlds__body">
          High-rise and mid-rise buildings, compact kitchens, stackable laundry, shared laundry
          rooms, building management logistics. Tenants on deadline, landlords who need quick
          turnaround, building managers who coordinate access. We work with all of them — call us
          and tell us your situation, we'll handle the rest.
        </p>
        <ul class="va-ww-two-worlds__bullets">
          {campusBullets.map((b) => (
            <li>
              <span class="va-diamond" aria-hidden="true">◆</span>
              <span>{b}</span>
            </li>
          ))}
        </ul>
      </article>

      <article class="va-ww-two-worlds__card va-ww-two-worlds__card--estates">
        <div class="va-ww-two-worlds__eyebrow">Little Holmby &amp; South Westwood</div>
        <h3 class="va-h3 va-ww-two-worlds__name">Estates, single-family homes, and Wilshire Corridor high-end condos</h3>
        <p class="va-ww-two-worlds__body">
          Little Holmby's leafy residential streets south of Sunset have some of the finest
          kitchens in LA — Sub-Zero columns, Wolf ranges, Thermador appliances. The Wilshire
          Corridor buildings add luxury condo kitchens. We carry OEM parts for all of these brands
          and are experienced with the built-in configurations common in this part of 90024.
        </p>
        <ul class="va-ww-two-worlds__bullets">
          {estatesBullets.map((b) => (
            <li>
              <span class="va-diamond" aria-hidden="true">◆</span>
              <span>{b}</span>
            </li>
          ))}
        </ul>
      </article>
    </div>
  </div>
</section>

<style>
  .va-ww-two-worlds__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  .va-ww-two-worlds__card {
    border-radius: 4px;
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    border: 1px solid rgba(201, 169, 97, 0.22);
  }
  .va-ww-two-worlds__card--campus {
    background: rgba(0, 80, 200, 0.12);
    border-color: rgba(0, 120, 220, 0.4);
  }
  .va-ww-two-worlds__card--estates {
    background: rgba(200, 16, 46, 0.10);
    border-color: rgba(200, 16, 46, 0.4);
  }
  .va-ww-two-worlds__eyebrow {
    font-family: var(--va-font-body);
    font-size: 12px;
    color: var(--va-gold);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 600;
  }
  .va-ww-two-worlds__name {
    margin: 0;
    color: var(--va-white);
    font-size: 22px;
    line-height: 1.25;
    letter-spacing: -0.01em;
  }
  .va-ww-two-worlds__body {
    margin: 8px 0 0;
    font-size: 15px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.85);
    font-family: var(--va-font-body);
  }
  .va-ww-two-worlds__bullets {
    list-style: none;
    margin: 14px 0 0;
    padding: 14px 0 0;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    display: grid;
    gap: 10px;
  }
  .va-ww-two-worlds__bullets li {
    display: flex;
    gap: 10px;
    align-items: baseline;
    font-family: var(--va-font-body);
    font-size: 14px;
    color: rgba(255, 255, 255, 0.85);
  }
  @media (max-width: 900px) {
    .va-ww-two-worlds__grid { grid-template-columns: 1fr; }
  }
</style>
