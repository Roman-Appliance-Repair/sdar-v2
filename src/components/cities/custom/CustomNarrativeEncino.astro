---
/**
 * Encino — Two Encinos zone-split narrative.
 * Two zone cards (red-tinted estate / white-tinted valley) on black background.
 * SOURCE-BUG FIX: Legacy H2 "Two Encinodes — One Service" corrected to
 * "Two Encinos — One Service" (typo cataloged in source-code-bugs).
 * Content verbatim from wiki/migration/content-dumps/encino.md (.en-zones block).
 */

import SectionHeader from '../shared/SectionHeader.astro';

export interface Props {
  number: string;
}

const { number } = Astro.props;
---

<section class="va-section va-section--black va-en-zones">
  <div class="va-container">
    <SectionHeader
      number={number}
      eyebrow="Two Encinos · One Service"
      headline="Two Encinos —"
      headlineAccent="one service"
      subheadline="The Ventura Blvd divide matters for appliances. Here's what each zone looks like."
      white={true}
    />

    <div class="va-en-zones__grid">
      <article class="va-en-zones__card va-en-zones__card--estate">
        <div class="va-en-zones__eyebrow">Hillside · Estates</div>
        <h3 class="va-h3 va-en-zones__name">South Encino · 91436</h3>
        <p class="va-en-zones__sub">Amestoy Estates · Hayvenhurst Hills</p>
        <p class="va-en-zones__body">
          The hillside homes south of Ventura Boulevard in 91436 are among the most private and
          substantial properties in the San Fernando Valley. Sub-Zero built-ins, Wolf ranges,
          Thermador wall ovens, and Miele dishwashers are the standard. Many properties have
          estate managers or household staff. We coordinate gate access in advance, work with
          whoever is managing the property, and bring OEM parts for every luxury brand on every
          vehicle.
        </p>
        <div class="va-en-zones__zip">ZIP 91436</div>
      </article>

      <article class="va-en-zones__card va-en-zones__card--valley">
        <div class="va-en-zones__eyebrow">Valley · Residential</div>
        <h3 class="va-h3 va-en-zones__name">North Encino · 91316</h3>
        <p class="va-en-zones__sub">Encino Commons · Balboa Corridor</p>
        <p class="va-en-zones__body">
          North of Ventura, Encino is established Valley residential — well-maintained
          single-family homes and condos near Balboa Park, Encino Commons, and the Ventura Freeway
          corridor. LG, Samsung, GE, and Whirlpool are the common brands here. Same reliable
          same-day service, same $89 diagnostic waived with repair, same 90-day warranty.
        </p>
        <div class="va-en-zones__zip">ZIP 91316</div>
      </article>
    </div>
  </div>
</section>

<style>
  .va-en-zones__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  .va-en-zones__card {
    border-radius: 4px;
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    border: 1px solid rgba(201, 169, 97, 0.22);
  }
  .va-en-zones__card--estate {
    background: rgba(200, 16, 46, 0.10);
    border-color: rgba(200, 16, 46, 0.4);
  }
  .va-en-zones__card--valley {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.18);
  }
  .va-en-zones__eyebrow {
    font-family: var(--va-font-body);
    font-size: 12px;
    color: var(--va-gold);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 600;
  }
  .va-en-zones__name {
    margin: 0;
    color: var(--va-white);
    font-size: 26px;
    letter-spacing: -0.01em;
  }
  .va-en-zones__sub {
    margin: 0;
    font-family: var(--va-font-body);
    font-size: 13px;
    color: rgba(255, 255, 255, 0.65);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .va-en-zones__body {
    margin: 8px 0 0;
    font-size: 15px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.85);
    font-family: var(--va-font-body);
  }
  .va-en-zones__zip {
    margin-top: auto;
    padding-top: 14px;
    font-family: var(--va-font-body);
    font-size: 12px;
    color: var(--va-gold);
    font-weight: 600;
    letter-spacing: 0.06em;
  }
  @media (max-width: 900px) {
    .va-en-zones__grid { grid-template-columns: 1fr; }
  }
</style>
