---
/**
 * Long Beach — `.lb2-tiers` Three Tiers editorial block (Canal · Beach · Inland).
 * Three tier cards on black bg — Canal=red, Beach=blue, Inland=white.
 * Pattern: structurally identical to CustomNarrativeManhattanBeach.astro
 * (3 zone cards, different tints), adapted for Long Beach coastal-to-inland gradient.
 * Verbatim content from wiki/migration/content-dumps/long-beach.md (.lb2-tiers).
 */

import SectionHeader from '../shared/SectionHeader.astro';

export interface Props {
  number: string;
}

const { number } = Astro.props;

interface Tier {
  key: 'canal' | 'beach' | 'inland';
  label: string;
  area: string;
  description: string;
  zips: string;
}

const tiers: Tier[] = [
  {
    key: 'canal',
    label: 'Canal · Waterfront',
    area: 'Naples Island · Alamitos Bay',
    description:
      "Canal-front homes on one of LA's most prestigious waterway communities. Sub-Zero, Wolf, Thermador standard. Direct water exposure — aggressive salt air. Most complex service environment in Long Beach.",
    zips: 'ZIP 90803',
  },
  {
    key: 'beach',
    label: 'Beach · Shore',
    area: 'Belmont Shore · Bluff Park · Belmont Heights',
    description:
      '2nd Street corridor, oceanfront homes, vacation rentals. Significant salt air. Rental priority calls common. Mix of primary residences and investment properties.',
    zips: 'ZIPs 90803 · 90814',
  },
  {
    key: 'inland',
    label: 'Established · Inland',
    area: 'Bixby Knolls · Los Altos · East LB',
    description:
      'Mid-century single-family homes, established neighborhoods. GE, LG, Samsung, Whirlpool common. Standard repair profile — same reliable same-day service.',
    zips: 'ZIPs 90807 · 90808 · 90815',
  },
];
---

<section class="va-section va-section--black va-lb-tiers">
  <div class="va-container">
    <SectionHeader
      number={number}
      eyebrow="Coastal to Inland · Three Tiers"
      headline="Long Beach —"
      headlineAccent="coastal to inland"
      subheadline="Different neighborhoods, same same-day commitment across all ZIP codes."
      white={true}
    />

    <div class="va-lb-tiers__grid">
      {tiers.map((t) => (
        <article class={`va-lb-tiers__card va-lb-tiers__card--${t.key}`}>
          <div class="va-lb-tiers__label">{t.label}</div>
          <div class="va-lb-tiers__area">{t.area}</div>
          <p class="va-lb-tiers__desc">{t.description}</p>
          <div class="va-lb-tiers__zips">{t.zips}</div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .va-lb-tiers__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
  }
  .va-lb-tiers__card {
    border-radius: 4px;
    padding: 28px 24px;
    border: 1px solid rgba(201, 169, 97, 0.22);
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .va-lb-tiers__card--canal {
    background: rgba(200, 16, 46, 0.12);
    border-color: rgba(200, 16, 46, 0.4);
  }
  .va-lb-tiers__card--beach {
    background: rgba(0, 100, 200, 0.12);
    border-color: rgba(0, 140, 220, 0.4);
  }
  .va-lb-tiers__card--inland {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.18);
  }
  .va-lb-tiers__label {
    font-family: var(--va-font-display);
    font-size: 24px;
    color: var(--va-white);
    font-weight: 500;
    letter-spacing: -0.01em;
  }
  .va-lb-tiers__area {
    font-family: var(--va-font-body);
    font-size: 12px;
    color: var(--va-gold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
  }
  .va-lb-tiers__desc {
    margin: 6px 0 0;
    font-size: 14px;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.85);
    font-family: var(--va-font-body);
  }
  .va-lb-tiers__zips {
    margin-top: auto;
    padding-top: 14px;
    font-family: var(--va-font-body);
    font-size: 12px;
    color: var(--va-gold);
    font-weight: 600;
    letter-spacing: 0.06em;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
  }
  @media (max-width: 900px) {
    .va-lb-tiers__grid { grid-template-columns: 1fr; }
  }
</style>
