---
/**
 * Glendale — `.gl-context` editorial block.
 * Paragraphs + 4-stat grid + 18-brand pill panel on black background.
 * Pattern: BrandedExpertiseWestHollywood-style stat scoreboard, but with
 * 18 brand pills and Glendale-specific Mediterranean/mid-century narrative.
 * Verbatim content from wiki/migration/content-dumps/glendale.md (.gl-context).
 */

import SectionHeader from '../shared/SectionHeader.astro';

export interface Props {
  number: string;
}

const { number } = Astro.props;

const stats = [
  { num: '85%', label: 'First-visit fix rate' },
  { num: '90', label: 'Day warranty' },
  { num: '$89', label: 'Diagnostic fee' },
  { num: '7', label: 'Days a week' },
];

const brands = [
  'Samsung', 'LG', 'Whirlpool', 'GE', 'Maytag', 'Bosch',
  'KitchenAid', 'Frigidaire', 'Electrolux', 'Sub-Zero',
  'Viking', 'Thermador', 'Wolf', 'Miele', 'Dacor',
  'Jenn-Air', 'Speed Queen', 'Fisher & Paykel',
];
---

<section class="va-section va-section--black va-gl-context">
  <div class="va-container">
    <SectionHeader
      number={number}
      eyebrow="What Makes Glendale Different"
      headline="Hillside estates, mid-century homes, Brand Blvd condos —"
      headlineAccent="we've worked in all of them"
      white={true}
    />

    <div class="va-gl-context__grid">
      <div class="va-gl-context__copy">
        <p class="va-body va-body--white">
          Glendale sits between the Verdugo Mountains and Griffith Park, and that geography shapes
          everything about how appliances live here. Verdugo Woodlands and Rossmoyne are full of
          Mediterranean estates with Viking ranges, Sub-Zero built-ins, and Thermador wall ovens.
          Brand Blvd and Tropico run toward newer condo construction with Samsung French doors and
          LG laundry. Adams Hill and Sparr Heights hold Craftsman homes with appliances that may be
          a decade or two old but still worth repairing.
        </p>
        <p class="va-body va-body--white">
          Our technicians carry OEM parts for both ends of that spectrum on the same vehicle —
          Sub-Zero fill valves and Whirlpool drain pumps in the same parts bin. Glendale is also
          home to one of the largest Armenian-American communities in the United States, and the
          care, hospitality, and same-day expectations we bring to every call reflect that. Same
          service, same availability, every neighborhood.
        </p>
        <ul class="va-gl-context__brands">
          {brands.map((b) => (<li>{b}</li>))}
        </ul>
        <p class="va-gl-context__brands-label">All brands our technicians repair in Glendale</p>
      </div>
      <div class="va-gl-context__stats">
        {stats.map((s) => (
          <div class="va-gl-context__stat">
            <div class="va-gl-context__stat-num va-fraunces">{s.num}</div>
            <div class="va-gl-context__stat-label">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .va-gl-context__grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 56px;
    align-items: start;
  }
  .va-gl-context__copy p { margin-bottom: 18px; }
  .va-gl-context__brands {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    list-style: none;
    margin: 24px 0 8px;
    padding: 0;
  }
  .va-gl-context__brands li {
    padding: 8px 14px;
    border: 1px solid rgba(201, 169, 97, 0.4);
    border-radius: 999px;
    color: var(--va-gold);
    font-size: 13px;
    font-family: var(--va-font-body);
    letter-spacing: 0.02em;
  }
  .va-gl-context__brands-label {
    margin: 8px 0 0;
    font-family: var(--va-font-body);
    font-size: 12px;
    color: rgba(255, 255, 255, 0.55);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .va-gl-context__stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: rgba(201, 169, 97, 0.2);
    border: 1px solid rgba(201, 169, 97, 0.2);
  }
  .va-gl-context__stat {
    background: var(--va-black);
    padding: 28px 22px;
    text-align: center;
  }
  .va-gl-context__stat-num {
    font-size: 44px;
    color: var(--va-gold);
    line-height: 1;
    font-weight: 400;
    margin-bottom: 8px;
    letter-spacing: -0.02em;
  }
  .va-gl-context__stat-label {
    font-family: var(--va-font-body);
    font-size: 12px;
    color: rgba(255, 255, 255, 0.7);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  @media (max-width: 900px) {
    .va-gl-context__grid { grid-template-columns: 1fr; gap: 32px; }
  }
</style>
