---
/**
 * Marina del Rey — `.mdr-locations` All-of-the-Marina block.
 * 1fr 260px split with sticky CTA card "In a condo building?" — adapted from
 * CustomNarrativeWestHollywood.astro (Property Manager / sticky CTA pattern).
 * Verbatim content from wiki/migration/content-dumps/marina-del-rey.md (.mdr-locations).
 * Note: branch is Los Angeles (424) 325-0520.
 */

import SectionHeader from '../shared/SectionHeader.astro';
import { BRANCHES } from '../../../data/branches.ts';

export interface Props {
  number: string;
}

const { number } = Astro.props;
const branch = BRANCHES.find((b) => b.slug === 'los-angeles')!;
const phone = branch.phone;
const phoneTel = `+1${phone.replace(/\D/g, '')}`;

const marinaComplexes = [
  'Via Marina', 'Palawan Way', 'Bali Way',
  'Mindanao Way', 'Admiralty Way', 'Basin complexes',
];
const neighborhoods = [
  'Oxford Triangle', 'Villa Marina', 'Marina Peninsula',
  'The Shores', 'Marina del Rey Hotel area', 'Fiji Way area',
];
const nearby = [
  'Venice (90291)', 'Playa del Rey (90293)', 'Playa Vista (90094)',
  'Mar Vista (90066)', 'Culver City (90230)', 'Santa Monica',
];
---

<section class="va-section va-section--black va-mdr-locations">
  <div class="va-container">
    <SectionHeader
      number={number}
      eyebrow="We Know Every Part of the Marina"
      headline="All of Marina del Rey —"
      headlineAccent="90292"
      subheadline="A small ZIP, but the building types vary widely — high-rise Admiralty Way towers, low-rise Via Marina island channels, marina-facing first floors and interior units. Each has its own appliance maintenance reality."
      white={true}
    />

    <div class="va-mdr-locations__grid">
      <div class="va-mdr-locations__copy">
        <div class="va-mdr-locations__group">
          <div class="va-mdr-locations__group-title">Marina Complexes</div>
          <ul class="va-mdr-locations__list">
            {marinaComplexes.map((c) => (<li>{c}</li>))}
          </ul>
        </div>

        <div class="va-mdr-locations__group">
          <div class="va-mdr-locations__group-title">Neighborhoods</div>
          <ul class="va-mdr-locations__list">
            {neighborhoods.map((n) => (<li>{n}</li>))}
          </ul>
        </div>

        <div class="va-mdr-locations__group">
          <div class="va-mdr-locations__group-title">Nearby We Serve</div>
          <ul class="va-mdr-locations__list">
            {nearby.map((n) => (<li>{n}</li>))}
          </ul>
        </div>
      </div>

      <aside class="va-mdr-locations__cta">
        <div class="va-mdr-locations__cta-eyebrow va-eyebrow-gold">In a condo building?</div>
        <p class="va-body va-body--muted">
          We coordinate with HOA &amp; building management. Elevator access, COI on request,
          service reports for building records.
        </p>
        <a href={`tel:${phoneTel}`} class="va-btn-primary">Call {phone}</a>
        <p class="va-mdr-locations__hours">
          $89 diagnostic · Waived with repair · 90-day warranty
        </p>
      </aside>
    </div>
  </div>
</section>

<style>
  .va-mdr-locations__grid {
    display: grid;
    grid-template-columns: 1fr 260px;
    gap: 56px;
    align-items: start;
  }
  .va-mdr-locations__group {
    margin-bottom: 28px;
  }
  .va-mdr-locations__group-title {
    font-family: var(--va-font-body);
    font-size: 12px;
    color: var(--va-gold);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 600;
    margin-bottom: 12px;
  }
  .va-mdr-locations__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px 16px;
  }
  .va-mdr-locations__list li {
    padding: 10px 14px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 4px;
    font-family: var(--va-font-display);
    font-weight: 500;
    font-size: 15px;
    color: var(--va-white);
    letter-spacing: -0.005em;
  }
  .va-mdr-locations__cta {
    background: var(--va-white);
    border: 1px solid var(--va-border);
    border-radius: 4px;
    padding: 28px 24px;
    position: sticky;
    top: 96px;
  }
  .va-mdr-locations__cta-eyebrow { margin-bottom: 12px; }
  .va-mdr-locations__cta p { margin: 0 0 18px; font-size: 15px; }
  .va-mdr-locations__cta .va-btn-primary {
    width: 100%;
    justify-content: center;
    margin-bottom: 14px;
  }
  .va-mdr-locations__hours {
    margin: 0;
    font-size: 12px;
    color: var(--va-muted);
    text-align: center;
  }
  @media (max-width: 900px) {
    .va-mdr-locations__grid { grid-template-columns: 1fr; gap: 32px; }
    .va-mdr-locations__cta { position: static; }
    .va-mdr-locations__list { grid-template-columns: 1fr; }
  }
</style>
