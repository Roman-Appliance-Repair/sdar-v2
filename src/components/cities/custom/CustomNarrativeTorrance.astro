---
/**
 * Torrance — `.tr-areas` All-Neighborhoods 6-card 3-col grid editorial block.
 * REPLACES the standard NeighborhoodGrid section — this component IS the
 * neighborhood section for Torrance. 1 card featured (Coastal Bluff /
 * Hollywood Riviera), 5 standard. Variant A tokens, cream/black/white tints.
 * Verbatim content from wiki/migration/content-dumps/torrance.md (.tr-areas).
 */

import SectionHeader from '../shared/SectionHeader.astro';

export interface Props {
  number: string;
}

const { number } = Astro.props;

interface Area {
  label: string;
  name: string;
  description: string;
  zips: string;
  featured?: boolean;
}

const areas: Area[] = [
  {
    label: 'Coastal Bluff',
    name: 'Hollywood Riviera',
    description:
      'Ocean-facing bluff homes in the 90277/90278 border area. Sub-Zero and premium brands common. Moderate coastal exposure — we check coils on relevant calls.',
    zips: 'ZIPs 90503 · 90505',
    featured: true,
  },
  {
    label: 'Historic Core',
    name: 'Old Torrance',
    description:
      'Craftsman bungalows and early 20th century homes around Sartori Ave and the historic downtown. Well-maintained older housing with a mix of vintage and modern appliances.',
    zips: 'ZIP 90501',
  },
  {
    label: 'Hillside',
    name: 'Walteria',
    description:
      'Eastern Torrance hillside with larger mid-century homes and established landscaping. GE, Samsung, LG common. Standard same-day service profile.',
    zips: 'ZIP 90505',
  },
  {
    label: 'South Bay Corridor',
    name: 'North Torrance',
    description:
      'Dense residential along the Crenshaw/Hawthorne corridor. Mix of single-family and multi-family. LG, Samsung, Whirlpool most common.',
    zips: 'ZIP 90504',
  },
  {
    label: 'Established Residential',
    name: 'South Torrance',
    description:
      'Borders Redondo Beach and PV. Well-kept mid-century and newer homes. Standard appliance profile — all brands serviced same day.',
    zips: 'ZIPs 90503 · 90505',
  },
  {
    label: 'Central',
    name: 'Central Torrance',
    description:
      'Del Amo area, Madrona Ave, Anza Ave corridor. All brands, all housing types. Same-day available throughout.',
    zips: 'ZIPs 90503 · 90504',
  },
];
---

<section class="va-section va-section--cream va-tr-areas">
  <div class="va-container">
    <SectionHeader
      number={number}
      eyebrow="All Neighborhoods · 90501–90505"
      headline="Torrance —"
      headlineAccent="all neighborhoods"
      subheadline="Hollywood Riviera to North Torrance — same commitment across all ZIP codes."
    />

    <div class="va-tr-areas__grid">
      {areas.map((a) => (
        <article class={`va-tr-areas__card${a.featured ? ' va-tr-areas__card--featured' : ''}`}>
          <div class="va-tr-areas__label">{a.label}</div>
          <h3 class="va-h3 va-tr-areas__name">{a.name}</h3>
          <p class="va-tr-areas__desc">{a.description}</p>
          <div class="va-tr-areas__zips">{a.zips}</div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .va-tr-areas__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
  }
  .va-tr-areas__card {
    background: var(--va-white);
    border: 1px solid var(--va-border);
    border-radius: 4px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .va-tr-areas__card--featured {
    background: rgba(200, 16, 46, 0.05);
    border-color: rgba(200, 16, 46, 0.3);
  }
  .va-tr-areas__label {
    font-family: var(--va-font-body);
    font-size: 12px;
    color: var(--va-gold);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 600;
  }
  .va-tr-areas__name {
    margin: 0;
    color: var(--va-text);
    font-size: 24px;
    letter-spacing: -0.01em;
  }
  .va-tr-areas__desc {
    margin: 6px 0 0;
    font-size: 14px;
    line-height: 1.65;
    color: var(--va-text);
    font-family: var(--va-font-body);
  }
  .va-tr-areas__zips {
    margin-top: auto;
    padding-top: 14px;
    border-top: 1px solid var(--va-border);
    font-family: var(--va-font-body);
    font-size: 12px;
    color: var(--va-gold);
    font-weight: 600;
    letter-spacing: 0.06em;
  }
  @media (max-width: 900px) {
    .va-tr-areas__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 560px) {
    .va-tr-areas__grid { grid-template-columns: 1fr; }
  }
</style>
