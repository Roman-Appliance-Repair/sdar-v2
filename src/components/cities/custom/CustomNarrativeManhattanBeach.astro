---
/**
 * Manhattan Beach — Three Sections custom narrative (Sand · Tree · Hill).
 * Three zone cards on black bg — Sand=blue, Tree=green, Hill=red.
 * Content verbatim from wiki/migration/content-dumps/manhattan-beach.md
 * (.mb-sections block).
 */

import SectionHeader from '../shared/SectionHeader.astro';

export interface Props {
  number: string;
}

const { number } = Astro.props;

interface Zone {
  key: 'sand' | 'tree' | 'hill';
  label: string;
  area: string;
  description: string;
  approach: string;
}

const zones: Zone[] = [
  {
    key: 'sand',
    label: 'Sand Section',
    area: 'West of Highland Ave · Strand to 2nd St',
    description:
      "Direct ocean exposure means salt air hits appliances harder here than anywhere else in our service area. Refrigerator condenser coils corrode in 12–18 months instead of 4–5 years. Dishwasher door gaskets fail early. Outdoor grill igniter systems need annual attention.",
    approach:
      'Proactive coil inspection on every fridge call. 4-month cleaning schedule recommended for beachfront properties.',
  },
  {
    key: 'tree',
    label: 'Tree Section',
    area: 'Between Highland & Sepulveda · Named streets',
    description:
      'The family core of Manhattan Beach — Elm, Pine, Oak, Maple — with a mix of older craftsmans, updated Spanish colonials, and newer construction. Full range of appliances from decade-old Whirlpools to new Samsung French doors to Bosch dishwashers in recent kitchen remodels.',
    approach:
      'All brands, all ages. Salt air is real here too — typically 18–24 month coil cycle.',
  },
  {
    key: 'hill',
    label: 'Hill Section',
    area: 'East of Sepulveda · Ocean views · Larger lots',
    description:
      "The Hill Section's larger properties and ocean-view homes trend toward luxury appliances — Sub-Zero columns, Wolf dual-fuel ranges, Thermador cooktops, and Miele dishwashers. Built-in cabinetry and custom kitchens are common.",
    approach:
      'OEM parts for luxury brands on every truck. Built-in experience, no cabinetry damage.',
  },
];
---

<section class="va-section va-section--black va-mb-sections">
  <div class="va-container">
    <SectionHeader
      number={number}
      eyebrow="Three Sections · Three Realities"
      headline="Three sections, three different"
      headlineAccent="appliance realities"
      subheadline="Manhattan Beach residents know exactly which section they're in. So do our technicians."
      white={true}
    />

    <div class="va-mb-sections__grid">
      {zones.map((z) => (
        <article class={`va-mb-sections__card va-mb-sections__card--${z.key}`}>
          <div class="va-mb-sections__label">{z.label}</div>
          <div class="va-mb-sections__area">{z.area}</div>
          <p class="va-mb-sections__desc">{z.description}</p>
          <div class="va-mb-sections__approach">
            <strong>Our approach:</strong> {z.approach}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .va-mb-sections__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
  }
  .va-mb-sections__card {
    border-radius: 4px;
    padding: 28px 24px;
    border: 1px solid rgba(201, 169, 97, 0.22);
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .va-mb-sections__card--sand {
    background: rgba(0, 120, 200, 0.12);
    border-color: rgba(0, 140, 220, 0.4);
  }
  .va-mb-sections__card--tree {
    background: rgba(0, 140, 60, 0.10);
    border-color: rgba(0, 160, 80, 0.4);
  }
  .va-mb-sections__card--hill {
    background: rgba(200, 16, 46, 0.10);
    border-color: rgba(200, 16, 46, 0.4);
  }
  .va-mb-sections__label {
    font-family: var(--va-font-display);
    font-size: 24px;
    color: var(--va-white);
    font-weight: 500;
    letter-spacing: -0.01em;
  }
  .va-mb-sections__area {
    font-family: var(--va-font-body);
    font-size: 12px;
    color: var(--va-gold);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
  }
  .va-mb-sections__desc {
    margin: 6px 0 0;
    font-size: 14px;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.85);
    font-family: var(--va-font-body);
  }
  .va-mb-sections__approach {
    margin-top: auto;
    padding-top: 14px;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    font-size: 13px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.78);
    font-family: var(--va-font-body);
  }
  .va-mb-sections__approach strong {
    color: var(--va-gold);
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  @media (max-width: 900px) {
    .va-mb-sections__grid { grid-template-columns: 1fr; }
  }
</style>
