---
/**
 * Koreatown — `.kt-contexts` Two Contexts editorial block.
 * Two context cards (red residential / green commercial) on black bg.
 * Pattern adapted from CustomNarrativeEncino.astro two-zone structure but with
 * residential red / commercial green color coding.
 * Verbatim content from wiki/migration/content-dumps/koreatown.md (.kt-contexts).
 */

import SectionHeader from '../shared/SectionHeader.astro';

export interface Props {
  number: string;
}

const { number } = Astro.props;
---

<section class="va-section va-section--black va-kt-contexts">
  <div class="va-container">
    <SectionHeader
      number={number}
      eyebrow="Two Contexts · One Service"
      headline="Two Koreatown contexts —"
      headlineAccent="residential and the restaurant corridor"
      subheadline="Apartments and condos on one side, the Wilshire/6th/Vermont restaurant density on the other. We serve both."
      white={true}
    />

    <div class="va-kt-contexts__grid">
      <article class="va-kt-contexts__card va-kt-contexts__card--residential">
        <div class="va-kt-contexts__icon" aria-hidden="true">🏢</div>
        <div class="va-kt-contexts__eyebrow">Residential</div>
        <h3 class="va-h3 va-kt-contexts__name">Apartments &amp; Condos</h3>
        <p class="va-kt-contexts__body">
          In-unit stackable washers, compact galley kitchens, older building plumbing — the
          appliance landscape in Koreatown's residential buildings requires care with space and
          documentation. We work in tight spaces and provide written tenant diagnostic reports
          as standard. Samsung, LG, GE, Whirlpool — OEM parts on every vehicle.
        </p>
        <ul class="va-kt-contexts__tags">
          <li>Written tenant reports</li>
          <li>Compact kitchens</li>
          <li>Stackable units</li>
        </ul>
      </article>

      <article class="va-kt-contexts__card va-kt-contexts__card--commercial">
        <div class="va-kt-contexts__icon" aria-hidden="true">🍽️</div>
        <div class="va-kt-contexts__eyebrow">Commercial</div>
        <h3 class="va-h3 va-kt-contexts__name">Restaurant Corridor</h3>
        <p class="va-kt-contexts__body">
          Wilshire Blvd, 6th Street, Vermont Ave — Koreatown's restaurant density is among the
          highest in LA. When a reach-in cooler or commercial refrigerator fails during service,
          the cost of lost product exceeds the repair. We service commercial refrigeration in
          restaurant settings throughout the Koreatown corridor.
        </p>
        <ul class="va-kt-contexts__tags">
          <li>Commercial refrigeration</li>
          <li>Restaurant priority</li>
          <li>Same day</li>
        </ul>
      </article>
    </div>
  </div>
</section>

<style>
  .va-kt-contexts__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  .va-kt-contexts__card {
    border-radius: 4px;
    padding: 32px 28px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    border: 1px solid rgba(201, 169, 97, 0.22);
  }
  .va-kt-contexts__card--residential {
    background: rgba(200, 16, 46, 0.10);
    border-color: rgba(200, 16, 46, 0.4);
  }
  .va-kt-contexts__card--commercial {
    background: rgba(0, 140, 60, 0.10);
    border-color: rgba(0, 160, 80, 0.4);
  }
  .va-kt-contexts__icon {
    font-size: 28px;
    line-height: 1;
  }
  .va-kt-contexts__eyebrow {
    font-family: var(--va-font-body);
    font-size: 12px;
    color: var(--va-gold);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-weight: 600;
  }
  .va-kt-contexts__name {
    margin: 0;
    color: var(--va-white);
    font-size: 26px;
    letter-spacing: -0.01em;
  }
  .va-kt-contexts__body {
    margin: 8px 0 0;
    font-size: 15px;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.85);
    font-family: var(--va-font-body);
  }
  .va-kt-contexts__tags {
    margin: 14px 0 0;
    padding: 14px 0 0;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .va-kt-contexts__tags li {
    padding: 5px 12px;
    border: 1px solid rgba(201, 169, 97, 0.4);
    border-radius: 999px;
    color: var(--va-gold);
    font-size: 12px;
    font-family: var(--va-font-body);
    letter-spacing: 0.02em;
  }
  @media (max-width: 900px) {
    .va-kt-contexts__grid { grid-template-columns: 1fr; }
  }
</style>
