---
/**
 * West Hollywood — Branded Expertise block.
 * Sub-Zero · Thermador · Viking luxury depth + .luxury-stats 4-card scoreboard.
 * Content verbatim from wiki/migration/content-dumps/west-hollywood.md.
 */

import SectionHeader from '../shared/SectionHeader.astro';

export interface Props {
  number: string;
}

const { number } = Astro.props;

const luxuryBrands = [
  'Sub-Zero', 'Viking', 'Thermador', 'Wolf',
  'Miele', 'Bosch', 'Dacor', 'Fisher & Paykel',
];

const stats = [
  { num: '85%', label: 'First-visit fix rate' },
  { num: '90', label: 'Day warranty' },
  { num: '$89', label: 'Diagnostic fee' },
  { num: '4.6', label: 'Google rating' },
];
---

<section class="va-section va-section--black va-weho-luxury">
  <div class="va-container">
    <SectionHeader
      number={number}
      eyebrow="Luxury Appliance Specialists"
      headline="Sub-Zero, Thermador & Viking repair in"
      headlineAccent="West Hollywood"
      subheadline="WeHo has more Sub-Zeros per block than almost anywhere in LA. Our technicians see them constantly."
      white={true}
    />

    <div class="va-weho-luxury__grid">
      <div class="va-weho-luxury__copy">
        <p class="va-body va-body--white">
          WeHo has more Sub-Zeros per block than almost anywhere in LA. Our technicians see them
          constantly — in the penthouses off Sunset, the renovated Craftsman kitchens in West Hollywood
          Heights, the luxury condos near Robertson. These aren't appliances you call just anyone about.
          A Sub-Zero with a failed evaporator fan or a Thermador with a sticking gas valve needs someone
          who actually knows the machine.
        </p>
        <p class="va-body va-body--white">
          Our team is trained on these brands specifically — the dual-compressor architecture in Sub-Zero
          refrigerators, the Star burner system in Thermador cooktops, how Viking gas valves behave when
          they age. We carry OEM parts for these brands on every service vehicle. Most luxury appliance
          repairs we complete in one visit without ordering anything.
        </p>
        <p class="va-body va-body--white">
          One thing our technicians mention to almost every Sub-Zero owner in WeHo: condenser coil
          cleaning. In West Hollywood's dry, dusty climate, coil buildup is the single most common
          cause of early compressor failure we see. A quick coil cleaning during our service visit
          — or once a year on your own — can prevent a $600+ compressor repair down the road.
        </p>
        <ul class="va-weho-luxury__brands">
          {luxuryBrands.map((b) => (<li>{b}</li>))}
        </ul>
      </div>
      <div class="va-weho-luxury__stats">
        {stats.map((s) => (
          <div class="va-weho-luxury__stat">
            <div class="va-weho-luxury__stat-num va-fraunces">{s.num}</div>
            <div class="va-weho-luxury__stat-label">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .va-weho-luxury__grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 56px;
    align-items: start;
  }
  .va-weho-luxury__copy p { margin-bottom: 18px; }
  .va-weho-luxury__brands {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    list-style: none;
    margin: 24px 0 0;
    padding: 0;
  }
  .va-weho-luxury__brands li {
    padding: 8px 14px;
    border: 1px solid rgba(201, 169, 97, 0.4);
    border-radius: 999px;
    color: var(--va-gold);
    font-size: 13px;
    font-family: var(--va-font-body);
    letter-spacing: 0.02em;
  }
  .va-weho-luxury__stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: rgba(201, 169, 97, 0.2);
    border: 1px solid rgba(201, 169, 97, 0.2);
  }
  .va-weho-luxury__stat {
    background: var(--va-black);
    padding: 28px 22px;
    text-align: center;
  }
  .va-weho-luxury__stat-num {
    font-size: 44px;
    color: var(--va-gold);
    line-height: 1;
    font-weight: 400;
    margin-bottom: 8px;
    letter-spacing: -0.02em;
  }
  .va-weho-luxury__stat-label {
    font-family: var(--va-font-body);
    font-size: 12px;
    color: rgba(255, 255, 255, 0.7);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  @media (max-width: 900px) {
    .va-weho-luxury__grid { grid-template-columns: 1fr; gap: 32px; }
  }
</style>
