---
/**
 * Temecula — Branded Expertise block.
 * Wine Cooler / Wine Cellar specialty (EuroCave · Liebherr · Sub-Zero Wine
 * · Wine Enthusiast · Vinotemp · WhisperKOOL · CellarPro). Two-column layout:
 * prose + side card with common issues. Content verbatim from
 * wiki/migration/content-dumps/temecula.md and legacy src/pages/temecula.astro.
 */

import SectionHeader from '../shared/SectionHeader.astro';

export interface Props {
  number: string;
}

const { number } = Astro.props;

const wineBrands = [
  'EuroCave',
  'Liebherr',
  'Sub-Zero Wine Storage',
  'Wine Enthusiast',
  'Vinotemp',
  'U-Line',
  'Perlick',
  'Marvel',
  'True Residential',
  'Thermador',
  'WhisperKOOL',
  'CellarPro',
  'Breezaire',
  'Wine Guardian',
];

const commonIssues = [
  'Upper zone warm, lower zone fine (dual-zone failure)',
  'Compressor running constantly without cycling',
  'Temperature drift above 55°F set point',
  'Excessive ice buildup on evaporator',
  'Door seal degradation from UV exposure',
  'Cellar drifting 5°F+ above set point in summer',
  'Built-in unit installed without front venting',
  'Thermistor failure on independent zone circuit',
];
---

<section class="va-section va-section--cream va-temecula-wine">
  <div class="va-container">
    <SectionHeader
      number={number}
      eyebrow="Wine Country Specialty"
      headline="Wine cooler & wine cellar repair in"
      headlineAccent="Temecula"
      subheadline="Most appliance companies in Temecula treat wine coolers as just another refrigerator. They're not."
    />

    <div class="va-temecula-wine__grid">
      <div class="va-temecula-wine__copy">
        <p class="va-body">
          Temecula wine country means a lot of serious wine collections. We service more wine
          coolers and dedicated wine cellar units here than anywhere else in our coverage area.
          Nowhere else in our Southern California service area do we see this concentration of
          serious wine collections — dual-zone built-in coolers, freestanding wine refrigerators,
          and dedicated wine cellar cooling units that maintain 55°F year-round.
        </p>

        <h3 class="va-h3 va-temecula-wine__sub-title">Single-zone vs. dual-zone failures</h3>
        <p class="va-body">
          Single-zone wine coolers maintain one temperature throughout. When they fail, it's
          usually the compressor, thermostat, or condenser fan. Dual-zone units are more complex —
          they have two independent temperature circuits and can fail in one zone while the other
          operates normally. We've seen plenty of dual-zone units where the owner assumes total
          failure because the top section is warm, when in fact only the upper zone thermostat
          or thermistor has failed — a $150–$250 repair rather than a replacement.
        </p>
        <p class="va-body">
          The Temecula climate creates a specific challenge for wine coolers: the 30–40 degree
          daily temperature swings in summer put thermal stress on compressors that aren't
          present in coastal or stable-temperature environments. A wine cooler sitting in a home
          where the kitchen hits 85°F in the afternoon and cools to 68°F at night is cycling hard.
          Condenser coils should be cleaned every 4–6 months in wine country homes.
        </p>

        <h3 class="va-h3 va-temecula-wine__sub-title">Built-in vs. freestanding units</h3>
        <p class="va-body">
          Built-in wine coolers are designed to vent from the front — they can be installed flush
          in cabinetry. Freestanding units vent from the rear and need clearance. We regularly find
          freestanding units that have been built in without adequate clearance, forcing the
          compressor to run constantly and fail prematurely. If your wine cooler compressor runs
          without stopping, check the rear clearance before assuming the compressor is the problem.
        </p>

        <h3 class="va-h3 va-temecula-wine__sub-title">Wine cellar cooling systems</h3>
        <p class="va-body">
          Dedicated wine cellar cooling systems — split systems or self-contained through-wall
          units — are a step above wine coolers and require different diagnosis. We service
          WhisperKOOL, CellarPro, Breezaire, and Wine Guardian units. If your cellar temperature
          is drifting, the first checks are door seals, refrigerant level, and evaporator coil
          condition. A cellar that runs 5°F above set point in summer but holds temperature in
          winter almost always has a refrigerant issue or insufficient cooling capacity for the
          summer heat load.
        </p>

        <p class="va-body">
          We carry OEM parts for major brands and source through manufacturer channels for
          specialty units. We don't use aftermarket compressors or thermostat assemblies on
          wine coolers — precision temperature control requires the correct parts.
        </p>

        <ul class="va-temecula-wine__brands">
          {wineBrands.map((b) => (<li>{b}</li>))}
        </ul>
      </div>

      <aside class="va-temecula-wine__card">
        <h3 class="va-h3 va-temecula-wine__card-title">Common wine cooler & cellar issues we fix</h3>
        <ul class="va-temecula-wine__issues">
          {commonIssues.map((issue) => (
            <li>
              <span class="va-diamond" aria-hidden="true">◆</span>
              <span>{issue}</span>
            </li>
          ))}
        </ul>
      </aside>
    </div>
  </div>
</section>

<style>
  .va-temecula-wine__grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 48px;
    align-items: start;
  }
  .va-temecula-wine__copy p {
    margin: 0 0 18px;
    font-size: 17px;
    line-height: 1.75;
    color: var(--va-text);
  }
  .va-temecula-wine__sub-title {
    margin: 28px 0 12px;
    color: var(--va-text);
  }
  .va-temecula-wine__brands {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    list-style: none;
    margin: 24px 0 0;
    padding: 0;
  }
  .va-temecula-wine__brands li {
    padding: 8px 14px;
    border: 1px solid rgba(201, 169, 97, 0.5);
    border-radius: 999px;
    color: var(--va-gold);
    font-size: 13px;
    font-family: var(--va-font-body);
    letter-spacing: 0.02em;
    background: var(--va-white);
  }
  .va-temecula-wine__card {
    background: var(--va-white);
    border: 1px solid var(--va-border);
    border-radius: 4px;
    padding: 28px 26px;
    position: sticky;
    top: 24px;
  }
  .va-temecula-wine__card-title {
    margin: 0 0 18px;
    font-size: 20px;
    color: var(--va-text);
  }
  .va-temecula-wine__issues {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .va-temecula-wine__issues li {
    display: flex;
    align-items: baseline;
    gap: 10px;
    font-size: 15px;
    line-height: 1.55;
    color: var(--va-text);
    font-family: var(--va-font-body);
  }
  .va-temecula-wine__issues .va-diamond {
    color: var(--va-gold);
    font-size: 10px;
    flex-shrink: 0;
  }
  @media (max-width: 900px) {
    .va-temecula-wine__grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .va-temecula-wine__card { position: static; }
  }
</style>
