---
/**
 * Los Angeles — Branded Expertise block.
 * Wine Cellar Cooling Unit specialty (WhisperKool · CellarPro · Wine Guardian
 * · US Cellar Systems). Two-column layout: prose + side card with common
 * issues. Content verbatim from wiki/migration/content-dumps/los-angeles.md.
 */

import SectionHeader from '../shared/SectionHeader.astro';

export interface Props {
  number: string;
}

const { number } = Astro.props;

const wineBrands = [
  'WhisperKool',
  'CellarPro',
  'Wine Guardian',
  'US Cellar Systems',
  'WhisperKool SC',
  'CellarPro 8000VSx',
];

const commonIssues = [
  'Unit running but cellar temperature rising',
  'Excessive ice buildup on evaporator coils',
  'Unit cycling on/off every few minutes',
  'Loud compressor or fan noise',
  'Error codes on digital display',
  'Unit not turning on at all',
  'Temperature swings of 5°F or more',
  'Condensation forming inside the cellar',
];
---

<section class="va-section va-section--cream va-la-wine">
  <div class="va-container">
    <SectionHeader
      number={number}
      eyebrow="Specialty Service"
      headline="Wine cellar cooling unit repair —"
      headlineAccent="Los Angeles"
      subheadline="A specialty most appliance repair companies don't touch. We do."
    />

    <div class="va-la-wine__grid">
      <div class="va-la-wine__copy">
        <p class="va-body">
          Wine cellar cooling units are a specialty most appliance repair companies don't touch.
          We do. Homes throughout West LA, Brentwood, Hancock Park, and the hillside neighborhoods
          have WhisperKool, CellarPro, Wine Guardian, and US Cellar Systems units that require
          someone who actually knows the difference between a condenser fan failure and a
          refrigerant issue.
        </p>
        <p class="va-body">
          If your wine cellar isn't maintaining temperature, is icing over, running louder than
          usual, or cycling on and off too frequently — those are all diagnosable problems. We
          service through-wall, ductless split, and self-contained cooling units.
        </p>
        <ul class="va-la-wine__brands">
          {wineBrands.map((b) => (<li>{b}</li>))}
        </ul>
      </div>

      <aside class="va-la-wine__card">
        <h3 class="va-h3 va-la-wine__card-title">Common wine cellar cooling issues we fix</h3>
        <ul class="va-la-wine__issues">
          {commonIssues.map((issue) => (
            <li>
              <span class="va-diamond" aria-hidden="true">◆</span>
              <span>{issue}</span>
            </li>
          ))}
        </ul>
      </aside>
    </div>
  </div>
</section>

<style>
  .va-la-wine__grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 48px;
    align-items: start;
  }
  .va-la-wine__copy p {
    margin: 0 0 18px;
    font-size: 17px;
    line-height: 1.75;
    color: var(--va-text);
  }
  .va-la-wine__brands {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    list-style: none;
    margin: 24px 0 0;
    padding: 0;
  }
  .va-la-wine__brands li {
    padding: 8px 14px;
    border: 1px solid rgba(201, 169, 97, 0.5);
    border-radius: 999px;
    color: var(--va-gold);
    font-size: 13px;
    font-family: var(--va-font-body);
    letter-spacing: 0.02em;
    background: var(--va-white);
  }
  .va-la-wine__card {
    background: var(--va-white);
    border: 1px solid var(--va-border);
    border-radius: 4px;
    padding: 28px 26px;
  }
  .va-la-wine__card-title {
    margin: 0 0 18px;
    font-size: 20px;
    color: var(--va-text);
  }
  .va-la-wine__issues {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .va-la-wine__issues li {
    display: flex;
    align-items: baseline;
    gap: 10px;
    font-size: 15px;
    line-height: 1.55;
    color: var(--va-text);
    font-family: var(--va-font-body);
  }
  .va-la-wine__issues .va-diamond {
    color: var(--va-gold);
    font-size: 10px;
    flex-shrink: 0;
  }
  @media (max-width: 900px) {
    .va-la-wine__grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>
