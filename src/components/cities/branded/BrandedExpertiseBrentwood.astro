---
/**
 * Brentwood — Branded Expertise block.
 * Cove dishwasher specialty (Cove · Miele · Bosch · Thermador · KitchenAid +
 * Fisher & Paykel range). Two-column layout: prose + brand list with featured
 * Cove pill. Content verbatim from wiki/migration/content-dumps/brentwood.md
 * (.bw-cove block).
 */

import SectionHeader from '../shared/SectionHeader.astro';

export interface Props {
  number: string;
}

const { number } = Astro.props;

const dishwasherBrands = [
  { name: 'Cove (Fisher & Paykel)', featured: true },
  { name: 'Miele', featured: false },
  { name: 'Bosch', featured: false },
  { name: 'Thermador', featured: false },
  { name: 'KitchenAid', featured: false },
  { name: 'GE Monogram', featured: false },
  { name: 'Samsung', featured: false },
  { name: 'LG', featured: false },
];

const commonIssues = [
  'Cove drainage fault codes (most frequent call)',
  'Wash arm failure on the upper rack',
  'Control board communication errors on connected models',
  'Door seal replacement on older units',
  'Panel-ready disassembly without damaging custom front',
  'Sub-Zero built-in column condenser dust buildup',
  'Wolf dual-fuel oven igniter degradation',
  'Miele W1 motor brushes and hall sensor faults',
];
---

<section class="va-section va-section--black va-bw-cove">
  <div class="va-container">
    <SectionHeader
      number={number}
      eyebrow="Cove Dishwasher Specialists — Brentwood"
      headline="Cove dishwasher repair in"
      headlineAccent="Brentwood, CA"
      subheadline="Cove — Fisher &amp; Paykel's luxury line — has become a fixture in Brentwood remodels. Most repair companies have never worked on one. We have."
      white={true}
    />

    <div class="va-bw-cove__grid">
      <div class="va-bw-cove__copy">
        <p class="va-body va-body--white">
          Cove — Fisher &amp; Paykel's luxury dishwasher line — has become a common fixture in
          Brentwood kitchen remodels over the past several years. It's a premium product that most
          appliance repair companies in the area have never worked on. Our technicians have.
        </p>
        <p class="va-body va-body--white">
          Common Cove issues we see in Brentwood homes: drainage fault codes (the most frequent
          call), wash arm failures on the upper rack, control board communication errors on
          connected models, and door seal replacements on older units. The panel-ready installation
          typical in Brentwood kitchens requires careful disassembly — we don't damage the custom
          front panel or the surrounding cabinetry.
        </p>
        <p class="va-body va-body--white">
          We also service the full Fisher &amp; Paykel range, Miele, Bosch, Thermador, and
          KitchenAid dishwashers — the other brands you'll find here. Sub-Zero built-in columns,
          Wolf dual-fuel ranges, and Wolf steam ovens fill out the Brentwood luxury kitchen, and
          our technicians service all of them with OEM parts on every vehicle.
        </p>
        <ul class="va-bw-cove__brands">
          {dishwasherBrands.map((b) => (
            <li class={b.featured ? 'va-bw-cove__brand--featured' : ''}>{b.name}</li>
          ))}
        </ul>
      </div>

      <aside class="va-bw-cove__card">
        <h3 class="va-h3 va-bw-cove__card-title">Common Brentwood luxury issues we fix</h3>
        <ul class="va-bw-cove__issues">
          {commonIssues.map((issue) => (
            <li>
              <span class="va-diamond" aria-hidden="true">◆</span>
              <span>{issue}</span>
            </li>
          ))}
        </ul>
      </aside>
    </div>
  </div>
</section>

<style>
  .va-bw-cove__grid {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 56px;
    align-items: start;
  }
  .va-bw-cove__copy p { margin-bottom: 18px; }
  .va-bw-cove__brands {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    list-style: none;
    margin: 24px 0 0;
    padding: 0;
  }
  .va-bw-cove__brands li {
    padding: 8px 14px;
    border: 1px solid rgba(201, 169, 97, 0.4);
    border-radius: 999px;
    color: var(--va-gold);
    font-size: 13px;
    font-family: var(--va-font-body);
    letter-spacing: 0.02em;
  }
  .va-bw-cove__brand--featured {
    background: rgba(201, 169, 97, 0.15);
    border-color: var(--va-gold) !important;
    color: var(--va-white) !important;
    font-weight: 600;
  }
  .va-bw-cove__card {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(201, 169, 97, 0.25);
    border-radius: 4px;
    padding: 28px 26px;
  }
  .va-bw-cove__card-title {
    margin: 0 0 18px;
    font-size: 20px;
    color: var(--va-white);
  }
  .va-bw-cove__issues {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .va-bw-cove__issues li {
    display: flex;
    align-items: baseline;
    gap: 10px;
    font-size: 14px;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.85);
    font-family: var(--va-font-body);
  }
  .va-bw-cove__issues .va-diamond {
    color: var(--va-gold);
    font-size: 10px;
    flex-shrink: 0;
  }
  @media (max-width: 900px) {
    .va-bw-cove__grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }
</style>
