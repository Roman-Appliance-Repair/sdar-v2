---
/**
 * Pacific Palisades — Branded Expertise block.
 * La Cornue / Gaggenau / European luxury focus. 1fr 260px split with sticky CTA
 * card (different from WeHo grid; closer to PP's legacy `.pp-luxury` block).
 * Content verbatim from wiki/migration/content-dumps/pacific-palisades.md.
 */

import SectionHeader from '../shared/SectionHeader.astro';
import { BRANCHES } from '../../../data/branches.ts';

export interface Props {
  number: string;
}

const { number } = Astro.props;
const branch = BRANCHES.find((b) => b.slug === 'los-angeles')!;
const phone = branch.phone;
const phoneTel = `+1${phone.replace(/\D/g, '')}`;

const luxuryBrands = [
  { name: 'La Cornue', featured: true },
  { name: 'Gaggenau', featured: true },
  { name: 'Sub-Zero', featured: false },
  { name: 'Wolf', featured: false },
  { name: 'Miele', featured: false },
  { name: 'Thermador', featured: false },
  { name: 'Viking', featured: false },
  { name: 'GE Monogram', featured: false },
];
---

<section class="va-section va-section--black va-pp-luxury">
  <div class="va-container">
    <SectionHeader
      number={number}
      eyebrow="Rare Brands. Fully Covered."
      headline="La Cornue, Gaggenau &amp; European luxury repair in"
      headlineAccent="Pacific Palisades"
      subheadline="Most LA companies pause at La Cornue and Gaggenau. We service them — manufacturer-spec, OEM parts, no guesswork."
      white={true}
    />

    <div class="va-pp-luxury__grid">
      <div class="va-pp-luxury__copy">
        <p class="va-body va-body--white">
          Most appliance repair companies in Los Angeles will work on Sub-Zero and Wolf, hesitate
          at Thermador and Viking, and pause completely at La Cornue and Gaggenau. We service all
          of them. The Riviera, Huntington Palisades, Castellammare — these neighborhoods have
          European luxury appliances that require specific technical knowledge, OEM parts, and the
          discipline to follow the manufacturer's service procedure rather than improvising.
        </p>
        <p class="va-body va-body--white">
          La Cornue CornuFé and Château ranges have specific gas valves, oven door hinges, and
          ignition assemblies that are not interchangeable with Wolf or Thermador parts. Gaggenau
          steam combination ovens and Vario induction cooktops require trained diagnostics — the
          E3 and E4 fault codes, the descaling procedures, the water level sensor calibration are
          all manufacturer-specific. We carry OEM parts for these brands and follow the service
          procedure to the letter.
        </p>
        <p class="va-body va-body--white">
          Sub-Zero built-in columns, Wolf dual-fuel ranges, and Miele dishwashers and laundry
          systems round out the Palisades luxury kitchen. Our technicians service all of them
          regularly. Post-2025 fires, we've also been doing rebuild commissioning calls — new Wolf
          ranges with factory offsets that need field calibration, new Sub-Zero installations that
          need verification, full system checks before a homeowner moves back in.
        </p>
        <ul class="va-pp-luxury__brands">
          {luxuryBrands.map((b) => (
            <li class={b.featured ? 'va-pp-luxury__brand--featured' : ''}>{b.name}</li>
          ))}
        </ul>
      </div>

      <aside class="va-pp-luxury__cta">
        <div class="va-pp-luxury__cta-eyebrow va-eyebrow-gold">Luxury Appliance Not Working?</div>
        <p class="va-body va-body--muted-white">
          We service what other companies won't touch. La Cornue, Gaggenau, the rare European
          brands — we have the parts, the training, and the patience to do it right.
        </p>
        <a href={`tel:${phoneTel}`} class="va-btn-primary">Call {phone}</a>
        <p class="va-pp-luxury__fine">
          $89 diagnostic · Waived with repair · OEM parts only · 90-day warranty
        </p>
      </aside>
    </div>
  </div>
</section>

<style>
  .va-pp-luxury__grid {
    display: grid;
    grid-template-columns: 1fr 260px;
    gap: 56px;
    align-items: start;
  }
  .va-pp-luxury__copy p { margin-bottom: 18px; }
  .va-pp-luxury__brands {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    list-style: none;
    margin: 24px 0 0;
    padding: 0;
  }
  .va-pp-luxury__brands li {
    padding: 8px 14px;
    border: 1px solid rgba(201, 169, 97, 0.4);
    border-radius: 999px;
    color: var(--va-gold);
    font-size: 13px;
    font-family: var(--va-font-body);
    letter-spacing: 0.02em;
  }
  .va-pp-luxury__brand--featured {
    background: rgba(201, 169, 97, 0.18);
    border-color: var(--va-gold) !important;
    color: var(--va-white) !important;
    font-weight: 600;
  }
  .va-pp-luxury__cta {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(201, 169, 97, 0.25);
    border-radius: 4px;
    padding: 28px 24px;
    position: sticky;
    top: 96px;
  }
  .va-pp-luxury__cta-eyebrow { margin-bottom: 12px; }
  .va-pp-luxury__cta p {
    margin: 0 0 18px;
    font-size: 14px;
    line-height: 1.6;
  }
  .va-body--muted-white { color: rgba(255, 255, 255, 0.7); }
  .va-pp-luxury__cta .va-btn-primary {
    width: 100%;
    justify-content: center;
    margin-bottom: 14px;
  }
  .va-pp-luxury__fine {
    margin: 0;
    font-size: 11px;
    color: rgba(255, 255, 255, 0.5);
    text-align: center;
    letter-spacing: 0.02em;
  }
  @media (max-width: 900px) {
    .va-pp-luxury__grid { grid-template-columns: 1fr; gap: 32px; }
    .va-pp-luxury__cta { position: static; }
  }
</style>
