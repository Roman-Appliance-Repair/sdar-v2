---
/**
 * Sherman Oaks — Branded Expertise block.
 * UNIQUE 6-card brand detail grid (.so-brands) — each card has name + detail + note.
 * Content verbatim from wiki/migration/content-dumps/sherman-oaks.md.
 */

import SectionHeader from '../shared/SectionHeader.astro';

export interface Props {
  number: string;
}

const { number } = Astro.props;

interface BrandCard {
  name: string;
  detail: string;
  note: string;
  featured?: boolean;
}

const brandCards: BrandCard[] = [
  {
    name: 'Jenn-Air',
    detail: 'Column refrigerators · French door · Pro-style ranges · Panel-ready dishwashers · Built-in ovens.',
    note: 'Most-searched brand in Sherman Oaks. Control board failures, cooling issues, and ice maker problems are common in Jenn-Air column units. OEM Jenn-Air parts on every vehicle.',
    featured: true,
  },
  {
    name: 'Gaggenau',
    detail: 'Steam combination ovens · Vario cooktops · Column refrigeration · Dishwashers.',
    note: 'Gaggenau requires specific technical knowledge — particularly for the steam combi oven systems and Vario induction cooktops. We carry OEM Gaggenau parts and are trained on these systems.',
    featured: true,
  },
  {
    name: 'Sub-Zero · Wolf',
    detail: 'Built-in refrigeration · Pro ranges · Dual-fuel · Outdoor.',
    note: 'Standard in Sherman Oaks 91423 hillside kitchens. OEM parts, LADWP hard water inlet valve checks included on every Sub-Zero call.',
  },
  {
    name: 'Thermador',
    detail: 'Star burner ranges · Built-in refrigeration · Steam ovens.',
    note: 'Thermador star burner igniter failures common in heavily-used Valley kitchens. OEM parts on vehicle, full ignition module replacement available same day.',
  },
  {
    name: 'Bertazzoni',
    detail: 'Italian pro-style ranges · Electric &amp; gas · Dishwashers.',
    note: 'Increasingly common in Sherman Oaks renovations. Trained on Bertazzoni-specific ignition and control systems, including the sealed-burner moisture pattern.',
  },
  {
    name: 'All Standard Brands',
    detail: 'Samsung · LG · GE · Whirlpool · Bosch · KitchenAid · Maytag.',
    note: "Valley floor homes and condos — same same-day commitment, same $89 diagnostic waived with repair, same 90-day warranty as the luxury calls.",
  },
];
---

<section class="va-section va-section--black va-so-brands">
  <div class="va-container">
    <SectionHeader
      number={number}
      eyebrow="Sherman Oaks Luxury Brands"
      headline="Sherman Oaks luxury brands —"
      headlineAccent="we know these systems"
      subheadline="The 91423 hillside homes search for these brands specifically. So do we."
      white={true}
    />

    <div class="va-so-brands__grid">
      {brandCards.map((card) => (
        <article class={`va-so-brands__card ${card.featured ? 'va-so-brands__card--featured' : ''}`}>
          <h3 class="va-h3 va-so-brands__card-name">{card.name}</h3>
          <p class="va-so-brands__card-detail" set:html={card.detail}></p>
          <p class="va-so-brands__card-note">{card.note}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .va-so-brands__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 20px;
  }
  .va-so-brands__card {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(201, 169, 97, 0.22);
    border-radius: 4px;
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .va-so-brands__card--featured {
    background: rgba(201, 169, 97, 0.08);
    border-color: var(--va-gold);
  }
  .va-so-brands__card-name {
    margin: 0;
    font-size: 22px;
    color: var(--va-gold);
    letter-spacing: -0.01em;
  }
  .va-so-brands__card-detail {
    margin: 0;
    font-size: 14px;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.9);
    font-family: var(--va-font-body);
    letter-spacing: 0.01em;
  }
  .va-so-brands__card-note {
    margin: 0;
    font-size: 13px;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.65);
    font-family: var(--va-font-body);
  }
  @media (max-width: 900px) {
    .va-so-brands__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 560px) {
    .va-so-brands__grid { grid-template-columns: 1fr; }
  }
</style>
