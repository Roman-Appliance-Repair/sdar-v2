---
/**
 * Variant A — How We Work / Method block.
 * Hardcoded shared methodology — identical across all 87 cities.
 * 4 numbered steps with Fraunces titles.
 */

import SectionHeader from './SectionHeader.astro';

export interface Props {
  number: string;
}

const { number } = Astro.props;

const steps = [
  {
    n: '1',
    title: 'You call. A real person picks up.',
    body: 'No call center, no third-party dispatcher. The phone reaches the team that runs your branch. We tell you a real arrival window — usually a 2-hour block, not a 6-hour one — and we show up in it.',
  },
  {
    n: '2',
    title: 'Diagnostic, then written estimate — before any work.',
    body: 'The $89 diagnostic covers a full inspection of the appliance. You get a written estimate with parts and labor itemized before we start. The $89 is credited toward the repair if you proceed.',
  },
  {
    n: '3',
    title: 'OEM parts. On the truck for the most common repairs.',
    body: 'We stock manufacturer-original parts for the brands we see most often in your area. The majority of repairs are completed in a single visit — no parts order, no second appointment, no wait.',
  },
  {
    n: '4',
    title: '90-day warranty. Same issue returns, we come back free.',
    body: 'Every repair is covered for 90 days on parts and labor. If the same problem recurs, we return at no charge. CSLB Licensed #1138898, BBB A+, fully insured.',
  },
];
---

<section class="va-section va-section--cream va-method">
  <div class="va-container">
    <SectionHeader
      number={number}
      eyebrow="How We Work"
      headline="How a repair actually goes —"
      headlineAccent="from call to close"
      subheadline="No mystery, no surprises. Same process whether you're in West Hollywood, San Clemente, or anywhere in between."
    />
    <ol class="va-method__steps">
      {steps.map((s) => (
        <li class="va-method__step">
          <span class="va-method__num va-fraunces">{s.n}</span>
          <div class="va-method__body">
            <h3 class="va-h3 va-method__title">{s.title}</h3>
            <p class="va-body va-body--muted">{s.body}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .va-method__steps {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 32px 48px;
  }
  .va-method__step {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 24px;
    align-items: start;
  }
  .va-method__num {
    font-size: 56px;
    line-height: 1;
    color: var(--va-gold);
    font-weight: 400;
    font-style: italic;
    min-width: 56px;
  }
  .va-method__title {
    margin: 0 0 8px;
    font-size: 20px;
  }
  .va-method__body p { margin: 0; font-size: 15px; line-height: 1.65; }
  @media (max-width: 900px) {
    .va-method__steps { grid-template-columns: 1fr; gap: 32px; }
  }
</style>
