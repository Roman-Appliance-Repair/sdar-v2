---
/**
 * Variant A — Nearby cities links block.
 * Cream pill buttons. SEO-relevant cross-linking between adjacent city pages.
 */

export interface NearbyLink {
  slug: string;
  name: string;
  /** Set to true to render even though target page does not exist (anchor stays
   *  for legacy SEO). Avoid using — broken links should be cleaned up at source. */
  brokenAllowed?: boolean;
}

export interface Props {
  links: NearbyLink[];
  headline?: string;
}

const {
  links,
  headline = 'Also Serving Nearby',
} = Astro.props;
---

<section class="va-section va-section--white va-nearby">
  <div class="va-container">
    <h2 class="va-nearby__title">{headline}</h2>
    <ul class="va-nearby__list">
      {links.map((l) => (
        <li>
          <a href={`/${l.slug}/`}>
            Appliance Repair {l.name}
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <path d="M5 12h14M13 6l6 6-6 6"/>
            </svg>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .va-nearby {
    padding: 56px 0;
    border-top: 1px solid var(--va-border);
  }
  .va-nearby__title {
    font-family: var(--va-font-body);
    font-size: 12px;
    font-weight: 600;
    color: var(--va-gold);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin: 0 0 22px;
  }
  .va-nearby__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .va-nearby__list a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 18px;
    border: 1px solid var(--va-border);
    border-radius: 999px;
    color: var(--va-text);
    text-decoration: none;
    font-size: 14px;
    font-family: var(--va-font-body);
    transition: border-color 0.18s, color 0.18s;
  }
  .va-nearby__list a:hover {
    border-color: var(--va-gold);
    color: var(--va-red);
    text-decoration: none;
  }
</style>
