---
/**
 * Variant A — Two-Neighborhoods detail block.
 * Renders 2 featured neighborhoods as side-by-side cards with descriptions.
 * Used as the head of NeighborhoodGrid when mode="featured".
 */

import type { Neighborhood } from './NeighborhoodGrid.astro';

export interface Props {
  neighborhoods: Neighborhood[];
}

const { neighborhoods } = Astro.props;
---

<div class="va-twonh">
  {neighborhoods.map((n, i) => (
    <article class="va-twonh__card">
      <div class="va-twonh__num va-fraunces">{`0${i + 1}`}</div>
      <h3 class="va-h3 va-twonh__name">
        {n.name}
        {n.zip && <span class="va-twonh__zip">{n.zip}</span>}
      </h3>
      {n.description && <p class="va-body va-body--muted va-twonh__desc">{n.description}</p>}
    </article>
  ))}
</div>

<style>
  .va-twonh {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    margin-bottom: 32px;
  }
  .va-twonh__card {
    background: var(--va-white);
    border: 1px solid var(--va-border);
    border-radius: 4px;
    padding: 32px 28px;
    position: relative;
  }
  .va-twonh__num {
    position: absolute;
    top: 18px;
    right: 22px;
    font-size: 32px;
    color: var(--va-gold);
    opacity: 0.4;
    line-height: 1;
  }
  .va-twonh__name {
    margin: 0 0 12px;
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 10px;
  }
  .va-twonh__zip {
    font-family: var(--va-font-body);
    font-size: 13px;
    font-weight: 600;
    color: var(--va-gold);
    letter-spacing: 0.04em;
  }
  .va-twonh__desc {
    margin: 0;
    font-size: 16px;
    line-height: 1.65;
  }
  @media (max-width: 768px) {
    .va-twonh { grid-template-columns: 1fr; }
  }
</style>
