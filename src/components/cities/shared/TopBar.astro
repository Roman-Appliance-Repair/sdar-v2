---
/**
 * Variant A — Sticky red TopBar with branch phone CTA.
 * Phone is read from branches.ts via branchSlug. NEVER hardcode phone here.
 */

import { BRANCHES, MAIN_PHONE, isPlaceholderPhone } from '../../../data/branches.ts';

export interface Props {
  branchSlug: string;
}

const { branchSlug } = Astro.props;

const branch = BRANCHES.find((b) => b.slug === branchSlug);
if (!branch) {
  throw new Error(`TopBar: unknown branchSlug "${branchSlug}". Update branches.ts citiesServed or fix the city page.`);
}

// Pending branches (Rancho Cucamonga, Temecula) carry 555-prefixed placeholders.
// Per NAP policy, do NOT show placeholders in primary CTAs — fall back to MAIN_PHONE
// (LA branch). When real DIDs are assigned, branches.ts updates and the city pages
// auto-correct on next build.
const phone = isPlaceholderPhone(branch.phone) ? MAIN_PHONE : branch.phone;
const phoneTel = `+1${phone.replace(/\D/g, '')}`;
---

<div class="va-topbar">
  <div class="va-container va-topbar__inner">
    <a href="/" class="va-topbar__logo" aria-label="Same Day Appliance Repair — home">
      <span class="va-topbar__logo-ring" aria-hidden="true"></span>
      <span class="va-topbar__logo-text">Same Day <em>Appliance Repair</em></span>
    </a>
    <nav class="va-topbar__nav" aria-label="Primary">
      <a href="/services/">Services</a>
      <a href="/brands/">Brands</a>
      <a href="/areas/">Service Areas</a>
      <a href="/pricing/">Pricing</a>
    </nav>
    <a href={`tel:${phoneTel}`} class="va-topbar__phone">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.29h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
      </svg>
      <span>{phone}</span>
    </a>
  </div>
</div>

<style>
  .va-topbar {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--va-red);
    color: var(--va-white);
  }
  .va-topbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 14px;
    padding-bottom: 14px;
    gap: 32px;
  }
  .va-topbar__logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--va-white);
    text-decoration: none;
    font-family: var(--va-font-display);
    font-weight: 500;
    font-size: 18px;
    letter-spacing: -0.01em;
  }
  .va-topbar__logo:hover { text-decoration: none; }
  .va-topbar__logo-ring {
    width: 14px;
    height: 14px;
    border: 2px solid var(--va-white);
    border-radius: 50%;
    display: inline-block;
  }
  .va-topbar__logo-text em {
    font-style: italic;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.85);
  }
  .va-topbar__nav {
    display: flex;
    gap: 28px;
    flex: 1;
    justify-content: center;
  }
  .va-topbar__nav a {
    color: rgba(255, 255, 255, 0.92);
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.02em;
  }
  .va-topbar__nav a:hover { color: var(--va-white); text-decoration: underline; }
  .va-topbar__phone {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--va-white);
    background: rgba(0, 0, 0, 0.18);
    padding: 8px 16px;
    border-radius: 4px;
    font-weight: 600;
    font-size: 15px;
    text-decoration: none;
    letter-spacing: 0.02em;
  }
  .va-topbar__phone:hover { background: rgba(0, 0, 0, 0.32); text-decoration: none; }

  @media (max-width: 900px) {
    .va-topbar__nav { display: none; }
  }
  @media (max-width: 480px) {
    .va-topbar__inner { gap: 12px; }
    .va-topbar__logo-text em { display: none; }
  }
</style>
