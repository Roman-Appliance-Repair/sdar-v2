---
/**
 * Variant A — Trust bar (4 items, diamond separators, gold accents on black).
 *
 * NAP & Rating Policy SSOT compliance (wiki/decisions/nap-rating-policy-ssot.md):
 *   - NO numerical aggregate ratings (no "4.6 · 37 reviews")
 *   - Only qualitative trust signals until GMB API integration
 *   - Items 1+2 are years-in-business + license; items 3+4 commonly customizable
 */

export interface Props {
  licenseText?: string;
  yearsInBusiness?: number;
  /** Override item-3 text (defaults to "Same-Day Service"). */
  item3Text?: string;
  /** Override item-3 fine label (defaults to "Most calls before noon"). */
  item3Fine?: string;
  /** Override item-4 text (defaults to "90-Day Warranty"). */
  item4Text?: string;
  /** Override item-4 fine label (defaults to "Parts & labor"). */
  item4Fine?: string;
}

const {
  licenseText = 'CA CSLB #1138898',
  yearsInBusiness = 12,
  item3Text = 'Same-Day Service',
  item3Fine = 'Most calls before noon',
  item4Text = '90-Day Warranty',
  item4Fine = 'Parts & labor',
} = Astro.props;
---

<section class="va-trustbar">
  <div class="va-container va-trustbar__inner">
    <div class="va-trustbar__item">
      <span class="va-trustbar__num va-fraunces">{yearsInBusiness}</span>
      <span class="va-trustbar__label">Years serving Southern California</span>
    </div>
    <span class="va-diamond" aria-hidden="true">◆</span>
    <div class="va-trustbar__item">
      <span class="va-trustbar__label-strong">Licensed &amp; Insured</span>
      <span class="va-trustbar__label-fine">{licenseText}</span>
    </div>
    <span class="va-diamond" aria-hidden="true">◆</span>
    <div class="va-trustbar__item">
      <span class="va-trustbar__label-strong">{item3Text}</span>
      <span class="va-trustbar__label-fine">{item3Fine}</span>
    </div>
    <span class="va-diamond" aria-hidden="true">◆</span>
    <div class="va-trustbar__item">
      <span class="va-trustbar__label-strong">{item4Text}</span>
      <span class="va-trustbar__label-fine">{item4Fine}</span>
    </div>
  </div>
</section>

<style>
  .va-trustbar {
    background: var(--va-black);
    color: var(--va-white);
    padding: 18px 0;
    border-top: 1px solid rgba(201, 169, 97, 0.18);
    border-bottom: 1px solid rgba(201, 169, 97, 0.18);
  }
  .va-trustbar__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 8px 16px;
  }
  .va-trustbar__item {
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
    font-family: var(--va-font-body);
    font-size: 13px;
    color: rgba(255, 255, 255, 0.92);
  }
  .va-trustbar__num {
    font-size: 20px;
    font-weight: 500;
    color: var(--va-gold);
  }
  .va-trustbar__label {
    color: rgba(255, 255, 255, 0.78);
    letter-spacing: 0.01em;
  }
  .va-trustbar__label-strong {
    color: var(--va-white);
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  .va-trustbar__label-fine {
    color: rgba(255, 255, 255, 0.55);
    font-size: 12px;
    margin-left: 6px;
  }
  .va-trustbar .va-diamond {
    color: var(--va-gold);
    opacity: 0.55;
  }
  @media (max-width: 700px) {
    .va-trustbar__inner { gap: 6px 12px; }
    .va-trustbar__label-fine { display: none; }
    .va-trustbar .va-diamond { display: none; }
  }
</style>
