---
/** v2 WhyCallsUsBack — 4 reasons grid. */

export interface Reason { iconKey: 'clock' | 'parts' | 'shield' | 'team'; title: string; body: string; }
export interface Props {
  cityName: string;
  reasons: Reason[];
  /** Optional override of the default H2 ("Why {cityName} Calls Us Back"). */
  headline?: string;
}

const { cityName, reasons, headline } = Astro.props;
const finalHeadline = headline ?? `Why ${cityName} Calls Us Back`;

const ICONS: Record<Reason['iconKey'], string> = {
  clock: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>',
  parts: '<path d="M14.5 10c-.83 0-1.5-.67-1.5-1.5v-5c0-.83.67-1.5 1.5-1.5s1.5.67 1.5 1.5v5c0 .83-.67 1.5-1.5 1.5z"/><path d="M9.5 14c.83 0 1.5.67 1.5 1.5v5c0 .83-.67 1.5-1.5 1.5S8 21.33 8 20.5v-5c0-.83.67-1.5 1.5-1.5z"/><path d="M14 14.5c0-.83.67-1.5 1.5-1.5h5c.83 0 1.5.67 1.5 1.5s-.67 1.5-1.5 1.5h-5c-.83 0-1.5-.67-1.5-1.5z"/><path d="M10 9.5C10 8.67 9.33 8 8.5 8h-5C2.67 8 2 8.67 2 9.5S2.67 11 3.5 11h5c.83 0 1.5-.67 1.5-1.5z"/>',
  shield: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  team: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>'
};
---

<section class="v2-why">
  <div class="v2-container">
    <h2 class="v2-section-title">{finalHeadline}</h2>
    <div class="v2-why__grid">
      {reasons.map((r) => (
        <div class="v2-why__card">
          <div class="v2-why__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" set:html={ICONS[r.iconKey]} />
          </div>
          <div class="v2-why__title">{r.title}</div>
          <p class="v2-why__body" set:html={r.body}></p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .v2-why { padding: 72px 0; background: var(--v2-white); }
  .v2-section-title {
    font-family: var(--v2-font-display);
    font-size: 30px; font-weight: 700; color: var(--v2-black);
    margin: 0 0 40px; text-align: center;
  }
  .v2-why__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
  }
  .v2-why__card {
    background: var(--v2-gray);
    border-radius: 12px;
    padding: 28px 24px;
    font-family: var(--v2-font-body);
  }
  .v2-why__icon {
    width: 48px; height: 48px;
    background: var(--v2-red); color: var(--v2-white);
    border-radius: 10px;
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 16px;
  }
  .v2-why__title { font-size: 16px; font-weight: 600; color: var(--v2-black); margin-bottom: 10px; }
  .v2-why__body { font-size: 14px; color: var(--v2-muted); line-height: 1.6; margin: 0; }
  @media (max-width: 1024px) { .v2-why__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) { .v2-why__grid { grid-template-columns: 1fr; } }
</style>
