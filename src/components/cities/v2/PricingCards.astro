---
/** v2 PricingCards — 6 residential price tiers + footnote.
 *  RESIDENTIAL ONLY. No $120 commercial tier. */

export interface PriceTier { appliance: string; range: string; note: string; featured?: boolean; }

export interface Props {
  cityName: string;
  tiers: PriceTier[];
  /** Optional override of the default H2 ("Appliance Repair Costs in {cityName}"). */
  headline?: string;
  /** Optional override of the default subheadline. */
  subhead?: string;
  /** Optional luxury-brand footnote. Default is the WeHo wording; pass empty string
   *  or false to omit. */
  footnote?: string | false;
}

const {
  cityName,
  tiers,
  headline,
  subhead,
  footnote = "Sub-Zero, Thermador, Viking, Miele and other luxury brands may cost more due to OEM part pricing. We'll always tell you upfront. No work starts without your written approval.",
} = Astro.props;
const finalHeadline = headline ?? `Appliance Repair Costs in ${cityName}`;
const finalSub = subhead ?? 'Honest estimates. Written before we start. Diagnostic fee $89 — waived with repair.';
---

<section class="v2-pricing">
  <div class="v2-container">
    <h2 class="v2-section-title">{finalHeadline}</h2>
    <p class="v2-section-sub">{finalSub}</p>
    <div class="v2-pricing__grid">
      {tiers.map((t) => (
        <div class={`v2-pricing__card ${t.featured ? 'v2-pricing__card--featured' : ''}`}>
          <div class="v2-pricing__appliance">{t.appliance}</div>
          <div class="v2-pricing__range">{t.range}</div>
          <div class="v2-pricing__note">{t.note}</div>
        </div>
      ))}
    </div>
    {footnote && <p class="v2-pricing__footnote">{footnote}</p>}
  </div>
</section>

<style>
  .v2-pricing { padding: 72px 0; background: var(--v2-white); }
  .v2-section-title {
    font-family: var(--v2-font-display);
    font-size: 30px; font-weight: 700; color: var(--v2-black);
    margin: 0 0 8px; text-align: center;
  }
  .v2-section-sub {
    font-size: 16px; color: var(--v2-muted); text-align: center;
    margin: 0 0 40px; font-family: var(--v2-font-body);
  }
  .v2-pricing__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    max-width: 1000px;
    margin: 0 auto;
  }
  .v2-pricing__card {
    background: var(--v2-gray);
    border: 1px solid var(--v2-border);
    border-radius: 10px;
    padding: 22px 20px;
    text-align: center;
    font-family: var(--v2-font-body);
  }
  .v2-pricing__card--featured {
    background: var(--v2-black);
    color: var(--v2-white);
    border-color: var(--v2-red);
  }
  .v2-pricing__appliance { font-size: 13px; color: var(--v2-muted); text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 8px; font-weight: 600; }
  .v2-pricing__card--featured .v2-pricing__appliance { color: rgba(255,255,255,0.7); }
  .v2-pricing__range {
    font-family: var(--v2-font-display);
    font-size: 24px; font-weight: 700;
    color: var(--v2-black);
    margin-bottom: 8px;
  }
  .v2-pricing__card--featured .v2-pricing__range { color: var(--v2-red); }
  .v2-pricing__note { font-size: 13px; color: var(--v2-muted); line-height: 1.5; }
  .v2-pricing__card--featured .v2-pricing__note { color: rgba(255,255,255,0.7); }
  .v2-pricing__footnote {
    margin: 32px auto 0;
    max-width: 720px;
    font-size: 14px;
    color: var(--v2-muted);
    text-align: center;
    line-height: 1.6;
    font-family: var(--v2-font-body);
  }
  @media (max-width: 768px) { .v2-pricing__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 480px) { .v2-pricing__grid { grid-template-columns: 1fr; } }
</style>
