---
/** v2 NeighborhoodPhoto — Photo slot 2 (between Intro and Services). */

export interface Props { citySlug: string; cityName: string; }
const { citySlug, cityName } = Astro.props;

const photoSrc = `/images/cities/${citySlug}/neighborhood.webp`;
const alt = `${cityName} neighborhood landmark — appliance repair service area`;
---

<section class="v2-nhphoto">
  <div class="v2-container">
    <div class="v2-photo-slot v2-nhphoto__slot">
      <picture>
        <source srcset={photoSrc} type="image/webp" />
        <img src={photoSrc} alt={alt} width="1200" height="500" loading="lazy" onerror="this.style.display='none'" />
      </picture>
      <svg class="v2-photo-slot__icon" viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path d="M8 48 L32 24 L56 48 Z M16 48 V32 H24 V48 M40 48 V32 H48 V48"/>
      </svg>
    </div>
  </div>
</section>

<style>
  .v2-nhphoto { padding: 0 0 72px; background: var(--v2-white); }
  .v2-nhphoto__slot { aspect-ratio: 21 / 9; max-height: 500px; }
</style>
