---
/** v2 AlsoServingNearby — horizontal pill links to nearby cities. */

export interface NearbyCity { name: string; slug: string; }
export interface Props { nearbyCities: NearbyCity[]; }

const { nearbyCities } = Astro.props;
---

<section class="v2-nearby">
  <div class="v2-container">
    <h2 class="v2-nearby__title">Also Serving Nearby Areas</h2>
    <div class="v2-nearby__grid">
      {nearbyCities.map((c) => (
        <a href={`/${c.slug}/`} class="v2-nearby__link">{c.name}</a>
      ))}
    </div>
  </div>
</section>

<style>
  .v2-nearby { padding: 48px 0; background: var(--v2-white); border-top: 1px solid var(--v2-border); }
  .v2-nearby__title {
    font-family: var(--v2-font-display);
    font-size: 20px;
    font-weight: 600;
    color: var(--v2-black);
    margin: 0 0 20px;
    text-align: center;
  }
  .v2-nearby__grid {
    display: flex; gap: 10px; justify-content: center; flex-wrap: wrap;
  }
  .v2-nearby__link {
    padding: 8px 20px;
    border: 1px solid var(--v2-border);
    border-radius: 20px;
    font-size: 14px;
    color: var(--v2-text);
    text-decoration: none;
    font-family: var(--v2-font-body);
    transition: border-color 0.2s, color 0.2s;
  }
  .v2-nearby__link:hover { border-color: var(--v2-red); color: var(--v2-red); }
</style>
