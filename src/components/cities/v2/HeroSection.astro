---
/** v2 HeroSection — Full-bleed photo background + frosted glass panel left.
 *  Photo fallback chain: city → tier-default → universal → gradient.
 *  Phone always pulled from branches.ts via cityBranch lookup. */

import { CITIES } from '../../../data/cities';
import { BRANCHES, MAIN_PHONE, isPlaceholderPhone } from '../../../data/branches';

export interface Props {
  citySlug: string;
  headlineTop: string;
  headlineCity: string;
  subheadline: string;
  zips: string[];
  heroPhoto?: string;
  tier?: 1 | 2 | 3;
}

const {
  citySlug,
  headlineTop,
  headlineCity,
  subheadline,
  zips,
  heroPhoto,
  tier = 2
} = Astro.props;

const city = CITIES.find((c) => c.slug === citySlug);
if (!city) throw new Error(`HeroSection: unknown citySlug "${citySlug}". Add to cities.ts.`);
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;
const rawPhone = branch.phone;
const phone = rawPhone;
const phoneTel = `+1${phone.replace(/\D/g, '')}`;

// Photo fallback chain
const photoSrc = heroPhoto
  ?? `/images/cities/${citySlug}/hero.webp`;
const photoAlt = `Appliance repair technician in ${city.name}, CA kitchen`;

const eyebrow = `${city.name}, CA · ${zips.join(' · ')}`;
---

<section class="v2-hero">
  <div class="v2-hero__bg">
    <picture>
      <source srcset={photoSrc} type="image/webp" />
      <img
        src={photoSrc}
        alt={photoAlt}
        width="1920"
        height="900"
        loading="eager"
        fetchpriority="high"
        onerror="this.style.display='none'"
      />
    </picture>
    <div class="v2-hero__overlay"></div>
  </div>

  <div class="v2-container v2-hero__inner">
    <div class="v2-glass v2-hero__panel">
      <div class="v2-hero__eyebrow">{eyebrow}</div>
      <h1 class="v2-hero__h1">
        {headlineTop}<br>
        <span class="v2-hero__accent">{headlineCity}</span>
      </h1>
      <p class="v2-hero__sub">{subheadline}</p>
      <div class="v2-hero__ctas">
        <a href={`tel:${phoneTel}`} class="v2-btn-primary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.29h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
          </svg>
          Call {phone}
        </a>
        <a href="/book/" class="v2-btn-secondary">Book Online</a>
      </div>
    </div>
  </div>
</section>

<style>
  .v2-hero {
    position: relative;
    min-height: 580px;
    background: var(--v2-black);
    color: var(--v2-white);
    display: flex;
    align-items: center;
    overflow: hidden;
  }
  .v2-hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .v2-hero__bg picture, .v2-hero__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .v2-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(0,0,0,0.78) 0%, rgba(0,0,0,0.55) 60%, rgba(0,0,0,0.35) 100%);
    z-index: 1;
  }
  .v2-hero__inner {
    position: relative;
    z-index: 2;
    width: 100%;
    padding-top: 80px;
    padding-bottom: 80px;
  }
  .v2-hero__panel {
    max-width: 620px;
    padding: 40px 36px;
    color: var(--v2-white);
  }
  .v2-hero__eyebrow {
    font-size: 13px;
    font-weight: 500;
    color: var(--v2-red);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 18px;
  }
  .v2-hero__h1 {
    font-family: var(--v2-font-display);
    font-size: clamp(36px, 5vw, 52px);
    font-weight: 700;
    line-height: 1.1;
    margin: 0 0 20px;
    color: var(--v2-white);
  }
  .v2-hero__accent { color: var(--v2-red); }
  .v2-hero__sub {
    font-size: 17px;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.85);
    margin: 0 0 28px;
  }
  .v2-hero__ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 22px;
  }
  @media (max-width: 768px) {
    .v2-hero__panel { padding: 28px 22px; }
    .v2-hero__inner { padding-top: 56px; padding-bottom: 56px; }
  }
</style>
