---
/** v2 TrustBadgesRow — 5 trust badges below Hero. */

export interface Badge { label: string; icon: 'clock' | 'shield' | 'check' | 'lock' | 'star'; }
export interface Props { badges?: Badge[]; }

const defaultBadges: Badge[] = [
  { label: 'Same-Day Service', icon: 'clock' },
  { label: '90-Day Warranty', icon: 'shield' },
  { label: 'OEM Parts', icon: 'check' },
  { label: 'Licensed & Insured', icon: 'lock' },
  { label: '85% First-Visit Fix Rate', icon: 'star' },
];
const { badges = defaultBadges } = Astro.props;

const ICONS: Record<Badge['icon'], string> = {
  clock: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>',
  shield: '<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>',
  check: '<polyline points="20 6 9 17 4 12"/>',
  lock: '<rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>',
  star: '<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>',
};
---

<section class="v2-trust">
  <div class="v2-container v2-trust__inner">
    {badges.map((b) => (
      <div class="v2-trust__item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" set:html={ICONS[b.icon]} />
        <span>{b.label}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .v2-trust { background: var(--v2-red); color: var(--v2-white); padding: 16px 0; }
  .v2-trust__inner {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }
  .v2-trust__item {
    display: flex; align-items: center; gap: 8px;
    font-size: 14px; font-weight: 500;
    font-family: var(--v2-font-body);
  }
  @media (max-width: 768px) { .v2-trust__inner { justify-content: center; } }
</style>
