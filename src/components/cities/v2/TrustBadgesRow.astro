---
/** v2 TrustBadgesRow — 5 trust badges below Hero. T13: emoji prefixes + BBB Accredited as 5th. */

export interface Badge { label: string; emoji: string; }
export interface Props { badges?: Badge[]; }

const defaultBadges: Badge[] = [
  { emoji: '⚡', label: 'Same-Day Service' },
  { emoji: '🛡️', label: '90-Day Warranty' },
  { emoji: '🔧', label: 'OEM Parts' },
  { emoji: '✅', label: 'Licensed & Insured' },
  { emoji: '🏅', label: 'BBB Accredited' },
];
const { badges = defaultBadges } = Astro.props;
---

<section class="v2-trust">
  <div class="v2-container v2-trust__inner">
    {badges.map((b) => (
      <div class="v2-trust__item">
        <span class="v2-trust__emoji" aria-hidden="true">{b.emoji}</span>
        <span>{b.label}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .v2-trust { background: var(--v2-red); color: var(--v2-white); padding: 16px 0; }
  .v2-trust__inner {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }
  .v2-trust__item {
    display: flex; align-items: center; gap: 8px;
    font-size: 14px; font-weight: 500;
    font-family: var(--v2-font-body);
  }
  .v2-trust__emoji { font-size: 16px; line-height: 1; }
  @media (max-width: 768px) { .v2-trust__inner { justify-content: center; } }
</style>
