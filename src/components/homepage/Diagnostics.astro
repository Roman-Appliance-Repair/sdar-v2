---
// Diagnostics.astro — AI Diagnostic teaser section
//
// Step 6: replaces the Step 3 scaffold with a 2-column promotional teaser.
// LEFT column: pitch text + 4 bullets + CTA to /ai-diagnostic/.
// RIGHT column: CSS-only mockup of the widget interface (decorative, aria-hidden).
// Full interactive widget is post-launch — this section just teases it.

interface Props {}
---

<section class="diagnostics-section" id="diagnostics">
  <div class="container">

    <header class="section-header-simple">
      <h2 class="section-title">
        Free <span class="text-gold">AI Diagnostic</span>
      </h2>
      <p class="section-subtitle">
        Get a likely-cause diagnosis and ballpark cost estimate before you schedule a visit
      </p>
    </header>

    <div class="diag-grid">

      <!-- LEFT: pitch -->
      <div class="diag-pitch">
        <div class="diag-eyebrow">
          <span class="diag-ai-badge">AI</span>
          Powered by repair pattern analysis
        </div>

        <h3 class="diag-pitch-title">
          Describe the problem.<br>
          Get an answer in 30 seconds.
        </h3>

        <p class="diag-pitch-desc">
          Our AI cross-references your symptoms against thousands of real repair
          cases to give you a likely-cause diagnosis, recommended fix, and
          ballpark cost estimate — all before you commit to a service visit.
        </p>

        <ul class="diag-bullets">
          <li>
            <span class="diag-bullet-icon" aria-hidden="true">◆</span>
            <span><strong>Select your appliance</strong> — describe the problem, get instant diagnosis</span>
          </li>
          <li>
            <span class="diag-bullet-icon" aria-hidden="true">◆</span>
            <span><strong>Cross-referenced</strong> against 50,000+ documented repair patterns</span>
          </li>
          <li>
            <span class="diag-bullet-icon" aria-hidden="true">◆</span>
            <span><strong>Free preliminary estimate</strong>, technician checklist, downloadable PDF report</span>
          </li>
          <li>
            <span class="diag-bullet-icon" aria-hidden="true">◆</span>
            <span><strong>No email or phone required</strong> to get started</span>
          </li>
        </ul>

        <a href="/ai-diagnostic/" class="diag-cta-primary">
          Try Free AI Diagnostic
          <span class="diag-cta-arrow" aria-hidden="true">→</span>
        </a>

        <div class="diag-disclaimer">
          Preliminary AI estimate. Final diagnosis confirmed on-site by a licensed technician.
        </div>
      </div>

      <!-- RIGHT: CSS mockup -->
      <div class="diag-mockup" aria-hidden="true">
        <div class="mockup-frame">

          <div class="mockup-header">
            <div class="mockup-ai-badge">AI</div>
            <div>
              <div class="mockup-title">AI Appliance Diagnostics</div>
              <div class="mockup-sub">Free preliminary diagnosis · cost estimate · checklist</div>
            </div>
          </div>

          <div class="mockup-steps">
            <div class="mockup-step">1 — Appliance</div>
            <div class="mockup-step active">2 — Problem</div>
            <div class="mockup-step">3 — Diagnosis</div>
            <div class="mockup-step">4 — Book</div>
          </div>

          <div class="mockup-body">
            <div class="mockup-label">Selected appliance</div>
            <div class="mockup-pill-row">
              <div class="mockup-pill mockup-pill-active">🧊 Refrigerator</div>
            </div>

            <div class="mockup-label">Brand</div>
            <div class="mockup-input">
              <span>Sub-Zero</span>
              <span class="mockup-chevron">▼</span>
            </div>

            <div class="mockup-label">Symptoms — select all that apply</div>
            <div class="mockup-chips">
              <div class="mockup-chip mockup-chip-active">Not cooling</div>
              <div class="mockup-chip">Ice maker leaking</div>
              <div class="mockup-chip mockup-chip-active">Strange noise</div>
              <div class="mockup-chip">Door seal damaged</div>
              <div class="mockup-chip">Water dispenser issue</div>
            </div>

            <div class="mockup-cta">
              Run AI Diagnosis →
            </div>
          </div>

        </div>

        <div class="mockup-glow"></div>
      </div>

    </div>
  </div>
</section>

<style>
  /* Scoped tokens — match preview-homepage.html convention */
  .diagnostics-section {
    --bg: #0a0a0a;
    --bg2: #151515;
    --bg3: #1a1a1a;
    --bg4: #1e1e1e;
    --gold: #D4AF37;
    --gold-h: #e5c254;
    --gold-dim: rgba(212, 175, 55, 0.2);
    --red: #C8102E;
    --red-dark: #a00d24;
    --red-dim: rgba(200, 16, 46, 0.12);
    --text: #ffffff;
    --text2: #d4d4d4;
    --text3: #888888;
    --text4: #555555;
    --border: rgba(255, 255, 255, 0.08);
    --border-gold: rgba(212, 175, 55, 0.4);

    background: var(--bg);
    color: var(--text);
    padding: 112px 24px;
    overflow: hidden;
  }

  .diagnostics-section .container {
    max-width: 1280px;
    margin: 0 auto;
  }

  .section-header-simple {
    text-align: center;
    margin-bottom: 72px;
  }

  .section-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(28px, 3.4vw, 44px);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0 0 16px 0;
    color: var(--text);
  }

  .text-gold {
    color: var(--gold);
    font-style: italic;
  }

  .section-subtitle {
    color: var(--text2);
    font-family: 'Montserrat', sans-serif;
    font-size: 16px;
    max-width: 640px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .diag-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  /* ──────── LEFT: PITCH ──────── */
  .diag-pitch {
    max-width: 540px;
  }

  .diag-eyebrow {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: 'Cinzel', 'Playfair Display', serif;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--gold);
    margin-bottom: 24px;
  }

  .diag-ai-badge {
    display: inline-block;
    background: var(--red);
    color: #fff;
    font-family: 'Montserrat', sans-serif;
    font-size: 9px;
    font-weight: 800;
    letter-spacing: 0.15em;
    padding: 4px 8px;
    border-radius: 2px;
  }

  .diag-pitch-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(28px, 3vw, 40px);
    font-weight: 600;
    line-height: 1.15;
    margin: 0 0 24px 0;
    color: var(--text);
  }

  .diag-pitch-desc {
    font-family: 'Montserrat', sans-serif;
    font-size: 16px;
    line-height: 1.75;
    color: var(--text2);
    margin: 0 0 32px 0;
  }

  .diag-bullets {
    list-style: none;
    padding: 0;
    margin: 0 0 40px 0;
  }
  .diag-bullets li {
    display: flex;
    gap: 14px;
    padding: 12px 0;
    font-family: 'Montserrat', sans-serif;
    font-size: 14px;
    line-height: 1.6;
    color: var(--text2);
    border-bottom: 1px solid var(--border);
  }
  .diag-bullets li:last-child { border-bottom: none; }
  .diag-bullets strong { color: var(--text); font-weight: 600; }

  .diag-bullet-icon {
    color: var(--gold);
    flex-shrink: 0;
    font-size: 12px;
    line-height: 1.6;
  }

  .diag-cta-primary {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: var(--red);
    color: #fff;
    text-decoration: none;
    padding: 16px 32px;
    font-family: 'Montserrat', sans-serif;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    transition: background 0.2s ease, transform 0.2s ease;
    margin-bottom: 20px;
  }
  .diag-cta-primary:hover,
  .diag-cta-primary:focus-visible {
    background: var(--red-dark);
    transform: translateY(-1px);
  }
  .diag-cta-arrow { transition: transform 0.2s ease; }
  .diag-cta-primary:hover .diag-cta-arrow,
  .diag-cta-primary:focus-visible .diag-cta-arrow {
    transform: translateX(4px);
  }

  .diag-disclaimer {
    font-family: 'Montserrat', sans-serif;
    font-size: 11px;
    color: var(--text4);
    line-height: 1.6;
    font-style: italic;
  }

  /* ──────── RIGHT: MOCKUP ──────── */
  .diag-mockup {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .mockup-frame {
    position: relative;
    background: var(--bg2);
    border: 1px solid var(--border-gold);
    width: 100%;
    max-width: 480px;
    box-shadow:
      0 30px 80px rgba(0, 0, 0, 0.5),
      0 0 0 1px rgba(212, 175, 55, 0.1);
    z-index: 2;
  }

  .mockup-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 90%;
    height: 80%;
    background: radial-gradient(
      ellipse at center,
      rgba(212, 175, 55, 0.12) 0%,
      rgba(200, 16, 46, 0.06) 40%,
      transparent 70%
    );
    z-index: 1;
    pointer-events: none;
  }

  .mockup-header {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 18px 20px;
    border-bottom: 1px solid var(--border);
    background: var(--bg3);
  }

  .mockup-ai-badge {
    background: var(--red);
    color: #fff;
    font-family: 'Montserrat', sans-serif;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.15em;
    padding: 6px 10px;
    border-radius: 2px;
  }

  .mockup-title {
    font-family: 'Playfair Display', serif;
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
  }
  .mockup-sub {
    font-family: 'Montserrat', sans-serif;
    font-size: 10px;
    color: var(--text3);
    margin-top: 2px;
  }

  .mockup-steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-bottom: 1px solid var(--border);
  }
  .mockup-step {
    padding: 10px 8px;
    font-family: 'Montserrat', sans-serif;
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text4);
    text-align: center;
    border-right: 1px solid var(--border);
    background: var(--bg2);
  }
  .mockup-step:last-child { border-right: none; }
  .mockup-step.active {
    color: var(--gold);
    background: var(--bg);
    box-shadow: inset 0 -2px 0 var(--gold);
  }

  .mockup-body { padding: 20px; }

  .mockup-label {
    font-family: 'Montserrat', sans-serif;
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--red);
    font-weight: 700;
    margin: 0 0 10px 0;
  }
  .mockup-label:not(:first-child) { margin-top: 18px; }

  .mockup-pill-row {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .mockup-pill {
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 8px 14px;
    font-family: 'Montserrat', sans-serif;
    font-size: 12px;
    color: var(--text2);
  }
  .mockup-pill-active {
    border-color: var(--red);
    background: var(--red-dim);
    color: var(--text);
  }

  .mockup-input {
    background: var(--bg);
    border: 1px solid var(--border);
    padding: 10px 14px;
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    color: var(--text);
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .mockup-chevron { color: var(--text4); font-size: 9px; }

  .mockup-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .mockup-chip {
    padding: 7px 12px;
    background: var(--bg);
    border: 1px solid var(--border);
    font-family: 'Montserrat', sans-serif;
    font-size: 11px;
    color: var(--text3);
    border-radius: 2px;
  }
  .mockup-chip-active {
    border-color: var(--gold);
    background: var(--gold-dim);
    color: var(--text);
  }

  .mockup-cta {
    margin-top: 22px;
    background: var(--red);
    color: #fff;
    padding: 12px 18px;
    font-family: 'Montserrat', sans-serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-align: center;
  }

  /* ──────── RESPONSIVE ──────── */
  @media (max-width: 1024px) {
    .diag-grid { gap: 48px; }
  }

  @media (max-width: 768px) {
    .diagnostics-section { padding: 80px 16px; }
    .diag-grid { grid-template-columns: 1fr; gap: 56px; }
    .diag-pitch { max-width: 100%; text-align: center; }
    .diag-eyebrow { justify-content: center; }
    .diag-bullets li { text-align: left; }
    .diag-cta-primary { width: 100%; justify-content: center; }
    .mockup-frame { max-width: 100%; }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .diag-cta-primary,
    .diag-cta-arrow {
      transition: none;
    }
    .diag-cta-primary:hover,
    .diag-cta-primary:focus-visible {
      transform: none;
    }
    .diag-cta-primary:hover .diag-cta-arrow,
    .diag-cta-primary:focus-visible .diag-cta-arrow {
      transform: none;
    }
  }
</style>
