---
// Diagnostics.astro — AI-Powered Diagnostics block
//
// Status: SCAFFOLD (Step 3) — content comes in Step 5
//
// Will render: AI diagnostic widget mirroring the preview-homepage version
//   - Residential / Commercial unit-type tabs
//   - Appliance grid (24 residential + 18 commercial tiles)
//   - Symptom selector
//   - "Run Diagnostics" CTA
//   - Print Report + Request Callback forms
//
// NOTE: src/components/AiDiagnostic.astro (old top-level component) stays in
// place until this scaffold is filled. Step 5 will wire real content here and
// retire AiDiagnostic.astro.

interface Props {}
---

<section class="diagnostics" id="diagnostics">
  <div class="container">
    <header class="section-header-simple">
      <h2 class="section-title">
        AI-Powered <span class="text-gold">Diagnostics</span>
      </h2>
      <p class="section-subtitle">[Scaffold] Real diagnostic UI lands in Step 5.</p>
    </header>
    <div class="placeholder">
      <p>AI Diagnostics — Step 5</p>
    </div>
  </div>
</section>

<style>
  .diagnostics {
    background: #151515;
    color: #ffffff;
    padding: 112px 24px;
    border-bottom: 1px dashed rgba(212, 175, 55, 0.4);
  }
  .diagnostics .container { max-width: 1280px; margin: 0 auto; }
  .section-header-simple { text-align: center; margin-bottom: 32px; }
  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(28px, 3.4vw, 44px);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0 0 16px 0;
    color: #ffffff;
  }
  .text-gold { color: #D4AF37; font-style: italic; }
  .section-subtitle {
    color: #d4d4d4;
    font-family: 'Montserrat', sans-serif;
    max-width: 680px;
    margin: 0 auto;
  }
  .placeholder {
    margin-top: 32px;
    padding: 48px 24px;
    border: 1px dashed rgba(212, 175, 55, 0.4);
    color: #888;
    text-align: center;
    font-family: 'Cinzel', serif;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
  .placeholder p { margin: 0; }
</style>
