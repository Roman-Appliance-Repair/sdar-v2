---
// Pricing.astro — Transparent Pricing section
//
// Status: SCAFFOLD (Step 3) — content comes in Step 5
//
// Will render: centered "Transparent Pricing" header, 2-row diagnostic-fee table
// (Residential $89* / Commercial $120*), second-unit-free footnote,
// 4 trust bullets (OEM, 90-day, upfront quote, no surcharge),
// "View Full Price List →" link. Mirrors the recently-edited preview-homepage
// pricing block.

interface Props {}
---

<section class="pricing" id="pricing">
  <div class="container">
    <header class="section-header-simple">
      <h2 class="section-title">
        Transparent <span class="text-gold">Pricing</span>
      </h2>
      <p class="section-subtitle">[Scaffold] Diagnostic fee table lands in Step 5.</p>
    </header>
    <div class="placeholder">
      <p>Pricing table — Step 5</p>
    </div>
  </div>
</section>

<style>
  .pricing {
    background: #151515;
    color: #ffffff;
    padding: 112px 24px;
    border-bottom: 1px dashed rgba(212, 175, 55, 0.4);
  }
  .pricing .container { max-width: 1280px; margin: 0 auto; }
  .section-header-simple { text-align: center; margin-bottom: 32px; }
  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(28px, 3.4vw, 44px);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0 0 16px 0;
    color: #ffffff;
  }
  .text-gold { color: #D4AF37; font-style: italic; }
  .section-subtitle {
    color: #d4d4d4;
    font-family: 'Montserrat', sans-serif;
    max-width: 680px;
    margin: 0 auto;
  }
  .placeholder {
    margin-top: 32px;
    padding: 48px 24px;
    border: 1px dashed rgba(212, 175, 55, 0.4);
    color: #888;
    text-align: center;
    font-family: 'Cinzel', serif;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
  .placeholder p { margin: 0; }
</style>
