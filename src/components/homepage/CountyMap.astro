---
// CountyMap.astro
//
// Static SVG map of 5 SoCal counties served by SDAR with informational
// overlays. Refactored:
//   - Background: subtle gold grid pattern across full canvas + faint ocean
//     fill on the SW edge for geographic context
//   - 8 branch markers (1 HQ + 7 service_area) read from BRANCHES
//   - 4 outer branches use leader-line external labels
//   - 4 LA-county branches collapse into a "LOS ANGELES METRO" legend card
//   - Per-county branch counts under county names
//   - Corner stat badges (5 COUNTIES / 87 CITIES / 10+ YEARS)
//   - Hover tooltip per branch (name + phone + cities served count)
//
// Removed: freeways, 15-mile service-radius rings, per-branch on-map labels.
//
// Data sources: BRANCHES (county-boundaries.BRANCH_PIN_POSITIONS for x/y),
// CITIES (count cities per primaryBranch). Branch info propagates from data
// files — nothing about branches is hardcoded inside this SVG.

import {
  COUNTY_BOUNDARIES,
  SVG_VIEWBOX,
  SVG_WIDTH,
  SVG_HEIGHT,
  BRANCH_PIN_POSITIONS,
  type CountySlug
} from '../../data/county-boundaries';
import { BRANCHES, type Branch } from '../../data/branches';
import { CITIES } from '../../data/cities';

// ── Cities served per branch (for hover tooltip) ──
const cityCountByBranch = new Map<string, number>();
for (const c of CITIES) {
  cityCountByBranch.set(c.primaryBranch, (cityCountByBranch.get(c.primaryBranch) ?? 0) + 1);
}

// ── Branch count per county (for sub-label under each county name) ──
const branchCountByCounty = new Map<CountySlug, number>();
for (const b of BRANCHES) {
  branchCountByCounty.set(b.primaryCounty, (branchCountByCounty.get(b.primaryCounty) ?? 0) + 1);
}

// Branch render order (HQ painted last so its dot sits on top of any cluster)
const BRANCH_RENDER_ORDER = [
  'thousand-oaks',
  'beverly-hills',
  'los-angeles',
  'pasadena',
  'irvine',
  'rancho-cucamonga',
  'temecula',
  'west-hollywood'
];

interface BranchPin {
  branch: Branch;
  x: number;
  y: number;
  isHq: boolean;
  citiesServed: number;
}
const branchPins: BranchPin[] = BRANCH_RENDER_ORDER
  .map((slug) => {
    const branch = BRANCHES.find((b) => b.slug === slug);
    const pos = BRANCH_PIN_POSITIONS[slug];
    if (!branch || !pos) return null;
    return {
      branch,
      x: pos.x,
      y: pos.y,
      isHq: branch.type === 'physical_pin',
      citiesServed: cityCountByBranch.get(slug) ?? 0
    };
  })
  .filter((p): p is BranchPin => p !== null);

// ── External leader-line labels for the 4 outer-county branches.
//    LA-county branches (WeHo, BH, LA, Pasadena) are collected into the
//    LA Metro legend card instead of getting individual on-map labels. ──
type LeaderAnchor = 'start' | 'middle' | 'end';
interface LeaderLabel {
  slug: string;
  label: string;
  /** Endpoint of the leader-line near the label (~10 SVG units off the text) */
  lineX: number;
  lineY: number;
  /** Anchor point of the visible label text */
  textX: number;
  textY: number;
  anchor: LeaderAnchor;
}
const LEADER_LABELS: LeaderLabel[] = [
  // Thousand Oaks marker (143, 451) → label up-left, above Ventura
  { slug: 'thousand-oaks',    label: 'THOUSAND OAKS',    lineX:  88, lineY: 358, textX:  88, textY: 350, anchor: 'middle' },
  // Rancho Cucamonga marker (363, 460) → label right of marker, in empty SB strip below the SB county label
  { slug: 'rancho-cucamonga', label: 'RANCHO CUCAMONGA', lineX: 470, lineY: 415, textX: 470, textY: 408, anchor: 'middle' },
  // Irvine marker (324, 551) → label straight down, below Orange
  { slug: 'irvine',           label: 'IRVINE',           lineX: 324, lineY: 632, textX: 324, textY: 644, anchor: 'middle' },
  // Temecula marker (445, 588) → label down-right, between Riverside and the corner badge
  { slug: 'temecula',         label: 'TEMECULA',         lineX: 555, lineY: 658, textX: 555, textY: 670, anchor: 'middle' }
];

// ── LA Metro legend card content ──
interface LegendBranch {
  slug: string;
  name: string;
  isHq: boolean;
}
const LA_METRO_SLUGS = ['west-hollywood', 'los-angeles', 'beverly-hills', 'pasadena'];
const laMetroBranches: LegendBranch[] = LA_METRO_SLUGS
  .map((slug) => {
    const b = BRANCHES.find((br) => br.slug === slug);
    if (!b) return null;
    return { slug, name: b.name, isHq: b.type === 'physical_pin' };
  })
  .filter((x): x is LegendBranch => x !== null);

// Card geometry (top-center area of the SVG, above all county shapes)
const LEGEND = {
  x: 380,
  y: 30,
  w: 240,
  h: 122,
  paddingX: 18,
  titleY: 56,
  firstItemY: 80,
  itemStep: 18
};

// ── Corner stat badges ──
interface CornerBadge { x: number; y: number; w: number; h: number; text: string }
const CORNER_BADGES: CornerBadge[] = [
  { x:  20, y:  20, w: 130, h: 32, text: '5 COUNTIES'  },
  { x:  20, y: 648, w: 130, h: 32, text: '87 CITIES'   },
  { x: 850, y: 648, w: 130, h: 32, text: '10+ YEARS'   }
];

// ── Pacific Ocean approximate coastline polygon (covers SW corner of canvas).
//    Coordinates traced freehand against branch positions: Ventura west edge,
//    south through Santa Monica, Long Beach, Newport, off the bottom. ──
const OCEAN_PATH =
  'M 0 0 L 0 700 L 380 700 L 350 666 L 300 624 L 256 588 L 198 545 L 130 488 L 76 422 L 38 322 L 16 200 L 0 90 Z';
---

<div class="county-map-wrapper" role="region" aria-label="Service Area Map">
  <svg
    viewBox={SVG_VIEWBOX}
    xmlns="http://www.w3.org/2000/svg"
    class="county-map"
    role="img"
    aria-labelledby="map-title map-desc"
  >
    <title id="map-title">Same Day Appliance Repair Service Area — Southern California</title>
    <desc id="map-desc">
      Map of five Southern California counties served by Same Day Appliance Repair:
      Los Angeles, Orange, Ventura, San Bernardino, and Riverside. Headquartered in
      West Hollywood with eight branch locations covering 87 cities across the region.
    </desc>

    <defs>
      {/* Gold grid pattern — covers the entire SVG canvas */}
      <pattern id="map-grid" width="40" height="40" patternUnits="userSpaceOnUse">
        <path d="M 40 0 L 0 0 L 0 40" fill="none" stroke="#D4AF37" stroke-width="0.5" stroke-opacity="0.05"/>
      </pattern>
      <radialGradient id="county-fill" cx="50%" cy="50%" r="80%">
        <stop offset="0%" stop-color="#1a1a1a" />
        <stop offset="100%" stop-color="#0a0a0a" />
      </radialGradient>
    </defs>

    {/* Layer 1: black background + grid pattern across the full canvas */}
    <rect width={SVG_WIDTH} height={SVG_HEIGHT} fill="#0a0a0a" />
    <rect width={SVG_WIDTH} height={SVG_HEIGHT} fill="url(#map-grid)" />

    {/* Layer 2: Pacific Ocean outline (above grid, below counties) */}
    <path d={OCEAN_PATH} class="ocean-fill" aria-hidden="true" />

    {/* Layer 3: Counties (existing — clickable links to county hubs) */}
    <g class="counties">
      {COUNTY_BOUNDARIES.map((county) => (
        <a href={county.hubUrl} class="county-link" aria-label={`${county.name} service area`}>
          <path
            d={county.path}
            class="county-path"
            data-county={county.slug}
          >
            <title>{county.name}</title>
          </path>
        </a>
      ))}
    </g>

    {/* Layer 4: County labels + per-county branch counts */}
    <g class="county-labels" aria-hidden="true">
      {COUNTY_BOUNDARIES.map((county) => {
        const count = branchCountByCounty.get(county.slug) ?? 0;
        const label = `${count} ${count === 1 ? 'branch' : 'branches'}`;
        return (
          <>
            <text x={county.labelX} y={county.labelY}      class="county-label"          text-anchor="middle">{county.name.replace(' County', '').toUpperCase()}</text>
            <text x={county.labelX} y={county.labelY + 18} class="county-branches-label" text-anchor="middle">{label}</text>
          </>
        );
      })}
    </g>

    {/* Layer 5: Leader-lines for the 4 outer-county branches */}
    <g class="leader-lines" aria-hidden="true">
      {LEADER_LABELS.map((l) => {
        const pos = BRANCH_PIN_POSITIONS[l.slug];
        if (!pos) return null;
        return <line x1={pos.x} y1={pos.y} x2={l.lineX} y2={l.lineY} class="leader-line" />;
      })}
    </g>

    {/* Layer 6: External labels (text only — leader connects them to dots) */}
    <g class="leader-labels" aria-hidden="true">
      {LEADER_LABELS.map((l) => (
        <text x={l.textX} y={l.textY} class="leader-label" text-anchor={l.anchor}>{l.label}</text>
      ))}
    </g>

    {/* Layer 7: LA Metro legend card */}
    <g class="la-metro-legend" aria-hidden="true">
      <rect
        x={LEGEND.x}
        y={LEGEND.y}
        width={LEGEND.w}
        height={LEGEND.h}
        rx={2}
        class="legend-bg"
      />
      <text
        x={LEGEND.x + LEGEND.w / 2}
        y={LEGEND.y + LEGEND.titleY - LEGEND.y}
        class="legend-title"
        text-anchor="middle"
      >LOS ANGELES METRO</text>
      {laMetroBranches.map((b, i) => {
        const cy = LEGEND.y + LEGEND.firstItemY - LEGEND.y + i * LEGEND.itemStep;
        const dotX = LEGEND.x + LEGEND.paddingX + 4;
        const textX = LEGEND.x + LEGEND.paddingX + 18;
        return (
          <>
            {b.isHq ? (
              <>
                <circle cx={dotX} cy={cy - 3} r={5} class="legend-dot legend-dot-hq-outer" />
                <circle cx={dotX} cy={cy - 3} r={2} class="legend-dot-hq-inner" />
              </>
            ) : (
              <circle cx={dotX} cy={cy - 3} r={4} class="legend-dot" />
            )}
            <text x={textX} y={cy} class={`legend-item${b.isHq ? ' legend-item-hq' : ''}`}>
              {b.name}{b.isHq ? '  (HQ)' : ''}
            </text>
          </>
        );
      })}
    </g>

    {/* Layer 8: Branch markers (no individual labels — labels live in
        leader-lines or the LA Metro legend) + hover tooltips. */}
    <g class="branch-pins">
      {branchPins.map((p) => {
        const tipW = 180;
        const tipH = 64;
        const tipY = p.y - tipH - 14;
        const tipX = Math.max(8, Math.min(SVG_WIDTH - tipW - 8, p.x - tipW / 2));
        return (
          <g class={`branch-pin${p.isHq ? ' branch-pin-hq' : ''}`} data-branch={p.branch.slug}>
            {p.isHq ? (
              <>
                <circle cx={p.x} cy={p.y} r={10} class="branch-dot-outer" />
                <circle cx={p.x} cy={p.y} r={4}  class="branch-dot-inner" />
              </>
            ) : (
              <circle cx={p.x} cy={p.y} r={6} class="branch-dot" />
            )}
            {/* Tooltip — hidden by default, fades in on hover/focus */}
            <g class="branch-tooltip" transform={`translate(${tipX}, ${tipY})`} aria-hidden="true">
              <rect class="tooltip-bg" x={0} y={0} width={tipW} height={tipH} rx={2} />
              <text class="tooltip-name"   x={12} y={20}>{p.branch.name}{p.isHq ? ' (HQ)' : ''}</text>
              <text class="tooltip-phone"  x={12} y={38}>{p.branch.phone}</text>
              <text class="tooltip-cities" x={12} y={54}>
                {p.citiesServed} {p.citiesServed === 1 ? 'city' : 'cities'} served
              </text>
            </g>
            {/* Wider invisible hit-target so the dot is easy to hover */}
            <rect x={p.x - 14} y={p.y - 14} width={28} height={28} class="branch-hit" fill="transparent" />
          </g>
        );
      })}
    </g>

    {/* Layer 9: Corner stat badges (above all map content, below tooltips) */}
    <g class="corner-badges" aria-hidden="true">
      {CORNER_BADGES.map((b) => (
        <g class="corner-badge" transform={`translate(${b.x}, ${b.y})`}>
          <rect class="corner-badge-bg" x={0} y={0} width={b.w} height={b.h} rx={2} />
          <text class="corner-badge-text" x={b.w / 2} y={b.h / 2 + 1} text-anchor="middle" dominant-baseline="middle">
            {b.text}
          </text>
        </g>
      ))}
    </g>
  </svg>
</div>

<style>
  .county-map-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 10 / 7;
    background: #1a1a1a;
    border: 1px solid rgba(212, 175, 55, 0.4);
    overflow: hidden;
  }

  .county-map-wrapper::before {
    content: '';
    position: absolute;
    inset: 8px;
    border: 1px solid rgba(212, 175, 55, 0.2);
    pointer-events: none;
    z-index: 2;
  }

  .county-map {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* ── Ocean ── */
  .ocean-fill {
    fill: #0d1a2a;
    fill-opacity: 0.45;
    stroke: rgba(120, 150, 190, 0.10);
    stroke-width: 0.5;
    pointer-events: none;
  }

  /* ── Counties ── */
  .county-link { cursor: pointer; }
  .county-path {
    fill: url(#county-fill);
    stroke: #D4AF37;
    stroke-width: 1.5;
    stroke-linejoin: round;
    transition: fill 0.3s ease, stroke 0.3s ease, stroke-width 0.3s ease;
  }
  .county-link:hover .county-path,
  .county-link:focus-visible .county-path {
    fill: rgba(200, 16, 46, 0.15);
    stroke: #C8102E;
    stroke-width: 2;
  }

  /* ── County labels ── */
  .county-label {
    font-family: 'Cinzel', serif;
    font-size: 14px;
    font-weight: 600;
    fill: #D4AF37;
    letter-spacing: 0.15em;
    pointer-events: none;
    user-select: none;
  }
  .county-branches-label {
    font-family: 'Cinzel', serif;
    font-size: 10px;
    font-weight: 500;
    fill: rgba(212, 175, 55, 0.7);
    letter-spacing: 0.10em;
    pointer-events: none;
    user-select: none;
  }

  /* ── Leader-lines + external labels ── */
  .leader-line {
    stroke: #D4AF37;
    stroke-width: 0.5;
    stroke-opacity: 0.40;
    fill: none;
    pointer-events: none;
  }
  .leader-label {
    font-family: 'Cinzel', serif;
    font-size: 11px;
    font-weight: 600;
    fill: #D4AF37;
    letter-spacing: 0.10em;
    pointer-events: none;
    user-select: none;
  }

  /* ── LA Metro legend card ── */
  .legend-bg {
    fill: #0a0a0a;
    fill-opacity: 0.65;
    stroke: rgba(212, 175, 55, 0.40);
    stroke-width: 1;
  }
  .legend-title {
    font-family: 'Cinzel', serif;
    font-size: 12px;
    font-weight: 700;
    fill: #D4AF37;
    letter-spacing: 0.18em;
  }
  .legend-dot {
    fill: #D4AF37;
    stroke: #0a0a0a;
    stroke-width: 1;
  }
  .legend-dot-hq-outer {
    fill: #D4AF37;
    stroke: #0a0a0a;
    stroke-width: 1;
  }
  .legend-dot-hq-inner {
    fill: #C8102E;
  }
  .legend-item {
    font-family: 'Cinzel', serif;
    font-size: 11px;
    font-weight: 500;
    fill: #d4d4d4;
    letter-spacing: 0.05em;
  }
  .legend-item-hq {
    fill: #D4AF37;
    font-weight: 700;
  }

  /* ── Branch pins ── */
  .branch-pin { cursor: pointer; }
  .branch-dot {
    fill: #D4AF37;
    stroke: #0a0a0a;
    stroke-width: 1.5;
    transition: fill 0.2s ease;
  }
  .branch-pin-hq .branch-dot-outer {
    fill: #D4AF37;
    stroke: #0a0a0a;
    stroke-width: 1.5;
  }
  .branch-pin-hq .branch-dot-inner {
    fill: #C8102E;
    pointer-events: none;
  }
  .branch-pin:hover .branch-dot { fill: #e5c254; }
  .branch-hit { cursor: pointer; }

  /* ── Tooltip ── */
  .branch-tooltip {
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s ease;
  }
  .branch-pin:hover .branch-tooltip,
  .branch-pin:focus-within .branch-tooltip {
    opacity: 1;
  }
  .tooltip-bg {
    fill: #0a0a0a;
    fill-opacity: 0.95;
    stroke: rgba(212, 175, 55, 0.6);
    stroke-width: 1;
  }
  .tooltip-name {
    font-family: 'Montserrat', sans-serif;
    font-size: 12px;
    font-weight: 700;
    fill: #ffffff;
    letter-spacing: 0.04em;
  }
  .tooltip-phone {
    font-family: 'Montserrat', sans-serif;
    font-size: 11px;
    font-weight: 600;
    fill: #D4AF37;
    font-variant-numeric: tabular-nums;
  }
  .tooltip-cities {
    font-family: 'Montserrat', sans-serif;
    font-size: 10px;
    font-weight: 500;
    fill: #d4d4d4;
  }

  /* ── Corner badges ── */
  .corner-badge-bg {
    fill: #151515;
    fill-opacity: 0.92;
    stroke: rgba(212, 175, 55, 0.4);
    stroke-width: 1;
  }
  .corner-badge-text {
    font-family: 'Montserrat', sans-serif;
    font-size: 11px;
    font-weight: 700;
    fill: #D4AF37;
    letter-spacing: 0.18em;
    user-select: none;
  }

  /* ── Responsive: SVG-space font bumps so labels stay legible ── */
  @media (max-width: 768px) {
    .county-label { font-size: 12px; letter-spacing: 0.10em; }
    .county-branches-label { font-size: 9px; }
    .leader-label { font-size: 13px; }
    .legend-title { font-size: 14px; letter-spacing: 0.15em; }
    .legend-item { font-size: 13px; }
    .corner-badge-text { font-size: 13px; letter-spacing: 0.15em; }
    .tooltip-name { font-size: 13px; }
    .tooltip-phone { font-size: 12px; }
    .tooltip-cities { font-size: 11px; }
  }
  @media (max-width: 640px) {
    .county-label { font-size: 11px; }
    .county-branches-label { font-size: 8px; }
    /* Hide bottom-right badge on very narrow screens to avoid Riverside overlap */
    .corner-badge:nth-of-type(3) { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .county-path,
    .branch-dot,
    .branch-tooltip { transition: none; }
  }
</style>
