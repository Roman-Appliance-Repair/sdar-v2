---
// Credentials.astro — 8-card credentials grid
//
// Step 8 of homepage redesign sprint: replicates Section 07 of
// public/preview-homepage.html. 4-column desktop grid (2-col tablet, 1-col
// mobile) of trust credentials with inline SVG icons.
//
// URL resolution is done at build time against src/pages/credentials/. If the
// preview's preferred slug exists, link there. Otherwise try common variations
// (drop "-appliance-repair", drop "-certified", strip "-608"); if nothing
// matches, fall back to the /credentials/ hub.

import fs from 'node:fs';
import path from 'node:path';

import { CREDENTIALS, type Credential } from '../../data/credentials';

const SRC_DIR = path.resolve('./src/pages');
const pageExists = (rel: string) => fs.existsSync(path.join(SRC_DIR, rel));

function resolveCredentialUrl(preferredSlug: string): string {
  const tried = new Set<string>();
  const tryCandidates = (slug: string): string | null => {
    if (tried.has(slug)) return null;
    tried.add(slug);
    if (pageExists(`credentials/${slug}.astro`)) return `/credentials/${slug}/`;
    if (pageExists(`credentials/${slug}/index.astro`)) return `/credentials/${slug}/`;
    return null;
  };

  const direct = tryCandidates(preferredSlug);
  if (direct) return direct;

  const variations = [
    preferredSlug.replace(/-appliance-repair$/, ''),
    preferredSlug.replace(/-certified$/, ''),
    preferredSlug.replace(/^epa-608-/, 'epa-'),
    preferredSlug.replace(/^background-checked-.*/, 'background-checked'),
  ];
  for (const v of variations) {
    const hit = tryCandidates(v);
    if (hit) return hit;
  }

  return '/credentials/';
}

interface ResolvedCredential extends Credential {
  href: string;
}

const credentials: ResolvedCredential[] = CREDENTIALS.map((c) => ({
  ...c,
  href: resolveCredentialUrl(c.preferredSlug),
}));
---

<section class="credentials-section" id="credentials">
  <div class="section-header-simple">
    <h2 class="section-title">Credentials &amp; <span class="text-gold">Trust</span></h2>
  </div>
  <p class="section-subtitle">
    Everything we're licensed, insured, and certified for — 8 credentials pages
    covering the regulators, insurers, and industry bodies that verify our work.
  </p>

  <div class="credentials-grid">
    {credentials.map((c) => (
      <div class="credential-card">
        <div class="credential-icon" aria-hidden="true" set:html={c.iconSvg} />
        <h3 class="credential-title">{c.title}</h3>
        <p class="credential-description">{c.description}</p>
        <a href={c.href} class="credential-link">View Details →</a>
      </div>
    ))}
  </div>
</section>

<style>
  .credentials-section {
    --bg: #0a0a0a;
    --bg2: #151515;
    --bg3: #1a1a1a;
    --red: #C8102E;
    --gold: #D4AF37;
    --text: #ffffff;
    --text3: #888888;
    --border: rgba(255, 255, 255, 0.08);
    --border-gold: rgba(212, 175, 55, 0.4);

    padding: 60px 0;
    background: var(--bg);
    color: var(--text);
  }

  .credentials-section .section-header-simple,
  .credentials-section .section-subtitle {
    max-width: 1200px;
    margin-left: auto;
    margin-right: auto;
    padding-left: 24px;
    padding-right: 24px;
  }

  .section-header-simple {
    text-align: center;
    margin-bottom: 16px;
  }
  .section-header-simple .section-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 32px;
    font-weight: 700;
    color: var(--text);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0;
  }
  .text-gold { color: var(--gold); font-style: italic; font-weight: 600; }
  .section-subtitle {
    text-align: center;
    font-size: 13px;
    line-height: 1.3;
    color: var(--text3);
    margin: 0 auto 20px;
    font-family: 'Montserrat', sans-serif;
  }

  .credentials-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 24px;
    max-width: 1200px;
    margin: 24px auto 0;
    padding: 0 20px;
  }

  .credential-card {
    background: var(--bg2);
    border: 1px solid var(--border);
    padding: 32px 24px;
    text-align: center;
    transition: all 0.3s;
    border-radius: 8px;
    display: flex;
    flex-direction: column;
  }
  .credential-card:hover {
    border-color: var(--gold);
    box-shadow: 0 4px 16px rgba(212, 175, 55, 0.2);
    transform: translateY(-4px);
  }

  .credential-icon {
    margin-bottom: 16px;
    height: 80px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .credential-icon :global(svg) {
    width: 64px;
    height: 64px;
  }

  .credential-title {
    font-family: 'Montserrat', sans-serif;
    font-size: 18px;
    font-weight: 700;
    color: var(--text);
    margin: 0 0 12px;
  }
  .credential-description {
    font-family: 'Montserrat', sans-serif;
    font-size: 14px;
    color: var(--text3);
    margin: 0 0 16px;
    line-height: 1.6;
    flex: 1;
  }
  .credential-link {
    color: var(--gold);
    text-decoration: none;
    font-weight: 600;
    font-size: 14px;
    font-family: 'Montserrat', sans-serif;
    transition: color 0.3s;
    display: inline-block;
  }
  .credential-link:hover { color: var(--red); }

  /* ==== RESPONSIVE ==== */
  @media (max-width: 1024px) {
    .credentials-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 640px) {
    .credentials-grid { grid-template-columns: 1fr; }
  }
</style>
