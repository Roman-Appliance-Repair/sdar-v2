---
// Credentials.astro — 8-card credentials grid
//
// Status: SCAFFOLD (Step 3) — content comes in Step 5
//
// Will render: 8 credential cards (Background Checked, BBB Accredited, EPA 608,
// Insured, Licensed BHGS #A49573, OEM Parts, OSHA Certified, Same Day Service).
// Each card: inline SVG icon + title + 1-line description + "View Details →"
// link to /credentials/[slug]/.

interface Props {}
---

<section class="credentials" id="credentials">
  <div class="container">
    <header class="section-header-simple">
      <h2 class="section-title">
        Credentials &amp; <span class="text-gold">Trust</span>
      </h2>
      <p class="section-subtitle">[Scaffold] 8 credential cards land in Step 5.</p>
    </header>
    <div class="placeholder">
      <p>Credentials 8 cards — Step 5</p>
    </div>
  </div>
</section>

<style>
  .credentials {
    background: #151515;
    color: #ffffff;
    padding: 112px 24px;
    border-bottom: 1px dashed rgba(212, 175, 55, 0.4);
  }
  .credentials .container { max-width: 1280px; margin: 0 auto; }
  .section-header-simple { text-align: center; margin-bottom: 32px; }
  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(28px, 3.4vw, 44px);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0 0 16px 0;
    color: #ffffff;
  }
  .text-gold { color: #D4AF37; font-style: italic; }
  .section-subtitle {
    color: #d4d4d4;
    font-family: 'Montserrat', sans-serif;
    max-width: 680px;
    margin: 0 auto;
  }
  .placeholder {
    margin-top: 32px;
    padding: 48px 24px;
    border: 1px dashed rgba(212, 175, 55, 0.4);
    color: #888;
    text-align: center;
    font-family: 'Cinzel', serif;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
  .placeholder p { margin: 0; }
</style>
