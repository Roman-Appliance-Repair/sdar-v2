---
// FAQ.astro — Common Questions section
//
// Step 5.5: replaces the Step 3 scaffold with a 10-item accordion of approved
// Q/A pairs. Data lives in src/data/faq.ts so HomepageSchema.astro can render
// the same content as FAQPage JSON-LD.
//
// Implementation uses native <details>/<summary> — zero JS, keyboard-accessible
// (Enter/Space toggles), screen-reader friendly. First item open by default.

import { HOMEPAGE_FAQ } from '../../data/faq';

interface Props {}
---

<section class="faq-section" id="faq">
  <div class="container">
    <header class="section-header-simple">
      <h2 class="section-title">
        Common <span class="text-gold">Questions</span>
      </h2>
      <p class="section-subtitle">
        Everything you need to know before scheduling a repair
      </p>
    </header>

    <div class="faq-list">
      {HOMEPAGE_FAQ.map((item, index) => (
        <details class="faq-item" open={index === 0}>
          <summary class="faq-question">
            <span class="faq-question-text">{item.question}</span>
            <span class="faq-toggle" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="16" height="16" fill="none"
                   stroke="currentColor" stroke-width="2" stroke-linecap="round">
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </span>
          </summary>
          <div class="faq-answer">
            <p>{item.answer}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  /* Scoped tokens — match preview-homepage.html convention */
  .faq-section {
    --bg: #0a0a0a;
    --bg2: #151515;
    --bg3: #1a1a1a;
    --gold: #D4AF37;
    --red: #C8102E;
    --text: #ffffff;
    --text2: #d4d4d4;
    --text3: #888888;
    --border: rgba(255, 255, 255, 0.08);
    --border-gold: rgba(212, 175, 55, 0.4);

    background: var(--bg);
    color: var(--text);
    padding: 112px 24px;
  }

  .faq-section .container {
    max-width: 880px;
    margin: 0 auto;
  }

  .section-header-simple {
    text-align: center;
    margin-bottom: 56px;
  }

  .section-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(28px, 3.4vw, 44px);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0 0 16px 0;
    color: var(--text);
  }

  .text-gold {
    color: var(--gold);
    font-style: italic;
  }

  .section-subtitle {
    color: var(--text2);
    font-family: 'Montserrat', sans-serif;
    font-size: 16px;
    max-width: 640px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .faq-item {
    background: var(--bg2);
    border: 1px solid var(--border);
    transition: border-color 0.3s ease;
  }
  .faq-item[open] {
    border-color: var(--border-gold);
  }

  .faq-question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    padding: 24px 28px;
    cursor: pointer;
    list-style: none;
    user-select: none;
  }
  .faq-question::-webkit-details-marker { display: none; }

  .faq-question-text {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 18px;
    font-weight: 500;
    color: var(--text);
    line-height: 1.4;
    transition: color 0.3s ease;
  }
  .faq-question:hover .faq-question-text,
  .faq-question:focus-visible .faq-question-text {
    color: var(--gold);
  }

  .faq-toggle {
    color: var(--gold);
    flex-shrink: 0;
    transition: transform 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .faq-item[open] .faq-toggle {
    transform: rotate(180deg);
  }

  .faq-answer {
    padding: 0 28px 28px 28px;
  }
  .faq-answer p {
    font-family: 'Montserrat', sans-serif;
    font-size: 15px;
    line-height: 1.75;
    color: var(--text2);
    margin: 0;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .faq-section { padding: 80px 16px; }
    .faq-question { padding: 20px 20px; }
    .faq-question-text { font-size: 16px; }
    .faq-answer { padding: 0 20px 20px 20px; }
    .faq-answer p { font-size: 14px; }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .faq-toggle,
    .faq-item,
    .faq-question-text {
      transition: none;
    }
  }
</style>
