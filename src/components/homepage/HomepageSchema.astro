---
// HomepageSchema.astro
//
// Step 5: Generates JSON-LD structured data for the homepage using @graph
// format. Renders one <script type="application/ld+json"> block injected
// into <head> via Layout's `head-scripts` slot.
//
// Entities (11 total):
//   1. Organization (Same Day Appliance Repair — DBA, NOT HVAC 777 LLC)
//   2. WebSite
//   3. WebPage (homepage)
//   4-11. LocalBusiness × 8 (1 physical_pin + 7 service_area)
//
// All entities cross-reference via @id URIs.
//
// NAP rules (per wiki/decisions/branch-types-and-public-nap-rules.md):
//   - Only physical_pin (West Hollywood) renders address + root geo + hasMap
//   - service_area locations: NO address, NO root geo, ONLY serviceArea (GeoCircle)
//   - schema `name` = branch.gbpName (matches verified GBP listing word-for-word)
//   - HVAC 777 LLC NEVER appears in schema (only in footer legal compliance line)
//   - Internal addresses (Bellwind, Tiburon, Columbia Pl, etc.) NEVER in schema

import {
  BRANCHES,
  MAIN_PHONE,
  milesToMeters,
  type Branch
} from '../../data/branches';
import { HOMEPAGE_FAQ } from '../../data/faq';
import { CANONICAL_CREDENTIALS, LEGAL_NAME } from '../../data/credentials-schema';
import { OPENING_HOURS_SCHEMA } from '../../data/business-hours';
import { buildServiceCatalogSchema, SERVICE_CATALOG_REF } from '../../lib/build-service-catalog';

interface Props {}

const SITE_URL = 'https://samedayappliance.repair';
const ORG_ID = `${SITE_URL}/#organization`;
const WEBSITE_ID = `${SITE_URL}/#website`;
const WEBPAGE_ID = `${SITE_URL}/#webpage`;

function phoneE164(phone: string): string {
  return '+1' + phone.replace(/\D/g, '');
}

function branchId(slug: string): string {
  return `${SITE_URL}/#branch-${slug}`;
}

function slugToTitle(slug: string): string {
  return slug.split('-')
    .map(w => w.charAt(0).toUpperCase() + w.slice(1))
    .join(' ');
}

function hoursDaysToArray(days: string): string[] {
  const all = ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'];
  if (days === 'Mon-Sun') return all;
  if (days === 'Mon-Sat') return all.slice(0, 6);
  if (days === 'Mon-Fri') return all.slice(0, 5);
  return all;
}

function countyTitle(slug: Branch['primaryCounty']): string {
  // primaryCounty values are 'los-angeles' | 'orange' | 'ventura' |
  // 'san-bernardino' | 'riverside' — Title-Case + " County" suffix.
  return slugToTitle(slug) + ' County';
}

function buildLocalBusiness(branch: Branch): Record<string, unknown> {
  const base: Record<string, unknown> = {
    '@type': ['LocalBusiness', 'HomeAndConstructionBusiness'],
    '@id': branchId(branch.slug),
    name: branch.gbpName,
    legalName: LEGAL_NAME,
    url: `${SITE_URL}/`,
    telephone: phoneE164(branch.phone),
    email: branch.email,
    image: `${SITE_URL}/images/branches/${branch.slug}.jpg`,
    priceRange: '$$',
    openingHoursSpecification: OPENING_HOURS_SCHEMA,
    areaServed: branch.citiesServed.map(citySlug => ({
      '@type': 'City',
      name: slugToTitle(citySlug),
      containedInPlace: {
        '@type': 'AdministrativeArea',
        name: countyTitle(branch.primaryCounty)
      }
    })),
    parentOrganization: { '@id': ORG_ID },
    // Site-wide canonical credentials (BHGS / EPA 608 / CSLB C-20 / BBB).
    // Emitted on every LocalBusiness for NAP/credential consistency across
    // graph entries — matches docs/seo-policies.md §1 (FINAL 2026-05-07)
    // and the Organization node in this same @graph.
    hasCredential: [...CANONICAL_CREDENTIALS]
  };

  // physical_pin: full PostalAddress (with streetAddress) + root geo
  if (branch.type === 'physical_pin' && branch.address) {
    base.address = {
      '@type': 'PostalAddress',
      streetAddress: branch.address.street,
      addressLocality: branch.address.city,
      addressRegion: branch.address.state,
      postalCode: branch.address.zip,
      addressCountry: 'US'
    };
    if (typeof branch.address.lat === 'number' && typeof branch.address.lng === 'number') {
      base.geo = {
        '@type': 'GeoCoordinates',
        latitude: branch.address.lat,
        longitude: branch.address.lng
      };
    }
  }

  // service_area: emit PostalAddress with locality/region/postalCode but
  // NEVER streetAddress — required by Google SAB guidelines and enforced
  // by branches.ts header (line 5-9). Falls back to displayCity when
  // internalAddress is absent (LA/BH/RC have no zip on record yet).
  // Also emit GeoCircle as serviceArea — never root geo.
  if (branch.type === 'service_area') {
    const sabAddress: Record<string, unknown> = {
      '@type': 'PostalAddress',
      addressLocality: branch.internalAddress?.city ?? branch.displayCity,
      addressRegion: 'CA',
      addressCountry: 'US'
    };
    if (branch.internalAddress?.zip) {
      sabAddress.postalCode = branch.internalAddress.zip;
    }
    base.address = sabAddress;

    base.serviceArea = {
      '@type': 'GeoCircle',
      geoMidpoint: {
        '@type': 'GeoCoordinates',
        latitude: branch.geo.cityCenterLat,
        longitude: branch.geo.cityCenterLng
      },
      geoRadius: milesToMeters(branch.geo.serviceRadius).toString()
    };
  }

  // hasMap only for branches with a real (non-TODO) GBP URL
  if (branch.gbpUrl && !branch.gbpUrl.startsWith('TODO_')) {
    base.hasMap = branch.gbpUrl;
  }

  // sameAs — branch-level cross-link signals (verified GBP place_id maps URL,
  // and YouTube channel; WeHo additionally carries Facebook profile since the
  // FB account is anchored to the WeHo physical pin). Source: branch.sameAs in
  // src/data/branches.ts. Emitted only when at least one URL is configured —
  // empty/undefined arrays are skipped (defensive: avoids `"sameAs": []`).
  if (Array.isArray(branch.sameAs) && branch.sameAs.length > 0) {
    base.sameAs = [...branch.sameAs];
  }

  // hasOfferCatalog — @id reference to the canonical OfferCatalog graph node
  // defined elsewhere in this @graph. All 8 LocalBusiness point at the same
  // catalog (#service-catalog) rather than embedding 48 services 8 times.
  base.hasOfferCatalog = SERVICE_CATALOG_REF;

  // aggregateRating intentionally omitted per NAP/Rating SSOT Rule 3
  // (wiki/decisions/nap-rating-policy-ssot.md) — body and schema ratings
  // are removed everywhere until GMB API integration.

  return base;
}

const graph: Array<Record<string, unknown>> = [
  // 1. Organization
  {
    '@type': 'Organization',
    '@id': ORG_ID,
    name: 'Same Day Appliance Repair',
    alternateName: 'SDAR',
    legalName: LEGAL_NAME,
    url: SITE_URL,
    logo: {
      '@type': 'ImageObject',
      url: `${SITE_URL}/logo.png`,
      width: 512,
      height: 512
    },
    // Organization-level sameAs — org-wide social profiles (FB + YT). The
    // verified GBP listings live at the per-branch LocalBusiness level via
    // branch.sameAs (place_id maps URLs), not duplicated here. Older
    // share.google/* shortened links replaced with the canonical maps
    // place_id form on the branch entries.
    sameAs: [
      'https://www.facebook.com/profile.php?id=61577069941613',
      'https://www.youtube.com/@SameDayAppliance.Repair'
    ],
    contactPoint: [{
      '@type': 'ContactPoint',
      telephone: phoneE164(MAIN_PHONE),
      contactType: 'customer service',
      areaServed: 'US-CA',
      availableLanguage: ['en']
    }],
    hasCredential: [...CANONICAL_CREDENTIALS],
    // hasOfferCatalog — @id ref to the canonical OfferCatalog node below.
    // Same anchor that all 8 LocalBusiness point at (single SSOT, no payload
    // duplication across entities in this graph).
    hasOfferCatalog: SERVICE_CATALOG_REF
  },

  // 2. WebSite
  {
    '@type': 'WebSite',
    '@id': WEBSITE_ID,
    url: SITE_URL,
    name: 'Same Day Appliance Repair',
    publisher: { '@id': ORG_ID },
    inLanguage: 'en-US'
  },

  // 3. WebPage
  {
    '@type': 'WebPage',
    '@id': WEBPAGE_ID,
    url: SITE_URL + '/',
    name: 'Same Day Appliance Repair — Los Angeles & Southern California',
    description:
      'Same-day appliance repair across 5 SoCal counties. Residential, commercial kitchen, cold storage, outdoor. BHGS #A49573, BBB Accredited, EPA 608, CSLB C-20.',
    inLanguage: 'en-US',
    isPartOf: { '@id': WEBSITE_ID },
    about: { '@id': ORG_ID },
    primaryImageOfPage: {
      '@type': 'ImageObject',
      url: `${SITE_URL}/og-homepage.jpg`
    }
  },

  // 4-11. LocalBusiness × 8 (1 physical_pin + 7 service_area)
  ...BRANCHES.map(buildLocalBusiness),

  // 12. OfferCatalog — canonical service catalog (6 sub-catalogs / 48 services).
  // Defined HERE on the homepage @graph; all other pages (LocalBusiness on
  // city pillars, contact location array, etc.) reference this via
  // `{ "@id": "https://samedayappliance.repair/#service-catalog" }`. SSOT
  // lives in src/data/service-catalog.ts; renderer in src/lib/build-service-catalog.ts.
  buildServiceCatalogSchema(),

  // 12. FAQPage — 10 Q/A pairs from src/data/faq.ts
  // (Same content as the visible accordion in FAQ.astro for NAP-style consistency
  //  between visible content and rich-result eligibility.)
  {
    '@type': 'FAQPage',
    '@id': `${SITE_URL}/#faq`,
    inLanguage: 'en-US',
    isPartOf: { '@id': WEBPAGE_ID },
    mainEntity: HOMEPAGE_FAQ.map(item => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.answer
      }
    }))
  }
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': graph
};
---

<script type="application/ld+json" set:html={JSON.stringify(jsonLd, null, 2)} />
