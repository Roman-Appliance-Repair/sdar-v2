---
// Hero.astro — Homepage hero section
//
// Step 4-fix: exact 1-to-1 visual replica of public/preview-homepage.html
// hero (lines 1576-1657) with TWO text changes per spec:
//   1. Subheading rewritten to lead with "Headquartered in West Hollywood."
//   2. (Topbar change is in TrustBar.astro, not here.)
//
// Class names match preview verbatim so visual treatment is identical.
// Branch list is data-driven from BRANCHES; phones rendered as-is.

import { BRANCHES, MAIN_PHONE } from '../../data/branches';

interface Props {}

const HERO_BRANCH_ORDER = [
  'pasadena',
  'west-hollywood',
  'beverly-hills',
  'los-angeles',
  'thousand-oaks',
  'irvine',
  'rancho-cucamonga',
  'riverside'
];

const heroBranches = HERO_BRANCH_ORDER
  .map(slug => BRANCHES.find(b => b.slug === slug))
  .filter((b): b is NonNullable<typeof b> => b !== undefined);

function telLink(phone: string): string {
  return 'tel:+1' + phone.replace(/\D/g, '');
}

const bullets = [
  { strong: 'Same day service',     desc: '7 days a week' },
  { strong: '85% fixed first visit', desc: 'techs stock 200+ OEM parts' },
  { strong: 'Licensed & Insured',    desc: 'BHGS #A49573, BBB Accredited' },
  { strong: '90-day warranty',       desc: 'on all repairs' }
];

// Background image is set in scoped CSS below: gradient overlay + real
// Sub-Zero technician photo (Artlist, processed via scripts/process-hero-image.mjs
// into desktop WebP/JPG and mobile WebP variants under /images/hero/).
---

<section class="hero-section" id="hero">
  <div class="hero-overlay">
    <div class="hero-content-box">
      <p class="hero-eyebrow">Same Day Appliance Repair — Est. Southern California</p>

      <h1 class="hero-title">
        Same Day Appliance Repair —
        <span class="text-red">Los Angeles</span> &amp;
        <span class="text-gold">Southern California</span>
      </h1>

      <p class="hero-description">
        Headquartered in West Hollywood with service across Los Angeles, Orange,
        Ventura, San Bernardino, and Riverside counties. Over 10 years repairing
        Southern California’s homes and businesses — fully licensed (BHGS #A49573),
        insured, and staffed by background-checked technicians factory-trained on
        every major brand. Our priority is doing the job right the first time,
        with honest diagnostics and transparent pricing on every visit.
      </p>

      <div class="hero-two-cols">
        <div class="hero-bullets">
          {bullets.map(b => (
            <div class="bullet-item">
              <span class="bullet-icon">◆</span>
              <span class="bullet-text"><strong>{b.strong}</strong> — {b.desc}</span>
            </div>
          ))}
        </div>

        <div class="hero-branches">
          <h3 class="branches-header">Our Branches</h3>
          {heroBranches.map(b => (
            <div class="branch-item-hero">
              <span class="branch-icon">📍</span>
              <span class="branch-city">{b.name}</span> —
              <a href={telLink(b.phone)} class="branch-phone-hero">{b.phone}</a>
            </div>
          ))}
        </div>
      </div>

      <div class="hero-cta">
        <a href={telLink(MAIN_PHONE)} class="btn-primary">CALL {MAIN_PHONE}</a>
        <a href="/book/" class="btn-secondary">BOOK ONLINE</a>
      </div>
    </div>
  </div>
</section>

<style>
  /* Scoped tokens — match preview-homepage.html :root values 1-to-1 so the
     visual is byte-identical. Declared on the section so descendants inherit. */
  .hero-section {
    --bg: #0a0a0a;
    --bg2: #151515;
    --bg3: #1a1a1a;
    --red: #C8102E;
    --red-h: #e0152f;
    --red-glow: rgba(200, 16, 46, 0.3);
    --gold: #D4AF37;
    --gold-h: #e5c254;
    --gold-dim: rgba(212, 175, 55, 0.2);
    --text: #ffffff;
    --text2: #d4d4d4;
    --text3: #888888;
    --border: rgba(255, 255, 255, 0.08);
    --border2: rgba(255, 255, 255, 0.15);

    position: relative;
    min-height: 100vh;
    /* JPG fallback for browsers that don't understand image-set() */
    background-image:
      linear-gradient(135deg, rgba(10,10,10,0.5), rgba(200,16,46,0.3)),
      url('/images/hero/hero-technician-subzero.jpg');
    background-image:
      linear-gradient(135deg, rgba(10,10,10,0.5), rgba(200,16,46,0.3)),
      image-set(
        url('/images/hero/hero-technician-subzero.webp') type('image/webp'),
        url('/images/hero/hero-technician-subzero.jpg') type('image/jpeg')
      );
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    display: flex;
    align-items: center;
    padding: 60px 0;
    color: var(--text);
    font-family: 'Montserrat', -apple-system, BlinkMacSystemFont, sans-serif;
  }

  .hero-overlay {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .hero-content-box {
    max-width: 50%;
    background: rgba(10, 10, 10, 0.75);
    -webkit-backdrop-filter: blur(8px);
    backdrop-filter: blur(8px);
    padding: 48px;
    border-radius: 0;
    border: 1px solid var(--border);
  }

  .hero-eyebrow {
    font-family: 'Cinzel', serif;
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold);
    margin: 0 0 16px 0;
    font-weight: 600;
  }

  .hero-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 48px;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 20px 0;
    color: #ffffff;
  }
  .hero-title .text-red { color: var(--red); font-style: italic; }
  .hero-title .text-gold { color: var(--gold); }

  .hero-description {
    font-family: 'Montserrat', sans-serif;
    font-size: 15px;
    line-height: 1.6;
    color: var(--text2);
    margin: 0 0 32px 0;
    padding-left: 16px;
    border-left: 2px solid var(--gold);
  }

  .hero-two-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
    margin-bottom: 32px;
  }

  .hero-bullets {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .bullet-item {
    display: flex;
    gap: 12px;
    font-size: 14px;
    line-height: 1.6;
    color: var(--text2);
  }
  .bullet-icon {
    color: var(--gold);
    flex-shrink: 0;
    font-size: 12px;
    margin-top: 4px;
    font-family: 'Cinzel', serif;
  }
  .bullet-text strong { color: var(--text); font-weight: 600; }

  .hero-branches {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .branches-header {
    font-family: 'Cinzel', serif;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--gold);
    margin: 0 0 12px 0;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
    font-weight: 600;
  }
  .branch-item-hero {
    font-size: 14px;
    line-height: 1.6;
    color: var(--text3);
    display: flex;
    gap: 8px;
    align-items: baseline;
    margin-bottom: 6px;
  }
  .branch-icon {
    flex-shrink: 0;
    font-size: 12px;
  }
  .branch-city {
    font-weight: 600;
    color: var(--text2);
    font-size: 14px;
    min-width: 180px;
    white-space: nowrap;
  }
  .branch-phone-hero {
    color: var(--gold);
    font-weight: 600;
    font-size: 14px;
    text-decoration: none;
    font-variant-numeric: tabular-nums;
    transition: color 0.3s;
    white-space: nowrap;
  }
  .branch-phone-hero:hover { color: var(--red); }

  .hero-cta {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }
  .btn-primary {
    background: var(--red);
    border: 1px solid transparent;
    color: #ffffff;
    padding: 14px 28px;
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-decoration: none;
    transition: all 0.3s;
    display: inline-block;
  }
  .btn-primary:hover {
    border-color: var(--gold);
    box-shadow: 0 0 24px var(--red-glow);
  }
  .btn-secondary {
    background: transparent;
    border: 1px solid var(--gold);
    color: var(--gold);
    padding: 14px 28px;
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-decoration: none;
    transition: all 0.3s;
    display: inline-block;
  }
  .btn-secondary:hover { background: var(--gold-dim); }

  /* ── Responsive — match preview breakpoints ── */
  @media (max-width: 1024px) {
    .hero-content-box { max-width: 60%; padding: 36px; }
    .hero-title { font-size: 36px; }
  }

  @media (max-width: 768px) {
    .hero-section {
      background-image:
        linear-gradient(135deg, rgba(10,10,10,0.6), rgba(200,16,46,0.35)),
        url('/images/hero/hero-technician-subzero-mobile.webp');
    }
    .hero-content-box { max-width: 100%; padding: 32px 24px; }
    .hero-two-cols { grid-template-columns: 1fr; gap: 24px; }
    .hero-title { font-size: 32px; }
    .hero-cta { flex-direction: column; }
    .btn-primary, .btn-secondary { text-align: center; }
  }

  @media (max-width: 640px) {
    .hero-section { min-height: auto; padding: 40px 0; }
  }
</style>
