---
// Hero.astro — Homepage hero section
//
// Status: SCAFFOLD (Step 3) — content fills in during Step 4
//
// Will render: full-screen luxury editorial hero with split layout
//   - Eyebrow: "Same Day Appliance Repair · Est. Southern California"
//   - H1 with --red and --gold color spans
//   - Subheading: 7 service locations summary
//   - 4 trust bullets
//   - 7 location list with phone links (HEADQUARTERS + SERVICE_AREAS, only active phones)
//   - 2 CTAs (Call + Book Online)

import { HEADQUARTERS, SERVICE_AREAS, MAIN_PHONE } from '../../data/branches';

interface Props {
  // Empty — Hero is fully data-driven from BRANCHES.
}
---

<section class="hero" id="hero">
  <div class="container">
    <p class="hero-eyebrow">Hero — scaffold (Step 3)</p>
    <h1 class="hero-title">
      Hero scaffold —
      <span class="text-red">content</span> in
      <span class="text-gold">Step 4</span>
    </h1>
    <p class="hero-subtitle">
      Will render: 7 service locations including {HEADQUARTERS.name} HQ and
      {SERVICE_AREAS.length} service territories. Main phone {MAIN_PHONE}.
    </p>
  </div>
</section>

<style>
  .hero {
    min-height: 60vh;
    background: var(--bg, #0a0a0a);
    color: var(--text, #ffffff);
    padding: 120px 24px;
    display: flex;
    align-items: center;
    border-bottom: 1px dashed rgba(212, 175, 55, 0.4);
  }
  .hero .container {
    max-width: 1280px;
    margin: 0 auto;
    width: 100%;
  }
  .hero-eyebrow {
    color: #D4AF37;
    font-family: 'Cinzel', serif;
    font-size: 12px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    margin: 0 0 24px 0;
  }
  .hero-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(36px, 5vw, 64px);
    line-height: 1.1;
    margin: 0 0 24px 0;
    color: #ffffff;
  }
  .hero-title .text-red { color: #C8102E; }
  .hero-title .text-gold { color: #D4AF37; font-style: italic; }
  .hero-subtitle {
    color: #d4d4d4;
    font-family: 'Montserrat', sans-serif;
    font-size: 16px;
    line-height: 1.75;
    max-width: 680px;
    margin: 0;
  }
</style>
