---
// ServiceArea.astro — Unified Service Area section
//
// Step 4.5: replaces the Step 3 scaffold with full Variant A content
// (header → CountyMap → branches grouped by county → CTA).
//
// Visual styling matches preview-homepage.html Section 06 (BRANCHES):
//   - .county-header: Montserrat 10px bold red small caps
//   - .branch-title: Montserrat 20px bold white, embedded gold .branch-phone
//   - .cities-grid: 5-column auto grid, 6/12 gap; collapses on smaller widths
//   - .city-item: Montserrat 14px text3, gold on hover
//
// NAP rules: SAB locations show city + phone only (no street). RC and
// Temecula 555 placeholders render as-is until Monday DID swap.

import CountyMap from './CountyMap.astro';
import {
  BRANCHES,
  CITIES_WITHOUT_PAGES,
  TOTAL_CITIES_WITH_PAGES,
  type Branch,
} from '../../data/branches';
import { COUNTIES, type CountySlug } from '../../data/cities';

interface Props {}

// Same display order as Hero — keeps narrative consistent across the page.
const HERO_BRANCH_ORDER = [
  'pasadena',
  'west-hollywood',
  'los-angeles',
  'thousand-oaks',
  'irvine',
  'rancho-cucamonga',
  'temecula',
];

const COUNTY_ORDER: CountySlug[] = [
  'los-angeles',
  'ventura',
  'orange',
  'san-bernardino',
  'riverside',
];

const branchesByCounty = COUNTY_ORDER.map(countySlug => ({
  county: countySlug,
  countyName: COUNTIES[countySlug].name,
  countyHubUrl: COUNTIES[countySlug].hubUrl,
  branches: HERO_BRANCH_ORDER
    .map(slug => BRANCHES.find(b => b.slug === slug))
    .filter((b): b is Branch => b !== undefined && b.primaryCounty === countySlug),
}));

function citySlugToTitle(slug: string): string {
  return slug.split('-')
    .map(w => w.charAt(0).toUpperCase() + w.slice(1))
    .join(' ');
}

function telLink(phone: string): string {
  return 'tel:+1' + phone.replace(/\D/g, '');
}
---

<section class="service-area" id="service-area">
  <div class="container">

    <header class="section-header-simple">
      <h2 class="section-title">
        Our <span class="text-gold">Service Area</span>
      </h2>
      <p class="section-subtitle">
        Headquartered in West Hollywood · {TOTAL_CITIES_WITH_PAGES} cities ·
        7 service locations across Southern California
      </p>
    </header>

    <div class="map-wrapper">
      <CountyMap />
    </div>

    <div class="branches-by-county">
      {branchesByCounty.map(({ countyName, countyHubUrl, branches }) => (
        branches.length > 0 && (
          <div class="county-section">
            <a
              href={countyHubUrl}
              class="county-header-link"
              aria-label={`View ${countyName} service area page`}
            >
              <h3 class="county-header">{countyName.toUpperCase()}</h3>
            </a>

            {branches.map(branch => (
              <div class="branch-group">
                <h4 class="branch-title">
                  {branch.name} Branch —
                  <a
                    href={telLink(branch.phone)}
                    class="branch-phone"
                    aria-label={`Call ${branch.name} branch at ${branch.phone}`}
                  >{branch.phone}</a>
                </h4>

                <div class="cities-grid">
                  {branch.citiesServed.map(citySlug => {
                    const isServeable = !CITIES_WITHOUT_PAGES.has(citySlug);
                    const cityName = citySlugToTitle(citySlug);
                    return isServeable ? (
                      <a href={`/${citySlug}/`} class="city-item city-link">{cityName}</a>
                    ) : (
                      <span class="city-item city-static">{cityName}</span>
                    );
                  })}
                </div>
              </div>
            ))}
          </div>
        )
      ))}
    </div>

    <div class="service-area-cta">
      <a href="/areas/" class="btn-secondary">View All Cities →</a>
    </div>

  </div>
</section>

<style>
  /* Scoped tokens — match preview-homepage.html :root values 1-to-1. */
  .service-area {
    --bg: #0a0a0a;
    --bg2: #151515;
    --bg3: #1a1a1a;
    --gold: #D4AF37;
    --gold-h: #e5c254;
    --gold-dim: rgba(212, 175, 55, 0.2);
    --red: #C8102E;
    --red-h: #e0152f;
    --red-glow: rgba(200, 16, 46, 0.3);
    --red-dim: rgba(200, 16, 46, 0.05);
    --text: #ffffff;
    --text2: #d4d4d4;
    --text3: #888888;
    --text4: #555555;
    --border: rgba(255, 255, 255, 0.08);
    --border-gold: rgba(212, 175, 55, 0.4);

    background: var(--bg);
    color: var(--text);
    padding: 112px 0;
    font-family: 'Montserrat', -apple-system, BlinkMacSystemFont, sans-serif;
  }

  .service-area .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ── Header ── */
  .section-header-simple {
    text-align: center;
    margin-bottom: 16px;
  }
  .section-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(28px, 3.4vw, 48px);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #ffffff;
    margin: 0 0 16px 0;
  }
  .text-gold { color: var(--gold); font-style: italic; }
  .section-subtitle {
    font-family: 'Montserrat', sans-serif;
    font-size: 15px;
    line-height: 1.6;
    color: var(--text2);
    max-width: 800px;
    margin: 0 auto;
  }

  /* ── Map ── */
  .map-wrapper {
    margin: 56px 0;
  }

  /* ── County sections ── */
  .branches-by-county {
    margin-top: 56px;
  }
  .county-section {
    margin-bottom: 48px;
  }
  .county-section:last-child { margin-bottom: 0; }

  .county-header-link {
    text-decoration: none;
    display: block;
    margin-bottom: 16px;
    transition: color 0.3s;
  }
  .county-header {
    font-family: 'Montserrat', sans-serif;
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--red);
    margin: 0;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border-gold);
    transition: color 0.3s;
  }
  .county-header-link:hover .county-header,
  .county-header-link:focus-visible .county-header {
    color: var(--gold);
  }

  /* ── Branch group ── */
  .branch-group {
    margin-bottom: 28px;
    padding-bottom: 24px;
    border-bottom: 1px solid var(--border);
  }
  .branch-group:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }
  .branch-title {
    font-family: 'Montserrat', sans-serif;
    font-size: 20px;
    font-weight: 700;
    color: var(--text);
    margin: 0 0 14px 0;
  }
  .branch-phone {
    font-size: 20px;
    font-weight: 700;
    color: var(--gold);
    text-decoration: none;
    font-variant-numeric: tabular-nums;
    transition: color 0.3s;
    margin-left: 6px;
  }
  .branch-phone:hover,
  .branch-phone:focus-visible { color: var(--red); }

  /* ── Cities grid ── */
  .cities-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 8px 16px;
  }
  .city-item {
    font-family: 'Montserrat', sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: var(--text3);
    text-decoration: none;
    transition: color 0.3s;
  }
  .city-link:hover,
  .city-link:focus-visible {
    color: var(--gold);
  }
  .city-static {
    color: var(--text4);
    cursor: default;
    font-style: italic;
  }

  /* ── CTA ── */
  .service-area-cta {
    text-align: center;
    margin-top: 56px;
  }
  .btn-secondary {
    background: transparent;
    border: 1px solid var(--gold);
    color: var(--gold);
    padding: 14px 28px;
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-decoration: none;
    transition: all 0.3s;
    display: inline-block;
  }
  .btn-secondary:hover,
  .btn-secondary:focus-visible {
    background: var(--gold-dim);
    color: var(--gold-h);
  }

  /* ── Responsive ── */
  @media (max-width: 1024px) {
    .cities-grid { grid-template-columns: repeat(4, 1fr); }
  }
  @media (max-width: 768px) {
    .service-area { padding: 80px 0; }
    .map-wrapper { margin: 40px 0; }
    .branches-by-county { margin-top: 40px; }
    .cities-grid { grid-template-columns: repeat(3, 1fr); }
    .branch-title { font-size: 16px; }
    .branch-phone { font-size: 16px; }
    .county-header { font-size: 10px; }
  }
  @media (max-width: 640px) {
    .cities-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (prefers-reduced-motion: reduce) {
    .city-item, .branch-phone, .county-header, .btn-secondary {
      transition: none;
    }
  }
</style>
