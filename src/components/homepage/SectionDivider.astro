---
// SectionDivider.astro — minimal centered gold rule between homepage sections.
// Purely presentational; no props.
---

<div class="section-divider" role="presentation" aria-hidden="true">
  <span class="section-divider-line"></span>
</div>

<style>
  .section-divider {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 100%;
    margin: 40px auto;
  }

  .section-divider-line {
    display: block;
    width: 100%;
    max-width: 200px;
    height: 1px;
    background-color: #D4AF37;
    opacity: 0.15;
  }

  @media (max-width: 768px) {
    .section-divider { margin: 24px auto; }
  }
</style>
