---
// HomepageFooter.astro — Optional homepage-specific footer
//
// Status: SCAFFOLD (Step 3) — decision in Step 6 whether to use this or
// delegate to Layout.astro's standard <Footer />.
//
// Will render (if used): 4-column footer (Company / Services / Branches /
// Contact) styled to match the preview-homepage luxury treatment, including
// the legal compliance line with HVAC 777 LLC + mailing PMB + BHGS #A49573.
//
// NAP rule: legal entity name appears ONLY here (compliance line), never in
// schema name/legalName. See wiki/decisions/branch-types-and-public-nap-rules.md

import { LEGAL_ADDRESS, MAIN_PHONE, BRANCHES } from '../../data/branches';

interface Props {}

const activeBranches = BRANCHES.filter(b => b.phoneStatus === 'active');
---

<footer class="homepage-footer" role="contentinfo">
  <div class="container">
    <p class="scaffold-note">
      [Scaffold] Homepage footer renders in Step 6 — 4 columns + legal line.
      Will reference {activeBranches.length} active branches and main phone {MAIN_PHONE}.
    </p>
    <p class="legal-line">
      {LEGAL_ADDRESS.entity} · {LEGAL_ADDRESS.street}, {LEGAL_ADDRESS.city}{' '}
      {LEGAL_ADDRESS.state} {LEGAL_ADDRESS.zip} · BHGS #A49573 · BBB A+ ·
      © {new Date().getFullYear()} Same Day Appliance Repair
    </p>
  </div>
</footer>

<style>
  .homepage-footer {
    background: #0a0a0a;
    color: #d4d4d4;
    padding: 64px 24px 32px;
    border-top: 1px solid rgba(212, 175, 55, 0.2);
  }
  .homepage-footer .container { max-width: 1280px; margin: 0 auto; }
  .scaffold-note {
    padding: 24px;
    border: 1px dashed rgba(212, 175, 55, 0.4);
    color: #888;
    text-align: center;
    margin: 0 0 24px 0;
  }
  .legal-line {
    color: #888;
    font-size: 12px;
    text-align: center;
    margin: 0;
    line-height: 1.7;
  }
</style>
