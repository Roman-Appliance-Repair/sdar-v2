---
// Services.astro — Residential + Commercial tabbed service catalog
//
// Step 7 of homepage redesign sprint, with post-launch fixes:
//   - Single-column menu (was 2-col grid)
//   - Chip-button baseline for ALL items (active state ADDS emphasis)
//   - Both menus rendered in SSR (tab switch toggles visibility, no JS rebuild
//     of the menu — preserves Astro scoped CSS on items)
//   - Right photo card stretches to match menu height; photo flex-fills the
//     remaining vertical space inside the card
//
// URL resolution is done at build time against src/pages/. If a service id
// (or its `urlSlug` override) maps to an existing page, the menu links there;
// otherwise it falls back to /book/.

import fs from 'node:fs';
import path from 'node:path';

import {
  RESIDENTIAL_SERVICES,
  COMMERCIAL_SERVICES,
  type HomepageService,
} from '../../data/homepage-services';
import { BRANCHES } from '../../data/branches';

const SRC_PAGES = path.resolve('./src/pages');
const pageExists = (rel: string) => fs.existsSync(path.join(SRC_PAGES, rel));

function resolveServiceUrl(svc: HomepageService): string {
  if (svc.urlSlug) {
    const dir = svc.category === 'residential' ? 'services' : 'commercial';
    if (pageExists(`${dir}/${svc.urlSlug}.astro`)) return `/${dir}/${svc.urlSlug}/`;
  }
  const cleanId = svc.id.replace(/^comm-/, '').replace(/-comm$/, '');
  const candidates =
    svc.category === 'residential'
      ? [`services/${cleanId}-repair.astro`, `${cleanId}-repair.astro`]
      : [
          `commercial/${cleanId}-repair.astro`,
          `commercial/${cleanId}.astro`,
          `${cleanId}-repair.astro`,
        ];
  for (const cand of candidates) {
    if (pageExists(cand)) return '/' + cand.replace(/\.astro$/, '/');
  }
  return '/book/';
}

interface ResolvedService extends HomepageService {
  url: string;
}

const residential: ResolvedService[] = RESIDENTIAL_SERVICES.map((s) => ({
  ...s,
  url: resolveServiceUrl(s),
}));
const commercial: ResolvedService[] = COMMERCIAL_SERVICES.map((s) => ({
  ...s,
  url: resolveServiceUrl(s),
}));

const laBranch = BRANCHES.find((b) => b.slug === 'los-angeles');
const callPhone = laBranch?.phone ?? '(424) 325-0520';
const callPhoneE164 = '+1' + callPhone.replace(/\D/g, '');

const residentialJson = JSON.stringify(residential);
const commercialJson = JSON.stringify(commercial);

// Photos live in two directories — residential at /images/services/, commercial
// at /images/comm-services/ — and ship at different aspect ratios (4:5 vs 4:3).
function photoBase(svc: HomepageService): string {
  return svc.category === 'residential'
    ? `/images/services/${svc.id}`
    : `/images/comm-services/${svc.id}`;
}
const initial = residential[0];
const initialPhotoBase = photoBase(initial);
---

<section class="services-section" id="services">
  <div class="container">
    <header class="section-header-simple">
      <h2 class="section-title">
        Residential <span class="text-gold">+</span> Commercial
      </h2>
    </header>
    <p class="section-subtitle">
      Full coverage across home appliances and commercial restaurant / hotel / agricultural equipment.
    </p>

    <div class="services-tabs" role="tablist">
      <button class="tab active" data-type="residential" role="tab" aria-selected="true">Residential</button>
      <button class="tab" data-type="commercial" id="commercial" role="tab" aria-selected="false">Commercial</button>
    </div>

    <div class="services-container residential" data-active="residential">
      {/* Both menus are rendered server-side so tab switching only toggles
          visibility — no innerHTML rebuild that would strip Astro scoping. */}
      <div class="services-menu" data-tab="residential">
        {residential.map((s, idx) => (
          <button
            class={`service-item${idx === 0 ? ' active' : ''}`}
            data-service={s.id}
            type="button"
          >
            {s.name}
          </button>
        ))}
      </div>
      <div class="services-menu" data-tab="commercial">
        {commercial.map((s, idx) => (
          <button
            class={`service-item${idx === 0 ? ' active' : ''}`}
            data-service={s.id}
            type="button"
          >
            {s.name}
          </button>
        ))}
      </div>

      <div class="services-content">
        <div class="service-display">
          <div class="service-photo">
            <picture>
              <source srcset={`${initialPhotoBase}.webp`} type="image/webp" />
              <img
                src={`${initialPhotoBase}.jpg`}
                alt={`${initial.name} — Same Day Appliance Repair`}
                loading="eager"
              />
            </picture>
          </div>
          <h3 class="service-name">{initial.name}</h3>
          <p class="service-desc">{initial.desc}</p>
          <div class="service-actions">
            <a href={initial.url} class="btn-secondary">Learn More →</a>
            <a href={`tel:${callPhoneE164}`} class="btn-primary">Call {callPhone}</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script
  is:inline
  define:vars={{ residential: residentialJson, commercial: commercialJson, callPhone, callPhoneE164 }}
>
  (function () {
    const RES = JSON.parse(residential);
    const COMM = JSON.parse(commercial);

    const root = document.getElementById('services');
    if (!root) return;
    const tabs = root.querySelectorAll('.services-tabs .tab');
    const container = root.querySelector('.services-container');
    const menus = {
      residential: root.querySelector('.services-menu[data-tab="residential"]'),
      commercial: root.querySelector('.services-menu[data-tab="commercial"]'),
    };
    const content = root.querySelector('.services-content');
    if (!container || !menus.residential || !menus.commercial || !content) return;

    function escapeHtml(s) {
      return String(s)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    function photoBase(item) {
      const dir = item.category === 'residential' ? 'services' : 'comm-services';
      return '/images/' + dir + '/' + item.id;
    }

    function renderPhoto(item, eager) {
      const base = photoBase(item);
      const alt = escapeHtml(item.name + ' — Same Day Appliance Repair');
      const loading = eager ? 'eager' : 'lazy';
      return (
        '<picture>' +
        '<source srcset="' + base + '.webp" type="image/webp" />' +
        '<img src="' + base + '.jpg" alt="' + alt + '" loading="' + loading + '" />' +
        '</picture>'
      );
    }

    function renderContent(item, eager) {
      content.innerHTML =
        '<div class="service-display">' +
        '<div class="service-photo">' +
        renderPhoto(item, eager) +
        '</div>' +
        '<h3 class="service-name">' + escapeHtml(item.name) + '</h3>' +
        '<p class="service-desc">' + escapeHtml(item.desc) + '</p>' +
        '<div class="service-actions">' +
        '<a href="' + escapeHtml(item.url) + '" class="btn-secondary">Learn More →</a>' +
        '<a href="tel:' + escapeHtml(callPhoneE164) + '" class="btn-primary">Call ' + escapeHtml(callPhone) + '</a>' +
        '</div>' +
        '</div>';
    }

    function attachMenuListeners(menuEl, items) {
      menuEl.querySelectorAll('.service-item').forEach((btn, idx) => {
        btn.addEventListener('click', () => {
          menuEl.querySelectorAll('.service-item').forEach((b) => b.classList.remove('active'));
          btn.classList.add('active');
          renderContent(items[idx], false);
        });
      });
    }

    function activateTab(type) {
      const items = type === 'commercial' ? COMM : RES;
      tabs.forEach((t) => {
        const isActive = t.dataset.type === type;
        t.classList.toggle('active', isActive);
        t.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });
      container.className = 'services-container ' + type;
      container.setAttribute('data-active', type);
      // Reset active highlight to first item in the newly-shown menu
      const menuEl = menus[type];
      menuEl.querySelectorAll('.service-item').forEach((b, i) => {
        b.classList.toggle('active', i === 0);
      });
      renderContent(items[0], true);
    }

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => activateTab(tab.dataset.type));
    });

    attachMenuListeners(menus.residential, RES);
    attachMenuListeners(menus.commercial, COMM);
  })();
</script>

<style>
  .services-section {
    --bg: #0a0a0a;
    --bg2: #151515;
    --bg3: #1a1a1a;
    --red: #C8102E;
    --red-dim: rgba(200, 16, 46, 0.05);
    --red-glow: rgba(200, 16, 46, 0.3);
    --gold: #D4AF37;
    --gold-h: #e5c254;
    --gold-dim: rgba(212, 175, 55, 0.2);
    --text: #ffffff;
    --text2: #d4d4d4;
    --text3: #888888;
    --border: rgba(255, 255, 255, 0.08);
    --border2: rgba(255, 255, 255, 0.15);

    background: var(--bg);
    color: var(--text);
    padding: 70px 24px;
    position: relative;
  }
  .services-section .container {
    max-width: 1280px;
    margin: 0 auto;
  }

  .section-header-simple {
    text-align: center;
    margin-bottom: 16px;
  }
  .section-header-simple .section-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 32px;
    font-weight: 700;
    color: var(--text);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0;
  }
  .text-gold { color: var(--gold); font-style: italic; font-weight: 600; }
  .section-subtitle {
    text-align: center;
    font-size: 13px;
    line-height: 1.3;
    color: var(--text2);
    max-width: 800px;
    margin: 0 auto 20px;
    font-family: 'Montserrat', sans-serif;
  }

  /* ==== TABS ==== */
  .services-tabs {
    display: flex;
    gap: 0;
    margin-bottom: 32px;
    border-bottom: 1px solid var(--border);
  }
  .services-tabs .tab {
    flex: 1;
    padding: 18px 24px;
    background: transparent;
    border: none;
    border-bottom: 2px solid transparent;
    color: var(--text3);
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    margin-bottom: -1px;
  }
  .services-tabs .tab:hover:not(.active) { color: var(--text2); border-bottom-color: var(--border2); }
  .services-tabs .tab.active {
    background: var(--red);
    border-bottom-color: var(--gold);
    color: var(--text);
  }

  /* ==== LAYOUT ==== */
  /* flex with default align-items: stretch — left and right columns share height */
  .services-container {
    display: flex;
    gap: 32px;
    align-items: stretch;
    min-height: 600px;
    transition: opacity 0.2s ease;
  }

  /* ==== MENU — single column for both tabs ==== */
  .services-menu {
    flex: 0 0 34%;
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-content: start;
  }
  /* Hide the inactive tab's menu */
  .services-container.residential .services-menu[data-tab="commercial"],
  .services-container.commercial  .services-menu[data-tab="residential"] {
    display: none;
  }

  /* ==== SERVICE ITEM CHIP — unconditional baseline for every item.
       `:global` so the same rules apply to JS-rebuilt content-card descendants
       even though the menu items themselves are now SSR-rendered. ==== */
  .services-section :global(.service-item) {
    display: block;
    width: 100%;
    padding: 12px 16px;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 4px;
    color: var(--text);
    font-family: 'Montserrat', sans-serif;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-align: center;
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease, color 0.2s ease, box-shadow 0.2s ease;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    line-height: 1.2;
  }
  .services-section :global(.service-item:hover) {
    background: var(--bg3);
    border-color: var(--gold);
    color: var(--gold);
  }
  /* Active state ADDS emphasis on top of the baseline; the chip silhouette
     (border, padding, centered text, dark fill) is preserved. */
  .services-section :global(.service-item.active) {
    background: var(--red);
    border-color: var(--gold);
    color: #ffffff;
    font-weight: 700;
    box-shadow: 0 0 12px var(--red-glow);
  }
  .services-section :global(.service-item.active:hover) {
    color: #ffffff;
  }

  /* ==== CONTENT CARD ==== */
  .services-content {
    flex: 1;
    background: var(--bg2);
    border: 1px solid var(--border);
    padding: 32px;
    /* flex column so the inner .service-display can stretch full height */
    display: flex;
    flex-direction: column;
    min-height: 0;
  }

  /* `.service-display`, `.service-photo`, etc. are rebuilt by JS on item
     click via innerHTML — use :global so scoped CSS still applies. */
  .services-content :global(.service-display) {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-height: 0;
    animation: servicesFadeIn 0.4s ease-out;
  }
  @keyframes servicesFadeIn {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .services-content :global(.service-photo) {
    width: 100%;
    margin-bottom: 28px;
    border: 2px solid var(--gold);
    overflow: hidden;
    box-shadow: 0 0 30px var(--red-glow);
    position: relative;
  }
  /* Aspect ratio differs per tab — residential photos are 4:5 portrait, commercial are 4:3 landscape. */
  .services-container.residential .services-content :global(.service-photo) {
    aspect-ratio: 4 / 5;
  }
  .services-container.commercial .services-content :global(.service-photo) {
    aspect-ratio: 4 / 3;
  }
  .services-content :global(.service-photo picture),
  .services-content :global(.service-photo img) {
    width: 100%;
    height: 100%;
    display: block;
  }
  .services-content :global(.service-photo img) {
    object-fit: cover;
  }
  .services-content :global(.service-photo .photo-placeholder) {
    width: 100%;
    height: 100%;
    background: var(--bg3);
    border: 1px dashed var(--border2);
    color: var(--text3);
    font-size: 13px;
    font-family: 'Montserrat', sans-serif;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 16px;
    box-sizing: border-box;
  }
  .services-content :global(.service-name) {
    font-family: 'Playfair Display', serif;
    font-size: 32px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0 0 14px;
    color: var(--text);
  }
  .services-content :global(.service-desc) {
    font-size: 15px;
    color: var(--text2);
    line-height: 1.85;
    margin: 0 0 28px;
    font-weight: 300;
    font-family: 'Montserrat', sans-serif;
  }
  .services-content :global(.service-actions) {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }
  .services-content :global(.btn-primary) {
    display: inline-block;
    background: var(--red);
    border: 1px solid transparent;
    color: #fff;
    padding: 13px 26px;
    font-family: 'Montserrat', sans-serif;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    text-decoration: none;
  }
  .services-content :global(.btn-primary:hover) {
    border-color: var(--gold);
    box-shadow: 0 0 20px var(--red-glow);
  }
  .services-content :global(.btn-secondary) {
    display: inline-block;
    background: transparent;
    border: 1px solid var(--gold);
    color: var(--gold);
    padding: 13px 26px;
    font-family: 'Montserrat', sans-serif;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    text-decoration: none;
  }
  .services-content :global(.btn-secondary:hover) {
    background: var(--gold-dim);
    color: var(--gold-h);
  }

  /* ==== RESPONSIVE ==== */
  @media (max-width: 1024px) {
    .services-section { padding: 80px 24px; }
    .services-menu { flex: 0 0 32%; }
  }

  @media (max-width: 768px) {
    .section-header-simple .section-title { font-size: 24px; }
    .services-container { flex-direction: column; min-height: 0; }
    .services-menu { flex: 1; }
    .services-content :global(.service-name) { font-size: 24px; }
  }

  @media (max-width: 640px) {
    .services-section { padding: 64px 20px; }
  }
</style>
