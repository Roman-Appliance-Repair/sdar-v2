---
// Services.astro — Residential + Commercial tabbed service grid
//
// Status: SCAFFOLD (Step 3) — content comes in Step 5
//
// Will render: tabbed UI (Residential / Commercial) with 2-col mirrored
// service-list + selected-service detail card. Mirrors the preview-homepage
// services section: 24 residential tiles + 18 commercial tiles.

interface Props {}
---

<section class="services" id="services">
  <div class="container">
    <header class="section-header-simple">
      <h2 class="section-title">
        Residential <span class="text-gold">+</span> Commercial
      </h2>
      <p class="section-subtitle">[Scaffold] Tabbed service grid lands in Step 5.</p>
    </header>
    <div class="placeholder">
      <p>Services tabbed grid — Step 5</p>
    </div>
  </div>
</section>

<style>
  .services {
    background: #0a0a0a;
    color: #ffffff;
    padding: 112px 24px;
    border-bottom: 1px dashed rgba(212, 175, 55, 0.4);
  }
  .services .container { max-width: 1280px; margin: 0 auto; }
  .section-header-simple { text-align: center; margin-bottom: 32px; }
  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(28px, 3.4vw, 44px);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0 0 16px 0;
    color: #ffffff;
  }
  .text-gold { color: #D4AF37; font-style: italic; }
  .section-subtitle {
    color: #d4d4d4;
    font-family: 'Montserrat', sans-serif;
    max-width: 680px;
    margin: 0 auto;
  }
  .placeholder {
    margin-top: 32px;
    padding: 48px 24px;
    border: 1px dashed rgba(212, 175, 55, 0.4);
    color: #888;
    text-align: center;
    font-family: 'Cinzel', serif;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
  .placeholder p { margin: 0; }
</style>
