---
// Reviews.astro — Verified Reviews horizontal slider
//
// Status: SCAFFOLD (Step 3) — content comes in Step 5
//
// Will render: tab strip (All / Google / Thumbtack) + horizontal scroll slider
// of 20 review cards with arrow nav and dot pagination. Mirrors the
// preview-homepage reviews block.

interface Props {}
---

<section class="reviews" id="reviews">
  <div class="container">
    <header class="section-header-simple">
      <h2 class="section-title">
        Verified <span class="text-gold">Reviews</span>
      </h2>
      <p class="section-subtitle">[Scaffold] 20-card review slider lands in Step 5.</p>
    </header>
    <div class="placeholder">
      <p>Reviews slider — Step 5</p>
    </div>
  </div>
</section>

<style>
  .reviews {
    background: #0a0a0a;
    color: #ffffff;
    padding: 112px 24px;
    border-bottom: 1px dashed rgba(212, 175, 55, 0.4);
  }
  .reviews .container { max-width: 1280px; margin: 0 auto; }
  .section-header-simple { text-align: center; margin-bottom: 32px; }
  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(28px, 3.4vw, 44px);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0 0 16px 0;
    color: #ffffff;
  }
  .text-gold { color: #D4AF37; font-style: italic; }
  .section-subtitle {
    color: #d4d4d4;
    font-family: 'Montserrat', sans-serif;
    max-width: 680px;
    margin: 0 auto;
  }
  .placeholder {
    margin-top: 32px;
    padding: 48px 24px;
    border: 1px dashed rgba(212, 175, 55, 0.4);
    color: #888;
    text-align: center;
    font-family: 'Cinzel', serif;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
  .placeholder p { margin: 0; }
</style>
