---
/** TrustBar — top strip with credentials (no phone per T13). */

const credentials = [
  '⚡ SAME DAY · 7 DAYS/WEEK',
  '🔧 85% FIXED FIRST VISIT',
  '⭐ VERIFIED 5-STAR SERVICE',
  '📜 LICENSED & INSURED · BHGS #A49573',
  '🏆 BBB A+',
  '🏢 8 BRANCHES · LA · OC · VENTURA · SB · RIVERSIDE'
];
---

<div class="top-bar">
  <div class="top-bar-content">
    {credentials.map((item, i) => (
      <>
        <span class={`credential-item${i === credentials.length - 1 ? ' hide-mobile' : ''}`}>{item}</span>
        {i < credentials.length - 1 && <span class="divider" aria-hidden="true">|</span>}
      </>
    ))}
  </div>
</div>

<style>
  /* Scoped tokens — match preview-homepage.html */
  .top-bar {
    --red: #C8102E;
    --gold: #D4AF37;

    background: var(--red);
    border-bottom: 1px solid var(--gold);
    padding: 8px 24px;
  }

  .top-bar-content {
    max-width: 1400px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #ffffff;
    white-space: nowrap;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .top-bar-content::-webkit-scrollbar { display: none; }

  .credential-item { flex-shrink: 0; }

  .divider {
    color: rgba(255, 255, 255, 0.3);
    flex-shrink: 0;
  }

  @media (max-width: 1024px) {
    .hide-mobile { display: none; }
    .top-bar-content { font-size: 10px; gap: 8px; }
  }

  @media (max-width: 768px) {
    .top-bar-content .credential-item:nth-child(n+5) { display: none; }
    .top-bar-content { justify-content: flex-start; }
  }
</style>
