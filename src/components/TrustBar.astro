---
/**
 * TrustBar — red strip at top of page with credentials.
 * Scrolls on mobile.
 */

const badges = [
  { label: 'BBB A+ Accredited', href: '/credentials/bbb-accredited/' },
  { label: 'CSLB C-20 Licensed #1138898', href: '/credentials/licensed/' },
  { label: 'Fully Insured', href: '/credentials/insured/' },
  { label: 'EPA 608 Certified', href: '/credentials/epa-certified/' },
  { label: 'Background Checked', href: '/credentials/background-checked/' },
  { label: 'BHGS #A49573', href: '/credentials/licensed/' },
];
---

<div class="trust-bar">
  <div class="container trust-bar-inner">
    <div class="trust-bar-track">
      {badges.map((badge) => (
        <a href={badge.href} class="trust-badge">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
          <span>{badge.label}</span>
        </a>
      ))}
    </div>
  </div>
</div>

<style>
  .trust-bar {
    background: var(--black);
    color: var(--white);
    height: var(--trust-bar-height);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.01em;
    overflow: hidden;
  }

  .trust-bar-inner {
    height: 100%;
    display: flex;
    align-items: center;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .trust-bar-inner::-webkit-scrollbar { display: none; }

  .trust-bar-track {
    display: flex;
    align-items: center;
    gap: 28px;
    white-space: nowrap;
  }

  .trust-badge {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    color: var(--white);
    text-decoration: none;
    opacity: 0.92;
    transition: opacity 0.15s var(--ease);
  }
  .trust-badge:hover { opacity: 1; color: var(--white); }

  .trust-badge svg {
    color: var(--red);
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .trust-bar { font-size: 12px; }
    .trust-bar-track { gap: 20px; }
  }
</style>
