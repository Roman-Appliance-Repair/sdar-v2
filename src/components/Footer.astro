---
/**
 * Footer — NAP via BRANCHES SSOT, no hardcoded address.
 * NAP/SSOT 2026-05-06: legal mailing address (PMB) removed from footer.
 * Only WeHo physical_pin renders a public street address (on its own pillar).
 * Branches list, hours, credentials all derive from data layer.
 */

import { BRANCHES } from '../data/branches';
import { BUSINESS_HOURS } from '../data/business-hours';
import BranchNAP from './BranchNAP.astro';

function slugFromPath(p: string) { return (p.split('/').pop() ?? '').replace(/\.astro$/, ''); }
function slugToLabel(slug: string) {
  return slug.split('-').map((w) =>
    w.charAt(0).toUpperCase() + w.slice(1)
  ).join(' ');
}

const countySlugs = Object.keys(import.meta.glob('../pages/*.astro'))
  .map(slugFromPath)
  .filter((s) => s.endsWith('-county'))
  .sort();
const counties = countySlugs.map((slug) => ({
  label: slugToLabel(slug),
  href: `/${slug}/`
}));

const currentYear = new Date().getFullYear();

const servicesLinks = [
  { label: 'Refrigerator Repair', href: '/services/refrigerator-repair/' },
  { label: 'Washer Repair', href: '/services/washer-repair/' },
  { label: 'Dryer Repair', href: '/services/dryer-repair/' },
  { label: 'Oven Repair', href: '/services/oven-repair/' },
  { label: 'Dishwasher Repair', href: '/services/dishwasher-repair/' },
  { label: 'All Services →', href: '/services/' }
];

const companyLinks = [
  { label: 'Credentials', href: '/credentials/' },
  { label: 'For Business', href: '/for-business/' },
  { label: 'Price List', href: '/price-list/' },
  { label: 'Service Areas', href: '/areas/' },
  { label: 'Commercial', href: '/commercial/' },
  { label: 'Brands', href: '/brands/' },
  { label: 'AI Diagnostic Tool', href: '/ai-diagnostic/' }
];

const legalLinks = [
  { label: 'Privacy Policy', href: '/privacy-policy/' },
  { label: 'Terms of Service', href: '/terms/' },
  { label: 'Sitemap', href: '/sitemap-index.xml' }
];
---

<footer class="footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <div class="footer-logo">
          <span class="footer-logo-main">Same Day</span>
          <span class="footer-logo-sub">Appliance Repair</span>
        </div>
        <p class="footer-tagline">
          Same-day appliance repair across LA, Orange, Ventura, San Bernardino, and Riverside counties.
          $89 residential / $120 commercial diagnostic, waived with repair.
        </p>
      </div>

      <div class="footer-col footer-branches">
        <h4>Branches</h4>
        <ul>
          {BRANCHES.map((b) => (
            <li class="branch-listing">
              <BranchNAP branch={b} showHeading={true} showEmail={true} showCities={true} />
            </li>
          ))}
        </ul>
      </div>

      <div class="footer-col">
        <h4>Counties</h4>
        <ul>
          {counties.map((c) => (
            <li><a href={c.href}>{c.label}</a></li>
          ))}
          <li><a href="/areas/"><strong>All Areas →</strong></a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Services</h4>
        <ul>
          {servicesLinks.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer-col">
        <h4>Company</h4>
        <ul>
          {companyLinks.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="footer-credentials">
      <a href="/credentials/" class="cred-link">
        <div class="cred-item">
          <strong>BHGS</strong>
          <span>Registration #A49573</span>
        </div>
      </a>
      <a href="/credentials/" class="cred-link">
        <div class="cred-item">
          <strong>EPA 608 Universal</strong>
          <span>#1346255700410</span>
        </div>
      </a>
      <a href="/credentials/" class="cred-link">
        <div class="cred-item">
          <strong>CSLB C-20 HVAC</strong>
          <span>License #1138898</span>
        </div>
      </a>
      <a href="/credentials/" class="cred-link">
        <div class="cred-item">
          <strong>BBB Accredited</strong>
          <span>Business · Verifiable</span>
        </div>
      </a>
      <a href="/credentials/" class="cred-link">
        <div class="cred-item">
          <strong>Insured</strong>
          <span>$1M General Liability</span>
        </div>
      </a>
    </div>

    <div class="footer-hours">
      <strong>Hours:</strong> {BUSINESS_HOURS.display}
    </div>

    <div class="footer-bottom">
      <p class="copyright">
        © {currentYear} HVAC 777 LLC dba Same Day Appliance Repair. All rights reserved.
      </p>
      <ul class="footer-legal">
        {legalLinks.map((link, i) => (
          <>
            {i > 0 && <li class="sep" aria-hidden="true">·</li>}
            <li><a href={link.href}>{link.label}</a></li>
          </>
        ))}
      </ul>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--black);
    color: var(--white);
    padding: 72px 0 28px;
    border-top: 3px solid var(--red);
  }
  .footer h4 {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--red);
    margin-bottom: 18px;
  }
  .footer a {
    color: rgba(255,255,255,0.75);
    text-decoration: none;
    transition: color 0.15s var(--ease);
  }
  .footer a:hover { color: var(--white); }
  .footer ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .footer-top {
    display: grid;
    grid-template-columns: 1.4fr 1.4fr 1fr 1fr 1fr;
    gap: 40px;
    padding-bottom: 48px;
    border-bottom: 1px solid rgba(255,255,255,0.12);
  }
  @media (max-width: 1100px) {
    .footer-top { grid-template-columns: 1.4fr 1.4fr 1fr; gap: 36px; }
  }
  @media (max-width: 720px) {
    .footer-top { grid-template-columns: 1fr 1fr; gap: 32px; }
  }
  @media (max-width: 480px) {
    .footer-top { grid-template-columns: 1fr; gap: 28px; }
  }
  .footer-logo { line-height: 1; margin-bottom: 16px; }
  .footer-logo-main {
    display: block;
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 700;
    color: var(--white);
    letter-spacing: -0.02em;
  }
  .footer-logo-sub {
    display: block;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--red);
    margin-top: 4px;
  }
  .footer-tagline {
    font-size: 14px;
    line-height: 1.7;
    color: rgba(255,255,255,0.65);
    margin-bottom: 20px;
    max-width: 380px;
  }
  .footer-branches li.branch-listing {
    margin-bottom: 16px;
    padding-bottom: 14px;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .footer-branches li.branch-listing:last-child {
    border-bottom: none;
  }
  .branch-city {
    display: block;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.5);
    margin-bottom: 4px;
  }
  .branch-phone {
    display: block;
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 600;
    color: var(--white) !important;
    margin-bottom: 2px;
  }
  .branch-phone:hover { color: var(--red) !important; }
  .branch-email {
    display: block;
    font-size: 12px;
    color: rgba(255,255,255,0.55) !important;
    margin-bottom: 4px;
  }
  .branch-email:hover { color: var(--white) !important; }
  .branch-areas {
    display: block;
    font-size: 11px;
    color: rgba(255,255,255,0.4);
    line-height: 1.4;
  }
  .footer-col li { margin-bottom: 10px; font-size: 14px; }
  .footer-col a { font-size: 14px; }
  .footer-credentials {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 24px;
    padding: 32px 0;
    border-bottom: 1px solid rgba(255,255,255,0.12);
  }
  .cred-link {
    display: block;
    color: inherit;
    text-decoration: none;
    transition: opacity 0.15s var(--ease);
  }
  .cred-link:hover { opacity: 0.75; }
  .cred-link:hover .cred-item strong { text-decoration: underline; }
  .cred-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .cred-item strong {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    color: var(--red);
  }
  .cred-item span {
    font-size: 12px;
    color: rgba(255,255,255,0.6);
  }
  .footer-hours {
    padding: 24px 0;
    font-size: 14px;
    color: rgba(255,255,255,0.75);
    border-bottom: 1px solid rgba(255,255,255,0.12);
  }
  .footer-hours strong { color: var(--white); margin-right: 6px; }
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 28px;
    flex-wrap: wrap;
    gap: 16px;
  }
  .copyright {
    font-size: 13px;
    color: rgba(255,255,255,0.55);
    margin: 0;
  }
  .footer-legal {
    display: flex;
    gap: 14px;
    list-style: none;
    align-items: center;
  }
  .footer-legal li { font-size: 13px; }
  .footer-legal .sep { color: rgba(255,255,255,0.3); }
  @media (max-width: 640px) {
    .footer-bottom { flex-direction: column; align-items: flex-start; }
  }
</style>
