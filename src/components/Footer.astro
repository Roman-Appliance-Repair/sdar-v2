---
/**
 * Footer — NAP, branches, quick links, counties, legal.
 */

function slugFromPath(p: string) { return (p.split('/').pop() ?? '').replace(/\.astro$/, ''); }
function slugToLabel(slug: string) {
  return slug.split('-').map((w) =>
    w.charAt(0).toUpperCase() + w.slice(1)
  ).join(' ');
}

// Dynamically pull county hubs from root pages
const countySlugs = Object.keys(import.meta.glob('../pages/*.astro'))
  .map(slugFromPath)
  .filter((s) => s.endsWith('-county'))
  .sort();
const counties = countySlugs.map((slug) => ({
  label: slugToLabel(slug),
  href: `/${slug}/`,
}));

const currentYear = new Date().getFullYear();

const branches = [
  { city: 'West Hollywood', phone: '(323) 870-4790', tel: '+13238704790' },
  { city: 'Los Angeles', phone: '(424) 325-0520', tel: '+14243250520' },
  { city: 'Thousand Oaks', phone: '(424) 208-0228', tel: '+14242080228' },
  { city: 'Pasadena', phone: '(626) 376-4458', tel: '+16263764458' },
  { city: 'Irvine', phone: '(213) 401-9019', tel: '+12134019019' },
];

const servicesLinks = [
  { label: 'Refrigerator Repair', href: '/services/refrigerator-repair/' },
  { label: 'Washer Repair', href: '/services/washer-repair/' },
  { label: 'Dryer Repair', href: '/services/dryer-repair/' },
  { label: 'Oven Repair', href: '/services/oven-repair/' },
  { label: 'Dishwasher Repair', href: '/services/dishwasher-repair/' },
  { label: 'All Services →', href: '/services/' },
];

const companyLinks = [
  { label: 'Credentials', href: '/credentials/' },
  { label: 'For Business', href: '/for-business/' },
  { label: 'Price List', href: '/price-list/' },
  { label: 'Service Areas', href: '/areas/' },
  { label: 'Commercial', href: '/commercial/' },
  { label: 'Brands', href: '/brands/' },
];

const legalLinks = [
  { label: 'Privacy Policy', href: '/privacy-policy/' },
  { label: 'Terms of Service', href: '/terms/' },
  { label: 'Sitemap', href: '/sitemap-index.xml' },
];
---

<footer class="footer">
  <div class="container">
    <!-- Top grid -->
    <div class="footer-top">
      <div class="footer-brand">
        <div class="footer-logo">
          <span class="footer-logo-main">Same Day</span>
          <span class="footer-logo-sub">Appliance Repair</span>
        </div>
        <p class="footer-tagline">
          Licensed C-20 appliance & HVAC repair across Los Angeles, Orange, and Ventura counties.
          Same-day service. $89 diagnostic waived with repair.
        </p>
        <address class="footer-address">
          <strong>HVAC 777 LLC</strong><br />
          DBA Same Day Appliance Repair<br />
          6230 Wilshire Blvd Ste A PMB 2267<br />
          Los Angeles, CA 90048<br />
          <a href="tel:+14243250520" class="address-phone">(424) 325-0520</a>
        </address>
      </div>

      <div class="footer-col">
        <h4>Branches</h4>
        <ul>
          {branches.map((b) => (
            <li>
              <span class="branch-city">{b.city}</span>
              <a href={`tel:${b.tel}`} class="branch-phone">{b.phone}</a>
            </li>
          ))}
        </ul>
      </div>

      <div class="footer-col">
        <h4>Counties</h4>
        <ul>
          {counties.map((c) => (
            <li><a href={c.href}>{c.label}</a></li>
          ))}
          <li><a href="/areas/"><strong>All Areas →</strong></a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h4>Services</h4>
        <ul>
          {servicesLinks.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer-col">
        <h4>Company</h4>
        <ul>
          {companyLinks.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Credentials strip -->
    <div class="footer-credentials">
      <div class="cred-item">
        <strong>CSLB C-20</strong>
        <span>License #1138898</span>
      </div>
      <div class="cred-item">
        <strong>BBB A+</strong>
        <span>Accredited Business</span>
      </div>
      <div class="cred-item">
        <strong>BHGS</strong>
        <span>Registration #A49573</span>
      </div>
      <div class="cred-item">
        <strong>EPA 608</strong>
        <span>Refrigerant Certified</span>
      </div>
      <div class="cred-item">
        <strong>4.6 ★</strong>
        <span>37 verified reviews</span>
      </div>
    </div>

    <!-- Hours -->
    <div class="footer-hours">
      <strong>Hours:</strong> Monday–Saturday 8:00 AM – 8:00 PM
      <span class="sep">·</span>
      <span>Sunday closed</span>
      <span class="sep">·</span>
      <span>Phone answered 24/7</span>
    </div>

    <!-- Bottom -->
    <div class="footer-bottom">
      <p class="copyright">
        © {currentYear} HVAC 777 LLC dba Same Day Appliance Repair. All rights reserved.
      </p>
      <ul class="footer-legal">
        {legalLinks.map((link, i) => (
          <>
            {i > 0 && <li class="sep" aria-hidden="true">·</li>}
            <li><a href={link.href}>{link.label}</a></li>
          </>
        ))}
      </ul>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--black);
    color: var(--white);
    padding: 72px 0 28px;
    margin-top: 80px;
  }

  .footer h4 {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--red);
    margin-bottom: 18px;
  }

  .footer a {
    color: rgba(255,255,255,0.75);
    text-decoration: none;
    transition: color 0.15s var(--ease);
  }
  .footer a:hover { color: var(--white); }

  .footer ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  /* Top grid — 5 columns (brand + 4 cols) */
  .footer-top {
    display: grid;
    grid-template-columns: 1.8fr 1fr 1fr 1fr 1fr;
    gap: 40px;
    padding-bottom: 48px;
    border-bottom: 1px solid rgba(255,255,255,0.12);
  }

  @media (max-width: 1100px) {
    .footer-top { grid-template-columns: 1.6fr 1fr 1fr; gap: 36px; }
  }
  @media (max-width: 720px) {
    .footer-top { grid-template-columns: 1fr 1fr; gap: 32px; }
  }
  @media (max-width: 480px) {
    .footer-top { grid-template-columns: 1fr; gap: 28px; }
  }

  /* Brand block */
  .footer-logo { line-height: 1; margin-bottom: 16px; }
  .footer-logo-main {
    display: block;
    font-family: var(--font-display);
    font-size: 28px;
    font-weight: 700;
    color: var(--white);
    letter-spacing: -0.02em;
  }
  .footer-logo-sub {
    display: block;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--red);
    margin-top: 4px;
  }
  .footer-tagline {
    font-size: 14px;
    line-height: 1.7;
    color: rgba(255,255,255,0.65);
    margin-bottom: 20px;
    max-width: 380px;
  }
  .footer-address {
    font-style: normal;
    font-size: 13px;
    line-height: 1.7;
    color: rgba(255,255,255,0.65);
  }
  .footer-address strong { color: var(--white); font-weight: 600; }
  .address-phone {
    display: inline-block;
    margin-top: 8px;
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 600;
    color: var(--white) !important;
  }
  .address-phone:hover { color: var(--red) !important; }

  /* Column lists */
  .footer-col li { margin-bottom: 10px; font-size: 14px; }
  .footer-col a { font-size: 14px; }

  .branch-city {
    display: block;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.5);
    margin-bottom: 2px;
  }
  .branch-phone {
    font-family: var(--font-display);
    font-size: 17px;
    font-weight: 600;
    color: var(--white) !important;
  }
  .branch-phone:hover { color: var(--red) !important; }

  /* Credentials strip */
  .footer-credentials {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 24px;
    padding: 32px 0;
    border-bottom: 1px solid rgba(255,255,255,0.12);
  }
  .cred-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .cred-item strong {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 700;
    color: var(--red);
  }
  .cred-item span {
    font-size: 12px;
    color: rgba(255,255,255,0.6);
  }

  /* Hours */
  .footer-hours {
    padding: 24px 0;
    font-size: 14px;
    color: rgba(255,255,255,0.75);
    border-bottom: 1px solid rgba(255,255,255,0.12);
  }
  .footer-hours strong { color: var(--white); margin-right: 6px; }
  .footer-hours .sep { margin: 0 12px; color: rgba(255,255,255,0.3); }

  /* Bottom */
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 28px;
    flex-wrap: wrap;
    gap: 16px;
  }
  .copyright {
    font-size: 13px;
    color: rgba(255,255,255,0.55);
    margin: 0;
  }
  .footer-legal {
    display: flex;
    gap: 14px;
    list-style: none;
    align-items: center;
  }
  .footer-legal li { font-size: 13px; }
  .footer-legal .sep { color: rgba(255,255,255,0.3); }

  @media (max-width: 640px) {
    .footer-bottom { flex-direction: column; align-items: flex-start; }
  }
</style>
