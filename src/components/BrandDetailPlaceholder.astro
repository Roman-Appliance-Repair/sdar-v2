---
export interface Props {
  brandName: string;
  brandSlug: string;
  category: string;
  categorySlug: string;
  hubUrl: string;
}

const { brandName, brandSlug, category, categorySlug, hubUrl } = Astro.props;
---

<!-- ── HERO ── -->
<section class="hero">
  <div class="hero-inner">
    <div class="hero-content">
      <p class="hero-eyebrow">LOS ANGELES · 90048 · 90046 · 90026 · 90036</p>
      <h1>{brandName} {category} Repair Los Angeles</h1>
      <p class="hero-sub">Content for {brandName} {category} repair coming soon. Call (424) 325-0520 for same-day service.</p>
      <div class="hero-ctas">
        <a href="tel:+14243250520" class="btn-primary">☎ (424) 325-0520</a>
        <a href="/contact/" class="btn-outline">Book Online</a>
      </div>
      <div class="hero-rating">
        <span class="stars">★★★★★</span>
        <span>4.6 · 37 reviews · Google</span>
      </div>
    </div>
    <div class="hero-img-wrap">
      <div class="hero-img-placeholder">
        <p>{brandName} {category}</p>
        <p>Los Angeles</p>
      </div>
    </div>
  </div>
</section>

<!-- ── TRUST BAR ── -->
<div class="trust-bar">
  <div class="trust-bar-inner">
    <div class="trust-item"><span class="trust-icon">🏅</span> CSLB Licensed #1138898</div>
    <div class="trust-item"><span class="trust-icon">🛡️</span> Fully Insured</div>
    <div class="trust-item"><span class="trust-icon">⚡</span> Same Day Available</div>
    <div class="trust-item"><span class="trust-icon">🔩</span> OEM Parts on Truck</div>
    <div class="trust-item"><span class="trust-icon">💬</span> $89 Diagnostic — Waived With Repair</div>
  </div>
</div>

<!-- ── BACK + RELATED ── -->
<section class="related">
  <div class="container">
    <p class="rel-eyebrow">Back to {brandName}</p>
    <h2>Explore More</h2>
    <div class="rel-grid">
      <a href={hubUrl} class="rel-card">
        <span class="rel-label">All {brandName} Appliances</span>
        <span class="rel-sub">See every {brandName} category we service</span>
        <span class="rel-arrow">→</span>
      </a>
      <a href={`/services/${categorySlug}/`} class="rel-card">
        <span class="rel-label">{category} Repair — All Brands</span>
        <span class="rel-sub">Full {category.toLowerCase()} repair page, every brand</span>
        <span class="rel-arrow">→</span>
      </a>
      <a href="/contact/" class="rel-card">
        <span class="rel-label">Book Service</span>
        <span class="rel-sub">Same-day appointments across LA</span>
        <span class="rel-arrow">→</span>
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    background: var(--black);
    color: #fff;
    padding: 72px 24px;
  }
  .hero-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }
  .hero-eyebrow {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: .12em;
    text-transform: uppercase;
    color: var(--red);
    margin-bottom: 16px;
  }
  .hero h1 {
    font-family: var(--font-display);
    font-size: clamp(28px, 4vw, 46px);
    font-weight: 700;
    line-height: 1.15;
    margin-bottom: 20px;
    letter-spacing: -.02em;
    color: #fff;
  }
  .hero-sub {
    font-size: 17px;
    color: rgba(255,255,255,.72);
    margin-bottom: 32px;
    line-height: 1.6;
  }
  .hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; }
  .btn-primary {
    background: var(--red);
    color: #fff;
    padding: 14px 28px;
    border-radius: 6px;
    font-size: 15px;
    font-weight: 600;
    text-decoration: none;
  }
  .btn-outline {
    border: 1.5px solid rgba(255,255,255,.35);
    color: #fff;
    padding: 14px 28px;
    border-radius: 6px;
    font-size: 15px;
    font-weight: 500;
    text-decoration: none;
  }
  .hero-rating {
    margin-top: 28px;
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13px;
    color: rgba(255,255,255,.55);
  }
  .stars { color: #f59e0b; letter-spacing: 2px; }
  .hero-img-wrap {
    border-radius: 12px;
    overflow: hidden;
    background: #1a1a1a;
    aspect-ratio: 4/3;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hero-img-placeholder {
    color: rgba(255,255,255,.2);
    font-size: 14px;
    text-align: center;
    line-height: 1.6;
  }

  .trust-bar {
    background: var(--red);
    color: #fff;
    padding: 16px 24px;
  }
  .trust-bar-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .trust-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 500;
  }
  .trust-icon { font-size: 16px; }

  .related { padding: 72px 24px; background: #fff; }
  .container { max-width: 1100px; margin: 0 auto; }
  .rel-eyebrow {
    font-size: 12px; font-weight: 700; letter-spacing: .18em;
    text-transform: uppercase; color: var(--red); margin-bottom: 10px;
  }
  .related h2 {
    font-family: var(--font-display);
    font-size: clamp(26px, 3.5vw, 36px);
    margin-bottom: 32px;
  }
  .rel-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 16px;
  }
  .rel-card {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-areas: "label arrow" "sub arrow";
    gap: 4px 16px;
    padding: 22px 24px;
    border: 1px solid var(--border);
    border-radius: 6px;
    text-decoration: none;
    color: var(--black);
    background: #fff;
    transition: all .15s var(--ease);
  }
  .rel-card:hover {
    border-color: var(--red);
    transform: translateY(-2px);
  }
  .rel-label { grid-area: label; font-size: 16px; font-weight: 700; }
  .rel-sub { grid-area: sub; font-size: 13px; color: var(--muted); }
  .rel-arrow { grid-area: arrow; align-self: center; font-size: 20px; color: var(--red); }

  @media (max-width: 768px) {
    .hero-inner { grid-template-columns: 1fr; gap: 32px; }
    .hero-img-wrap { display: none; }
  }
</style>
