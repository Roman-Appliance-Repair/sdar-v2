---
/**
 * SDAR V2 — Main Layout
 * Applied to all pages. Includes: Navbar + MegaMenu + Trust Bar + Footer.
 */

import '../styles/global.css';
import MegaMenu from '../components/MegaMenu.astro';
import TrustBar from '../components/TrustBar.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description?: string;
  canonical?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'Same-day appliance repair in Los Angeles, Orange County, and Ventura County. Licensed C-20, BBB A+, EPA-certified. $89 diagnostic waived with repair.',
  canonical,
  image = '/og-image.png',
  noindex = false,
} = Astro.props;

const siteUrl = 'https://samedayappliance.repair';
const canonicalUrl = canonical || new URL(Astro.url.pathname, siteUrl).toString();
const ogImage = new URL(image, siteUrl).toString();
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Same Day Appliance Repair — 5 SoCal counties" />
    <meta property="og:site_name" content="Same Day Appliance Repair" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon set -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192x192.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0a0a0a" />

    <!-- Google Fonts: Playfair Display + DM Sans -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Playfair+Display:wght@500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- Page-specific head content (JSON-LD schema, etc.) -->
    <slot name="head-scripts" />

    <!-- Google Tag Manager — zero-impact lazy load -->
    <script>
      (function() {
        var loaded = false;
        function loadGTM() {
          if (loaded) return;
          loaded = true;
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({'gtm.start': Date.now(), event: 'gtm.js'});
          var s = document.createElement('script');
          s.async = true;
          s.src = 'https://www.googletagmanager.com/gtm.js?id=GTM-M43LT47K';
          document.head.appendChild(s);
        }
        var events = ['scroll', 'mousemove', 'touchstart', 'click', 'keydown'];
        function trigger() {
          events.forEach(function(e) { window.removeEventListener(e, trigger); });
          ('requestIdleCallback' in window) ? requestIdleCallback(loadGTM, {timeout: 2000}) : setTimeout(loadGTM, 200);
        }
        events.forEach(function(e) { window.addEventListener(e, trigger, {once: true, passive: true}); });
        setTimeout(trigger, 4000);
      })();
    </script>
    <!-- End Google Tag Manager -->
  </head>

  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-M43LT47K"
      height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->

    <!-- ================== Trust Bar ================== -->
    <TrustBar />

    <!-- ================== Navbar ================== -->
    <header class="navbar">
      <div class="container navbar-inner">
        <a href="/" class="logo" aria-label="Same Day Appliance Repair — Home">
          <span class="logo-main">Same Day</span>
          <span class="logo-sub">Appliance Repair</span>
        </a>

        <MegaMenu />

        <div class="nav-cta">
          <a href="/book/" class="nav-book">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
              <line x1="16" y1="2" x2="16" y2="6"/>
              <line x1="8" y1="2" x2="8" y2="6"/>
              <line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
            <span>Book Online</span>
          </a>
          <button class="mobile-toggle" aria-label="Open menu" aria-expanded="false" id="mobile-toggle">
            <span></span><span></span><span></span>
          </button>
        </div>
      </div>
    </header>

    <!-- ================== Breadcrumbs ================== -->
    <Breadcrumbs />

    <!-- ================== Main Content ================== -->
    <main>
      <slot />
    </main>

    <!-- ================== Footer ================== -->
    <Footer />

    <!-- Mobile menu toggle -->
    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const toggle = document.getElementById('mobile-toggle');
        const nav = document.querySelector('.mega-menu');
        if (toggle && nav) {
          toggle.addEventListener('click', () => {
            const isOpen = nav.classList.toggle('is-open');
            toggle.setAttribute('aria-expanded', String(isOpen));
            toggle.classList.toggle('is-open', isOpen);
          });
        }
      });
    </script>
  </body>
</html>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--white);
    border-bottom: 1px solid var(--border);
    height: var(--nav-height);
  }

  .navbar-inner {
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }

  /* Logo */
  .logo {
    display: flex;
    flex-direction: column;
    line-height: 1;
    text-decoration: none;
    color: var(--black);
    flex-shrink: 0;
  }
  .logo-main {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--black);
  }
  .logo-sub {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--red);
    margin-top: 3px;
  }

  /* CTA group */
  .nav-cta {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }

  .nav-book {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    background: var(--white);
    color: var(--black);
    font-weight: 600;
    font-size: 14px;
    border: 1px solid var(--black);
    border-radius: 4px;
    text-decoration: none;
    transition: background 0.2s var(--ease), color 0.2s var(--ease);
    white-space: nowrap;
  }
  .nav-book:hover { background: var(--black); color: var(--white); }

  /* Mobile hamburger */
  .mobile-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    padding: 8px;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 4px;
    cursor: pointer;
  }
  .mobile-toggle span {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--black);
    transition: all 0.2s var(--ease);
  }
  .mobile-toggle.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .mobile-toggle.is-open span:nth-child(2) { opacity: 0; }
  .mobile-toggle.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  @media (max-width: 1024px) {
    .mobile-toggle { display: flex; }
    .nav-book { display: none; }
  }

  @media (max-width: 640px) {
    .logo-sub { display: none; }
  }
</style>
