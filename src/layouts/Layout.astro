---
/**
 * SDAR V2 — Main Layout
 * Applied to all pages. Includes: Navbar + MegaMenu + Trust Bar + Footer.
 */

import '../styles/global.css';
import MegaMenu from '../components/MegaMenu.astro';
import TrustBar from '../components/TrustBar.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description?: string;
  canonical?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'Same-day appliance repair in Los Angeles, Orange County, and Ventura County. Licensed C-20, BBB A+, EPA-certified. $89 diagnostic waived with repair.',
  canonical,
  image = '/og-default.jpg',
  noindex = false,
} = Astro.props;

const siteUrl = 'https://samedayappliance.repair';
const canonicalUrl = canonical || new URL(Astro.url.pathname, siteUrl).toString();
const ogImage = new URL(image, siteUrl).toString();

// Main phone for homepage = West Hollywood
const mainPhone = '(323) 870-4790';
const mainPhoneTel = '+13238704790';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Same Day Appliance Repair" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <!-- Google Fonts: Playfair Display + DM Sans -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Playfair+Display:wght@500;600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- Page-specific head content (JSON-LD schema, etc.) -->
    <slot name="head-scripts" />
  </head>

  <body>
    <!-- ================== Trust Bar ================== -->
    <TrustBar />

    <!-- ================== Navbar ================== -->
    <header class="navbar">
      <div class="container navbar-inner">
        <a href="/" class="logo" aria-label="Same Day Appliance Repair — Home">
          <span class="logo-main">Same Day</span>
          <span class="logo-sub">Appliance Repair</span>
        </a>

        <MegaMenu />

        <div class="nav-cta">
          <a href="/book/" class="nav-book">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
              <line x1="16" y1="2" x2="16" y2="6"/>
              <line x1="8" y1="2" x2="8" y2="6"/>
              <line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
            <span>Book Online</span>
          </a>
          <a href={`tel:${mainPhoneTel}`} class="nav-phone">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            <span>{mainPhone}</span>
          </a>
          <button class="mobile-toggle" aria-label="Open menu" aria-expanded="false" id="mobile-toggle">
            <span></span><span></span><span></span>
          </button>
        </div>
      </div>
    </header>

    <!-- ================== Breadcrumbs ================== -->
    <Breadcrumbs />

    <!-- ================== Main Content ================== -->
    <main>
      <slot />
    </main>

    <!-- ================== Footer ================== -->
    <Footer />

    <!-- Mobile menu toggle -->
    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const toggle = document.getElementById('mobile-toggle');
        const nav = document.querySelector('.mega-menu');
        if (toggle && nav) {
          toggle.addEventListener('click', () => {
            const isOpen = nav.classList.toggle('is-open');
            toggle.setAttribute('aria-expanded', String(isOpen));
            toggle.classList.toggle('is-open', isOpen);
          });
        }
      });
    </script>
  </body>
</html>

<style>
  .navbar {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--white);
    border-bottom: 1px solid var(--border);
    height: var(--nav-height);
  }

  .navbar-inner {
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
  }

  /* Logo */
  .logo {
    display: flex;
    flex-direction: column;
    line-height: 1;
    text-decoration: none;
    color: var(--black);
    flex-shrink: 0;
  }
  .logo-main {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--black);
  }
  .logo-sub {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--red);
    margin-top: 3px;
  }

  /* CTA group */
  .nav-cta {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }

  .nav-book {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    background: var(--white);
    color: var(--black);
    font-weight: 600;
    font-size: 14px;
    border: 1px solid var(--black);
    border-radius: 4px;
    text-decoration: none;
    transition: background 0.2s var(--ease), color 0.2s var(--ease);
    white-space: nowrap;
  }
  .nav-book:hover { background: var(--black); color: var(--white); }

  .nav-phone {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 11px 20px;
    background: var(--red);
    color: var(--white);
    font-weight: 600;
    font-size: 15px;
    border-radius: 4px;
    text-decoration: none;
    transition: background 0.2s var(--ease);
    white-space: nowrap;
  }
  .nav-phone:hover { background: var(--red-dark); color: var(--white); }

  /* Mobile hamburger */
  .mobile-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    padding: 8px;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 4px;
    cursor: pointer;
  }
  .mobile-toggle span {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--black);
    transition: all 0.2s var(--ease);
  }
  .mobile-toggle.is-open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .mobile-toggle.is-open span:nth-child(2) { opacity: 0; }
  .mobile-toggle.is-open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  @media (max-width: 1024px) {
    .mobile-toggle { display: flex; }
    .nav-book { display: none; }
  }

  @media (max-width: 640px) {
    .logo-sub { display: none; }
    .nav-phone span { display: none; }
    .nav-phone { padding: 11px; }
  }
</style>
