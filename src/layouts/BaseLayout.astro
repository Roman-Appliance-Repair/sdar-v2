---
/**
 * BaseLayout — alias for Layout.astro.
 * Exists so pages that import BaseLayout (chino-hills, corona, fontana, …
 * + commercial-refrigeration brand pages) keep working. Identical props.
 */
import Layout from './Layout.astro';

export interface Props {
  title: string;
  description?: string;
  canonical?: string;
  image?: string;
  noindex?: boolean;
}

const props = Astro.props;
---

<Layout {...props}>
  <slot />
</Layout>
