---
// src/layouts/BlogLayout.astro
// Wave 25c — Blog post layout component for /blog/* articles.
// BlogPosting schema, author block, date, reading time, body slot.
import Layout from './Layout.astro';

export interface Props {
  title: string;
  description: string;
  slug: string;
  publishedDate: string;
  author?: string;
  readingTime?: string;
  category?: string;
}

const {
  title,
  description,
  slug,
  publishedDate,
  author = 'SDAR Field Technicians',
  readingTime = '6 min read',
  category = 'Repair Tips'
} = Astro.props;

const canonical = `https://samedayappliance.repair/blog/${slug}/`;
const blogPostingSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": title,
  "description": description,
  "url": canonical,
  "datePublished": publishedDate,
  "author": {
    "@type": "Organization",
    "name": "Same Day Appliance Repair",
    "url": "https://samedayappliance.repair/"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Same Day Appliance Repair",
    "url": "https://samedayappliance.repair/"
  },
  "mainEntityOfPage": canonical
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://samedayappliance.repair/blog/" },
    { "@type": "ListItem", "position": 3, "name": title, "item": canonical }
  ]
};
---

<Layout title={title} description={description}>

<Fragment slot="head-scripts">
  <script type="application/ld+json" set:html={JSON.stringify(blogPostingSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Fragment>

<article class="blog-article">

  <header class="article-hero">
    <div class="container narrow">
      <p class="article-meta">
        <a href="/blog/" class="meta-back">← Blog</a>
        <span class="meta-sep">·</span>
        <span class="meta-cat">{category}</span>
        <span class="meta-sep">·</span>
        <span class="meta-date">{new Date(publishedDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
        <span class="meta-sep">·</span>
        <span class="meta-time">{readingTime}</span>
      </p>
      <h1 class="article-title">{title}</h1>
      <p class="article-author">By {author}</p>
    </div>
  </header>

  <div class="article-body">
    <div class="container narrow">
      <slot />
    </div>
  </div>

  <section class="article-cta">
    <div class="container narrow">
      <h2>Need a repair? We're licensed, insured, and same-day across SoCal.</h2>
      <p>BHGS #A49573 · EPA 608 Universal certified (#1346255700410) · BBB Accredited Business · 90-day warranty.</p>
      <div class="cta-row">
        <a href="tel:+14243250520" class="btn-red">☎ Call (424) 325-0520</a>
        <a href="/contact/" class="btn-outline">Book Online</a>
      </div>
    </div>
  </section>

  <section class="related-articles">
    <div class="container narrow">
      <h3>More from the field</h3>
      <div class="related-grid">
        <a href="/blog/repair-vs-replace-refrigerator-la-guide/" class="related-card">
          <p class="related-cat">Repair Tips</p>
          <h4>Repair vs Replace: Refrigerator Decision Guide</h4>
        </a>
        <a href="/blog/why-dryer-takes-2-hours-diagnosis-guide/" class="related-card">
          <p class="related-cat">Diagnosis</p>
          <h4>Why Your Dryer Is Taking 2 Hours</h4>
        </a>
        <a href="/blog/la-hard-water-killing-dishwasher/" class="related-card">
          <p class="related-cat">Maintenance</p>
          <h4>LA Hard Water Is Killing Your Dishwasher</h4>
        </a>
      </div>
    </div>
  </section>

</article>

</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .blog-article { color: var(--text); }
  .article-hero { background: var(--black); color: #fff; padding: 64px 24px 48px; }
  .container.narrow { max-width: 820px; margin: 0 auto; }
  .article-meta { font-size: 12px; color: rgba(255,255,255,.55); letter-spacing: .04em; margin-bottom: 24px; display: flex; flex-wrap: wrap; gap: 6px; align-items: center; }
  .article-meta .meta-back { color: var(--red); font-weight: 700; text-decoration: none; }
  .article-meta .meta-back:hover { color: #ff1f47; }
  .article-meta .meta-sep { color: rgba(255,255,255,.25); }
  .article-meta .meta-cat { color: rgba(255,255,255,.78); font-weight: 600; text-transform: uppercase; letter-spacing: .12em; font-size: 11px; }
  .article-title { font-size: clamp(28px, 4.5vw, 44px); font-weight: 800; line-height: 1.15; margin: 0 0 18px; letter-spacing: -0.02em; color: #fff; }
  .article-author { font-size: 14px; color: rgba(255,255,255,.55); margin: 0; }

  .article-body { padding: 56px 24px; background: #fff; }
  .article-body :global(h2) { font-size: clamp(22px, 3vw, 30px); font-weight: 800; margin: 36px 0 16px; line-height: 1.25; color: var(--text); letter-spacing: -0.01em; }
  .article-body :global(h3) { font-size: clamp(18px, 2.4vw, 22px); font-weight: 700; margin: 28px 0 12px; line-height: 1.3; color: var(--text); }
  .article-body :global(p) { font-size: 17px; line-height: 1.75; color: var(--text); margin: 0 0 18px; }
  .article-body :global(ul), .article-body :global(ol) { margin: 0 0 18px; padding-left: 26px; }
  .article-body :global(li) { font-size: 17px; line-height: 1.7; color: var(--text); margin-bottom: 8px; }
  .article-body :global(strong) { font-weight: 700; color: var(--text); }
  .article-body :global(a) { color: var(--red); font-weight: 600; text-decoration: none; }
  .article-body :global(a:hover) { text-decoration: underline; }
  .article-body :global(blockquote) { border-left: 4px solid var(--red); padding: 12px 22px; margin: 24px 0; background: var(--gray); border-radius: 4px; font-style: italic; color: var(--muted); }
  .article-body :global(.callout) { background: var(--gray); border-left: 4px solid var(--red); border-radius: 6px; padding: 22px 26px; margin: 28px 0; }
  .article-body :global(.callout p) { margin-bottom: 8px; }
  .article-body :global(.callout p:last-child) { margin-bottom: 0; }
  .article-body :global(table) { width: 100%; border-collapse: collapse; margin: 22px 0; background: #fff; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; font-size: 15px; }
  .article-body :global(table th) { background: var(--black); color: #fff; padding: 12px 16px; text-align: left; font-size: 12px; letter-spacing: .04em; }
  .article-body :global(table td) { padding: 12px 16px; border-bottom: 1px solid var(--border); vertical-align: top; }
  .article-body :global(table tr:last-child td) { border-bottom: none; }

  .article-cta { background: var(--red); color: #fff; padding: 56px 24px; text-align: center; }
  .article-cta h2 { font-size: clamp(20px, 2.6vw, 26px); font-weight: 800; color: #fff; margin: 0 0 12px; }
  .article-cta p { color: rgba(255,255,255,.92); font-size: 14px; margin: 0 0 24px; }
  .cta-row { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; }
  .btn-red { background: #fff; color: var(--red); padding: 14px 28px; border-radius: 6px; font-weight: 700; text-decoration: none; }
  .btn-outline { background: transparent; color: #fff; padding: 14px 28px; border-radius: 6px; border: 2px solid rgba(255,255,255,.55); font-weight: 600; text-decoration: none; }

  .related-articles { background: var(--gray); padding: 56px 24px; }
  .related-articles h3 { font-size: clamp(18px, 2.4vw, 22px); font-weight: 700; margin: 0 0 22px; color: var(--text); }
  .related-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 14px; }
  .related-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 22px; text-decoration: none; color: var(--text); transition: border-color .2s, transform .2s; }
  .related-card:hover { border-color: var(--red); transform: translateY(-2px); }
  .related-card .related-cat { font-size: 11px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: var(--red); margin: 0 0 8px; }
  .related-card h4 { font-size: 15px; font-weight: 700; line-height: 1.4; color: var(--text); margin: 0; }
</style>
