---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import CustomNarrative from '../components/cities/v2/CustomNarrative.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

import { mergeCredentials } from '../data/credentials-schema';
const citySlug = 'pacific-palisades';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = 'Pacific Palisades';
const zips = ['90272'];

const phoneRaw = `+1${branch.phone.replace(/\D/g, '')}`;

const title = `Appliance Repair Pacific Palisades CA — Same Day Service`;
const description = `Same-day appliance repair in Pacific Palisades, CA 90272. Sub-Zero, Wolf, Thermador, La Cornue, Gaggenau specialists. Licensed, OEM parts.`;
const canonical = 'https://samedayappliance.repair/pacific-palisades/';

const localBusinessSchema = mergeCredentials({
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { '@type': 'Neighborhood', name: 'Pacific Palisades' },
    { '@type': 'Neighborhood', name: 'The Riviera' },
    { '@type': 'Neighborhood', name: 'Castellammare' },
    { '@type': 'Neighborhood', name: 'Huntington Palisades' }
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$$',
  license: 'BHGS #A49573'

});

const introParagraphs = [
  "Pacific Palisades is distinct from other Westside luxury neighborhoods in a few ways that matter for appliance repair. The housing is largely single-family, spread across hillside streets, canyons, and coastal bluffs — Temescal Canyon, Potrero Canyon, Marquez Knolls, Los Liones, and the flatter Alphabet Streets all have different access realities. The appliances in these homes skew toward the very high end: Sub-Zero built-in columns, Wolf professional ranges, and increasingly, European brands — La Cornue, Gaggenau, and Miele — in the design-forward kitchens that define newer construction here.",
  "Many of these homes are also in the process of being rebuilt or extensively renovated following the 2025 fires. New kitchens with freshly installed luxury appliances need proper commissioning — oven calibration, refrigerator system checks, built-in integration verification. We also see <a href=\"/brands/liebherr/\">Liebherr</a> column installs and <a href=\"/brands/marvel/\">Marvel built-in refrigerators</a> specified in new construction here. Our technicians work with new installations and can handle the full range of what's going into Palisades homes right now.",
  "Coastal areas — particularly Castellammare and the Bluffs — have real salt air exposure that affects refrigerator coils and dishwasher seals faster than inland LA. We check for this proactively on every call in those areas.",
  `Diagnostic fee: <strong>$89</strong> — waived with repair. Written estimate before we start. <strong>90-day warranty</strong> on everything. Call <a href="tel:${phoneRaw}">${branch.phone}</a>.`,
  "<strong>Coastal maintenance note:</strong> If you're in Castellammare, along the Bluffs, or within half a mile of PCH — clean your refrigerator condenser coils every 4 months, not 12. Salt air deposits on coils faster than anywhere else in our service area. A 20-minute coil vacuum twice a year can double your compressor's useful life. We check this on every coastal Pacific Palisades call as part of standard diagnostics."
];

const services = [
  { icon: '🧊', name: 'Refrigerator Repair', slug: 'refrigerator', issues: 'Built-in columns · Not cooling · Coil cleaning · Salt air issues · Ice maker', brands: 'Sub-Zero · Wolf · GE Monogram · True · Viking' },
  { icon: '🔥', name: 'Oven, Range & La Cornue Repair', slug: 'oven', issues: 'Wolf dual-fuel · La Cornue · Gaggenau · Temperature calibration · Igniter', brands: 'Wolf · La Cornue · Gaggenau · Thermador · Viking · Miele' },
  { icon: '🍽️', name: 'Dishwasher Repair', slug: 'dishwasher', issues: 'Not draining · Panel-ready · Miele electronic · Gasket wear (coastal)', brands: 'Miele · Gaggenau · Bosch · Thermador · Cove · KitchenAid' },
  { icon: '🫧', name: 'Washer & Dryer Repair', slug: 'washer', issues: 'Not draining · Not spinning · Miele W1/T1 · European models', brands: 'Miele · Bosch · LG · Samsung · Speed Queen · Electrolux' },
  { icon: '🍷', name: 'Wine Cooler & Cellar Repair', slug: 'wine-cooler', issues: 'Temperature off · Coastal humidity · Sub-Zero wine storage · Built-in', brands: 'Sub-Zero · True · EuroCave · Liebherr · Thermador' },
  { icon: '🔆', name: 'Cooktop & Range Hood Repair', slug: 'cooktop', issues: 'Wolf star burner · Gaggenau induction · Hood motor · Ventilation', brands: 'Wolf · Gaggenau · Miele · Thermador · Viking · Zephyr' },
  { icon: '❄️', name: 'Freezer & Ice Maker Repair', slug: 'freezer', issues: 'Not freezing · Sub-Zero column · Ice production · Built-in', brands: 'Sub-Zero · True · GE Monogram · U-Line · Scotsman' },
  { icon: '🔧', name: 'New Installation Service', slug: 'refrigerator', issues: 'Rebuilt home commissioning · Oven calibration · System checks · Built-in setup', brands: 'All luxury brands · New construction · Remodel projects' }
];

const luxuryNarrative = {
  eyebrow: 'RARE BRANDS. FULLY COVERED.',
  headline: 'La Cornue, Gaggenau & European Luxury Repair in Pacific Palisades',
  paragraphs: [
    'Most appliance repair companies in LA will tell you they service "all luxury brands" and then pause when you say La Cornue or Gaggenau. These are not niche appliances in Pacific Palisades — they appear regularly in The Riviera and Huntington Palisades kitchens, particularly in homes designed by architects who specify European equipment.',
    "La Cornue ranges — including the CornuFé and Château models — require specific knowledge of their dual-fuel configurations, the oven door hinge systems, and the gas valve assemblies that differ substantially from American brands. Gaggenau induction cooktops, steam ovens, and combi-steam units have electronic control systems that need correct diagnostic equipment and software.",
    "Our technicians have worked on these brands. We carry OEM parts, source manufacturer-spec components, and don't guess at repairs on equipment this valuable.",
    'Brands we service: La Cornue · Gaggenau · Sub-Zero · Wolf · Miele · Thermador · Viking · GE Monogram.'
  ]
};

const neighborhoods = [
  { name: 'The Riviera', zip: '90272', featured: true },
  { name: 'Huntington Palisades', zip: '90272', featured: true },
  { name: 'Castellammare', zip: '90272', featured: true },
  { name: 'Alphabet Streets', zip: '90272' },
  { name: 'Marquez Knolls', zip: '90272' },
  { name: 'Palisades Village area', zip: '90272' },
  { name: 'Temescal Canyon', zip: '90272' },
  { name: 'Potrero Canyon', zip: '90272' },
  { name: 'Los Liones', zip: '90272' },
  { name: 'Sunset Mesa', zip: '90272' },
  { name: 'The Bluffs', zip: '90272' },
  { name: 'Rustic Canyon (south)', zip: '90272' }
];

const recentJobs = [
  {
    appliance: 'La Cornue CornuFé',
    location: 'The Riviera, 90272',
    quote: '"Oven not reaching temperature, right burner weak"',
    description: 'La Cornue CornuFé 90 dual-fuel — the oven igniter was failing and a gas valve on the right front burner had weakened flow. These are not the same parts as a Wolf or Thermador, and the disassembly procedure is specific to La Cornue\'s chassis design. Our tech had the correct components, replaced both, calibrated the oven against a probe thermometer, and tested all five burners. The homeowner had been told by two other companies they "don\'t work on those."',
    outcome: '✓ Same day · OEM La Cornue parts · Oven calibrated'
  },
  {
    appliance: 'Sub-Zero Built-In Column',
    location: 'Huntington Palisades, 90272',
    quote: '"Running constantly, warm at the top of the fridge section"',
    description: '48-inch Sub-Zero integrated column — upper evaporator fan motor had seized, causing warm spots at the top of the refrigerator compartment while the lower section and freezer remained cold. Replaced the fan motor with an OEM Sub-Zero part, defrosted the upper evaporator which had partially iced over, and cleaned the condensers — significant dust buildup from the hillside location. Back to even temperature throughout within 90 minutes.',
    outcome: '✓ Same day · OEM Sub-Zero · Condenser cleaning done'
  },
  {
    appliance: 'Gaggenau Steam Oven',
    location: 'Alphabet Streets, 90272',
    quote: '"E4 fault code, steam function not working"',
    description: 'Gaggenau BS474 steam oven — E4 indicates a water inlet or steam generator fault. Found a blocked inlet filter and a scale buildup on the steam generator heating element from hard water. Descaled the generator, cleaned and cleared the inlet filter, ran a full steam calibration cycle. Advised the homeowner on descaling frequency for the Palisades water supply. Whole job: 75 minutes. The oven had been sitting non-functional for three weeks.',
    outcome: '✓ Same day · Descaled + inlet cleared · 75 minutes'
  },
  {
    appliance: 'New Build Commissioning',
    location: 'Temescal Canyon area, 90272',
    quote: '"Just moved into rebuilt home, Wolf oven running low"',
    description: 'Rebuilt home post-fire — new Wolf 48-inch DF range installed during construction. The oven was running 22°F below set temperature — a common factory offset that needs field calibration. Our tech calibrated both oven compartments, verified all six burners and both ovens, checked the gas pressure at the range, and confirmed the range hood integration. This is exactly the kind of commissioning call that saves a homeowner months of cooking frustration in a new kitchen.',
    outcome: '✓ Same day · Oven calibrated +22°F · Full system check'
  }
];

const whyReasons = [
  {
    iconKey: 'parts' as const,
    title: 'We Work on the Rare Brands',
    body: 'La Cornue, Gaggenau, Miele steam ovens — these aren\'t "all brands" for most repair companies. They are for us. Our technicians have the training, parts, and diagnostic tools for European luxury equipment.'
  },
  {
    iconKey: 'team' as const,
    title: 'New Build & Rebuild Ready',
    body: "Palisades homes are being rebuilt with new kitchens. We commission new appliances — calibrate ovens, verify refrigerator systems, check built-in integrations. If something's off from day one, we find it before it becomes a problem."
  },
  {
    iconKey: 'shield' as const,
    title: 'We Know the Coastal Climate',
    body: "Salt air from the coast affects appliances differently than inland LA. We proactively check condenser coils and door seals on every coastal Palisades call — it's that consistently a factor in Castellammare and the Bluffs."
  },
  {
    iconKey: 'clock' as const,
    title: '90-Day Warranty, OEM Only',
    body: 'Every repair backed by 90 days on parts and labor. Genuine OEM parts only — no aftermarket on luxury equipment. $89 diagnostic fee waived with repair. California licensed, BBB Accredited.'
  }
];

const testimonials = [
  {
    stars: 5,
    text: '"We have a La Cornue range and two other companies said they don\'t service it. Same Day Appliance Repair came out same day, had the right parts, fixed the oven and one burner, and calibrated the temperature. This is the first repair company in the Palisades that actually knew the brand."',
    author: '— Margaret B., The Riviera, Pacific Palisades'
  },
  {
    stars: 5,
    text: '"Sub-Zero in our Huntington Palisades home was running constantly. Technician came same day, found the fan issue and condenser buildup from the hillside dust, fixed everything in one visit. Also explained the maintenance schedule for our location. Really know their craft."',
    author: '— Eric K., Huntington Palisades'
  },
  {
    stars: 5,
    text: '"Just moved into our rebuilt home and the Wolf oven was running 22 degrees low. Same Day came out, calibrated both ovens, checked every burner, confirmed the hood. Finally everything works right. Wish we\'d called during construction — this is exactly the kind of service new builds need."',
    author: '— Diana R., Temescal Canyon area, Pacific Palisades'
  }
];

const pricingTiers = [
  { appliance: 'Refrigerator (standard)', range: '$200–$450', note: 'Fan motor, coil cleaning, ice maker, thermostat' },
  { appliance: 'Sub-Zero / Wolf Built-In', range: '$300–$700+', note: 'OEM parts · Built-in integration · Sealed systems', featured: true },
  { appliance: 'La Cornue / Gaggenau', range: '$300–$800+', note: 'European luxury · OEM parts sourced · Full calibration' },
  { appliance: 'Miele Washer / Dishwasher', range: '$200–$500', note: 'European models · OEM Miele parts · Electronic systems' },
  { appliance: 'Standard Appliances', range: '$150–$350', note: 'Samsung, LG, Whirlpool, GE, Bosch' },
  { appliance: 'Diagnostic Fee', range: '$89', note: 'Waived when you proceed with the repair' }
];

const faqs = [
  {
    question: 'Do you offer same-day appliance repair in Pacific Palisades, CA?',
    answer: 'Yes. Our technicians cover all of Pacific Palisades 90272 — The Riviera, Huntington Palisades, Castellammare, Alphabet Streets, Marquez Knolls, Potrero Canyon, Temescal Canyon, Sunset Mesa, and Los Liones. Call before noon and we can typically be there the same afternoon.'
  },
  {
    question: 'Do you repair Sub-Zero, Wolf, La Cornue, and Gaggenau appliances in Pacific Palisades?',
    answer: 'Yes. Pacific Palisades homes — particularly in The Riviera, Castellammare, and Huntington Palisades — frequently have Sub-Zero refrigerators, Wolf ranges, and high-end European brands including La Cornue, Gaggenau, and Miele. Our technicians are trained on all of these and carry OEM parts on every service vehicle.'
  },
  {
    question: 'Do you service newly installed appliances in rebuilt Pacific Palisades homes?',
    answer: 'Yes. Many Pacific Palisades homes are being rebuilt or renovated following the 2025 fires, with new kitchens featuring Sub-Zero, Wolf, Thermador, and other premium appliances. Our technicians work with new installations — calibrating ovens, checking refrigerator systems, servicing appliances in custom cabinetry. Call us if you\'re moving into a rebuilt or newly renovated Palisades home.'
  },
  {
    question: 'Does Pacific Palisades coastal air affect appliances differently?',
    answer: 'Yes. Castellammare and beachside areas of the Palisades have real salt-air exposure that accelerates corrosion on refrigerator condenser coils and dishwasher door gaskets. Our technicians account for this on every coastal call — we check coil condition proactively and recommend a shorter cleaning interval (every 4–6 months) for appliances in Castellammare, the Bluffs, and along PCH-adjacent properties.'
  },
  {
    question: 'What is your diagnostic fee in Pacific Palisades?',
    answer: 'Our diagnostic fee is $89, waived when you proceed with the repair. For luxury brands — Sub-Zero, Wolf, La Cornue, Gaggenau, Miele — repair costs may be higher due to OEM part pricing. We give you a full written estimate before starting any work.'
  },
  {
    question: 'Do you work with estate managers and household staff in Pacific Palisades?',
    answer: 'Yes. Many Pacific Palisades properties are managed by household staff or estate managers. We coordinate access with whoever handles the property, work on flexible schedules, and handle communication professionally. Call us to discuss how we work with your household.'
  },
  {
    question: 'Do you also serve Malibu, Brentwood, and Santa Monica from Pacific Palisades?',
    answer: 'Yes. Our Pacific Palisades service area extends along the coast to Malibu and east to Brentwood, Santa Monica, and West LA. ZIP codes 90265, 90049, 90402, and 90025 are all in our regular coverage area.'
  }
];

const nearbyCities = [
  { name: 'Malibu', slug: 'malibu' },
  { name: 'Brentwood', slug: 'brentwood' },
  { name: 'Santa Monica', slug: 'santa-monica' },
  { name: 'Beverly Hills', slug: 'beverly-hills' },
  { name: 'Los Angeles', slug: 'los-angeles' },
  { name: 'West Hollywood', slug: 'west-hollywood' },
  { name: 'Culver City', slug: 'culver-city' },
  { name: 'Marina del Rey', slug: 'marina-del-rey' }
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair"
    headlineCity="Pacific Palisades, CA"
    subheadline="Sub-Zero, Wolf, Thermador, La Cornue, Gaggenau, Miele — the appliances in Pacific Palisades homes. Our technicians cover all of 90272, from The Riviera to Marquez Knolls to Castellammare. Same-day service, OEM parts, 90-day warranty."
    zips={zips}
    tier={1}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance Repair in Pacific Palisades — What Our Technicians See Here"
    paragraphs={introParagraphs}
    bookingTitle="Pacific Palisades Service"
    bookingSub="90272 · Sub-Zero · Wolf · La Cornue · Gaggenau"
  />

  <ServicesGrid
    cityName={cityName}
    headline="What We Repair in Pacific Palisades"
    subhead="All luxury brands · Built-ins & custom cabinetry · 90272"
    services={services}
  />

  <CustomNarrative
    eyebrow={luxuryNarrative.eyebrow}
    headline={luxuryNarrative.headline}
    paragraphs={luxuryNarrative.paragraphs}
    background="black"
  />

  <ServiceArea
    cityName={cityName}
    headline="All of Pacific Palisades — Every Neighborhood"
    subheadline="ZIP code 90272 — from the canyon streets to the coastal bluffs"
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={[]}
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Jobs in Pacific Palisades"
    jobs={recentJobs}
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="Why Pacific Palisades Homeowners Call Us"
    reasons={whyReasons}
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What Pacific Palisades Clients Say"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Appliance Repair Costs in Pacific Palisades"
    subhead="Written estimate before we start. $89 diagnostic — waived with repair. OEM parts only."
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="Questions Pacific Palisades Clients Ask"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby Areas"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance broken in Pacific Palisades?"
    body="La Cornue · Gaggenau · Sub-Zero · Wolf · All brands — same-day in 90272. $89 diagnostic waived with repair. 90-day warranty. OEM parts only."
  />
</CityLayoutV2>
