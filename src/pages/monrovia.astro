---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import CustomNarrative from '../components/cities/v2/CustomNarrative.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES, MAIN_PHONE, isPlaceholderPhone } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

const citySlug = 'monrovia';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = 'Monrovia';
const zips = ['91016'];

const phone = branch.phone;
const phoneRaw = `+1${phone.replace(/\D/g, '')}`;

const title = `Appliance Repair Monrovia CA 91016 — Same Day | Old Town · Foothill · Sub-Zero | ${phone}`;
const description = `Same-day appliance repair in Monrovia, CA 91016. Sub-Zero, Wolf, Samsung, LG, all brands. Licensed, OEM parts Weekends available.`;
const canonical = 'https://samedayappliance.repair/monrovia/';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { '@type': 'City', name: 'Monrovia', sameAs: 'https://en.wikipedia.org/wiki/Monrovia,_California' }
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$',
  license: 'BHGS #A49573'

};

const introParagraphs = [
  "Monrovia divides naturally along Foothill Boulevard. South of Foothill is Old Town and the historic residential streets — Victorian homes and Craftsman bungalows from the 1890s through the 1930s along Myrtle Avenue, Mayflower Village, and the surrounding blocks. These homes have been lovingly maintained for decades, and many have been updated with modern appliances sitting alongside original architectural detail that requires care during service.",
  "North of Foothill, the homes get larger and newer — more recent construction with updated kitchens, some with Sub-Zero refrigerators, Wolf ranges, and Viking appliances. It's a different service call from the older south-side bungalows, and our technicians handle both without pretending one approach fits everything.",
  "Hard water is a consistent factor in Monrovia. Served by the San Gabriel Valley Municipal Water District — the same mineral-rich SGV groundwater that runs through Arcadia and San Marino — ice maker inlet valves and dishwasher spray arms scale up faster here than the national average. We test for this on every relevant Monrovia call. It comes up regularly.",
  `Diagnostic fee: <strong>$89</strong> — waived with repair. Written estimate before we start. <strong>90-day warranty</strong> on all parts and labor. Available <strong>Saturdays and Sundays</strong>. Call <a href="tel:${phoneRaw}">${phone}</a>.`
];

const services = [
  { icon: '🧊', name: 'Refrigerator Repair', slug: 'refrigerator', issues: 'Hard water ice maker · Not cooling · Fan motor · Sub-Zero built-in', brands: 'Sub-Zero · Samsung · LG · GE · Whirlpool · Wolf' },
  { icon: '🍽️', name: 'Dishwasher Repair', slug: 'dishwasher', issues: 'Hard water spray arm scale · Not draining · Spots · Error codes', brands: 'Bosch · KitchenAid · Samsung · LG · Miele · GE' },
  { icon: '🫧', name: 'Washer Repair', slug: 'washer', issues: 'Hard water inlet screens · Not draining · Not spinning · Error codes', brands: 'LG · Samsung · Whirlpool · Maytag · Bosch · Speed Queen' },
  { icon: '♨️', name: 'Dryer Repair + Vent Cleaning', slug: 'dryer', issues: 'Not heating · Older vent runs · Thermal fuse · Lint buildup', brands: 'LG · Samsung · GE · Maytag · Whirlpool · Electrolux' },
  { icon: '🔥', name: 'Oven, Range & Stove', slug: 'oven', issues: 'Not heating · Gas igniter · Temperature off · Wolf & Viking', brands: 'Wolf · Viking · Thermador · GE · Samsung · Bosch' },
  { icon: '❄️', name: 'Freezer & Ice Maker Repair', slug: 'freezer', issues: 'Hard water inlet valve · Not freezing · Ice stopped · Frost', brands: 'Sub-Zero · Samsung · LG · GE · Whirlpool · Frigidaire' },
  { icon: '🍷', name: 'Wine Cooler Repair', slug: 'wine-cooler', issues: 'Temperature off · Compressor · Under-counter · Built-in', brands: 'Sub-Zero · True · U-Line · Liebherr · Dacor' },
  { icon: '🔆', name: 'Cooktop & Range Hood', slug: 'cooktop', issues: 'Igniter · Gas burner · Induction not heating · Hood motor', brands: 'Wolf · Viking · GE · Bosch · Samsung · Broan' }
];

const hardWaterTipNarrative = {
  headline: 'What We Know About This City — Old Town, Foothill, and SGVMWD Hard Water',
  paragraphs: [
    "<strong>Hard water tip for Monrovia:</strong> SGVMWD delivers mineral-rich groundwater throughout the SGV. If your refrigerator ice maker has been producing less and less ice over several months, or your dishwasher is leaving spots despite a clean filter — mineral scale on the inlet valve is the most common cause in this water district. A 6-month refrigerator filter replacement cycle (not 12 months) helps significantly."
  ]
};

const neighborhoods = [
  { name: 'Old Town Monrovia', zip: '91016', featured: true },
  { name: 'Myrtle Ave historic corridor', zip: '91016', featured: true },
  { name: 'Foothill neighborhoods (north)', zip: '91016', featured: true },
  { name: 'Mayflower Village', zip: '91016' },
  { name: 'Bradbury adjacent', zip: '91016' },
  { name: 'South Monrovia', zip: '91016' }
];

const keyStreets = ['Myrtle Ave', 'Foothill Blvd', 'Huntington Drive', 'Duarte Road', 'Primrose Ave', 'Colorado Blvd'];

const recentJobs = [
  {
    appliance: 'LG Refrigerator',
    location: 'Myrtle Ave, Old Town, 91016',
    quote: 'Ice maker completely stopped over a few months',
    description: '1920s Craftsman bungalow on Myrtle — the kitchen had been updated but the galvanized supply lines were original, adding iron on top of the SGVMWD mineral content. LG French door ice maker: inlet valve completely blocked with calcium-iron scale deposits. Replaced with an OEM LG inlet valve, flushed the water line, installed a new in-door filter (original, never changed). Full ice production within 24 hours. Explained the combined effect of SGVMWD water and older pipes — owner set a 6-month filter reminder.',
    outcome: '✓ Same day · OEM LG inlet valve · Older pipe factor explained'
  },
  {
    appliance: 'Samsung Dishwasher',
    location: 'Foothill neighborhood, north Monrovia',
    quote: 'Everything comes out with white film — spots on everything',
    description: "Newer construction home north of Foothill — Samsung DW80 series with both spray arm ports clogged from SGVMWD mineral scale. Less than 18 months old. Descaled both arms completely, deep-cleaned the filter trap, ran a full citric acid maintenance cycle. Tested three loads before leaving — clear glasses, no spots. Advised the monthly dishwasher tablet routine given the SGV water supply. Owner hadn't realized how quickly scale builds in this water district.",
    outcome: '✓ Same day · Scale cleared · Three loads confirmed · Routine advised'
  },
  {
    appliance: 'Maytag Dryer',
    location: 'Mayflower Village, 91016',
    quote: 'No heat at all, clothes still wet after full cycle',
    description: 'Maytag electric dryer — thermal fuse blown from a partially blocked vent run. The vent exited through the side of the original 1940s garage conversion, with a 45-degree offset that had accumulated lint over years. Replaced the thermal fuse, cleared the vent run completely, confirmed strong airflow at the exterior termination. Called on a Saturday morning — had it done by noon. The family had laundry piling up from the week.',
    outcome: '✓ Saturday same day · Vent cleared · Done by noon'
  },
  {
    appliance: 'Wolf Range',
    location: 'Bradbury-adjacent, north Monrovia',
    quote: 'Oven running at wrong temperature, two burners clicking',
    description: 'Wolf 36-inch dual-fuel in a foothill-area home near the Bradbury border — oven igniter weak current (the Wolf-specific failure where the igniter glows without drawing enough amperage to open the gas valve), two surface electrodes corroded. Replaced oven igniter and both electrodes with OEM Wolf parts, calibrated the oven (running 18°F low). All six burners tested and confirmed before leaving. Homeowner had been compensating with oven temp adjustments for months without realizing the igniter was the cause.',
    outcome: '✓ Same day · OEM Wolf · Oven calibrated · All burners confirmed'
  }
];

const whyReasons = [
  {
    iconKey: 'team' as const,
    title: 'Old Town & Foothill Both',
    body: 'Craftsman bungalows in Old Town have different service situations than foothill homes north of Foothill Boulevard. We work in both without a one-size-fits-all approach — older homes get attention to aging supply lines and vent configurations; newer homes get the luxury brand focus they need.'
  },
  {
    iconKey: 'parts' as const,
    title: 'SGVMWD Hard Water',
    body: 'San Gabriel Valley Municipal Water District groundwater means faster scale on ice maker inlet valves and dishwasher spray arms. We test for mineral deposits proactively on every relevant Monrovia call — it consistently comes up in this water district.'
  },
  {
    iconKey: 'clock' as const,
    title: 'Open Weekends',
    body: "Saturday 8am–7pm and Sunday 9am–5pm. Some Monrovia appliance companies close on weekends. We're available when you need us — including Saturday morning emergency calls before family comes over."
  },
  {
    iconKey: 'shield' as const,
    title: '90-Day Warranty, OEM Only',
    body: 'Every repair backed by 90 days on parts and labor. Genuine OEM parts only. $89 diagnostic waived with repair. Written estimate before we start. California licensed, BBB A+ rated.'
  }
];

const testimonials = [
  {
    stars: 5,
    text: '"Our Craftsman home on Myrtle had no ice maker output for months. Same Day came out, identified the mineral scale from our old pipes plus the SGV water, replaced the inlet valve, explained exactly why it keeps happening. Full ice production by next morning. Very thorough and honest about the water quality issue."',
    author: '— Robert K., Myrtle Ave, Old Town Monrovia'
  },
  {
    stars: 5,
    text: '"Brand new Samsung dishwasher leaving white film on everything after less than 2 years. Tech showed me the mineral deposits on both spray arms — clogged by hard water. Cleared everything in an hour, explained the SGV water issue, gave me a maintenance routine. Clean dishes from the first load after. Very knowledgeable."',
    author: '— Lisa M., North Monrovia'
  },
  {
    stars: 5,
    text: '"Called Saturday morning — dryer completely dead, no heat, laundry piling up. Same Day came out the same morning, found the blocked vent and blown fuse, fixed it by noon. Most companies I called said Monday earliest. The weekend availability is what makes the difference."',
    author: '— Angela T., Mayflower Village, Monrovia'
  }
];

const pricingTiers = [
  { appliance: 'Refrigerator / Ice Maker', range: '$150 – $400', note: 'SGVMWD hard water inlet valve · Fan motor · OEM', featured: true },
  { appliance: 'Dishwasher', range: '$150 – $320', note: 'Hard water descaling · Drain pump · Spray arm', featured: true },
  { appliance: 'Sub-Zero / Wolf / Viking', range: '$300 – $700+', note: 'OEM parts · Built-in · Foothill estate service' },
  { appliance: 'Dryer + Vent Cleaning', range: '$150 – $320', note: 'Thermal fuse · Older vent runs · Airflow check' },
  { appliance: 'Washer / Oven / Range', range: '$150 – $400', note: 'Standard repair range · Gas & electric' },
  { appliance: 'Diagnostic Fee', range: '$89', note: 'Waived when you proceed with the repair' }
];

const faqs = [
  {
    question: 'Do you offer same-day appliance repair in Monrovia, CA?',
    answer: "Yes. Our technicians cover all of Monrovia 91016 — Old Town and the Myrtle Avenue corridor, the foothill neighborhoods north of Foothill Boulevard, Mayflower Village, and every street in the city. Call before noon for same-day afternoon service. We're also available Saturdays and Sundays."
  },
  {
    question: 'Does hard water in Monrovia affect appliances?',
    answer: 'Yes. Monrovia is served by the San Gabriel Valley Municipal Water District, which delivers mineral-rich groundwater from the SGV basin. Ice maker inlet valves, dishwasher spray arms, and washing machine inlet screens accumulate scale faster than in softer-water cities. We check for this proactively on every Monrovia call involving ice makers and dishwashers.'
  },
  {
    question: "Do you repair appliances in Monrovia's older historic homes?",
    answer: "Yes. Old Town Monrovia has a significant stock of Victorian and Craftsman homes from the 1890s–1930s, many of which have been updated and maintained. These older homes sometimes have complex dryer vent installations, aging water supply lines that compound hard water effects, or non-standard appliance configurations. We're familiar with these situations and come prepared."
  },
  {
    question: 'Do you repair Sub-Zero, Wolf, and luxury appliances in Monrovia?',
    answer: 'Yes. The foothill neighborhoods north of Foothill Boulevard and larger Monrovia homes frequently have Sub-Zero refrigerators, Wolf ranges, and Viking appliances. Our technicians carry OEM parts for these brands on every service vehicle.'
  },
  {
    question: 'Are you available on weekends in Monrovia?',
    answer: "Yes. Saturday 8am–7pm and Sunday 9am–5pm. Some Monrovia appliance companies close on weekends — we don't."
  },
  {
    question: 'What is your diagnostic fee in Monrovia?',
    answer: 'Our diagnostic fee is $89, waived when you proceed with the repair. Written estimate before we start. Most Monrovia repairs run $150–$400 depending on the appliance.'
  },
  {
    question: 'Do you also serve Arcadia, Duarte, and Temple City?',
    answer: 'Yes. Our Monrovia service area extends to Arcadia, Duarte, Temple City, Bradbury, Azusa, Glendora, and South Pasadena. All within our regular SGV service route from the Pasadena branch.'
  }
];

const nearbyCities = [
  { name: 'Pasadena', slug: 'pasadena' },
  { name: 'Arcadia', slug: 'arcadia' },
  { name: 'South Pasadena', slug: 'south-pasadena' },
  { name: 'San Marino', slug: 'san-marino' },
  { name: 'Glendale', slug: 'glendale' },
  { name: 'Burbank', slug: 'burbank' },
  { name: 'Los Angeles', slug: 'los-angeles' },
  { name: 'West Hollywood', slug: 'west-hollywood' }
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair"
    headlineCity="Monrovia, CA"
    subheadline="From Craftsman bungalows in Old Town to foothill homes above Foothill Boulevard — all of Monrovia 91016. Sub-Zero, Wolf, Samsung, LG, all brands. Same-day service, OEM parts, 90-day warranty. Weekends available."
    zips={zips}
    tier={3}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance Repair in Monrovia — What We Know About This City"
    paragraphs={introParagraphs}
    bookingTitle="Monrovia Service Team"
    bookingSub="91016 · Old Town & foothill · Weekends ok"
  />

  <ServicesGrid
    cityName={cityName}
    headline="What We Repair in Monrovia"
    services={services}
  />

  <CustomNarrative
    headline={hardWaterTipNarrative.headline}
    paragraphs={hardWaterTipNarrative.paragraphs}
    background="white"
  />

  <ServiceArea
    cityName={cityName}
    headline="All of Monrovia — 91016"
    subheadline="Old Town to foothill — every neighborhood in the city"
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={keyStreets}
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Jobs in Monrovia"
    subhead="Real calls from 91016 — historic bungalows, foothill homes, SGVMWD hard water."
    jobs={recentJobs}
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="Why Monrovia Calls Us Back"
    reasons={whyReasons}
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What Monrovia Customers Are Saying"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Appliance Repair Costs in Monrovia"
    subhead="Written estimate before we start. $89 diagnostic — waived with repair."
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="Questions Monrovia Customers Ask"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby Areas"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance broken in Monrovia?"
    body="Old Town · Foothill homes · SGVMWD hard water specialists · Weekends available. 91016. $89 diagnostic waived with repair. 90-day warranty."
  />
</CityLayoutV2>
