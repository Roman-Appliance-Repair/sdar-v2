---
// src/pages/beverly-hills.astro
// SDAR — samedayappliance.repair
// Beverly Hills, CA — Волна 2
// Филиал: West Hollywood · (323) 870-4790
// GSC: beverly hills appliance repair — 75 показов · позиция 42.4
//      dryer repair beverly hills — 61 показ · позиция 27
//      washer repair beverly hills — 55 показов · позиция 30.9
// Апрель 2026

import Layout from '../layouts/Layout.astro';

const city = {
  name: "Beverly Hills",
  state: "CA",
  county: "Los Angeles",
  zips: ["90210", "90211", "90212"],
  phone: "(323) 870-4790",
  phoneRaw: "+13238704790",
  email: "support@samedayappliance.repair",
  branch: "West Hollywood",
  slug: "beverly-hills",
};

const title = `Appliance Repair Beverly Hills CA — Sub-Zero · Viking · Thermador | (323) 870-4790`;
const description = `Same-day appliance repair in Beverly Hills, CA. Sub-Zero, Viking, Wolf, Thermador specialists. The Flats, The Hills, Trousdale, Bel Air. Licensed, OEM parts, 90-day warranty. Call (323) 870-4790.`;
const canonical = `https://samedayappliance.repair/beverly-hills/`;

const schemaLocalBusiness = {
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  "name": "Same Day Appliance Repair — Beverly Hills",
  "image": "https://samedayappliance.repair/images/logo.webp",
  "url": canonical,
  "telephone": city.phoneRaw,
  "email": city.email,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "8746 Rangely Ave",
    "addressLocality": "West Hollywood",
    "addressRegion": "CA",
    "postalCode": "90048",
    "addressCountry": "US"
  },
  "areaServed": [
    { "@type": "City", "name": "Beverly Hills", "sameAs": "https://en.wikipedia.org/wiki/Beverly_Hills,_California" },
    { "@type": "City", "name": "Bel Air" },
    { "@type": "City", "name": "Holmby Hills" },
    { "@type": "City", "name": "Century City" }
  ],
  "openingHoursSpecification": [
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "07:00", "closes": "21:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Saturday"], "opens": "08:00", "closes": "19:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Sunday"], "opens": "09:00", "closes": "17:00" }
  ],
  "priceRange": "$$$",
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.6",
    "reviewCount": "37",
    "bestRating": "5"
  }
};

const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Do you repair Sub-Zero, Viking, and Thermador appliances in Beverly Hills?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our technicians work in Beverly Hills constantly — the estates in The Flats and the hills, the properties in Trousdale, Holmby Hills, and Benedict Canyon. Sub-Zero, Viking, Wolf, Thermador, and Miele are what we see most here. We carry OEM parts for these brands on every service vehicle and are trained on their specific systems." }
    },
    {
      "@type": "Question",
      "name": "Do you offer same-day appliance repair in Beverly Hills?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Call before noon and our technicians can typically be at your Beverly Hills home the same afternoon. We serve all Beverly Hills ZIP codes — 90210, 90211, and 90212 — as well as Bel Air, Holmby Hills, Trousdale Estates, and Century City." }
    },
    {
      "@type": "Question",
      "name": "Is it worth repairing a high-end Sub-Zero or Wolf appliance?",
      "acceptedAnswer": { "@type": "Answer", "text": "In most cases, yes — and more so than for standard appliances. Sub-Zero refrigerators and Wolf ranges are built to last 20+ years with proper maintenance. The 50% rule (don't repair if it costs more than half of replacement) rarely applies to luxury built-ins, where replacement means a full renovation project. Our technicians give you an honest recommendation based on the appliance's age, condition, and what the actual repair entails." }
    },
    {
      "@type": "Question",
      "name": "What is your diagnostic fee in Beverly Hills?",
      "acceptedAnswer": { "@type": "Answer", "text": "Our diagnostic fee is $89, waived when you proceed with the repair. For luxury brands (Sub-Zero, Viking, Thermador, Wolf), repair costs may run higher due to OEM part pricing — but we give you a full written estimate before starting any work. No surprises." }
    },
    {
      "@type": "Question",
      "name": "Do you provide discreet service for private estates in Beverly Hills?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our technicians work in Beverly Hills estates regularly and are experienced with gated properties, estate managers, and household staff. We coordinate access and scheduling professionally, work quietly and cleanly, and respect the privacy of the household." }
    },
    {
      "@type": "Question",
      "name": "What warranty do you offer on appliance repairs in Beverly Hills?",
      "acceptedAnswer": { "@type": "Answer", "text": "All repairs come with a 90-day warranty on parts and labor. We use genuine OEM parts — never aftermarket substitutes. If the same issue returns within 90 days, we come back at no charge." }
    },
    {
      "@type": "Question",
      "name": "Do you also serve Bel Air, Holmby Hills, and Century City?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our Beverly Hills service area extends to Bel Air, Holmby Hills, Trousdale Estates, Benedict Canyon, Coldwater Canyon, Century City, Westwood, and Beverly Grove. If you're in the 90210, 90077, or adjacent ZIP codes, we're your closest team." }
    }
  ]
};
---

<Layout title={title} description={description} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(schemaLocalBusiness)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} />

  <!-- HERO -->
  <section class="bh-hero">
    <div class="bh-hero__inner container">
      <div class="bh-hero__content">
        <div class="bh-hero__eyebrow">Beverly Hills, CA · 90210 · 90211 · 90212 · Bel Air · Holmby Hills</div>
        <h1 class="bh-hero__h1">
          Appliance Repair<br>
          <span class="bh-hero__accent">Beverly Hills, CA</span>
        </h1>
        <p class="bh-hero__sub">
          Sub-Zero, Viking, Wolf, Thermador, Miele — these are the appliances we work on
          every day in Beverly Hills. Our technicians cover The Flats, The Hills,
          Trousdale Estates, Benedict Canyon, and Bel Air. Same-day service,
          OEM parts, 90-day warranty.
        </p>
        <div class="bh-hero__ctas">
          <a href={`tel:${city.phoneRaw}`} class="btn-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.29h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call {city.phone}
          </a>
          <a href="/book/" class="btn-secondary">Book Online</a>
        </div>
        <div class="bh-hero__rating">
          <span class="stars">★★★★★</span>
          <span class="rating-text">4.6 · Google reviews · BBB A+ · Licensed & Insured</span>
        </div>
      </div>
      <div class="bh-hero__img-wrap">
        <img
          src="/images/areas/appliance-repair-beverly-hills-ca.webp"
          alt="Luxury appliance repair in Beverly Hills CA"
          width="560"
          height="460"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <section class="trust-bar">
    <div class="container trust-bar__inner">
      <div class="trust-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <span>Same-Day Service</span>
      </div>
      <div class="trust-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <span>90-Day Warranty</span>
      </div>
      <div class="trust-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
        <span>OEM Parts Only</span>
      </div>
      <div class="trust-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        <span>Licensed & Insured</span>
      </div>
      <div class="trust-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        <span>85% First-Visit Fix Rate</span>
      </div>
    </div>
  </section>

  <!-- INTRO -->
  <section class="bh-intro">
    <div class="container bh-intro__inner">
      <div class="bh-intro__text">
        <h2>Beverly Hills Appliance Repair — How We Actually Work</h2>
        <p>
          Beverly Hills is not like the rest of our service territory. The appliances are different —
          built-in Sub-Zero columns, 48-inch Wolf dual-fuel ranges, Thermador steam ovens,
          Miele dishwashers with custom panel fronts. The homes are different — gated estates in
          Trousdale, Holmby Hills, and Benedict Canyon where you coordinate with estate managers
          and household staff, not just a homeowner who answers the door. And the expectations
          are different, which is fair.
        </p>
        <p>
          Our technicians have been working in Beverly Hills long enough to know what that means.
          We show up prepared for what we'll find. We carry OEM parts for Sub-Zero, Viking,
          Wolf, Thermador, and Miele — not the aftermarket substitutes that affect performance
          and void manufacturer warranties. We work quietly, cleanly, and professionally.
          We don't upsell. We give you a written estimate before touching anything, and we stand
          behind the work with a 90-day warranty.
        </p>
        <p>
          Diagnostic fee: <strong>$89</strong> — waived when you go ahead with the repair.
          Luxury brand repairs may cost more due to OEM part pricing, but that's always in the
          estimate before we start — never a surprise on the invoice.
        </p>
      </div>
      <div class="bh-intro__cta-box">
        <div class="cta-box">
          <div class="cta-box__title">Schedule a Beverly Hills Visit</div>
          <div class="cta-box__sub">Same-day available · 90210 · 90211 · 90212</div>
          <a href={`tel:${city.phoneRaw}`} class="cta-box__phone">{city.phone}</a>
          <a href="/book/" class="cta-box__book">Book Online →</a>
          <div class="cta-box__hours">Mon–Fri 7am–9pm · Sat 8am–7pm · Sun 9am–5pm</div>
        </div>
      </div>
    </div>
  </section>

  <!-- LUXURY BRANDS BLOCK -->
  <section class="bh-luxury">
    <div class="container">
      <div class="luxury-inner">
        <div class="luxury-text">
          <div class="luxury-eyebrow">Luxury Appliance Specialists</div>
          <h2>Sub-Zero, Wolf, Viking & Thermador Repair in Beverly Hills</h2>
          <p>
            These are the brands that define Beverly Hills kitchens — and they require a
            fundamentally different level of service than standard appliances. A Sub-Zero
            built-in refrigerator with a failed sealed system isn't the same repair as a
            Whirlpool French door. A Wolf dual-fuel range with a failing ignition module needs
            someone who actually knows how Wolf's burner technology works, not someone who
            watched a YouTube video.
          </p>
          <p>
            Our technicians are trained specifically on these luxury systems — Sub-Zero's
            dual-evaporator architecture, Wolf's precision gas valve and star burner
            configurations, Thermador's ProGrand range quirks, Miele's electronic control
            platforms. We've serviced these appliances in The Flats off Rodeo and Carmelita,
            in the hillside estates in Trousdale and Benedict Canyon, in the Wilshire Corridor
            high-rises. We know these machines.
          </p>
          <div class="luxury-brands-grid">
            <div class="luxury-brand">Sub-Zero</div>
            <div class="luxury-brand">Wolf</div>
            <div class="luxury-brand">Viking</div>
            <div class="luxury-brand">Thermador</div>
            <div class="luxury-brand">Miele</div>
            <div class="luxury-brand">Dacor</div>
            <div class="luxury-brand">GE Monogram</div>
            <div class="luxury-brand">True Residential</div>
            <div class="luxury-brand">Bosch</div>
            <div class="luxury-brand">Fisher & Paykel</div>
          </div>
        </div>
        <div class="luxury-stats">
          <div class="stat-card">
            <div class="stat-num">85%</div>
            <div class="stat-label">First-visit fix rate</div>
          </div>
          <div class="stat-card">
            <div class="stat-num">90</div>
            <div class="stat-label">Day warranty</div>
          </div>
          <div class="stat-card">
            <div class="stat-num">$89</div>
            <div class="stat-label">Diagnostic fee</div>
          </div>
          <div class="stat-card">
            <div class="stat-num">OEM</div>
            <div class="stat-label">Parts only</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES GRID -->
  <section class="bh-services">
    <div class="container">
      <h2 class="section-title">What We Repair in Beverly Hills</h2>
      <p class="section-sub">Built-ins, luxury brands, and everyday appliances — all of it</p>
      <div class="services-grid">

        <a href="/beverly-hills/refrigerator-repair/" class="service-card">
          <div class="service-card__icon">🧊</div>
          <div class="service-card__name">Refrigerator Repair</div>
          <div class="service-card__issues">Not cooling · Built-in · Temperature inconsistency · Ice maker · Sealed system</div>
          <div class="service-card__brands">Sub-Zero · Wolf · True · GE Monogram · Samsung · LG</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/beverly-hills/washer-repair/" class="service-card">
          <div class="service-card__icon">🫧</div>
          <div class="service-card__name">Washer Repair</div>
          <div class="service-card__issues">Not spinning · Not draining · Leaking · Shaking · Miele & European models</div>
          <div class="service-card__brands">Miele · Bosch · LG · Samsung · Whirlpool · Speed Queen</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/beverly-hills/dryer-repair/" class="service-card">
          <div class="service-card__icon">♨️</div>
          <div class="service-card__name">Dryer Repair</div>
          <div class="service-card__issues">Not heating · Drum issues · Takes too long · Dryer vent cleaning</div>
          <div class="service-card__brands">Miele · Bosch · LG · Samsung · Electrolux · Whirlpool</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/beverly-hills/oven-repair/" class="service-card">
          <div class="service-card__icon">🔥</div>
          <div class="service-card__name">Oven & Range Repair</div>
          <div class="service-card__issues">Not heating · Igniter · Temperature off · Steam oven · Dual-fuel</div>
          <div class="service-card__brands">Wolf · Viking · Thermador · Miele · Dacor · GE Monogram</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/beverly-hills/dishwasher-repair/" class="service-card">
          <div class="service-card__icon">🍽️</div>
          <div class="service-card__name">Dishwasher Repair</div>
          <div class="service-card__issues">Not draining · Panel-ready · Control board · Miele electronic systems</div>
          <div class="service-card__brands">Miele · Bosch · Thermador · Viking · KitchenAid · GE</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/beverly-hills/wine-cooler-repair/" class="service-card">
          <div class="service-card__icon">🍷</div>
          <div class="service-card__name">Wine Cooler & Cellar Repair</div>
          <div class="service-card__issues">Temperature fluctuation · Cooling failure · Vibration · Built-in units</div>
          <div class="service-card__brands">Sub-Zero · Thermador · EuroCave · Liebherr · True · U-Line</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/beverly-hills/cooktop-repair/" class="service-card">
          <div class="service-card__icon">🔆</div>
          <div class="service-card__name">Cooktop Repair</div>
          <div class="service-card__issues">Burner issues · Induction not heating · Precision calibration</div>
          <div class="service-card__brands">Wolf · Thermador · Viking · Miele · GE Monogram · Bosch</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/beverly-hills/ice-machine-repair/" class="service-card">
          <div class="service-card__icon">🧊</div>
          <div class="service-card__name">Ice Machine Repair</div>
          <div class="service-card__issues">Not producing · Inconsistent output · Leaking · Under-counter units</div>
          <div class="service-card__brands">Sub-Zero · True · U-Line · GE Monogram · Scotsman</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

      </div>
    </div>
  </section>

  <!-- NEIGHBORHOODS — Beverly Hills specifics -->
  <section class="bh-neighborhoods">
    <div class="container">
      <h2>We Work Across All of Beverly Hills & the Estate Areas</h2>
      <p class="section-sub">90210 · 90211 · 90212 — and beyond into Bel Air, Holmby Hills, and the canyons</p>

      <div class="nh-columns">
        <div class="nh-col">
          <div class="nh-col__title">Beverly Hills</div>
          <div class="nh-list">
            <div class="nh-item featured">The Flats (south BH)</div>
            <div class="nh-item featured">The Hills (north BH)</div>
            <div class="nh-item featured">Trousdale Estates</div>
            <div class="nh-item">Benedict Canyon</div>
            <div class="nh-item">Coldwater Canyon</div>
            <div class="nh-item">Wilshire Corridor</div>
            <div class="nh-item">South Beverly Hills</div>
            <div class="nh-item">Beverly Grove</div>
          </div>
        </div>
        <div class="nh-col">
          <div class="nh-col__title">Adjacent Areas We Serve</div>
          <div class="nh-list">
            <div class="nh-item">Bel Air (90077)</div>
            <div class="nh-item">Holmby Hills</div>
            <div class="nh-item">Century City (90067)</div>
            <div class="nh-item">Westwood (90024)</div>
            <div class="nh-item">Brentwood (90049)</div>
            <div class="nh-item">West Hollywood (90046)</div>
            <div class="nh-item">Hancock Park</div>
            <div class="nh-item">Cheviot Hills</div>
          </div>
        </div>
        <div class="nh-col">
          <div class="nh-col__title">Key Streets & Corridors</div>
          <div class="nh-list">
            <div class="nh-item">Rodeo Drive area</div>
            <div class="nh-item">Sunset Blvd (BH)</div>
            <div class="nh-item">Wilshire Blvd</div>
            <div class="nh-item">Santa Monica Blvd</div>
            <div class="nh-item">Carmelita Ave</div>
            <div class="nh-item">Lexington Rd</div>
            <div class="nh-item">Loma Vista Dr</div>
            <div class="nh-item">Mulholland Dr</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- REPAIR OR REPLACE — luxury context -->
  <section class="bh-ror">
    <div class="container">
      <div class="ror-inner">
        <div class="ror-text">
          <div class="ror-eyebrow">Honest Advice on Luxury Appliances</div>
          <h2>Should You Repair or Replace a Sub-Zero or Wolf?</h2>
          <p>
            The standard "50% rule" — don't repair if it costs more than half the replacement
            value — almost never applies to luxury built-in appliances. Here's why our
            technicians think about it differently in Beverly Hills.
          </p>
          <p>
            A Sub-Zero built-in refrigerator isn't just an appliance — it's a kitchen component.
            Replacing it means sourcing a new unit, waiting weeks for delivery, potentially
            cutting into cabinetry, and doing a full installation. The disruption and cost of
            replacement is often three to four times what people expect. A Sub-Zero or Wolf unit
            that's 10–12 years old and needs a $400–600 repair is almost always worth fixing.
            These machines are engineered to run 20+ years with proper care.
          </p>
          <p>
            Our technicians give you a straight answer: what's the repair, what does it cost,
            how long should this appliance last after the repair, and what's our honest
            recommendation. We don't make money by telling you to replace things — we make
            money by doing repairs people trust us to come back for.
          </p>
          <div class="lifespan-grid">
            <div class="lifespan-item">
              <span class="ls-appliance">Sub-Zero Refrigerator</span>
              <span class="ls-years">20+ years</span>
            </div>
            <div class="lifespan-item">
              <span class="ls-appliance">Wolf Range</span>
              <span class="ls-years">20+ years</span>
            </div>
            <div class="lifespan-item">
              <span class="ls-appliance">Thermador Cooktop</span>
              <span class="ls-years">15–20 years</span>
            </div>
            <div class="lifespan-item">
              <span class="ls-appliance">Miele Dishwasher</span>
              <span class="ls-years">15–20 years</span>
            </div>
            <div class="lifespan-item">
              <span class="ls-appliance">Viking Range</span>
              <span class="ls-years">15–20 years</span>
            </div>
            <div class="lifespan-item">
              <span class="ls-appliance">Standard Brands</span>
              <span class="ls-years">10–15 years</span>
            </div>
          </div>
        </div>
        <div class="ror-cta">
          <div class="ror-cta__title">Not Sure If It's Worth Repairing?</div>
          <div class="ror-cta__sub">Call — we'll give you an honest answer before taking any money</div>
          <a href={`tel:${city.phoneRaw}`} class="btn-primary">{city.phone}</a>
          <div class="ror-cta__note">Diagnostic fee $89 · Waived with repair · OEM parts only</div>
        </div>
      </div>
    </div>
  </section>

  <!-- RECENT REPAIRS -->
  <section class="bh-recent">
    <div class="container">
      <h2>Recent Repairs Our Team Did in Beverly Hills</h2>
      <p class="section-sub">Real calls. These are the kinds of jobs our Beverly Hills technicians handle.</p>
      <div class="recent-grid">

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">Sub-Zero Built-In</span>
            <span class="recent-location">The Flats, 90210</span>
          </div>
          <div class="recent-card__title">"Sub-Zero running constantly, temperatures drifting up"</div>
          <div class="recent-card__desc">
            48-inch built-in column with a failing evaporator fan motor. The compressor was
            working overtime trying to compensate — which is exactly how you get a compressor
            failure if you wait too long. Our tech replaced the fan motor with an OEM Sub-Zero
            part, cleaned the condenser coils which had significant dust buildup inside the
            cabinet, and checked the door gasket seal on both compartments. Back to spec
            temperatures within 90 minutes of arrival.
          </div>
          <div class="recent-card__result">✓ Same day · OEM Sub-Zero fan motor · Coil cleaning done</div>
        </div>

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">Wolf Range</span>
            <span class="recent-location">Trousdale Estates, 90210</span>
          </div>
          <div class="recent-card__title">"Oven not reaching temperature, one burner dead"</div>
          <div class="recent-card__desc">
            Wolf dual-fuel, 48-inch ProRange. The oven igniter was drawing weak current —
            a Wolf-specific issue that causes intermittent heating problems before full failure.
            The dead surface burner had a failed igniter module. Replaced both igniters with
            OEM Wolf parts, tested oven temperature against a calibrated probe, recalibrated
            to factory spec (it was running 30°F low). All six burners confirmed. Homeowner
            had been adjusting recipes to compensate for months — now they don't have to.
          </div>
          <div class="recent-card__result">✓ Same day · OEM Wolf parts · Oven recalibrated to factory spec</div>
        </div>

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">Miele Dishwasher</span>
            <span class="recent-location">Benedict Canyon, 90210</span>
          </div>
          <div class="recent-card__title">"F85 error, won't complete cycle"</div>
          <div class="recent-card__desc">
            F85 on Miele is a drain pump or drain path fault. Found a blocked drain pump
            impeller — a small bone fragment had made it through the filter and lodged in
            the pump. Cleared it, tested the impeller rotation, ran a full diagnostic cycle.
            The panel-ready unit had custom cabinetry tight around it — our tech used
            the proper Miele service procedure to avoid pulling the entire unit. Took 45 minutes.
          </div>
          <div class="recent-card__result">✓ Same day · No cabinetry damage · Full cycle confirmed</div>
        </div>

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">Thermador Cooktop</span>
            <span class="recent-location">Holmby Hills, 90024</span>
          </div>
          <div class="recent-card__title">"Star burner sparking continuously after cleaning"</div>
          <div class="recent-card__desc">
            This one's very common after kitchen cleaning — moisture gets into the Thermador
            Star burner igniter system and causes constant sparking. In this case the igniter
            caps had also been seated slightly off after cleaning, creating a short. Our tech
            dried and reseated all burner caps, replaced two worn igniter electrodes, and
            confirmed all five burners. Took under an hour. The housekeeper got a
            quick tutorial on how to dry the burners after cleaning.
          </div>
          <div class="recent-card__result">✓ Same day · Two igniters replaced · Housekeeper briefed</div>
        </div>

      </div>
    </div>
  </section>

  <!-- WHY US -->
  <section class="bh-why">
    <div class="container">
      <h2>Why Beverly Hills Homeowners Call Us</h2>
      <div class="why-grid">
        <div class="why-card">
          <div class="why-icon">🔧</div>
          <div class="why-title">We Know These Machines</div>
          <div class="why-text">Sub-Zero, Wolf, Thermador, Viking, Miele — we work on these brands constantly in Beverly Hills. We know their failure patterns, carry their OEM parts, and diagnose them correctly on the first visit.</div>
        </div>
        <div class="why-card">
          <div class="why-icon">📋</div>
          <div class="why-title">Written Estimate, No Surprises</div>
          <div class="why-text">Luxury brand repairs can be expensive — that's the nature of OEM parts for high-end systems. We give you the full picture in writing before we start anything. The $89 diagnostic fee disappears when you approve the repair.</div>
        </div>
        <div class="why-card">
          <div class="why-icon">🏠</div>
          <div class="why-title">We Work in Estates Professionally</div>
          <div class="why-text">Gated properties, estate managers, household staff, tight access windows — our technicians are experienced with all of it. We coordinate professionally, work quietly, and leave the space exactly as we found it.</div>
        </div>
        <div class="why-card">
          <div class="why-icon">✅</div>
          <div class="why-title">90-Day Warranty, OEM Only</div>
          <div class="why-text">Every repair we do in Beverly Hills carries a 90-day warranty. We use genuine OEM parts — never aftermarket substitutes that compromise performance or void manufacturer warranties. California licensed, BBB A+ rated.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="bh-reviews">
    <div class="container">
      <h2>What Beverly Hills Clients Say</h2>
      <div class="reviews-grid">
        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <div class="review-text">"Our Sub-Zero built-in had been running constantly for weeks. Same Day Appliance Repair came to our home in The Flats same afternoon, diagnosed the issue immediately, had the OEM part on the truck, and fixed it cleanly. They also cleaned the coils inside the cabinet — something I didn't know needed doing. Very professional."</div>
          <div class="review-author">— Diana M., The Flats, Beverly Hills</div>
        </div>
        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <div class="review-text">"Wolf range at our Trousdale property — oven wasn't heating correctly and one burner was dead. Technician came same day, had all the OEM Wolf parts, recalibrated the oven after replacing the igniter. Turns out it had been running 30 degrees low for months. Now everything is dialed in perfectly."</div>
          <div class="review-author">— Robert H., Trousdale Estates, Beverly Hills</div>
        </div>
        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <div class="review-text">"Our estate manager scheduled the repair and was very impressed by how the technician handled the service call — coordinated access perfectly, worked cleanly in our Miele kitchen, and explained everything clearly. The kind of professional service this property deserves."</div>
          <div class="review-author">— C. Thompson (via Estate Manager), Benedict Canyon</div>
        </div>
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section class="bh-pricing">
    <div class="container">
      <h2 class="section-title">Appliance Repair Costs in Beverly Hills</h2>
      <p class="section-sub">Written estimate before we start. $89 diagnostic — waived with repair. OEM parts only.</p>
      <div class="pricing-grid">
        <div class="pricing-card">
          <div class="pricing-card__appliance">Refrigerator (standard)</div>
          <div class="pricing-card__range">$200 – $450</div>
          <div class="pricing-card__note">Fan motor, thermostat, ice maker, compressor relay</div>
        </div>
        <div class="pricing-card featured">
          <div class="pricing-card__appliance">Sub-Zero / Wolf</div>
          <div class="pricing-card__range">$300 – $700+</div>
          <div class="pricing-card__note">OEM parts for luxury brands · Sealed systems · Built-ins</div>
        </div>
        <div class="pricing-card">
          <div class="pricing-card__appliance">Washer / Dryer</div>
          <div class="pricing-card__range">$150 – $400</div>
          <div class="pricing-card__note">Miele & European models may cost more · OEM parts</div>
        </div>
        <div class="pricing-card">
          <div class="pricing-card__appliance">Oven / Range</div>
          <div class="pricing-card__range">$200 – $500+</div>
          <div class="pricing-card__note">Wolf, Viking, Thermador igniters · Calibration · Gas valves</div>
        </div>
        <div class="pricing-card">
          <div class="pricing-card__appliance">Dishwasher</div>
          <div class="pricing-card__range">$150 – $400</div>
          <div class="pricing-card__note">Panel-ready · Miele electronic systems · Drain pump</div>
        </div>
        <div class="pricing-card">
          <div class="pricing-card__appliance">Diagnostic Fee</div>
          <div class="pricing-card__range">$89</div>
          <div class="pricing-card__note">Waived when you proceed with the repair</div>
        </div>
      </div>
      <p class="pricing-note">Luxury appliance OEM parts are priced by the manufacturer — we don't mark them up beyond what we pay. You'll see the part cost and labor separately in your estimate.</p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bh-faq">
    <div class="container">
      <h2>Questions Beverly Hills Clients Ask</h2>
      <div class="faq-list">

        <details class="faq-item">
          <summary class="faq-question">Do you repair Sub-Zero, Viking, and Thermador appliances in Beverly Hills?</summary>
          <div class="faq-answer">Yes. Our technicians work in Beverly Hills constantly — the estates in The Flats and the hills, the properties in Trousdale, Holmby Hills, and Benedict Canyon. Sub-Zero, Viking, Wolf, Thermador, and Miele are what we see most here. We carry OEM parts for these brands on every service vehicle and are trained on their specific systems.</div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">Do you offer same-day appliance repair in Beverly Hills?</summary>
          <div class="faq-answer">Yes. Call before noon and our technicians can typically be at your Beverly Hills home the same afternoon. We serve all Beverly Hills ZIP codes — 90210, 90211, and 90212 — as well as Bel Air, Holmby Hills, Trousdale Estates, and Century City.</div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">Is it worth repairing a high-end Sub-Zero or Wolf appliance?</summary>
          <div class="faq-answer">In most cases, yes — and more so than for standard appliances. Sub-Zero refrigerators and Wolf ranges are built to last 20+ years with proper maintenance. The 50% rule rarely applies to luxury built-ins, where replacement means a full renovation project. Our technicians give you an honest recommendation based on the appliance's age, condition, and what the actual repair entails.</div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">What is your diagnostic fee in Beverly Hills?</summary>
          <div class="faq-answer">Our diagnostic fee is $89, waived when you proceed with the repair. For luxury brands, repair costs may run higher due to OEM part pricing — but we give you a full written estimate before starting any work. No surprises.</div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">Do you provide discreet service for private estates in Beverly Hills?</summary>
          <div class="faq-answer">Yes. Our technicians work in Beverly Hills estates regularly and are experienced with gated properties, estate managers, and household staff. We coordinate access and scheduling professionally, work quietly and cleanly, and respect the privacy of the household.</div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">What warranty do you offer on appliance repairs in Beverly Hills?</summary>
          <div class="faq-answer">All repairs come with a 90-day warranty on parts and labor. We use genuine OEM parts — never aftermarket substitutes. If the same issue returns within 90 days, we come back at no charge.</div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">Do you also serve Bel Air, Holmby Hills, and Century City?</summary>
          <div class="faq-answer">Yes. Our Beverly Hills service area extends to Bel Air, Holmby Hills, Trousdale Estates, Benedict Canyon, Coldwater Canyon, Century City, Westwood, and Beverly Grove. If you're in the 90210, 90077, or adjacent ZIP codes, we're your closest team.</div>
        </details>

      </div>
    </div>
  </section>

  <!-- NEARBY -->
  <section class="bh-nearby">
    <div class="container">
      <h2>Also Serving Nearby Areas</h2>
      <div class="nearby-grid">
        <a href="/west-hollywood/" class="nearby-link">West Hollywood</a>
        <a href="/brentwood/" class="nearby-link">Brentwood</a>
        <a href="/santa-monica/" class="nearby-link">Santa Monica</a>
        <a href="/los-angeles/" class="nearby-link">Los Angeles</a>
        <a href="/culver-city/" class="nearby-link">Culver City</a>
