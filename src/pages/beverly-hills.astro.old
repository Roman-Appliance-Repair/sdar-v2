        <a href="/hollywood/" class="nearby-link">Hollywood</a>
        <a href="/los-feliz/" class="nearby-link">Los Feliz</a>
      </div>
    </div>
  </section>

  <!-- BOTTOM CTA -->
  <section class="bh-bottom-cta">
    <div class="container">
      <div class="bottom-cta__inner">
        <div class="bottom-cta__text">
          <h2>Need Appliance Repair in Beverly Hills?</h2>
          <p>Same-day service · OEM parts · 90-day warranty · Diagnostic $89 waived with repair. We pick up the phone.</p>
        </div>
        <div class="bottom-cta__actions">
          <a href={`tel:${city.phoneRaw}`} class="btn-primary btn-large">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.29h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            {city.phone}
          </a>
          <a href="/book/" class="btn-secondary btn-large">Book Online</a>
        </div>
        <div class="bottom-cta__nap">
          <span>Same Day Appliance Repair — Beverly Hills</span>
          <span>·</span>
          <span>Serving 90210 · 90211 · 90212 · Bel Air · Holmby Hills</span>
          <span>·</span>
          <a href={`mailto:${city.email}`}>{city.email}</a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  :root {
    --bh-red: #C8102E;
    --bh-black: #0a0a0a;
    --bh-gray: #f5f5f5;
    --bh-border: #e2e2e2;
    --bh-text: #1a1a1a;
    --bh-muted: #6b6b6b;
    --bh-gold: #b8972a;
  }

  .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }

  /* HERO */
  .bh-hero { background: var(--bh-black); color: white; padding: 80px 0 60px; }
  .bh-hero__inner { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
  .bh-hero__eyebrow { font-size: 13px; font-weight: 500; color: var(--bh-red); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 16px; }
  .bh-hero__h1 { font-size: clamp(36px, 5vw, 52px); font-weight: 700; line-height: 1.1; margin-bottom: 20px; color: white; }
  .bh-hero__accent { color: var(--bh-red); }
  .bh-hero__sub { font-size: 17px; line-height: 1.6; color: rgba(255,255,255,0.75); margin-bottom: 32px; max-width: 520px; }
  .bh-hero__ctas { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 24px; }
  .bh-hero__rating { display: flex; align-items: center; gap: 10px; }
  .stars { color: #FFD700; font-size: 18px; letter-spacing: 2px; }
  .rating-text { font-size: 14px; color: rgba(255,255,255,0.7); }
  .bh-hero__img-wrap img { width: 100%; height: auto; border-radius: 12px; object-fit: cover; }

  /* BUTTONS */
  .btn-primary { display: inline-flex; align-items: center; gap: 8px; background: var(--bh-red); color: white; padding: 14px 28px; border-radius: 8px; font-weight: 600; font-size: 16px; text-decoration: none; transition: background 0.2s; }
  .btn-primary:hover { background: #a50e25; }
  .btn-secondary { display: inline-flex; align-items: center; gap: 8px; background: transparent; color: white; padding: 14px 28px; border-radius: 8px; font-weight: 600; font-size: 16px; text-decoration: none; border: 1.5px solid rgba(255,255,255,0.35); transition: border-color 0.2s; }
  .btn-secondary:hover { border-color: white; }
  .btn-large { padding: 16px 36px; font-size: 17px; }
  .bh-bottom-cta .btn-secondary { color: var(--bh-text); border-color: var(--bh-border); }
  .bh-bottom-cta .btn-secondary:hover { background: var(--bh-gray); }

  /* TRUST BAR */
  .trust-bar { background: var(--bh-red); padding: 16px 0; }
  .trust-bar__inner { display: flex; justify-content: space-between; flex-wrap: wrap; gap: 12px; }
  .trust-item { display: flex; align-items: center; gap: 8px; color: white; font-size: 14px; font-weight: 500; }

  /* INTRO */
  .bh-intro { padding: 72px 0; background: white; }
  .bh-intro__inner { display: grid; grid-template-columns: 1fr 340px; gap: 60px; align-items: start; }
  .bh-intro__text h2 { font-size: 28px; font-weight: 700; color: var(--bh-black); margin-bottom: 20px; }
  .bh-intro__text p { font-size: 16px; line-height: 1.7; color: var(--bh-text); margin-bottom: 16px; }
  .cta-box { background: var(--bh-black); color: white; border-radius: 12px; padding: 32px; text-align: center; position: sticky; top: 80px; }
  .cta-box__title { font-size: 18px; font-weight: 700; margin-bottom: 4px; }
  .cta-box__sub { font-size: 13px; color: rgba(255,255,255,0.6); margin-bottom: 24px; }
  .cta-box__phone { display: block; font-size: 24px; font-weight: 700; color: var(--bh-red); text-decoration: none; margin-bottom: 12px; }
  .cta-box__book { display: block; font-size: 15px; color: white; text-decoration: none; padding: 12px; border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; margin-bottom: 16px; }
  .cta-box__book:hover { background: rgba(255,255,255,0.08); }
  .cta-box__hours { font-size: 12px; color: rgba(255,255,255,0.5); }

  /* LUXURY */
  .bh-luxury { padding: 72px 0; background: var(--bh-black); color: white; }
  .luxury-inner { display: grid; grid-template-columns: 1fr 280px; gap: 60px; align-items: start; }
  .luxury-eyebrow { font-size: 13px; font-weight: 500; color: var(--bh-red); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 12px; }
  .luxury-text h2 { font-size: 28px; font-weight: 700; color: white; margin-bottom: 20px; }
  .luxury-text p { font-size: 15px; line-height: 1.7; color: rgba(255,255,255,0.75); margin-bottom: 16px; }
  .luxury-brands-grid { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 20px; }
  .luxury-brand { padding: 6px 14px; border: 1px solid rgba(255,255,255,0.2); border-radius: 20px; font-size: 13px; color: rgba(255,255,255,0.8); }
  .luxury-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .stat-card { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; padding: 24px; text-align: center; }
  .stat-num { font-size: 32px; font-weight: 700; color: var(--bh-red); margin-bottom: 4px; }
  .stat-label { font-size: 13px; color: rgba(255,255,255,0.6); }

  /* SECTION */
  .section-title { font-size: 30px; font-weight: 700; color: var(--bh-black); margin-bottom: 8px; text-align: center; }
  .section-sub { font-size: 16px; color: var(--bh-muted); text-align: center; margin-bottom: 40px; }

  /* SERVICES */
  .bh-services { padding: 72px 0; background: var(--bh-gray); }
  .services-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
  .service-card { background: white; border: 1px solid var(--bh-border); border-radius: 12px; padding: 24px 20px; text-decoration: none; color: var(--bh-text); transition: box-shadow 0.2s, transform 0.2s; display: block; }
  .service-card:hover { box-shadow: 0 4px 24px rgba(0,0,0,0.1); transform: translateY(-2px); }
  .service-card__icon { font-size: 28px; margin-bottom: 10px; }
  .service-card__name { font-size: 16px; font-weight: 600; color: var(--bh-black); margin-bottom: 8px; }
  .service-card__issues { font-size: 13px; color: var(--bh-muted); line-height: 1.5; margin-bottom: 8px; }
  .service-card__brands { font-size: 12px; color: var(--bh-muted); margin-bottom: 12px; }
  .service-card__cta { font-size: 13px; color: var(--bh-red); font-weight: 500; }

  /* NEIGHBORHOODS */
  .bh-neighborhoods { padding: 72px 0; background: white; }
  .bh-neighborhoods h2 { font-size: 30px; font-weight: 700; color: var(--bh-black); margin-bottom: 8px; text-align: center; }
  .nh-columns { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; }
  .nh-col__title { font-size: 13px; font-weight: 600; color: var(--bh-muted); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 16px; }
  .nh-list { display: flex; flex-direction: column; gap: 8px; }
  .nh-item { font-size: 14px; color: var(--bh-text); padding: 8px 12px; background: var(--bh-gray); border-radius: 6px; }
  .nh-item.featured { background: #fff5f7; border: 1px solid var(--bh-red); color: var(--bh-black); font-weight: 500; }

  /* REPAIR OR REPLACE */
  .bh-ror { padding: 72px 0; background: var(--bh-gray); }
  .ror-inner { display: grid; grid-template-columns: 1fr 300px; gap: 60px; align-items: start; }
  .ror-eyebrow { font-size: 13px; font-weight: 500; color: var(--bh-red); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 12px; }
  .ror-text h2 { font-size: 28px; font-weight: 700; color: var(--bh-black); margin-bottom: 20px; }
  .ror-text p { font-size: 15px; line-height: 1.7; color: var(--bh-text); margin-bottom: 16px; }
  .lifespan-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin: 20px 0 12px; }
  .lifespan-item { background: white; border-radius: 8px; padding: 14px; display: flex; flex-direction: column; gap: 4px; border: 1px solid var(--bh-border); }
  .ls-appliance { font-size: 13px; color: var(--bh-muted); }
  .ls-years { font-size: 15px; font-weight: 600; color: var(--bh-black); }
  .ror-cta { background: var(--bh-black); color: white; border-radius: 12px; padding: 32px; text-align: center; position: sticky; top: 80px; }
  .ror-cta__title { font-size: 17px; font-weight: 700; color: white; margin-bottom: 8px; }
  .ror-cta__sub { font-size: 13px; color: rgba(255,255,255,0.6); margin-bottom: 24px; }
  .ror-cta .btn-primary { width: 100%; justify-content: center; margin-bottom: 12px; }
  .ror-cta__note { font-size: 12px; color: rgba(255,255,255,0.4); }

  /* RECENT */
  .bh-recent { padding: 72px 0; background: white; }
  .bh-recent h2 { font-size: 30px; font-weight: 700; color: var(--bh-black); margin-bottom: 8px; text-align: center; }
  .recent-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .recent-card { background: var(--bh-gray); border: 1px solid var(--bh-border); border-radius: 12px; padding: 24px; }
  .recent-card__header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; flex-wrap: wrap; gap: 6px; }
  .recent-badge { background: var(--bh-red); color: white; font-size: 11px; font-weight: 600; padding: 3px 10px; border-radius: 20px; }
  .recent-location { font-size: 12px; color: var(--bh-muted); }
  .recent-card__title { font-size: 15px; font-weight: 600; color: var(--bh-black); margin-bottom: 10px; font-style: italic; }
  .recent-card__desc { font-size: 14px; color: var(--bh-text); line-height: 1.6; margin-bottom: 12px; }
  .recent-card__result { font-size: 13px; color: #2a7a2a; font-weight: 500; }

  /* WHY */
  .bh-why { padding: 72px 0; background: var(--bh-gray); }
  .bh-why h2 { font-size: 30px; font-weight: 700; color: var(--bh-black); margin-bottom: 40px; text-align: center; }
  .why-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
  .why-card { background: white; border-radius: 12px; padding: 28px 24px; border: 1px solid var(--bh-border); }
  .why-icon { font-size: 28px; margin-bottom: 14px; }
  .why-title { font-size: 16px; font-weight: 600; color: var(--bh-black); margin-bottom: 10px; }
  .why-text { font-size: 14px; color: var(--bh-muted); line-height: 1.6; }

  /* REVIEWS */
  .bh-reviews { padding: 72px 0; background: white; }
  .bh-reviews h2 { font-size: 30px; font-weight: 700; color: var(--bh-black); margin-bottom: 40px; text-align: center; }
  .reviews-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .review-card { background: var(--bh-gray); border: 1px solid var(--bh-border); border-radius: 12px; padding: 28px; }
  .review-stars { color: #FFD700; font-size: 18px; margin-bottom: 12px; }
  .review-text { font-size: 14px; color: var(--bh-text); line-height: 1.7; margin-bottom: 16px; font-style: italic; }
  .review-author { font-size: 13px; color: var(--bh-muted); font-weight: 500; }

  /* PRICING */
