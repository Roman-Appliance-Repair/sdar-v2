      <div class="hero-stat"><div class="hero-stat-num">8</div><div class="hero-stat-label">Cities in Riverside County</div></div>
      <div class="hero-stat"><div class="hero-stat-num">$89</div><div class="hero-stat-label">Diagnostic · Waived With Repair</div></div>
