---
/**
 * Hollywood, CA — v2 migrated page (T12 batch).
 * Branch: West Hollywood — physical_pin (only WeHo gets streetAddress in schema).
 * Content source of truth: legacy hollywood.astro.legacy + content-dump.
 *
 * Verbatim contract: every paragraph, FAQ, recent job, review, neighborhood
 * from legacy hollywood is preserved. Hollywood maps to WeHo branch
 * (cities.ts.primaryBranch = 'west-hollywood'), so schema includes
 * streetAddress + geo per physical_pin rules.
 *
 * Pricing-discipline: $120 commercial line in Q4 FAQ replaced with neutral
 * pricing language (only the $120 sentence). Custom narrative paragraph
 * referencing $120 commercial diagnostic also dropped only that clause.
 */

import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import CustomNarrative from '../components/cities/v2/CustomNarrative.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

import { mergeCredentials } from '../data/credentials-schema';
const citySlug = 'hollywood';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = 'Hollywood';
const zips = ['90028', '90038', '90068'];

const title = 'Appliance Repair Hollywood, CA';
const description = `Same-day appliance repair Hollywood CA. Beachwood Canyon, Fountain Ave, Los Feliz border. Sub-Zero, Viking, LG, Wolf. BHGS #A49573. $89 dx.`;
const canonical = 'https://samedayappliance.repair/hollywood/';

const phoneRaw = `+1${branch.phone.replace(/\D/g, '')}`;

// LocalBusiness schema — physical_pin (WeHo branch) so streetAddress + geo included.
const localBusinessSchema = mergeCredentials({
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  
  geo: {
    '@type': 'GeoCoordinates',
    latitude: branch.geo.cityCenterLat,
    longitude: branch.geo.cityCenterLng
  },
  areaServed: [
    { '@type': 'City', name: 'Hollywood', sameAs: 'https://en.wikipedia.org/wiki/Hollywood,_Los_Angeles' },
    { '@type': 'Place', name: 'Beachwood Canyon' },
    { '@type': 'Place', name: 'Los Feliz' },
    { '@type': 'Place', name: 'Fountain Avenue' }
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$',
  license: 'BHGS #A49573'

});

// =====================================================================
// INTRO — H2 "Hollywood is a Different Kind of Service Area"
// 3 paragraphs verbatim from legacy hollywood.astro.
// =====================================================================
const introParagraphs = [
  "Hollywood is one of the more layered cities we work in — and we mean that literally. You've got the vintage fourplexes off Fountain Avenue where the washer closets are barely wide enough to open the door, Beachwood Canyon homes with Viking ranges and Sub-Zero refrigerators built into custom cabinetry, apartment stacks along Cahuenga where three units share a laundry room, and restaurants on Hollywood Boulevard running commercial refrigeration around the clock.",
  `When you call same day appliance repair Hollywood and reach us, you're not going through a dispatch center in Chatsworth. Our West Hollywood office is 10 minutes away. Our technicians run this corridor — Hollywood, East Hollywood, Los Feliz, Silver Lake — every day. They know the buildings, the access issues, the brands people actually have here.`,
  `Hollywood's dry, dusty climate — especially up in the hills — is harder on appliances than people expect. Condenser coils clog faster. Dryer vents in older buildings get blocked without anyone noticing until there's a problem. We flag those things. Our $89 diagnostic fee tells you exactly what's wrong and what it costs to fix it. That fee goes away the moment you say yes to the repair.`
];

// =====================================================================
// SERVICES — 8 cards (3-tier with issues + brands), legacy verbatim.
// =====================================================================
const services = [
  { icon: '🧊', name: 'Refrigerator Repair', slug: 'refrigerator', issues: 'Not cooling, ice maker issues, water dispenser, compressor', brands: 'Sub-Zero · Samsung · LG · GE' },
  { icon: '🌀', name: 'Washer Repair', slug: 'washer', issues: 'Not spinning, not draining, error codes. Stackable units in vintage Hollywood apartments', brands: 'Samsung · LG · Bosch · Whirlpool' },
  { icon: '💨', name: 'Dryer Repair', slug: 'dryer', issues: 'Not heating, taking too long, dryer vent cleaning. Important in older Hollywood buildings', brands: 'LG · Samsung · GE · Maytag' },
  { icon: '🔥', name: 'Oven, Stove & Range Repair', slug: 'oven', issues: 'Burner issues, igniter, control board, Viking and Wolf range specialists', brands: 'Viking · Wolf · Thermador · GE' },
  { icon: '🍽️', name: 'Dishwasher Repair', slug: 'dishwasher', issues: 'Not cleaning, not draining, leaking. Bosch, Miele, KitchenAid', brands: 'Bosch · Miele · KitchenAid · Samsung' },
  { icon: '🏢', name: 'Commercial Equipment', slug: 'commercial-refrigerator', issues: 'Restaurant refrigeration, commercial ovens, walk-in coolers. East Hollywood, Hollywood Blvd', brands: 'True · Scotsman · Hoshizaki · Sub-Zero' },
  { icon: '❄️', name: 'Freezer Repair', slug: 'freezer', issues: 'Not freezing, icing over, fan motor, defrost issues', brands: 'Sub-Zero · Samsung · LG · GE' },
  { icon: '⚡', name: 'Cooktop Repair', slug: 'cooktop', issues: 'Gas, electric, induction. Wolf, Thermador, GE Profile', brands: 'Wolf · Thermador · GE · Bosch' }
];

// =====================================================================
// CUSTOM_NARRATIVE — "Hollywood's Housing Stock Requires a Different Approach"
// 3 paragraphs verbatim. Last paragraph: pricing-discipline edit drops only
// the "$120 commercial diagnostic waived with repair" sentence.
// =====================================================================
const housingNarrative = {
  headline: "Hollywood's Housing Stock Requires a Different Approach",
  paragraphs: [
    "A significant part of Hollywood's housing is pre-war — buildings from the 1920s and 30s that were designed for iceboxes, not 36-inch Sub-Zero refrigerators. Getting large appliances in and out of Beachwood Canyon homes, Whitley Heights craftsmans, or narrow Franklin Village apartments requires planning. Our technicians know this before they show up.",
    "On the other end, the newer developments along Vine Street and around the 101 corridor have modern kitchens with full suites of high-end appliances — Thermador, Miele, Wolf — that require factory-level knowledge to diagnose properly. We carry OEM parts for these brands on the truck.",
    "And then there's the commercial side. Hollywood Boulevard and Sunset Avenue have a dense restaurant corridor. East Hollywood has dozens of small cafés and restaurants that depend on commercial refrigeration. We handle that too — same-day response. Call us for commercial pricing."
  ]
};

// =====================================================================
// NEIGHBORHOODS — 8 entries verbatim from legacy.
// =====================================================================
const neighborhoods = [
  { name: 'Beachwood Canyon', zip: '90068' },
  { name: 'Whitley Heights', zip: '90028' },
  { name: 'Franklin Village', zip: '90028' },
  { name: 'East Hollywood', zip: '90029' },
  { name: 'Little Armenia & Thai Town', zip: '90027' },
  { name: 'Los Feliz Border', zip: '90027' },
  { name: 'Cahuenga Corridor', zip: '90038' },
  { name: 'Hollywood Hills West', zip: '90046' }
];

// =====================================================================
// RECENT_JOBS — 4 jobs verbatim from legacy.
// =====================================================================
const recentJobs = [
  {
    appliance: 'Viking Refrigerator',
    location: 'Beachwood Canyon, 90068',
    quote: 'Fridge running but nothing is cold',
    description: "Viking built-in refrigerator in a canyon home — evaporator fan had seized. The fridge was running but air wasn't circulating. Replaced fan motor with OEM Viking part, confirmed temperatures before leaving. Customer had a dinner party that evening.",
    outcome: '✓ Same day · OEM Viking fan motor'
  },
  {
    appliance: 'Whirlpool Dryer',
    location: 'Fountain Ave, 90028',
    quote: "Dryer takes three cycles, smells like it's burning",
    description: "Classic blocked vent situation in a 1940s fourplex — the vent run was over 20 feet with two 90-degree bends. Completely packed with lint. Cleared the vent, replaced the heating element that had partially failed from the heat buildup. A thermal fuse blows for a reason — we find what caused it.",
    outcome: '✓ Same day · Vent cleared + heating element'
  },
  {
    appliance: 'Commercial Walk-In',
    location: 'East Hollywood, 90029',
    quote: 'Commercial walk-in not holding temp overnight',
    description: 'Restaurant on Sunset — walk-in cooler losing 8 degrees overnight. Evaporator coils had iced over from a faulty defrost timer. Replaced timer, defrosted coils, confirmed it was holding temperature at 37°F before we left. Called at 7am, done by noon.',
    outcome: '✓ Same day · Defrost timer · Coils defrosted'
  },
  {
    appliance: 'Wolf Range',
    location: 'Hollywood Hills West, 90046',
    quote: "Wolf range — two burners won't ignite",
    description: "Grease had gotten into the igniter ports during a cleaning. Removed and cleaned both igniters, replaced one that had cracked. Burners lit clean on the first try. Owner mentioned the cleaning service hadn't mentioned anything — we showed them what to watch for.",
    outcome: '✓ Same day · OEM Wolf igniter · Both burners restored'
  }
];

// =====================================================================
// WHY_US — 4 reasons verbatim from legacy (5 in legacy; consolidating
// to 4 to fit v2 grid — keep the most distinctive ones verbatim).
// =====================================================================
const whyReasons = [
  {
    iconKey: 'team' as const,
    title: 'We pick up the phone',
    body: `Not a call center. When you call ${branch.phone}, someone who knows the schedule picks up and tells you honestly when we can be there.`
  },
  {
    iconKey: 'shield' as const,
    title: 'Upfront pricing before we start',
    body: 'What we quote is what appears on the invoice. No add-ons discovered mid-repair.'
  },
  {
    iconKey: 'clock' as const,
    title: "We're already nearby",
    body: "Our West Hollywood base is 10 minutes from most of Hollywood. We're not driving from the Valley. 85% first-visit fix rate."
  },
  {
    iconKey: 'parts' as const,
    title: 'OEM parts only',
    body: "We don't substitute aftermarket parts when OEM is available. Especially important for Sub-Zero, Wolf, and Miele."
  }
];

// =====================================================================
// REVIEWS — 3 testimonials verbatim from legacy.
// =====================================================================
const testimonials = [
  {
    stars: 5,
    text: '"Called at 9am about my Sub-Zero, tech was here by 1pm. Fixed the ice maker and found a secondary issue I didn\'t even know about. Professional from start to finish."',
    author: '— M. Rosenberg, Beachwood Canyon'
  },
  {
    stars: 5,
    text: '"My dryer had been taking forever to dry things for months. Turns out the vent was completely blocked. They fixed it same day and explained exactly what happened."',
    author: '— T. Nguyen, East Hollywood'
  },
  {
    stars: 5,
    text: '"Restaurant called on a Friday morning when the walk-in went down. They were there by 10, fixed by noon. Saved our weekend service."',
    author: '— R. Castellano, Hollywood Blvd'
  }
];

// =====================================================================
// PRICING — 6 cards (residential 2-tier per legacy). Diagnostic added as
// the featured card per v2 pattern.
// =====================================================================
const pricingTiers = [
  { appliance: 'Refrigerator', range: '$200 – $450', note: 'Standard brands · Luxury Sub-Zero $300–$700+' },
  { appliance: 'Washer', range: '$150 – $350', note: 'Standard · Miele $200–$450' },
  { appliance: 'Dryer', range: '$150 – $320', note: 'Standard · Luxury $200–$400' },
  { appliance: 'Oven / Range', range: '$175 – $420', note: 'Standard · Wolf, Viking $250–$500+' },
  { appliance: 'Dishwasher', range: '$150 – $320', note: 'Standard · Miele $200–$450' },
  { appliance: 'Diagnostic Fee', range: '$89', note: 'Waived when you proceed with the repair', featured: true }
];

// =====================================================================
// FAQ — 7 items verbatim from legacy. Q4 commercial answer: only the
// "$120" sentence is replaced with neutral language; rest verbatim.
// =====================================================================
const faqs = [
  {
    question: 'Do you offer same-day appliance repair in Hollywood, CA?',
    answer: `Yes — we offer same-day service throughout Hollywood including ZIP codes 90028, 90038, and 90068. Call ${branch.phone} before noon and we can typically have a technician there the same day.`
  },
  {
    question: 'What is your diagnostic fee for Hollywood appliance repair?',
    answer: 'Our diagnostic fee is $89 for residential appliances — and it disappears the moment you approve the repair. What we quote upfront is what appears on the invoice.'
  },
  {
    question: 'Do you repair Sub-Zero, Viking, and Wolf appliances in Hollywood?',
    answer: 'Yes. We work on Sub-Zero, Viking, Wolf, Thermador, Miele, Dacor, and all major luxury brands. Hollywood has a lot of high-end appliances — our technicians come prepared for them.'
  },
  {
    question: 'Can you repair restaurant and commercial equipment in Hollywood?',
    answer: 'Yes. We handle commercial refrigeration, walk-in coolers, commercial ovens, and restaurant equipment throughout Hollywood and East Hollywood. Call us for commercial pricing.'
  },
  {
    question: 'What warranty do you offer on repairs?',
    answer: '90 days on parts and labor, every job. We use OEM parts where available.'
  },
  {
    question: 'Which neighborhoods in Hollywood do you serve?',
    answer: 'We serve all of Hollywood — Beachwood Canyon, Los Feliz border, Fountain Ave, East Hollywood, Franklin Village, Whitley Heights, Little Armenia, Thai Town, and along Hollywood Blvd and Sunset Blvd.'
  },
  {
    question: 'How much does refrigerator repair cost in Hollywood?',
    answer: 'Most refrigerator repairs in Hollywood run $200–$450 for standard brands. Sub-Zero and high-end units typically range $300–$700+. We give upfront pricing before starting any work.'
  }
];

// =====================================================================
// NEARBY_LINKS — 8 OC + LA neighbors. Legacy listed "East Hollywood"
// pointing to /areas/east-hollywood/ which doesn't exist as a city page;
// dropped from this list — already covered as a neighborhood above.
// =====================================================================
const nearbyCities = [
  { name: 'West Hollywood', slug: 'west-hollywood' },
  { name: 'Los Feliz', slug: 'los-feliz' },
  { name: 'Silver Lake', slug: 'silver-lake' },
  { name: 'Glendale', slug: 'glendale' },
  { name: 'Burbank', slug: 'burbank' },
  { name: 'Koreatown', slug: 'koreatown' },
  { name: 'North Hollywood', slug: 'north-hollywood' }
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair"
    headlineCity="Hollywood, CA"
    subheadline="Same-day service on every major appliance. Sub-Zero, Viking, Wolf, Bosch, Samsung, LG — we cover all of Hollywood from Beachwood Canyon to East Hollywood. Licensed, OEM parts, 90-day warranty."
    zips={zips}
    tier={2}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Hollywood is a Different Kind of Service Area"
    paragraphs={introParagraphs}
    bookingTitle="Hollywood Service"
    bookingSub="Available Today"
  />

  <ServicesGrid
    cityName={cityName}
    headline="Appliance Repair Services in Hollywood"
    services={services}
  />

  <CustomNarrative
    headline={housingNarrative.headline}
    paragraphs={housingNarrative.paragraphs}
    background="white"
  />

  <ServiceArea
    cityName={cityName}
    headline="Hollywood Neighborhoods We Serve"
    subheadline="We cover all of Hollywood — residential and commercial."
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={[]}
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Repairs in Hollywood"
    jobs={recentJobs}
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="Why Hollywood Residents Call Us"
    reasons={whyReasons}
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What Hollywood Customers Say"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Appliance Repair Pricing in Hollywood"
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="Frequently Asked Questions — Hollywood"
    faqs={faqs}
  />

  <section class="section">
    <div class="container narrow" style="max-width:820px;margin:0 auto;padding:48px 24px;">
      <p style="font-size:0.75rem; font-weight:700; letter-spacing:0.14em; text-transform:uppercase; color:#C8102E; margin-bottom:10px;">Service-specific pages for Hollywood</p>
      <h2 style="font-size:1.6rem; font-weight:800; margin:0 0 18px;">Hollywood appliance repair by service.</h2>
      <p>Each service-specific page covers brand pool, failure patterns, and pricing relevant to Hollywood home stock and local conditions. Hollywood Hills above-Sunset estates run premium tier (Sub-Zero, Wolf, Miele, Thermador, La Cornue); Hollywood proper runs entertainment-industry mid-premium mix.</p>
      <ul style="padding-left:22px; margin:14px 0 18px;">
        <li><a href="/hollywood/refrigerator-repair/">Refrigerator repair in Hollywood</a></li>
        <li><a href="/hollywood/dryer-repair/">Dryer repair in Hollywood</a></li>
        <li><a href="/hollywood/washer-repair/">Washer repair in Hollywood</a></li>
        <li><a href="/hollywood/dishwasher-repair/">Dishwasher repair in Hollywood</a></li>
        <li><a href="/hollywood/oven-repair/">Oven repair in Hollywood</a></li>
      </ul>
      <p style="font-size:0.92rem; color:#6b6b6b;">Note: Hollywood is distinct from <a href="/west-hollywood/">West Hollywood</a> (different city, different incorporation). Both are dispatched from our West Hollywood branch.</p>
    </div>
  </section>

  <AlsoServingNearby nearbyCities={nearbyCities} />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Need Appliance Repair in Hollywood Today?"
    body="Call now or book online. Same-day service available across Hollywood — Beachwood Canyon, East Hollywood, Hollywood Hills West, and the Boulevard."
  />
</CityLayoutV2>
