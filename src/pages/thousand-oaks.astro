    subheadline="Conejo Valley's mix of luxury estates and established suburban homes — Sub-Zero, Thermador, Miele alongside Samsung and LG. Local Thousand Oaks branch, same-day service, OEM parts, 90-day warranty. Gated communities welcome. Weekends available."
    zips={zips}
    tier={2}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance Repair in Thousand Oaks — The Conejo Valley Difference"
