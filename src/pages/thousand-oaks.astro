const testimonials = [
  {
    stars: 5,
    text: '"Sub-Zero in our Dos Vientos home was running constantly and our electric bill had spiked. Same Day coordinated gate access through our property manager, cleaned the dusty coils from our hillside landscaping, put us on an 8-month schedule. Back to normal immediately. They understood the hillside dust issue specifically — not just generic advice."',
    author: '— Patricia N. (via property manager), Dos Vientos'
  },
  {
    stars: 5,
    text: '"Thermador 48-inch range with two star burners clicking but not lighting. Same Day came out, replaced both igniter assemblies with OEM Thermador parts, tested everything, then calibrated the oven because I mentioned it was running cool. Done in under 90 minutes. This is what service for a premium appliance should look like."',
    author: '— Michael T., North Ranch, Thousand Oaks'
  },
  {
    stars: 5,
    text: '"Miele dishwasher F11 error in our Lynn Ranch home. Tech found the inlet filter clogged with sediment, replaced the valve with OEM Miele parts, ran the full diagnostic cycle. Explained the difference between hard water scale and sediment blockage — our water here is moderate hardness but the sediment was the culprit. Very thorough."',
    author: '— Karen L., Lynn Ranch, Thousand Oaks'
  },
