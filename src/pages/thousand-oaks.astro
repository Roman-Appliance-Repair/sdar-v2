const recentJobs = [
  {
    appliance: 'Sub-Zero Built-In Fridge',
    location: 'Dos Vientos, 91362',
    quote: '"Running longer and longer — electric bill noticeably higher"',
    description: "Dos Vientos estate — gate access coordinated through the property manager. Sub-Zero 48-inch built-in with condenser coils packed with fine dust and debris from hillside landscaping. The dry Conejo Valley air carries significant particulate in the summer months. Thorough coil cleaning, inspected the condenser fan, confirmed door seal integrity across both columns. Cycling immediately returned to normal intervals. Placed on an 8-month inspection schedule appropriate for a hillside property with active landscaping. Sub-Zero recommends annual — Dos Vientos hillside properties realistically need it twice.",
    outcome: '✓ Same day · Gate coordinated · Coils cleaned · 8-month plan · Normal cycling'
  },
  {
    appliance: 'Thermador Pro Range',
    location: 'North Ranch, 91361',
    quote: '"Two star burners not lighting — clicking but no flame"',
    description: "North Ranch home — Thermador 48-inch pro range with two ExtraLow star burners failing to light. Found both igniter electrodes weakened and one with a small crack from thermal cycling — common in high-use pro ranges in active cooking households. Replaced both igniter assemblies with OEM Thermador parts, tested all six burners and both oven cavities. Also calibrated the left oven after the owner mentioned it was running slightly cool. All temperatures confirmed accurate within 5 degrees.",
    outcome: '✓ Same day · OEM Thermador igniters · All burners · Ovens calibrated'
  },
  {
    appliance: 'Miele Dishwasher',
    location: 'Lynn Ranch, 91360',
    quote: '"F11 error — no water filling, machine completely stopped"',
    description: "Lynn Ranch home — Miele G 7000 F11 water intake fault. Found the water inlet valve assembly partially blocked — not hard water scale (Thousand Oaks water is moderate hardness) but fine sediment from the household supply. The sediment filter screen in the valve was clogged. Cleared the inlet filter, tested valve flow, replaced the valve given partial obstruction had been stressing the solenoid. Ran the Miele diagnostics cycle, confirmed full water intake on three cycles. Also performed a maintenance descale cycle given the age of the machine.",
    outcome: '✓ Same day · F11 resolved · OEM Miele valve · Diagnostic cycle clear'
  },
  {
    appliance: 'LG Washer',
    location: 'Central Thousand Oaks, 91360',
    quote: '"UE error every cycle — violent vibration even with small loads"',
    description: "LG front-loader in a Thousand Oaks single-family — UE unbalanced error on every cycle regardless of load size or distribution. Found two rear shock absorbers failed and two more weakened. Replaced all four with OEM LG parts, levelled the machine, tested three full spin cycles at maximum speed. Completely smooth. The family had assumed they were overloading — they weren't. The shocks had been degrading for months and triggering the balance sensor even with correctly distributed loads.",
    outcome: '✓ Same day · OEM LG shocks · All four replaced · Full spin confirmed'
  },
];

const whyReasons = [
