import { CITIES } from '../data/cities';
import { BRANCHES } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

const citySlug = 'thousand-oaks';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = "Thousand Oaks";
const zips = ["91360", "91361", "91362", "91320"];

const phone = branch.phone;
const phoneRaw = `+1${phone.replace(/\D/g, '')}`;

const title = `Appliance Repair Thousand Oaks CA — Same Day | Dos Vientos · Lynn Ranch · Newbury Park | ${phone}`;
const description = `Same-day appliance repair in Thousand Oaks, CA. Dos Vientos, Lynn Ranch, Newbury Park, Westlake Village area. Sub-Zero, Wolf, Thermador, Miele, Samsung, LG. Licensed, OEM parts, 90-day warranty. Call ${phone}.`;
const canonical = "https://samedayappliance.repair/thousand-oaks/";

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  name: branch.fullName,
  image: "https://samedayappliance.repair/images/logo.webp",
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { "@type": "City", name: "Thousand Oaks", sameAs: "https://en.wikipedia.org/wiki/Thousand_Oaks,_California" },
    { "@type": "Neighborhood", name: "Dos Vientos" },
    { "@type": "Neighborhood", name: "Newbury Park" },
    { "@type": "Neighborhood", name: "Lynn Ranch" },
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: "$$",
  license: "CA BHGS #A49573"

};

const introParagraphs = [
  "Thousand Oaks is one of the most consistently well-kept communities in Southern California — and the appliances inside these homes reflect that. The Dos Vientos and North Ranch estates have Sub-Zero built-ins, Thermador pro ranges, and Miele dishwashers as standard. The established neighborhoods throughout the rest of 91360 and 91361 have LG, Samsung, GE, and Whirlpool machines that need the same reliable same-day service.",
  "One environmental factor that matters here but rarely gets mentioned: the Conejo Valley's hot, dry summers push significant particulate through the air — particularly in hillside properties with mature landscaping. Refrigerator condenser coils accumulate dust and debris faster than in coastal or urban environments. We check condenser coils on every Thousand Oaks refrigerator call. A coil that's loaded with dusty buildup runs the compressor harder, drives up energy costs, and shortens the unit's life. It's a consistent finding here.",
  "We're familiar with the gate access protocols for Dos Vientos and other gated communities throughout Thousand Oaks. Estate managers, household staff, and property managers are all part of our normal workflow in this area.",
  "Diagnostic fee: <strong>$89</strong> — waived with repair. Written estimate before we start. <strong>90-day warranty</strong>. Weekends available.",
  "<strong>Conejo Valley climate tip:</strong> Thousand Oaks summers are hot and dry, and hillside properties see significant dust load through the condenser. If your refrigerator has been running longer cycles than usual — particularly after a dry, windy stretch or after landscaping work — dusty condenser coils are almost certainly the cause. Clean coils every 6–9 months in this environment, not the 12-month recommendation written for temperate climates.",
];

const communitiesNarrative = {
  eyebrow: "Conejo Valley Coverage",
  headline: "Thousand Oaks — Every Community",
  paragraphs: [
    "From Dos Vientos estates to Lynn Ranch to central TO — same same-day commitment.",
  ],
  subSections: [
    {
      title: "Dos Vientos",
      paragraphs: [
        "Gated · Sub-Zero / Thermador estates · Estate manager coordination · Gate access arranged.",
      ]
    },
    {
      title: "North Ranch",
      paragraphs: [
        "Luxury hillside · Wolf / Miele common · Large format kitchens · Outdoor kitchen service.",
      ]
    },
    {
      title: "Lynn Ranch",
