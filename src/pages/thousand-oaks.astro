        "91360 · All brands · Townhomes & single-family.",
      ]
    },
    {
      title: "Westlake Village adjacent",
      paragraphs: [
        "91361 · Premium homes · Sub-Zero and Wolf frequent.",
      ]
    },
    {
      title: "Oak Park / Agoura Hills",
      paragraphs: [
        "Adjacent coverage · All brands · Same-day route.",
      ]
    },
    {
      title: "Moorpark",
      paragraphs: [
        "93021 · Adjacent Ventura County · Same-day covered.",
      ]
    },
  ]
};

const services = [
  { icon: '🧊', name: 'Refrigerator Repair', slug: 'refrigerator', issues: 'Dusty coil inspection · Sub-Zero built-in · Not cooling · Ice maker', brands: 'Sub-Zero · Samsung · LG · GE · Thermador · Bosch' },
  { icon: '🔥', name: 'Oven, Range & Pro Range', slug: 'oven', issues: 'Thermador pro-style · Wolf dual-fuel · Gas igniter · Temperature off', brands: 'Wolf · Thermador · Gaggenau · Viking · GE · Samsung' },
  { icon: '🍽️', name: 'Dishwasher Repair', slug: 'dishwasher', issues: 'Miele · Bosch · Panel-ready · Not draining · Error codes', brands: 'Miele · Bosch · Thermador · KitchenAid · Samsung · GE' },
  { icon: '🫧', name: 'Washer Repair', slug: 'washer', issues: 'OE / UE error · Not draining · Not spinning · Error codes', brands: 'LG · Samsung · Whirlpool · Maytag · Bosch · Speed Queen' },
  { icon: '♨️', name: 'Dryer Repair + Vent Cleaning', slug: 'dryer', issues: 'Not heating · Thermal fuse · Vent buildup · Gas & electric', brands: 'LG · Samsung · GE · Maytag · Whirlpool · Miele' },
  { icon: '❄️', name: 'Freezer & Ice Maker Repair', slug: 'freezer', issues: 'Not freezing · Ice stopped · Frost buildup · Sub-Zero', brands: 'Sub-Zero · Samsung · LG · GE · True · Whirlpool' },
  { icon: '🍷', name: 'Wine Cellar & Cooler Repair', slug: 'wine-cooler', issues: 'Temperature off · WhisperKOOL · Sub-Zero wine · Compressor', brands: 'Sub-Zero · EuroCave · True · WhisperKOOL · Liebherr' },
  { icon: '🔆', name: 'Cooktop & Range Hood', slug: 'cooktop', issues: 'Thermador star burner · Wolf igniter · Induction · Hood motor', brands: 'Wolf · Thermador · Gaggenau · Miele · Viking · Dacor' },
