---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import CustomNarrative from '../components/cities/v2/CustomNarrative.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES, MAIN_PHONE, isPlaceholderPhone } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

const citySlug = 'ontario';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = 'Ontario';
const zips = ['91758', '91761', '91762', '91764'];

const phone = branch.phone;
const phoneRaw = `+1${phone.replace(/\D/g, '')}`;

const title = `Appliance Repair Ontario CA — Same Day | All Brands | ${phone}`;
const description = `Same-day appliance repair in Ontario CA. Refrigerator, washer, dryer, oven, dishwasher & more. Ontario Ranch, Downtown, South Ontario. Licensed. OEM parts.`;
const canonical = 'https://samedayappliance.repair/ontario/';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { '@type': 'City', name: 'Ontario', sameAs: 'https://en.wikipedia.org/wiki/Ontario,_California' }
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$',
  license: 'BHGS #A49573'

};

const introParagraphs = [
  "Ontario is one of the hardest-working cities in the Inland Empire — home to one of the busiest cargo airports on the West Coast, a massive logistics and warehouse corridor, and a dense, diverse residential population that spans everything from 1960s rental homes along Holt Blvd to brand-new master-planned development at Ontario Ranch. The appliance profile here reflects that diversity: older Whirlpool and GE in the established neighborhoods, Samsung and LG in mid-range homes from the 1990s and 2000s, and newer KitchenAid and Samsung in the Ontario Ranch builds.",
  "The rental market is a significant part of who calls us in Ontario. Apartments and rental homes along Holt Blvd, Euclid, and Fourth Street need appliance repairs resolved quickly — a tenant without a working washer or refrigerator isn't just an inconvenience, it's a habitability issue. We work directly with landlords and property managers and understand the urgency that comes with an active tenancy. We communicate with both parties and aim to close every rental call the same day we open it.",
  "The industrial environment around Ontario International Airport and the logistics corridor adds a climate factor most appliance companies don't mention: fine particulate from warehouse activity and airport ground operations settles on condenser coils faster in parts of Ontario than in purely residential cities. Homes near the airport corridor and south of the 60 freeway see measurably heavier coil loading. We account for this in every refrigerator call in that zone.",
  `Same-day coverage across all four Ontario ZIP codes — 91758, 91761, 91762, 91764. Call <a href="tel:${phoneRaw}">${phone}</a>.`
];

const services = [
  { icon: '❄️', name: 'Refrigerator Repair', slug: 'refrigerator' },
  { icon: '🌀', name: 'Washer Repair', slug: 'washer' },
  { icon: '💨', name: 'Dryer Repair', slug: 'dryer' },
  { icon: '🔥', name: 'Oven & Range Repair', slug: 'oven' },
  { icon: '🫧', name: 'Dishwasher Repair', slug: 'dishwasher' },
  { icon: '🍳', name: 'Stove & Cooktop Repair', slug: 'stove' },
  { icon: '🧊', name: 'Freezer Repair', slug: 'freezer' },
  { icon: '🧊', name: 'Ice Maker Repair', slug: 'ice-maker' }
];

const ontarioContextNarrative = {
  headline: "Ontario's Housing Stock — Four Distinct Markets",
  subSections: [
    {
      title: 'Downtown & Holt Blvd — 1960s–1980s Mix',
      paragraphs: [
        "The established neighborhoods near Downtown Ontario and along Holt Boulevard represent Ontario's oldest residential stock — single-family homes and apartment complexes built from the 1960s through the '80s. Appliances here range from 15 to 25 years old, and we see a high concentration of rental properties. Whirlpool, GE, and Maytag are the dominant brands. These machines are mechanically simpler than modern units and often worth repairing at advanced age — a Whirlpool Direct Drive washer with a worn coupling is a $120 fix, not a $700 replacement. We work with landlords in this part of Ontario regularly and understand the rental urgency dynamic."
      ]
    },
    {
      title: 'College Park, Creekside & North Ontario — 1990s–2000s Mid-Range',
      paragraphs: [
        "The planned neighborhoods north of the 10 freeway were developed primarily in the 1990s and 2000s. Samsung, LG, KitchenAid, and Whirlpool from this era are now 15–25 years into their lifespan. College Park and Creekside call us most often for LG linear inverter compressor relay failures (2014–2019 generation), Samsung ice maker issues, and front-load washer bearing wear. Hard water is consistent throughout Ontario — dishwasher filter cleaning and ice maker descaling are part of virtually every applicable service call in these neighborhoods."
      ]
    },
    {
      title: 'Ontario Ranch — New Development, 2015+',
      paragraphs: [
        "Ontario Ranch is one of the largest master-planned communities in Southern California, built out since 2015 with homes running 2,000–4,000 square feet. Builder-grade Samsung, KitchenAid, and LG appliances from the early Ontario Ranch builds are now 7–10 years old — entering the first failure window. Ice maker issues, evaporator fan failures, and dishwasher drain errors are the common calls. The airport corridor proximity adds industrial dust exposure to coil maintenance considerations — we recommend 5-month cleaning cycles for refrigerators in this zone."
      ]
    },
    {
      title: 'Commercial Ontario — Airport, Logistics, Restaurants',
      paragraphs: [
        "Ontario International Airport is one of the busiest cargo facilities in the US, and the logistics corridor around it supports dozens of warehouses, distribution centers, and commercial operations. We service break room refrigerators, commercial ice machines, undercounter coolers, and commercial laundry for businesses throughout this corridor. Restaurant and food-service equipment on Fourth Street and around Ontario Mills also falls in our service area. We aim for same-day commercial response — a failed walk-in cooler or break room fridge is a business disruption we take seriously."
      ]
    },
    {
      title: 'Hard Water Throughout Ontario',
      paragraphs: [
        "Ontario water runs hard — consistent with the broader SB County profile. Dishwasher filters clog at 3-month intervals. Ice maker fill tubes scale up. Front-load washer door gaskets accumulate mineral deposits that accelerate the mold and odor issues common in Samsung and LG front-loaders. We include descaling as standard on every applicable service call and leave customers with the right maintenance schedule for their specific water quality and usage."
      ]
    }
  ]
};

const neighborhoods = [
  { name: 'Ontario Ranch', zip: '91761' },
  { name: 'Downtown Ontario', zip: '91762' },
  { name: 'South Ontario', zip: '91761' },
  { name: 'North Ontario', zip: '91764' },
  { name: 'Holt Blvd Corridor', zip: '91762' },
  { name: 'Euclid Ave Area', zip: '91762' },
  { name: 'Haven Ave Corridor', zip: '91764' },
  { name: 'Fourth St District', zip: '91762' },
  { name: 'Ontario Mills Area', zip: '91764' },
  { name: 'College Park', zip: '91764' },
  { name: 'Creekside', zip: '91761' },
  { name: 'Airport Corridor', zip: '91761' }
];

const recentJobs = [
  {
    appliance: 'Samsung RF23M8090SG',
    location: 'Ontario Ranch, 91761',
    quote: 'not cooling, 22C error, Ontario Ranch 2019 build',
    description: "2019 Samsung French-door from an Ontario Ranch new construction, 22C error — ice room temperature sensor fault. This error in summer heat usually means the ice maker compartment is warming due to a sealing issue or a defrost system problem. Found a partially failed door-in-door gasket on the ice compartment — the foam seal had compressed unevenly, allowing warm air infiltration on the right side. Also found the condenser coils moderately loaded with the fine particulate common near Ontario's airport and industrial corridors. Replaced the door-in-door gasket with an OEM Samsung part, cleaned the coils. 22C cleared, unit holding temperature within 24 hours.",
    outcome: 'Ontario Ranch homes near the airport corridor get more industrial dust than typical residential areas. Coil cleaning every 5–6 months.'
  },
  {
    appliance: 'Whirlpool WTW5000DW',
    location: 'Holt Blvd rental property, 91762',
    quote: "won't agitate, spins fine, 2003 model",
    description: "Landlord called — tenant reporting washer not cleaning clothes. 21-year-old Whirlpool top-loader, agitator not moving, spin cycle fine. Classic transmission mode shift failure — the shift actuator had worn out. On a machine this age, the motor and transmission are sound, just the actuator tab needed replacement. Had the part on the truck. Repair took 50 minutes including diagnosis. Landlord had been quoted $400 for a new machine by another company. Actuator repair cost: $130 parts and labor. Tenant back up and running same afternoon.",
    outcome: 'Older Whirlpool Direct Drive machines are worth repairing. Mechanically simple, parts still available, motors last decades.'
  },
  {
    appliance: 'LG LRMVS3006S',
    location: 'South Ontario, 91761',
    quote: 'clicking, not cooling, 2016 model',
    description: "Another LG linear inverter start relay failure — this generation (2014–2019) is one of the most common calls we make in San Bernardino County. Clicking on compressor startup, unit not maintaining temperature. Tested the start relay: open circuit confirmed. Replaced it ($18 part), confirmed normal compressor operation, unit at 38°F within 40 minutes. Customer had been without a fridge for five days waiting for a compressor quote from another company. Start relay repair: $89 diagnostic + $85 labor and parts. Total savings versus incorrect compressor replacement: over $400.",
    outcome: 'LG 2014–2019: always check the start relay first. Same clicking symptom, $18 vs. $450 compressor.'
  },
  {
    appliance: 'KitchenAid KDTE334GPS dishwasher',
    location: 'College Park, 91764',
    quote: 'E1 F9 error, flooding sensor',
    description: "KitchenAid dishwasher triggering the flood sensor, shutting down mid-cycle. E1 F9 means the base pan flood sensor detected water. In College Park homes with hard water, we find two common causes: a drain pump partially blocked by mineral scale (water backs up and overflows into the base pan), or a failed door bottom gasket allowing slow leakage into the base. This unit had both — a partially blocked pump impeller and a worn door bottom gasket. Cleared the pump, replaced the gasket, reset the flood sensor. Unit running clean. Hard water maintenance briefing left with the customer.",
    outcome: 'E1 F9 in hard water areas almost always has a maintenance component. Address the root cause, not just the sensor.'
  }
];

const whyReasons = [
  {
    iconKey: 'team' as const,
    title: 'Rental property specialists',
    body: 'A broken appliance in an occupied rental is urgent. We coordinate directly with landlords and property managers, communicate clearly with tenants on scheduling, and close rental calls same-day whenever possible. No landlord should have to manage a habitability complaint for more than 24 hours.'
  },
  {
    iconKey: 'shield' as const,
    title: 'Residential and commercial',
    body: "Whether it's a fridge in an Ontario Ranch home or a walk-in cooler in a restaurant near Fourth Street, we handle both. We prioritize commercial calls to minimize downtime — a failed ice machine or cooler during business hours is a revenue issue."
  },
  {
    iconKey: 'parts' as const,
    title: 'Diagnosis before the quote',
    body: 'The $89 fee means we look at the actual appliance before recommending anything. An LG clicking sound is an $18 relay until proven otherwise — not a $450 compressor. What we quote is what appears on the invoice.'
  },
  {
    iconKey: 'clock' as const,
    title: 'OEM parts across all generations',
    body: "From a 1995 GE top-loader to a 2022 Samsung French-door, we source OEM parts through proper channels. In Ontario's hot, dusty, hard-water environment, the right part matters more than usual. We don't cut corners with aftermarket components."
  }
];

const testimonials = [
  {
    stars: 5,
    text: '"Landlord here — tenant called about a broken washer on a Monday morning. Same Day was there by afternoon, diagnosed a worn actuator, fixed it same visit. $130 instead of buying a new machine. They handled the whole coordination with my tenant. Very smooth."',
    author: '— Marcus J., Holt Blvd landlord'
  },
  {
    stars: 5,
    text: '"LG fridge in our Ontario Ranch home started clicking and stopped cooling. Another company quoted a compressor — $490. Same Day diagnosed a bad start relay, fixed it for under $100. Couldn\'t believe the difference. Should have called them first."',
    author: '— Sarah & Tom P., Ontario Ranch'
  },
  {
    stars: 5,
    text: '"KitchenAid dishwasher flooding error in our College Park home. Tech found it was hard water scale blocking the pump and a worn door gasket — two issues, one visit. Explained the maintenance schedule for our water. Very knowledgeable."',
    author: '— Linda R., College Park'
  }
];

const pricingTiers = [
  { appliance: 'Refrigerator Repair', range: '$150–$450', note: 'Compressor relay · Coil cleaning · Inlet valve · Fan motor' },
  { appliance: 'Washer Repair', range: '$120–$380', note: 'Drive coupling · Drain pump · Bearing · Actuator' },
  { appliance: 'Dryer Repair', range: '$120–$320', note: 'Thermal fuse · Heating element · Vent path' },
  { appliance: 'Dishwasher Repair', range: '$89–$360', note: 'Drain pump · Spray arm · Filter · E1 F9 errors' },
  { appliance: 'Oven / Range Repair', range: '$140–$400', note: 'Igniter · Bake element · Gas valve · Calibration' },
  { appliance: 'Diagnostic Fee', range: '$89', note: 'Applied to repair cost. No trip charge to Ontario ZIP codes.' }
];

const faqs = [
  {
    question: 'Do you offer same-day appliance repair in Ontario CA?',
    answer: `Yes — same-day service is available throughout Ontario including Ontario Ranch, Downtown, South Ontario, College Park, Creekside, and the Holt Blvd and Haven Ave corridors. Call ${phone} before noon for same-day availability. We cover all Ontario ZIP codes — 91758, 91761, 91762, and 91764 — without a trip surcharge.`
  },
  {
    question: 'Do you service rental properties and apartments in Ontario?',
    answer: "Yes, and it's a significant part of our Ontario call volume. Ontario has a large rental market — apartments along Holt Blvd, older rental homes near Downtown, and newer rental units in Ontario Ranch. We work directly with landlords and property managers. When a tenant reports a broken washer or a warm refrigerator, we understand the urgency — a tenant without working appliances is a habitability issue. We prioritize rental calls and communicate clearly with both landlord and tenant about scheduling and completion."
  },
  {
    question: 'What brands do you repair in Ontario?',
    answer: "All major brands. Ontario's housing stock runs a wide range: older GE and Whirlpool in the 1960s–1980s homes near Downtown and Holt Blvd, mid-range Samsung, LG, and Maytag in the 1990s–2000s stock, and newer KitchenAid and Samsung in Ontario Ranch. We carry OEM parts for all generations and don't use aftermarket substitutes."
  },
  {
    question: 'What is your diagnostic fee?',
    answer: '$89 for residential, applied directly to the repair cost when you proceed. No hidden trip charge to Ontario. We quote on-site after diagnosis — not over the phone based on symptoms.'
  },
  {
    question: 'Do you service commercial appliances for Ontario businesses?',
    answer: "Yes. Ontario's logistics corridor and commercial density around the airport and Ontario Mills mean we service break room refrigerators, commercial ice machines, restaurant ovens, and walk-in cooler units regularly. Call us for commercial pricing. We prioritize commercial calls to minimize business downtime."
  },
  {
    question: "My refrigerator runs warm every summer but works fine in winter — what's the cause?",
    answer: 'Ontario summers routinely hit 100–107°F in the Inland Valley, and appliances that managed fine in mild weather get pushed past their limit in heat. The first check is always condenser coils — in Ontario\'s dusty environment near the airport corridor and logistics warehouses, coils load up faster than average. A refrigerator with partially clogged coils that was borderline in spring will fail outright in July. We clean and test on every summer refrigerator call.'
  },
  {
    question: 'Is it worth repairing older appliances in Downtown Ontario or along Holt Blvd?',
    answer: "Usually yes, for mechanically sound machines. Older Whirlpool and GE appliances in Ontario's 1960s–1980s housing stock are often worth repairing — they're simpler machines with fewer electronics. A $120–$160 repair on a 20-year-old Whirlpool Direct Drive washer with a worn drive coupling often makes more sense than a $700 replacement, especially for rental properties where mid-range appliances are the right call. We give you the honest numbers after diagnosis."
  }
];

const nearbyCities = [
  { name: 'Rancho Cucamonga', slug: 'rancho-cucamonga' },
  { name: 'Upland', slug: 'upland' },
  { name: 'Chino Hills', slug: 'chino-hills' },
  { name: 'Fontana', slug: 'fontana' },
  { name: 'Corona', slug: 'corona' },
  { name: 'San Bernardino', slug: 'san-bernardino' }
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair"
    headlineCity="Ontario CA"
    subheadline="Same-day service in Ontario Ranch, Downtown, South Ontario, College Park, Creekside, and throughout the city. Residential and commercial. All brands, OEM parts."
    zips={zips}
    tier={3}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance Repair in Ontario CA — A City That Runs on Working Appliances"
    paragraphs={introParagraphs}
    bookingTitle="Ontario CA"
    bookingSub="Same-Day Service"
  />

  <ServicesGrid
    cityName={cityName}
    headline="What We Repair in Ontario CA"
    services={services}
  />

  <CustomNarrative
    headline={ontarioContextNarrative.headline}
    subSections={ontarioContextNarrative.subSections}
    background="white"
  />

  <ServiceArea
    cityName={cityName}
    headline="Neighborhoods We Service in Ontario CA"
    subheadline="We cover all of Ontario — from Ontario Ranch and Creekside in the south to College Park and North Ontario near the Upland border. No travel surcharge to any Ontario ZIP code."
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={[]}
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Repairs in Ontario CA"
    jobs={recentJobs}
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="Why Ontario Residents & Property Managers Call Us"
    reasons={whyReasons}
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What Ontario Customers Are Saying"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Typical Repair Pricing in Ontario CA"
    subhead="Every repair is quoted on-site after diagnosis. The $89 diagnostic is applied when you proceed."
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="Ontario CA Appliance Repair — FAQ"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby Cities"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Need Appliance Repair in Ontario CA Today?"
    body="Same-day residential and commercial service across Ontario Ranch, Downtown, College Park, South Ontario, and all Ontario ZIP codes."
  />
</CityLayoutV2>
