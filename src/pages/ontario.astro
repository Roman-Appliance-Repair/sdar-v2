---
// src/pages/ontario.astro
import BaseLayout from '../layouts/BaseLayout.astro';

const city = "Ontario";
const citySlug = "ontario";
const phone = "(626) 376-4458";
const phoneRaw = "6263764458";
const zipCodes = ["91758", "91761", "91762", "91764"];
const county = "San Bernardino";

const title = `Appliance Repair Ontario CA — Same Day | All Brands | ${phone}`;
const description = `Same-day appliance repair in Ontario CA. Refrigerator, washer, dryer, oven, dishwasher & more. Ontario Ranch, Downtown, South Ontario. Licensed. OEM parts. Call ${phone}.`;

const services = [
  { name: "Refrigerator Repair", slug: "refrigerator-repair", icon: "❄️" },
  { name: "Washer Repair", slug: "washer-repair", icon: "🌀" },
  { name: "Dryer Repair", slug: "dryer-repair", icon: "💨" },
  { name: "Oven & Range Repair", slug: "oven-repair", icon: "🔥" },
  { name: "Dishwasher Repair", slug: "dishwasher-repair", icon: "🫧" },
  { name: "Stove & Cooktop Repair", slug: "stove-repair", icon: "🍳" },
  { name: "Freezer Repair", slug: "freezer-repair", icon: "🧊" },
  { name: "Ice Maker Repair", slug: "ice-maker-repair", icon: "🧊" },
];

const neighborhoods = [
  { name: "Ontario Ranch", zip: "91761" },
  { name: "Downtown Ontario", zip: "91762" },
  { name: "South Ontario", zip: "91761" },
  { name: "North Ontario", zip: "91764" },
  { name: "Holt Blvd Corridor", zip: "91762" },
  { name: "Euclid Ave Area", zip: "91762" },
  { name: "Haven Ave Corridor", zip: "91764" },
  { name: "Fourth St District", zip: "91762" },
  { name: "Ontario Mills Area", zip: "91764" },
  { name: "College Park", zip: "91764" },
  { name: "Creekside", zip: "91761" },
  { name: "Airport Corridor", zip: "91761" },
];

const faqItems = [
  {
    q: "Do you offer same-day appliance repair in Ontario CA?",
    a: `Yes — same-day service is available throughout Ontario including Ontario Ranch, Downtown, South Ontario, College Park, Creekside, and the Holt Blvd and Haven Ave corridors. Call ${phone} before noon for same-day availability. We cover all Ontario ZIP codes — 91758, 91761, 91762, and 91764 — without a trip surcharge.`
  },
  {
    q: "Do you service rental properties and apartments in Ontario?",
    a: "Yes, and it's a significant part of our Ontario call volume. Ontario has a large rental market — apartments along Holt Blvd, older rental homes near Downtown, and newer rental units in Ontario Ranch. We work directly with landlords and property managers. When a tenant reports a broken washer or a warm refrigerator, we understand the urgency — a tenant without working appliances is a habitability issue. We prioritize rental calls and communicate clearly with both landlord and tenant about scheduling and completion."
  },
  {
    q: "What brands do you repair in Ontario?",
    a: "All major brands. Ontario's housing stock runs a wide range: older GE and Whirlpool in the 1960s–1980s homes near Downtown and Holt Blvd, mid-range Samsung, LG, and Maytag in the 1990s–2000s stock, and newer KitchenAid and Samsung in Ontario Ranch. We carry OEM parts for all generations and don't use aftermarket substitutes."
  },
  {
    q: "What is your diagnostic fee?",
    a: `$89 for residential, applied directly to the repair cost when you proceed. $120 for commercial. No hidden trip charge to Ontario. We quote on-site after diagnosis — not over the phone based on symptoms.`
  },
  {
    q: "Do you service commercial appliances for Ontario businesses?",
    a: "Yes. Ontario's logistics corridor and commercial density around the airport and Ontario Mills mean we service break room refrigerators, commercial ice machines, restaurant ovens, and walk-in cooler units regularly. Commercial diagnostic is $120, applied to the repair. We prioritize commercial calls to minimize business downtime."
  },
  {
    q: "My refrigerator runs warm every summer but works fine in winter — what's the cause?",
    a: "Ontario summers routinely hit 100–107°F in the Inland Valley, and appliances that managed fine in mild weather get pushed past their limit in heat. The first check is always condenser coils — in Ontario's dusty environment near the airport corridor and logistics warehouses, coils load up faster than average. A refrigerator with partially clogged coils that was borderline in spring will fail outright in July. We clean and test on every summer refrigerator call."
  },
  {
    q: "Is it worth repairing older appliances in Downtown Ontario or along Holt Blvd?",
    a: "Usually yes, for mechanically sound machines. Older Whirlpool and GE appliances in Ontario's 1960s–1980s housing stock are often worth repairing — they're simpler machines with fewer electronics. A $120–$160 repair on a 20-year-old Whirlpool Direct Drive washer with a worn drive coupling often makes more sense than a $700 replacement, especially for rental properties where mid-range appliances are the right call. We give you the honest numbers after diagnosis."
  },
];

const recentRepairs = [
  {
    title: "Samsung RF23M8090SG — not cooling, 22C error, Ontario Ranch 2019 build",
    neighborhood: "Ontario Ranch, 91761",
    description: "2019 Samsung French-door from an Ontario Ranch new construction, 22C error — ice room temperature sensor fault. This error in summer heat usually means the ice maker compartment is warming due to a sealing issue or a defrost system problem. Found a partially failed door-in-door gasket on the ice compartment — the foam seal had compressed unevenly, allowing warm air infiltration on the right side. Also found the condenser coils moderately loaded with the fine particulate common near Ontario's airport and industrial corridors. Replaced the door-in-door gasket with an OEM Samsung part, cleaned the coils. 22C cleared, unit holding temperature within 24 hours.",
    note: "Ontario Ranch homes near the airport corridor get more industrial dust than typical residential areas. Coil cleaning every 5–6 months."
  },
  {
    title: "Whirlpool WTW5000DW — won't agitate, spins fine, 2003 model",
    neighborhood: "Holt Blvd rental property, 91762",
    description: "Landlord called — tenant reporting washer not cleaning clothes. 21-year-old Whirlpool top-loader, agitator not moving, spin cycle fine. Classic transmission mode shift failure — the shift actuator had worn out. On a machine this age, the motor and transmission are sound, just the actuator tab needed replacement. Had the part on the truck. Repair took 50 minutes including diagnosis. Landlord had been quoted $400 for a new machine by another company. Actuator repair cost: $130 parts and labor. Tenant back up and running same afternoon.",
    note: "Older Whirlpool Direct Drive machines are worth repairing. Mechanically simple, parts still available, motors last decades."
  },
  {
    title: "LG LRMVS3006S — clicking, not cooling, 2016 model",
    neighborhood: "South Ontario, 91761",
    description: "Another LG linear inverter start relay failure — this generation (2014–2019) is one of the most common calls we make in San Bernardino County. Clicking on compressor startup, unit not maintaining temperature. Tested the start relay: open circuit confirmed. Replaced it ($18 part), confirmed normal compressor operation, unit at 38°F within 40 minutes. Customer had been without a fridge for five days waiting for a compressor quote from another company. Start relay repair: $89 diagnostic + $85 labor and parts. Total savings versus incorrect compressor replacement: over $400.",
    note: "LG 2014–2019: always check the start relay first. Same clicking symptom, $18 vs. $450 compressor."
  },
  {
    title: "KitchenAid KDTE334GPS dishwasher — E1 F9 error, flooding sensor",
    neighborhood: "College Park, 91764",
    description: "KitchenAid dishwasher triggering the flood sensor, shutting down mid-cycle. E1 F9 means the base pan flood sensor detected water. In College Park homes with hard water, we find two common causes: a drain pump partially blocked by mineral scale (water backs up and overflows into the base pan), or a failed door bottom gasket allowing slow leakage into the base. This unit had both — a partially blocked pump impeller and a worn door bottom gasket. Cleared the pump, replaced the gasket, reset the flood sensor. Unit running clean. Hard water maintenance briefing left with the customer.",
    note: "E1 F9 in hard water areas almost always has a maintenance component. Address the root cause, not just the sensor."
  },
];

const schema = {
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  "name": "Same Day Appliance Repair — Ontario",
  "telephone": phone,
  "email": "info@samedayappliance.repair",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Ontario",
    "addressRegion": "CA",
    "addressCountry": "US"
  },
  "areaServed": zipCodes.map(zip => ({ "@type": "PostalCode", "postalCode": zip })),
  "openingHoursSpecification": [
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "07:00", "closes": "21:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Saturday"], "opens": "08:00", "closes": "19:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Sunday"], "opens": "09:00", "closes": "17:00" }
  ],
  "priceRange": "$$",
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.6",
    "reviewCount": "37",
    "bestRating": "5"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
};
---

<BaseLayout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- HERO -->
  <section class="city-hero">
    <div class="hero-inner container">
      <div class="hero-text">
        <p class="eyebrow">San Bernardino County · ZIP 91758, 91761, 91762, 91764</p>
        <h1>Appliance Repair<br><span class="accent">Ontario CA</span></h1>
        <p class="hero-sub">Same-day service in Ontario Ranch, Downtown, South Ontario, College Park, Creekside, and throughout the city. Residential and commercial. All brands, OEM parts.</p>
        <div class="hero-ctas">
          <a href={`tel:${phoneRaw}`} class="btn btn-primary btn-lg">{phone}</a>
          <a href="/book" class="btn btn-outline btn-lg">Book Online</a>
        </div>
        <div class="hero-trust">
          <span>⭐ 4.6 · 37 Reviews</span>
          <span>Licensed &amp; Insured</span>
          <span>$89 Diagnostic</span>
        </div>
      </div>
      <div class="hero-img">
        <img src="/images/cities/ontario-appliance-repair.jpg" alt="Appliance repair in Ontario CA" width="560" height="420" loading="eager" />
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <div class="trust-bar">
    <div class="container trust-bar-inner">
      <div class="trust-item"><span class="ti-icon">📅</span><span>Same-Day Availability</span></div>
      <div class="trust-item"><span class="ti-icon">🏢</span><span>Residential &amp; Commercial</span></div>
      <div class="trust-item"><span class="ti-icon">🔧</span><span>OEM Parts Only</span></div>
      <div class="trust-item"><span class="ti-icon">💲</span><span>$89 Diagnostic → Applied to Repair</span></div>
      <div class="trust-item"><span class="ti-icon">✅</span><span>90-Day Parts &amp; Labor Warranty</span></div>
    </div>
  </div>

  <!-- INTRO + SIDEBAR -->
  <section class="intro-section container">
    <div class="intro-content">

      <h2>Appliance Repair in Ontario CA — A City That Runs on Working Appliances</h2>

      <p>Ontario is one of the hardest-working cities in the Inland Empire — home to one of the busiest cargo airports on the West Coast, a massive logistics and warehouse corridor, and a dense, diverse residential population that spans everything from 1960s rental homes along Holt Blvd to brand-new master-planned development at Ontario Ranch. The appliance profile here reflects that diversity: older Whirlpool and GE in the established neighborhoods, Samsung and LG in mid-range homes from the 1990s and 2000s, and newer KitchenAid and Samsung in the Ontario Ranch builds.</p>

      <p>The rental market is a significant part of who calls us in Ontario. Apartments and rental homes along Holt Blvd, Euclid, and Fourth Street need appliance repairs resolved quickly — a tenant without a working washer or refrigerator isn't just an inconvenience, it's a habitability issue. We work directly with landlords and property managers and understand the urgency that comes with an active tenancy. We communicate with both parties and aim to close every rental call the same day we open it.</p>

      <p>The industrial environment around Ontario International Airport and the logistics corridor adds a climate factor most appliance companies don't mention: fine particulate from warehouse activity and airport ground operations settles on condenser coils faster in parts of Ontario than in purely residential cities. Homes near the airport corridor and south of the 60 freeway see measurably heavier coil loading. We account for this in every refrigerator call in that zone.</p>

      <p>Same-day coverage across all four Ontario ZIP codes — 91758, 91761, 91762, 91764. Commercial calls serviced at $120 diagnostic. Call {phone}.</p>

    </div>

    <aside class="sticky-cta-box">
      <p class="scb-city">Ontario CA</p>
      <p class="scb-phone">{phone}</p>
      <a href={`tel:${phoneRaw}`} class="btn btn-primary btn-block">Call Now</a>
      <a href="/book" class="btn btn-outline btn-block">Book Online</a>
      <ul class="scb-list">
        <li>✓ Same-Day Available</li>
        <li>✓ $89 Residential / $120 Commercial</li>
        <li>✓ Rental &amp; Property Manager Priority</li>
        <li>✓ OEM Parts — No Aftermarket</li>
        <li>✓ 90-Day Warranty</li>
        <li>✓ Licensed &amp; Insured</li>
      </ul>
      <p class="scb-hours">Mon–Fri 7am–9pm · Sat 8am–7pm · Sun 9am–5pm</p>
    </aside>
  </section>

  <!-- SERVICES GRID -->
  <section class="services-section">
    <div class="container">
      <h2>What We Repair in Ontario CA</h2>
      <div class="services-grid">
        {services.map(svc => (
          <a href={`/${citySlug}/${svc.slug}/`} class="service-card">
            <span class="svc-icon">{svc.icon}</span>
            <span class="svc-name">{svc.name}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- HOUSING + MARKET BLOCK -->
  <section class="context-block container">
    <div class="context-inner">
      <div class="context-number">01</div>
      <div class="context-body">
        <h2>Ontario's Housing Stock — Four Distinct Markets</h2>

        <h3>Downtown &amp; Holt Blvd — 1960s–1980s Mix</h3>
        <p>The established neighborhoods near Downtown Ontario and along Holt Boulevard represent Ontario's oldest residential stock — single-family homes and apartment complexes built from the 1960s through the '80s. Appliances here range from 15 to 25 years old, and we see a high concentration of rental properties. Whirlpool, GE, and Maytag are the dominant brands. These machines are mechanically simpler than modern units and often worth repairing at advanced age — a Whirlpool Direct Drive washer with a worn coupling is a $120 fix, not a $700 replacement. We work with landlords in this part of Ontario regularly and understand the rental urgency dynamic.</p>

        <h3>College Park, Creekside &amp; North Ontario — 1990s–2000s Mid-Range</h3>
        <p>The planned neighborhoods north of the 10 freeway were developed primarily in the 1990s and 2000s. Samsung, LG, KitchenAid, and Whirlpool from this era are now 15–25 years into their lifespan. College Park and Creekside call us most often for LG linear inverter compressor relay failures (2014–2019 generation), Samsung ice maker issues, and front-load washer bearing wear. Hard water is consistent throughout Ontario — dishwasher filter cleaning and ice maker descaling are part of virtually every applicable service call in these neighborhoods.</p>

        <h3>Ontario Ranch — New Development, 2015+</h3>
        <p>Ontario Ranch is one of the largest master-planned communities in Southern California, built out since 2015 with homes running 2,000–4,000 square feet. Builder-grade Samsung, KitchenAid, and LG appliances from the early Ontario Ranch builds are now 7–10 years old — entering the first failure window. Ice maker issues, evaporator fan failures, and dishwasher drain errors are the common calls. The airport corridor proximity adds industrial dust exposure to coil maintenance considerations — we recommend 5-month cleaning cycles for refrigerators in this zone.</p>

        <h3>Commercial Ontario — Airport, Logistics, Restaurants</h3>
        <p>Ontario International Airport is one of the busiest cargo facilities in the US, and the logistics corridor around it supports dozens of warehouses, distribution centers, and commercial operations. We service break room refrigerators, commercial ice machines, undercounter coolers, and commercial laundry for businesses throughout this corridor. Restaurant and food-service equipment on Fourth Street and around Ontario Mills also falls in our service area. Commercial diagnostic is $120, applied to the repair. We aim for same-day commercial response — a failed walk-in cooler or break room fridge is a business disruption we take seriously.</p>

        <h3>Hard Water Throughout Ontario</h3>
        <p>Ontario water runs hard — consistent with the broader SB County profile. Dishwasher filters clog at 3-month intervals. Ice maker fill tubes scale up. Front-load washer door gaskets accumulate mineral deposits that accelerate the mold and odor issues common in Samsung and LG front-loaders. We include descaling as standard on every applicable service call and leave customers with the right maintenance schedule for their specific water quality and usage.</p>
      </div>
    </div>
  </section>

  <!-- NEIGHBORHOODS -->
  <section class="neighborhoods-section container">
    <div class="section-intro">
      <div class="context-number">02</div>
      <h2>Neighborhoods We Service in Ontario CA</h2>
      <p>We cover all of Ontario — from Ontario Ranch and Creekside in the south to College Park and North Ontario near the Upland border. No travel surcharge to any Ontario ZIP code.</p>
    </div>
    <div class="neighborhoods-grid">
      {neighborhoods.map(n => (
        <div class="nbhd-card">
          <span class="nbhd-name">{n.name}</span>
          <span class="nbhd-zip">ZIP {n.zip}</span>
        </div>
      ))}
    </div>
    <p class="nbhd-note">Also serving Montclair, Chino, and Eastvale — same dispatch, no surcharge. Call {phone}.</p>
  </section>

  <!-- RECENT REPAIRS -->
  <section class="repairs-section container">
    <div class="section-header">
      <div class="context-number">03</div>
      <h2>Recent Repairs in Ontario CA</h2>
    </div>
    <div class="repairs-grid">
      {recentRepairs.map(r => (
        <div class="repair-card">
          <h3 class="repair-title">"{r.title}"</h3>
          <p class="repair-location">📍 {r.neighborhood}</p>
          <p class="repair-desc">{r.description}</p>
          <p class="repair-note"><em>{r.note}</em></p>
        </div>
      ))}
    </div>
  </section>

  <!-- WHY US + REVIEWS + PRICING -->
  <section class="why-section container">
    <div class="context-number">04</div>
    <h2>Why Ontario Residents &amp; Property Managers Call Us</h2>

    <div class="why-grid">
      <div class="why-item">
        <h3>Rental property specialists</h3>
        <p>A broken appliance in an occupied rental is urgent. We coordinate directly with landlords and property managers, communicate clearly with tenants on scheduling, and close rental calls same-day whenever possible. No landlord should have to manage a habitability complaint for more than 24 hours.</p>
      </div>
      <div class="why-item">
        <h3>Residential and commercial</h3>
        <p>Whether it's a fridge in an Ontario Ranch home or a walk-in cooler in a restaurant near Fourth Street, we handle both. Commercial diagnostic is $120. We prioritize commercial calls to minimize downtime — a failed ice machine or cooler during business hours is a revenue issue.</p>
      </div>
      <div class="why-item">
        <h3>Diagnosis before the quote</h3>
        <p>The $89 fee means we look at the actual appliance before recommending anything. An LG clicking sound is an $18 relay until proven otherwise — not a $450 compressor. What we quote is what appears on the invoice.</p>
      </div>
      <div class="why-item">
        <h3>OEM parts across all generations</h3>
        <p>From a 1995 GE top-loader to a 2022 Samsung French-door, we source OEM parts through proper channels. In Ontario's hot, dusty, hard-water environment, the right part matters more than usual. We don't cut corners with aftermarket components.</p>
      </div>
    </div>

    <!-- Reviews -->
    <div class="reviews-grid">
      <div class="review-card">
        <div class="stars">★★★★★</div>
        <p>"Landlord here — tenant called about a broken washer on a Monday morning. Same Day was there by afternoon, diagnosed a worn actuator, fixed it same visit. $130 instead of buying a new machine. They handled the whole coordination with my tenant. Very smooth."</p>
        <p class="reviewer">— Marcus J., Holt Blvd landlord</p>
      </div>
      <div class="review-card">
        <div class="stars">★★★★★</div>
        <p>"LG fridge in our Ontario Ranch home started clicking and stopped cooling. Another company quoted a compressor — $490. Same Day diagnosed a bad start relay, fixed it for under $100. Couldn't believe the difference. Should have called them first."</p>
        <p class="reviewer">— Sarah &amp; Tom P., Ontario Ranch</p>
      </div>
      <div class="review-card">
        <div class="stars">★★★★★</div>
        <p>"KitchenAid dishwasher flooding error in our College Park home. Tech found it was hard water scale blocking the pump and a worn door gasket — two issues, one visit. Explained the maintenance schedule for our water. Very knowledgeable."</p>
        <p class="reviewer">— Linda R., College Park</p>
      </div>
    </div>

    <!-- Pricing -->
    <div class="pricing-block">
      <h3>Typical Repair Pricing in Ontario CA</h3>
      <p>Every repair is quoted on-site after diagnosis. The $89 residential / $120 commercial diagnostic is applied when you proceed.</p>
      <div class="pricing-grid">
        <div class="price-item">
          <span class="pi-service">Refrigerator Repair</span>
          <span class="pi-range">$150–$450</span>
        </div>
        <div class="price-item">
          <span class="pi-service">Washer Repair</span>
          <span class="pi-range">$120–$380</span>
        </div>
        <div class="price-item">
          <span class="pi-service">Dryer Repair</span>
          <span class="pi-range">$120–$320</span>
        </div>
        <div class="price-item">
          <span class="pi-service">Dishwasher Repair</span>
          <span class="pi-range">$89–$360</span>
        </div>
        <div class="price-item">
          <span class="pi-service">Oven / Range Repair</span>
          <span class="pi-range">$140–$400</span>
        </div>
        <div class="price-item">
          <span class="pi-service">Ice Maker Repair</span>
          <span class="pi-range">$120–$280</span>
        </div>
        <div class="price-item">
          <span class="pi-service">Commercial Diagnostic</span>
          <span class="pi-range">$120</span>
        </div>
        <div class="price-item">
          <span class="pi-service">Condenser Coil Cleaning</span>
          <span class="pi-range">$89–$150</span>
        </div>
      </div>
      <p class="pricing-note">Diagnostic applied to repair cost. No trip charge to Ontario ZIP codes.</p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section container">
    <h2>Ontario CA Appliance Repair — FAQ</h2>
    <div class="faq-list">
      {faqItems.map(item => (
        <details class="faq-item">
          <summary class="faq-q">{item.q}</summary>
          <p class="faq-a">{item.a}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- NEARBY -->
  <section class="nearby-section container">
    <h2>Also Serving Nearby Cities</h2>
    <div class="nearby-grid">
      <a href="/rancho-cucamonga/">Rancho Cucamonga</a>
      <a href="/upland/">Upland</a>
      <a href="/chino-hills/">Chino Hills</a>
      <a href="/fontana/">Fontana</a>
      <a href="/corona/">Corona</a>
      <a href="/san-bernardino/">San Bernardino</a>
    </div>
  </section>

  <!-- BOTTOM CTA -->
  <section class="bottom-cta">
    <div class="container">
      <h2>Need Appliance Repair in Ontario CA Today?</h2>
      <p>Same-day residential and commercial service across Ontario Ranch, Downtown, College Park, South Ontario, and all Ontario ZIP codes.</p>
      <div class="cta-buttons">
        <a href={`tel:${phoneRaw}`} class="btn btn-primary btn-lg">{phone}</a>
        <a href="/book" class="btn btn-outline btn-lg">Book Online</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
.city-hero { background: var(--color-bg); padding: 5rem 0 4rem; }
.hero-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
.eyebrow { font-size: .75rem; letter-spacing: .12em; text-transform: uppercase; color: var(--color-accent); margin-bottom: .75rem; }
h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 800; line-height: 1.1; margin-bottom: 1rem; }
h1 .accent { color: var(--color-accent); }
.hero-sub { font-size: 1.05rem; color: var(--color-text-muted); margin-bottom: 2rem; max-width: 48ch; }
.hero-ctas { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 1.5rem; }
.hero-trust { display: flex; gap: 1.5rem; flex-wrap: wrap; font-size: .85rem; color: var(--color-text-muted); }
.hero-img img { width: 100%; border-radius: .5rem; object-fit: cover; }
.trust-bar { background: var(--color-accent); padding: 1rem 0; }
.trust-bar-inner { display: flex; gap: 2rem; justify-content: center; flex-wrap: wrap; }
.trust-item { display: flex; align-items: center; gap: .5rem; color: #fff; font-size: .875rem; font-weight: 600; }
.intro-section { display: grid; grid-template-columns: 1fr 300px; gap: 4rem; padding-top: 4rem; padding-bottom: 4rem; }
.intro-content h2 { font-size: 1.6rem; margin-bottom: 1.25rem; }
