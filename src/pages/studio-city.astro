---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

const citySlug = 'studio-city';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = 'Studio City';
const zips = ['91604'];

const phoneRaw = `+1${branch.phone.replace(/\D/g, '')}`;

const title = `Appliance Repair Studio City CA — Same Day Service`;
const description = `Same-day appliance repair in Studio City, CA 91604. Sub-Zero, Wolf, Thermador, Samsung, LG, GE. Licensed, OEM parts.`;
const canonical = 'https://samedayappliance.repair/studio-city/';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { '@type': 'Neighborhood', name: 'Studio City', sameAs: 'https://en.wikipedia.org/wiki/Studio_City,_Los_Angeles' },
    { '@type': 'Neighborhood', name: 'Fryman Canyon' },
    { '@type': 'Neighborhood', name: 'Tujunga Village' }
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$',
  license: 'BHGS #A49573'

};

const introParagraphs = [
  "Studio City sits between the Santa Monica Mountains and the San Fernando Valley floor — part hillside, part flat, all character. The Fryman Canyon homes above Mulholland are serious properties with serious kitchens: Sub-Zero, Wolf, Thermador. The bungalows and mid-century homes along Coldwater and the streets south of Ventura have GE, Samsung, and LG that need the same reliable same-day service as any other home.",
  "Studio City has an unusually high concentration of entertainment industry professionals — writers, directors, producers, editors who work irregular hours and are rarely available in a standard weekday morning window. We don't require you to clear your schedule for us. We work around yours: evenings within our service window, early slots, weekends. Tell us when you're available and we'll be there.",
  "LADWP hard water is a consistent factor throughout 91604 — 230–310 mg/L hardness, and many older Studio City homes still have original galvanized supply lines that compound the mineral content. Ice maker inlet valves and dishwasher spray arms scale faster here than national average. We check for this on every relevant call.",
  "Diagnostic fee: <strong>$89</strong> — waived with repair. Written estimate before we start. <strong>90-day warranty</strong>. Weekends available.",
  "<strong>LADWP hard water tip for Studio City:</strong> If your refrigerator ice maker has been declining gradually — not a sudden stop but a slow reduction in output over weeks or months — LADWP mineral scale on the water inlet valve is the most likely cause in 91604. Older homes with galvanized supply lines compound the effect. A 6-month filter change cycle (not 12) meaningfully slows the accumulation rate on Studio City's water supply."
];

const services = [
  { icon: '🧊', name: 'Refrigerator Repair', slug: 'refrigerator', issues: 'LADWP hard water ice maker · Sub-Zero built-in · Not cooling · Fan', brands: 'Sub-Zero · Samsung · LG · GE · Thermador · Bosch' },
  { icon: '🔥', name: 'Oven, Range & Pro Range', slug: 'oven', issues: 'Wolf dual-fuel · Thermador igniter · Gas igniter · Temperature off', brands: 'Wolf · Thermador · Viking · GE · Samsung · KitchenAid' },
  { icon: '🫧', name: 'Washer Repair', slug: 'washer', issues: 'OE / UE error · Not draining · Not spinning · Stackable', brands: 'LG · Samsung · Whirlpool · Maytag · Bosch · Speed Queen' },
  { icon: '♨️', name: 'Dryer Repair + Vent Cleaning', slug: 'dryer', issues: 'Not heating · Thermal fuse · Hillside vent runs · Gas & electric', brands: 'LG · Samsung · GE · Maytag · Whirlpool · Miele' },
  { icon: '🍽️', name: 'Dishwasher Repair', slug: 'dishwasher', issues: 'LADWP scale · E24 · Miele · Panel-ready · Not draining', brands: 'Miele · Bosch · KitchenAid · Samsung · LG · GE' },
  { icon: '❄️', name: 'Freezer & Ice Maker Repair', slug: 'freezer', issues: 'LADWP inlet valve scale · Not freezing · Ice stopped · Sub-Zero', brands: 'Sub-Zero · Samsung · LG · GE · True · Whirlpool' },
  { icon: '🍷', name: 'Wine Cellar & Cooler Repair', slug: 'wine-cooler', issues: 'Temperature off · Sub-Zero wine · WhisperKOOL · EuroCave', brands: 'Sub-Zero · EuroCave · True · WhisperKOOL · Liebherr' },
  { icon: '🔆', name: 'Cooktop & Range Hood', slug: 'cooktop', issues: 'Wolf star burner · Thermador igniter · Induction · Hood motor', brands: 'Wolf · Thermador · Gaggenau · GE · Bosch · Dacor' }
];

const neighborhoods = [
  { name: 'Fryman Canyon estates', zip: '91604', featured: true },
  { name: 'Ventura Blvd corridor', zip: '91604', featured: true },
  { name: 'Coldwater Canyon area', zip: '91604', featured: true },
  { name: 'Tujunga Village', zip: '91604' },
  { name: 'Laurel Canyon border', zip: '91604' },
  { name: 'CBS Studio Center area', zip: '91604' },
  { name: 'Wrightwood Estates', zip: '91604' }
];

const keyStreets = ['Ventura Blvd', 'Coldwater Canyon Ave', 'Laurel Canyon Blvd', 'Mulholland Dr (south side)', 'Moorpark St', 'Fryman Rd'];

const recentJobs = [
  {
    appliance: 'Sub-Zero Built-In',
    location: 'Fryman Canyon, 91604',
    quote: 'Ice maker almost stopped — both sides barely producing',
    description: 'Fryman Canyon home above Mulholland — Sub-Zero 48-inch built-in, ice production declining for approximately three months. LADWP hard water plus original galvanized supply lines: inlet valve scaled to roughly 20% capacity on each column. Replaced both OEM Sub-Zero inlet valves, flushed both water lines, confirmed full production from both ice makers by end of call. Recommended a 6-month filter replacement schedule given the galvanized pipe factor and LADWP mineral content. Owner coordinated with the estate manager — access was arranged before we arrived.',
    outcome: '✓ Same day · OEM Sub-Zero both valves · LADWP cause explained · 6-month plan'
  },
  {
    appliance: 'Wolf Dual-Fuel Range',
    location: 'Coldwater Canyon area, 91604',
    quote: 'Three burners not lighting — clicking but no flame',
    description: 'Coldwater Canyon home — Wolf 36-inch dual-fuel with three surface igniter electrodes failing. Found the electrode boots cracked from thermal cycling over time — a common failure on heavily-used Wolf ranges in active cooking households. Replaced all three electrode assemblies with OEM Wolf parts, tested all six surface burners and both oven cavities. The owner is a food writer — this range gets used every day. Done in under 90 minutes with everything confirmed before we left.',
    outcome: '✓ Same day · OEM Wolf igniters · All burners · Both cavities confirmed'
  },
  {
    appliance: 'LG Washer',
    location: 'Ventura Blvd area, 91604',
    quote: 'OE drain error — called at 7pm, needed it fixed tonight',
    description: 'Studio City condo south of Ventura — homeowner on a production schedule, needed the call after 6pm. LG front-loader OE drain error. We scheduled an evening appointment — within our 7am–9pm window. Found the pump filter blocked with a combination of lint and LADWP mineral scale, plus a small foreign object (a coin) jamming the impeller. Cleared the filter, removed the coin, ran three drain cycles. OE gone. Done by 8:30pm. Homeowner was back on the call with their writers room by 9.',
    outcome: '✓ Evening slot · OE resolved · Coin found · Done by 8:30pm'
  },
  {
    appliance: 'Bosch Dishwasher',
    location: 'Tujunga Village area, 91604',
    quote: 'E24 drain error — second time in six months',
    description: 'Tujunga Village bungalow — Bosch 500 series, E24 drain error recurring. First occurrence six months ago was pump debris; this time it was LADWP mineral scale in the pump housing combined with a kinked drain hose that had slowly tightened behind the unit. Cleared the mineral-scaled pump housing, re-routed the drain hose with proper clearance and a high loop, confirmed three consecutive drain cycles. Explained the LADWP factor and recommended a descale maintenance cycle every 4–6 months for this water supply.',
    outcome: '✓ Same day · E24 resolved · Hose re-routed · Descale schedule explained'
  }
];

const whyReasons = [
  {
    iconKey: 'clock' as const,
    title: 'Schedule Flexibility',
    body: "Studio City has an above-average share of people who work non-standard hours. We don't require you to be home between 10am and 2pm on a Tuesday. Evening appointments within our 7am–9pm window, early slots, weekends — tell us when you're available and we work around that."
  },
  {
    iconKey: 'parts' as const,
    title: 'LADWP Hard Water Aware',
    body: 'Studio City is LADWP territory at 230–310 mg/L. Older homes with galvanized supply lines add iron on top. Ice makers and dishwashers scale faster here than national average. We test for mineral deposits proactively on every relevant 91604 call.'
  },
  {
    iconKey: 'team' as const,
    title: 'Hillside to Valley Floor',
    body: 'Fryman Canyon estates with Sub-Zero and Wolf, Ventura Blvd condos with LG and Samsung, mid-century bungalows with Whirlpool — we cover all of it. Same $89 diagnostic waived with repair, same OEM parts, same 90-day warranty regardless of address.'
  },
  {
    iconKey: 'shield' as const,
    title: '90-Day Warranty, OEM Only',
    body: 'Every repair backed by 90 days on parts and labor. Genuine OEM parts only. Written estimate before we start. California licensed, BBB A+ rated. No upcharges for same-day, no dispatch center routing, no hourly waiting windows.'
  }
];

const testimonials = [
  {
    stars: 5,
    text: '"Sub-Zero in our Fryman Canyon home — ice production from both columns declining for months. Tech came out, found LADWP scale on both inlet valves, replaced both with OEM Sub-Zero parts, explained the galvanized pipe factor, put us on a 6-month filter plan. Full ice by evening. Thorough and honest."',
    author: '— Richard H. (via estate manager), Fryman Canyon, Studio City'
  },
  {
    stars: 5,
    text: `"I needed a 7pm appointment because of my production schedule — they had no problem with that. LG washer OE error, found a coin in the impeller, cleared the pump filter, done by 8:30. I was back on my writers room call by 9. This is exactly what 'same-day service' should mean."`,
    author: '— Alex K., Ventura Blvd area, Studio City'
  },
  {
    stars: 5,
    text: '"Wolf range with three burners not lighting. Tech replaced all three electrodes with OEM Wolf parts, tested every surface burner and both oven cavities before leaving. I use this range every single day — having someone who takes that seriously makes all the difference."',
    author: '— Sarah M. (food writer), Coldwater Canyon, Studio City'
  }
];

const pricingTiers = [
  { appliance: 'Sub-Zero / Wolf / Thermador', range: '$300 – $800+', note: 'OEM parts · Fryman Canyon · Hillside estates', featured: true },
  { appliance: 'Refrigerator / Ice Maker', range: '$150 – $400', note: 'LADWP inlet valve · Galvanized pipe factor · Fan motor' },
  { appliance: 'Washer / Dryer', range: '$150 – $350', note: 'OE drain error · Thermal fuse · Vent · Hillside runs' },
  { appliance: 'Dishwasher', range: '$150 – $320', note: 'LADWP scale · E24 · Miele · Panel-ready · Pump' },
  { appliance: 'Oven / Range', range: '$150 – $450', note: 'Wolf igniter · Gas valve · Temperature calibration' },
  { appliance: 'Diagnostic Fee', range: '$89', note: 'Waived when you proceed with the repair' }
];

const faqs = [
  {
    question: 'Do you offer same-day appliance repair in Studio City, CA?',
    answer: 'Yes. Our technicians cover all of Studio City 91604 — Ventura Boulevard corridor, Fryman Canyon hillside homes, Tujunga Village area, Coldwater Canyon, Laurel Canyon border, and every residential street. Call before noon for same-day afternoon service.'
  },
  {
    question: 'Do you repair Sub-Zero, Wolf, and Thermador appliances in Studio City?',
    answer: "Yes. Sub-Zero, Wolf, Thermador, Miele, and Viking are common throughout Studio City's hillside homes and the premium properties in the Fryman Canyon area. Our technicians carry OEM parts for all luxury brands on every service vehicle."
  },
  {
    question: 'Does LADWP hard water affect appliances in Studio City?',
    answer: 'Yes. Studio City is LADWP territory at 230–310 mg/L hardness. Ice maker inlet valves and dishwasher spray arms accumulate mineral deposits faster than in soft-water areas. We check for this proactively on every relevant Studio City call involving refrigerators and dishwashers.'
  },
  {
    question: 'Are you available on weekends in Studio City?',
    answer: 'Yes. Saturday Mon–Sat 8am–8pm · Sun closed · Phone answered 24/7.'
  },
  {
    question: 'What is your diagnostic fee in Studio City?',
    answer: 'Our diagnostic fee is $89, waived when you proceed with the repair. Written estimate before we start. Most Studio City repairs run $150–$450 depending on brand and appliance.'
  },
  {
    question: 'Can you work around production and work schedules in Studio City?',
    answer: "Yes. We know Studio City has an above-average share of entertainment industry professionals with irregular schedules. We work around your availability — evenings within our service window, early mornings, weekends. We don't require you to be home in a 4-hour window; we schedule to fit your day."
  },
  {
    question: 'Do you also serve Sherman Oaks, North Hollywood, and Burbank?',
    answer: 'Yes. Our Studio City service extends to Sherman Oaks, North Hollywood, Burbank, Toluca Lake, Valley Village, and all of the San Fernando Valley.'
  }
];

const nearbyCities = [
  { name: 'North Hollywood', slug: 'north-hollywood' },
  { name: 'Burbank', slug: 'burbank' },
  { name: 'West Hollywood', slug: 'west-hollywood' },
  { name: 'Los Feliz', slug: 'los-feliz' },
  { name: 'Silver Lake', slug: 'silver-lake' },
  { name: 'Sherman Oaks', slug: 'sherman-oaks' },
  { name: 'Toluca Lake', slug: 'toluca-lake' },
  { name: 'Los Angeles', slug: 'los-angeles' }
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair"
    headlineCity="Studio City, CA"
    subheadline="Where the Valley meets the hills — Ventura Boulevard boutiques, Fryman Canyon estates, and an above-average share of people whose schedule doesn't follow a 9-to-5. Same-day service that works around yours. Sub-Zero, Wolf, Samsung, LG — all brands. OEM parts, 90-day warranty."
    zips={zips}
    tier={2}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance Repair in Studio City — What This Neighbourhood Actually Needs"
    paragraphs={introParagraphs}
    bookingTitle="Studio City Service"
    bookingSub="91604 · Schedule flexibility · Same day"
  />

  <ServicesGrid
    cityName={cityName}
    headline="What We Repair in Studio City"
    subhead="Luxury & all brands · LADWP hard water aware · All of 91604"
    services={services}
  />

  <ServiceArea
    cityName={cityName}
    headline="All of Studio City — 91604"
    subheadline="Ventura Blvd to the hillsides — every part of the neighbourhood"
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={keyStreets}
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Jobs in Studio City"
    subhead="Real calls from 91604 — hillside estates, Ventura Blvd homes, LADWP hard water."
    jobs={recentJobs}
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="Why Studio City Calls Us Back"
    reasons={whyReasons}
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What Studio City Customers Are Saying"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Appliance Repair Costs in Studio City"
    subhead="Written estimate before we start. $89 diagnostic — waived with repair. OEM parts only."
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="Questions Studio City Customers Ask"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby Areas"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance broken in Studio City?"
    body="Fryman Canyon · Ventura Blvd · Coldwater Canyon · LADWP hard water aware · Evening & weekend slots available. $89 diagnostic waived with repair. 90-day warranty."
  />
</CityLayoutV2>
