      { "@type": "Question", "name": "Which cities in Los Angeles County do you service?", "acceptedAnswer": { "@type": "Answer", "text": "We cover 26 cities: Los Angeles, West Hollywood, Beverly Hills, Santa Monica, Pasadena, Glendale, Burbank, Brentwood, Silver Lake, Culver City, Manhattan Beach, Studio City, Sherman Oaks, Encino, Woodland Hills, Marina del Rey, Redondo Beach, Long Beach, Koreatown, Highland Park, Atwater Village, Eagle Rock, Malibu, Pacific Palisades, Calabasas, and Los Feliz." } },
