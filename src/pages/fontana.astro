---
// src/pages/fontana.astro
import BaseLayout from '../layouts/BaseLayout.astro';

const city = "Fontana";
const citySlug = "fontana";
const phone = "(626) 376-4458";
const phoneRaw = "6263764458";
const zipCodes = ["92335", "92336", "92337"];
const county = "San Bernardino";

const title = `Appliance Repair Fontana CA — Same Day | All Brands | ${phone}`;
const description = `Same-day appliance repair in Fontana CA. Refrigerator, washer, dryer, oven, dishwasher & more. Sierra Lakes, South Fontana, Heritage Village. Licensed. OEM parts. Call ${phone}.`;

const services = [
  { name: "Refrigerator Repair", slug: "refrigerator-repair", icon: "❄️" },
  { name: "Washer Repair", slug: "washer-repair", icon: "🌀" },
  { name: "Dryer Repair", slug: "dryer-repair", icon: "💨" },
  { name: "Oven & Range Repair", slug: "oven-repair", icon: "🔥" },
  { name: "Dishwasher Repair", slug: "dishwasher-repair", icon: "🫧" },
  { name: "Stove & Cooktop Repair", slug: "stove-repair", icon: "🍳" },
  { name: "Freezer Repair", slug: "freezer-repair", icon: "🧊" },
  { name: "Ice Maker Repair", slug: "ice-maker-repair", icon: "🧊" },
];

const neighborhoods = [
  { name: "Sierra Lakes", zip: "92336" },
  { name: "Heritage Village", zip: "92335" },
  { name: "South Fontana", zip: "92337" },
  { name: "North Fontana", zip: "92336" },
  { name: "Citrus Heights", zip: "92335" },
  { name: "Arrow Blvd Corridor", zip: "92335" },
  { name: "Sierra Ave Area", zip: "92336" },
  { name: "Foothill Blvd Area", zip: "92335" },
  { name: "Cherry Ave", zip: "92335" },
  { name: "Auto Club Speedway Area", zip: "92337" },
  { name: "East Fontana", zip: "92336" },
  { name: "West Fontana", zip: "92335" },
];

const faqItems = [
  {
    q: "Do you offer same-day appliance repair in Fontana?",
    a: `Yes — same-day service is available throughout Fontana including Sierra Lakes, Heritage Village, South Fontana, North Fontana, and Citrus Heights. Call ${phone} before noon for same-day scheduling. We cover ZIP codes 92335, 92336, and 92337 without a trip surcharge.`
  },
  {
    q: "Why does my refrigerator fail every summer in Fontana?",
    a: "Fontana is consistently one of the hottest cities in Southern California — summer temperatures regularly hit 108–115°F, putting refrigerators under thermal loads that coastal or even most IE cities don't see. At those ambient temperatures, a refrigerator compressor is working against a 70-degree differential to hold 38°F. Condenser coils that were marginal in spring fail outright in Fontana's summer heat. We see more summer refrigerator calls in Fontana per capita than anywhere else in our SB County service area. Coil cleaning every 5 months — not 6, not annually — is the right maintenance schedule here."
  },
  {
    q: "Our family does heavy laundry — washer breaks more often than expected. Normal?",
    a: "In households with large families running 10–15 loads a week, washer components wear at 2–3x the rate of typical owner-occupied homes. Bearing wear, door gasket deterioration, and drum seal failures all show up earlier under heavy use. We see this pattern regularly in Fontana's larger family homes. The fix is usually the same — bearing replacement, seal replacement — but the maintenance interval should be shorter. If your machine is getting heavy use, annual inspection is worth scheduling."
  },
  {
    q: "What brands do you repair in Fontana?",
    a: "All major brands. Fontana's housing mix runs Samsung, LG, Whirlpool, GE, and Maytag across the 1970s–2000s stock, with newer LG and Samsung in the Sierra Lakes and North Fontana developments. We carry OEM parts for all generations. For heavy-use households, we specifically recommend OEM parts over aftermarket — in a high-heat, high-use environment, the quality difference matters."
  },
  {
    q: "What is your diagnostic fee?",
    a: `$89, applied directly to the repair cost when you proceed. No hidden trip charge to Fontana. We quote on-site after diagnosis — not over the phone based on symptoms. What we quote is what appears on the invoice.`
  },
  {
    q: "My dryer takes forever to dry — two or three cycles. What's wrong?",
    a: "In Fontana's housing stock, the most common causes are a blocked vent run combined with a weakening heating element. The vent runs in many Fontana tract homes are 15–20 feet through interior walls — long enough that lint buildup seriously restricts airflow over time. In Fontana's extreme heat, a restricted vent can also push exhaust temperatures high enough to blow the thermal fuse repeatedly. We inspect both the full vent path and the heating element on every dryer call here."
  },
  {
    q: "Do you service commercial appliances in Fontana?",
    a: "Yes. Fontana has significant commercial and industrial activity — warehouses, logistics operations, small restaurants, and food service businesses. We service commercial refrigerators, walk-in coolers, ice machines, and commercial laundry. Commercial diagnostic is $120, applied to the repair."
  },
];

const recentRepairs = [
  {
    title: "Samsung RF28R7351SR — compressor running constantly, warm fridge, July call",
    neighborhood: "Sierra Lakes, 92336",
    description: "Classic Fontana summer pattern. Samsung French-door, compressor running without stopping, fridge section at 55°F. Three-year-old unit that had never had maintenance. Condenser coils at the back were loaded with a combination of Fontana dust and pet hair — completely restricting airflow. In 108°F ambient heat, the coils simply couldn't dissipate enough heat for the compressor to maintain temperature. Cleaned the coils thoroughly, confirmed compressor function — completely normal under proper airflow. Also replaced the water filter, 20 months old. Both issues resolved without any parts replacement. $89 diagnostic + $65 coil cleaning service.",
    note: "In Fontana's summer heat, condenser coil cleaning is not optional. Every 5 months, not annually."
  },
  {
    title: "LG WM4000HWA front-load washer — loud grinding spin, 9 years old",
    neighborhood: "South Fontana, 92337",
    description: "Family of six in South Fontana — 12–15 loads per week. LG front-loader at year 9 with grinding noise during spin. Rear drum bearing failure — exactly what heavy-use washing does to front-loaders. The seal had worn first (it always does under heavy loads), allowing moisture into the bearing. We replaced the bearing and seal together as a complete set. Machine running quietly. Walked the family through a quarterly drum cleaning schedule and explained why the wear shows up faster in high-use households. They were running without fabric softener, which actually accelerates gasket degradation — useful thing to know.",
    note: "Heavy-use front-loaders: bearing and seal together, never just the bearing. And no fabric softener in the drum."
  },
  {
    title: "Whirlpool WED5000DW dryer — no heat, thermal fuse blown twice in 6 months",
    neighborhood: "Heritage Village, 92335",
    description: "Second blown thermal fuse in six months — the previous repair had been done by another company that replaced the fuse without checking the vent. We found a 23-foot vent run through the interior of a Heritage Village tract home, with a 90-degree bend at the far end that had accumulated lint down to about 30% of original diameter. Cleared the entire vent run, replaced the thermal fuse AND the thermal limiter as a set (replacing the fuse alone on Whirlpool units leaves the limiter at risk), and confirmed 800+ CFM at the exterior vent. Also found the heating element was running at 90% capacity — borderline. Replaced it while we had everything open.",
    note: "A thermal fuse that blows twice means the vent was never fixed the first time. Always find the root cause."
  },
  {
    title: "GE GFSS6KKYBSS — ice maker not producing, water dispenser fine, 2015 model",
    neighborhood: "North Fontana, 92336",
    description: "8-year-old GE side-by-side, ice maker silent, water dispenser working. Isolated to the ice maker inlet valve secondary solenoid — independent failure from the water solenoid. Also found the fill tube had a partial mineral scale deposit from hard water that was slowing fill rate. Replaced the inlet valve assembly with OEM GE parts, cleared and descaled the fill tube, replaced the water filter (22 months old). Also adjusted the freezer temperature from -2°F to +2°F — the overly cold set point was contributing to fill tube freeze risk in combination with the scale deposit. Ice production restored same visit.",
    note: "Fontana hard water + freezer set below 0°F = fill tube scaling. Adjust the set point, replace the filter."
  },
];

const schema = {
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  "name": "Same Day Appliance Repair — Fontana",
  "telephone": phone,
  "email": "info@samedayappliance.repair",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Fontana",
    "addressRegion": "CA",
    "addressCountry": "US"
  },
  "areaServed": zipCodes.map(zip => ({ "@type": "PostalCode", "postalCode": zip })),
  "openingHoursSpecification": [
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "07:00", "closes": "21:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Saturday"], "opens": "08:00", "closes": "19:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Sunday"], "opens": "09:00", "closes": "17:00" }
  ],
  "priceRange": "$$",
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.6",
    "reviewCount": "37",
    "bestRating": "5"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": { "@type": "Answer", "text": item.a }
  }))
};
---

<BaseLayout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- HERO -->
  <section class="city-hero">
    <div class="hero-inner container">
      <div class="hero-text">
        <p class="eyebrow">San Bernardino County · ZIP 92335, 92336, 92337</p>
        <h1>Appliance Repair<br><span class="accent">Fontana</span></h1>
        <p class="hero-sub">Same-day service in Sierra Lakes, Heritage Village, South Fontana, North Fontana, and throughout the city. Built for Fontana's heat. All brands, OEM parts, licensed.</p>
        <div class="hero-ctas">
          <a href={`tel:${phoneRaw}`} class="btn btn-primary btn-lg">{phone}</a>
          <a href="/book" class="btn btn-outline btn-lg">Book Online</a>
        </div>
        <div class="hero-trust">
          <span>⭐ 4.6 · 37 Reviews</span>
          <span>Licensed &amp; Insured</span>
          <span>$89 Diagnostic</span>
        </div>
      </div>
      <div class="hero-img">
        <img src="/images/cities/fontana-appliance-repair.jpg" alt="Appliance repair in Fontana CA" width="560" height="420" loading="eager" />
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <div class="trust-bar">
    <div class="container trust-bar-inner">
      <div class="trust-item"><span class="ti-icon">📅</span><span>Same-Day Availability</span></div>
      <div class="trust-item"><span class="ti-icon">🌡️</span><span>Extreme Heat Specialists</span></div>
      <div class="trust-item"><span class="ti-icon">🔧</span><span>OEM Parts Only</span></div>
      <div class="trust-item"><span class="ti-icon">💲</span><span>$89 Diagnostic → Applied to Repair</span></div>
      <div class="trust-item"><span class="ti-icon">✅</span><span>90-Day Parts &amp; Labor Warranty</span></div>
    </div>
  </div>

  <!-- INTRO + SIDEBAR -->
  <section class="intro-section container">
    <div class="intro-content">

      <h2>Appliance Repair in Fontana — Built for the Heat</h2>

      <p>Fontana is one of the hottest cities in Southern California — not just warm, but consistently in the top tier for summer temperatures across the entire state. When the thermometer hits 110°F in the afternoon, refrigerators in Fontana are working under conditions that most appliance manufacturers design to, but rarely encounter in actual service. Compressors run continuously, condenser coils load up with dust faster than anywhere else we service, and appliances that were borderline in June fail outright in July. We make more summer refrigerator calls in Fontana per capita than any other city in our SB County territory.</p>

      <p>The other characteristic that sets Fontana apart: large households. Fontana is a working-class, family-oriented city with a significant proportion of large families — households running 10–15 loads of laundry a week, refrigerators that get opened dozens of times a day, dishwashers running two and three cycles daily. This usage profile accelerates appliance wear in ways the manufacturers' maintenance schedules don't account for. A front-load washer that's rated for 10 years at normal use hits bearing failure at year 7–8 in a heavy-use household. We see this constantly in South Fontana and Heritage Village.</p>

      <p>We come prepared for both challenges — extreme heat and heavy use. We carry extra condenser cleaning equipment for summer calls, OEM bearing and seal sets for the most common washer models in this market, and thermal fuse/limiter pairs for every Whirlpool and GE dryer generation we encounter here.</p>

      <p>Same-day coverage across ZIP codes 92335, 92336, and 92337. Call {phone}.</p>

    </div>

    <aside class="sticky-cta-box">
      <p class="scb-city">Fontana</p>
      <p class="scb-phone">{phone}</p>
      <a href={`tel:${phoneRaw}`} class="btn btn-primary btn-block">Call Now</a>
      <a href="/book" class="btn btn-outline btn-block">Book Online</a>
      <ul class="scb-list">
        <li>✓ Same-Day Available</li>
        <li>✓ $89 Diagnostic → Applied to Repair</li>
        <li>✓ Extreme Heat Expertise</li>
        <li>✓ Heavy-Use Household Experience</li>
        <li>✓ OEM Parts — No Aftermarket</li>
        <li>✓ 90-Day Warranty</li>
      </ul>
      <p class="scb-hours">Mon–Fri 7am–9pm · Sat 8am–7pm · Sun 9am–5pm</p>
    </aside>
  </section>

  <!-- SERVICES GRID -->
  <section class="services-section">
    <div class="container">
      <h2>What We Repair in Fontana</h2>
      <div class="services-grid">
        {services.map(svc => (
          <a href={`/${citySlug}/${svc.slug}/`} class="service-card">
            <span class="svc-icon">{svc.icon}</span>
            <span class="svc-name">{svc.name}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FONTANA HEAT + HEAVY USE BLOCK -->
  <section class="context-block container">
    <div class="context-inner">
      <div class="context-number">01</div>
      <div class="context-body">
        <h2>What Fontana's Heat and Heavy Use Do to Your Appliances</h2>

        <h3>Extreme Summer Heat — The Fontana Refrigerator Problem</h3>
        <p>Fontana regularly records ambient temperatures of 108–115°F during July and August. At 110°F, your refrigerator's compressor is working against a 72-degree differential to hold 38°F inside. Manufacturers rate their compressors to handle this, but only if everything else — condenser coils, fan motors, door gaskets — is in perfect condition. In Fontana's dusty environment, condenser coils load up with fine particulate in 4–5 months. A partially clogged coil in mild weather becomes a failed coil in Fontana's summer heat.</p>

        <p>The maintenance schedule we recommend for Fontana refrigerators: condenser coil cleaning every 5 months, not 6. For homes near unpaved roads or the warehouse corridor along Arrow Boulevard, closer to every 4 months. Refrigerator water filters every 4 months — hard water saturates faster here. Door gaskets should be inspected annually — Fontana's dry heat hardens gaskets faster than coastal climates.</p>

        <h3>Heavy-Use Households — When Normal Wear Rates Don't Apply</h3>
        <p>Manufacturer warranty and lifespan estimates are based on average household use — typically 5–8 washer loads per week, refrigerator opened 15–20 times per day. In larger Fontana households running 10–15 loads weekly and opening the fridge 40–50 times a day, these components wear at 2–3x the standard rate.</p>

        <p><strong>Front-load washers:</strong> Rear drum bearing failure in heavy-use households shows up at year 7–8 instead of year 10–12. The seal wears first, allowing moisture into the bearing. We replace bearing and seal together as a set — never just the bearing alone. We also strongly advise against fabric softener in heavy-use front-loaders: it accelerates door gasket breakdown and contributes to the mold and odor issues LG and Samsung front-loaders are known for.</p>

        <p><strong>Dryers:</strong> Heavy-use dryers in Fontana have a specific failure pattern: the thermal fuse blows repeatedly because the vent run is partially blocked AND the heating element is weakening. Fontana's tract homes have long interior vent runs — 15–25 feet through interior walls. Under heavy use, lint accumulates faster. We inspect and clear the full vent path on every Fontana dryer call. A thermal fuse that has blown twice has a root cause that was never addressed.</p>

        <p><strong>Dishwashers:</strong> Hard water is consistent throughout SB County, and in heavy-use Fontana households running 2–3 dishwasher cycles daily, mineral scale accumulates in the filter, spray arms, and pump at a rate that demands quarterly cleaning — not annual. The Bosch E24 drain error, KitchenAid F9 flooding error, and Samsung dishwasher drain issues we encounter in Fontana are almost always hard water maintenance problems before they're mechanical failures.</p>

        <h3>Fontana Neighborhoods and Their Appliance Profiles</h3>
        <p><strong>Sierra Lakes and North Fontana (92336):</strong> Master-planned communities built 1990s–2010s, newer appliances in the 8–15 year range. Samsung, LG, and KitchenAid. Ice maker failures and front-load bearing wear are the most common calls.</p>
        <p><strong>Heritage Village and West Fontana (92335):</strong> Older tract housing from the 1970s and '80s, mix of original and replacement appliances. Whirlpool, GE, and Maytag workhorses. Thermal fuse failures and compressor heat stress in summer.</p>
        <p><strong>South Fontana and East Fontana (92337):</strong> Diverse mix of housing generations, high proportion of large family households. Heaviest wear rates in our Fontana service area. We make more bearing replacement calls here than anywhere else in SB County.</p>
      </div>
    </div>
  </section>

  <!-- NEIGHBORHOODS -->
  <section class="neighborhoods-section container">
    <div class="section-intro">
      <div class="context-number">02</div>
      <h2>Neighborhoods We Service in Fontana</h2>
      <p>We cover all of Fontana — Sierra Lakes, Heritage Village, South Fontana, North Fontana, Citrus Heights, and every neighborhood in between. No travel surcharge to any address in 92335, 92336, or 92337.</p>
    </div>
    <div class="neighborhoods-grid">
      {neighborhoods.map(n => (
        <div class="nbhd-card">
          <span class="nbhd-name">{n.name}</span>
          <span class="nbhd-zip">ZIP {n.zip}</span>
        </div>
      ))}
    </div>
    <p class="nbhd-note">Also serving Rialto and San Bernardino — same dispatch, no surcharge. Call {phone}.</p>
  </section>

  <!-- RECENT REPAIRS -->
  <section class="repairs-section container">
    <div class="section-header">
      <div class="context-number">03</div>
      <h2>Recent Repairs in Fontana</h2>
    </div>
    <div class="repairs-grid">
      {recentRepairs.map(r => (
        <div class="repair-card">
          <h3 class="repair-title">"{r.title}"</h3>
          <p class="repair-location">📍 {r.neighborhood}</p>
          <p class="repair-desc">{r.description}</p>
          <p class="repair-note"><em>{r.note}</em></p>
        </div>
      ))}
    </div>
  </section>

  <!-- WHY US + REVIEWS + PRICING -->
  <section class="why-section container">
    <div class="context-number">04</div>
    <h2>Why Fontana Residents Call Us</h2>

    <div class="why-grid">
      <div class="why-item">
        <h3>We know Fontana's heat</h3>
        <p>108–115°F summers create appliance stress that most companies don't account for. We do. Every summer refrigerator call in Fontana starts with condenser coils before anything else. We recommend the right maintenance schedule for this specific climate — 5-month cycles, not annual.</p>
      </div>
      <div class="why-item">
        <h3>We understand heavy-use households</h3>
        <p>A family running 14 loads a week puts 2–3x the wear on a washer compared to the manufacturer's estimate. We've seen this pattern in Fontana hundreds of times. We come with the right parts and give realistic advice on when repair makes sense versus when wear has simply caught up with the machine.</p>
      </div>
      <div class="why-item">
        <h3>Root cause, not just symptoms</h3>
        <p>A thermal fuse that's blown twice means the vent was never cleared the first time. A dishwasher drain error in Fontana hard water is a filter problem until proven otherwise. We find the actual cause before recommending parts — because fixing the symptom without the cause is a callback waiting to happen.</p>
      </div>
      <div class="why-item">
        <h3>OEM parts in a hard-use environment</h3>
        <p>Aftermarket parts fail faster under Fontana's heat and heavy-use conditions. We source OEM for every repair. In a market where appliances are already under more stress than average, using the correct parts is the difference between a 5-year fix and a 2-year one.</p>
      </div>
    </div>

    <!-- Reviews -->
    <div class="reviews-grid">
      <div class="review-card">
        <div class="stars">★★★★★</div>
        <p>"Fridge in our Sierra Lakes home stops cooling every July. Finally called Same Day — tech cleaned the condenser coils, which were completely packed. Explained the 5-month cleaning schedule for Fontana's heat. Machine has been perfect since. Should have done this years ago."</p>
        <p class="reviewer">— Carlos &amp; Maria R., Sierra Lakes</p>
      </div>
      <div class="review-card">
        <div class="stars">★★★★★</div>
        <p>"LG washer grinding badly with 6 kids in the house. Tech said the bearing was gone from heavy use — made total sense. Fixed the bearing and seal together, explained why both need to be done. Running quiet again. Also told us about no fabric softener in the drum, didn't know that."</p>
        <p class="reviewer">— Vanessa T., South Fontana</p>
      </div>
      <div class="review-card">
        <div class="stars">★★★★★</div>
        <p>"Whirlpool dryer blew the thermal fuse for the second time in 6 months. Previous company just replaced the fuse. Same Day found the vent was 80% blocked — 23 feet through the wall. Cleared it, replaced fuse AND limiter, problem solved for good. Very thorough."</p>
        <p class="reviewer">— James K., Heritage Village</p>
      </div>
    </div>

    <!-- Pricing -->
    <div class="pricing-block">
      <h3>Typical Repair Pricing in Fontana</h3>
      <p>Every repair is quoted on-site after diagnosis. The $89 diagnostic is applied when you proceed.</p>
      <div class="pricing-grid">
        <div class="price-item">
          <span class="pi-service">Refrigerator Repair</span>
          <span class="pi-range">$150–$450</span>
        </div>
        <div class="price-item">
          <span class="pi-service">Washer Repair</span>
          <span class="pi-range">$140–$380</span>
        </div>
        <div class="price-item">
          <span class="pi-service">Dryer Repair</span>
          <span class="pi-range">$120–$320</span>
        </div>
        <div class="price-item">
          <span class="pi-service">Dishwasher Repair</span>
          <span class="pi-range">$89–$360</span>
        </div>
        <div class="price-item">
          <span class="pi-service">Oven / Range Repair</span>
          <span class="pi-range">$140–$400</span>
        </div>
        <div class="price-item">
          <span class="pi-service">Ice Maker Repair</span>
          <span class="pi-range">$120–$280</span>
        </div>
        <div class="price-item">
          <span class="pi-service">Condenser Coil Cleaning</span>
          <span class="pi-range">$89–$150</span>
        </div>
        <div class="price-item">
          <span class="pi-service">Dryer Vent Cleaning</span>
          <span class="pi-range">$89–$140</span>
        </div>
      </div>
      <p class="pricing-note">$89 diagnostic applied to repair cost. No trip charge to Fontana ZIP codes.</p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section container">
    <h2>Fontana Appliance Repair — FAQ</h2>
    <div class="faq-list">
      {faqItems.map(item => (
        <details class="faq-item">
          <summary class="faq-q">{item.q}</summary>
          <p class="faq-a">{item.a}</p>
        </details>
      ))}
    </div>
  </section>

  <!-- NEARBY -->
  <section class="nearby-section container">
    <h2>Also Serving Nearby Cities</h2>
    <div class="nearby-grid">
      <a href="/rancho-cucamonga/">Rancho Cucamonga</a>
      <a href="/ontario/">Ontario</a>
      <a href="/san-bernardino/">San Bernardino</a>
      <a href="/upland/">Upland</a>
      <a href="/redlands/">Redlands</a>
      <a href="/riverside/">Riverside</a>
    </div>
  </section>

  <!-- BOTTOM CTA -->
  <section class="bottom-cta">
    <div class="container">
      <h2>Need Appliance Repair in Fontana Today?</h2>
      <p>Same-day service in Sierra Lakes, Heritage Village, South Fontana, North Fontana, and all Fontana ZIP codes. Built for the heat.</p>
      <div class="cta-buttons">
        <a href={`tel:${phoneRaw}`} class="btn btn-primary btn-lg">{phone}</a>
        <a href="/book" class="btn btn-outline btn-lg">Book Online</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
.city-hero { background: var(--color-bg); padding: 5rem 0 4rem; }
.hero-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; }
.eyebrow { font-size: .75rem; letter-spacing: .12em; text-transform: uppercase; color: var(--color-accent); margin-bottom: .75rem; }
h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 800; line-height: 1.1; margin-bottom: 1rem; }
h1 .accent { color: var(--color-accent); }
.hero-sub { font-size: 1.05rem; color: var(--color-text-muted); margin-bottom: 2rem; max-width: 48ch; }
.hero-ctas { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 1.5rem; }
.hero-trust { display: flex; gap: 1.5rem; flex-wrap: wrap; font-size: .85rem; color: var(--color-text-muted); }
