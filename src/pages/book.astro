---
import Layout from '../layouts/Layout.astro';
import { BRANCHES, type Branch } from '../data/branches';

// Filter out branches with placeholder 555 phones (RC + Temecula are 'pending'
// until Roman buys real DIDs). Don't publish 555-fake numbers.
const activeBranches = BRANCHES.filter(b => b.phoneStatus === 'active');
const phoneRawFor = (b: Branch) => '+1' + b.phone.replace(/\D/g, '');
const slugToTitle = (slug: string) =>
  slug.split('-').map(w => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');

const title = 'Book Appliance Repair — Same-Day Dispatch in LA, OC, Ventura | SDAR';
const description = 'Book a same-day appliance repair visit online or by phone. $89 dx waived, OEM parts, 90-day labor warranty. 5 branches across SoCal.';
const canonical = 'https://samedayappliance.repair/book/';

const mainPhone = '(424) 325-0520';
const mainPhoneTel = '+14243250520';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  '@id': 'https://samedayappliance.repair/#business',
  name: 'Same Day Appliance Repair',
  legalName: 'HVAC 777 LLC',
  url: 'https://samedayappliance.repair/',
  telephone: mainPhone,
  priceRange: '$89 diagnostic · OEM parts · 90-day warranty',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '6230 Wilshire Blvd Ste A PMB 2267',
    addressLocality: 'Los Angeles',
    addressRegion: 'CA',
    postalCode: '90048',
    addressCountry: 'US'
  },
  geo: { '@type': 'GeoCoordinates', latitude: 34.0619, longitude: -118.3692 },
  areaServed: [
    { '@type': 'AdministrativeArea', name: 'Los Angeles County' },
    { '@type': 'AdministrativeArea', name: 'Orange County' },
    { '@type': 'AdministrativeArea', name: 'Ventura County' },
    { '@type': 'AdministrativeArea', name: 'San Bernardino County' },
    { '@type': 'AdministrativeArea', name: 'Riverside County' },
  ],
  potentialAction: {
    '@type': 'ReserveAction',
    target: { '@type': 'EntryPoint', urlTemplate: canonical },
    name: 'Book an appliance repair visit'
  }
};

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Book an appliance repair visit',
  url: canonical,
  description,
  inLanguage: 'en-US',
  isPartOf: { '@type': 'WebSite', name: 'Same Day Appliance Repair', url: 'https://samedayappliance.repair/' }
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://samedayappliance.repair/' },
    { '@type': 'ListItem', position: 2, name: 'Book', item: canonical },
  ]
};

const applianceOptions = [
  'Refrigerator', 'Freezer', 'Wine Cooler / Cellar', 'Ice Maker',
  'Dishwasher', 'Oven / Wall Oven', 'Range / Stove', 'Cooktop',
  'Microwave', 'Range Hood', 'Washer', 'Dryer', 'Stackable Washer-Dryer',
  'Garbage Disposal', 'Trash Compactor', 'BBQ Grill', 'Pizza Oven', 'Other',
];
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <section class="book-hero">
    <div class="container">
      <p class="eyebrow">Book · Same-Day Visits</p>
      <h1>Book a repair visit. We'll call you back in 30 minutes.</h1>
      <p class="lede">
        Tell us the appliance, the brand, and the zip. A dispatcher from the nearest branch — West
        Hollywood, Los Angeles, Pasadena, Thousand Oaks, or Irvine — calls back with a 2-hour
        arrival window. Most same-day requests booked before noon get a tech out the same afternoon.
      </p>
      <div class="hero-ctas">
        <a href={`tel:${mainPhoneTel}`} class="btn-primary">Call {mainPhone}</a>
        <a href="#book-form" class="btn-ghost">Book online ↓</a>
      </div>
      <p class="hero-micro">
        $89 residential diagnostic, waived when the repair goes ahead. OEM parts. 90-day labor
        warranty. Commercial rates start at $120 — ask for commercial dispatch.
      </p>
    </div>
  </section>

  <section class="flow-section">
    <div class="container">
      <h2>How booking works</h2>
      <div class="step-grid">
        <div class="step">
          <span class="step-num">1</span>
          <h3>You submit the form or call</h3>
          <p>
            Takes about 60 seconds. We need the appliance, the make/model if you have it, the
            symptom, and your address. Model plate is usually on the inside wall, door frame,
            or back panel — no stress if you can't find it.
          </p>
        </div>
        <div class="step">
          <span class="step-num">2</span>
          <h3>Dispatch calls back</h3>
          <p>
            Within 30 minutes on a weekday. We confirm the address, book a 2-hour arrival window,
            and tell the tech which parts to stock on the truck. You get a text with the window
            and the tech's name.
          </p>
        </div>
        <div class="step">
          <span class="step-num">3</span>
          <h3>Tech arrives, diagnoses, quotes</h3>
          <p>
            The $89 diagnostic covers up to 45 minutes of testing — pulling codes, checking
            compressor draw, inspecting water valves, whatever the symptom points at. You get a
            flat written repair quote before anything gets swapped.
          </p>
        </div>
        <div class="step">
          <span class="step-num">4</span>
          <h3>Approve → repair → 90-day warranty</h3>
          <p>
            Approve the quote and the $89 is waived — it rolls into the repair. OEM parts where
            available. You get a 90-day labor warranty and, on most parts, the manufacturer's
            parts warranty on top.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="form-section" id="book-form">
    <div class="container form-container">
      <h2>Book online</h2>
      <p class="section-intro">
        Fastest path is a call — but if you prefer to type, this form opens your email client
        pre-filled and sends to our dispatch queue. We call back within 30 minutes during
        business hours.
      </p>

      <form class="book-form" id="bookingForm" novalidate>
        <div class="form-row">
          <label>
            <span>Your name *</span>
            <input type="text" id="f-name" name="name" required autocomplete="name" />
          </label>
          <label>
            <span>Phone *</span>
            <input type="tel" id="f-phone" name="phone" required autocomplete="tel" />
          </label>
        </div>

        <div class="form-row">
          <label>
            <span>Email (for confirmation)</span>
            <input type="email" id="f-email" name="email" autocomplete="email" />
          </label>
          <label>
            <span>Service zip</span>
            <input type="text" id="f-zip" name="zip" pattern="[0-9]{5}" autocomplete="postal-code" />
          </label>
        </div>

        <label class="full">
          <span>Service address *</span>
          <input type="text" id="f-address" name="address" placeholder="Street, unit if any, city" autocomplete="street-address" required />
        </label>

        <label class="full">
          <span>Service area * (routes to nearest branch)</span>
          <select id="f-city" name="city" required>
            <option value="">— Select your area —</option>
            {activeBranches.map((b) => (
              <option value={b.slug}>{b.name} — {b.phone}</option>
            ))}
          </select>
        </label>

        <div class="form-row">
          <label>
            <span>Appliance *</span>
            <select id="f-appliance" name="appliance" required>
              <option value="">— Select —</option>
              {applianceOptions.map((o) => <option value={o}>{o}</option>)}
            </select>
          </label>
          <label>
            <span>Brand &amp; model (if known)</span>
            <input type="text" id="f-brand" name="brand" placeholder="e.g. Sub-Zero 648PROG" />
          </label>
        </div>

        <label class="full">
          <span>What's wrong? *</span>
          <textarea id="f-issue" name="symptom" rows="4" required placeholder="Freezer fine, fridge side warming. Started about 3 days ago. Compressor runs but not cold."></textarea>
        </label>

        <div class="form-row">
          <label>
            <span>Preferred date</span>
            <input type="date" id="f-date" name="date" />
          </label>
          <label>
            <span>Preferred time</span>
            <select id="f-time" name="window">
              <option value="asap">ASAP — same day if possible</option>
              <option value="today-pm">Today, afternoon</option>
              <option value="tomorrow-am">Tomorrow, morning</option>
              <option value="tomorrow-pm">Tomorrow, afternoon</option>
              <option value="flex">Flexible — tell me what's open</option>
            </select>
          </label>
        </div>

        <input type="text" id="f-hp" name="website" autocomplete="off" tabindex="-1" aria-hidden="true"
               style="position:absolute;left:-9999px;opacity:0;pointer-events:none;height:1px;width:1px" />

        <button type="button" id="bookSubmit" class="btn-primary submit">Send booking request</button>
        <p class="form-note">
          For same-day service before noon, calling <a href={`tel:${mainPhoneTel}`}>{mainPhone}</a>
          is faster than the form. Phones answered 24/7.
        </p>
      </form>

      <div id="bookingSuccess" class="book-success" style="display:none">
        <div class="success-check" aria-hidden="true">✓</div>
        <h3>Booking received</h3>
        <p>
          A dispatcher from your nearest branch will call back within 30 minutes during business
          hours (Mon–Sat 8AM–8PM). Your branch line is shown below — for urgent same-day needs,
          calling directly is fastest.
        </p>
        <a id="successCallLink" href={`tel:${mainPhoneTel}`} class="btn-primary submit">Call {mainPhone}</a>
      </div>
    </div>
  </section>

  <section class="branch-phones">
    <div class="container">
      <h2>Or call the branch closest to you</h2>
      <p class="section-intro">
        All five dispatch queues route through the same team. Calling the local branch just helps
        us pick the right truck faster.
      </p>
      <div class="phone-grid">
        {activeBranches.map((b) => (
          <a href={`tel:${phoneRawFor(b)}`} class="phone-card">
            <span class="phone-city">{b.name}</span>
            <span class="phone-num">{b.phone}</span>
            <span class="phone-zones">{b.citiesServed.slice(0, 4).map(slugToTitle).join(' · ')}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="coverage-note">
    <div class="container">
      <div class="note-grid">
        <div>
          <h3>Service area</h3>
          <p>
            Los Angeles County (from Malibu to the San Gabriel Valley), Orange County, Ventura
            County (through Thousand Oaks to Oxnard), plus parts of western San Bernardino and
            Riverside counties from the Irvine and Los Angeles branches. If you're outside the
            map, call anyway — we've driven further for the right repair.
          </p>
        </div>
        <div>
          <h3>Not residential?</h3>
          <p>
            Restaurants, hotels, bars, grocery, property management, Airbnb portfolios — see our
            <a href="/for-business/">For Business</a> page for net-30 invoicing and named account
            managers, or call and ask for commercial dispatch. Commercial diagnostic is $120 and
            carries a different parts-warranty structure.
          </p>
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      var btn = document.getElementById('bookSubmit');
      if (!btn) return;
      var form = document.getElementById('bookingForm');
      var success = document.getElementById('bookingSuccess');
      var successCall = document.getElementById('successCallLink');

      // city slug -> phone (display only — server is authoritative)
      var BRANCH_PHONES = {
        'pasadena': '(626) 376-4458',
        'beverly-hills': '(424) 248-1199',
        'thousand-oaks': '(424) 208-0228',
        'irvine': '(213) 401-9019',
        'rancho-cucamonga': '(909) 457-1030',
        'temecula': '(951) 577-3877',
        'west-hollywood': '(323) 870-4790',
        'los-angeles': '(424) 325-0520'
      };

      function val(id) {
        var el = document.getElementById(id);
        return el ? (el.value || '').trim() : '';
      }

      btn.addEventListener('click', async function () {
        var name = val('f-name');
        var phone = val('f-phone');
        var email = val('f-email');
        var zip = val('f-zip');
        var address = val('f-address');
        var city = val('f-city');
        var appliance = val('f-appliance');
        var brand = val('f-brand');
        var issue = val('f-issue');
        var date = val('f-date');
        var time = val('f-time');
        var hp = val('f-hp');

        if (!name) { alert('Please enter your name.'); return; }
        if (!phone || phone.replace(/\D/g, '').length < 7) {
          alert('Please enter a valid phone number.');
          return;
        }
        if (!address) { alert('Please enter your service address.'); return; }
        if (!city) { alert('Please select your service area.'); return; }
        if (!appliance) { alert('Please select the appliance type.'); return; }
        if (!issue) { alert('Please describe the issue briefly.'); return; }

        btn.disabled = true;
        var origText = btn.textContent;
        btn.textContent = 'Sending…';

        try {
          var res = await fetch('/api/contact', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              type: 'booking',
              brand_site: 'samedayappliance.repair',
              name: name,
              phone: phone,
              email: email,
              zip: zip,
              address: address,
              city: city,
              equipment: appliance,
              brand: brand,
              description: issue,
              date: date,
              time: time,
              _hp: hp
            })
          });
          var data = await res.json();
          if (data.ok) {
            // Update success-state phone link to the branch dispatcher
            var branchPhone = BRANCH_PHONES[city] || BRANCH_PHONES['los-angeles'];
            if (successCall) {
              var raw = '+1' + branchPhone.replace(/\D/g, '');
              successCall.href = 'tel:' + raw;
              successCall.textContent = 'Call ' + branchPhone;
            }
            form.style.display = 'none';
            success.style.display = 'block';
            window.dataLayer = window.dataLayer || [];
            window.dataLayer.push({
              event: 'booking_submitted',
              branch: data.branch || city,
              appliance: appliance
            });
            window.scrollTo({ top: form.offsetTop - 80, behavior: 'smooth' });
          } else {
            alert(data.error || 'Submission failed. Please call (424) 325-0520 directly.');
            btn.disabled = false;
            btn.textContent = origText;
          }
        } catch (err) {
          alert('Network error. Please call (424) 325-0520 directly.');
          btn.disabled = false;
          btn.textContent = origText;
        }
      });
    })();
  </script>
</Layout>

<style>
  .book-hero { padding: 80px 0 64px; background: var(--gray); border-bottom: 1px solid var(--border); }
  .eyebrow { font-size: 12px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--red); margin-bottom: 16px; }
  h1 { font-size: clamp(2rem, 5vw, 3.2rem); line-height: 1.1; margin: 0 0 20px; max-width: 820px; }
  .lede { max-width: 720px; font-size: 18px; line-height: 1.65; color: var(--muted); margin-bottom: 28px; }
  .hero-ctas { display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: 20px; }
  .hero-micro { font-size: 14px; color: var(--muted); max-width: 720px; }

  .btn-primary {
    display: inline-block; padding: 12px 22px; background: var(--red); color: var(--white);
    font-weight: 600; border-radius: 4px; text-decoration: none; transition: background 0.2s var(--ease);
    border: none; font-family: inherit; cursor: pointer; font-size: 15px;
  }
  .btn-primary:hover { background: var(--red-dark, #8a0d20); color: var(--white); }
  .btn-ghost {
    display: inline-block; padding: 12px 22px; background: transparent; color: var(--black);
    font-weight: 600; border: 1px solid var(--border); border-radius: 4px; text-decoration: none;
  }
  .btn-ghost:hover { border-color: var(--black); }

  .flow-section { padding: 72px 0; }
  h2 { font-size: clamp(1.6rem, 3.5vw, 2.2rem); margin: 0 0 14px; }
  .section-intro { color: var(--muted); max-width: 720px; margin-bottom: 32px; font-size: 16px; line-height: 1.6; }
  .step-grid { display: grid; gap: 20px; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); margin-top: 28px; }
  .step { padding: 24px; background: var(--gray); border-radius: 6px; border: 1px solid var(--border); position: relative; }
  .step-num {
    position: absolute; top: -14px; left: 20px; display: inline-flex;
    align-items: center; justify-content: center; width: 32px; height: 32px;
    background: var(--red); color: var(--white); border-radius: 50%;
    font-weight: 700; font-size: 15px;
  }
  .step h3 { font-size: 17px; margin: 8px 0 10px; font-family: var(--font-body); font-weight: 600; }
  .step p { font-size: 14px; line-height: 1.65; color: var(--muted); margin: 0; }

  .book-success {
    margin-top: 28px; background: var(--white); padding: 48px 32px; border: 1px solid var(--border);
    border-radius: 6px; text-align: center;
  }
  .book-success h3 { font-size: 1.6rem; margin: 0 0 12px; }
  .book-success p { color: var(--muted); max-width: 520px; margin: 0 auto 24px; line-height: 1.65; font-size: 15px; }
  .success-check {
    display: inline-flex; align-items: center; justify-content: center;
    width: 56px; height: 56px; background: var(--red); color: var(--white);
    border-radius: 50%; font-size: 28px; font-weight: 700; margin: 0 auto 20px;
  }

  .form-section { padding: 72px 0; background: var(--gray); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .form-container { max-width: 820px; }
  .book-form { margin-top: 28px; background: var(--white); padding: 28px; border: 1px solid var(--border); border-radius: 6px; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; margin-bottom: 14px; }
  @media (max-width: 640px) { .form-row { grid-template-columns: 1fr; } }
  label { display: block; font-size: 13px; font-weight: 600; color: var(--text); }
  label.full { display: block; margin-bottom: 14px; }
  label span { display: block; margin-bottom: 6px; }
  input, textarea, select {
    width: 100%; padding: 10px 12px; border: 1px solid var(--border); border-radius: 4px;
    font-family: inherit; font-size: 14px; background: var(--white); color: var(--text);
  }
  input:focus, textarea:focus, select:focus { outline: 2px solid var(--red); outline-offset: 1px; border-color: var(--red); }
  .submit { margin-top: 8px; }
  .form-note { margin-top: 14px; font-size: 13px; color: var(--muted); }
  .form-note a { color: var(--red); }

  .branch-phones { padding: 72px 0; }
  .phone-grid { display: grid; gap: 14px; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); }
  .phone-card {
    display: flex; flex-direction: column; gap: 4px; padding: 18px 20px;
    background: var(--gray); border: 1px solid var(--border); border-radius: 6px;
    text-decoration: none; transition: all 0.2s var(--ease);
  }
  .phone-card:hover { background: var(--white); border-color: var(--black); transform: translateY(-1px); }
  .phone-city { font-size: 11px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--red); }
  .phone-num { font-family: var(--font-display); font-size: 22px; font-weight: 700; color: var(--black); }
  .phone-zones { font-size: 12px; color: var(--muted); margin-top: 4px; }

  .coverage-note { padding: 56px 0 96px; border-top: 1px solid var(--border); }
  .note-grid { display: grid; gap: 32px; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); }
  .note-grid h3 { font-size: 15px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--red); margin: 0 0 14px; }
  .note-grid p { font-size: 15px; line-height: 1.7; color: var(--text); }
  .note-grid a { color: var(--red); }
</style>
