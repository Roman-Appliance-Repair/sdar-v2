---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair"
    headlineCity="Chino Hills, CA"
    subheadline="Same-day service throughout Butterfield Ranch, Rolling Ridge, Eucalyptus Hills, Carbon Canyon, and all Chino Hills neighborhoods. Hard water specialists. All brands, OEM parts."
    zips={zips}
    tier={2}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance Repair in Chino Hills — What's Different Here"
    paragraphs={introParagraphs}
    bookingTitle="Chino Hills Service"
    bookingSub="91709 · Hard water specialists · Same-day"
  />

  <ServicesGrid
    cityName={cityName}
    headline="What We Repair in Chino Hills"
    services={services}
  />

  <CustomNarrative
    headline={hardWaterNarrative.headline}
    paragraphs={hardWaterNarrative.paragraphs}
    subSections={hardWaterNarrative.subSections}
    background="white"
  />

  <ServiceArea
    cityName={cityName}
    headline="Neighborhoods We Service in Chino Hills"
    subheadline="From Butterfield Ranch to Los Serranos, the canyon roads off Carbon Canyon, and the newer developments along Chino Hills Parkway. No travel surcharge anywhere in 91709."
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={[]}
  />

  <CustomNarrative
    headline={housingStockNarrative.headline}
    paragraphs={housingStockNarrative.paragraphs}
    subSections={housingStockNarrative.subSections}
    background="gray"
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Repairs in Chino Hills"
    jobs={recentJobs}
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="Why Chino Hills Residents Call Us"
    reasons={whyReasons}
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What Chino Hills Clients Say"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Typical Repair Pricing in Chino Hills"
    subhead="Every repair is different. The $89 diagnostic fee is applied when you proceed. These are typical ranges for common calls in this market."
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
