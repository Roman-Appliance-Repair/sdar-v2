---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import CustomNarrative from '../components/cities/v2/CustomNarrative.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES, MAIN_PHONE, isPlaceholderPhone } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

const citySlug = 'chino-hills';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = 'Chino Hills';
const zips = ['91709'];

const phone = isPlaceholderPhone(branch.phone) ? MAIN_PHONE : branch.phone;
const phoneRaw = `+1${phone.replace(/\D/g, '')}`;

const title = `Appliance Repair Chino Hills CA — Same Day | All Brands | ${phone}`;
const description = `Same-day appliance repair in Chino Hills 91709. Refrigerator, washer, dryer, oven, dishwasher & more. Hard water specialists. Samsung, LG, Bosch, Sub-Zero. Licensed. Call ${phone}.`;
const canonical = 'https://samedayappliance.repair/chino-hills/';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { '@type': 'City', name: 'Chino Hills', sameAs: 'https://en.wikipedia.org/wiki/Chino_Hills,_California' },
    { '@type': 'Place', name: 'Butterfield Ranch' },
    { '@type': 'Place', name: 'Rolling Ridge' },
    { '@type': 'Place', name: 'Eucalyptus Hills' },
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$',
  license: 'CA CSLB #1138898',
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.6',
    reviewCount: '37',
    bestRating: '5',
  },
};

const introParagraphs = [
  "Chino Hills is one of the cleaner, quieter calls we make in San Bernardino County. The city is mostly planned residential — newer homes, well-maintained HOA communities, a mix of mid-range Samsung and LG alongside some genuinely high-end Sub-Zero and Wolf kitchens in the hillside estates. The homes are newer than most of what we service in the Inland Empire, which means the appliances are in that 8–15 year window where things start to go wrong.",
  "The one thing that surprises first-time customers here: hard water. Chino Hills gets its water supply through a combination of MWD imported water and local groundwater, and the hardness levels are consistently high. This affects appliances in specific ways. Dishwashers scale up faster than anywhere on the Westside. Ice makers clog with mineral deposits. Washing machines develop scale buildup in the drum and door gasket. We see more hard water-related calls in Chino Hills and the broader San Bernardino County corridor than anywhere else we service — including coastal cities.",
  "The hillside geography matters too. Homes in Eucalyptus Hills, Carbon Canyon, and the elevated streets off Chino Hills Parkway sit higher than the valley floor. Santa Ana wind events move through the canyons here with real force, carrying fine particulate. Condenser coils on refrigerators and wine coolers in homes near the canyon ridges clog noticeably faster. And outdoor kitchens — which are common in the nicer properties here — need more frequent service than indoor appliances exposed to SoCal's mild-but-dusty climate.",
  `We dispatch to Chino Hills with same-day availability throughout ZIP 91709. Call us at <a href="tel:${phoneRaw}">${phone}</a>.`,
];

const services = [
  { icon: '❄️', name: 'Refrigerator Repair', slug: 'refrigerator' },
  { icon: '🌀', name: 'Washer Repair', slug: 'washer' },
  { icon: '💨', name: 'Dryer Repair', slug: 'dryer' },
  { icon: '🔥', name: 'Oven & Range Repair', slug: 'oven' },
  { icon: '🫧', name: 'Dishwasher Repair', slug: 'dishwasher' },
  { icon: '🍳', name: 'Stove & Cooktop Repair', slug: 'cooktop' },
  { icon: '🍷', name: 'Wine Cooler Repair', slug: 'wine-cooler' },
  { icon: '🧊', name: 'Outdoor Refrigerator', slug: 'freezer' },
