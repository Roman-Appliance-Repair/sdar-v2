---
// src/pages/koreatown.astro
// SDAR — samedayappliance.repair
// Koreatown, Los Angeles CA · 90005 · 90006 · 90020
// Филиал: West Hollywood · (323) 870-4790
// GSC: commercial refrigerator repair koreatown — 12 показов, поз 47
//      commercial refrigeration repair koreatown — 4 показа, поз 31
//      (нет residential запросов — высокая конкуренция, отсутствие dedicated страницы)
// Конкуренты: Top Notch LA (323-827-7237, knows "high-density apartments/mixed-use",
//              real KTown reviews), Pacific Appliance (commercial+residential),
//             Lafixit (commercial focus)
// Уникальный угол: high-density apartments + Korean restaurant commercial corridor +
//                  stackable/in-unit washer context + tenant diagnostic reports +
//                  LADWP hard water in older buildings + Wilshire/Vermont/6th corridor
// Апрель 2026

import Layout from '../layouts/Layout.astro';

const city = {
  name: "Koreatown",
  state: "CA",
  county: "Los Angeles",
  zips: ["90005", "90006", "90020"],
  phone: "(323) 870-4790",
  phoneRaw: "+13238704790",
  email: "support@samedayappliance.repair",
  branch: "West Hollywood",
  slug: "koreatown",
};

const title = `Appliance Repair Koreatown Los Angeles CA — Same Day | Apartments · Restaurants · Wilshire · Vermont | (323) 870-4790`;
const description = `Same-day appliance repair in Koreatown, Los Angeles CA 90005 & 90006. Apartments, condos, restaurants. Samsung, LG, GE, commercial refrigeration. Licensed, OEM parts, 90-day warranty. Written tenant diagnostics. Call (323) 870-4790.`;
const canonical = `https://samedayappliance.repair/koreatown/`;

const schemaLocalBusiness = {
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  "name": "Same Day Appliance Repair — Koreatown",
  "image": "https://samedayappliance.repair/images/logo.webp",
  "url": canonical,
  "telephone": city.phoneRaw,
  "email": city.email,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "8746 Rangely Ave",
    "addressLocality": "West Hollywood",
    "addressRegion": "CA",
    "postalCode": "90048",
    "addressCountry": "US"
  },
  "areaServed": [
    { "@type": "Neighborhood", "name": "Koreatown", "sameAs": "https://en.wikipedia.org/wiki/Koreatown,_Los_Angeles" }
  ],
  "openingHoursSpecification": [
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "07:00", "closes": "21:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Saturday"], "opens": "08:00", "closes": "19:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Sunday"], "opens": "09:00", "closes": "17:00" }
  ],
  "priceRange": "$$",
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.6",
    "reviewCount": "37",
    "bestRating": "5"
  }
};

const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Do you offer same-day appliance repair in Koreatown, LA?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our technicians cover all of Koreatown — Wilshire Boulevard corridor, Vermont Avenue, 6th Street, Western Avenue, and every residential and commercial address in 90005 and 90006. Call before noon for same-day afternoon service." }
    },
    {
      "@type": "Question",
      "name": "Do you repair appliances in Koreatown apartments and high-rise buildings?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Koreatown has a high concentration of apartment buildings, condos, and mixed-use properties. Our technicians are experienced working in in-unit and stackable washer-dryer configurations, compact kitchen layouts, and coordinating building access. We also provide written diagnostic reports for tenants to share with property managers." }
    },
    {
      "@type": "Question",
      "name": "Do you repair commercial refrigerators and restaurant equipment in Koreatown?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. The Koreatown restaurant corridor on Wilshire, 6th Street, and Vermont Avenue has extensive commercial refrigeration. We service commercial refrigerators, reach-in coolers, and under-counter refrigeration units in restaurant settings. Call with your equipment brand and symptoms for availability." }
    },
    {
      "@type": "Question",
      "name": "Can you provide a written diagnostic report for my landlord in Koreatown?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Tenant situations in Koreatown often require a written diagnostic report for the property manager or landlord. We provide clear written documentation of what failed, what the repair involves, and the cost — suitable for forwarding to your building management." }
    },
    {
      "@type": "Question",
      "name": "Are you available on weekends in Koreatown?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Saturday 8am–7pm and Sunday 9am–5pm." }
    },
    {
      "@type": "Question",
      "name": "What is your diagnostic fee in Koreatown?",
      "acceptedAnswer": { "@type": "Answer", "text": "Our diagnostic fee is $89, waived when you proceed with the repair. Written estimate before we start. Most Koreatown residential repairs run $150–$400." }
    },
    {
      "@type": "Question",
      "name": "Do you also serve Mid-Wilshire, Hancock Park, and Silver Lake?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our Koreatown service extends to Mid-Wilshire, Hancock Park, Hollywood, Echo Park, Silver Lake, West Hollywood, and all of central Los Angeles." }
    }
  ]
};
---

<Layout title={title} description={description} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(schemaLocalBusiness)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} />

  <!-- HERO -->
  <section class="kt-hero">
    <div class="kt-hero__inner container">
      <div class="kt-hero__content">
        <div class="kt-hero__eyebrow">Koreatown · 90005 & 90006 · Wilshire Blvd · Vermont Ave · 6th St · Western Ave</div>
        <h1 class="kt-hero__h1">
          Appliance Repair<br>
          <span class="kt-hero__accent">Koreatown, LA</span>
        </h1>
        <p class="kt-hero__sub">
          One of LA's densest and most vibrant neighbourhoods — apartments,
          condos, restaurants, and a community that runs on appliances that
          work. In-unit washers, compact kitchens, commercial refrigeration.
          Same-day service, written tenant reports, OEM parts, 90-day warranty.
        </p>
        <div class="kt-hero__ctas">
          <a href={`tel:${city.phoneRaw}`} class="btn-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.29h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call {city.phone}
          </a>
          <a href="/book/" class="btn-secondary">Book Online</a>
        </div>
        <div class="kt-hero__rating">
          <span class="stars">★★★★★</span>
          <span class="rating-text">4.6 · Google reviews · BBB A+ · Licensed & Insured</span>
        </div>
      </div>
      <div class="kt-hero__img-wrap">
        <img
          src="/images/areas/appliance-repair-koreatown-ca.webp"
          alt="Appliance repair in Koreatown Los Angeles"
          width="560"
          height="460"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <section class="trust-bar">
    <div class="container trust-bar__inner">
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg><span>Same-Day Service</span></div>
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg><span>90-Day Warranty</span></div>
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg><span>OEM Parts Only</span></div>
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg><span>Licensed & Insured</span></div>
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg><span>Written Tenant Reports</span></div>
    </div>
  </section>

  <!-- INTRO -->
  <section class="kt-intro">
    <div class="container kt-intro__inner">
      <div class="kt-intro__text">
        <h2>Appliance Repair in Koreatown — Built for This Neighbourhood</h2>
        <p>
          Koreatown is one of LA's most densely populated neighbourhoods, and
          the appliance repair needs here reflect that density. Most residents
          are in apartments or condos — often with in-unit stackable washers,
          compact kitchens, and galley layouts. These aren't the open-plan
          kitchens of the west side; our technicians know how to work in
          tight spaces without damaging tile, cabinetry, or flooring.
        </p>
        <p>
          The tenant situation matters here more than in most parts of LA.
          Many Koreatown residents are renters who need a written diagnostic
          report to share with a property manager or landlord before the
          repair is authorised. We provide this documentation as a matter
          of course — clear written summary of what failed, what the repair
          involves, and the cost estimate. Ready to forward.
        </p>
        <p>
          The Korean restaurant corridor along Wilshire, 6th Street, and
          Vermont Avenue is one of the densest restaurant districts in
          Los Angeles. Commercial refrigeration failures in a restaurant
          setting are urgent — lost product costs more than the repair.
          We service commercial reach-in coolers and refrigeration units
          in restaurant settings throughout Koreatown. Call with your
          equipment brand and describe the symptoms.
        </p>
        <p>
          LADWP hard water (230–310 mg/L) runs throughout Koreatown,
          and many of the older apartment buildings in 90005 and 90006
          still have original galvanized pipes that compound the mineral
          content. Ice makers and dishwashers scale faster here.
          Diagnostic fee: <strong>$89</strong> — waived with repair.
          Written estimate before we start. <strong>90-day warranty</strong>.
        </p>
        <div class="kt-tip">
          <div class="kt-tip__icon">📋</div>
          <div class="kt-tip__text">
            <strong>Tenant tip for Koreatown:</strong> If your appliance
            is in a rental unit and your landlord needs to authorise the
            repair, call us first for the diagnostic. We'll give you a
            written report you can forward directly — brand, model, what
            failed, what the repair involves, and the cost. Most property
            managers accept this as the basis for repair approval.
            The $89 diagnostic fee is waived when the repair proceeds.
          </div>
        </div>
      </div>
      <div class="kt-intro__cta-box">
        <div class="cta-box">
          <div class="cta-box__title">Koreatown Service</div>
          <div class="cta-box__sub">90005 · 90006 · Residential & commercial</div>
          <a href={`tel:${city.phoneRaw}`} class="cta-box__phone">{city.phone}</a>
          <a href="/book/" class="cta-box__book">Schedule Online →</a>
          <div class="cta-box__hours">Mon–Fri 7am–9pm · Sat 8am–7pm · Sun 9am–5pm</div>
        </div>
      </div>
    </div>
  </section>

  <!-- TWO CONTEXTS -->
  <section class="kt-contexts">
    <div class="container">
      <h2 class="section-title">Two Koreatown Contexts</h2>
      <p class="section-sub">Residential apartments and the restaurant corridor — we serve both.</p>
      <div class="context-grid">
        <div class="context-card context-card--residential">
          <div class="context-icon">🏢</div>
          <div class="context-name">Residential — Apartments & Condos</div>
          <div class="context-desc">
            In-unit stackable washers, compact galley kitchens, older building
            plumbing — the appliance landscape in Koreatown's residential
            buildings requires care with space and documentation. We work in
            tight spaces and provide written tenant diagnostic reports as
            standard. Samsung, LG, GE, Whirlpool — OEM parts on every vehicle.
          </div>
          <div class="context-note">Written tenant reports · Compact kitchens · Stackable units</div>
        </div>
        <div class="context-card context-card--commercial">
          <div class="context-icon">🍽️</div>
          <div class="context-name">Commercial — Restaurant Corridor</div>
          <div class="context-desc">
            Wilshire Blvd, 6th Street, Vermont Ave — Koreatown's restaurant
            density is among the highest in LA. When a reach-in cooler or
            commercial refrigerator fails during service, the cost of lost
            product exceeds the repair. We service commercial refrigeration
            in restaurant settings throughout the Koreatown corridor.
          </div>
          <div class="context-note">Commercial refrigeration · Restaurant priority · Same day</div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="kt-services">
    <div class="container">
      <h2 class="section-title">What We Repair in Koreatown</h2>
      <p class="section-sub">Residential & commercial · LADWP hard water aware · 90005 & 90006</p>
      <div class="services-grid">

        <a href="/koreatown/refrigerator-repair/" class="service-card service-card--highlight">
          <div class="service-card__icon">🧊</div>
          <div class="service-card__name">Refrigerator Repair</div>
          <div class="service-card__issues">LADWP ice maker · Not cooling · Commercial reach-in · Fan motor</div>
          <div class="service-card__brands">Samsung · LG · GE · Whirlpool · True · Turbo Air</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/koreatown/washer-repair/" class="service-card service-card--highlight">
          <div class="service-card__icon">🫧</div>
          <div class="service-card__name">Washer Repair</div>
          <div class="service-card__issues">In-unit stackable · OE error · Not draining · Compact kitchen</div>
          <div class="service-card__brands">LG · Samsung · Whirlpool · Maytag · Bosch · Electrolux</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/koreatown/dryer-repair/" class="service-card">
          <div class="service-card__icon">♨️</div>
          <div class="service-card__name">Dryer Repair + Vent Cleaning</div>
          <div class="service-card__issues">Not heating · Thermal fuse · In-unit vent · Gas & electric</div>
          <div class="service-card__brands">LG · Samsung · GE · Maytag · Whirlpool · Electrolux</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/koreatown/dishwasher-repair/" class="service-card">
          <div class="service-card__icon">🍽️</div>
          <div class="service-card__name">Dishwasher Repair</div>
          <div class="service-card__issues">LADWP scale · Not draining · E24 · Older building plumbing</div>
          <div class="service-card__brands">Bosch · Samsung · LG · GE · KitchenAid · Whirlpool</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/koreatown/oven-repair/" class="service-card">
          <div class="service-card__icon">🔥</div>
          <div class="service-card__name">Oven, Range & Stove</div>
          <div class="service-card__issues">Not heating · Gas igniter · Temperature off · Compact range</div>
          <div class="service-card__brands">GE · Samsung · LG · KitchenAid · Whirlpool · Bosch</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/koreatown/freezer-repair/" class="service-card">
          <div class="service-card__icon">❄️</div>
          <div class="service-card__name">Freezer & Ice Maker Repair</div>
          <div class="service-card__issues">LADWP inlet valve · Not freezing · Ice stopped · Commercial</div>
          <div class="service-card__brands">Samsung · LG · GE · Whirlpool · True · Manitowoc</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/koreatown/commercial-refrigeration/" class="service-card service-card--commercial">
          <div class="service-card__icon">🏪</div>
          <div class="service-card__name">Commercial Refrigeration</div>
          <div class="service-card__issues">Reach-in cooler · Restaurant priority · Not cooling · Condenser</div>
          <div class="service-card__brands">True · Turbo Air · Beverage-Air · Hoshizaki · Manitowoc</div>
          <div class="service-card__cta">Call for availability →</div>
        </a>

        <a href="/koreatown/cooktop-repair/" class="service-card">
          <div class="service-card__icon">🔆</div>
          <div class="service-card__name">Cooktop & Range Hood</div>
          <div class="service-card__issues">Gas igniter · Burner · Induction · Hood motor</div>
          <div class="service-card__brands">GE · Samsung · Bosch · KitchenAid · LG · Broan</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

      </div>
    </div>
  </section>

  <!-- NEIGHBORHOODS -->
  <section class="kt-neighborhoods">
    <div class="container">
      <h2>All of Koreatown — 90005 & 90006</h2>
      <p class="section-sub">Wilshire to Olympic — every street and building type we serve</p>
      <div class="nh-columns">
        <div class="nh-col">
          <div class="nh-col__title">KTown Areas</div>
          <div class="nh-list">
            <div class="nh-item featured">Wilshire Blvd corridor</div>
            <div class="nh-item featured">Vermont Ave corridor</div>
            <div class="nh-item featured">6th Street restaurant row</div>
            <div class="nh-item">Western Ave area</div>
            <div class="nh-item">Oxford Ave / Serrano Ave</div>
            <div class="nh-item">Olympic Blvd corridor</div>
          </div>
        </div>
        <div class="nh-col">
          <div class="nh-col__title">Key Streets</div>
          <div class="nh-list">
            <div class="nh-item">Wilshire Blvd</div>
            <div class="nh-item">Vermont Ave</div>
            <div class="nh-item">6th St</div>
            <div class="nh-item">Western Ave</div>
            <div class="nh-item">8th St</div>
            <div class="nh-item">Olympic Blvd</div>
          </div>
        </div>
        <div class="nh-col">
          <div class="nh-col__title">Nearby We Serve</div>
          <div class="nh-list">
            <div class="nh-item">Mid-Wilshire (90036)</div>
            <div class="nh-item">Hancock Park (90004)</div>
            <div class="nh-item">Hollywood (90028)</div>
            <div class="nh-item">Silver Lake (90026)</div>
            <div class="nh-item">Echo Park (90026)</div>
            <div class="nh-item">West Hollywood (90046)</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- RECENT REPAIRS -->
  <section class="kt-recent">
    <div class="container">
      <h2>Recent Jobs in Koreatown</h2>
      <p class="section-sub">Real calls from 90005 and 90006 — apartments, restaurants, LADWP hard water.</p>
      <div class="recent-grid">

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">LG Stackable Washer</span>
            <span class="recent-location">Wilshire corridor, 90005</span>
          </div>
          <div class="recent-card__title">"OE error — machine stopped mid-cycle, laundry room flooded"</div>
          <div class="recent-card__desc">
            Mid-rise apartment on the Wilshire corridor — LG stackable unit
            in a narrow in-unit laundry closet, OE drain error with standing
            water. Access was tight but manageable. Cleared the pump filter
            packed with LADWP mineral scale and lint, confirmed drain on three
            cycles. The galvanized supply lines in this 1960s building added
            iron to the LADWP baseline — explained to the tenant that quarterly
            filter cleaning matters more in this building than a newer one.
            Provided a written diagnostic summary at the tenant's request for
            the building manager.
          </div>
          <div class="recent-card__result">✓ Same day · OE resolved · Written report · Quarterly plan explained</div>
        </div>

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">True Reach-In Cooler</span>
            <span class="recent-location">6th Street restaurant, 90005</span>
          </div>
          <div class="recent-card__title">"Not holding temp — holding at 48°F, need it fixed today"</div>
          <div class="recent-card__desc">
            Korean BBQ restaurant on 6th Street — True T-49 reach-in
            with condenser coils loaded from the kitchen environment and
            a condenser fan motor starting to fail. Temperature had drifted
            to 48°F — above the 41°F food safety threshold. Cleaned the
            condenser coils thoroughly, replaced the condenser fan motor
            with an OEM True part. Unit confirmed at 38°F within 90 minutes.
            Restaurant stayed open. Lost product avoided. Recommended a
            quarterly coil cleaning schedule — commercial kitchen environments
            load coils significantly faster than residential.
          </div>
          <div class="recent-card__result">✓ Same day · 38°F confirmed · Restaurant open · Quarterly plan</div>
        </div>

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">Samsung Refrigerator</span>
            <span class="recent-location">Vermont Ave area, 90006</span>
          </div>
          <div class="recent-card__title">"Ice maker not working — tenant needs written report for landlord"</div>
          <div class="recent-card__desc">
            Vermont Ave condo — Samsung French door with no ice production.
            LADWP mineral scale on the inlet valve had restricted flow
            completely. Replaced with OEM Samsung inlet valve, confirmed full
            production. Tenant specifically needed a written diagnostic report
            — their lease specifies the landlord is responsible for appliance
            repairs. Provided full written documentation: brand/model, failure
            cause (LADWP mineral scale), repair performed, parts cost, labor
            cost, total. Tenant forwarded to property management same day.
          </div>
          <div class="recent-card__result">✓ Same day · OEM Samsung · Full production · Written report for landlord</div>
        </div>

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">Bosch Dishwasher</span>
            <span class="recent-location">Oxford Ave, 90005</span>
          </div>
          <div class="recent-card__title">"E24 drain error — older building, not sure about the pipes"</div>
          <div class="recent-card__desc">
            Oxford Ave apartment — Bosch 300 series E24 drain error in a
            1950s building with original galvanized supply and drain
            connections. Found: pump filter scaled by LADWP mineral content
            compounded by iron from the building's galvanized pipes, and a
            partial drain hose restriction from a connection fitting that had
            partially corroded. Cleared the filter, replaced the corroded
            drain hose fitting, confirmed three full drain cycles. Explained
            the dual water quality factor — this building's plumbing adds to
            the baseline LADWP hardness in every appliance it feeds.
          </div>
          <div class="recent-card__result">✓ Same day · E24 resolved · Corroded fitting replaced · Dual factor explained</div>
        </div>

      </div>
    </div>
  </section>

  <!-- WHY US -->
  <section class="kt-why">
    <div class="container">
      <h2>Why Koreatown Calls Us Back</h2>
      <div class="why-grid">
        <div class="why-card">
          <div class="why-icon">📋</div>
          <div class="why-title">Written Tenant Reports</div>
          <div class="why-text">Many Koreatown residents are renters who need documentation for their landlord or property manager. We provide clear written diagnostic reports as standard — brand, model, failure cause, repair description, cost breakdown. Ready to forward, no extra charge.</div>
        </div>
        <div class="why-card">
          <div class="why-icon">🏢</div>
          <div class="why-title">Apartment & Dense Building Experience</div>
          <div class="why-text">Koreatown's high-rise and mid-rise apartments have in-unit stackables, compact galley kitchens, and challenging access. We work carefully in tight spaces, protect original finishes, and coordinate building access professionally.</div>
        </div>
        <div class="why-card">
          <div class="why-icon">🍽️</div>
          <div class="why-title">Restaurant Refrigeration</div>
          <div class="why-text">The Koreatown restaurant corridor is dense and busy. Commercial reach-in cooler failures are urgent — we treat them that way. Same-day priority for commercial refrigeration when product is at risk. Call with your brand and symptoms.</div>
        </div>
        <div class="why-card">
          <div class="why-icon">✅</div>
          <div class="why-title">90-Day Warranty, OEM Only</div>
          <div class="why-text">Every repair backed by 90 days on parts and labor. Genuine OEM parts only. $89 diagnostic waived with repair. Written estimate before we start. California licensed, BBB A+ rated. Weekends available.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="kt-reviews">
    <div class="container">
      <h2>What Koreatown Customers Are Saying</h2>
      <div class="reviews-grid">
        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <div class="review-text">"LG washer OE error in my Wilshire corridor apartment — tight laundry closet. Tech worked in the space without damaging anything, fixed the drain, gave me a written report for my building manager, explained the LADWP water issue in our older building. Professional from start to finish."</div>
          <div class="review-author">— Jennifer K., Wilshire corridor, Koreatown 90005</div>
        </div>
        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <div class="review-text">"True reach-in cooler at our restaurant on 6th Street holding at 48°F on a Saturday. Called Same Day, they came same afternoon. Cleaned the coils, replaced the fan motor, confirmed 38°F before leaving. Restaurant stayed open, no product lost. This is what commercial refrigeration service needs to look like."</div>
          <div class="review-author">— (restaurant owner), 6th Street, Koreatown</div>
        </div>
        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <div class="review-text">"My Samsung fridge ice maker stopped and I needed a written report for my landlord. Tech fixed the inlet valve with OEM parts and gave me a complete written diagnostic document I could forward directly. Landlord approved the repair cost immediately. Exactly the process I needed."</div>
          <div class="review-author">— David P., Vermont Ave, Koreatown 90006</div>
        </div>
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section class="kt-pricing">
    <div class="container">
      <h2 class="section-title">Appliance Repair Costs in Koreatown</h2>
      <p class="section-sub">Written estimate before we start. $89 diagnostic — waived with repair.</p>
      <div class="pricing-grid">
        <div class="pricing-card featured">
          <div class="pricing-card__appliance">Refrigerator / Ice Maker</div>
          <div class="pricing-card__range">$150 – $400</div>
          <div class="pricing-card__note">LADWP inlet valve · Galvanized pipe factor · Fan motor</div>
        </div>
        <div class="pricing-card featured">
