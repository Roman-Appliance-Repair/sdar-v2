<CityLayout
  title={title}
  description={description}
  canonical={canonical}
  branchSlug={branchSlug}
>
  <script type="application/ld+json" slot="head-scripts" set:html={JSON.stringify(localBusinessSchema)} />

  <HeroEditorial
    eyebrow="Los Angeles, CA · Westside · Mid-City · Koreatown · Downtown"
    headlineMain="Appliance repair in"
    headlineAccent="Los Angeles, CA"
    subheadline="Same-day service on every major appliance across LA. Sub-Zero, Viking, Wolf, Samsung, LG, GE — plus wine cellar cooling units. OEM parts, 90-day warranty, $89 diagnostic — waived with repair."
    branchSlug={branchSlug}
  />
  <TrustBar />

  <CustomNarrative
    number="01"
    eyebrow="A varied repair market"
    headline="Los Angeles has every kind of"
    headlineAccent="appliance problem"
    paragraphs={introParagraphs}
  />

  <RepairGrid
    number="02"
    eyebrow="Capabilities"
    headline="Appliance repair services in"
    headlineAccent="Los Angeles"
    subheadline="Residential. All major brands. Same-day availability across LA."
    services={services}
    cardStructure="2-tier"
  />

  <BrandedExpertiseLosAngeles number="03" />

  <NeighborhoodGrid
    number="04"
    eyebrow="Service Area"
    headline="Los Angeles neighborhoods"
    headlineAccent="we serve"
