  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Los Angeles Has Every Kind of Appliance Problem"
    paragraphs={introParagraphs}
    bookingTitle="Los Angeles"
    bookingSub="Available Today"
  />

