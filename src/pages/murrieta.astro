---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import CustomNarrative from '../components/cities/v2/CustomNarrative.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES, MAIN_PHONE, isPlaceholderPhone } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

const citySlug = 'murrieta';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = 'Murrieta';
const zips = ['92562', '92563'];

const phone = branch.phone;
const phoneRaw = `+1${phone.replace(/\D/g, '')}`;

const title = `Appliance Repair Murrieta CA — Same Day | All Brands | ${phone}`;
const description = `Same-day appliance repair in Murrieta. Greer Ranch, California Oaks, French Valley. Licensed. OEM parts.`;
const canonical = 'https://samedayappliance.repair/murrieta/';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { '@type': 'City', name: 'Murrieta' }
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$',
  license: 'BHGS #A49573'

};

const introParagraphs = [
  "Murrieta is one of the fastest-growing cities in California, and that growth pattern shows up directly in our call volume. The city was largely built between 2000 and 2018 — Toll Brothers, Lennar, KB Homes — and the appliances installed in those homes are hitting the 8–15 year mark right now. That's exactly when builder-grade Samsung, LG, Whirlpool, and GE appliances start to fail. Ice maker components wear out. Washer bearings go. Refrigerator evaporator fans seize. LG linear inverter start relays fail. We see this timeline play out across Greer Ranch, California Oaks, French Valley, and every other Murrieta master-planned community on a predictable schedule.",
  "The climate compounds it. Murrieta summers run 95–105°F with low humidity and dusty inland air. Condenser coils on refrigerators and freezers load up faster than in coastal climates. Dryer vent runs in the tract homes here are often long — 15 to 25 feet through interior walls — and lint builds up quickly. We clear partial vent blockages on a large share of every dryer call we make in this city.",
  "Hard water is also a factor. Riverside County water is consistently high in dissolved minerals, and we include descaling as part of every dishwasher and ice maker repair call in Murrieta. A dishwasher filter cleaning here should happen every three months, not annually. Most people never do it — and then wonder why their machine stopped draining.",
  `Same-day coverage throughout 92562 and 92563, including the French Valley area and the Temecula border neighborhoods. Call us at <a href="tel:${phoneRaw}">${phone}</a>.`
];

const services = [
  { icon: '❄️', name: 'Refrigerator Repair', slug: 'refrigerator' },
  { icon: '🌀', name: 'Washer Repair', slug: 'washer' },
  { icon: '💨', name: 'Dryer Repair', slug: 'dryer' },
  { icon: '🔥', name: 'Oven & Range Repair', slug: 'oven' },
  { icon: '🫧', name: 'Dishwasher Repair', slug: 'dishwasher' },
  { icon: '🍳', name: 'Stove & Cooktop Repair', slug: 'stove' },
  { icon: '🧊', name: 'Freezer Repair', slug: 'freezer' },
  { icon: '🧊', name: 'Ice Maker Repair', slug: 'ice-maker' }
];

const murrietaContextNarrative = {
  headline: "Murrieta's Appliance Failure Window — What's Happening Right Now",
  subSections: [
    {
      title: 'Builder-Grade Appliances: What Was Installed and When It Fails',
      paragraphs: [
        "Murrieta's growth timeline creates a specific service pattern. Most of the city was built in two waves: 2000–2008 and 2010–2018. The appliances in those homes are now 7–20 years old — squarely in the window where first and second major failures happen.",
        "Tract home builders in Murrieta — Toll Brothers, Lennar, KB Homes, William Lyon — installed primarily mid-range Samsung, LG, Whirlpool, and GE appliances as standard equipment. These are solid machines, but they're not built for a 20-year lifespan without maintenance. The 7–12 year range is when we see the most calls: ice maker component wear, front-load washer bearing failure, refrigerator evaporator fan seizure, and dishwasher pump assembly wear.",
        "The question we get often is whether to repair or replace. Our honest answer for most 8–12 year old appliances in otherwise good working order: repair. A $180 washer bearing repair on a machine that's structurally sound is better economics than a $900 replacement. The exception is when the compressor on a refrigerator is failing — that repair cost versus replacement value math changes significantly on older units. We give you the numbers after diagnosis and let you decide."
      ]
    },
    {
      title: 'LG Linear Inverter Compressor — Know Your Model',
      paragraphs: [
        "Murrieta has a high concentration of LG French-door and side-by-side refrigerators from 2012–2019 — this generation used the linear inverter compressor that was the subject of a class-action settlement. If your LG refrigerator is clicking and not cooling, test the start relay before assuming the compressor is gone. The relay is an $18 part. A compressor replacement on these models runs $400–$600. They present identically. We test both on every LG refrigerator call.",
        "If your LG refrigerator is within the class-action date range (certain models manufactured 2014–2017), you may be entitled to free repair or a prorated refund. We walk customers through this process on every qualifying call — it's worth checking before you pay out of pocket."
      ]
    },
    {
      title: 'Samsung French-Door Ice Maker — Common Failures in This Climate',
      paragraphs: [
        "Samsung French-door refrigerators from the 2013–2020 generation have well-documented ice maker issues. In Murrieta's inland heat, the most common failure is the ice maker fill tube freezing — caused by a freezer temperature set slightly too low combined with hard water mineral deposits in the tube. The fix is usually a fill tube clearing, ice maker mold descaling, temperature set point adjustment, and water filter replacement — not a new ice maker assembly. We find the $89–$150 fix before recommending the $280 assembly replacement."
      ]
    },
    {
      title: 'Dryer Vent Runs in Murrieta Tract Homes',
      paragraphs: [
        "Murrieta's tract homes were built with laundry rooms in interior locations — sometimes two rooms away from an exterior wall. Vent runs of 15–25 feet are standard. At that length, every 90-degree bend in the duct reduces effective flow. Add Riverside County dust and the lint accumulates fast. The recommended cleaning interval for a vent run over 15 feet is every 12 months — not every 2–3 years as most people assume. A slow dryer in Murrieta is a blocked vent until proven otherwise."
      ]
    },
    {
      title: 'Hard Water — Maintenance Schedule for Murrieta Homes',
      paragraphs: [
        "<strong>Dishwasher filter:</strong> Every 3 months — run a hot white vinegar cycle monthly<br /><strong>Refrigerator water filter:</strong> Every 4 months (not 6 — hard water saturates faster)<br /><strong>Ice maker descale:</strong> Every 12–18 months, sooner if cubes turn cloudy<br /><strong>Dryer vent:</strong> Every 12 months for runs over 15 feet<br /><strong>Condenser coils:</strong> Every 6 months in Murrieta's summer heat<br /><strong>Washing machine drum clean:</strong> Monthly with cleaner tablet"
      ]
    }
  ]
};

const neighborhoods = [
  { name: 'Greer Ranch', zip: '92562' },
  { name: 'California Oaks', zip: '92562' },
  { name: 'Copper Canyon', zip: '92562' },
  { name: 'French Valley', zip: '92563' },
  { name: 'Murrieta Hot Springs', zip: '92563' },
  { name: 'Los Alamos Hills', zip: '92563' },
  { name: 'Alta Murrieta', zip: '92562' },
  { name: 'Town Gate', zip: '92562' },
  { name: 'Central Murrieta', zip: '92562' },
  { name: 'Nighthawk', zip: '92562' },
  { name: 'Mapleton', zip: '92563' },
  { name: 'South Murrieta / Temecula Border', zip: '92562' }
];

const recentJobs = [
  {
    appliance: 'Samsung RS28A500ASR',
    location: 'California Oaks, 92562',
    quote: 'warm fridge, freezer fine, built 2014',
    description: 'Ten-year-old Samsung side-by-side, freezer holding temperature fine, fridge section at 58°F. This is a classic evaporator fan failure pattern — the fridge and freezer share one evaporator but the fan distributes cold air to the fridge section. Fan motor had seized. On a 2014 Samsung in this climate, bearing wear from a decade of inland heat cycling is the usual cause. Replaced the OEM evaporator fan motor, defrosted the partially iced coils, confirmed 38°F stability. Customer had been quoted a full refrigerant recharge by another company — wrong diagnosis entirely.',
    outcome: '✓ Warm fridge, cold freezer almost never means refrigerant. Check the evaporator fan first.'
  },
  {
    appliance: 'Whirlpool WFW9620HC',
    location: 'Greer Ranch, 92562',
    quote: 'F5 E2 lid lock error, 6 years old',
    description: "Front-load Whirlpool showing F5 E2 — door lock error. On this generation of Whirlpool front-loaders, F5 E2 is frequently caused by a door latch striker that's worn down slightly over years of use, not an actual lock failure. The latch tab had worn enough that the door sensor wasn't registering a full close. Replaced the door latch assembly with an OEM Whirlpool part — $85 part, about 45 minutes labor. Customer had been told by the manufacturer's service line it needed a new door lock module at $260.",
    outcome: "✓ Door latch wear is mechanical, not electrical. It presents as a lock error but it's a $85 fix, not a $260 one."
  },
  {
    appliance: 'LG LFXS26973S',
    location: 'French Valley, 92563',
    quote: 'loud clicking on startup, not cooling',
    description: '2016 LG French-door, clicking compressor, not cooling. Exactly the start relay failure pattern common in this LG linear inverter generation. Tested the relay — confirmed open circuit failure. Replaced the start relay ($18 part), let the unit run for 30 minutes in our presence, confirmed normal compressor startup and cooling. Total repair: $89 diagnostic + $95 labor and parts. Another company had quoted a compressor replacement at $580. The customer had already spent a week without a refrigerator waiting for that quote.',
    outcome: '✓ LG linear inverter compressor clicking = test the start relay first. Every time.'
  },
  {
    appliance: 'GE Profile PYD22KBLTS',
    location: 'Murrieta Hot Springs, 92563',
    quote: 'ice maker not producing, water dispenser fine',
    description: "Water dispenser working, ice maker silent. Pulled the ice maker assembly — the fill tube had frozen solid, a result of the freezer temperature being set slightly too low (0°F instead of the recommended 2°F) combined with Murrieta's hard water leaving mineral deposits in the tube that accelerated ice bridging. Cleared the blockage, adjusted the freezer set point, descaled the fill tube and ice maker mold. Also replaced the water filter, which was 22 months old. Ice production restored same visit.",
    outcome: '✓ Freezer set below 0°F combined with hard water is a recipe for fill tube freezing. Keep it at 2°F.'
  }
];

const whyReasons = [
  {
    iconKey: 'parts' as const,
    title: 'We diagnose before quoting',
    body: 'The $89 fee covers a real diagnosis — not a symptom guess over the phone. An LG refrigerator clicking could be an $18 relay or a $500 compressor. We find out which before recommending anything. What we quote is what appears on the invoice.'
  },
  {
    iconKey: 'team' as const,
    title: "We know Murrieta's housing stock",
    body: "Toll Brothers Greer Ranch, Lennar California Oaks, KB Homes French Valley — we've been inside all of them. We know what was installed, when it was installed, and what fails at year 8 versus year 12. We come prepared, not guessing."
  },
  {
    iconKey: 'shield' as const,
    title: 'Honest repair vs. replace guidance',
    body: "We tell you the real economics. An 8-year-old washer with a bearing failure is almost always worth repairing. A 14-year-old refrigerator with a dying compressor might not be. We give you the numbers and let you decide — we don't push repairs that don't make sense."
  },
  {
    iconKey: 'clock' as const,
    title: 'OEM parts, not aftermarket',
    body: "Builder-grade appliances in their failure window need the right parts to last another 5–8 years. Aftermarket parts fail faster and can void remaining warranties. We source OEM for everything — it costs a little more and it's the right call."
  }
];

const testimonials = [
  {
    stars: 5,
    text: '"LG fridge in our Greer Ranch home was clicking and not cooling. Another company quoted us a $550 compressor replacement. Same Day came out, diagnosed a bad start relay, fixed it for $95 total. I can\'t believe the difference. Should have called them first."',
    author: '— Kevin M., Greer Ranch'
  },
  {
    stars: 5,
    text: '"Samsung ice maker stopped working. Tech came same day, found the fill tube was frozen and the water filter was overdue. Fixed and descaled everything in one visit. Also explained the hard water filter schedule. Very thorough."',
    author: '— Lisa & Dan R., California Oaks'
  },
  {
    stars: 4,
    text: '"Whirlpool dryer taking two cycles to dry. Tech found a partially blocked vent run — 20 feet through the interior wall. Cleared it and checked the heating element. Explained why it happens in these tract homes. Honest and fast."',
    author: '— Angela T., French Valley'
  }
];

const pricingTiers = [
  { appliance: 'Refrigerator Repair', range: '$150–$450', note: 'Compressor relay · Coil cleaning · Inlet valve · Fan motor' },
  { appliance: 'Washer Repair', range: '$140–$380', note: 'Bearing + seal set · Drain pump · Door latch · Hall sensor' },
  { appliance: 'Dryer Repair', range: '$120–$320', note: 'Thermal fuse · Heating element · Vent path' },
  { appliance: 'Dishwasher Repair', range: '$89–$360', note: 'Drain pump · Spray arm · Filter · Error codes' },
  { appliance: 'Oven / Range Repair', range: '$140–$400', note: 'Igniter · Bake element · Gas valve · Calibration' },
  { appliance: 'Ice Maker Repair', range: '$120–$280', note: 'Inlet valve · Mold descaling · Fill tube · Filter' },
  { appliance: 'Dryer Vent Cleaning', range: '$89–$140', note: 'Long runs · Lint clearance · Airflow check' },
  { appliance: 'Condenser Coil Cleaning', range: '$89–$150', note: 'Summer heat preventive · 6-month interval' }
];

const faqs = [
  {
    question: 'Do you offer same-day appliance repair in Murrieta?',
    answer: `Yes — same-day service is available throughout Murrieta including Greer Ranch, California Oaks, French Valley, Copper Canyon, and Murrieta Hot Springs. Call ${phone} before noon for same-day scheduling. We cover ZIP codes 92562 and 92563 without a trip surcharge, and service the Temecula border area without additional fees.`
  },
  {
    question: 'My appliances are only 8–10 years old — is it worth repairing them?',
    answer: "Almost always, yes. The builder-grade Samsung, LG, and Whirlpool appliances installed in Murrieta's Toll Brothers and Lennar homes between 2005 and 2015 are hitting their first major failure point right now. A $150–$280 repair on a machine that's otherwise in good shape is almost always better economics than a $900–$1,400 replacement. The exception: if the compressor on a refrigerator is failing and the unit is over 12 years old, replacement starts to make more sense. We tell you honestly which way to go after diagnosis."
  },
  {
    question: 'What brands do you repair in Murrieta?',
    answer: "All major brands. Murrieta's newer housing stock runs primarily Samsung, LG, Whirlpool, Maytag, GE, and KitchenAid — builder-grade and mid-range appliances installed by Toll Brothers, Lennar, and KB Homes. Greer Ranch and the upper end of French Valley have some Sub-Zero and Wolf. We carry OEM parts for all of these and don't use aftermarket substitutes."
  },
  {
    question: 'What is your diagnostic fee?',
    answer: '$89, applied directly to the repair cost when you proceed. No hidden trip charge to Murrieta. We quote on-site after looking at the appliance — not over the phone based on symptoms. What we quote is what appears on the invoice.'
  },
  {
    question: "Why does my dryer take forever to dry — it's only 7 years old?",
    answer: "In most Murrieta homes we service, a slow dryer comes down to one of two things: a partially blocked vent run, or a weakening heating element. Murrieta's tract homes often have long vent runs from laundry rooms through interior walls — 15 to 25 feet isn't unusual. At that length, even partial lint buildup cuts airflow significantly. We inspect both the heating element and the full vent path on every dryer call. A blocked vent is also a fire hazard, not just an inconvenience."
  },
  {
    question: "My LG refrigerator makes a clicking sound and then stops cooling — what's wrong?",
    answer: "Clicking followed by the compressor shutting off is almost always the start relay on LG models — particularly the linear inverter compressor generation built between 2012 and 2019, which are common in Murrieta's mid-2010s housing stock. The start relay is an $18 part. The compressor is $400–$600. They present with identical symptoms. We diagnose before recommending the expensive fix — and if it is the compressor, we'll tell you whether the repair makes economic sense given the unit's age."
  },
  {
    question: 'Do you service appliances in the French Valley area?',
    answer: `Yes — French Valley is within our regular Murrieta service area. No surcharge, same-day availability applies to all of ZIP 92563. Call ${phone}.`
  }
];

const nearbyCities = [
  { name: 'Temecula', slug: 'temecula' },
  { name: 'Menifee', slug: 'menifee' },
  { name: 'Lake Elsinore', slug: 'lake-elsinore' },
  { name: 'Corona', slug: 'corona' },
  { name: 'Riverside', slug: 'riverside' },
  { name: 'Chino Hills', slug: 'chino-hills' }
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair"
    headlineCity="Murrieta"
    subheadline="Same-day service in Greer Ranch, California Oaks, French Valley, Copper Canyon, Murrieta Hot Springs, and throughout the city. All brands. OEM parts. Licensed."
    zips={zips}
    tier={3}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance Repair in Murrieta — What We See Here"
    paragraphs={introParagraphs}
    bookingTitle="Murrieta"
    bookingSub="Same-Day Service"
  />

  <ServicesGrid
    cityName={cityName}
    headline="What We Repair in Murrieta"
    services={services}
  />

  <CustomNarrative
    headline={murrietaContextNarrative.headline}
    subSections={murrietaContextNarrative.subSections}
    background="white"
  />

  <ServiceArea
    cityName={cityName}
    headline="Neighborhoods We Service in Murrieta"
    subheadline="We cover all of Murrieta — from Greer Ranch and California Oaks in the west to French Valley and Murrieta Hot Springs in the east. No travel surcharge to any address in 92562 or 92563."
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={[]}
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Repairs in Murrieta"
    jobs={recentJobs}
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="Why Murrieta Residents Call Us"
    reasons={whyReasons}
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What Murrieta Customers Are Saying"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Typical Repair Pricing in Murrieta"
    subhead="Every repair is quoted on-site after diagnosis. The $89 diagnostic fee is applied when you proceed."
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="Murrieta Appliance Repair — FAQ"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby Cities"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Need Appliance Repair in Murrieta Today?"
    body="Same-day service in Greer Ranch, California Oaks, French Valley, and all of Murrieta. No trip charge to 92562 or 92563."
  />
</CityLayoutV2>
