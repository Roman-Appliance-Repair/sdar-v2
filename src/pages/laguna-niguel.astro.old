---
// src/pages/laguna-niguel.astro
// Same Day Appliance Repair — Laguna Niguel, CA
// Branch: Irvine/OC | Phone: (213) 401-9019

import Layout from '../layouts/Layout.astro';
import CTA from '../components/CTA.astro';

const city = "Laguna Niguel";
const citySlug = "laguna-niguel";
const phone = "(213) 401-9019";
const phoneRaw = "+12134019019";
const email = "oc@samedayappliance.repair";
const branch = "Irvine";

const metaTitle = "Appliance Repair Laguna Niguel CA | Same Day Service | (213) 401-9019";
const metaDesc = "Same-day appliance repair in Laguna Niguel, CA. Rancho Niguel, Bear Brand, Laguna Sur. Sub-Zero, Wolf & all brands. OEM parts, 90-day warranty. $89 diagnostic — waived with repair.";

const neighborhoods = [
  { name: "Rancho Niguel", zip: "92677" },
  { name: "Bear Brand Ranch", zip: "92677" },
  { name: "Laguna Sur", zip: "92677" },
  { name: "Beacon Hill", zip: "92677" },
  { name: "Marina Hills", zip: "92677" },
  { name: "Aliso Niguel area", zip: "92677" },
  { name: "Laguna Ridge", zip: "92677" },
  { name: "Pacific Island area", zip: "92677" },
  { name: "Crown Valley Pkwy corridor", zip: "92677" },
  { name: "Moulton Parkway area", zip: "92677" },
];

const services = [
  { name: "Refrigerator Repair", slug: "refrigerator-repair", icon: "❄️" },
  { name: "Washer Repair", slug: "washer-repair", icon: "🫧" },
  { name: "Dryer Repair", slug: "dryer-repair", icon: "💨" },
  { name: "Dishwasher Repair", slug: "dishwasher-repair", icon: "🍽️" },
  { name: "Oven & Range Repair", slug: "oven-repair", icon: "🔥" },
  { name: "Cooktop Repair", slug: "cooktop-repair", icon: "♨️" },
  { name: "Wine Cooler Repair", slug: "wine-cooler-repair", icon: "🍷" },
  { name: "Freezer Repair", slug: "freezer-repair", icon: "🧊" },
];

const recentRepairs = [
  {
    title: "Sub-Zero refrigerator — ice maker producing hollow, undersized cubes",
    neighborhood: "Bear Brand Ranch",
    detail: "Sub-Zero 690 in a Bear Brand Ranch home — ice maker running but producing hollow, undersized cubes with a slight off-taste. Water inlet valve was partially failing, reducing water fill volume. Also found the water filter had been in service over 18 months — well beyond the 6-month replacement cycle for this model. Replaced the inlet valve with an OEM Sub-Zero part, installed a new filter, ran three ice maker cycles to verify cube quality. Customer hadn't known the filter needed that frequent replacement on Sub-Zero units.",
    part: "Sub-Zero OEM inlet valve + water filter",
    time: "1.5 hours"
  },
  {
    title: "Thermador wall oven — oven not preheating to set temperature",
    neighborhood: "Rancho Niguel",
    detail: "Thermador MEDS301RWS wall oven — set to 375°F, actual temperature stalling at 290°F. Temperature sensor probe had failed, causing the control board to misread the cavity temperature and cut the heating element too early. Replaced the probe with an OEM Thermador part, recalibrated the oven, ran temperature verification at 325°F, 375°F, and 425°F before signing off. Customer had been compensating by setting the oven 80 degrees higher than needed — that kind of workaround accelerates element wear.",
    part: "Thermador OEM temperature sensor probe",
    time: "1.5 hours"
  },
  {
    title: "Samsung washer — F7 error, door lock failing, won't start",
    neighborhood: "Marina Hills",
    detail: "Samsung WF50R8500AW — F7 door lock error on every cycle. Door lock assembly had failed. These Samsung door lock units are a known wear item at 4-5 years on machines with heavy household use. Replaced the assembly with an OEM Samsung part, tested through five full cycles. Family of four with two kids — that washer runs hard. We noted the drain hose routing was slightly kinked behind the unit and corrected that at no charge while we were there.",
    part: "Samsung OEM door lock assembly",
    time: "1 hour"
  },
  {
    title: "KitchenAid dishwasher — top rack not cleaning, spray arm not spinning",
    neighborhood: "Laguna Sur",
    detail: "KitchenAid KDTM354ESS — bottom rack clean, top rack coming out with food residue. Upper spray arm was stationary during cycles. Removed the arm and found the center nozzle completely blocked with mineral deposits — the arm couldn't rotate. Descaled the upper arm and the manifold assembly, cleaned the filter, ran a test cycle. Advised the homeowner on monthly rinse-aid use to prevent recurrence. Simple fix, but only if you know what to look for.",
    part: "Descale + filter service",
    time: "1 hour"
  }
];

const faqs = [
  {
    q: "Do you offer same-day appliance repair in Laguna Niguel?",
    a: "Yes — Laguna Niguel is part of our regular Orange County route from Irvine. We cover all neighborhoods including Rancho Niguel, Bear Brand Ranch, Marina Hills, and Laguna Sur. Call before noon for same-day service."
  },
  {
    q: "What is your diagnostic fee in Laguna Niguel?",
    a: "Our diagnostic fee is $89. It covers the service call, full appliance inspection, and a written estimate. If you proceed with the repair, the $89 is credited toward your invoice — you pay nothing extra for the diagnosis."
  },
  {
    q: "Do you repair Sub-Zero, Thermador, and Wolf in Laguna Niguel?",
    a: "Yes. The Rancho Niguel and Bear Brand Ranch estates commonly have Sub-Zero refrigerators, Thermador ovens and cooktops, Wolf ranges, and Miele or Bosch dishwashers. Our OC technicians carry OEM parts for these brands and service them regularly in Laguna Niguel."
  },
  {
    q: "Do your technicians wear shoe covers and clean up after the repair?",
    a: "Yes. Our technicians always use shoe covers and protect your floors and surfaces during the repair. We clean up completely before leaving. We understand that in Laguna Niguel — especially in HOA communities — how a service technician presents in your home matters."
  },
  {
    q: "What brands do you service in Laguna Niguel?",
    a: "All major brands: Samsung, LG, GE, Whirlpool, KitchenAid, Bosch, Maytag, Frigidaire, and luxury brands including Sub-Zero, Wolf, Thermador, Miele, Viking, and Dacor. We carry OEM parts for the brands most common in Laguna Niguel on our trucks."
  },
  {
    q: "How often should I replace the water filter on my Sub-Zero in Laguna Niguel?",
    a: "Sub-Zero recommends every 6 months in most areas. Many homeowners forget this cycle — we find filters in service for 18-24 months on a regular basis. An overdue filter reduces water flow to the ice maker, causes hollow cube formation, and affects water quality. We install a new filter on every Sub-Zero call where it's overdue."
  },
  {
    q: "Do you offer a warranty on repairs in Laguna Niguel?",
    a: "All repairs include a 90-day warranty on parts and labor. If the same issue returns within 90 days, we come back and fix it at no charge."
  }
];

const nearbyAreas = [
  { name: "Dana Point", slug: "dana-point" },
  { name: "Laguna Beach", slug: "laguna-beach" },
  { name: "Mission Viejo", slug: "mission-viejo" },
  { name: "Aliso Viejo", slug: "aliso-viejo" },
  { name: "Newport Beach", slug: "newport-beach" },
  { name: "San Clemente", slug: "san-clemente" },
];

const schemaJSON = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "HomeAndConstructionBusiness",
      "name": "Same Day Appliance Repair — Laguna Niguel",
      "telephone": phoneRaw,
      "email": email,
      "url": "https://samedayappliance.repair/laguna-niguel/",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "2600 Michelson Dr Suite 1700",
        "addressLocality": "Irvine",
        "addressRegion": "CA",
        "postalCode": "92612",
        "addressCountry": "US"
      },
      "areaServed": [
        { "@type": "City", "name": "Laguna Niguel" },
        { "@type": "Place", "name": "Rancho Niguel" },
        { "@type": "Place", "name": "Bear Brand Ranch" }
      ],
      "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "07:00", "closes": "21:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "08:00", "closes": "19:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "09:00", "closes": "17:00" }
      ],
      "priceRange": "$$",
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "reviewCount": "58",
        "bestRating": "5"
      },
      "license": "CA CSLB #1138898"
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
});
---

<Layout title={metaTitle} description={metaDesc}>
  <script type="application/ld+json" set:html={schemaJSON}></script>

  <section class="city-hero">
    <div class="city-hero-inner">
      <div class="city-hero-text">
        <div class="city-eyebrow">Laguna Niguel, CA · Orange County · 92677</div>
        <h1>Appliance Repair in Laguna Niguel, CA</h1>
        <p class="city-hero-sub">Same-day service across all of Laguna Niguel — Rancho Niguel, Bear Brand Ranch, Marina Hills, Laguna Sur. Sub-Zero, Wolf, Thermador & all brands. 90-day warranty.</p>
        <div class="city-hero-ctas">
          <a href={`tel:${phoneRaw}`} class="btn-primary">Call {phone}</a>
          <a href="/book/" class="btn-secondary">Book Online</a>
        </div>
        <div class="city-trust-row">
          <span>⭐ 4.9 Google Rating</span>
          <span>✓ Licensed & Insured</span>
          <span>✓ CA CSLB #1138898</span>
        </div>
      </div>
      <div class="city-hero-img">
        <img src="/images/areas/laguna-niguel/appliance-repair-laguna-niguel-ca.webp"
          alt="Appliance repair technician in Laguna Niguel CA"
          width="560" height="420" loading="eager" />
      </div>
    </div>
  </section>

  <section class="trust-bar">
    <div class="trust-bar-inner">
      <div class="trust-item"><span class="trust-icon">⚡</span><span>Same-Day Service</span></div>
      <div class="trust-item"><span class="trust-icon">🔧</span><span>OEM Parts</span></div>
      <div class="trust-item"><span class="trust-icon">🛡️</span><span>90-Day Warranty</span></div>
      <div class="trust-item"><span class="trust-icon">✅</span><span>Licensed & Insured</span></div>
      <div class="trust-item"><span class="trust-icon">🏅</span><span>BBB Accredited</span></div>
    </div>
  </section>

  <section class="city-intro">
    <div class="city-intro-inner">
      <div class="city-intro-content">
        <h2>Appliance Repair in Laguna Niguel — What We See Here</h2>
        <p>Laguna Niguel is a well-run planned community with a mix of housing that ranges from active-adult condos to large estate homes in Rancho Niguel and Bear Brand Ranch. The appliance picture follows the housing: mainstream brands in the more modest developments, Sub-Zero, Thermador, Wolf, and Miele in the larger homes on the hills.</p>
        <p>Our technicians work Laguna Niguel as part of our regular OC routes from Irvine. We know the neighborhoods, we arrive in clean uniforms, we use shoe covers without being asked, and we clean up before we leave. In an HOA community, how a service provider presents in your home is noticed — by you, and sometimes by your neighbors.</p>
        <p>Diagnostic fee is $89 — credited toward the repair. We give a written estimate before touching anything. Call <a href={`tel:${phoneRaw}`}>{phone}</a> and someone who actually knows our schedule picks up.</p>
      </div>
      <aside class="city-sidebar">
        <div class="city-sidebar-inner">
          <p class="sidebar-city-label">Laguna Niguel Service</p>
          <a href={`tel:${phoneRaw}`} class="btn-primary-lg">{phone}</a>
          <p class="sidebar-hours">Mon–Fri 7am–9pm · Sat 8am–7pm · Sun 9am–5pm</p>
          <a href="/book/" class="btn-secondary-sm">Book Online</a>
          <div class="sidebar-guarantee">
            <strong>$89 Diagnostic</strong>
            <span>— credited if you repair</span>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <section class="city-services">
    <div class="city-services-inner">
      <h2>Appliance Repair Services in Laguna Niguel</h2>
      <div class="services-grid">
        {services.map(s => (
          <a href={`/${citySlug}/${s.slug}/`} class="service-card">
            <span class="service-icon">{s.icon}</span>
            <span class="service-name">{s.name}</span>
            <span class="service-cta">Laguna Niguel →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="city-context">
    <div class="city-context-inner">
      <div class="section-number">01</div>
      <div class="city-context-content">
        <h2>Laguna Niguel's Two Markets — and Why It Matters for Repairs</h2>
        <p>Laguna Niguel isn't a uniform market for appliance repair, and knowing the difference helps us serve it better. The estates in Rancho Niguel, Bear Brand Ranch, and the hills along the ridgeline are a different world from the condos and town homes along Crown Valley Parkway and the more active communities near Aliso Viejo.</p>
        <p>In the estate neighborhoods, the appliances are typically Sub-Zero built-in refrigerators, Thermador or Wolf ranges, Miele or Bosch dishwashers, and wine coolers. These require technicians trained specifically on those brands, OEM parts on the truck, and the experience to diagnose correctly the first time. A misdiagnosed Sub-Zero compressor replacement costs $1,200 in parts alone — and is frequently unnecessary when the actual issue is a failed thermistor or a fouled condenser. We diagnose correctly.</p>
        <p>In the more accessible neighborhoods, the mix is Samsung, LG, KitchenAid, Whirlpool — high-use family appliances with their own characteristic failure patterns. Samsung ice maker wire harness. LG linear compressor. KitchenAid dishwasher spray arm. We carry OEM parts for these too and resolve most calls same visit.</p>
        <p>What's consistent across all of Laguna Niguel: residents take care of their homes, HOA standards are real, and they expect the service provider to show up prepared and leave the home as they found it. That's our standard too.</p>
      </div>
    </div>
  </section>

  <section class="city-neighborhoods">
    <div class="city-neighborhoods-inner">
      <div class="section-number">02</div>
      <h2>Laguna Niguel Neighborhoods We Service</h2>
      <div class="neighborhoods-grid">
        {neighborhoods.map(n => (
          <div class="neighborhood-card">
            <span class="neighborhood-name">{n.name}</span>
            <span class="neighborhood-zip">{n.zip}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="city-repairs">
    <div class="city-repairs-inner">
      <div class="section-number">03</div>
      <h2>Recent Repairs in Laguna Niguel</h2>
      <div class="repairs-grid">
        {recentRepairs.map(r => (
          <div class="repair-card">
            <h3 class="repair-title">"{r.title}"</h3>
            <div class="repair-location">📍 {r.neighborhood}</div>
            <p class="repair-detail">{r.detail}</p>
            <div class="repair-meta">
              <span class="repair-part">Part: {r.part}</span>
              <span class="repair-time">⏱ {r.time}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="city-why">
    <div class="city-why-inner">
      <div class="section-number">04</div>
      <h2>Why Laguna Niguel Residents Call Us</h2>
      <div class="why-grid">
        <div class="why-item">
          <h3>We diagnose correctly</h3>
          <p>A Sub-Zero running warm isn't automatically a compressor problem. A Thermador oven that won't hold temperature isn't automatically a control board. We find the actual cause before recommending parts — and we show you what we found.</p>
        </div>
        <div class="why-item">
          <h3>Professional in every sense</h3>
          <p>Shoe covers, clean uniforms, work area protected, home left as found. We understand that Laguna Niguel homes are maintained to a standard, and our technicians match it.</p>
        </div>
        <div class="why-item">
          <h3>OEM parts for luxury brands</h3>
          <p>Sub-Zero, Thermador, Wolf, Miele, Bosch — we stock OEM parts for the brands common in Rancho Niguel and Bear Brand Ranch. Most luxury brand calls finish same visit.</p>
        </div>
        <div class="why-item">
          <h3>90-day warranty standard</h3>
          <p>Every repair carries a 90-day warranty on parts and labor. Same issue returns within 90 days — we come back at no charge. No questions.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="city-reviews">
    <div class="city-reviews-inner">
      <h2>What Laguna Niguel Clients Say</h2>
      <div class="reviews-grid">
        <div class="review-card">
          <div class="review-stars">⭐⭐⭐⭐⭐</div>
          <p>"Sub-Zero ice maker producing odd-shaped cubes in our Bear Brand home. Technician replaced the inlet valve, installed a new filter, explained the 6-month filter cycle I'd been ignoring. Same day, professional, no mess. Exactly what you want."</p>
          <div class="review-author">— Patricia L., Bear Brand Ranch</div>
        </div>
        <div class="review-card">
          <div class="review-stars">⭐⭐⭐⭐⭐</div>
          <p>"Thermador oven stalling at 290°F — turned out to be the temperature probe, not the element or board as I'd feared. Same Day diagnosed it in 30 minutes, had the part on the truck. Running perfectly now. I appreciated that they showed me the failed probe and explained what it does."</p>
          <div class="review-author">— Michael R., Rancho Niguel</div>
        </div>
        <div class="review-card">
          <div class="review-stars">⭐⭐⭐⭐⭐</div>
          <p>"Samsung washer door lock failure. They were here within 3 hours of calling, fixed in under an hour, noticed a kink in my drain hose and corrected it at no extra charge. This is what good service looks like."</p>
          <div class="review-author">— Christine K., Marina Hills</div>
        </div>
      </div>
    </div>
  </section>

  <section class="city-pricing">
    <div class="city-pricing-inner">
      <h2>Repair Pricing in Laguna Niguel</h2>
      <div class="pricing-grid">
        <div class="pricing-card">
          <div class="pricing-label">Diagnostic Fee</div>
          <div class="pricing-price">$89</div>
          <div class="pricing-note">Credited toward repair · Written estimate · Professional presentation guaranteed</div>
        </div>
        <div class="pricing-card">
          <div class="pricing-label">Standard Repair</div>
          <div class="pricing-price">$150–$350</div>
          <div class="pricing-note">Parts + labor · OEM parts · 90-day warranty</div>
        </div>
        <div class="pricing-card">
          <div class="pricing-label">Luxury Brand Repair</div>
          <div class="pricing-price">$250–$600+</div>
          <div class="pricing-note">Sub-Zero, Wolf, Thermador, Miele, Dacor · OEM parts</div>
        </div>
        <div class="pricing-card highlight">
          <div class="pricing-label">Warranty</div>
          <div class="pricing-price">90 Days</div>
          <div class="pricing-note">All repairs · Parts & labor · No-charge callback</div>
        </div>
      </div>
    </div>
  </section>

  <section class="city-faq">
    <div class="city-faq-inner">
      <div class="section-number">05</div>
      <h2>Frequently Asked Questions — Laguna Niguel</h2>
      <div class="faq-list">
        {faqs.map(f => (
          <details class="faq-item">
            <summary class="faq-q">{f.q}</summary>
            <div class="faq-a">{f.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="city-nearby">
    <div class="city-nearby-inner">
      <h2>Also Serving Nearby South OC Cities</h2>
      <div class="nearby-grid">
        {nearbyAreas.map(a => (
          <a href={`/${a.slug}/`} class="nearby-link">Appliance Repair {a.name} →</a>
        ))}
      </div>
    </div>
  </section>

  <section class="city-bottom-cta">
    <div class="city-bottom-cta-inner">
      <h2>Schedule Your Laguna Niguel Repair Today</h2>
      <p>Same-day service across all of Laguna Niguel. Sub-Zero, Thermador, Wolf, and all major brands.</p>
      <div class="bottom-cta-btns">
        <a href={`tel:${phoneRaw}`} class="btn-primary-xl">Call {phone}</a>
        <a href="/book/" class="btn-secondary-xl">Book Online</a>
      </div>
      <p class="bottom-note">$89 diagnostic · 90-day warranty · OEM parts · Laguna Niguel, CA</p>
    </div>
  </section>

  <CTA phone={phone} branch={branch} zones={["Laguna Niguel", "Rancho Niguel", "Orange County"]} />
</Layout>
