---
import Layout from '../layouts/Layout.astro';

const title = "Wine Cellar Repair Beverly Hills | Same-Day · WhisperKOOL · CellarPro";
const description = "Wine cellar repair in Beverly Hills — split, ducted, self-contained refrigeration. EPA-certified. $89 diagnostic waived with repair. (323) 870-4790.";
const canonical = "https://samedayappliance.repair/wine-cellar-repair-beverly-hills/";

const faqs = [
  {
    "q": "How fast can you reach a Beverly Hills cellar emergency?",
    "a": "Same-day in nearly all cases. West Hollywood branch is 5–10 minutes from most Beverly Hills addresses; we keep cellar parts on the truck."
  },
  {
    "q": "Do you have a portable cooling option for at-risk collections?",
    "a": "Yes. While parts are ordered (typical 1–3 days for OEM cellar components), we deploy portable spot cooling to keep the cellar within safe range for the collection."
  },
  {
    "q": "Cost expectations for a Beverly Hills cellar repair?",
    "a": "$89 diagnostic, applied to the repair. Common range: $250–$1,400 depending on whether the issue is fan/sensor (low end) or refrigerant/compressor (high end)."
  }
];

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": "https://samedayappliance.repair/wine-cellar-repair-beverly-hills/#business",
    "name": "Same Day Appliance Repair",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": "https://samedayappliance.repair/wine-cellar-repair-beverly-hills/",
    "telephone": "+1-424-325-0520",
    "priceRange": "$$$",
        "geo": {
      "@type": "GeoCoordinates",
      "latitude": 34.0619,
      "longitude": -118.3692
    },
    "areaServed": [
      {
        "@type": "AdministrativeArea",
        "name": "Los Angeles County"
      },
      {
        "@type": "AdministrativeArea",
        "name": "Orange County"
      },
      {
        "@type": "AdministrativeArea",
        "name": "Ventura County"
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Wine Cellar Repair",
    "provider": {
      "@id": "https://samedayappliance.repair/wine-cellar-repair-beverly-hills/#business"
    },
    "areaServed": [
      {
        "@type": "AdministrativeArea",
        "name": "Los Angeles County"
      },
      {
        "@type": "AdministrativeArea",
        "name": "Orange County"
      },
      {
        "@type": "AdministrativeArea",
        "name": "Ventura County"
      }
    ],
    "description": "Wine cellar repair in Beverly Hills — split, ducted, self-contained refrigeration. EPA-certified. $89 diagnostic waived with repair. (323) 870-4790.",
    "offers": {
      "@type": "Offer",
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "89.00",
        "priceCurrency": "USD",
        "description": "Residential diagnostic fee, waived with repair"
      }
    }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://samedayappliance.repair/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Beverly Hills",
      "item": "https://samedayappliance.repair/wine-cellar-repair-beverly-hills/"
    }
  ] }
];
---
<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">
    {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
  </Fragment>

  <section class="ph-hero">
    <div class="ph-wrap">
      <p class="ph-eyebrow">Placeholder · Content Coming Soon</p>
      <h1>Wine Cellar Repair in Beverly Hills</h1>
      <p class="ph-intro">Beverly Hills has one of the densest concentrations of high-end wine cellars in the country — 2,000 to 5,000-bottle cellars, custom-built or retrofit, predominantly WhisperKOOL Platinum and CellarPro VSi-equipped. We dispatch from the West Hollywood branch (323) 870-4790, factory-trained on cellar refrigeration, EPA 608 certified for refrigerant work. Same-day service typical.</p>
      <div class="ph-ctas">
        <a href="tel:+14243250520" class="ph-btn">Call (424) 325-0520</a>
        <a href="/contact/" class="ph-btn ph-btn-ghost">Contact Us</a>
      </div>
    </div>
  </section>

  <section class="ph-faq">
    <div class="ph-wrap">
      <h2>Frequently Asked</h2>
      {faqs.map(f => (<details class="ph-detail"><summary>{f.q}</summary><p>{f.a}</p></details>))}
    </div>
  </section>
</Layout>

<style>
  .ph-wrap { max-width: 820px; margin: 0 auto; padding: 0 24px; }
  .ph-hero { background: #0a0a0a; color: #fff; padding: 64px 0; }
  .ph-eyebrow { color: #C8102E; font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; margin: 0 0 14px; }
  .ph-hero h1 { font-size: clamp(1.6rem, 3.2vw, 2.4rem); font-weight: 800; margin: 0 0 16px; line-height: 1.2; }
  .ph-intro { color: rgba(255,255,255,0.85); font-size: 1.05rem; margin: 0 0 28px; line-height: 1.65; }
  .ph-ctas { display: flex; gap: 12px; flex-wrap: wrap; }
  .ph-btn { display: inline-block; background: #C8102E; color: #fff; padding: 12px 24px; text-decoration: none; font-weight: 700; border-radius: 4px; font-size: 0.95rem; }
  .ph-btn-ghost { background: transparent; border: 1px solid rgba(255,255,255,0.4); }
  .ph-faq { padding: 56px 0; background: #f5f5f5; }
  .ph-faq h2 { font-size: 1.5rem; margin: 0 0 20px; color: #0a0a0a; }
  .ph-detail { background: #fff; border: 1px solid #e2e2e2; padding: 14px 18px; border-radius: 4px; margin-bottom: 8px; }
  .ph-detail summary { font-weight: 600; cursor: pointer; color: #0a0a0a; }
  .ph-detail p { margin: 10px 0 0; color: #444; line-height: 1.6; }
</style>
