---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import CustomNarrative from '../components/cities/v2/CustomNarrative.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

const citySlug = 'sherman-oaks';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = 'Sherman Oaks';
const zips = ['91401', '91403', '91411', '91423'];

const phoneRaw = `+1${branch.phone.replace(/\D/g, '')}`;

const title = `Appliance Repair Sherman Oaks CA — Same Day | Jenn-Air · Gaggenau · Sub-Zero · Ventura Blvd`;
const description = `Same-day appliance repair Sherman Oaks CA. 91403, 91423, 91401, 91411. Refrigerator, washer, dryer, oven. BHGS #A49573. $89 dx waived.`;
const canonical = 'https://samedayappliance.repair/sherman-oaks/';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { '@type': 'Neighborhood', name: 'Sherman Oaks', sameAs: 'https://en.wikipedia.org/wiki/Sherman_Oaks,_Los_Angeles' }
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$',
  license: 'BHGS #A49573'

};

const luxuryBrandsNarrative = {
  headline: 'Sherman Oaks Luxury Brands — We Know These Systems',
  paragraphs: [
    'The 91423 hillside homes search for these brands specifically. So do we.'
  ],
  subSections: [
    {
      title: 'Jenn-Air',
      paragraphs: [
        'Column refrigerators · French door · Pro-style ranges · Panel-ready dishwashers · Built-in ovens.',
        'Most-searched brand in Sherman Oaks. Control board failures, cooling issues, and ice maker problems are common in JA column units. OEM Jenn-Air parts on every vehicle.'
      ]
    },
    {
      title: 'Gaggenau',
      paragraphs: [
        'Steam combination ovens · Vario cooktops · Column refrigeration · Dishwashers.',
        'Gaggenau requires specific technical knowledge — particularly for the steam combi oven systems and Vario induction cooktops. We carry OEM Gaggenau parts and are trained on these systems.'
      ]
    },
    {
      title: 'Sub-Zero · Wolf',
      paragraphs: [
        'Built-in refrigeration · Pro ranges · Dual-fuel · Outdoor.',
        'Standard in Sherman Oaks 91423 hillside kitchens. OEM parts, LADWP hard water inlet valve checks included.'
      ]
    },
    {
      title: 'Thermador',
      paragraphs: [
        'Star burner ranges · Built-in refrigeration · Steam ovens.',
        'Thermador star burner igniter failures common in heavily-used Valley kitchens. OEM parts on vehicle.'
      ]
    },
    {
      title: 'Bertazzoni',
      paragraphs: [
        'Italian pro-style ranges · Electric & gas · Dishwashers.',
        'Increasingly common in Sherman Oaks renovations. Our technicians are trained on Bertazzoni-specific ignition and control systems.'
      ]
    },
    {
      title: 'All Standard Brands',
      paragraphs: [
        'Samsung · LG · GE · Whirlpool · Bosch · KitchenAid · Maytag.',
        'Valley floor homes and condos — same same-day commitment, same $89 diagnostic waived with repair.'
      ]
    }
  ]
};

const introParagraphs = [
  "Sherman Oaks divides fairly naturally along Mulholland Drive. South of Ventura Boulevard, heading up toward the 91423 ZIP, the homes are larger and the kitchens reflect it: Jenn-Air column refrigerators, Gaggenau cooktops, Sub-Zero built-ins. These appliances require OEM parts and technicians who know their specific failure modes — not generic Valley service.",
  "North of Ventura — the 91401 and 91411 corridors — is established suburban Sherman Oaks: well-maintained homes and condos with LG, Samsung, GE, and Whirlpool. Standard brands, standard repair needs, same reliable same-day service and the same $89 diagnostic waived with repair.",
  "LADWP hard water runs throughout all of Sherman Oaks at 230–310 mg/L. This affects ice maker inlet valves and dishwasher spray arms consistently across all ZIP codes — we check for mineral deposits proactively on every relevant call. Luxury brands like Jenn-Air and Gaggenau are not immune: their inlet valve systems and dishwasher fill circuits scale from LADWP water just like any other brand.",
  `Diagnostic fee: <strong>$89</strong> — waived with repair. Written estimate before we start. <strong>90-day warranty</strong>. Weekends available. Call <a href="tel:${phoneRaw}">${branch.phone}</a>.`,
  "<strong>LADWP hard water tip for Sherman Oaks:</strong> Jenn-Air and Gaggenau owners — LADWP mineral content at 230–310 mg/L affects your luxury appliances the same way it affects a standard Samsung. A Jenn-Air column refrigerator's fill valve scales gradually; a Gaggenau dishwasher's fill circuit needs periodic descaling. We check for this proactively on every Sherman Oaks call involving these brands — it's a consistent finding in 91423."
];

const services = [
  { icon: '🧊', name: 'Refrigerator Repair', slug: 'refrigerator', issues: 'Jenn-Air column · Sub-Zero built-in · LADWP ice maker · Not cooling', brands: 'Jenn-Air · Sub-Zero · Samsung · LG · GE · Thermador' },
  { icon: '🔥', name: 'Oven, Range & Pro Range', slug: 'oven', issues: 'Gaggenau steam combi · Jenn-Air pro range · Wolf · Thermador star burner', brands: 'Gaggenau · Jenn-Air · Wolf · Thermador · Bertazzoni · GE' },
  { icon: '🍽️', name: 'Dishwasher Repair', slug: 'dishwasher', issues: 'Gaggenau fill circuit · Jenn-Air panel-ready · LADWP scale · Not draining', brands: 'Gaggenau · Jenn-Air · Miele · Bosch · KitchenAid · Samsung' },
  { icon: '🫧', name: 'Washer Repair', slug: 'washer', issues: 'OE / UE error · Not draining · Not spinning · Error codes', brands: 'LG · Samsung · Whirlpool · Maytag · Bosch · Speed Queen' },
  { icon: '♨️', name: 'Dryer Repair + Vent Cleaning', slug: 'dryer', issues: 'Not heating · Thermal fuse · Hillside vent runs · Gas & electric', brands: 'LG · Samsung · GE · Maytag · Whirlpool · Miele' },
  { icon: '❄️', name: 'Freezer & Ice Maker Repair', slug: 'freezer', issues: 'Jenn-Air ice · LADWP inlet valve · Not freezing · Sub-Zero', brands: 'Jenn-Air · Sub-Zero · Samsung · LG · GE · True' },
  { icon: '🍷', name: 'Wine Cellar & Cooler Repair', slug: 'wine-cooler', issues: 'Temperature off · Sub-Zero wine · WhisperKOOL · Compressor', brands: 'Sub-Zero · EuroCave · True · Liebherr · U-Line' },
  { icon: '🔆', name: 'Cooktop & Range Hood', slug: 'cooktop', issues: 'Gaggenau Vario · Jenn-Air induction · Wolf star burner · Hood motor', brands: 'Gaggenau · Jenn-Air · Wolf · Thermador · Bertazzoni · Bosch' }
];

const neighborhoods = [
  { name: 'Mulholland Drive homes', zip: '91423', featured: true },
  { name: 'Ventura Blvd south side', zip: '91423', featured: true },
  { name: 'Longridge Estates area', zip: '91423' },
  { name: 'Royal Oaks Dr', zip: '91423' },
  { name: 'Roscomare Rd area', zip: '91423' },
  { name: 'Ventura Blvd corridor', zip: '91403' },
  { name: 'Van Nuys Blvd', zip: '91401' },
  { name: 'Sepulveda Blvd', zip: '91411' },
  { name: 'Sherman Oaks central', zip: '91403' },
  { name: 'Woodman Ave corridor', zip: '91401' }
];

const recentJobs = [
  {
    appliance: 'Jenn-Air Column Fridge',
    location: 'Mulholland hillside, 91423',
    quote: '"Not cooling evenly — warm on the left, fine on the right"',
    description: '91423 hillside home — Jenn-Air 36-inch column refrigerator with uneven temperature: left side inconsistent, right side at set point. Found a failed evaporator fan motor on the left column and a damper assembly partially stuck from LADWP mineral accumulation on the control mechanism. Replaced the OEM Jenn-Air evaporator fan motor, freed and cleaned the damper, ran a full Jenn-Air diagnostic cycle. Both columns at set temperature and cycling evenly. Jenn-Air column units have a specific failure pattern on the damper in LADWP territory — mineral scale is the consistent culprit.',
    outcome: '✓ Same day · OEM Jenn-Air fan + damper · Both columns even · LADWP factor noted'
  },
  {
    appliance: 'Gaggenau Steam Oven',
    location: 'Ventura Blvd south, 91423',
    quote: '"E3 error — steam function completely gone"',
    description: 'Gaggenau BSP 221 steam combination oven — E3 water system fault. Found the steam generator descaling required (LADWP mineral scale build-up in the water tank heating element), and the water level sensor fouled. Ran the Gaggenau-specified descaling procedure, cleaned and recalibrated the water level sensor, tested all steam functions: steam bake, steam roast, and full steam mode all confirmed operational. Recommended monthly descaling cycle appropriate for LADWP water — Gaggenau specifies this for hard water areas and 91423 qualifies.',
    outcome: '✓ Same day · E3 resolved · All steam modes confirmed · Monthly descale schedule'
  },
  {
    appliance: 'Samsung Refrigerator',
    location: 'Sherman Oaks central, 91403',
    quote: '"Ice maker declining for months — filter changes not helping"',
    description: 'Standard Sherman Oaks home — Samsung French door, ice maker output declining despite regular filter changes. LADWP mineral scale on the inlet valve had progressed past what filter changes could address — the valve solenoid itself was restricted. Replaced with OEM Samsung inlet valve, flushed the water line, confirmed full production. Explained the difference between filter replacement (addresses contaminants) and inlet valve replacement (addresses mechanical restriction from mineral buildup) — the homeowner had been changing filters every 3 months and wondering why output kept declining.',
    outcome: '✓ Same day · OEM Samsung valve · Full production · Filter vs valve explained'
  },
  {
    appliance: 'Bertazzoni Range',
    location: 'Woodman Ave corridor, 91401',
    quote: '"Two burners clicking and won\'t ignite — recent kitchen reno"',
    description: "Sherman Oaks home with a recent renovation — Bertazzoni 36-inch pro range installed 14 months ago, two burner igniters failing. Found moisture trapped in the igniter wells from a recent cleaning — Bertazzoni's sealed burner design can trap water if cleaned with excessive moisture before the igniter assemblies are fully dry. Dried both electrode wells with compressed air, tested — one recovered fully, one electrode had developed a crack and needed replacement. OEM Bertazzoni electrode replaced, all six burners confirmed. Provided cleaning guidance specific to the sealed burner design.",
    outcome: '✓ Same day · OEM Bertazzoni electrode · All burners · Cleaning guidance given'
  }
];

const whyReasons = [
  {
    iconKey: 'parts' as const,
    title: 'Jenn-Air & Gaggenau Expertise',
    body: 'Jenn-Air column refrigerators, French door units, and pro-style ranges have specific failure patterns we know well. Gaggenau steam combi ovens and Vario cooktops require OEM parts and specific technical training — not generic luxury repair. We carry OEM parts for both brands.'
  },
  {
    iconKey: 'shield' as const,
    title: 'LADWP Hard Water Aware',
    body: 'Sherman Oaks runs on LADWP at 230–310 mg/L throughout all ZIP codes. Jenn-Air column refrigerator dampers, Gaggenau steam generators, and Samsung ice makers all accumulate mineral deposits faster here. We check proactively on every relevant call.'
  },
  {
    iconKey: 'team' as const,
    title: 'Hillside to Valley Floor',
    body: "91423 hillside estates with Jenn-Air and Gaggenau, 91403 valley floor homes with Samsung and LG — same same-day commitment, same OEM parts, same 90-day warranty. We don't tier our service quality by ZIP code."
  },
  {
    iconKey: 'clock' as const,
    title: '90-Day Warranty, OEM Only',
    body: 'Every repair backed by 90 days on parts and labor. Genuine OEM parts only — never aftermarket. $89 diagnostic waived with repair. Written estimate before we start. California licensed, BBB A+ rated. Weekends available.'
  }
];

const testimonials = [
  {
    stars: 5,
    text: '"Jenn-Air column fridge with uneven temperature. Tech found the fan motor failure and LADWP damper issue, replaced both with OEM Jenn-Air parts, explained the specific LADWP mineral pattern in this model. Both columns even. This is exactly the level of expertise a Jenn-Air appliance deserves — not generic appliance repair."',
    author: '— Catherine R., Mulholland hillside, Sherman Oaks 91423'
  },
  {
    stars: 5,
    text: '"Gaggenau steam oven E3 error. Tech ran the full Gaggenau descaling procedure, cleaned the water level sensor, tested all steam modes before leaving. Put us on a monthly descaling schedule for LADWP water. This isn\'t a repair company that guesses on luxury brands — they actually know these systems."',
    author: '— Michael T., Ventura Blvd south, Sherman Oaks 91423'
  },
  {
    stars: 5,
    text: '"Samsung ice maker declining despite regular filter changes. Tech explained the difference between filter replacement and inlet valve replacement — the filters weren\'t the issue, the valve was. Replaced the OEM Samsung valve, full production, problem solved. Really appreciated an explanation that actually made sense."',
    author: '— David K., Sherman Oaks central, 91403'
  }
];

const pricingTiers = [
  { appliance: 'Jenn-Air / Gaggenau', range: '$300–$800+', note: 'OEM parts · Column fridge · Steam combi · Vario cooktop · LADWP factor', featured: true },
  { appliance: 'Sub-Zero / Wolf / Thermador', range: '$300–$800+', note: 'OEM parts · 91423 hillside estates · Built-in refrigeration', featured: true },
  { appliance: 'Refrigerator (standard)', range: '$150–$400', note: 'LADWP inlet valve · Fan motor · Ice maker · Temperature' },
  { appliance: 'Washer / Dryer', range: '$150–$350', note: 'Hall sensor · Drain pump · Thermal fuse · Vent cleaning' },
  { appliance: 'Dishwasher / Oven', range: '$150–$450', note: 'LADWP scale · Gaggenau descale · Gas igniter · Error codes' },
  { appliance: 'Diagnostic Fee', range: '$89', note: 'Waived when you proceed with the repair' }
];

const faqs = [
  {
    question: 'Do you offer same-day appliance repair in Sherman Oaks, CA?',
    answer: 'Yes. Our technicians cover all of Sherman Oaks — Ventura Boulevard corridor, Mulholland Drive hillside homes, and all ZIP codes 91401, 91403, 91411, and 91423. Call before noon for same-day afternoon service.'
  },
  {
    question: 'Do you repair Jenn-Air appliances in Sherman Oaks?',
    answer: 'Yes. Jenn-Air refrigerators, ranges, dishwashers, and built-in appliances are common throughout Sherman Oaks — particularly in the 91423 hillside homes. Our technicians carry OEM Jenn-Air parts on every vehicle and are familiar with the specific failure modes of Jenn-Air column refrigerators, French door models, and pro-style ranges.'
  },
  {
    question: 'Do you repair Gaggenau appliances in Sherman Oaks?',
    answer: "Yes. Gaggenau ovens, cooktops, and dishwashers require specific expertise and genuine OEM parts. Our technicians are trained on Gaggenau's unique systems and carry parts for the most common Gaggenau failures in the Sherman Oaks area."
  },
  {
    question: 'Does LADWP hard water affect appliances in Sherman Oaks?',
    answer: 'Yes. Sherman Oaks is LADWP territory at 230–310 mg/L hardness. Ice maker inlet valves and dishwasher spray arms accumulate mineral deposits faster here. We check for this proactively on every relevant Sherman Oaks call.'
  },
  {
    question: 'Are you available on weekends in Sherman Oaks?',
    answer: 'Yes. Saturday Mon–Sat 8am–8pm · Sun closed · Phone answered 24/7.'
  },
  {
    question: 'What is your diagnostic fee in Sherman Oaks?',
    answer: 'Our diagnostic fee is $89, waived when you proceed with the repair. Written estimate before we start. Most Sherman Oaks repairs run $150–$500 depending on brand and appliance.'
  },
  {
    question: 'Do you also serve Encino, Studio City, and Van Nuys?',
    answer: 'Yes. Our Sherman Oaks service extends to Encino, Studio City, North Hollywood, Van Nuys, Tarzana, Reseda, and all of the San Fernando Valley.'
  }
