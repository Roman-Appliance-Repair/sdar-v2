const nearbyCities = [
  { name: 'Studio City', slug: 'studio-city' },
  { name: 'North Hollywood', slug: 'north-hollywood' },
  { name: 'Burbank', slug: 'burbank' },
  { name: 'West Hollywood', slug: 'west-hollywood' },
  { name: 'Beverly Hills', slug: 'beverly-hills' },
  { name: 'Los Angeles', slug: 'los-angeles' },
  { name: 'Calabasas', slug: 'calabasas' },
  { name: 'Thousand Oaks', slug: 'thousand-oaks' }
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair"
    headlineCity="Sherman Oaks, CA"
    subheadline="Jenn-Air, Gaggenau, Sub-Zero, Wolf — the hillside homes above Mulholland have premium kitchens that need premium service. The Valley floor has Samsung, LG, and GE that need reliable same-day. We cover all of it. OEM parts, 90-day warranty. Weekends available."
    zips={zips}
    tier={1}
  />

  <TrustBadgesRow />

  <CustomNarrative
    headline={luxuryBrandsNarrative.headline}
    paragraphs={luxuryBrandsNarrative.paragraphs}
    subSections={luxuryBrandsNarrative.subSections}
    background="gray"
  />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance Repair in Sherman Oaks — Two Neighborhoods, One Service"
    paragraphs={introParagraphs}
    bookingTitle="Sherman Oaks Service"
    bookingSub="91403 · 91423 · Jenn-Air · Gaggenau · Same day"
  />

  <ServicesGrid
    cityName={cityName}
    headline="What We Repair in Sherman Oaks"
    subhead="Jenn-Air · Gaggenau · Sub-Zero · All brands · LADWP hard water aware · All ZIP codes"
    services={services}
  />

  <ServiceArea
    cityName={cityName}
    headline="All of Sherman Oaks — 91401 · 91403 · 91411 · 91423"
    subheadline="Valley floor to Mulholland hillside — every neighbourhood covered"
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={[]}
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Jobs in Sherman Oaks"
    jobs={recentJobs}
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="Why Sherman Oaks Calls Us Back"
    reasons={whyReasons}
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What Sherman Oaks Customers Are Saying"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Appliance Repair Costs in Sherman Oaks"
    subhead="Written estimate before we start. $89 diagnostic — waived with repair. OEM parts only."
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="Questions Sherman Oaks Customers Ask"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby Areas"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance broken in Sherman Oaks?"
    body="Jenn-Air · Gaggenau · Sub-Zero · Wolf · LADWP hard water aware · All of 91401, 91403, 91411, 91423. $89 diagnostic waived with repair. 90-day warranty."
  />
</CityLayoutV2>
