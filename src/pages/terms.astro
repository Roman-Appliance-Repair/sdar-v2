---
import Layout from '../layouts/Layout.astro';

const title = 'Terms of Service | Same Day Appliance Repair';
const description = 'Terms of Service for HVAC 777 LLC (DBA Same Day Appliance Repair) — diagnostic fee, warranty, payment, cancellation, parts, and liability terms for residential and commercial appliance repair.';
const canonical = 'https://samedayappliance.repair/terms/';
const lastUpdated = 'April 1, 2026';
const effectiveDate = 'April 1, 2026';

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  url: canonical,
  description,
  inLanguage: 'en-US',
  dateModified: '2026-04-01',
  isPartOf: { '@type': 'WebSite', name: 'Same Day Appliance Repair', url: 'https://samedayappliance.repair/' },
  about: { '@type': 'Thing', name: 'Terms of Service' },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://samedayappliance.repair/' },
    { '@type': 'ListItem', position: 2, name: 'Terms', item: canonical },
  ],
};
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">
    <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <article class="legal">
    <div class="container legal-container">
      <p class="eyebrow">Legal · Terms</p>
      <h1>Terms of Service</h1>
      <p class="meta">Effective {effectiveDate} · Last updated {lastUpdated}</p>

      <p class="lede">
        These Terms of Service govern (a) your use of the Same Day Appliance Repair website at
        <a href="https://samedayappliance.repair/">samedayappliance.repair</a> and (b) any
        residential or commercial appliance repair service you book with HVAC 777 LLC, doing
        business as Same Day Appliance Repair ("SDAR", "we", "us", "our"). By using the Site,
        submitting a booking, or accepting a technician's diagnostic, you agree to these terms.
      </p>

      <nav class="toc" aria-label="Table of contents">
        <h2>On this page</h2>
        <ol>
          <li><a href="#acceptance">Acceptance of terms</a></li>
          <li><a href="#services">The services we provide</a></li>
          <li><a href="#diagnostic">Diagnostic fee &amp; waiver</a></li>
          <li><a href="#estimate">Written repair estimate</a></li>
          <li><a href="#parts">Parts &amp; OEM sourcing</a></li>
          <li><a href="#warranty">Labor warranty &amp; what it covers</a></li>
          <li><a href="#payment">Payment terms</a></li>
          <li><a href="#cancellation">Cancellation, rescheduling &amp; no-shows</a></li>
          <li><a href="#access">Site access, safety &amp; scope of work</a></li>
          <li><a href="#commercial">Commercial accounts</a></li>
          <li><a href="#website-use">Website use</a></li>
          <li><a href="#disclaimers">Disclaimers</a></li>
          <li><a href="#limitation">Limitation of liability</a></li>
          <li><a href="#indemnification">Indemnification</a></li>
          <li><a href="#disputes">Disputes &amp; governing law</a></li>
          <li><a href="#changes">Changes to these terms</a></li>
          <li><a href="#contact">Contact</a></li>
        </ol>
      </nav>

      <h2 id="acceptance">1. Acceptance of terms</h2>
      <p>
        By booking a visit, confirming a dispatch, or allowing a tech onto the premises to
        diagnose or repair an appliance, you represent that you are (a) 18 years or older, (b)
        the owner of the appliance or authorized by the owner to permit the work, and (c) the
        person authorized to incur charges on behalf of the property. If you disagree with any
        part of these terms, do not book a visit; any work already performed to the point of
        disagreement is still payable under the terms in effect when the work began.
      </p>

      <h2 id="services">2. The services we provide</h2>
      <p>We diagnose and repair residential and commercial appliances including:</p>
      <ul>
        <li>Refrigerators, freezers, ice makers, wine coolers and cellars.</li>
        <li>Dishwashers.</li>
        <li>Ranges, ovens, wall ovens, cooktops, stoves, range hoods.</li>
        <li>Microwaves.</li>
        <li>Washers, dryers, stackable washer-dryers, dryer vents.</li>
        <li>BBQ grills, pizza ovens, garbage disposals, trash compactors.</li>
        <li>Commercial equivalents: walk-ins, ice machines, fryers, commercial dishwashers, laundry, etc.</li>
      </ul>
      <p>
        We are a California C-20 licensed contractor (CSLB #1138898) and registered with the
        California Bureau of Household Goods and Services (BHGS #A49573). We carry EPA Section
        608 Technician Certification for refrigerant handling.
      </p>
      <p>
        We do not perform: plumbing work beyond the appliance water supply and drain connection,
        electrical work beyond the appliance junction and dedicated appliance circuit, gas line
        modifications, or structural cabinetry work. If a repair requires any of those, we will
        recommend a licensed trade and resume when that work is complete.
      </p>

      <h2 id="diagnostic">3. Diagnostic fee &amp; waiver</h2>
      <p>
        The residential diagnostic fee is <strong>$89</strong>. It covers up to 45 minutes of
        on-site testing, including pulling any fault codes the appliance reports, inspecting
        the component the symptom points at, checking the supply (power, water, gas) as
        applicable, and writing up the fault. Commercial diagnostic is <strong>$120</strong>.
      </p>
      <p>
        <strong>Waiver:</strong> if you approve the repair quote on the same visit and we perform
        the repair, the diagnostic fee is waived — it rolls into the repair invoice and you are
        charged only the flat repair amount.
      </p>
      <p>
        If the appliance is not economically repairable or you decline the quote, the diagnostic
        fee is due at the end of the visit. The diagnostic is not a guarantee that we can repair
        the appliance; it is an evaluation for which we are compensated.
      </p>

      <h2 id="estimate">4. Written repair estimate</h2>
      <p>
        Before we install any part or perform any billable labor beyond diagnostic, the
        technician provides a written estimate on a tablet or on paper. The estimate lists the
        fault, the proposed repair, the parts required, the total flat price, and any
        conditions (for example, "price valid if the compressor tests within spec after board
        replacement"). You sign or electronically confirm the estimate before work proceeds.
      </p>
      <p>
        The estimate price is flat. If mid-repair we discover additional faults that change the
        scope — for example, a control board replaces cleanly but then reveals a failed
        evaporator fan — we stop, write a supplemental estimate, and get your approval before
        continuing. You are not billed for scope you did not approve.
      </p>

      <h2 id="parts">5. Parts &amp; OEM sourcing</h2>
      <p>
        We use original equipment manufacturer (OEM) parts wherever the OEM still supplies
        them. For discontinued models or parts that the OEM no longer produces, we may use a
        superseded OEM part, an approved aftermarket equivalent, or a salvaged OEM part from
        our supplier network. The estimate will disclose when a non-new or aftermarket part is
        proposed, and you may decline.
      </p>
      <p>
        Parts remain our property until paid for in full. Replaced (removed) parts are
        discarded by us unless you ask in writing for them to be left on site. For refrigerant
        recovery and disposal, we follow EPA Section 608 procedures.
      </p>

      <h2 id="warranty">6. Labor warranty &amp; what it covers</h2>
      <p>
        We offer a <strong>90-day labor warranty</strong> on the specific repair we performed,
        measured from the date of the repair invoice. If the same fault recurs on the same
        component within 90 days, we return and re-diagnose at no labor charge and, if the
        failure was caused by our workmanship, re-perform the labor at no charge.
      </p>
      <p>
        Parts carry the manufacturer's warranty, which is typically 90 days to 1 year depending
        on the part and brand. We pass that warranty through to you — if a covered part fails
        within the manufacturer's window, we file the warranty claim and credit the part cost
        on your side.
      </p>
      <p>The warranty does not cover:</p>
      <ul>
        <li>A different component failing (e.g. we fixed the compressor; the ice maker fails two weeks later — that's a new diagnostic).</li>
        <li>Damage caused by misuse, power surges, water-line pressure spikes, pest infestation, flood, fire, or customer disassembly.</li>
        <li>Commercial appliances used in residential settings or residential appliances used in commercial settings (the duty cycle is different and voids pass-through coverage).</li>
        <li>Wear items (e.g. door gaskets, lint filters) where the manufacturer excludes them.</li>
        <li>Cosmetic damage that was present before the visit.</li>
      </ul>

      <h2 id="payment">7. Payment terms</h2>
      <p>
        Residential invoices are due <strong>on completion of the visit</strong>. We accept
        Visa, MasterCard, American Express, Discover, Apple Pay, Google Pay, and ACH. We do not
        take cash as a routine payment method because of field-safety practice, but a tech can
        accept cash on request with a written receipt.
      </p>
      <p>
        Commercial accounts may qualify for <strong>net-30 invoicing</strong> after the first
        paid visit — see <a href="/for-business/">For Business</a>. Past-due commercial invoices
        accrue 1.5% per month (or the maximum allowed by California law, whichever is lower)
        after 30 days.
      </p>
      <p>
        If a card charge is reversed or a check bounces, we charge a $25 processing fee and may
        suspend future service until the balance is cleared. Disputed charges should be raised
        with us first — most disputes are resolved inside one business day without involving
        the card network.
      </p>

      <h2 id="cancellation">8. Cancellation, rescheduling &amp; no-shows</h2>
      <p>
        You can cancel or reschedule a visit at no charge up to 2 hours before the arrival
        window starts. Cancellations inside the 2-hour window, or no-shows after the tech has
        been dispatched, incur a $49 trip fee that covers driving time.
      </p>
      <p>
        If we have to cancel on you — stuck truck, emergency on a prior call, tech out sick —
        we call or text as soon as we know and reschedule to the earliest slot. We do not
        charge a trip fee for our cancellations, and we prioritize the reschedule.
      </p>
      <p>
        Under the California Home Solicitation Sales Act, if a contract is signed at your home
        for more than $25, you may cancel in writing before midnight of the third business day
        after the contract date. This right applies to written contracts entered into in your
        home; it does not apply to the diagnostic fee for a visit you requested, nor to repairs
        performed on the same visit.
      </p>

      <h2 id="access">9. Site access, safety &amp; scope of work</h2>
      <p>
        You agree to provide safe access to the appliance: cleared walkways, a responsible
        adult on site or able to be reached by phone, any pets secured, and reasonable work
        clearance. If a built-in appliance is wedged or the cabinet is damaged in a way that
        makes extraction unsafe, the tech may decline to proceed until the condition is
        addressed.
      </p>
      <p>
        The tech may photograph the appliance, the model plate, the fault, and the repair area
        for service records and warranty. We do not photograph other parts of the home, and
        photos are retained under the <a href="/privacy-policy/#retention">retention rules in
        our Privacy Policy</a>.
      </p>
      <p>
        If the tech identifies a condition outside the scope of the repair that presents a
        safety risk — a scorched gas line, a compromised breaker, a water leak behind the
        appliance — we will flag it in writing. Addressing it is your responsibility, and we
        may decline to operate the appliance if the risk is present.
      </p>

      <h2 id="commercial">10. Commercial accounts</h2>
      <p>
        Commercial service (restaurants, hotels, bars, grocery, property management, Airbnb
        portfolios, commissary kitchens) runs under a commercial addendum with a $120
        diagnostic, different parts-warranty pass-through for commercial-grade equipment, and
        the option of a named account manager, PO workflow, and net-30 billing. Email
        <a href="mailto:commercial@samedayappliance.repair">commercial@samedayappliance.repair</a>
        or ask for commercial dispatch on the main line.
      </p>

      <h2 id="website-use">11. Website use</h2>
      <p>
        You may use the Site for personal and commercial reference. You may not (a) scrape or
        mirror the Site at volume, (b) use automated tools to overwhelm the dispatch form, (c)
        copy substantial portions of the content for republication without written permission,
        or (d) use the Site in a way that violates applicable law. Trademarks, model numbers,
        and brand names shown on the Site belong to their respective owners; we use them
        nominatively to describe repair service.
      </p>

      <h2 id="disclaimers">12. Disclaimers</h2>
      <p>
        The repair advice, model notes, and troubleshooting content on the Site are provided
        for informational purposes. Appliance failures vary by model, age, installation, and
        operating conditions. The content is not a substitute for an on-site diagnostic by a
        licensed technician. To the fullest extent permitted by law, the Site content is
        provided "as is," without warranty of accuracy, completeness, or fitness for a
        particular purpose.
      </p>
      <p>
        Service results depend on appliance condition, availability of parts, and operating
        environment. We make no representation that every appliance is repairable, nor that
        repair is always the economical choice over replacement. The written estimate we
        provide on site supersedes any informational content on the Site.
      </p>

      <h2 id="limitation">13. Limitation of liability</h2>
      <p>
        To the maximum extent permitted by California law, HVAC 777 LLC, its officers,
        employees, and subcontractors will not be liable for indirect, incidental, special,
        consequential, or punitive damages — including loss of food in a refrigerator or
        freezer beyond normal spoilage, loss of business revenue, loss of use, or loss of data
        — arising out of or related to the services.
      </p>
      <p>
        Direct damages, if awarded, are capped at the greater of (a) the amount you paid us for
        the specific repair at issue, or (b) $1,000. This limitation does not apply to bodily
        injury or property damage caused by our gross negligence or willful misconduct, which
        remain covered by our general liability insurance.
      </p>

      <h2 id="indemnification">14. Indemnification</h2>
      <p>
        You agree to indemnify and hold HVAC 777 LLC harmless from third-party claims arising
        out of (a) a misrepresentation you made about ownership, authorization, or the
        condition of the appliance; (b) your failure to disclose a known hazard in the work
        area; or (c) your use of the Site in violation of these terms. We will defend and
        indemnify you for claims arising out of our work to the extent covered by our general
        liability insurance and subject to the limits of that policy.
      </p>

      <h2 id="disputes">15. Disputes &amp; governing law</h2>
      <p>
        These terms are governed by the laws of the State of California, without regard to
        conflict-of-law rules. Before filing any action, you agree to contact us first at
        <a href="mailto:disputes@samedayappliance.repair">disputes@samedayappliance.repair</a>
        or by phone and give us 30 days to resolve the issue informally — most disputes are
        resolved this way.
      </p>
      <p>
        If informal resolution fails, disputes will be brought exclusively in the state or
        federal courts located in Los Angeles County, California, and you consent to personal
        jurisdiction there. You retain the right to file a complaint with the Contractors
        State License Board (CSLB) at any time; CSLB's complaint process is independent of
        these terms. California residents may also reach the Department of Consumer Affairs /
        BHGS for appliance-service complaints.
      </p>

      <h2 id="changes">16. Changes to these terms</h2>
      <p>
        We may update these terms from time to time. Material changes — changes to the
        warranty, the diagnostic fee, the payment terms, or the liability limits — will be
        flagged at the top of this page for at least 30 days and, where we have your email on
        file, emailed to customers who have had a visit in the prior 12 months. The
        "Effective" date at the top of this page reflects the current version.
      </p>

      <h2 id="contact">17. Contact</h2>
      <address class="legal-contact">
        HVAC 777 LLC<br />
        DBA Same Day Appliance Repair<br />
        CSLB C-20 License #1138898 · BHGS Registration #A49573<br />
        6230 Wilshire Blvd Ste A PMB 2267<br />
        Los Angeles, CA 90048<br />
        <br />
        General: <a href="/contact/">/contact/</a><br />
        Phone: <a href="tel:+14243250520">(424) 325-0520</a><br />
        Disputes: <a href="mailto:disputes@samedayappliance.repair">disputes@samedayappliance.repair</a><br />
        Commercial: <a href="mailto:commercial@samedayappliance.repair">commercial@samedayappliance.repair</a>
      </address>
    </div>
  </article>
</Layout>

<style>
  .legal { padding: 72px 0 96px; }
  .legal-container { max-width: 780px; }
  .eyebrow { font-size: 12px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--red); margin-bottom: 16px; }
  h1 { font-size: clamp(2rem, 5vw, 2.8rem); line-height: 1.1; margin: 0 0 12px; }
  .meta { font-size: 13px; color: var(--muted); margin-bottom: 32px; }
  .lede { font-size: 17px; line-height: 1.7; color: #cccccc; margin-bottom: 28px; }

  h2 { font-size: clamp(1.3rem, 3vw, 1.7rem); margin: 40px 0 14px; padding-top: 8px; border-top: 1px solid var(--border); line-height: 1.2; }
  h2:first-of-type { border-top: none; padding-top: 0; }
  h3 { font-size: 17px; font-family: var(--font-body); font-weight: 600; margin: 24px 0 10px; }

  p, li { font-size: 15px; line-height: 1.75; color: #cccccc; }
  p { margin-bottom: 14px; }
  ul, ol { padding-left: 22px; margin-bottom: 14px; }
  li { margin-bottom: 8px; }
  strong { color: #ffffff; font-weight: 600; }
  em { font-style: italic; }
  a { color: var(--red); text-decoration: underline; text-underline-offset: 2px; }
  a:hover { color: #ffffff; }

  .toc { padding: 20px 24px; background: var(--gray); border: 1px solid var(--border); border-radius: 6px; margin-bottom: 36px; }
  .toc h2 { font-size: 13px; text-transform: uppercase; letter-spacing: 0.12em; color: var(--red); margin: 0 0 10px; padding: 0; border: none; }
  .toc ol { column-count: 2; column-gap: 24px; margin: 0; padding-left: 22px; }
  .toc li { font-size: 14px; margin-bottom: 4px; break-inside: avoid; color: var(--text); }
  .toc a { color: var(--text); text-decoration: none; }
  .toc a:hover { color: var(--red); }
  @media (max-width: 640px) { .toc ol { column-count: 1; } }

  .legal-contact { font-style: normal; padding: 20px 24px; background: var(--gray); border-radius: 6px; font-size: 15px; line-height: 1.8; color: var(--text); }
  .legal-contact a:hover { color: var(--red-dark); }
</style>
