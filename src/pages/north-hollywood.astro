---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import CustomNarrative from '../components/cities/v2/CustomNarrative.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES, MAIN_PHONE, isPlaceholderPhone } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

const citySlug = 'north-hollywood';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = 'North Hollywood';
const zips = ['91601', '91602', '91605', '91606'];

const phone = isPlaceholderPhone(branch.phone) ? MAIN_PHONE : branch.phone;
const phoneRaw = `+1${phone.replace(/\D/g, '')}`;

const title = `Appliance Repair North Hollywood CA — Same Day | NoHo Arts District · 91601 · 91606 | ${phone}`;
const description = `Same-day appliance repair in North Hollywood, CA. NoHo Arts District, Valley Village, Toluca Woods, Magnolia Park. 91601–91606. Production-schedule friendly. Licensed, OEM parts, 90-day warranty. Call ${phone}.`;
const canonical = 'https://samedayappliance.repair/north-hollywood/';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { '@type': 'City', name: 'North Hollywood', sameAs: 'https://en.wikipedia.org/wiki/North_Hollywood,_Los_Angeles' },
    { '@type': 'Neighborhood', name: 'NoHo Arts District' },
    { '@type': 'Neighborhood', name: 'Valley Village' },
    { '@type': 'Neighborhood', name: 'Toluca Woods' },
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$',
  license: 'CA CSLB #1138898',
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.6',
    reviewCount: '37',
    bestRating: '5',
  },
};

const introParagraphs = [
  "North Hollywood has changed a lot in the last decade. The NoHo Arts District brought new apartment buildings along Lankershim, new mixed-use development near the Metro B Line station, and a population that works in production, music, post-production, and the entertainment industry at large — schedules that don't fit neatly into a standard service window.",
  "We get that. If your dryer stopped heating before a long shoot, or your fridge quit while you're on a six-day production call schedule, we work around your availability. Saturdays, early mornings, call us and tell us your constraints. We'll find a time. That flexibility is part of why NoHo residents call us back.",
  "The rest of North Hollywood — the valley ranch houses in Valley Village, the craftsman bungalows in Toluca Woods, the garden apartments in Magnolia Park — we're there too, same day, same approach. Written estimate before we start. <strong>$89 diagnostic</strong> waived with repair. <strong>90-day warranty</strong>.",
];

const services = [
  { icon: '🧊', name: 'Refrigerator Repair', slug: 'refrigerator', issues: 'Not cooling · Ice maker · Fan motor · Temperature off · Leaking', brands: 'Samsung · LG · GE · Whirlpool · Sub-Zero · Bosch' },
  { icon: '♨️', name: 'Dryer Repair + Vent Cleaning', slug: 'dryer', issues: 'Not heating · Vent clogged · Takes forever · Fire hazard check', brands: 'LG · Samsung · GE · Maytag · Whirlpool · Electrolux' },
  { icon: '🫧', name: 'Washer Repair', slug: 'washer', issues: 'Not draining · Not spinning · Leaking · Error codes · Stackable', brands: 'LG · Samsung · Whirlpool · Maytag · Bosch · Speed Queen' },
  { icon: '🔥', name: 'Oven, Range & Stove Repair', slug: 'oven', issues: 'Not heating · Gas igniter · Temperature control · Broiler', brands: 'GE · Samsung · Bosch · Wolf · Viking · Thermador' },
  { icon: '🍽️', name: 'Dishwasher Repair', slug: 'dishwasher', issues: "Not draining · Leaking · Error codes · Won't start · Spots", brands: 'Bosch · KitchenAid · Samsung · LG · Miele · GE' },
  { icon: '❄️', name: 'Freezer & Ice Maker Repair', slug: 'freezer', issues: 'Not freezing · Ice maker stopped · Frost buildup · Temperature', brands: 'Samsung · LG · GE · Whirlpool · Sub-Zero · Frigidaire' },
  { icon: '🔆', name: 'Cooktop & Range Hood', slug: 'cooktop', issues: 'Igniter issues · Burner clicking · Induction · Hood motor', brands: 'GE · Samsung · Bosch · Wolf · Thermador · Broan' },
  { icon: '🏪', name: 'Commercial Appliance Repair', slug: 'commercial', issues: 'Commercial washers · Walk-in cooler · Ice machine · Restaurant', brands: 'Speed Queen · True · Hoshizaki · Manitowoc · Hobart' },
];

const dryerVentTipNarrative = {
  headline: 'Dryer Vent Tip for North Hollywood',
  paragraphs: [
    "<strong>Dryer vent tip for North Hollywood:</strong> In the older housing stock here — the 1950s ranch houses and converted bungalows — dryer vent ducts are often long, kinked, or run through walls in ways that trap lint faster than modern installations. A blocked vent is the top cause of residential dryer fires and the top reason dryers take two cycles to dry one load. We check vent airflow on every North Hollywood dryer call — it costs nothing extra and it matters.",
  ],
};

const neighborhoods = [
  { name: 'NoHo Arts District', zip: '91601', featured: true },
  { name: 'Valley Village', zip: '91607', featured: true },
  { name: 'Toluca Woods', zip: '91602', featured: true },
  { name: 'Magnolia Park', zip: '91601' },
  { name: 'Tujunga Village', zip: '91602' },
  { name: 'NoHo West', zip: '91605' },
  { name: 'East North Hollywood', zip: '91606' },
  { name: 'Laurel Grove', zip: '91605' },
];

const keyStreets = ['Lankershim Blvd', 'Vineland Ave', 'Chandler Blvd', 'Victory Blvd', 'Magnolia Blvd', 'Cahuenga Blvd', 'Laurel Canyon Blvd', 'Oxnard St'];

const recentJobs = [
  {
    appliance: 'LG Dryer',
    location: 'NoHo Arts District, 91601',
    quote: 'Takes forever to dry — three cycles for one load',
    description: 'Arts District apartment — the dryer vent ran through the wall and out the ceiling, an original 1960s installation. Lint had accumulated in a 90-degree elbow about 6 feet in, blocking roughly 70% of the airflow. Cleared the blockage, tested airflow at the exterior vent cap (was barely moving), replaced the thermal fuse that had tripped from the heat. Single cycle drying time from first test after: 42 minutes. The tenant mentioned their electricity bill had been climbing for months — that tracks with a restricted vent.',
    outcome: '✓ Same day · Vent cleared · Thermal fuse replaced · One cycle now',
  },
  {
    appliance: 'Samsung Refrigerator',
    location: 'Valley Village, 91607',
    quote: 'Fridge warm, freezer fine — happened overnight',
    description: 'Classic Samsung dual-evaporator presentation — upper fan motor seized, leaving the fresh food section without airflow while the freezer ran independently. Valley Village craftsman, original kitchen layout with the fridge in a tight alcove. Our tech replaced the fan motor with an OEM Samsung part, cleared the blocked defrost drain that had been slowly building up, confirmed temperatures in both compartments. Homeowner got home from work to a working fridge.',
    outcome: '✓ Same day · OEM Samsung fan motor · Both sections confirmed',
  },
  {
    appliance: 'Bosch Dishwasher',
    location: 'Toluca Woods, 91602',
    quote: "E15 error, water in the base — won't start",
    description: "E15 is Bosch's flood protection error — water in the base pan triggers the float switch and locks the machine. Found a loose water inlet hose connection at the back of the unit (likely vibrated loose over time). Dried the base pan, tightened and resealed the inlet connection, ran the anti-flood reset procedure, tested two full cycles. The homeowner was a food blogger and had been hand-washing everything for four days — they were very ready to have it back.",
    outcome: '✓ Same day · E15 resolved · No parts needed',
  },
  {
    appliance: 'GE Range',
    location: 'Magnolia Park, 91601',
    quote: "Oven igniter glowing but won't light the gas",
    description: 'This is a very specific GE issue — the igniter glows orange but doesn\'t draw enough current to open the gas valve. The igniter needs to reach a specific amperage, and a weak one will glow without triggering ignition. Standard replacement: OEM GE igniter, 30-minute job. Tested at 350°F, 400°F, and 450°F before leaving — accurate at all three. The homeowner had been trying to diagnose it themselves for two weeks and was convinced the valve was bad.',
    outcome: '✓ Same day · OEM GE igniter · All temps confirmed',
  },
];

const whyReasons = [
  {
    iconKey: 'team' as const,
    title: 'Production Schedule Friendly',
    body: 'A lot of NoHo residents work in entertainment — production, music, post. Schedules that don\'t fit a 9-to-5 window. We have Saturday and Sunday availability and can work around shoot schedules and irregular call times. Tell us your constraints.',
  },
  {
    iconKey: 'parts' as const,
    title: 'Dryer Vent Check Every Time',
    body: "North Hollywood's older housing stock has some of the longest, most convoluted dryer vent runs we see. A blocked vent is a fire hazard and the leading cause of dryers that \"take forever.\" We check vent airflow on every dryer call — standard, not extra.",
  },
  {
    iconKey: 'shield' as const,
    title: 'Houses & Apartments Both',
    body: 'Valley ranch houses, craftsman bungalows, garden apartments, new Lankershim high-rises — we work in all of them. Tenants, landlords, property managers — we coordinate with whoever needs to be involved.',
  },
  {
    iconKey: 'clock' as const,
    title: '90-Day Warranty, OEM Only',
    body: 'Every repair backed by 90 days on parts and labor. Genuine OEM parts only. $89 diagnostic waived with repair. California licensed, BBB A+ rated. If the same issue returns within 90 days, we come back at no charge.',
  },
];

const testimonials = [
  {
    stars: 5,
    text: '"My dryer had been taking three cycles forever. Tech came to my NoHo apartment, found the vent completely clogged in the wall, cleared it and replaced the thermal fuse. Single cycle now, 42 minutes. Also mentioned my electricity bill would drop — it already has. Wish I\'d called sooner."',
    author: '— Marcus T., NoHo Arts District',
  },
  {
    stars: 5,
    text: '"I work in production and needed a repair fitted around my schedule. Called Saturday morning, tech came out that same afternoon, Samsung fridge fan motor replaced and done before I left for a shoot. They were flexible about timing and professional throughout. Exactly what I needed."',
    author: '— Diana K., Valley Village, North Hollywood',
  },
  {
    stars: 5,
    text: '"Bosch dishwasher with E15 error — water in the base. They diagnosed the loose inlet hose, dried the pan, ran the reset, tested it fully. No parts needed, done in an hour. The technician explained exactly what happened and how to prevent it. Very knowledgeable, very efficient."',
    author: '— Sarah L., Toluca Woods, North Hollywood',
  },
];

const pricingTiers = [
  { appliance: 'Refrigerator', range: '$150 – $400', note: 'Fan motor, thermostat, ice maker, drain, compressor relay' },
  { appliance: 'Dryer + Vent Cleaning', range: '$150 – $320', note: 'Heating element, thermal fuse, vent inspection & clearance', featured: true },
  { appliance: 'Washer', range: '$150 – $350', note: 'Drain pump, door latch, shock absorbers, control board' },
  { appliance: 'Oven / Range', range: '$150 – $400', note: 'Igniter, bake element, gas valve, temperature calibration' },
  { appliance: 'Dishwasher', range: '$150 – $320', note: 'Drain pump, door latch, inlet valve, error code reset' },
  { appliance: 'Diagnostic Fee', range: '$89', note: 'Waived when you proceed with the repair' },
];

const faqs = [
  {
    question: 'Do you offer same-day appliance repair in North Hollywood, CA?',
    answer: 'Yes. Our technicians cover all of North Hollywood — the NoHo Arts District, Valley Village, Toluca Woods, Magnolia Park, Tujunga Village, NoHo West, and East North Hollywood. We serve ZIP codes 91601, 91602, 91605, and 91606. Call before noon for same-day afternoon service.',
  },
  {
    question: 'Can you work around production or entertainment industry schedules?',
    answer: "Yes. A lot of North Hollywood residents work in production, music, or the entertainment industry — which means schedules that don't fit a Mon–Fri 9-to-5 window. We have Saturday and Sunday availability (8am–7pm Sat, 9am–5pm Sun) and can work around call schedules, shoot days, and irregular availability. Call us and tell us your constraints — we'll find a time that works.",
  },
  {
    question: 'What is your diagnostic fee in North Hollywood?',
    answer: 'Our diagnostic fee is $89, waived when you proceed with the repair. We give you a complete written estimate before starting any work. Most North Hollywood repairs run $150–$400 depending on the appliance.',
  },
  {
    question: 'Do you repair dryer vents in North Hollywood?',
    answer: "Yes. Dryer vent cleaning is one of the most important appliance maintenance tasks in North Hollywood's older housing stock. A clogged vent is the leading cause of residential dryer fires — and takes two cycles where one should do. We clean and inspect dryer vents on every dryer call, and can do standalone vent cleaning on request.",
  },
  {
    question: 'Do you repair appliances in apartments and multi-family buildings in North Hollywood?',
    answer: "Yes. North Hollywood has a large rental population — garden apartments off Lankershim, new construction near the Metro B Line station, converted bungalow courts in the Arts District. We work with tenants, landlords, and property managers. If you're a renter, we can coordinate with your landlord directly if needed.",
  },
  {
    question: 'What warranty do you offer on appliance repairs in North Hollywood?',
    answer: 'All repairs come with a 90-day warranty on parts and labor. We use genuine OEM parts only. If the same issue returns within 90 days, we come back at no charge.',
  },
  {
    question: 'Do you also serve Burbank, Studio City, and Van Nuys?',
    answer: 'Yes. Our North Hollywood service area extends to Burbank, Studio City, Toluca Lake, Sherman Oaks, Van Nuys, Glendale, and Sun Valley. All are in our regular San Fernando Valley coverage area.',
  },
];

const nearbyCities = [
  { name: 'Burbank', slug: 'burbank' },
  { name: 'Glendale', slug: 'glendale' },
  { name: 'Pasadena', slug: 'pasadena' },
  { name: 'Los Angeles', slug: 'los-angeles' },
  { name: 'Silver Lake', slug: 'silver-lake' },
  { name: 'Los Feliz', slug: 'los-feliz' },
  { name: 'West Hollywood', slug: 'west-hollywood' },
  { name: 'Hollywood', slug: 'hollywood' },
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair"
    headlineCity="North Hollywood, CA"
    subheadline="NoHo Arts District, Valley Village, Toluca Woods, Magnolia Park, Tujunga Village. We cover all of North Hollywood — call us and we'll be there the same day. No 9-to-5 requirement. OEM parts, 90-day warranty."
    zips={zips}
    tier={2}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Same Day Appliance Repair in North Hollywood"
    paragraphs={introParagraphs}
    bookingTitle="North Hollywood Service"
    bookingSub="91601 · 91602 · 91605 · 91606"
  />

  <ServicesGrid
    cityName={cityName}
    headline="What We Repair in North Hollywood"
    services={services}
  />

  <CustomNarrative
    headline={dryerVentTipNarrative.headline}
    paragraphs={dryerVentTipNarrative.paragraphs}
    background="white"
  />

  <ServiceArea
    cityName={cityName}
    headline="All of North Hollywood — 91601, 91602, 91605, 91606"
    subheadline="Every neighborhood, every ZIP — from the Arts District to the Valley side"
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={keyStreets}
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Jobs in North Hollywood"
    subhead="Real calls from 91601–91606 — apartments, bungalows, and production schedules."
    jobs={recentJobs}
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="Why North Hollywood Calls Us Back"
    reasons={whyReasons}
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What North Hollywood Customers Are Saying"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Appliance Repair Costs in North Hollywood"
    subhead="Written estimate before we start. $89 diagnostic — waived with repair."
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="Questions North Hollywood Customers Ask"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby Areas"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance broken in North Hollywood?"
    body="NoHo Arts District · Valley Village · Toluca Woods · All of 91601–91606. Weekend available. $89 diagnostic waived with repair. 90-day warranty."
  />
</CityLayoutV2>
