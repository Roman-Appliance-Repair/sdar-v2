---
import Layout from '../layouts/Layout.astro';

const title = 'Privacy Policy | Same Day Appliance Repair';
const description = 'How HVAC 777 LLC (DBA Same Day Appliance Repair) collects, uses, and protects information from residents of California and beyond. CCPA and GDPR rights explained.';
const canonical = 'https://samedayappliance.repair/privacy-policy/';
const lastUpdated = 'April 1, 2026';
const effectiveDate = 'April 1, 2026';

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: title,
  url: canonical,
  description,
  inLanguage: 'en-US',
  dateModified: '2026-04-01',
  isPartOf: { '@type': 'WebSite', name: 'Same Day Appliance Repair', url: 'https://samedayappliance.repair/' },
  about: { '@type': 'Thing', name: 'Privacy Policy' },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://samedayappliance.repair/' },
    { '@type': 'ListItem', position: 2, name: 'Privacy Policy', item: canonical },
  ],
};
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">
    <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>

  <article class="legal">
    <div class="container legal-container">
      <p class="eyebrow">Legal · Privacy</p>
      <h1>Privacy Policy</h1>
      <p class="meta">Effective {effectiveDate} · Last updated {lastUpdated}</p>

      <p class="lede">
        HVAC 777 LLC, doing business as Same Day Appliance Repair ("SDAR", "we", "us", or "our"),
        operates <a href="https://samedayappliance.repair/">samedayappliance.repair</a> and
        dispatches appliance repair service across Los Angeles, Orange, Ventura, San Bernardino,
        and Riverside counties. This policy explains what personal information we collect, why
        we collect it, how we use and share it, and the rights you have under California and
        applicable law.
      </p>

      <nav class="toc" aria-label="Table of contents">
        <h2>On this page</h2>
        <ol>
          <li><a href="#who-we-are">Who we are</a></li>
          <li><a href="#info-collected">Information we collect</a></li>
          <li><a href="#how-we-use">How we use information</a></li>
          <li><a href="#sharing">How we share information</a></li>
          <li><a href="#cookies">Cookies &amp; tracking</a></li>
          <li><a href="#third-parties">Third-party services</a></li>
          <li><a href="#retention">Data retention</a></li>
          <li><a href="#ccpa">California (CCPA/CPRA) rights</a></li>
          <li><a href="#gdpr">EEA/UK (GDPR) rights</a></li>
          <li><a href="#security">Security</a></li>
          <li><a href="#children">Children's privacy</a></li>
          <li><a href="#changes">Changes to this policy</a></li>
          <li><a href="#contact">Contact</a></li>
        </ol>
      </nav>

      <h2 id="who-we-are">1. Who we are</h2>
      <p>
        We are a licensed California appliance repair company (CSLB C-20 License #1138898, BHGS
        Registration #A49573). Our mailing address is 6230 Wilshire Blvd Ste A PMB 2267, Los
        Angeles, CA 90048. For privacy questions, the designated contact is the SDAR office at
        <a href="mailto:privacy@samedayappliance.repair">privacy@samedayappliance.repair</a>.
      </p>
      <p>
        For the purposes of the EU and UK General Data Protection Regulations (GDPR and UK GDPR),
        HVAC 777 LLC is the "data controller" for information collected through the Site and in
        the course of dispatching and performing repairs.
      </p>

      <h2 id="info-collected">2. Information we collect</h2>

      <h3>2.1 Information you give us directly</h3>
      <p>
        When you call the dispatch line, submit the contact or booking form, text the on-call
        number, or email us, you may provide:
      </p>
      <ul>
        <li>Name, phone number, email address, and service address.</li>
        <li>Appliance make, model, serial number, symptom, and repair history.</li>
        <li>Photos or videos of the appliance that you send us voluntarily.</li>
        <li>Payment information when a repair is completed (processed by our card processor — we do not store full card numbers on our servers).</li>
        <li>Communications you have with our techs or office staff, including voicemails and SMS messages.</li>
      </ul>

      <h3>2.2 Information we collect automatically on the Site</h3>
      <p>
        When you visit samedayappliance.repair, our hosting provider and analytics tools record
        standard web-server data: IP address, browser type and version, operating system,
        referring URL, pages visited, time on page, and approximate location (city-level,
        derived from IP). Some of this is stored in cookies or local storage — see
        <a href="#cookies">section 5</a>.
      </p>

      <h3>2.3 Information from service delivery</h3>
      <p>
        When a tech arrives, we log the service address, the diagnostic findings, parts used,
        labor time, the technician assigned, and warranty status. We keep photos of the appliance
        before and after the repair for warranty and training purposes. This service history is
        tied to the phone number and address you provided.
      </p>

      <h3>2.4 Sensitive personal information</h3>
      <p>
        We do not knowingly collect categories the CCPA designates as "sensitive personal
        information" — Social Security numbers, driver's license numbers, precise geolocation,
        racial or ethnic origin, religious or philosophical beliefs, union membership, genetic
        data, biometric data, health information, or sexual orientation. If you volunteer any of
        these (for example, a doctor's note explaining an urgent repair), we process it only for
        the stated purpose and do not use it for any secondary purpose.
      </p>

      <h2 id="how-we-use">3. How we use information</h2>
      <p>We use the information above to:</p>
      <ul>
        <li>Dispatch a technician to the correct address with the right parts.</li>
        <li>Confirm arrival windows, send text updates, and follow up after the repair.</li>
        <li>Process payment and issue receipts, invoices, and warranty documentation.</li>
        <li>Honor the 90-day labor warranty — which requires us to retain the service record.</li>
        <li>Respond to questions, complaints, Better Business Bureau filings, and legal requests.</li>
        <li>Improve the Site, diagnose bugs, and measure which pages are useful.</li>
        <li>Send occasional service reminders (annual refrigerator cleaning, dryer-vent clearing) only if you opted in.</li>
        <li>Comply with tax, licensing, and contractor-law recordkeeping obligations (CSLB, BHGS, EPA 608).</li>
      </ul>
      <p>
        We do not sell your personal information. We do not share your personal information with
        advertisers for cross-context behavioral advertising as those terms are defined under the
        CCPA/CPRA.
      </p>

      <h2 id="sharing">4. How we share information</h2>
      <p>We share personal information only with the following categories of recipients:</p>
      <ul>
        <li><strong>Our field technicians and office staff</strong>, who need the address, appliance, and symptom to perform the work.</li>
        <li><strong>Sub-contractors</strong> we call in for specialty repairs (e.g. licensed electricians for hard-wired appliance faults). They receive only the information needed for that visit and are bound by written confidentiality terms.</li>
        <li><strong>Parts suppliers and OEM warranty desks</strong>, when a part is sent in for replacement under manufacturer warranty. They receive the appliance model, serial number, and the fault description.</li>
        <li><strong>Payment processors</strong> (e.g. Stripe, Square) that handle card transactions directly between you and them. We receive a tokenized receipt, not the full card.</li>
        <li><strong>Hosting, analytics, and communication providers</strong> listed in <a href="#third-parties">section 6</a>.</li>
        <li><strong>Regulators and courts</strong>, if we are compelled by a valid subpoena, court order, or by CSLB, BHGS, EPA, or tax-authority audit requirements.</li>
        <li><strong>A buyer</strong>, in the event of a sale, merger, or reorganization of HVAC 777 LLC. We would give reasonable notice on the Site before any transfer of customer data.</li>
      </ul>

      <h2 id="cookies">5. Cookies &amp; tracking</h2>
      <p>
        The Site uses cookies and similar technologies (local storage, pixel tags) to:
      </p>
      <ul>
        <li>Remember UI state like which mega-menu you last opened.</li>
        <li>Measure aggregate traffic and page performance (which pages are slow, which error out).</li>
        <li>Attribute the source of a booking (organic search, direct, referral) for business reporting.</li>
      </ul>
      <p>
        You can disable cookies in your browser, use private/incognito mode, or install a
        privacy extension. The Site works without cookies; a few conveniences like remembered
        menu state will not persist. We do not use cookies for cross-site advertising.
      </p>
      <p>
        If we add cookie-banner consent tooling in the future, this section will be updated with
        the specific categories and opt-out mechanism.
      </p>

      <h2 id="third-parties">6. Third-party services we use</h2>
      <p>
        The following vendors may process personal information on our behalf. Each has its own
        privacy policy and, where required, a Data Processing Agreement with us.
      </p>
      <ul>
        <li><strong>Cloudflare</strong> — hosting and content delivery. Processes IP addresses and request logs.</li>
        <li><strong>Google Analytics</strong> (if enabled) — aggregate traffic analytics. IP anonymization is enabled where supported.</li>
        <li><strong>Google Maps</strong> — to display service-area maps and directions. Tile requests expose IP and approximate location to Google.</li>
        <li><strong>Google Fonts</strong> — font delivery. May expose IP and user-agent.</li>
        <li><strong>SMS / voice providers</strong> (e.g. Twilio or the carrier's equivalent) — deliver dispatch texts and route inbound calls.</li>
        <li><strong>Email providers</strong> (e.g. Google Workspace) — send and receive customer-support email.</li>
        <li><strong>Card processors</strong> (e.g. Stripe, Square) — handle card payments.</li>
        <li><strong>Field-service CRM</strong> — track dispatch, invoicing, and technician routing.</li>
      </ul>
      <p>
        The specific list may change as vendors are added or swapped. Material additions will be
        reflected in an update to this page.
      </p>

      <h2 id="retention">7. Data retention</h2>
      <p>We keep records for the periods below, then delete or anonymize them:</p>
      <ul>
        <li><strong>Service history &amp; invoices</strong> — 7 years (California contractor &amp; tax recordkeeping).</li>
        <li><strong>Warranty files</strong> — the length of the warranty plus one year.</li>
        <li><strong>Dispatch call recordings &amp; voicemails</strong> — 90 days, unless flagged for a disputed repair.</li>
        <li><strong>Marketing email / SMS opt-in lists</strong> — until you unsubscribe or request deletion.</li>
        <li><strong>Web server &amp; analytics logs</strong> — typically 14 to 26 months in aggregate form.</li>
      </ul>

      <h2 id="ccpa">8. California residents — CCPA &amp; CPRA rights</h2>
      <p>
        If you are a California resident, you have the following rights under the California
        Consumer Privacy Act as amended by the CPRA:
      </p>
      <ul>
        <li><strong>Right to know</strong> what personal information we've collected about you, the categories of sources, the purposes, and who we've shared it with in the last 12 months.</li>
        <li><strong>Right to correct</strong> inaccurate personal information.</li>
        <li><strong>Right to delete</strong> personal information, subject to recordkeeping exceptions (warranty, tax, contractor law).</li>
        <li><strong>Right to limit use of sensitive personal information</strong> — we do not use sensitive information for secondary purposes, so this right is honored by default.</li>
        <li><strong>Right to opt out of the sale or sharing</strong> of personal information for cross-context behavioral advertising — we do not sell or share for those purposes, so there is nothing to opt out of.</li>
        <li><strong>Right to non-discrimination</strong> — we will not deny service, charge a different price, or provide a different level of service because you exercised a privacy right.</li>
      </ul>
      <p>
        To exercise any of these rights, email
        <a href="mailto:privacy@samedayappliance.repair">privacy@samedayappliance.repair</a> or
        call <a href="tel:+14243250520">(424) 325-0520</a> and ask for the privacy officer. We
        verify the request by confirming two to three data points from your prior service
        history (phone, address, last appliance serviced). We respond within 45 days and may
        extend once for another 45 days if the request is complex, with notice.
      </p>
      <p>
        You may designate an authorized agent to submit a request on your behalf with a signed
        permission and ID verification.
      </p>

      <h2 id="gdpr">9. EEA and UK residents — GDPR rights</h2>
      <p>
        If you are in the European Economic Area, the United Kingdom, or Switzerland, you have
        the following rights under the GDPR and UK GDPR:
      </p>
      <ul>
        <li>Access, rectification, erasure, restriction of processing, and portability of your data.</li>
        <li>The right to object to processing based on our legitimate interests.</li>
        <li>The right to withdraw consent where processing is based on consent (e.g. marketing email).</li>
        <li>The right to lodge a complaint with your national supervisory authority.</li>
      </ul>
      <p>
        Our legal bases for processing are: <em>contract</em> (performing the repair and warranty
        you requested), <em>legitimate interests</em> (running and improving the business, fraud
        prevention, website security), <em>legal obligation</em> (tax, licensing, recordkeeping),
        and <em>consent</em> (marketing messages).
      </p>
      <p>
        Because we operate primarily from California, personal information may be transferred to
        and stored in the United States. Where required, we rely on Standard Contractual Clauses
        or other approved transfer mechanisms.
      </p>

      <h2 id="security">10. Security</h2>
      <p>
        We use TLS encryption on the Site, access controls on dispatch software, device
        encryption on work phones and tablets, and tokenized payment processing. No method of
        transmission or storage is perfectly secure — if you notice a vulnerability or suspect a
        breach, email <a href="mailto:security@samedayappliance.repair">security@samedayappliance.repair</a>
        and we'll respond within one business day.
      </p>

      <h2 id="children">11. Children's privacy</h2>
      <p>
        The Site is intended for adults booking appliance service for their own homes or
        businesses. We do not knowingly collect information from children under 13, and we do
        not target services or marketing to minors. If you believe a child has provided us with
        personal information, email the privacy address above and we'll delete it.
      </p>

      <h2 id="changes">12. Changes to this policy</h2>
      <p>
        We update this page when we change vendors, add new data uses, or need to reflect a
        change in the law. The "Last updated" date at the top of the page reflects the most
        recent revision. Material changes — adding a new category of data, a new sharing
        recipient, or a new use — will be flagged at the top of the page for at least 30 days.
      </p>

      <h2 id="contact">13. Contact</h2>
      <address class="legal-contact">
        HVAC 777 LLC<br />
        DBA Same Day Appliance Repair<br />
        6230 Wilshire Blvd Ste A PMB 2267<br />
        Los Angeles, CA 90048<br />
        <br />
        Email: <a href="mailto:privacy@samedayappliance.repair">privacy@samedayappliance.repair</a><br />
        Phone: <a href="tel:+14243250520">(424) 325-0520</a><br />
        General contact: <a href="/contact/">/contact/</a>
      </address>
    </div>
  </article>
</Layout>

<style>
  .legal { padding: 72px 0 96px; }
  .legal-container { max-width: 780px; }
  .eyebrow { font-size: 12px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: var(--red); margin-bottom: 16px; }
  h1 { font-size: clamp(2rem, 5vw, 2.8rem); line-height: 1.1; margin: 0 0 12px; }
  .meta { font-size: 13px; color: var(--muted); margin-bottom: 32px; }
  .lede { font-size: 17px; line-height: 1.7; color: #cccccc; margin-bottom: 28px; }

  h2 { font-size: clamp(1.3rem, 3vw, 1.7rem); margin: 40px 0 14px; padding-top: 8px; border-top: 1px solid var(--border); line-height: 1.2; }
  h2:first-of-type { border-top: none; padding-top: 0; }
  h3 { font-size: 17px; font-family: var(--font-body); font-weight: 600; margin: 24px 0 10px; }

  p, li { font-size: 15px; line-height: 1.75; color: #cccccc; }
  p { margin-bottom: 14px; }
  ul, ol { padding-left: 22px; margin-bottom: 14px; }
  li { margin-bottom: 8px; }
  strong { color: #ffffff; font-weight: 600; }
  em { font-style: italic; }
  a { color: var(--red); text-decoration: underline; text-underline-offset: 2px; }
  a:hover { color: #ffffff; }

  .toc { padding: 20px 24px; background: var(--gray); border: 1px solid var(--border); border-radius: 6px; margin-bottom: 36px; }
  .toc h2 { font-size: 13px; text-transform: uppercase; letter-spacing: 0.12em; color: var(--red); margin: 0 0 10px; padding: 0; border: none; }
  .toc ol { column-count: 2; column-gap: 24px; margin: 0; padding-left: 22px; }
  .toc li { font-size: 14px; margin-bottom: 4px; break-inside: avoid; color: var(--text); }
  .toc a { color: var(--text); text-decoration: none; }
  .toc a:hover { color: var(--red); }
  @media (max-width: 640px) { .toc ol { column-count: 1; } }

  .legal-contact { font-style: normal; padding: 20px 24px; background: var(--gray); border-radius: 6px; font-size: 15px; line-height: 1.8; color: var(--text); }
  .legal-contact a:hover { color: var(--red-dark); }
</style>
