---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

const citySlug = 'monterey-park';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = "Monterey Park";
const zips = ['91754', '91755'];

const phoneRaw = `+1${branch.phone.replace(/\D/g, '')}`;

const title = `Appliance Repair Monterey Park CA | Same Day | ${branch.phone}`;
const description = "Same-day appliance repair in Monterey Park, CA. Sub-Zero, Wolf & all brands. $89 dx — waived with repair.";
const canonical = 'https://samedayappliance.repair/monterey-park/';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { '@type': 'City', name: 'Monterey Park', sameAs: 'https://en.wikipedia.org/wiki/Monterey_Park,_California' },
    { '@type': 'Place', name: 'Monterey Highlands' },
    { '@type': 'Place', name: 'Atlantic Times Square' },
    { '@type': 'Place', name: 'Monterey Vista' }
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$',
  license: 'BHGS #A49573'

};

const introParagraphs = [
  "Monterey Park sits at the entrance to the West San Gabriel Valley — bordered by East LA to the south, Alhambra to the west, San Gabriel to the east. Population around 60,000, two ZIP codes (91754 and 91755), and a strong residential character that mixes hillside single-family homes (Monterey Highlands, Monterey Vista) with downtown condos near Atlantic Times Square and older duplexes through East Monterey Park.",
  "The appliance brand mix here is meaningfully different from Pasadena or San Marino. Monterey Park has one of LA County's largest Asian-American populations (Chinese-American, Taiwanese-American, Vietnamese-American communities have been concentrated here since the 1980s), and Samsung Bespoke + Family Hub kitchens are the dominant luxury install — more so than Sub-Zero or Wolf, which tend to dominate Westside LA. We carry Samsung OEM parts (auger motors, ice-maker assemblies, French-door hinge kits, control boards) in our Pasadena truck stock for that reason. LG is a strong second-place install, especially on the laundry side.",
  `Monterey Park is on our regular West San Gabriel Valley route — Pasadena branch dispatches technicians through Monterey Park, Alhambra, San Gabriel, and Temple City daily. No distance surcharge, $89 residential diagnostic same as anywhere else we serve. Call <a href="tel:${phoneRaw}">${branch.phone}</a> — someone with our actual Pasadena schedule picks up.`
];

const services = [
  { icon: '❄️', name: 'Refrigerator Repair', slug: 'refrigerator' },
  { icon: '🫧', name: 'Washer Repair', slug: 'washer' },
  { icon: '💨', name: 'Dryer Repair', slug: 'dryer' },
  { icon: '🍽️', name: 'Dishwasher Repair', slug: 'dishwasher' },
  { icon: '🔥', name: 'Oven & Range Repair', slug: 'oven' },
  { icon: '🍳', name: 'Stove Repair', slug: 'stove' },
  { icon: '📻', name: 'Microwave Repair', slug: 'microwave' },
  { icon: '🧊', name: 'Ice Maker Repair', slug: 'ice-maker' },
  { icon: '🍷', name: 'Wine Cooler Repair', slug: 'wine-cooler' },
  { icon: '🧊', name: 'Freezer Repair', slug: 'freezer' },
  { icon: '🗑️', name: 'Garbage Disposal Repair', slug: 'garbage-disposal' },
  { icon: '♨️', name: 'Cooktop Repair', slug: 'cooktop' }
];

const neighborhoods = [
  { name: 'Monterey Highlands', zip: '91754' },
  { name: 'Monterey Vista', zip: '91754' },
  { name: 'Atlantic Times Square / Downtown', zip: '91754' },
  { name: 'East Monterey Park', zip: '91755' },
  { name: 'Cascades Park area', zip: '91754' },
  { name: 'South Monterey Park', zip: '91755' }
];

const recentJobs = [
  {
    appliance: 'Samsung French-door fridge',
    location: 'Monterey Highlands',
    quote: "Samsung French-door fridge — ice maker not cycling",
    description: "Samsung RF28R7351SR in a Monterey Highlands single-family home — ice maker had stopped producing ice; refrigerator and freezer holding temp normally. Diagnosed as failed ice-maker auger motor (the rotational motor that cycles the cubes out of the mold). Replaced with Samsung OEM motor, tested through three cycles, harvest verified. Monterey Highlands has a high concentration of Samsung Bespoke and Family Hub kitchens — we see the auger-motor failure pattern at 4-6 year mark on these models. Asian-American households favor Samsung in this neighborhood; we keep the OEM auger motor in truck stock for that reason.",
    outcome: '✓ Same day · Samsung OEM ice-maker auger motor · 1.5 hours'
  },
  {
    appliance: 'Bosch dishwasher',
    location: 'Atlantic Times Square / Downtown',
    quote: "Bosch dishwasher — E15 error, water collecting in base",
    description: "Bosch SHX-series dishwasher in a downtown Monterey Park condo near Atlantic Times Square — E15 leak-detection error halting the cycle. Water had collected in the unit's base safety pan, triggering the leak sensor. Found a hairline crack in the lower hose connection at the pump intake — small leak that had accumulated over weeks. Replaced the connection hose, dried the base pan, reset the leak sensor, ran two test cycles. Bosch E15 is one of the most-misdiagnosed dishwasher errors in our field; it's a leak detection alert, not a control board failure. Often the fix is a $40 hose, not a $400 board.",
    outcome: '✓ Same day · Bosch OEM lower hose connection · 1.5 hours'
  },
  {
    appliance: 'Whirlpool top-load washer',
    location: 'East Monterey Park',
    quote: "Whirlpool top-load washer — won't drain or spin",
    description: "Whirlpool top-load washer in an East Monterey Park duplex — wash cycle completed but water sitting in the drum, no spin. Drain pump was healthy; the lid switch had failed (older Whirlpool top-loaders use a mechanical lid switch as a safety interlock — without it the spin cycle won't engage). Replaced the lid switch, tested through full cycle. Fast, cheap fix once diagnosed correctly. The previous repair company had quoted a control-board replacement at $400+ — the actual issue was a $35 lid switch.",
    outcome: '✓ Same day · Whirlpool OEM lid switch · 1 hour'
  }
];

const whyReasons = [
  {
    iconKey: 'parts' as const,
    title: 'Samsung OEM parts on the truck',
    body: "Monterey Park's install base skews heavily Samsung — French-door refrigerators, Bespoke kitchens, Family Hub. Our Pasadena techs carry Samsung-specific OEM parts (auger motors, ice-maker assemblies, French-door hinges) so we don't have to roll a parts order on routine Samsung calls."
  },
  {
    iconKey: 'team' as const,
    title: 'West San Gabriel Valley regular route',
    body: "Pasadena branch runs Monterey Park, Alhambra, San Gabriel, Temple City daily. Same-day service is real here, not a sales claim. No distance surcharge."
  },
  {
    iconKey: 'shield' as const,
    title: 'Honest diagnostic before parts swap',
    body: "Bosch E15, Whirlpool no-spin, Samsung ice-maker faults — all of these get mis-diagnosed by less-experienced technicians as control-board failures requiring expensive board replacement. We test the actual subsystems first. Often the fix is a $35 lid switch or a $40 hose, not a $400 board."
  },
  {
    iconKey: 'clock' as const,
    title: 'Both ZIPs, every neighborhood',
    body: "91754 and 91755, Monterey Highlands hillside to East Monterey Park duplexes — same dispatch, same diagnostic, same warranty across the city."
  }
];

const pricingTiers = [
  { appliance: 'Diagnostic Fee', range: '$89', note: 'No distance surcharge · Credited toward repair · Written estimate' },
  { appliance: 'Standard Repair', range: '$150–$350', note: 'Parts + labor · OEM parts · 90-day warranty' },
  { appliance: 'Luxury Brand Repair', range: '$250–$600+', note: 'Sub-Zero, Wolf, Thermador, Viking · OEM parts' },
  { appliance: 'Warranty', range: '90 Days', note: 'All repairs · Parts & labor · No-charge callback', featured: true }
];

const faqs = [
  {
    question: 'Do you offer same-day appliance repair in Monterey Park?',
    answer: "Yes — Monterey Park is a regular service city for our Pasadena branch. We run routes through the West San Gabriel Valley including Monterey Park, Alhambra, San Gabriel, Temple City, and Arcadia daily. Call before noon and we can typically dispatch a technician that afternoon. Coverage spans both ZIPs (91754 and 91755) and the major neighborhoods from Monterey Highlands to Atlantic Times Square."
  },
  {
    question: 'What appliance brands do you service in Monterey Park?',
    answer: "All major brands including the ones we see most in Monterey Park: Samsung (Bespoke + Family Hub are especially common in Monterey Highlands), LG, Whirlpool, GE, Maytag, KitchenAid, Bosch, Frigidaire. For luxury kitchens we cover Sub-Zero, Wolf, Thermador, Miele, and Viking. Monterey Park has a particularly strong Samsung install base — Asian-American households here tend to favor Samsung — and we keep Samsung OEM parts (auger motors, control boards, ice-maker assemblies) in truck stock for that reason."
  },
  {
    question: 'Do you charge a distance surcharge for Monterey Park?',
    answer: "No. Monterey Park is on the regular Pasadena-branch route through the West San Gabriel Valley. The $89 residential diagnostic is the same here as in Pasadena or Arcadia. What we quote is what you pay."
  },
  {
    question: 'Which Monterey Park neighborhoods do you cover?',
    answer: "All of them — Monterey Highlands and Monterey Vista (the residential west side of the city), Atlantic Times Square and downtown (condos + commercial mix), East Monterey Park (older single-family + duplexes), Cascades Park area, and South Monterey Park bordering East LA. Both ZIPs (91754 and 91755) are routine service areas for us."
  },
  {
    question: 'What is your warranty on Monterey Park repairs?',
    answer: "All repairs carry a 90-day warranty on parts and labor. If the same issue returns within 90 days, we come back at no additional charge. BHGS #A49573, BBB accredited."
  }
];

const nearbyCities = [
  { name: 'Pasadena', slug: 'pasadena' },
  { name: 'Alhambra', slug: 'alhambra' },
  { name: 'South Pasadena', slug: 'south-pasadena' },
  { name: 'Arcadia', slug: 'arcadia' },
  { name: 'San Marino', slug: 'san-marino' },
  { name: 'Highland Park', slug: 'highland-park' }
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair in"
    headlineCity="Monterey Park, CA"
    subheadline="Same-day service across Monterey Highlands, Atlantic Times Square, and East Monterey Park. Samsung, LG, Sub-Zero, Wolf, and all major brands. $89 diagnostic — waived with repair."
    zips={zips}
    tier={3}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Monterey Park — West San Gabriel Valley gateway, Samsung-heavy install base"
    paragraphs={introParagraphs}
    bookingTitle="Monterey Park Service"
    bookingSub="Available Today"
  />

  <ServicesGrid
    cityName={cityName}
    headline="Appliance Repair Services in Monterey Park"
    services={services}
  />

  <ServiceArea
    cityName={cityName}
    headline="Monterey Park Neighborhoods We Service"
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={[]}
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Repairs in Monterey Park"
    jobs={recentJobs}
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="Why Monterey Park Residents Call Us"
    reasons={whyReasons}
  />

  <PricingCards
    cityName={cityName}
    headline="Repair Pricing in Monterey Park"
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="Frequently Asked Questions — Monterey Park"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby West San Gabriel Valley Cities"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Schedule Your Monterey Park Repair Today"
    body="Same-day service, both ZIPs, all neighborhoods. Samsung specialty + all major brands."
  />
</CityLayoutV2>
