  <!-- =====================================================================
       BOTTOM CTA
       ===================================================================== -->
  <section class="wh-bottom-cta">
    <div class="container">
      <div class="bottom-cta__inner">
        <div class="bottom-cta__text">
          <h2>Need Appliance Repair in West Hollywood Today?</h2>
          <p>Call now — same-day service available for most repairs. Diagnostic fee $89, waived with repair. 90-day warranty on all work.</p>
        </div>
        <div class="bottom-cta__actions">
          <a href={`tel:${city.phoneRaw}`} class="btn-primary btn-large">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.29h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            {city.phone}
          </a>
          <a href="/book/" class="btn-secondary btn-large">Book Online</a>
        </div>
        <div class="bottom-cta__nap">
          <span>Same Day Appliance Repair</span>
          <span>·</span>
          <span>8746 Rangely Ave, West Hollywood, CA 90048</span>
          <span>·</span>
          <a href={`mailto:${city.email}`}>{city.email}</a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* =========================================================
     GLOBAL TOKENS — West Hollywood page
     ========================================================= */
  :root {
    --wh-red: #C8102E;
    --wh-black: #0a0a0a;
    --wh-dark: #111111;
    --wh-gray: #f5f5f5;
    --wh-border: #e2e2e2;
    --wh-text: #1a1a1a;
    --wh-muted: #6b6b6b;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* =========================================================
     HERO
     ========================================================= */
  .wh-hero {
    background: var(--wh-black);
    color: white;
    padding: 80px 0 60px;
  }

  .wh-hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 60px;
    align-items: center;
  }

  .wh-hero__eyebrow {
    font-size: 13px;
    font-weight: 500;
    color: var(--wh-red);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  .wh-hero__h1 {
    font-size: clamp(36px, 5vw, 52px);
    font-weight: 700;
    line-height: 1.1;
    margin-bottom: 20px;
    color: white;
  }

  .wh-hero__accent {
    color: var(--wh-red);
  }

  .wh-hero__sub {
    font-size: 17px;
    line-height: 1.6;
    color: rgba(255,255,255,0.75);
    margin-bottom: 32px;
    max-width: 520px;
  }

  .wh-hero__ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 24px;
  }

  .wh-hero__rating {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .stars { color: #FFD700; font-size: 18px; letter-spacing: 2px; }
  .rating-text { font-size: 14px; color: rgba(255,255,255,0.7); }

  .wh-hero__img-wrap img {
    width: 100%;
    height: auto;
    border-radius: 12px;
    object-fit: cover;
  }

  /* =========================================================
     BUTTONS
     ========================================================= */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--wh-red);
    color: white;
    padding: 14px 28px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 16px;
    text-decoration: none;
    transition: background 0.2s;
  }
  .btn-primary:hover { background: #a50e25; }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: transparent;
    color: white;
    padding: 14px 28px;
    border-radius: 8px;
    font-weight: 600;
    font-size: 16px;
    text-decoration: none;
    border: 1.5px solid rgba(255,255,255,0.35);
    transition: border-color 0.2s, background 0.2s;
  }
  .btn-secondary:hover { border-color: white; background: rgba(255,255,255,0.08); }

  .btn-large { padding: 16px 36px; font-size: 17px; }

  /* Dark background btn-secondary — for bottom CTA */
  .wh-bottom-cta .btn-secondary {
    color: var(--wh-text);
    border-color: var(--wh-border);
  }
  .wh-bottom-cta .btn-secondary:hover { background: var(--wh-gray); }

  /* =========================================================
     TRUST BAR
     ========================================================= */
  .trust-bar {
    background: var(--wh-red);
    padding: 16px 0;
  }

  .trust-bar__inner {
    display: flex;
    gap: 0;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 8px;
    color: white;
    font-size: 14px;
    font-weight: 500;
  }

  /* =========================================================
     INTRO
     ========================================================= */
  .wh-intro { padding: 72px 0; background: white; }

  .wh-intro__inner {
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 60px;
    align-items: start;
  }

  .wh-intro__text h2 {
    font-size: 30px;
    font-weight: 700;
    color: var(--wh-black);
    margin-bottom: 20px;
  }

  .wh-intro__text p {
    font-size: 16px;
    line-height: 1.7;
    color: var(--wh-text);
    margin-bottom: 16px;
  }

  .cta-box {
    background: var(--wh-black);
    color: white;
    border-radius: 12px;
    padding: 32px;
    text-align: center;
    position: sticky;
    top: 80px;
  }

  .cta-box__title { font-size: 18px; font-weight: 700; margin-bottom: 4px; }
  .cta-box__sub { font-size: 13px; color: rgba(255,255,255,0.6); margin-bottom: 24px; }
  .cta-box__phone {
    display: block;
    font-size: 24px;
    font-weight: 700;
    color: var(--wh-red);
    text-decoration: none;
    margin-bottom: 12px;
  }
  .cta-box__book {
    display: block;
    font-size: 15px;
    color: white;
    text-decoration: none;
    padding: 12px;
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 8px;
    margin-bottom: 16px;
    transition: background 0.2s;
  }
  .cta-box__book:hover { background: rgba(255,255,255,0.08); }
  .cta-box__hours { font-size: 12px; color: rgba(255,255,255,0.5); }

  /* =========================================================
     SECTION HEADINGS
     ========================================================= */
  .section-title {
    font-size: 30px;
    font-weight: 700;
    color: var(--wh-black);
    margin-bottom: 8px;
    text-align: center;
  }

  .section-sub {
    font-size: 16px;
    color: var(--wh-muted);
    text-align: center;
    margin-bottom: 40px;
  }

  /* =========================================================
     SERVICES GRID
     ========================================================= */
  .wh-services {
    padding: 72px 0;
    background: var(--wh-gray);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }

  .service-card {
    background: white;
    border: 1px solid var(--wh-border);
    border-radius: 12px;
    padding: 24px 20px;
    text-decoration: none;
    color: var(--wh-text);
    transition: box-shadow 0.2s, transform 0.2s;
    display: block;
  }

  .service-card:hover {
    box-shadow: 0 4px 24px rgba(0,0,0,0.1);
    transform: translateY(-2px);
  }

  .service-card__icon { font-size: 28px; margin-bottom: 10px; }
  .service-card__name { font-size: 16px; font-weight: 600; color: var(--wh-black); margin-bottom: 8px; }
  .service-card__issues { font-size: 13px; color: var(--wh-muted); line-height: 1.5; margin-bottom: 8px; }
  .service-card__brands { font-size: 12px; color: var(--wh-muted); margin-bottom: 12px; }
  .service-card__cta { font-size: 13px; color: var(--wh-red); font-weight: 500; }

  /* =========================================================
     LUXURY BRANDS
     ========================================================= */
  .wh-luxury {
    padding: 72px 0;
    background: var(--wh-black);
    color: white;
  }

  .luxury-inner {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 60px;
    align-items: center;
  }

  .luxury-eyebrow {
    font-size: 13px;
    font-weight: 500;
    color: var(--wh-red);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .luxury-text h2 {
    font-size: 30px;
    font-weight: 700;
    color: white;
    margin-bottom: 20px;
  }

  .luxury-text p {
    font-size: 15px;
    line-height: 1.7;
    color: rgba(255,255,255,0.75);
    margin-bottom: 16px;
  }

  .luxury-brands-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 24px;
  }

  .luxury-brand {
    padding: 6px 14px;
    border: 1px solid rgba(255,255,255,0.2);
    border-radius: 20px;
    font-size: 13px;
    color: rgba(255,255,255,0.8);
  }

  .luxury-stats {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .stat-card {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 12px;
    padding: 24px;
    text-align: center;
  }

