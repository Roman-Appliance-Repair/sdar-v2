---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import CustomNarrative from '../components/cities/v2/CustomNarrative.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

const citySlug = 'ventura';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = "Ventura";
const zips = ["93001", "93003", "93004"];

const phone = branch.phone;
const phoneRaw = `+1${phone.replace(/\D/g, '')}`;

const title = `Appliance Repair Ventura CA | Same Day Service | ${phone}`;
const description = "Same-day appliance repair in Ventura, CA. Harbor, Midtown, Pierpont Beach, East Ventura. Salt air expertise. Sub-Zero, Wolf & all brands. OEM parts, 90-day warranty. $89 diagnostic.";
const canonical = "https://samedayappliance.repair/ventura/";

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  name: branch.fullName,
  image: "https://samedayappliance.repair/images/logo.webp",
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { "@type": "City", name: "Ventura", sameAs: "https://en.wikipedia.org/wiki/Ventura,_California" },
    { "@type": "Place", name: "Ventura Harbor" },
    { "@type": "Place", name: "Pierpont Beach" },
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: "$$",
  license: "CA BHGS #A49573"

};

const introParagraphs = [
  "Ventura is one of the more characterful cities in our service area — an actual coastal city with a working harbor, a historic Mission district, older neighborhoods with real history, and newer developments spreading east toward Camarillo. It's not a planned community and it's not trying to be. The appliances here reflect that range.",
  "The harbor area, Pierpont Beach, and Ventura Keys are exposed to Pacific salt air in the same way that Monarch Beach in Dana Point and Newport Peninsula are. Salt particulate deposits on condenser coils, corrodes range igniter electrodes, and degrades door gaskets. Harbor-adjacent homes in Ventura need the same 6-month coil cleaning cycle we recommend in Newport Beach — not because we're selling maintenance, but because the Pacific doesn't distinguish between zip codes.",
  "The older housing stock downtown and in the Mission District brings its own considerations. Appliances in these homes may be on their second or third owner. We repair them as long as the economics make sense and tell you when they don't. Honest assessment, written estimate, no pressure.",
  `Diagnostic fee is $89, credited toward the repair. Call <a href="tel:${phoneRaw}">${phone}</a>.`,
];

const services = [
  { icon: '❄️', name: 'Refrigerator Repair', slug: 'refrigerator' },
  { icon: '🫧', name: 'Washer Repair', slug: 'washer' },
  { icon: '💨', name: 'Dryer Repair', slug: 'dryer' },
  { icon: '🍽️', name: 'Dishwasher Repair', slug: 'dishwasher' },
  { icon: '🔥', name: 'Oven & Range Repair', slug: 'oven' },
  { icon: '♨️', name: 'Cooktop Repair', slug: 'cooktop' },
  { icon: '🧊', name: 'Freezer Repair', slug: 'freezer' },
  { icon: '🍷', name: 'Wine Cooler Repair', slug: 'wine-cooler' },
];

const venturaContextNarrative = {
  headline: "Three Things That Make Ventura Different for Appliance Repair",
  paragraphs: [],
  subSections: [
    {
      title: "1. The harbor and ocean are close — and your appliances know it",
      paragraphs: [
        "Ventura Harbor sits at the western edge of the city, and the Pacific runs along the entire southern boundary. The marine air that rolls off that water carries salt particulate that deposits on condenser coils, corrodes metal contacts, and accelerates wear on appliance components. Harbor-area homes, Pierpont Beach, and Ventura Keys see the most exposure. If your refrigerator is within a mile of the water in Ventura, the 12-month coil cleaning recommendation doesn't apply — we've seen 4-6 month cycles produce the same buildup that takes 12 months inland.",
      ]
    },
    {
      title: "2. The old housing stock has character — and age",
      paragraphs: [
        "The neighborhoods around downtown Ventura, the Mission, and the older flatland streets have homes that were built when appliances were built to last. Some of those older appliances are still running — and worth fixing. Others have been replaced with newer units that have their own failure patterns. We work on both. When a repair doesn't make economic sense, we'll tell you before we start, not after.",
      ]
    },
    {
      title: "3. Viking igniter misdiagnosis is common here",
      paragraphs: [
        "The Ondulando neighborhood and several Ventura hillside communities have a high density of Viking ranges. Viking oven F5 errors almost always mean a weak igniter — a $120-150 OEM part. We've seen multiple Ventura homeowners quoted control board replacements ($600+) for this exact failure. We diagnose correctly and charge you for the part that actually failed.",
      ]
    },
  ]
};

const neighborhoods = [
  { name: 'Ventura Harbor area', zip: '93001', featured: true },
  { name: 'Pierpont Beach', zip: '93001', featured: true },
  { name: 'Downtown / Mission District', zip: '93001' },
  { name: 'Midtown Ventura', zip: '93003' },
  { name: 'East Ventura', zip: '93004' },
  { name: 'Ondulando', zip: '93003' },
  { name: 'Poinsettia area', zip: '93004' },
  { name: 'Saticoy area', zip: '93004' },
  { name: 'Ventura Keys', zip: '93001' },
  { name: 'Westpark', zip: '93003' },
];

const recentJobs = [
  {
    appliance: 'GE Profile Refrigerator',
    location: 'Pierpont Beach',
    quote: '"GE refrigerator — not cooling, frost buildup on back wall"',
    description: "GE Profile PFE28KYNFS in a Pierpont Beach home steps from the water — not cooling properly, frost visible on the back interior wall. Defrost heater had failed, allowing ice to build up on the evaporator coil and block airflow. After defrosting the coil, we replaced the defrost heater assembly and the defrost thermostat, which was also reading out of spec. Also cleaned the condenser coils — significant salt particulate buildup from the harbor-adjacent location. Complete repair in two hours. The coastal proximity means salt air gets into the coil compartment; we explained the maintenance cycle going forward.",
    outcome: '✓ Same day · GE OEM defrost heater + thermostat · 2 hours'
  },
  {
    appliance: 'LG Front-Loader Washer',
    location: 'Midtown Ventura',
    quote: '"LG washer — DE1 error, door won\'t lock"',
    description: "LG front-loader WM3900HWA — DE1 door latch error, cycle refusing to start. Door latch assembly had failed — the plastic latch tab had cracked from repeated use. Replaced the full door latch assembly with an OEM LG part. While we were there, the customer mentioned the machine had been making a slight grinding sound for two months — checked the drum bearing, found early wear but not yet causing issues. Noted it for the homeowner: this one has maybe 6-12 months before it needs attention. Better to know than to be surprised.",
    outcome: '✓ Same day · LG OEM door latch assembly · 1 hour'
  },
  {
    appliance: 'Viking Range',
    location: 'Ondulando',
    quote: '"Viking range — oven not preheating, F5 error code"',
    description: "Viking VGIC5366BSS — F5 error on the oven display, preheating stalling at 180°F. Bake igniter had weakened and was failing to draw sufficient current to open the gas valve. This is the most common Viking oven failure and one we see regularly. Replaced the oven igniter with an OEM Viking part, tested preheat cycle to 350°F, 400°F, and 450°F before leaving. Customer had been told by another company it was the control board — a $600+ part. It was the igniter — a $120 part.",
    outcome: '✓ Same day · Viking OEM oven igniter · 1.5 hours'
  },
  {
    appliance: 'Bosch Dishwasher',
    location: 'East Ventura',
    quote: '"Bosch dishwasher — E22 filter error, not draining completely"',
    description: "Bosch SHPM88Z75N — E22 filter blocked code, 2 inches of water remaining after cycle. Filter and mesh screen completely clogged with food debris. Cleaned the filter assembly, checked the drain pump impeller (clear), ran diagnostic cycle. Hard water mineral deposits on the spray arm ports were also contributing to poor performance — descaled the upper and lower arms. Ventura's water hardness isn't as extreme as Simi Valley but it's enough to affect dishwasher performance over time without regular maintenance.",
    outcome: '✓ Same day · Filter cleaning + descale service · 1 hour'
  },
];

const whyReasons = [
  {
    iconKey: 'team' as const,
    title: 'Coastal experience',
    body: "We know what Ventura Harbor salt air does to condenser coils and range electrodes. We find it, explain it, and give you a maintenance plan that fits where you actually live."
  },
  {
    iconKey: 'parts' as const,
    title: 'We diagnose correctly',
    body: 'Viking F5 errors are igniters, not control boards. GE frost buildup is a defrost heater, not a sealed system problem. We find the actual failed component before recommending parts.'
  },
  {
    iconKey: 'clock' as const,
    title: 'Honest on old appliances',
    body: "Ventura has older housing stock. When an old appliance comes up for repair, we tell you if it's worth fixing — and what the repair will actually cost — before we start."
  },
  {
    iconKey: 'shield' as const,
    title: '90-day warranty, standard',
    body: 'Every repair includes a 90-day warranty on parts and labor. Same issue returns — we come back at no charge.'
  },
];

const testimonials = [
  {
    stars: 5,
    text: '"GE fridge near Pierpont Beach — frost buildup inside, not cooling. They fixed the defrost heater and cleaned the coils. Explained the salt air issue for harbor-area homes. Straightforward, fast, done right."',
    author: '— Laura M., Pierpont Beach'
  },
  {
    stars: 5,
    text: '"Viking range F5 error. Another company quoted me a control board at $650. Same Day came out, said it was the igniter, fixed it for $180. Tested every temperature setting before leaving. This is what honest service looks like."',
    author: '— Michael R., Ondulando'
  },
  {
    stars: 5,
    text: '"LG washer door latch. Fast, same day, clean, professional. Technician noticed the drum bearing starting to wear and flagged it — no pressure, just information. That kind of service builds trust."',
    author: '— Sandra K., Midtown Ventura'
  },
];

const pricingTiers = [
  { appliance: 'Diagnostic Fee', range: '$89', note: 'Credited toward repair · Written estimate · Coastal assessment included' },
  { appliance: 'Standard Repair', range: '$150–$380', note: 'Parts + labor · OEM parts · 90-day warranty' },
  { appliance: 'Luxury Brand Repair', range: '$250–$600+', note: 'Sub-Zero, Wolf, Viking, Thermador · OEM parts' },
  { appliance: 'Warranty', range: '90 Days', note: 'All repairs · Parts & labor · No-charge callback', featured: true },
];

const faqs = [
  {
    question: "Do you offer same-day appliance repair in Ventura?",
    answer: "Yes — Ventura is covered by our Thousand Oaks branch. We run regular Ventura County routes that include Ventura, Camarillo, Oxnard, and Moorpark. Call before noon for same-day service. We cover all Ventura neighborhoods from the harbor to East Ventura."
  },
  {
    question: "Does living near Ventura Harbor or the Pacific affect appliances?",
    answer: "It does. The harbor area, Pierpont Beach, and Ventura Keys are exposed to the same salt-laden marine air that affects appliances in Newport Beach and Dana Point. Condenser coils on refrigerators accumulate salt particulate faster, and metal components like range igniter electrodes corrode more quickly than inland. We recommend condenser coil cleaning every 6 months for harbor-adjacent and beachfront properties in Ventura."
  },
  {
    question: "What is your diagnostic fee in Ventura?",
    answer: "Our diagnostic fee is $89. It covers the service call, full appliance inspection, and written estimate. If you proceed with the repair, the $89 is credited against your invoice."
  },
  {
    question: "Do you repair older appliances in Ventura's older neighborhoods?",
    answer: "Yes. Downtown Ventura and the Mission District have older housing stock with appliances that may be 10-20 years old. We repair older units as long as the repair makes economic sense — and we'll tell you honestly when it doesn't. Parts availability is generally good for appliances up to 15 years old."
  },
  {
    question: "What brands do you service in Ventura?",
    answer: "All major brands: GE, Samsung, LG, Whirlpool, KitchenAid, Bosch, Maytag, Frigidaire, and luxury brands including Sub-Zero, Wolf, Viking, Thermador, and Miele. The Ondulando and higher hillside neighborhoods tend toward luxury brands; the downtown and midtown areas have mainstream brands. We carry OEM parts for both."
  },
  {
    question: "Do you repair Viking ranges in Ventura?",
    answer: "Yes. Viking ranges are common in the Ondulando area and other established Ventura neighborhoods. The most frequent Viking failure we see is the oven igniter — a straightforward repair that's often misdiagnosed as a control board issue. We diagnose correctly and replace the right part."
  },
  {
    question: "Do you offer a warranty on repairs in Ventura?",
    answer: "All repairs include a 90-day warranty on parts and labor. Same issue returns within 90 days — we come back at no charge."
  },
];

const nearbyCities = [
  { name: 'Camarillo', slug: 'camarillo' },
  { name: 'Oxnard', slug: 'oxnard' },
  { name: 'Thousand Oaks', slug: 'thousand-oaks' },
  { name: 'Moorpark', slug: 'moorpark' },
  { name: 'Newbury Park', slug: 'newbury-park' },
  { name: 'Ojai', slug: 'ojai' },
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair in"
    headlineCity="Ventura, CA"
    subheadline="Same-day service from the harbor to East Ventura. Coastal salt air expertise. Sub-Zero, Wolf, Viking & all major brands. $89 diagnostic — waived with repair."
    zips={zips}
    tier={3}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance Repair in Ventura — A Real Coastal City"
    paragraphs={introParagraphs}
    bookingTitle="Ventura Service"
    bookingSub="93001 · 93003 · 93004 · Same Day"
  />

  <ServicesGrid
    cityName={cityName}
    headline="Appliance Repair Services in Ventura"
    services={services}
  />

  <CustomNarrative
    headline={venturaContextNarrative.headline}
    paragraphs={venturaContextNarrative.paragraphs}
    subSections={venturaContextNarrative.subSections}
    background="white"
  />

  <ServiceArea
    cityName={cityName}
    headline="Ventura Neighborhoods We Service"
    subheadline="From the harbor to East Ventura — every part of the city."
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={[]}
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Repairs in Ventura"
    jobs={recentJobs}
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="Why Ventura Residents Call Us"
    reasons={whyReasons}
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What Ventura Clients Say"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Repair Pricing in Ventura"
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="Frequently Asked Questions — Ventura"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby Ventura County Cities"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Schedule Your Ventura Repair Today"
    body="Same-day service from the harbor to East Ventura. Sub-Zero, Wolf, Viking, and all major brands. $89 diagnostic · 90-day warranty · OEM parts."
  />
</CityLayoutV2>
