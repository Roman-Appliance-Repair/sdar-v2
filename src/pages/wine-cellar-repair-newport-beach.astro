---
import Layout from '../layouts/Layout.astro';

const title = "Wine Cellar Repair Newport Beach | Same-Day OC · CellarPro · WhisperKOOL";
const description = "Wine cellar repair Newport Beach — coastal cellar specialists, salt-air aware. $89 diagnostic waived with repair. (213) 401-9019.";
const canonical = "https://samedayappliance.repair/wine-cellar-repair-newport-beach/";

const faqs = [
  {
    "q": "Does coastal salt air really shorten cellar equipment life?",
    "a": "Yes — by 30–40% on average for compressors and condensers. Annual condenser cleaning + every-2-year refrigerant integrity check is the prevention program we recommend for Newport Beach cellars."
  },
  {
    "q": "Do you service Newport Coast estate cellars?",
    "a": "Yes — we work the gated communities (Pelican Hill, Crystal Cove). Larger ducted-split installs more common at this scale; we carry the diagnostic tooling for both Hooded and Ducted-style installs."
  },
  {
    "q": "Same-day from Irvine to Newport Beach?",
    "a": "Yes — typical 20-30 min response. Refrigerant leak emergencies prioritized."
  }
];

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": "https://samedayappliance.repair/wine-cellar-repair-newport-beach/#business",
    "name": "Same Day Appliance Repair",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": "https://samedayappliance.repair/wine-cellar-repair-newport-beach/",
    "telephone": "+1-424-325-0520",
    "priceRange": "$$$",
        "geo": {
      "@type": "GeoCoordinates",
      "latitude": 34.0619,
      "longitude": -118.3692
    },
    "areaServed": [
      {
        "@type": "AdministrativeArea",
        "name": "Los Angeles County"
      },
      {
        "@type": "AdministrativeArea",
        "name": "Orange County"
      },
      {
        "@type": "AdministrativeArea",
        "name": "Ventura County"
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Wine Cellar Repair",
    "provider": {
      "@id": "https://samedayappliance.repair/wine-cellar-repair-newport-beach/#business"
    },
    "areaServed": [
      {
        "@type": "AdministrativeArea",
        "name": "Los Angeles County"
      },
      {
        "@type": "AdministrativeArea",
        "name": "Orange County"
      },
      {
        "@type": "AdministrativeArea",
        "name": "Ventura County"
      }
    ],
    "description": "Wine cellar repair Newport Beach — coastal cellar specialists, salt-air aware. $89 diagnostic waived with repair. (213) 401-9019.",
    "offers": {
      "@type": "Offer",
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "89.00",
        "priceCurrency": "USD",
        "description": "Residential diagnostic fee, waived with repair"
      }
    }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://samedayappliance.repair/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Newport Beach",
      "item": "https://samedayappliance.repair/wine-cellar-repair-newport-beach/"
    }
  ] }
];
---
<Layout title={title} description={description} canonical={canonical} noindex={true}>
  <Fragment slot="head-scripts">
    {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
  </Fragment>

  <section class="ph-hero">
    <div class="ph-wrap">
      <p class="ph-eyebrow">Placeholder · Content Coming Soon</p>
      <h1>Wine Cellar Repair in Newport Beach</h1>
      <p class="ph-intro">Newport Beach and Newport Coast cellars face coastal salt-air stress that inland Pasadena or Bel Air cellars never see. Compressor seal lifespans run shorter (8–10 years vs 12–15 inland), condenser corrosion is a regular service item, and refrigerant leak rates are higher on copper line sets. We dispatch from Irvine branch (213) 401-9019, with coastal-aware service protocols. EPA 608 certified.</p>
      <div class="ph-ctas">
        <a href="tel:+14243250520" class="ph-btn">Call (424) 325-0520</a>
        <a href="/contact/" class="ph-btn ph-btn-ghost">Contact Us</a>
      </div>
    </div>
  </section>

  <section class="ph-faq">
    <div class="ph-wrap">
      <h2>Frequently Asked</h2>
      {faqs.map(f => (<details class="ph-detail"><summary>{f.q}</summary><p>{f.a}</p></details>))}
    </div>
  </section>
</Layout>

<style>
  .ph-wrap { max-width: 820px; margin: 0 auto; padding: 0 24px; }
  .ph-hero { background: #0a0a0a; color: #fff; padding: 64px 0; }
  .ph-eyebrow { color: #C8102E; font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; margin: 0 0 14px; }
  .ph-hero h1 { font-size: clamp(1.6rem, 3.2vw, 2.4rem); font-weight: 800; margin: 0 0 16px; line-height: 1.2; }
  .ph-intro { color: rgba(255,255,255,0.85); font-size: 1.05rem; margin: 0 0 28px; line-height: 1.65; }
  .ph-ctas { display: flex; gap: 12px; flex-wrap: wrap; }
  .ph-btn { display: inline-block; background: #C8102E; color: #fff; padding: 12px 24px; text-decoration: none; font-weight: 700; border-radius: 4px; font-size: 0.95rem; }
  .ph-btn-ghost { background: transparent; border: 1px solid rgba(255,255,255,0.4); }
  .ph-faq { padding: 56px 0; background: #f5f5f5; }
  .ph-faq h2 { font-size: 1.5rem; margin: 0 0 20px; color: #0a0a0a; }
  .ph-detail { background: #fff; border: 1px solid #e2e2e2; padding: 14px 18px; border-radius: 4px; margin-bottom: 8px; }
  .ph-detail summary { font-weight: 600; cursor: pointer; color: #0a0a0a; }
  .ph-detail p { margin: 10px 0 0; color: #444; line-height: 1.6; }
</style>
