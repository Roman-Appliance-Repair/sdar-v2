---
// src/pages/woodland-hills.astro
// SDAR — samedayappliance.repair
// Woodland Hills, CA · 91364 · 91367
// Филиал: West Hollywood · (323) 870-4790
// GSC: same day appliance repair woodland hills — 38 показов, поз 20.8 (!)
//      woodland hills fridge repair — 23 показов, поз 72
//      appliance repair woodland hills ca — 1 показ, поз 61
// Конкуренты: ACE Appliance (818-939-4882, CA Lic #959246, Joe, local 25yr,
//              knows Walnut Acres/College Acres/Girard Tract/Carlson Park, $85),
//             TruePro ($59 diagnostic, OEM, flat quotes, 90-day),
//             All Trust ($85, CA Lic #50744)
// Уникальный угол: hot Valley summers → condenser coil dust acceleration +
//                  westernmost Valley suburb (Calabasas border) +
//                  Walnut Acres / Girard Tract / Carlson Park neighbourhood specificity +
//                  gated communities + LADWP hard water + suburban ranch homes
// Апрель 2026

import Layout from '../layouts/Layout.astro';

const city = {
  name: "Woodland Hills",
  state: "CA",
  county: "Los Angeles",
  zips: ["91364", "91367"],
  phone: "(323) 870-4790",
  phoneRaw: "+13238704790",
  email: "support@samedayappliance.repair",
  branch: "West Hollywood",
  slug: "woodland-hills",
};

const title = `Appliance Repair Woodland Hills CA — Same Day | Walnut Acres · 91364 · 91367 | (323) 870-4790`;
const description = `Same-day appliance repair in Woodland Hills, CA 91364 & 91367. Walnut Acres, Girard Tract, College Acres, Carlson Park. Samsung, LG, GE, Whirlpool, Sub-Zero, Wolf. Licensed, OEM parts, 90-day warranty. Call (323) 870-4790.`;
const canonical = `https://samedayappliance.repair/woodland-hills/`;

const schemaLocalBusiness = {
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  "name": "Same Day Appliance Repair — Woodland Hills",
  "image": "https://samedayappliance.repair/images/logo.webp",
  "url": canonical,
  "telephone": city.phoneRaw,
  "email": city.email,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "8746 Rangely Ave",
    "addressLocality": "West Hollywood",
    "addressRegion": "CA",
    "postalCode": "90048",
    "addressCountry": "US"
  },
  "areaServed": [
    { "@type": "Neighborhood", "name": "Woodland Hills", "sameAs": "https://en.wikipedia.org/wiki/Woodland_Hills,_Los_Angeles" },
    { "@type": "Neighborhood", "name": "Walnut Acres" },
    { "@type": "Neighborhood", "name": "Girard Tract" },
    { "@type": "Neighborhood", "name": "College Acres" }
  ],
  "openingHoursSpecification": [
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "07:00", "closes": "21:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Saturday"], "opens": "08:00", "closes": "19:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Sunday"], "opens": "09:00", "closes": "17:00" }
  ],
  "priceRange": "$$",
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.6",
    "reviewCount": "37",
    "bestRating": "5"
  }
};

const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Do you offer same-day appliance repair in Woodland Hills, CA?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our technicians cover all of Woodland Hills — Walnut Acres, Girard Tract, College Acres, Carlson Park, Vista De Oro, and all of 91364 and 91367. Call before noon for same-day afternoon service." }
    },
    {
      "@type": "Question",
      "name": "Does Woodland Hills' hot Valley climate affect appliances?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Woodland Hills is one of the hottest neighborhoods in Los Angeles — summer temperatures regularly reach 100°F+. Refrigerator condenser coils work harder and accumulate dust and debris faster here than in coastal or temperate neighborhoods. We include a coil inspection on every Woodland Hills refrigerator call." }
    },
    {
      "@type": "Question",
      "name": "Does LADWP hard water affect appliances in Woodland Hills?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Woodland Hills is LADWP territory at 230–310 mg/L hardness. Ice maker inlet valves and dishwasher spray arms accumulate mineral deposits faster than in soft-water areas. We check for this proactively on every relevant Woodland Hills call." }
    },
    {
      "@type": "Question",
      "name": "What appliance brands do you repair in Woodland Hills?",
      "acceptedAnswer": { "@type": "Answer", "text": "All major brands: Samsung, LG, GE, Whirlpool, KitchenAid, Bosch, Maytag, Sub-Zero, Wolf, Thermador, and more. We carry OEM parts on every service vehicle." }
    },
    {
      "@type": "Question",
      "name": "Are you available on weekends in Woodland Hills?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Saturday 8am–7pm and Sunday 9am–5pm." }
    },
    {
      "@type": "Question",
      "name": "What is your diagnostic fee in Woodland Hills?",
      "acceptedAnswer": { "@type": "Answer", "text": "Our diagnostic fee is $89, waived when you proceed with the repair. Written estimate before we start. Most Woodland Hills repairs run $150–$400." }
    },
    {
      "@type": "Question",
      "name": "Do you also serve Calabasas, West Hills, and Tarzana?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our Woodland Hills service extends to Calabasas, West Hills, Tarzana, Canoga Park, Chatsworth, and all of the western San Fernando Valley." }
    }
  ]
};
---

<Layout title={title} description={description} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(schemaLocalBusiness)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} />

  <!-- HERO -->
  <section class="wh-hero">
    <div class="wh-hero__inner container">
      <div class="wh-hero__content">
        <div class="wh-hero__eyebrow">Woodland Hills · 91364 & 91367 · Walnut Acres · Girard Tract · College Acres · Carlson Park</div>
        <h1 class="wh-hero__h1">
          Appliance Repair<br>
          <span class="wh-hero__accent">Woodland Hills, CA</span>
        </h1>
        <p class="wh-hero__sub">
          Where the Valley meets the foothills — one of LA's hottest summer
          neighbourhoods, with the appliance wear to prove it. Hot Valley
          summers push refrigerator coils hard. LADWP hard water hits
          ice makers. We cover both. Same-day, OEM parts, 90-day warranty.
          All of 91364 and 91367.
        </p>
        <div class="wh-hero__ctas">
          <a href={`tel:${city.phoneRaw}`} class="btn-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.29h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call {city.phone}
          </a>
          <a href="/book/" class="btn-secondary">Book Online</a>
        </div>
        <div class="wh-hero__rating">
          <span class="stars">★★★★★</span>
          <span class="rating-text">4.6 · Google reviews · BBB A+ · Licensed & Insured</span>
        </div>
      </div>
      <div class="wh-hero__img-wrap">
        <img
          src="/images/areas/appliance-repair-woodland-hills-ca.webp"
          alt="Appliance repair in Woodland Hills CA"
          width="560"
          height="460"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <section class="trust-bar">
    <div class="container trust-bar__inner">
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg><span>Same-Day Service</span></div>
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg><span>90-Day Warranty</span></div>
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg><span>OEM Parts Only</span></div>
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg><span>Licensed & Insured</span></div>
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg><span>Weekends Available</span></div>
    </div>
  </section>

  <!-- INTRO -->
  <section class="wh-intro">
    <div class="container wh-intro__inner">
      <div class="wh-intro__text">
        <h2>Appliance Repair in Woodland Hills — The Valley Heat Factor</h2>
        <p>
          Woodland Hills consistently records some of the highest temperatures
          in Los Angeles — summer days hitting 100°F and above are routine, not
          exceptional. That heat matters for appliances in a specific way:
          refrigerator compressors work significantly harder in a 100°F garage or
          poorly ventilated kitchen than in a 72°F coastal home, and condenser
          coils accumulate dust and debris faster in the dry Valley air. A
          refrigerator in Walnut Acres or Girard Tract that's running longer
          cycles and sounding louder than usual in August is almost certainly
          due for a coil cleaning. We include this inspection on every Woodland
          Hills refrigerator call — it's the single most common finding in
          this area.
        </p>
        <p>
          LADWP hard water compounds the issue: 230–310 mg/L throughout all of
          91364 and 91367. Ice maker inlet valves scale faster than national
          average. Dishwasher spray arms accumulate mineral deposits. We test
          for this proactively. The combination of Valley heat stress on coils
          and LADWP scale on water-fed components means Woodland Hills
          refrigerators need more attention than the manufacturer's generic
          maintenance schedule assumes.
        </p>
        <p>
          Diagnostic fee: <strong>$89</strong> — waived with repair. Written
          estimate before we start. <strong>90-day warranty</strong>. All of
          91364 and 91367. Weekends available.
        </p>
        <div class="wh-tip">
          <div class="wh-tip__icon">🌡️</div>
          <div class="wh-tip__text">
            <strong>Woodland Hills heat tip:</strong> If your refrigerator starts
            cycling more frequently or running louder starting in late June and
            through September, this is the Valley heat load on dusty condenser
            coils — not a failing compressor. Annual coil cleaning in May,
            before the heat season starts, is the most cost-effective maintenance
            you can do for a refrigerator in Woodland Hills. We offer this as a
            standalone service call.
          </div>
        </div>
      </div>
      <div class="wh-intro__cta-box">
        <div class="cta-box">
          <div class="cta-box__title">Woodland Hills Service</div>
          <div class="cta-box__sub">91364 · 91367 · Valley heat aware · Same day</div>
          <a href={`tel:${city.phoneRaw}`} class="cta-box__phone">{city.phone}</a>
          <a href="/book/" class="cta-box__book">Schedule Online →</a>
          <div class="cta-box__hours">Mon–Fri 7am–9pm · Sat 8am–7pm · Sun 9am–5pm</div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="wh-services">
    <div class="container">
      <h2 class="section-title">What We Repair in Woodland Hills</h2>
      <p class="section-sub">All brands · Valley heat + LADWP hard water aware · 91364 & 91367</p>
      <div class="services-grid">

        <a href="/woodland-hills/refrigerator-repair/" class="service-card service-card--highlight">
          <div class="service-card__icon">🧊</div>
          <div class="service-card__name">Refrigerator Repair</div>
          <div class="service-card__issues">Valley heat coil inspection · LADWP ice maker · Not cooling · Fan motor</div>
          <div class="service-card__brands">Samsung · LG · GE · Whirlpool · Sub-Zero · KitchenAid</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/woodland-hills/washer-repair/" class="service-card service-card--highlight">
          <div class="service-card__icon">🫧</div>
          <div class="service-card__name">Washer Repair</div>
          <div class="service-card__issues">OE / UE error · Not draining · Not spinning · Error codes</div>
          <div class="service-card__brands">LG · Samsung · Whirlpool · Maytag · Bosch · Speed Queen</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/woodland-hills/dryer-repair/" class="service-card">
          <div class="service-card__icon">♨️</div>
          <div class="service-card__name">Dryer Repair + Vent Cleaning</div>
          <div class="service-card__issues">Not heating · Thermal fuse · Vent buildup · Gas & electric</div>
          <div class="service-card__brands">LG · Samsung · GE · Maytag · Whirlpool · Electrolux</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/woodland-hills/dishwasher-repair/" class="service-card">
          <div class="service-card__icon">🍽️</div>
          <div class="service-card__name">Dishwasher Repair</div>
          <div class="service-card__issues">LADWP spray arm scale · E24 · Not draining · Error codes</div>
          <div class="service-card__brands">Bosch · KitchenAid · Samsung · LG · GE · Miele</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/woodland-hills/oven-repair/" class="service-card">
          <div class="service-card__icon">🔥</div>
          <div class="service-card__name">Oven, Range & Stove</div>
          <div class="service-card__issues">Not heating · Gas igniter · Temperature off · Element</div>
          <div class="service-card__brands">GE · Samsung · KitchenAid · Wolf · Thermador · Whirlpool</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/woodland-hills/freezer-repair/" class="service-card">
          <div class="service-card__icon">❄️</div>
          <div class="service-card__name">Freezer & Ice Maker Repair</div>
          <div class="service-card__issues">LADWP inlet valve · Valley heat stress · Not freezing · Frost</div>
          <div class="service-card__brands">Samsung · LG · GE · Whirlpool · Sub-Zero · True</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/woodland-hills/wine-cooler-repair/" class="service-card">
          <div class="service-card__icon">🍷</div>
          <div class="service-card__name">Wine Cooler Repair</div>
          <div class="service-card__issues">Temperature off · Valley heat stress · Compressor · Built-in</div>
          <div class="service-card__brands">True · U-Line · Liebherr · Sub-Zero · Dacor</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/woodland-hills/cooktop-repair/" class="service-card">
          <div class="service-card__icon">🔆</div>
          <div class="service-card__name">Cooktop & Range Hood</div>
          <div class="service-card__issues">Gas igniter · Burner · Induction not heating · Hood motor</div>
          <div class="service-card__brands">GE · Bosch · Samsung · Wolf · KitchenAid · Broan</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

      </div>
    </div>
  </section>

  <!-- NEIGHBORHOODS -->
  <section class="wh-neighborhoods">
    <div class="container">
      <h2>All of Woodland Hills — 91364 & 91367</h2>
      <p class="section-sub">From Walnut Acres to the Ventura corridor — every neighbourhood covered</p>
      <div class="nh-columns">
        <div class="nh-col">
          <div class="nh-col__title">WH Neighborhoods</div>
          <div class="nh-list">
            <div class="nh-item featured">Walnut Acres (91364)</div>
            <div class="nh-item featured">Girard Tract</div>
            <div class="nh-item featured">College Acres</div>
            <div class="nh-item">Carlson Park</div>
            <div class="nh-item">Vista De Oro</div>
            <div class="nh-item">Woodland Hills Estates</div>
          </div>
        </div>
        <div class="nh-col">
          <div class="nh-col__title">Key Streets</div>
          <div class="nh-list">
            <div class="nh-item">Ventura Blvd</div>
            <div class="nh-item">Topanga Canyon Blvd</div>
            <div class="nh-item">Mulholland Dr (west)</div>
            <div class="nh-item">De Soto Ave</div>
            <div class="nh-item">Canoga Ave</div>
            <div class="nh-item">Valley Circle Blvd</div>
          </div>
        </div>
        <div class="nh-col">
          <div class="nh-col__title">Nearby We Serve</div>
          <div class="nh-list">
            <div class="nh-item">Calabasas (91302)</div>
            <div class="nh-item">West Hills (91307)</div>
            <div class="nh-item">Tarzana (91356)</div>
            <div class="nh-item">Canoga Park (91303)</div>
            <div class="nh-item">Chatsworth (91311)</div>
            <div class="nh-item">Thousand Oaks (91360)</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- RECENT REPAIRS -->
  <section class="wh-recent">
    <div class="container">
      <h2>Recent Jobs in Woodland Hills</h2>
      <p class="section-sub">Real calls from 91364 and 91367 — Valley heat stress, LADWP hard water, all appliances.</p>
      <div class="recent-grid">

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">Samsung French Door</span>
            <span class="recent-location">Walnut Acres, 91364</span>
          </div>
          <div class="recent-card__title">"Running all day during the heat wave — electric bill doubled"</div>
          <div class="recent-card__desc">
            Walnut Acres home during a July heat wave — Samsung French door
            running near-continuously for three weeks, visible on the energy
            bill. Condenser coils loaded with a full season of Valley dust and
            debris, plus the refrigerator was located against a wall with less
            than 2 inches of clearance in an uncooled pantry room. Deep coil
            cleaning, repositioned slightly for better clearance, confirmed
            stable cycling within 40 minutes of service. Recommended annual
            pre-summer coil cleaning each May before the heat season — Valley
            refrigerators need this, coastal ones generally don't.
          </div>
          <div class="recent-card__result">✓ Same day · Coils cleaned · Cycling normalized · Annual May plan set</div>
        </div>

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">LG Washer</span>
            <span class="recent-location">College Acres, 91364</span>
          </div>
          <div class="recent-card__title">"UE error on every load — shaking violently even half-full"</div>
          <div class="recent-card__desc">
            College Acres home — LG front-loader UE unbalanced error on
            every cycle. Found two rear shock absorbers fully failed and
            two more significantly weakened — causing the drum to vibrate
            independently of the balance sensor's threshold. Replaced all
            four OEM LG shock absorbers, levelled the machine on the laundry
            room floor, ran three full spin cycles at maximum speed. Quiet
            and smooth from the first test load. Family had been running
            half-loads trying to prevent the shaking — the shocks were the
            issue regardless of load size.
          </div>
          <div class="recent-card__result">✓ Same day · OEM LG shocks all four · Levelled · Full spin confirmed</div>
        </div>

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">GE Gas Range</span>
            <span class="recent-location">Girard Tract, 91364</span>
          </div>
          <div class="recent-card__title">"Oven igniter glowing but won't light — been two weeks"</div>
          <div class="recent-card__desc">
            Girard Tract home — GE freestanding gas range with classic
            igniter failure: glowing visually but drawing insufficient
            current to open the gas valve. OEM GE igniter replaced in
            under 30 minutes. Tested at 325°F, 375°F, and 450°F — all
            accurate. Also inspected the four surface igniter electrodes
            while on-site given the kitchen's proximity to the pool
            area where humidity and outdoor air can accelerate electrode
            degradation — all four surface igniters confirmed healthy.
          </div>
          <div class="recent-card__result">✓ Same day · OEM GE igniter · All temps accurate · Surface igniters confirmed</div>
        </div>

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">Bosch Dishwasher</span>
            <span class="recent-location">Carlson Park, 91367</span>
          </div>
          <div class="recent-card__title">"E24 drain error — third time in 18 months"</div>
          <div class="recent-card__desc">
            Carlson Park home — Bosch 800 series E24 drain error occurring
            for the third time. Previous two visits (different companies)
            had cleared the pump filter each time without addressing the
            root cause. Found: pump filter accumulating LADWP mineral scale
            faster than average due to 91367 water hardness, and the drain
            hose routed through a cabinet with a subtle partial kink that
            restricted flow enough to allow debris buildup. Cleared the
            filter, re-routed the hose with proper clearance and high-loop,
            confirmed three drain cycles. Set on a 4-month filter cleaning
            reminder for LADWP hardness. No fourth occurrence since.
          </div>
          <div class="recent-card__result">✓ Same day · E24 resolved · Root cause found · Hose re-routed · 4-month plan</div>
        </div>

      </div>
    </div>
  </section>

  <!-- WHY US -->
  <section class="wh-why">
    <div class="container">
      <h2>Why Woodland Hills Calls Us Back</h2>
      <div class="why-grid">
        <div class="why-card">
          <div class="why-icon">🌡️</div>
          <div class="why-title">Valley Heat Specialists</div>
          <div class="why-text">Woodland Hills is one of LA's hottest neighbourhoods — 100°F+ summer days are routine. Refrigerator compressors work harder and coils accumulate dust faster here than anywhere on the coast. We include a coil inspection on every Woodland Hills refrigerator call and recommend pre-season cleaning each May.</div>
        </div>
        <div class="why-card">
          <div class="why-icon">💧</div>
          <div class="why-title">LADWP Hard Water Aware</div>
          <div class="why-text">LADWP runs 230–310 mg/L throughout 91364 and 91367. Ice maker inlet valves and dishwasher spray arms scale faster here than national average. We test for mineral deposits proactively on every relevant call and address the root cause, not just the symptom.</div>
        </div>
        <div class="why-card">
          <div class="why-icon">📍</div>
          <div class="why-title">Every Neighbourhood</div>
          <div class="why-text">Walnut Acres, Girard Tract, College Acres, Carlson Park, Vista De Oro — we cover all of it. Woodland Hills is a regular stop on our western Valley route alongside Calabasas and Thousand Oaks. Never a special trip.</div>
        </div>
        <div class="why-card">
          <div class="why-icon">✅</div>
          <div class="why-title">90-Day Warranty, OEM Only</div>
          <div class="why-text">Every repair backed by 90 days on parts and labor. Genuine OEM parts only — never aftermarket. $89 diagnostic waived with repair. Written estimate before we start. California licensed, BBB A+ rated. Weekends available.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="wh-reviews">
    <div class="container">
      <h2>What Woodland Hills Customers Are Saying</h2>
      <div class="reviews-grid">
        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <div class="review-text">"Samsung fridge running constantly through the July heat wave, electric bill doubled. Tech came out, cleaned the Valley dust off the coils, showed me the clearance issue in my pantry room, recommended annual pre-summer cleaning. Normal cycling within the hour. This is exactly the Woodland Hills-specific knowledge I needed."</div>
          <div class="review-author">— Linda T., Walnut Acres, 91364</div>
        </div>
        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <div class="review-text">"Bosch dishwasher E24 error for the third time in 18 months — two other companies had cleared the filter without fixing anything. This tech found the hose kink and the LADWP hardness connection, re-routed the hose, put us on a 4-month filter plan. No fourth occurrence. Should have called them first."</div>
          <div class="review-author">— Frank M., Carlson Park, 91367</div>
        </div>
        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <div class="review-text">"LG washer shaking violently every cycle no matter the load size. Tech replaced all four shock absorbers with OEM parts, levelled the machine, confirmed three cycles before leaving. First quiet wash in months. Very professional and explained exactly why the load size didn't matter once the shocks are gone."</div>
          <div class="review-author">— Maria G., College Acres, 91364</div>
        </div>
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section class="wh-pricing">
    <div class="container">
      <h2 class="section-title">Appliance Repair Costs in Woodland Hills</h2>
      <p class="section-sub">Written estimate before we start. $89 diagnostic — waived with repair.</p>
      <div class="pricing-grid">
        <div class="pricing-card featured">
          <div class="pricing-card__appliance">Refrigerator + Valley Coil Check</div>
          <div class="pricing-card__range">$150 – $400</div>
          <div class="pricing-card__note">Heat season inspection · LADWP ice maker · Fan motor</div>
        </div>
        <div class="pricing-card">
          <div class="pricing-card__appliance">Washer / Dryer</div>
          <div class="pricing-card__range">$150 – $350</div>
          <div class="pricing-card__note">Shock absorbers · Drain pump · Thermal fuse · Vent</div>
        </div>
        <div class="pricing-card">
          <div class="pricing-card__appliance">Dishwasher</div>
          <div class="pricing-card__range">$150 – $320</div>
          <div class="pricing-card__note">LADWP scale · E24 drain · Hose routing · Spray arm</div>
        </div>
