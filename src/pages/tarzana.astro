---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import CustomNarrative from '../components/cities/v2/CustomNarrative.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

import { mergeCredentials } from '../data/credentials-schema';
const citySlug = 'tarzana';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = "Tarzana";
const zips = ["91356"];

const phone = branch.phone;
const phoneRaw = `+1${phone.replace(/\D/g, '')}`;

const title = `Appliance Repair Tarzana CA — Same Day Service`;
const description = `Same-day appliance repair in Tarzana, CA 91356. Samsung, LG, GE, Whirlpool, Sub-Zero, Wolf. Licensed, OEM parts Weekends available.`;
const canonical = "https://samedayappliance.repair/tarzana/";

const localBusinessSchema = mergeCredentials({
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  name: branch.fullName,
  image: "https://samedayappliance.repair/images/logo.webp",
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { "@type": "Neighborhood", name: "Tarzana", sameAs: "https://en.wikipedia.org/wiki/Tarzana,_Los_Angeles" }
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: "$$",
  license: "BHGS #A49573"

});

const introParagraphs = [
  "Tarzana is one of those Valley neighbourhoods that has stayed genuinely residential — not particularly flashy, not anonymous. The El Caballero area and the hillside streets near Caballero Canyon have larger homes with premium kitchens. The Ventura Blvd and Reseda Blvd corridors have the established mid-Valley homes where LG, Samsung, GE, and Whirlpool need reliable same-day service.",
  "Two environmental factors apply consistently across all of 91356. First, Valley heat: Tarzana sees 100°F+ summer days regularly, which means refrigerator compressors work harder and condenser coils accumulate dust and debris faster than in coastal neighbourhoods. We include a coil inspection on every Tarzana refrigerator call. Second, LADWP hard water at 230–310 mg/L — some hillside properties also supplement with well water, which can compound the mineral content further. Ice maker inlet valves and dishwasher spray arms scale faster here. We check for both on every relevant call.",
  "Diagnostic fee: <strong>$89</strong> — waived with repair. Written estimate before we start. <strong>90-day warranty</strong>. Weekends available — including Sundays.",
  "<strong>Tarzana heat + water tip:</strong> If your refrigerator starts cycling more frequently in July and your ice maker has been gradually slowing down — these are two separate issues happening simultaneously in Tarzana. The cycling is Valley heat on dusty condenser coils. The declining ice is LADWP mineral scale on the inlet valve. Both are fixable in a single visit. Annual coil cleaning before summer and a 6-month filter replacement cycle are the two most effective maintenance steps for a Tarzana refrigerator."
];

const services = [
  { icon: '🧊', name: 'Refrigerator Repair', slug: 'refrigerator', issues: 'Valley heat coil inspection · LADWP ice maker · Not cooling · Fan', brands: 'Samsung · LG · GE · Whirlpool · Sub-Zero · KitchenAid' },
  { icon: '🫧', name: 'Washer Repair', slug: 'washer', issues: 'OE / UE error · Not draining · Not spinning · Error codes', brands: 'LG · Samsung · Whirlpool · Maytag · Bosch · Speed Queen' },
  { icon: '♨️', name: 'Dryer Repair + Vent Cleaning', slug: 'dryer', issues: 'Not heating · Thermal fuse · Flow sense · Vent buildup', brands: 'LG · Samsung · GE · Maytag · Whirlpool · Electrolux' },
  { icon: '🍽️', name: 'Dishwasher Repair', slug: 'dishwasher', issues: 'LADWP spray arm scale · E24 · Not draining · Error codes', brands: 'Bosch · KitchenAid · Samsung · LG · GE · Miele' },
  { icon: '🔥', name: 'Oven, Range & Stove', slug: 'oven', issues: 'Not heating · Gas igniter · Temperature off · Jenn-Air · Wolf', brands: 'GE · Samsung · Jenn-Air · Wolf · Bertazzoni · KitchenAid' },
  { icon: '❄️', name: 'Freezer & Ice Maker Repair', slug: 'freezer', issues: 'LADWP inlet valve · Valley heat stress · Not freezing · Frost', brands: 'Samsung · LG · GE · Whirlpool · Sub-Zero · True' },
  { icon: '🍷', name: 'Wine Cooler Repair', slug: 'wine-cooler', issues: 'Temperature off · Valley heat stress · Compressor · Built-in', brands: 'True · U-Line · Liebherr · Sub-Zero · Dacor' },
  { icon: '🔆', name: 'Cooktop & Range Hood', slug: 'cooktop', issues: 'Gas igniter · Burner · Induction not heating · Hood motor', brands: 'GE · Bosch · Samsung · Jenn-Air · Wolf · Bertazzoni' }
];

const neighborhoods = [
  { name: 'El Caballero Country Club area', zip: '91356', featured: true },
  { name: 'Caballero Canyon hillside', zip: '91356', featured: true },
  { name: 'Ventura Blvd corridor', zip: '91356' },
  { name: 'Reseda Blvd corridor', zip: '91356' },
  { name: 'Vanalden Ave area', zip: '91356' },
  { name: 'Tampa Ave corridor', zip: '91356' }
];

const keyStreets = ['Ventura Blvd', 'Reseda Blvd', 'Avenida Oriente', 'Vanalden Ave', 'Tampa Ave', 'Topanga Canyon Blvd'];

const recentJobs = [
  {
    appliance: 'LG French Door Fridge',
    location: 'El Caballero area, 91356',
    quote: '"Running constantly in summer, ice maker almost nothing"',
    description: "El Caballero area home during an August heat stretch — LG French door with two problems presenting simultaneously. Condenser coils loaded with Valley dust from a full summer season, plus the water inlet valve scaled by LADWP minerals down to roughly 15% flow. Deep coil cleaning first, then inlet valve replacement with OEM LG part. Cycling normalised within 45 minutes, full ice production confirmed next morning. Both issues in one visit — explained to the homeowner that the timing (both worsening in summer) is a Tarzana-specific pattern: heat stress the coils while water usage increases, accelerating scale on the valve.",
    outcome: '✓ Same day · Coils + inlet valve · OEM LG · Both issues one visit'
  },
  {
    appliance: 'Whirlpool Gas Dryer',
    location: 'Caballero Canyon, 91356',
    quote: '"No heat — two cycles to dry anything, this started last week"',
    description: "Caballero Canyon hillside home — Whirlpool gas dryer with thermal fuse blown from a vent run that had been gradually accumulating lint inside a long flexible section snaking through the hillside wall. Found approximately 60% blockage. Replaced the thermal fuse, cleared the full vent run to the exterior, replaced the warped plastic exterior cap with a proper metal backdraft damper. Single-cycle drying confirmed on the first test load. Hillside vent runs in Tarzana tend to be longer than Valley floor properties — worth annual inspection given the lint accumulation rate.",
    outcome: '✓ Same day · Thermal fuse · Vent cleared · Metal cap · Single cycle'
  },
  {
    appliance: 'Bosch Dishwasher',
    location: 'Ventura Blvd area, 91356',
    quote: '"E24 drain error — dishes not clean either, white film on everything"',
    description: "Ventura Blvd corridor home — Bosch 500 series E24 drain error combined with white mineral film on dishes. LADWP hard water had scaled both the drain pump filter and the spray arm jets. The pump filter was restricting drain flow (causing E24) while the scaled spray arm jets were reducing wash pressure enough to leave residue. Cleared both, ran the Bosch diagnostic cycle, confirmed clean drain and full spray pressure on three test loads — spotless dishes. Set on a 4-month filter cleaning and quarterly descale cycle appropriate for LADWP hardness.",
    outcome: '✓ Same day · E24 resolved · Spray arms descaled · LADWP plan set'
  },
  {
    appliance: 'Samsung Washer',
    location: 'Reseda Blvd corridor, 91356',
    quote: '"4E error — water not filling, machine stopped mid-cycle"',
    description: "Tarzana home near Reseda Blvd — Samsung front-loader 4E water supply error. Found the inlet valve inlet screen partially blocked by a combination of LADWP mineral debris and fine sediment — a pattern consistent with this water supply. Cleaned the inlet screen thoroughly, tested inlet valve solenoid function (still good), ran a full wash cycle — 4E clear. Also found the hot water supply pressure slightly low from a partially closed shutoff valve behind the unit — opened it fully. Explained the LADWP sediment factor and recommended cleaning the inlet screen annually.",
    outcome: '✓ Same day · 4E resolved · Inlet screen cleaned · Shutoff corrected'
  }
];

const whyReasons = [
  {
    iconKey: 'team' as const,
    title: 'Valley Heat + LADWP Aware',
    body: "Tarzana's 100°F+ summers stress refrigerator compressors and load condenser coils with dust. LADWP hard water scales ice maker valves and dishwasher spray arms. We address both in a single visit when both are present — and explain the combined pattern so you understand what to watch for."
  },
  {
    iconKey: 'clock' as const,
    title: 'Open Sundays',
    body: "Saturday Mon–Sat 8am–8pm · Sun closed · Phone answered 24/7. Several Tarzana appliance repair companies close on Sundays. We don't. Weekend appliance failures don't wait for Monday, and neither do we."
  },
  {
    iconKey: 'parts' as const,
    title: 'Western Valley Route',
    body: "Tarzana is on the same western Valley route as Encino, Woodland Hills, and Calabasas. Call before noon and we're typically there that afternoon — never a special trip, never an extra charge for being in 91356."
  },
  {
    iconKey: 'shield' as const,
    title: '90-Day Warranty, OEM Only',
    body: 'Every repair backed by 90 days on parts and labor. Genuine OEM parts only. $89 diagnostic waived with repair. Written estimate before we start. California licensed, BBB Accredited.'
  }
];

const testimonials = [
  {
    stars: 5,
    text: '"LG fridge running constantly in August heat and ice maker barely producing. Tech found both issues in one visit — dirty coils and scaled inlet valve — fixed both, explained why they happen together in Tarzana summer. Cycling normal and full ice the next morning. Efficient, honest, and actually understood the local water."',
    author: '— Robert H., El Caballero area, Tarzana'
  },
  {
    stars: 5,
    text: '"Needed a Sunday appointment — called Same Day because other companies were closed. Tech came out Sunday afternoon, fixed the Bosch E24 error, descaled the spray arms, set up a maintenance plan for our LADWP water. Spotless dishes from the first load. Really appreciated that Sunday availability."',
    author: '— Karen S., Ventura Blvd area, Tarzana 91356'
  },
  {
    stars: 5,
    text: '"Whirlpool dryer no heat in our Caballero Canyon home. Tech found the lint-blocked hillside vent run, replaced the thermal fuse, installed a proper metal vent cap, confirmed single-cycle drying. Mentioned that hillside vent runs need annual checking — nobody had ever told us that before. Preventive and professional."',
    author: '— Michael T., Caballero Canyon, Tarzana'
  }
];

const pricingTiers = [
  { appliance: 'Refrigerator + Valley Coil + LADWP Check', range: '$150 – $400', note: 'Both heat and water factors addressed in one visit', featured: true },
  { appliance: 'Washer / Dryer', range: '$150 – $350', note: 'Inlet screen · Drain pump · Thermal fuse · Vent cleaning' },
  { appliance: 'Dishwasher', range: '$150 – $320', note: 'LADWP scale · E24 · Spray arm descale · Filter' },
  { appliance: 'Oven / Range', range: '$150 – $400', note: 'Gas igniter · Bake element · Jenn-Air · Temperature' },
  { appliance: 'Sub-Zero / Wolf', range: '$300 – $700+', note: 'OEM parts · El Caballero estates' },
  { appliance: 'Diagnostic Fee', range: '$89', note: 'Waived when you proceed with the repair' }
];

const faqs = [
  {
    question: "Do you offer same-day appliance repair in Tarzana, CA?",
    answer: "Yes. Our technicians cover all of Tarzana 91356 — El Caballero area, Caballero Canyon, Ventura Blvd, Reseda Blvd, and every residential street. Call before noon for same-day afternoon service."
  },
  {
    question: "Does Tarzana's hot Valley climate affect appliances?",
    answer: "Yes. 100°F+ summer days put refrigerator compressors under load and accelerate condenser coil dust buildup. We include a coil inspection on every Tarzana refrigerator call and offer pre-summer annual cleaning."
  },
  {
    question: "Does LADWP hard water affect appliances in Tarzana?",
    answer: "Yes. LADWP runs 230–310 mg/L in 91356. Some hillside properties also supplement with well water, compounding the hardness. Ice makers and dishwashers scale faster here. We check proactively on every relevant call."
  },
  {
    question: "Are you available on Sundays in Tarzana?",
    answer: "Sunday is closed for in-person service, but our phones are answered 24/7. Call any time and we'll book you into the Monday-morning queue. Saturday 8am–8pm dispatch is fully open if you need same-weekend service."
  },
  {
    question: "What appliance brands do you repair in Tarzana?",
    answer: "All major brands: Samsung, LG, GE, Whirlpool, KitchenAid, Bosch, Maytag, Sub-Zero, Wolf, Jenn-Air, Bertazzoni, and more. OEM parts on every vehicle."
  },
  {
    question: "What is your diagnostic fee in Tarzana?",
    answer: "Our diagnostic fee is $89, waived when you proceed with the repair. Written estimate before we start. Most Tarzana repairs run $150–$400."
  },
  {
    question: "Do you also serve Encino, Woodland Hills, and Reseda?",
    answer: "Yes. Our Tarzana service extends to Encino, Woodland Hills, Reseda, Canoga Park, West Hills, and all of the western San Fernando Valley."
  }
];

const nearbyCities = [
  { name: 'Encino', slug: 'encino' },
  { name: 'Woodland Hills', slug: 'woodland-hills' },
  { name: 'Sherman Oaks', slug: 'sherman-oaks' },
  { name: 'Calabasas', slug: 'calabasas' },
  { name: 'Thousand Oaks', slug: 'thousand-oaks' },
  { name: 'Studio City', slug: 'studio-city' },
  { name: 'West Hollywood', slug: 'west-hollywood' },
  { name: 'Los Angeles', slug: 'los-angeles' }
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair"
    headlineCity="Tarzana, CA"
    subheadline="Named for Tarzan, built around Edgar Rice Burroughs' 1919 ranch — Tarzana has its own character in the western Valley. Hot summers, LADWP hard water, and a mix of El Caballero hillside estates and well-kept Valley homes. Same-day service, OEM parts, 90-day warranty. Open Sundays."
    zips={zips}
    tier={3}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance Repair in Tarzana — The Local Reality"
    paragraphs={introParagraphs}
    bookingTitle="Tarzana Service"
    bookingSub="91356 · Valley heat aware · Open Sundays"
  />

  <ServicesGrid
    cityName={cityName}
    headline="What We Repair in Tarzana"
    subhead="All brands · Valley heat + LADWP hard water aware · All of 91356"
    services={services}
  />

  <ServiceArea
    cityName={cityName}
    headline="All of Tarzana — 91356"
    subheadline="From El Caballero hillsides to the Ventura corridor — every street in Tarzana"
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={keyStreets}
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Jobs in Tarzana"
    subhead="Real calls from 91356 — Valley heat, LADWP hard water, all neighbourhoods."
    jobs={recentJobs}
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="Why Tarzana Calls Us Back"
    reasons={whyReasons}
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What Tarzana Customers Are Saying"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Appliance Repair Costs in Tarzana"
    subhead="Written estimate before we start. $89 diagnostic — waived with repair."
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="Questions Tarzana Customers Ask"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby Areas"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance broken in Tarzana?"
    body="El Caballero · Caballero Canyon · Valley heat + LADWP hard water aware · Open Sundays · All of 91356. $89 diagnostic waived with repair. 90-day warranty."
  />
</CityLayoutV2>
