---
// src/pages/south-pasadena.astro
// SDAR — samedayappliance.repair
// South Pasadena, CA 91030
// Филиал: Pasadena · (626) 376-4458
// GSC: appliance repair south pasadena — 116 показов, позиция 22.1 ⚡
//      south pasadena appliance repair — 15 показов, позиция 24.7
// Конкуренты: Chuck's (vintage stoves, local, no weekends), Expert Appliance (40yr), 
//             SoPas Appliance Repair (generic), PasadenaPeak (HVAC+)
// Уникальный угол: Craftsman/bungalow housing stock + vintage stoves + LADWP hard water
//                  + Chuck's weakness: closed weekends, no online booking
// Апрель 2026

import Layout from '../layouts/Layout.astro';

const city = {
  name: "South Pasadena",
  state: "CA",
  county: "Los Angeles",
  zips: ["91030"],
  phone: "(626) 376-4458",
  phoneRaw: "+16263764458",
  email: "pasadena@samedayappliance.repair",
  branch: "Pasadena",
  slug: "south-pasadena",
};

const title = `Appliance Repair South Pasadena CA 91030 — Same Day | Craftsman Homes · Vintage Stoves | (626) 376-4458`;
const description = `Same-day appliance repair in South Pasadena, CA 91030. Craftsman bungalows, vintage O'Keefe & Merritt and Wedgewood ranges welcome. Mission Street, Marengo Ave, Meridian Ave. Licensed, OEM parts, 90-day warranty. Weekends available. Call (626) 376-4458.`;
const canonical = `https://samedayappliance.repair/south-pasadena/`;

const schemaLocalBusiness = {
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  "name": "Same Day Appliance Repair — South Pasadena",
  "image": "https://samedayappliance.repair/images/logo.webp",
  "url": canonical,
  "telephone": city.phoneRaw,
  "email": city.email,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "55 S Lake Ave",
    "addressLocality": "Pasadena",
    "addressRegion": "CA",
    "postalCode": "91101",
    "addressCountry": "US"
  },
  "areaServed": [
    { "@type": "City", "name": "South Pasadena", "sameAs": "https://en.wikipedia.org/wiki/South_Pasadena,_California" }
  ],
  "openingHoursSpecification": [
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "07:00", "closes": "21:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Saturday"], "opens": "08:00", "closes": "19:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Sunday"], "opens": "09:00", "closes": "17:00" }
  ],
  "priceRange": "$$",
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.6",
    "reviewCount": "37",
    "bestRating": "5"
  }
};

const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Do you offer same-day appliance repair in South Pasadena, CA?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our technicians cover all of South Pasadena 91030 — Mission Street corridor, Marengo Avenue, Meridian Avenue, El Centro, Fairview Avenue, Diamond Avenue, and all streets through the historic bungalow neighborhoods. Call before noon for same-day afternoon service. We're also available Saturdays and Sundays." }
    },
    {
      "@type": "Question",
      "name": "Do you repair vintage ranges and O'Keefe & Merritt stoves in South Pasadena?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. South Pasadena's Craftsman bungalows and Spanish Colonial homes often have vintage ranges — O'Keefe & Merritt, Wedgewood, Roper — that have been running for decades. We assess these honestly. If the parts are available and the repair makes economic sense, we do it. We won't turn away a vintage stove just because it's not a modern brand." }
    },
    {
      "@type": "Question",
      "name": "Does hard water in South Pasadena affect appliances?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. LADWP water hardness in the South Pasadena area runs 230–310 mg/L, and older homes with galvanized supply pipes can add iron on top of that. This means ice maker inlet valves, dishwasher spray arms, and washing machine inlet hoses accumulate mineral deposits faster than the national average. We check and test for this on every South Pasadena call involving ice makers and dishwashers." }
    },
    {
      "@type": "Question",
      "name": "Are you available on weekends in South Pasadena?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. We're available Saturday 8am–7pm and Sunday 9am–5pm — unlike some South Pasadena appliance companies that close on weekends. If your appliance breaks Friday evening or Saturday morning, you don't have to wait until Monday." }
    },
    {
      "@type": "Question",
      "name": "What is your diagnostic fee in South Pasadena?",
      "acceptedAnswer": { "@type": "Answer", "text": "Our diagnostic fee is $89, waived when you proceed with the repair. We give you a complete written estimate before starting any work. Most South Pasadena repairs run $150–$400 depending on the appliance." }
    },
    {
      "@type": "Question",
      "name": "What warranty do you offer on appliance repairs in South Pasadena?",
      "acceptedAnswer": { "@type": "Answer", "text": "All repairs come with a 90-day warranty on parts and labor. We use genuine OEM parts only. If the same issue returns within 90 days, we come back at no charge." }
    },
    {
      "@type": "Question",
      "name": "Do you also serve Pasadena, San Marino, and Alhambra?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our South Pasadena service extends to Pasadena, San Marino, Alhambra, San Gabriel, Arcadia, and Monrovia. We're the closest team for all 91030 calls and cover the surrounding SGV cities as well." }
    }
  ]
};
---

<Layout title={title} description={description} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(schemaLocalBusiness)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} />

  <!-- HERO -->
  <section class="sp-hero">
    <div class="sp-hero__inner container">
      <div class="sp-hero__content">
        <div class="sp-hero__eyebrow">South Pasadena, CA · 91030 · Mission Street · Marengo Ave · Meridian Ave · Historic District</div>
        <h1 class="sp-hero__h1">
          Appliance Repair<br>
          <span class="sp-hero__accent">South Pasadena, CA</span>
        </h1>
        <p class="sp-hero__sub">
          Craftsman bungalows, Spanish Colonials, vintage kitchens — and all the
          modern appliances living alongside them. We cover all of South Pasadena 91030.
          Vintage stoves welcome. Same-day service, weekends available.
          OEM parts, 90-day warranty.
        </p>
        <div class="sp-hero__ctas">
          <a href={`tel:${city.phoneRaw}`} class="btn-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.29h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call {city.phone}
          </a>
          <a href="/book/" class="btn-secondary">Book Online</a>
        </div>
        <div class="sp-hero__rating">
          <span class="stars">★★★★★</span>
          <span class="rating-text">4.6 · Google reviews · BBB A+ · Licensed & Insured</span>
        </div>
      </div>
      <div class="sp-hero__img-wrap">
        <img
          src="/images/areas/appliance-repair-south-pasadena-ca.webp"
          alt="Appliance repair in South Pasadena CA"
          width="560"
          height="460"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <section class="trust-bar">
    <div class="container trust-bar__inner">
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg><span>Same-Day Service</span></div>
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg><span>90-Day Warranty</span></div>
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg><span>OEM Parts</span></div>
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg><span>Licensed & Insured</span></div>
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg><span>Weekends Available</span></div>
    </div>
  </section>

  <!-- INTRO -->
  <section class="sp-intro">
    <div class="container sp-intro__inner">
      <div class="sp-intro__text">
        <h2>Appliance Repair in South Pasadena — What Makes This City Different</h2>
        <p>
          South Pasadena is one of the best-preserved small cities in the San Gabriel
          Valley. The Craftsman bungalows along Marengo, Meridian, and Fairview Avenues,
          the Spanish Colonials and Victorians throughout the historic district — these
          homes have been maintained and loved for decades, and their kitchens reflect that.
        </p>
        <p>
          A meaningful number of those kitchens still have vintage ranges — O'Keefe &
          Merritt, Wedgewood, Roper — running alongside modern dishwashers and
          refrigerators. We don't turn these away. If a vintage range can be repaired
          economically, we do it. If it can't, we'll tell you that directly rather than
          waste your time and money.
        </p>
        <p>
          Hard water is a real factor in South Pasadena. LADWP water in this area runs
          230–310 mg/L hardness, and older galvanized pipes in the 1920s–40s homes
          add iron. Ice maker inlet valves and dishwasher spray arms scale up faster
          than the national average — we test for this on every relevant South Pasadena
          call. It consistently matters here.
        </p>
        <p>
          Diagnostic fee: <strong>$89</strong> — waived with repair. Written estimate
          before we start. <strong>90-day warranty</strong>. We're available
          <strong>Saturdays and Sundays</strong> — unlike some South Pasadena
          competitors who close on weekends.
        </p>
        <div class="sp-tip">
          <div class="sp-tip__icon">🏠</div>
          <div class="sp-tip__text">
            <strong>Vintage range tip for South Pasadena:</strong> If you have an
            O'Keefe & Merritt, Wedgewood, or Roper still running in your Craftsman
            kitchen — these are worth keeping. Parts are still available for most
            common failures (burner igniters, pilot assemblies, oven thermostats).
            A $150–$250 repair on a range that cooks beautifully is almost always
            the right call. We assess vintage ranges honestly and won't push you
            toward unnecessary replacement.
          </div>
        </div>
      </div>
      <div class="sp-intro__cta-box">
        <div class="cta-box">
          <div class="cta-box__title">South Pasadena Service</div>
          <div class="cta-box__sub">91030 · Vintage stoves welcome · Weekends ok</div>
          <a href={`tel:${city.phoneRaw}`} class="cta-box__phone">{city.phone}</a>
          <a href="/book/" class="cta-box__book">Schedule Online →</a>
          <div class="cta-box__hours">Mon–Fri 7am–9pm · Sat 8am–7pm · Sun 9am–5pm</div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="sp-services">
    <div class="container">
      <h2 class="section-title">What We Repair in South Pasadena</h2>
      <p class="section-sub">Modern & vintage · All brands · Hard water aware · 91030</p>
      <div class="services-grid">

        <a href="/south-pasadena/refrigerator-repair/" class="service-card">
          <div class="service-card__icon">🧊</div>
          <div class="service-card__name">Refrigerator Repair</div>
          <div class="service-card__issues">Not cooling · Hard water ice maker · Fan motor · Temperature off</div>
          <div class="service-card__brands">Samsung · LG · GE · Whirlpool · Sub-Zero · Bosch</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/south-pasadena/oven-repair/" class="service-card service-card--highlight">
          <div class="service-card__icon">🔥</div>
          <div class="service-card__name">Oven, Range & Vintage Stove</div>
          <div class="service-card__issues">O'Keefe & Merritt · Wedgewood · Roper · Gas igniter · Oven thermostat</div>
          <div class="service-card__brands">Vintage brands · GE · Samsung · Bosch · Wolf · Viking</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/south-pasadena/washer-repair/" class="service-card">
          <div class="service-card__icon">🫧</div>
          <div class="service-card__name">Washer Repair</div>
          <div class="service-card__issues">Hard water inlet screens · Not draining · Not spinning · Error codes</div>
          <div class="service-card__brands">LG · Samsung · Whirlpool · Maytag · Bosch · Speed Queen</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/south-pasadena/dryer-repair/" class="service-card">
          <div class="service-card__icon">♨️</div>
          <div class="service-card__name">Dryer Repair + Vent Cleaning</div>
          <div class="service-card__issues">Not heating · Older vent runs · Thermal fuse · Lint buildup</div>
          <div class="service-card__brands">LG · Samsung · GE · Maytag · Whirlpool · Electrolux</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/south-pasadena/dishwasher-repair/" class="service-card service-card--highlight">
          <div class="service-card__icon">🍽️</div>
          <div class="service-card__name">Dishwasher Repair</div>
          <div class="service-card__issues">Hard water spray arm scale · Not draining · Spots · Error codes</div>
          <div class="service-card__brands">Bosch · KitchenAid · Samsung · LG · GE · Miele</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/south-pasadena/freezer-repair/" class="service-card">
          <div class="service-card__icon">❄️</div>
          <div class="service-card__name">Freezer & Ice Maker Repair</div>
          <div class="service-card__issues">Hard water valve · Not freezing · Ice stopped · Frost buildup</div>
          <div class="service-card__brands">Samsung · LG · GE · Whirlpool · Sub-Zero · Frigidaire</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/south-pasadena/cooktop-repair/" class="service-card">
          <div class="service-card__icon">🔆</div>
          <div class="service-card__name">Cooktop & Range Hood</div>
          <div class="service-card__issues">Igniter issues · Gas burner · Induction not heating · Hood motor</div>
          <div class="service-card__brands">GE · Bosch · Samsung · Wolf · Thermador · Broan</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/south-pasadena/wine-cooler-repair/" class="service-card">
          <div class="service-card__icon">🍷</div>
          <div class="service-card__name">Wine Cooler Repair</div>
          <div class="service-card__issues">Temperature off · Compressor · Under-counter · Built-in</div>
          <div class="service-card__brands">Sub-Zero · True · U-Line · Liebherr · Dacor</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

      </div>
    </div>
  </section>

  <!-- NEIGHBORHOODS -->
  <section class="sp-neighborhoods">
    <div class="container">
      <h2>All of South Pasadena — 91030</h2>
      <p class="section-sub">Every neighborhood and street in the city</p>
      <div class="nh-columns">
        <div class="nh-col">
          <div class="nh-col__title">South Pasadena Areas</div>
          <div class="nh-list">
            <div class="nh-item featured">Mission Street corridor</div>
            <div class="nh-item featured">Historic District</div>
            <div class="nh-item featured">Marengo Avenue</div>
            <div class="nh-item">Meridian Avenue</div>
            <div class="nh-item">El Centro Street</div>
            <div class="nh-item">Fairview Avenue</div>
            <div class="nh-item">Diamond Avenue</div>
            <div class="nh-item">Arroyo Seco adjacent</div>
          </div>
        </div>
        <div class="nh-col">
          <div class="nh-col__title">Key Streets</div>
          <div class="nh-list">
            <div class="nh-item">Fair Oaks Ave</div>
            <div class="nh-item">Mission St</div>
            <div class="nh-item">Huntington Drive</div>
            <div class="nh-item">Fremont Ave</div>
            <div class="nh-item">Mound Ave</div>
            <div class="nh-item">Garfield Ave</div>
          </div>
        </div>
        <div class="nh-col">
          <div class="nh-col__title">Nearby We Serve</div>
          <div class="nh-list">
            <div class="nh-item">Pasadena (91101–91109)</div>
            <div class="nh-item">San Marino (91108)</div>
            <div class="nh-item">Alhambra (91801)</div>
            <div class="nh-item">San Gabriel (91775)</div>
            <div class="nh-item">Arcadia (91006)</div>
            <div class="nh-item">Monrovia (91016)</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- RECENT REPAIRS -->
  <section class="sp-recent">
    <div class="container">
      <h2>Recent Jobs in South Pasadena</h2>
      <p class="section-sub">Real calls from 91030 — bungalows, vintage kitchens, and modern appliances alike.</p>
      <div class="recent-grid">

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">O'Keefe & Merritt Range</span>
            <span class="recent-location">Marengo Ave, 91030</span>
          </div>
          <div class="recent-card__title">"Two burners not lighting, oven pilot out"</div>
          <div class="recent-card__desc">
            1952 O'Keefe & Merritt in a Craftsman bungalow — the homeowners had kept it
            in beautiful condition and were determined to keep it running. Two surface
            burner igniters had corroded contacts; the oven pilot had gone out and the
            thermocouple was weak. Our tech cleaned and adjusted the igniter contacts,
            relit and adjusted the oven pilot, tested the thermocouple, and ran all
            four burners plus the oven. Everything working perfectly — and a range this
            well-maintained absolutely deserves to keep cooking.
          </div>
          <div class="recent-card__result">✓ Same day · Vintage range restored · Worth every dollar to keep</div>
        </div>

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">Samsung Dishwasher</span>
            <span class="recent-location">Meridian Ave, 91030</span>
          </div>
          <div class="recent-card__title">"Glasses coming out spotty, spray arm barely spinning"</div>
          <div class="recent-card__desc">
            Classic South Pasadena hard water situation — spray arm ports almost
            completely blocked by mineral scale. LADWP 230–310 mg/L plus the older
            supply pipes in this 1930s bungalow. Descaled both spray arms, cleaned
            the filter trap, ran a full citric acid maintenance cycle, confirmed
            full spray arm rotation. Advised a monthly dishwasher cleaning tablet
            routine specifically for hard water — small habit, big difference in
            a house like this.
          </div>
          <div class="recent-card__result">✓ Same day · Scale cleared · Hard water routine explained</div>
        </div>

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">LG Refrigerator</span>
            <span class="recent-location">El Centro, 91030</span>
          </div>
          <div class="recent-card__title">"Ice maker stopped — barely any ice for two months"</div>
          <div class="recent-card__desc">
            LG French door — gradual ice production decline is textbook mineral deposit
            buildup on the water inlet valve. The galvanized pipes in this 1940s South
            Pasadena home had added iron to the LADWP water hardness, leaving significant
            scale on the valve orifice. Replaced the inlet valve with an OEM LG part,
            flushed the water line, replaced the in-door filter (over a year old).
            Full ice production restored within 24 hours. Owner now on 6-month filter
            replacement cycle.
          </div>
          <div class="recent-card__result">✓ Same day · OEM LG inlet valve · Filter replaced · Full production</div>
        </div>

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">Maytag Dryer</span>
            <span class="recent-location">Fairview Ave, 91030</span>
          </div>
          <div class="recent-card__title">"Saturday morning — dryer dead before family visiting"</div>
          <div class="recent-card__desc">
            Called Saturday at 8:30am — Maytag electric dryer completely dead, no heat
            at all, and family coming for the weekend. Arrived by 11am. Thermal fuse
            blown from a partially blocked vent run — the duct ran through the original
            1920s wall cavity and had a 90-degree elbow that had accumulated significant
            lint. Replaced the thermal fuse, cleared the vent run completely, confirmed
            exterior airflow. Single cycle working before noon. Homeowner very relieved.
          </div>
          <div class="recent-card__result">✓ Saturday same day · Done by noon · Vent cleared · Family visit saved</div>
        </div>

      </div>
    </div>
  </section>

  <!-- WHY US -->
  <section class="sp-why">
    <div class="container">
      <h2>Why South Pasadena Calls Us Back</h2>
      <div class="why-grid">
        <div class="why-card">
          <div class="why-icon">🏡</div>
          <div class="why-title">Vintage Range Friendly</div>
          <div class="why-text">O'Keefe & Merritt, Wedgewood, Roper — we assess these honestly. If parts are available and the repair makes economic sense, we do it. South Pasadena's Craftsman kitchens deserve technicians who understand vintage appliances.</div>
        </div>
        <div class="why-card">
          <div class="why-icon">💧</div>
          <div class="why-title">Hard Water Aware</div>
          <div class="why-text">LADWP 230–310 mg/L plus older galvanized pipes means ice makers and dishwashers scale up faster than average. We test inlet valves and check for mineral deposits on every relevant South Pasadena call — it's that consistently a factor here.</div>
        </div>
        <div class="why-card">
          <div class="why-icon">📅</div>
          <div class="why-title">Open Weekends</div>
          <div class="why-text">Saturday 8am–7pm, Sunday 9am–5pm — available when some South Pasadena competitors aren't. If your appliance breaks Friday evening or Saturday morning, you can call us and get it fixed the same day.</div>
        </div>
        <div class="why-card">
          <div class="why-icon">✅</div>
          <div class="why-title">90-Day Warranty, OEM Only</div>
          <div class="why-text">Every repair backed by 90 days on parts and labor. Genuine OEM parts only. $89 diagnostic waived with repair. Written estimate before we start. California licensed, BBB A+ rated.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="sp-reviews">
    <div class="container">
      <h2>What South Pasadena Customers Are Saying</h2>
      <div class="reviews-grid">
        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <div class="review-text">"We have a 1952 O'Keefe & Merritt that we absolutely love. Two companies told us to just get a new stove. Same Day actually came out, knew exactly what was wrong, fixed it in an hour, and the range works perfectly. Someone who understands why these old stoves are worth keeping — that's hard to find."</div>
          <div class="review-author">— Carol W., Marengo Ave, South Pasadena</div>
        </div>
        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <div class="review-text">"Refrigerator ice maker had been dying slowly for months. Same Day came out, immediately identified the mineral buildup from our hard water and older pipes, replaced the inlet valve, showed me the scale on the old one. Ice maker fully working again and I finally understand why it kept failing. Very knowledgeable."</div>
          <div class="review-author">— James T., El Centro, South Pasadena</div>
        </div>
        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <div class="review-text">"Called Saturday morning with a dead dryer and family coming. Tech was here by 11, found the blocked vent and blown fuse, had everything fixed before noon. Most companies around here are closed weekends — Same Day was there and got it done fast. Exactly what I needed."</div>
          <div class="review-author">— Maria L., Fairview Ave, South Pasadena</div>
        </div>
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section class="sp-pricing">
    <div class="container">
      <h2 class="section-title">Appliance Repair Costs in South Pasadena</h2>
      <p class="section-sub">Written estimate before we start. $89 diagnostic — waived with repair.</p>
      <div class="pricing-grid">
        <div class="pricing-card featured">
          <div class="pricing-card__appliance">Vintage Range (O'Keefe, Wedgewood)</div>
          <div class="pricing-card__range">$150 – $300</div>
          <div class="pricing-card__note">Igniter contacts, pilot, thermocouple, oven thermostat</div>
        </div>
        <div class="pricing-card">
          <div class="pricing-card__appliance">Refrigerator / Ice Maker</div>
          <div class="pricing-card__range">$150 – $400</div>
          <div class="pricing-card__note">Fan motor, hard water inlet valve, mineral flush</div>
        </div>
        <div class="pricing-card">
          <div class="pricing-card__appliance">Dishwasher</div>
          <div class="pricing-card__range">$150 – $320</div>
          <div class="pricing-card__note">Hard water descaling + drain pump + spray arm</div>
        </div>
        <div class="pricing-card">
          <div class="pricing-card__appliance">Washer / Dryer</div>
          <div class="pricing-card__range">$150 – $350</div>
          <div class="pricing-card__note">Drain pump, heating element, thermal fuse, vent</div>
        </div>
        <div class="pricing-card">
          <div class="pricing-card__appliance">Modern Oven / Range</div>
          <div class="pricing-card__range">$150 – $400</div>
          <div class="pricing-card__note">Igniter, bake element, gas valve, calibration</div>
        </div>
        <div class="pricing-card">
          <div class="pricing-card__appliance">Diagnostic Fee</div>
          <div class="pricing-card__range">$89</div>
          <div class="pricing-card__note">Waived when you proceed with the repair</div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="sp-faq">
    <div class="container">
      <h2>Questions South Pasadena Customers Ask</h2>
      <div class="faq-list">
        <details class="faq-item"><summary class="faq-question">Do you offer same-day appliance repair in South Pasadena, CA?</summary><div class="faq-answer">Yes. Our technicians cover all of South Pasadena 91030 — Mission Street, Marengo Avenue, Meridian Avenue, El Centro, Fairview Avenue, Diamond Avenue, and all streets through the historic bungalow neighborhoods. Call before noon for same-day afternoon service.</div></details>
        <details class="faq-item"><summary class="faq-question">Do you repair vintage ranges and O'Keefe & Merritt stoves?</summary><div class="faq-answer">Yes. South Pasadena's Craftsman homes often have vintage ranges still running. We assess these honestly — if parts are available and the repair makes economic sense, we do it. We won't tell you to replace a range that can be fixed.</div></details>
        <details class="faq-item"><summary class="faq-question">Does hard water in South Pasadena affect appliances?</summary><div class="faq-answer">Yes. LADWP water hardness in this area runs 230–310 mg/L. Older galvanized pipes add iron on top. Ice maker inlet valves and dishwasher spray arms scale up faster than national average. We test for this on every relevant South Pasadena call.</div></details>
        <details class="faq-item"><summary class="faq-question">Are you available on weekends in South Pasadena?</summary><div class="faq-answer">Yes. Saturday 8am–7pm and Sunday 9am–5pm. Unlike some South Pasadena appliance companies that close weekends, we're available if your appliance breaks Friday evening or Saturday morning.</div></details>
        <details class="faq-item"><summary class="faq-question">What is your diagnostic fee in South Pasadena?</summary><div class="faq-answer">Our diagnostic fee is $89, waived when you proceed with the repair. Written estimate before we start. Most South Pasadena repairs run $150–$400.</div></details>
        <details class="faq-item"><summary class="faq-question">What warranty do you offer on appliance repairs in South Pasadena?</summary><div class="faq-answer">All repairs come with a 90-day warranty on parts and labor. Genuine OEM parts only. If the same issue returns within 90 days, we come back at no charge.</div></details>
        <details class="faq-item"><summary class="faq-question">Do you also serve Pasadena, San Marino, and Alhambra?</summary><div class="faq-answer">Yes. Our South Pasadena service extends to Pasadena, San Marino, Alhambra, San Gabriel, Arcadia, and Monrovia. We're the closest team for all 91030 calls.</div></details>
      </div>
    </div>
  </section>

  <!-- NEARBY -->
  <section class="sp-nearby">
    <div class="container">
      <h2>Also Serving Nearby Areas</h2>
      <div class="nearby-grid">
