---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import CustomNarrative from '../components/cities/v2/CustomNarrative.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

import { mergeCredentials } from '../data/credentials-schema';
const citySlug = 'encino';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = 'Encino';
const zips = ['91316', '91436'];

const title = `Appliance Repair Encino CA — Same Day Service`;
const description = "Same-day appliance repair in Encino, CA. Sub-Zero, Wolf, Thermador, Miele. Estate access ready. LADWP hard water aware. OEM parts.";
const canonical = 'https://samedayappliance.repair/encino/';

const phoneRaw = `+1${branch.phone.replace(/\D/g, '')}`;

const localBusinessSchema = mergeCredentials({
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { '@type': 'Place', name: 'Encino', sameAs: 'https://en.wikipedia.org/wiki/Encino,_Los_Angeles' },
    { '@type': 'Place', name: 'Amestoy Estates' },
    { '@type': 'Place', name: 'Hayvenhurst Hills' }
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$$',
  license: 'BHGS #A49573'

});

const twoEncinosNarrative = {
  headline: 'Two Encinodes — One Service',
  paragraphs: [
    "The Ventura Blvd divide matters for appliances. Here's what each zone looks like."
  ],
  subSections: [
    {
      title: 'Hillside · Estates · South Encino · 91436 · Amestoy Estates · Hayvenhurst Hills',
      paragraphs: [
        "The hillside homes south of Ventura Boulevard in 91436 are among the most private and substantial properties in the San Fernando Valley. Sub-Zero built-ins, Wolf ranges, Thermador wall ovens, and Miele dishwashers are the standard. Many properties have estate managers or household staff. We coordinate gate access in advance, work with whoever is managing the property, and bring OEM parts for every luxury brand on every vehicle."
      ]
    },
    {
      title: 'Valley · Residential · North Encino · 91316 · Encino Commons · Balboa Corridor',
      paragraphs: [
        "North of Ventura, Encino is established Valley residential — well-maintained single-family homes and condos near Balboa Park, Encino Commons, and the Ventura Freeway corridor. LG, Samsung, GE, and Whirlpool are the common brands here. Same reliable same-day service, same $89 diagnostic waived with repair, same 90-day warranty."
      ]
    }
  ]
};

const introParagraphs = [
  "Encino is genuinely two communities sharing a single name. South of Ventura Boulevard, the 91436 hillside neighborhoods — Amestoy Estates, Hayvenhurst Hills, the streets up off Louise and Libbit — are some of the largest, most private homes in the Valley. Kitchens here run $50K–$150K in appliance value: Sub-Zero columns, Wolf dual-fuel ranges, Thermador wall ovens, Miele panel-integrated dishwashers. Many properties have estate managers, household staff, or property management on the access side.",
  "North of Ventura in 91316, Encino is established Valley residential — single-family homes and condos near Balboa Park, Encino Commons, and along the Ventura Freeway corridor. LG, Samsung, GE, and Whirlpool dominate. Different appliance landscape, same service standard.",
  "LADWP water hardness across both ZIPs runs 230–310 mg/L. The single most common Sub-Zero call we get from the 91436 hillside is gradual ice maker decline — and the cause is almost always LADWP mineral scale on the fill valve, not the compressor or the ice maker module. We carry OEM Sub-Zero fill valves on every vehicle for exactly this reason.",
  `Diagnostic fee is $89, credited toward repair. Call <a href="tel:${phoneRaw}">${branch.phone}</a> for same-day service across all of Encino.`,
  "<strong>LADWP hard water tip for Encino:</strong> Sub-Zero ice makers in the 91436 hillside homes are frequently affected by LADWP mineral scale on the fill valve — the same mechanism as a $400 Samsung, but the part costs more and the stakes feel higher. A gradual decline in ice output over weeks or months is almost always the fill valve, not the compressor or the ice maker module. OEM Sub-Zero valve replacement is the correct fix. We carry them."
];

const services = [
  { icon: '❄️', name: 'Refrigerator Repair', slug: 'refrigerator', issues: 'Sub-Zero built-in · LADWP ice maker · Not cooling · Fan motor', brands: 'Sub-Zero · Samsung · LG · GE · Thermador · Wolf' },
  { icon: '🔥', name: 'Oven, Range & Pro Range', slug: 'oven', issues: 'Wolf dual-fuel · Thermador star burner · Gas igniter', brands: 'Wolf · Thermador · Viking · GE · Samsung · KitchenAid' },
  { icon: '🍽️', name: 'Dishwasher Repair', slug: 'dishwasher', issues: 'Miele · LADWP scale · Panel-ready · Not draining', brands: 'Miele · Thermador · Bosch · KitchenAid · Samsung · GE' },
  { icon: '🫧', name: 'Washer Repair', slug: 'washer', issues: 'OE / UE error · Not draining · Stackable', brands: 'LG · Samsung · Whirlpool · Maytag · Bosch · Miele' },
  { icon: '💨', name: 'Dryer Repair + Vent Cleaning', slug: 'dryer', issues: 'Hillside vent runs · Not heating · Thermal fuse · Vent buildup', brands: 'LG · Samsung · GE · Maytag · Whirlpool · Miele' },
  { icon: '🧊', name: 'Freezer & Ice Maker Repair', slug: 'freezer', issues: 'Sub-Zero LADWP fill valve · Not freezing · Ice stopped', brands: 'Sub-Zero · Samsung · LG · GE · True · Whirlpool' },
  { icon: '🍷', name: 'Wine Cellar & Cooler Repair', slug: 'wine-cooler', issues: 'Sub-Zero wine · WhisperKOOL · EuroCave · Temperature off', brands: 'Sub-Zero · EuroCave · True · WhisperKOOL · Liebherr' },
  { icon: '♨️', name: 'Cooktop & Range Hood', slug: 'cooktop', issues: 'Wolf star burner · Thermador igniter · Induction · Hood motor', brands: 'Wolf · Thermador · Gaggenau · Miele · Viking · Dacor' }
];

const neighborhoods = [
  { name: 'Amestoy Estates', zip: '91436', featured: true },
  { name: 'Hayvenhurst Hills area', zip: '91436', featured: true },
  { name: 'Libbit Ave', zip: '91436', featured: true },
  { name: 'Louise Ave', zip: '91436' },
  { name: 'Encino Ave hillside', zip: '91436' },
  { name: 'Zelzah Ave upper', zip: '91436' },
  { name: 'Mulholland adjacent', zip: '91436' },
  { name: 'Encino Commons area', zip: '91316' },
  { name: 'Balboa Park corridor', zip: '91316' },
  { name: 'White Oak Ave', zip: '91316' },
  { name: 'Balboa Blvd', zip: '91316' },
  { name: 'Los Encinos area', zip: '91316' }
];

const recentJobs = [
  {
    appliance: 'Sub-Zero Built-In Fridge',
    location: 'Amestoy Estates, 91436',
    quote: 'Ice maker almost completely stopped — been declining for weeks',
    description: "Amestoy Estates estate — gate access coordinated through the property manager the morning of the call. Sub-Zero 48-inch built-in with ice output declining over approximately six weeks to near zero. LADWP mineral scale on the fill valve had restricted flow to less than 10% capacity. Replaced with the OEM Sub-Zero fill valve assembly, flushed both water lines, confirmed full ice production from both columns. Recommended a 6-month filter replacement cycle appropriate for LADWP territory. Property manager sent confirmation to the homeowner — done before the family returned that evening.",
    outcome: '✓ Same day · Gate coordinated · OEM Sub-Zero · Both columns · 6-month plan'
  },
  {
    appliance: 'Wolf Dual-Fuel Range',
    location: 'South Encino hills, 91436',
    quote: "Two star burners won't light — clicking but no flame",
    description: "South Encino hillside home — Wolf 48-inch dual-fuel range with two star burner igniter electrodes failed from thermal cycling in a heavily-used kitchen. Replaced both electrode assemblies with OEM Wolf parts, tested all eight surface burners and both oven cavities. Confirmed accurate temperature on dual oven at 350°F and 450°F. Also checked the remaining six electrodes for early degradation signs — two showing early wear but still functional, noted for the homeowner as a 12-month replacement candidate.",
    outcome: '✓ Same day · OEM Wolf igniters · All 8 burners · Both ovens · Proactive notes'
  },
  {
    appliance: 'LG Front-Load Washer',
    location: 'North Encino, 91316',
    quote: 'OE error every cycle — water sitting in the drum',
    description: "North Encino home near Balboa Park — LG front-loader OE drain error. Pump filter blocked with a combination of lint and LADWP mineral scale deposits. Cleared the filter housing thoroughly, confirmed drain pump operation, ran three full cycles including a spin-only cycle. OE resolved. Also found the door boot seal starting to develop a slight weep — pointed it out to the owner as a 6-month watch item before it becomes a full leak. One call, two issues addressed.",
    outcome: '✓ Same day · OE resolved · Boot seal noted · LADWP scale explained'
  },
  {
    appliance: 'Thermador Dishwasher',
    location: 'Hayvenhurst Hills, 91436',
    quote: 'Not cleaning — dishes coming out with white film, E24 error',
    description: "Hayvenhurst Hills estate — Thermador panel-integrated dishwasher with E24 drain error and heavy mineral film on dishes. Two-part problem: drain pump filter loaded with LADWP mineral scale, and the spray arm jets partially blocked by the same calcification. Cleared the drain pump filter, descaled the spray arm jets, confirmed full drain on the Thermador diagnostic cycle, ran a full wash — clean dishes, no film. Set the homeowner on a 3-month descale maintenance cycle using the correct Thermador descaling program — appropriate for LADWP hardness.",
    outcome: '✓ Same day · E24 resolved · Spray arms descaled · 3-month maintenance plan'
  }
];

const whyReasons = [
  {
    iconKey: 'team' as const,
    title: 'Estate Service Ready',
    body: "Amestoy Estates, Hayvenhurst Hills, and the South Encino hillside homes routinely involve estate managers, property management, household staff, or gate guards. We coordinate access in advance and run the appointment without the homeowner needing to be present."
  },
  {
    iconKey: 'parts' as const,
    title: 'Sub-Zero Specialists',
    body: 'South Encino is Sub-Zero territory — built-in columns, wine columns, panel-integrated units. We carry OEM Sub-Zero fill valves, fan motors, ice maker modules, and the diagnostic tooling specific to these units on every Encino vehicle.'
  },
  {
    iconKey: 'shield' as const,
    title: 'LADWP Hard Water Aware',
    body: 'LADWP water at 230–310 mg/L hardness is the single most consistent cause of Sub-Zero ice maker decline in 91436. We diagnose for it first on every gradual-decline ice maker call and resolve it without unnecessary parts replacement.'
  },
  {
    iconKey: 'clock' as const,
    title: '90-Day Warranty, OEM Only',
    body: 'Every repair we do in Encino carries a 90-day warranty on parts and labor. We use OEM parts on every job — Sub-Zero, Wolf, Thermador, Miele, and the rest. Same issue returns within 90 days — we come back at no charge.'
  }
];

const testimonials = [
  {
    stars: 5,
    text: '"Sub-Zero in our Amestoy Estates home — ice declining for weeks. Tech coordinated gate access through our property manager, came same day, replaced the fill valve with OEM Sub-Zero parts, confirmed full production. Done before we got home that evening. Exactly the level of service this house calls for."',
    author: '— (via property manager), Amestoy Estates, Encino 91436'
  },
  {
    stars: 5,
    text: '"Wolf range with two star burners not lighting in our south Encino kitchen. Tech replaced both OEM Wolf igniters, tested all eight burners and both oven cavities, and then told me two more electrodes were showing early wear and to watch them in 12 months. That kind of proactive communication is rare and valuable."',
    author: '— Jennifer T., South Encino hills, 91436'
  },
  {
    stars: 5,
    text: '"Thermador dishwasher E24 error and white film on everything. Tech cleared the pump filter, descaled the spray arms, showed me the LADWP hard water connection, and set me up on a 3-month descale maintenance routine specific to Thermador\'s program. Clean dishes from the first load. Thorough and honest."',
    author: '— Robert C., Hayvenhurst Hills, Encino 91436'
  }
];

const pricingTiers = [
  { appliance: 'Sub-Zero / Wolf', range: '$300–$800+', note: 'OEM parts · Built-in column · Pro range · Estate access', featured: true },
  { appliance: 'Thermador / Miele / Viking', range: '$250–$600+', note: 'OEM parts · Panel-ready · Pro range', featured: true },
  { appliance: 'Refrigerator (Standard)', range: '$150–$400', note: 'Inlet valve · Coil cleaning · Ice maker · Fan motor' },
  { appliance: 'Washer / Dryer', range: '$150–$350', note: 'OE/UE/LE errors · Pump filter · Vent cleaning' },
  { appliance: 'Dishwasher / Oven', range: '$150–$450', note: 'Spray arm descale · Igniter · Element' },
  { appliance: 'Diagnostic Fee', range: '$89', note: 'Credited toward repair · Written estimate' }
];

const faqs = [
  {
    question: 'Do you offer same-day appliance repair in Encino?',
    answer: "Yes — we cover both 91316 and 91436 daily, including Amestoy Estates, Hayvenhurst Hills, the South Encino hillside, Encino Commons, and the Balboa Park corridor. Call before noon for same-day service."
  },
  {
    question: 'Do you specialize in Sub-Zero refrigerator repair in Encino?',
    answer: "Yes. South Encino's 91436 is Sub-Zero territory — built-in columns, wine columns, panel-integrated units. We carry OEM Sub-Zero fill valves, condenser fan motors, ice maker modules, and the brand-specific diagnostic tools on every Encino vehicle."
  },
  {
    question: 'Do you service gated communities and estate properties in Encino?',
    answer: "Yes. Amestoy Estates and the larger South Encino hillside homes routinely involve estate managers, property management firms, household staff, or gate guards. Tell us when you call who manages access and we coordinate in advance — the appointment runs without the homeowner needing to be present."
  },
  {
    question: 'How does LADWP hard water affect appliances in Encino?',
    answer: "LADWP hardness across 91316 and 91436 runs 230–310 mg/L. The most common impacts: Sub-Zero ice maker fill valves scaling up over weeks to months (gradual decline pattern), dishwasher spray arms accumulating mineral deposits that cause white film on glassware, and washing machine pump filters blocking from a combination of LADWP scale and lint. We address the root cause and recommend the right maintenance interval for each."
  },
  {
    question: 'Are weekend appointments available in Encino?',
    answer: "Yes — we offer Saturday appointments. Call to confirm the next available slot. Sunday appointments are limited but we answer the phone every day."
  },
  {
    question: 'What is your diagnostic fee in Encino?',
    answer: "Our diagnostic fee is $89. It covers the trip, full appliance inspection, and a written estimate. If you proceed with the repair, the $89 is credited toward your invoice."
  },
  {
    question: 'Do you also serve Tarzana, Sherman Oaks, and Woodland Hills from Encino?',
    answer: "Yes — our Encino-area routes also cover Tarzana, Sherman Oaks, Woodland Hills, Studio City, and Calabasas. Same-day service is typically available across this corridor."
  }
];

const nearbyCities = [
  { name: 'Sherman Oaks', slug: 'sherman-oaks' },
  { name: 'Studio City', slug: 'studio-city' },
  { name: 'Calabasas', slug: 'calabasas' },
  { name: 'Thousand Oaks', slug: 'thousand-oaks' },
  { name: 'West Hollywood', slug: 'west-hollywood' },
  { name: 'Bel Air', slug: 'bel-air' },
  { name: 'Beverly Hills', slug: 'beverly-hills' },
  { name: 'Los Angeles', slug: 'los-angeles' }
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair"
    headlineCity="Encino, CA"
    subheadline="South Encino estates and North Encino residential — Sub-Zero, Wolf, Thermador, Miele specialists. Estate access ready. LADWP hard water aware. Same-day, OEM parts, 90-day warranty."
    zips={zips}
    tier={1}
  />

  <TrustBadgesRow />

  <CustomNarrative
    headline={twoEncinosNarrative.headline}
    paragraphs={twoEncinosNarrative.paragraphs}
    subSections={twoEncinosNarrative.subSections}
    background="black"
  />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance Repair in Encino — The Full Picture"
    paragraphs={introParagraphs}
    bookingTitle="Encino Service"
    bookingSub="91316 · 91436 · Estate access ready · Same day"
  />

  <ServicesGrid
    cityName={cityName}
    headline="What We Repair in Encino"
    services={services}
  />

  <ServiceArea
    cityName={cityName}
    headline="Encino Neighborhoods We Service"
    subheadline="From the 91436 hillside estates to the 91316 Balboa corridor — every part of Encino."
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={['Ventura Blvd', 'Louise Ave', 'Libbit Ave', 'Encino Ave', 'White Oak Ave', 'Balboa Blvd']}
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Repairs in Encino"
    jobs={recentJobs}
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="Why Encino Homeowners Call Us"
    reasons={whyReasons}
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What Encino Clients Say"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Repair Pricing in Encino"
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="Frequently Asked Questions — Encino"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby Cities"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance broken in Encino?"
    body="Amestoy Estates · South Encino hills · North Encino · Sub-Zero · Wolf · Thermador · LADWP. $89 diagnostic waived with repair. 90-day warranty."
  />
</CityLayoutV2>
