---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import CustomNarrative from '../components/cities/v2/CustomNarrative.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

const citySlug = 'bel-air';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = 'Bel Air';
const zips = ['90077'];

const phoneRaw = `+1${branch.phone.replace(/\D/g, '')}`;

const title = `Appliance Repair Bel Air CA 90077 — Sub-Zero · Wolf · Estate Service | ${branch.phone}`;
const description = `Same-day appliance repair in Bel Air, CA 90077. Lower Bel Air, Upper Bel Air, Stone Canyon, East Gate, West Gate. Sub-Zero, Wolf, Thermador, Gaggenau. Estate managers welcome. Licensed, OEM parts, 90-day warranty. Call ${branch.phone}.`;
const canonical = 'https://samedayappliance.repair/bel-air/';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { '@type': 'Neighborhood', name: 'Bel Air', sameAs: 'https://en.wikipedia.org/wiki/Bel_Air,_Los_Angeles' },
    { '@type': 'Neighborhood', name: 'Lower Bel Air' },
    { '@type': 'Neighborhood', name: 'Upper Bel Air' },
    { '@type': 'Neighborhood', name: 'Holmby Hills' },
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$$',
  license: 'CA CSLB #1138898'

};

const introParagraphs = [
  "Bel Air service calls are different from most of what we do in LA. The kitchens are larger and more complex — Sub-Zero column pairs, Wolf dual-fuel ranges, Gaggenau steam combi ovens, Miele and Thermador dishwashers with panel-front custom cabinetry. The properties require coordination: estate managers, security gates, household staff who manage access. Our technicians don't treat that as a burden — it's simply how Bel Air works, and we've been doing it long enough to handle the logistics without making them the homeowner's problem.",
  "The hillside geography matters for appliances too. Upper Bel Air and Stone Canyon properties have equipment rooms and service alcoves where appliances are installed in tight configurations that require care and the right tools to service without damaging surrounding cabinetry. Dryer vents in these hillside homes often run longer, more complex paths than flat properties. We come prepared for what we'll find — not surprised by it.",
  "Hard water is a real factor in 90077. LADWP delivers water at 230–310 mg/L in this area, and the older hillside supply lines can add iron on top of that. Ice maker inlet valves, dishwasher spray arms, and washing machine hoses scale up 2–3x faster than the national average. We test and check these components on every Bel Air call involving ice makers and dishwashers — it's consistently relevant here.",
  `Diagnostic fee: <strong>$89</strong> — waived with repair. Written estimate before we start anything. <strong>90-day warranty</strong> on all parts and labor. OEM parts only — no aftermarket substitutes that compromise warranty compliance or performance on luxury systems. Call <a href="tel:${phoneRaw}">${branch.phone}</a>.`,
];

const services = [
  { icon: '🧊', name: 'Refrigerator Repair', slug: 'refrigerator', issues: 'Built-in columns · Not cooling · Hard water ice maker · Sealed system', brands: 'Sub-Zero · Wolf · True · Monogram · Samsung · LG' },
  { icon: '🔥', name: 'Oven, Range & Steam Oven', slug: 'oven', issues: 'Dual-fuel · Steam combi · Temperature off · Igniter · Calibration', brands: 'Wolf · Gaggenau · Thermador · Miele · Viking · La Cornue' },
  { icon: '🍽️', name: 'Dishwasher Repair', slug: 'dishwasher', issues: 'Panel-ready · Hard water spray arm scale · Error codes · Miele systems', brands: 'Miele · Gaggenau · Thermador · Bosch · Cove · KitchenAid' },
  { icon: '🫧', name: 'Washer & Dryer Repair', slug: 'washer', issues: 'Miele heat pump dryer · Hard water inlet screens · Hillside vent runs', brands: 'Miele · Gaggenau · LG · Samsung · Bosch · Speed Queen' },
  { icon: '🍷', name: 'Wine Cellar & Cooler Repair', slug: 'wine-cooler', issues: 'Temperature fluctuation · Built-in · WhisperKOOL · Sub-Zero wine', brands: 'Sub-Zero · EuroCave · True · WhisperKOOL · U-Line · Liebherr' },
  { icon: '🔆', name: 'Cooktop & Range Hood', slug: 'cooktop', issues: 'Thermador Freedom induction · Wolf star burner · Hood motor', brands: 'Wolf · Thermador · Gaggenau · Miele · Viking · Dacor' },
  { icon: '🧊', name: 'Ice Machine & Ice Maker', slug: 'ice-maker', issues: 'Hard water scale · Low production · Inlet valve · Built-in', brands: 'Sub-Zero · True · Scotsman · U-Line · GE Monogram' },
  { icon: '❄️', name: 'Freezer Repair', slug: 'freezer', issues: 'Built-in columns · Not freezing · Sealed system · Frost buildup', brands: 'Sub-Zero · True · GE Monogram · Thermador · Viking' },
];

const brandedExpertiseNarrative = {
  eyebrow: 'LUXURY BRAND SPECIALISTS',
  headline: 'The Brands Common in Bel Air Kitchens — And What We Know About Them',
  paragraphs: [
    "Sub-Zero's dual-evaporator architecture. Wolf's star burner ignition system and dual-fuel oven configurations. Thermador's Freedom induction and ProGrand range specifics. Gaggenau's steam combi oven electronic controls. Miele's T1 dryer heat pump system. These machines have fundamentally different failure modes, service procedures, and part sourcing than standard brands.",
    "Our technicians carry OEM parts for all of these on every Bel Air vehicle. We diagnose correctly on the first visit because we know what these appliances actually do when they fail — not just what they're supposed to do when they're working.",
    "Brands we service: Sub-Zero · Wolf · Thermador · Gaggenau · Miele · Monogram · Viking · La Cornue · True Residential · Dacor · Fisher & Paykel · Cove. Plus all standard brands — Samsung, LG, GE, Whirlpool, Bosch, KitchenAid, Maytag, and more.",
  ]
};

const neighborhoods = [
  { name: 'Lower Bel Air (Sunset Blvd)', zip: '90077', featured: true },
  { name: 'Upper Bel Air', zip: '90077', featured: true },
  { name: 'Stone Canyon Road', zip: '90077', featured: true },
  { name: 'East Gate (Bellagio Dr)', zip: '90077' },
  { name: 'West Gate (Bel Air Rd)', zip: '90077' },
  { name: 'Bel Air Crest', zip: '90077' },
  { name: 'Bel Air Knolls', zip: '90077' },
  { name: 'Stradella Rd corridor', zip: '90077' },
  { name: 'Holmby Hills', zip: '90077' },
  { name: 'Benedict Canyon', zip: '90077' },
  { name: 'Coldwater Canyon', zip: '90077' },
];

const recentJobs = [
  {
    appliance: 'Sub-Zero Column',
    location: 'Upper Bel Air, Stone Canyon Rd',
    quote: '"Ice maker stopped completely, fridge temperature drifting"',
    description: "Estate coordinated through the property manager — access through the service entrance off the motor court, tight equipment room behind the kitchen. Sub-Zero 36-inch refrigerator column: inlet valve almost entirely scaled with mineral deposits from Bel Air's hard water supply. No ice production at all, and the water line restriction had started affecting the dispenser. Replaced the inlet valve with an OEM Sub-Zero part, flushed the water line, replaced the in-door filter. Ice production restored within 24 hours. Property manager received a full service report.",
    outcome: '✓ Same day · Estate coordinated · OEM Sub-Zero · Service report delivered'
  },
  {
    appliance: 'Gaggenau Steam Combi',
    location: 'Lower Bel Air, Sunset Blvd corridor',
    quote: '"F63 error, steam function not engaging"',
    description: "Gaggenau steam combi oven — F63 is a steam generator fault. Found the steam generator fill valve scaled with mineral deposits; the valve couldn't fully open to fill the tank. Descaled the fill valve assembly, tested steam generation through a full cycle, confirmed temperature calibration on both convection and steam modes. The housekeeper had been managing the call — homeowner received a brief summary via the estate manager. Gaggenau steam combi issues are uncommon but we know them well.",
    outcome: '✓ Same day · Gaggenau steam generator · Scale cleared · Both modes confirmed'
  },
  {
    appliance: 'Miele T1 Dryer',
    location: 'Bel Air Crest, 90077',
    quote: '"Error code F73, laundry room in the basement"',
    description: "Miele T1 heat pump dryer — F73 is a drain pump fault. The vent-free heat pump dryer routes condensate through a pump to a drain; the pump had a partial blockage. Cleared the condensate pump, ran diagnostic cycles, confirmed full drain function. The basement laundry room had the dryer stacked on a washer column in a built-in niche — our tech worked in that configuration without pulling the stack. Clean exit, everything back as found.",
    outcome: '✓ Same day · Miele heat pump · Stacked niche · No stack removal needed'
  },
  {
    appliance: 'Wolf Dual-Fuel Range',
    location: 'East Gate, Bellagio Dr',
    quote: '"Oven not reaching temperature, two star burners won\'t light"',
    description: "Wolf 48-inch dual-fuel — oven igniter drawing weak current (Wolf-specific failure: igniter glows but can't draw enough amperage to open the gas valve). Two surface igniter electrodes corroded — this home had occasional water intrusion near the range from a window above. Replaced all three igniters with OEM Wolf parts, calibrated oven to factory spec (was running 28°F low), sealed the electrode wells against moisture. Chef-managed kitchen; the household chef ran test dishes after — approved.",
    outcome: '✓ Same day · OEM Wolf · Calibrated · Chef sign-off'
  },
];

const whyReasons = [
  {
    iconKey: 'team' as const,
    title: 'Estate-Ready, Every Time',
    body: "Property managers, estate managers, household staff, gated access — this is the norm in Bel Air and we handle it professionally. We coordinate before arrival, work quietly and cleanly, and provide service documentation. The homeowner doesn't need to be involved unless they want to be."
  },
  {
    iconKey: 'parts' as const,
    title: 'Luxury Brand Depth',
    body: 'Sub-Zero, Wolf, Gaggenau, Thermador, Miele, La Cornue — we carry OEM parts for these brands and are trained on their specific systems. Not general appliance technicians who "also do" luxury brands. These are our primary focus in Bel Air.'
  },
  {
    iconKey: 'shield' as const,
    title: 'Hard Water Diagnostics',
    body: 'LADWP 230–310 mg/L in this area means ice makers and dishwashers scale up 2–3x faster than average. We test inlet valves and check for mineral deposits on every relevant Bel Air call — and we diagnose the actual cause before recommending expensive parts.'
  },
  {
    iconKey: 'clock' as const,
    title: '90-Day Warranty, OEM Only',
    body: 'Every repair backed by 90 days on parts and labor. Genuine OEM parts only — critical for maintaining manufacturer warranties on luxury appliances. $89 diagnostic waived with repair. Written estimate, no surprises.'
  },
];

const testimonials = [
  {
    stars: 5,
    text: "\"Our Sub-Zero column stopped making ice completely. Property manager coordinated everything — Same Day came through the service entrance, worked in the equipment room, replaced the inlet valve, left a service report. Homeowner didn't need to be involved at all. Exactly how estate service should work.\"",
    author: '— C. Harrison (Estate Manager), Upper Bel Air'
  },
  {
    stars: 5,
    text: "\"Gaggenau steam combi oven with an F63 error. Most companies I called didn't know what that was. Same Day came out same afternoon, diagnosed the mineral scale on the fill valve, cleared it, tested everything. The technician knew this oven specifically. Very impressed.\"",
    author: '— Diana W., Lower Bel Air'
  },
  {
    stars: 5,
    text: '"Wolf range — oven low and two burners dead. Tech came to our East Gate property same day, had all the OEM Wolf parts, recalibrated the oven. He explained every step to our house chef and made sure she was satisfied before leaving. Professional, thorough, and genuinely expert on Wolf equipment."',
    author: '— The Fairfax Estate, East Gate Bel Air'
  },
];

const pricingTiers = [
  { appliance: 'Sub-Zero / Wolf / Gaggenau', range: '$300–$800+', note: 'OEM parts · Built-in · Sealed system · Hard water check', featured: true },
  { appliance: 'Thermador / Miele / Viking', range: '$250–$600+', note: 'OEM parts · Panel-ready · Steam oven · Heat pump dryer' },
  { appliance: 'Refrigerator (standard)', range: '$200–$450', note: 'Fan motor, ice maker, hard water inlet valve' },
  { appliance: 'Washer / Dryer', range: '$150–$450', note: 'Miele heat pump · European models · Hard water screens' },
  { appliance: 'Dishwasher', range: '$150–$400', note: 'Hard water descaling · Miele electronics · Panel-ready' },
  { appliance: 'Diagnostic Fee', range: '$89', note: 'Waived when you proceed with the repair' },
];

const faqs = [
  {
    question: 'Do you offer same-day appliance repair in Bel Air, CA?',
    answer: 'Yes. Our technicians serve all of Bel Air 90077 — Lower Bel Air along Sunset, Upper Bel Air and Stone Canyon Rd, the East Gate and West Gate corridor, Bel Air Crest, and Holmby Hills. Call before noon for same-day afternoon service.'
  },
  {
    question: 'Do you repair Sub-Zero, Wolf, Gaggenau, and Thermador appliances in Bel Air?',
    answer: 'Yes. Sub-Zero, Wolf, Thermador, Miele, Gaggenau, and Monogram are standard in Bel Air kitchens. Our technicians are trained on these brands, carry OEM parts on every service vehicle, and are experienced with the complex built-in and panel-ready configurations common in Bel Air estates. We never use aftermarket substitutes.'
  },
  {
    question: 'Can you coordinate with estate managers and household staff in Bel Air?',
    answer: "Yes, and it's the norm here. Our technicians regularly work with estate managers, household staff, property managers, and security teams. We coordinate access, arrive on schedule, work quietly and cleanly, and provide service documentation for estate records. The homeowner doesn't need to be present."
  },
  {
    question: 'Do hillside properties in Bel Air create specific appliance challenges?',
    answer: "Yes. Upper Bel Air and Stone Canyon hillside estates often have appliances installed in tight equipment rooms or custom-built niches where standard service access isn't straightforward. Dryer vent runs in hillside homes are frequently longer and more complex than in flat properties. Our technicians have the tools and experience to work in these configurations without damaging surrounding cabinetry or finishes."
  },
  {
    question: 'Does hard water affect appliances in Bel Air?',
    answer: 'Yes. LADWP water hardness in the Bel Air area runs 230–310 mg/L, and hillside properties with older pipes can carry additional iron. This accelerates scale buildup in ice maker inlet valves, dishwasher spray arms, and washing machine inlet hoses. We test inlet valves and check for mineral deposits on every Bel Air call involving ice makers and dishwashers.'
  },
  {
    question: 'What is your diagnostic fee in Bel Air?',
    answer: 'Our diagnostic fee is $89, waived when you proceed with the repair. We provide a complete written estimate before starting any work. Luxury brand repairs may run higher due to OEM part pricing — always disclosed upfront, never a surprise on the invoice.'
  },
  {
    question: 'Do you also serve Beverly Hills, Holmby Hills, and Westwood?',
    answer: "Yes. Our Bel Air service area extends to Beverly Hills (90210), Holmby Hills, Westwood (90024), Brentwood (90049), Century City, and the Sunset Strip corridor. We're your closest team for all properties in the 90077 and adjacent ZIP codes."
  },
];

const nearbyCities = [
  { name: 'Beverly Hills', slug: 'beverly-hills' },
  { name: 'Brentwood', slug: 'brentwood' },
  { name: 'West Hollywood', slug: 'west-hollywood' },
  { name: 'Los Angeles', slug: 'los-angeles' },
  { name: 'Santa Monica', slug: 'santa-monica' },
  { name: 'Pacific Palisades', slug: 'pacific-palisades' },
  { name: 'Malibu', slug: 'malibu' },
  { name: 'Hollywood', slug: 'hollywood' },
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair"
    headlineCity="Bel Air, CA"
    subheadline="Sub-Zero, Wolf, Gaggenau, Thermador, Miele — the appliances that define Bel Air kitchens. Our technicians work here regularly: estate coordination, gated access, hillside installations, hard water diagnostics. Same-day service, OEM parts, 90-day warranty."
    zips={zips}
    tier={1}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance Repair in Bel Air — How We Actually Work Here"
    paragraphs={introParagraphs}
    bookingTitle="Bel Air Service Team"
    bookingSub="90077 · Estate-ready · Same day"
  />

  <CustomNarrative
    eyebrow={brandedExpertiseNarrative.eyebrow}
    headline={brandedExpertiseNarrative.headline}
    paragraphs={brandedExpertiseNarrative.paragraphs}
    background="black"
  />

  <ServicesGrid
    cityName={cityName}
    headline="What We Repair in Bel Air"
    subhead="Built-ins, luxury brands, hillside installations · All of 90077"
    services={services}
  />

  <ServiceArea
    cityName={cityName}
    headline="All of Bel Air — 90077"
    subheadline="Lower Bel Air to Stone Canyon · East Gate to West Gate · Every part of the 90077"
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={['Sunset Blvd (Lower)', 'Bel Air Rd', 'Bellagio Dr', 'Stone Canyon Rd', 'Stradella Rd', 'Mulholland Dr (north)']}
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Jobs in Bel Air"
    jobs={recentJobs}
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="Why Bel Air Clients Choose Us"
    reasons={whyReasons}
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What Bel Air Clients Are Saying"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Appliance Repair Costs in Bel Air"
    subhead="Written estimate before we start. $89 diagnostic — waived with repair. OEM parts only."
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="Questions Bel Air Clients Ask"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby Areas"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance issue in Bel Air?"
    body="Sub-Zero · Wolf · Gaggenau · Thermador · Estate coordination · Hard water diagnostics. $89 diagnostic waived with repair. 90-day warranty. OEM parts only."
  />
</CityLayoutV2>
