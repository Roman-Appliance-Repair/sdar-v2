---
// src/pages/pasadena.astro
// SDAR — samedayappliance.repair
// Pasadena, CA — Хаб филиала · Волна 2
// Телефон: (626) 376-4458
// GSC: 6,926 показов · 1 клик · CTR 0.01%
// Апрель 2026

import Layout from '../layouts/Layout.astro';

const city = {
  name: "Pasadena",
  state: "CA",
  county: "Los Angeles",
  zips: ["91101", "91103", "91104", "91105", "91106", "91107"],
  phone: "(626) 376-4458",
  phoneRaw: "+16263764458",
  email: "pasadena@samedayappliance.repair",
  branch: "Pasadena",
  slug: "pasadena",
};

const title = `Appliance Repair Pasadena CA — Same Day | All Brands | (626) 376-4458`;
const description = `Same-day appliance repair in Pasadena, CA. Our technicians serve Old Town, South Pasadena, Arcadia, San Gabriel Valley. Refrigerator, washer, dryer, oven. Licensed, OEM parts, 90-day warranty. Call (626) 376-4458.`;
const canonical = `https://samedayappliance.repair/pasadena/`;

const schemaLocalBusiness = {
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  "name": "Same Day Appliance Repair — Pasadena",
  "image": "https://samedayappliance.repair/images/logo.webp",
  "url": canonical,
  "telephone": city.phoneRaw,
  "email": city.email,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "55 S Lake Ave",
    "addressLocality": "Pasadena",
    "addressRegion": "CA",
    "postalCode": "91101",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 34.1478,
    "longitude": -118.1445
  },
  "openingHoursSpecification": [
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "07:00", "closes": "21:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Saturday"], "opens": "08:00", "closes": "19:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Sunday"], "opens": "09:00", "closes": "17:00" }
  ],
  "areaServed": [
    { "@type": "City", "name": "Pasadena", "sameAs": "https://en.wikipedia.org/wiki/Pasadena,_California" },
    { "@type": "City", "name": "Arcadia" },
    { "@type": "City", "name": "San Marino" },
    { "@type": "City", "name": "South Pasadena" }
  ],
  "priceRange": "$$",
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.6",
    "reviewCount": "37",
    "bestRating": "5"
  }
};

const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Do you offer same-day appliance repair in Pasadena, CA?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our Pasadena technicians offer same-day service throughout the city — Old Town, South Pasadena, Arcadia, San Marino, La Cañada Flintridge, and across the San Gabriel Valley. Call us before noon and we'll do our best to be there the same afternoon. We serve ZIP codes 91101, 91103, 91104, 91105, 91106, and 91107." }
    },
    {
      "@type": "Question",
      "name": "What appliances do your technicians repair in Pasadena?",
      "acceptedAnswer": { "@type": "Answer", "text": "Our team repairs all major home and commercial appliances: refrigerators, washers, dryers, ovens, stoves, dishwashers, cooktops, freezers, wine coolers, microwaves, and range hoods. We work on all brands — from everyday Whirlpool and Samsung to high-end Sub-Zero, Viking, Thermador, and Miele." }
    },
    {
      "@type": "Question",
      "name": "How much does appliance repair cost in Pasadena?",
      "acceptedAnswer": { "@type": "Answer", "text": "Most home appliance repairs in Pasadena run between $150 and $400 depending on the appliance and the issue. Our diagnostic fee is $89 and is waived when you go ahead with the repair. We give you a full written estimate before we start any work — no surprises on the invoice." }
    },
    {
      "@type": "Question",
      "name": "Do you repair Sub-Zero and Viking appliances in Pasadena?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Pasadena has a lot of high-end appliances — Sub-Zero refrigerators, Viking ranges, Thermador cooktops — especially in the older estates and renovated Craftsman homes. Our technicians are trained on these brands and carry OEM parts for them on every service vehicle." }
    },
    {
      "@type": "Question",
      "name": "Do you also do commercial appliance repair in Pasadena?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. We repair commercial refrigerators, freezers, ovens, dishwashers, and walk-in coolers for Old Town Pasadena restaurants, cafés, and food businesses. Commercial diagnostic fee is $120, waived with repair. We understand that a down commercial fridge means lost product — we prioritize these calls." }
    },
    {
      "@type": "Question",
      "name": "What areas near Pasadena do you serve?",
      "acceptedAnswer": { "@type": "Answer", "text": "Our Pasadena branch covers the wider San Gabriel Valley area including South Pasadena, Arcadia, San Marino, La Cañada Flintridge, Monrovia, Alhambra, Monterey Park, Glendale, Burbank, and North Hollywood." }
    },
    {
      "@type": "Question",
      "name": "What is your warranty on appliance repairs?",
      "acceptedAnswer": { "@type": "Answer", "text": "Every repair comes with a 90-day warranty on both parts and labor. If the same problem comes back within 90 days, we return and fix it at no additional cost. We use genuine OEM parts — not aftermarket substitutes." }
    }
  ]
};
---

<Layout title={title} description={description} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(schemaLocalBusiness)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} />

  <!-- HERO -->
  <section class="ps-hero">
    <div class="ps-hero__inner container">
      <div class="ps-hero__content">
        <div class="ps-hero__eyebrow">Pasadena, CA · 91101 · 91103 · 91104 · 91105 · 91106 · 91107</div>
        <h1 class="ps-hero__h1">
          Appliance Repair<br>
          <span class="ps-hero__accent">Pasadena, CA</span>
        </h1>
        <p class="ps-hero__sub">
          Our Pasadena technicians are out on calls every day — Old Town, South Pasadena,
          Arcadia, San Marino, La Cañada. Same-day service, OEM parts, 90-day warranty.
          Call before noon and we're usually there today.
        </p>
        <div class="ps-hero__ctas">
          <a href={`tel:${city.phoneRaw}`} class="btn-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.29h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call {city.phone}
          </a>
          <a href="/book/" class="btn-secondary">Book Online</a>
        </div>
        <div class="ps-hero__rating">
          <span class="stars">★★★★★</span>
          <span class="rating-text">4.6 · Google reviews · BBB A+ · Licensed</span>
        </div>
      </div>
      <div class="ps-hero__img-wrap">
        <img
          src="/images/areas/appliance-repair-pasadena-ca.webp"
          alt="Same Day Appliance Repair technician in Pasadena CA"
          width="560"
          height="460"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <section class="trust-bar">
    <div class="container trust-bar__inner">
      <div class="trust-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <span>Same-Day Service</span>
      </div>
      <div class="trust-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        <span>90-Day Warranty</span>
      </div>
      <div class="trust-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
        <span>OEM Parts</span>
      </div>
      <div class="trust-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        <span>Licensed & Insured</span>
      </div>
      <div class="trust-item">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        <span>85% First-Visit Fix Rate</span>
      </div>
    </div>
  </section>

  <!-- INTRO — живой голос от имени компании -->
  <section class="ps-intro">
    <div class="container ps-intro__inner">
      <div class="ps-intro__text">
        <h2>Appliance Repair in Pasadena — From Our Technicians</h2>
        <p>
          Our technicians drive through Pasadena every single day — down Orange Grove past the
          Tournament of Roses houses, through Old Town where the restaurants need their walk-ins
          running, up into the hills near Caltech where you find everything from 1920s Craftsman kitchens
          to fully renovated modern appliances. We know this city.
        </p>
        <p>
          When you call Same Day Appliance Repair, you're not calling a dispatch center that'll
          send whoever is closest. You're calling our Pasadena team — the same technicians who've
          been fixing refrigerators on Garfield Ave, washers in South Pasadena, and commercial
          ovens on Colorado Blvd for years. We pick up the phone, we give you a straight answer,
          and if we can make it the same day — we will.
        </p>
        <p>
          Our diagnostic fee is <strong>$89</strong> — and that goes away the moment you say yes
          to the repair. We bring the written estimate to you before we touch anything. No surprises.
          Every job leaves with a <strong>90-day warranty</strong> on parts and labor.
        </p>
        <div class="ps-tip">
          <div class="ps-tip__icon">💡</div>
          <div class="ps-tip__text">
            <strong>Quick tip from our techs:</strong> If your refrigerator is running constantly
            and the back feels warm, pull it out and vacuum the condenser coils at the bottom.
            In Pasadena's dry heat, dust buildup is the #1 cause of early compressor failure we see.
            Five minutes every six months can save you a $300+ repair.
          </div>
        </div>
        <div class="ps-tip">
          <div class="ps-tip__icon">🔥</div>
          <div class="ps-tip__text">
            <strong>Dryer safety tip:</strong> A blocked dryer vent isn't just an appliance problem —
            it's a fire hazard. If your dryer takes two cycles to dry a normal load, the vent is likely
            restricted. We do dryer vent inspections and cleaning as part of every dryer repair call in Pasadena.
            Don't wait for a thermal fuse to blow to find out there's a problem.
          </div>
        </div>
      </div>
      <div class="ps-intro__cta-box">
        <div class="cta-box">
          <div class="cta-box__title">Talk to Our Pasadena Team</div>
          <div class="cta-box__sub">Same-day service · Available today</div>
          <a href={`tel:${city.phoneRaw}`} class="cta-box__phone">{city.phone}</a>
          <a href="/book/" class="cta-box__book">Schedule Online →</a>
          <div class="cta-box__hours">Mon–Fri 7am–9pm · Sat 8am–7pm · Sun 9am–5pm</div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="ps-services">
    <div class="container">
      <h2 class="section-title">What We Fix in Pasadena</h2>
      <p class="section-sub">All major brands · Residential & commercial · Gas & electric</p>
      <div class="services-grid">

        <a href="/pasadena/refrigerator-repair/" class="service-card">
          <div class="service-card__icon">🧊</div>
          <div class="service-card__name">Refrigerator Repair</div>
          <div class="service-card__issues">Not cooling · Leaking · Ice maker down · Noisy · Freezer fine but fridge warm</div>
          <div class="service-card__brands">Sub-Zero · Samsung · LG · GE · Whirlpool · KitchenAid</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/pasadena/washer-repair/" class="service-card">
          <div class="service-card__icon">🫧</div>
          <div class="service-card__name">Washer Repair</div>
          <div class="service-card__issues">Not spinning · Not draining · Leaking · Shaking · Error codes</div>
          <div class="service-card__brands">LG · Samsung · Whirlpool · Maytag · Bosch · Speed Queen</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/pasadena/dryer-repair/" class="service-card">
          <div class="service-card__icon">♨️</div>
          <div class="service-card__name">Dryer Repair</div>
          <div class="service-card__issues">Not heating · Not spinning · Takes 2 cycles · Dryer vent cleaning · Gas & electric</div>
          <div class="service-card__brands">LG · Samsung · Maytag · GE · Whirlpool · Electrolux</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/pasadena/oven-repair/" class="service-card">
          <div class="service-card__icon">🔥</div>
          <div class="service-card__name">Oven, Stove & Range Repair</div>
          <div class="service-card__issues">Not heating · Uneven baking · Igniter clicking · Gas valve issues · Control board</div>
          <div class="service-card__brands">Viking · Thermador · GE · Whirlpool · Bosch · Wolf</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/pasadena/dishwasher-repair/" class="service-card">
          <div class="service-card__icon">🍽️</div>
          <div class="service-card__name">Dishwasher Repair</div>
          <div class="service-card__issues">Not cleaning · Not draining · Leaking · Won't latch · Noisy</div>
          <div class="service-card__brands">Bosch · Miele · KitchenAid · Samsung · LG</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/pasadena/wine-cooler-repair/" class="service-card">
          <div class="service-card__icon">🍷</div>
          <div class="service-card__name">Wine Cooler Repair</div>
          <div class="service-card__issues">Not cooling · Temperature swings · Compressor issues</div>
          <div class="service-card__brands">Sub-Zero · EuroCave · Liebherr · Thermador · Vinotemp</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/pasadena/cooktop-repair/" class="service-card">
          <div class="service-card__icon">🔆</div>
          <div class="service-card__name">Cooktop Repair</div>
          <div class="service-card__issues">Burner won't light · Induction not heating · Control issues</div>
          <div class="service-card__brands">Thermador · Viking · Bosch · GE · Miele</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/pasadena/freezer-repair/" class="service-card">
          <div class="service-card__icon">❄️</div>
          <div class="service-card__name">Freezer Repair</div>
          <div class="service-card__issues">Not freezing · Ice buildup · Temperature drifting · Noisy</div>
          <div class="service-card__brands">Whirlpool · GE · Samsung · LG · Sub-Zero</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

      </div>
    </div>
  </section>

  <!-- NEIGHBORHOODS -->
  <section class="ps-neighborhoods">
    <div class="container">
      <h2>Our Technicians Cover All of Pasadena & Surrounding Areas</h2>
      <p class="section-sub">We're out in these neighborhoods every day — ZIP codes 91101 through 91107</p>

      <div class="nh-columns">
        <div class="nh-col">
          <div class="nh-col__title">Pasadena Neighborhoods</div>
          <div class="nh-list">
            <div class="nh-item featured">Old Town Pasadena</div>
            <div class="nh-item featured">Caltech / South Lake Ave</div>
            <div class="nh-item featured">Historic Highlands</div>
            <div class="nh-item">Madison Heights</div>
            <div class="nh-item">Bungalow Heaven</div>
            <div class="nh-item">Lamanda Park</div>
            <div class="nh-item">San Rafael Hills</div>
            <div class="nh-item">Linda Vista</div>
            <div class="nh-item">Rose Bowl Area</div>
            <div class="nh-item">Hastings Ranch</div>
          </div>
        </div>
        <div class="nh-col">
          <div class="nh-col__title">Nearby Areas We Serve</div>
          <div class="nh-list">
            <div class="nh-item">South Pasadena</div>
            <div class="nh-item">San Marino</div>
            <div class="nh-item">Arcadia</div>
            <div class="nh-item">La Cañada Flintridge</div>
            <div class="nh-item">Monrovia</div>
            <div class="nh-item">Alhambra</div>
            <div class="nh-item">Monterey Park</div>
            <div class="nh-item">Altadena</div>
          </div>
        </div>
        <div class="nh-col">
          <div class="nh-col__title">Key Pasadena Streets</div>
          <div class="nh-list streets">
            <div class="nh-item">Colorado Blvd</div>
            <div class="nh-item">Orange Grove Blvd</div>
            <div class="nh-item">Lake Ave</div>
            <div class="nh-item">Walnut St</div>
            <div class="nh-item">Foothill Blvd</div>
            <div class="nh-item">Sierra Madre Blvd</div>
            <div class="nh-item">Garfield Ave</div>
            <div class="nh-item">Rosemead Blvd</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- COMMERCIAL SECTION — Pasadena ресторанный рынок -->
  <section class="ps-commercial">
    <div class="container">
      <div class="commercial-inner">
        <div class="commercial-text">
          <div class="commercial-eyebrow">For Old Town Restaurants & Businesses</div>
          <h2>Commercial Appliance Repair in Pasadena</h2>
          <p>
            Old Town Pasadena has one of the densest restaurant districts in the San Gabriel Valley.
            Our technicians know what it means when a walk-in cooler goes down during dinner prep
            or a commercial dishwasher quits mid-service. That's not a "schedule for next week"
            situation — that's a phone call we pick up and respond to today.
          </p>
          <p>
            We repair commercial refrigerators, walk-in coolers and freezers, commercial ovens,
            dishwashers, and laundry units for Pasadena restaurants, cafés, hotels, and multi-unit
            properties. Same approach as our residential work: we diagnose it honestly, quote it
            upfront, and fix it right the first time.
          </p>
          <ul class="commercial-list">
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              Walk-in cooler & freezer repair — same day for emergencies
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              Commercial refrigerator & ice machine repair
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              Restaurant oven, range & dishwasher service
            </li>
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              Commercial diagnostic fee: $120 — waived with repair
            </li>
          </ul>
        </div>
        <div class="commercial-cta">
          <div class="commercial-cta__title">Restaurant & Business Owners</div>
          <div class="commercial-cta__sub">Call us directly — we understand urgency</div>
          <a href={`tel:${city.phoneRaw}`} class="btn-primary">{city.phone}</a>
          <div class="commercial-cta__note">Available 7am–9pm Mon–Fri · Sat 8am–7pm</div>
        </div>
      </div>
    </div>
  </section>

  <!-- RECENT REPAIRS — живые кейсы -->
  <section class="ps-recent">
    <div class="container">
      <h2>Recent Repairs Our Team Did in Pasadena</h2>
      <p class="section-sub">These are real jobs — not made up. Our technicians did these.</p>
      <div class="recent-grid">

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">Sub-Zero Refrigerator</span>
            <span class="recent-location">Historic Highlands, 91105</span>
          </div>
          <div class="recent-card__title">"Freezer working fine, but the fridge section is warm"</div>
          <div class="recent-card__desc">
            Classic evaporator fan failure in a Sub-Zero 650 — the fridge side stops cooling but
            freezer still runs. Our tech replaced the evaporator fan motor with an OEM Sub-Zero part,
            defrosted the coils, and tested the temperatures before leaving. Customer had dinner
            guests coming — we made it by 4pm.
          </div>
          <div class="recent-card__result">✓ Same day · OEM Sub-Zero part · 90-day warranty</div>
        </div>

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">Commercial Walk-In</span>
            <span class="recent-location">Old Town Pasadena restaurant, 91103</span>
          </div>
          <div class="recent-card__title">"Walk-in cooler temperature rising during Friday lunch"</div>
          <div class="recent-card__desc">
            Owner called at 11:30am during service. We were there by 1pm. Found a failed condenser
            fan motor — the coils were icing over and blocking airflow. Replaced the fan, cleared
            the ice, ran the unit back down to temp. Restaurant stayed open. About $800 in product
            was saved.
          </div>
          <div class="recent-card__result">✓ Emergency same-day · Restaurant stayed open</div>
        </div>

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">LG Washer</span>
            <span class="recent-location">Bungalow Heaven, 91103</span>
          </div>
          <div class="recent-card__title">"OE error code, won't drain, clothes soaking wet"</div>
          <div class="recent-card__desc">
            OE on LG usually means a drain pump issue or a blocked filter. In this case — both.
            The pump was partially clogged and the impeller was cracked. Our tech cleaned the filter,
            replaced the drain pump assembly, and ran three cycles to confirm clean drainage.
            Customer had a mountain of wet laundry — we got her sorted by noon.
          </div>
          <div class="recent-card__result">✓ Completed same morning · OEM LG drain pump</div>
        </div>

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">Thermador Range</span>
            <span class="recent-location">San Rafael Hills, 91107</span>
          </div>
          <div class="recent-card__title">"Star burner igniter sparking constantly, won't stop"</div>
          <div class="recent-card__desc">
            Thermador Star burners are fantastic but they have a specific igniter design that wears
            differently than regular burners. The igniter switch was failing — it would trip and
            keep sparking even with the burner off. Replaced the igniter module. While there, we
            checked all five burners and the oven calibration. Everything good.
          </div>
          <div class="recent-card__result">✓ Same day · OEM Thermador igniter · Full check done</div>
        </div>

      </div>
    </div>
  </section>

  <!-- WHY US -->
  <section class="ps-why">
    <div class="container">
      <h2>How We Work — Straight from the Team</h2>
      <div class="why-grid">
        <div class="why-card">
          <div class="why-icon">📞</div>
          <div class="why-title">We Pick Up the Phone</div>
          <div class="why-text">When you call (626) 376-4458, you're talking to our Pasadena team — not a national call center. We'll tell you honestly whether we can make it same day, and if we can't, we'll give you the next available slot that actually works.</div>
        </div>
        <div class="why-card">
          <div class="why-icon">🔧</div>
          <div class="why-title">We Diagnose It Right</div>
          <div class="why-text">Our technicians have seen every common failure pattern on every major brand. We don't replace parts hoping something works — we diagnose the actual problem first, explain it to you in plain language, and give you a real estimate.</div>
        </div>
        <div class="why-card">
          <div class="why-icon">📦</div>
          <div class="why-title">Parts Are in the Van</div>
          <div class="why-text">We stock OEM parts for the most common failures on Samsung, LG, Whirlpool, GE, Bosch, Sub-Zero, Thermador and others. Most repairs are completed in one visit — no "we'll come back when the part arrives."</div>
        </div>
        <div class="why-card">
          <div class="why-icon">✅</div>
          <div class="why-title">We Stand Behind the Work</div>
          <div class="why-text">Every repair we do comes with a 90-day warranty. If something goes wrong with the same part or the same issue within 90 days, we come back and fix it — no charge. That's not a marketing line, that's how we've kept customers in Pasadena coming back to us.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="ps-reviews">
    <div class="container">
      <h2>What Pasadena Customers Are Saying</h2>
      <div class="reviews-grid">
        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <div class="review-text">"Our Sub-Zero stopped cooling on a Thursday. I called Same Day Appliance Repair not really expecting same-day service for a Sub-Zero. They showed up by 2pm, had the part on the truck, and it was fixed before dinner. Genuinely impressed."</div>
          <div class="review-author">— Catherine W., Historic Highlands, Pasadena</div>
        </div>
        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <div class="review-text">"Our restaurant walk-in started warming up on a Friday morning. These guys picked up immediately, came within two hours, and had us back to temperature before the dinner rush. I keep their number saved and will call them every time."</div>
          <div class="review-author">— Marco T., Restaurant owner, Old Town Pasadena</div>
        </div>
        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <div class="review-text">"The technician was straightforward, told me exactly what was wrong with my Thermador, gave me the price before starting, and fixed it cleanly. No upselling, no drama. That's rare. I've already recommended them to my neighbors on Orange Grove."</div>
          <div class="review-author">— Robert H., San Rafael Hills, Pasadena</div>
        </div>
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section class="ps-pricing">
    <div class="container">
      <h2>Appliance Repair Costs in Pasadena — What to Expect</h2>
      <p class="section-sub">Honest estimates. Written before we start. Diagnostic fee waived with repair.</p>
      <div class="pricing-grid">
        <div class="pricing-card">
          <div class="pricing-card__appliance">Refrigerator</div>
          <div class="pricing-card__range">$200 – $450</div>
          <div class="pricing-card__note">Fan motor, thermostat, compressor relay, ice maker</div>
        </div>
        <div class="pricing-card">
          <div class="pricing-card__appliance">Washer</div>
          <div class="pricing-card__range">$150 – $350</div>
          <div class="pricing-card__note">Drain pump, door latch, bearing, control board</div>
        </div>
        <div class="pricing-card">
          <div class="pricing-card__appliance">Dryer</div>
          <div class="pricing-card__range">$150 – $320</div>
          <div class="pricing-card__note">Heating element, thermal fuse, drum roller, belt</div>
        </div>
        <div class="pricing-card">
          <div class="pricing-card__appliance">Oven / Range</div>
          <div class="pricing-card__range">$175 – $420</div>
          <div class="pricing-card__note">Igniter, bake element, gas valve, control board</div>
        </div>
        <div class="pricing-card">
          <div class="pricing-card__appliance">Dishwasher</div>
          <div class="pricing-card__range">$150 – $320</div>
          <div class="pricing-card__note">Drain pump, wash motor, door latch, spray arm</div>
        </div>
        <div class="pricing-card featured">
          <div class="pricing-card__appliance">Diagnostic Fee</div>
          <div class="pricing-card__range">$89</div>
          <div class="pricing-card__note">Waived when you proceed with the repair</div>
        </div>
      </div>
      <p class="pricing-note">Premium brands (Sub-Zero, Viking, Thermador, Miele) may cost more due to OEM part pricing. We'll tell you upfront. Commercial appliance diagnostic: $120, waived with repair.</p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="ps-faq">
    <div class="container">
      <h2>Questions Our Pasadena Customers Ask</h2>
      <div class="faq-list">

        <details class="faq-item">
          <summary class="faq-question">Do you offer same-day appliance repair in Pasadena, CA?</summary>
          <div class="faq-answer">Yes. Our Pasadena technicians offer same-day service throughout the city — Old Town, South Pasadena, Arcadia, San Marino, La Cañada Flintridge, and across the San Gabriel Valley. Call us before noon and we'll do our best to be there the same afternoon. We serve ZIP codes 91101, 91103, 91104, 91105, 91106, and 91107.</div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">What appliances do your technicians repair in Pasadena?</summary>
          <div class="faq-answer">Our team repairs all major home and commercial appliances: refrigerators, washers, dryers, ovens, stoves, dishwashers, cooktops, freezers, wine coolers, microwaves, and range hoods. We work on all brands — from everyday Whirlpool and Samsung to high-end Sub-Zero, Viking, Thermador, and Miele.</div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">How much does appliance repair cost in Pasadena?</summary>
          <div class="faq-answer">Most home appliance repairs in Pasadena run between $150 and $400 depending on the appliance and the issue. Our diagnostic fee is $89 and is waived when you go ahead with the repair. We give you a full written estimate before we start any work — no surprises on the invoice.</div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">Do you repair Sub-Zero and Viking appliances in Pasadena?</summary>
          <div class="faq-answer">Yes. Pasadena has a lot of high-end appliances — Sub-Zero refrigerators, Viking ranges, Thermador cooktops — especially in the older estates and renovated Craftsman homes. Our technicians are trained on these brands and carry OEM parts for them on every service vehicle.</div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">Do you also do commercial appliance repair in Pasadena?</summary>
          <div class="faq-answer">Yes. We repair commercial refrigerators, freezers, ovens, dishwashers, and walk-in coolers for Old Town Pasadena restaurants, cafés, and food businesses. Commercial diagnostic fee is $120, waived with repair. We understand that a down commercial fridge means lost product — we prioritize these calls.</div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">What areas near Pasadena do you serve?</summary>
          <div class="faq-answer">Our Pasadena branch covers the wider San Gabriel Valley area including South Pasadena, Arcadia, San Marino, La Cañada Flintridge, Monrovia, Alhambra, Monterey Park, Glendale, Burbank, and North Hollywood.</div>
        </details>

        <details class="faq-item">
          <summary class="faq-question">What is your warranty on appliance repairs?</summary>
          <div class="faq-answer">Every repair comes with a 90-day warranty on both parts and labor. If the same problem comes back within 90 days, we return and fix it at no additional cost. We use genuine OEM parts — not aftermarket substitutes.</div>
        </details>

      </div>
    </div>
  </section>

  <!-- NEARBY -->
  <section class="ps-nearby">
    <div class="container">
      <h2>Also Serving Nearby Areas</h2>
      <div class="nearby-grid">
        <a href="/south-pasadena/" class="nearby-link">South Pasadena</a>
        <a href="/arcadia/" class="nearby-link">Arcadia</a>
        <a href="/san-marino/" class="nearby-link">San Marino</a>
        <a href="/la-canada-flintridge/" class="nearby-link">La Cañada Flintridge</a>
        <a href="/glendale/" class="nearby-link">Glendale</a>
        <a href="/burbank/" class="nearby-link">Burbank</a>
        <a href="/alhambra/" class="nearby-link">Alhambra</a>
        <a href="/monterey-park/" class="nearby-link">Monterey Park</a>
      </div>
    </div>
  </section>

  <!-- BOTTOM CTA -->
  <section class="ps-bottom-cta">
    <div class="container">
      <div class="bottom-cta__inner">
        <div class="bottom-cta__text">
          <h2>Appliance broken in Pasadena? Call us now.</h2>
          <p>Our team is out on calls in Pasadena today. Diagnostic fee $89, waived with repair. 90-day warranty. We pick up the phone.</p>
        </div>
        <div class="bottom-cta__actions">
          <a href={`tel:${city.phoneRaw}`} class="btn-primary btn-large">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.29h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            {city.phone}
          </a>
          <a href="/book/" class="btn-secondary btn-large">Book Online</a>
        </div>
        <div class="bottom-cta__nap">
          <span>Same Day Appliance Repair — Pasadena Branch</span>
          <span>·</span>
          <span>55 S Lake Ave, Pasadena, CA 91101</span>
          <span>·</span>
          <a href={`mailto:${city.email}`}>{city.email}</a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  :root {
    --ps-red: #C8102E;
    --ps-black: #0a0a0a;
    --ps-gray: #f5f5f5;
    --ps-border: #e2e2e2;
    --ps-text: #1a1a1a;
    --ps-muted: #6b6b6b;
  }

  .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }

  /* HERO */
  .ps-hero { background: var(--ps-black); color: white; padding: 80px 0 60px; }
  .ps-hero__inner { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
  .ps-hero__eyebrow { font-size: 13px; font-weight: 500; color: var(--ps-red); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 16px; }
  .ps-hero__h1 { font-size: clamp(36px, 5vw, 52px); font-weight: 700; line-height: 1.1; margin-bottom: 20px; color: white; }
  .ps-hero__accent { color: var(--ps-red); }
  .ps-hero__sub { font-size: 17px; line-height: 1.6; color: rgba(255,255,255,0.75); margin-bottom: 32px; max-width: 520px; }
  .ps-hero__ctas { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 24px; }
  .ps-hero__rating { display: flex; align-items: center; gap: 10px; }
  .stars { color: #FFD700; font-size: 18px; letter-spacing: 2px; }
  .rating-text { font-size: 14px; color: rgba(255,255,255,0.7); }
  .ps-hero__img-wrap img { width: 100%; height: auto; border-radius: 12px; object-fit: cover; }

  /* BUTTONS */
  .btn-primary { display: inline-flex; align-items: center; gap: 8px; background: var(--ps-red); color: white; padding: 14px 28px; border-radius: 8px; font-weight: 600; font-size: 16px; text-decoration: none; transition: background 0.2s; }
  .btn-primary:hover { background: #a50e25; }
  .btn-secondary { display: inline-flex; align-items: center; gap: 8px; background: transparent; color: white; padding: 14px 28px; border-radius: 8px; font-weight: 600; font-size: 16px; text-decoration: none; border: 1.5px solid rgba(255,255,255,0.35); transition: border-color 0.2s; }
  .btn-secondary:hover { border-color: white; }
  .btn-large { padding: 16px 36px; font-size: 17px; }
  .ps-bottom-cta .btn-secondary { color: var(--ps-text); border-color: var(--ps-border); }
  .ps-bottom-cta .btn-secondary:hover { background: var(--ps-gray); }

  /* TRUST BAR */
  .trust-bar { background: var(--ps-red); padding: 16px 0; }
  .trust-bar__inner { display: flex; justify-content: space-between; flex-wrap: wrap; gap: 12px; }
  .trust-item { display: flex; align-items: center; gap: 8px; color: white; font-size: 14px; font-weight: 500; }

  /* INTRO */
  .ps-intro { padding: 72px 0; background: white; }
  .ps-intro__inner { display: grid; grid-template-columns: 1fr 340px; gap: 60px; align-items: start; }
  .ps-intro__text h2 { font-size: 28px; font-weight: 700; color: var(--ps-black); margin-bottom: 20px; }
  .ps-intro__text p { font-size: 16px; line-height: 1.7; color: var(--ps-text); margin-bottom: 16px; }
  .ps-tip { display: flex; gap: 14px; background: #fff8e7; border: 1px solid #f0d070; border-radius: 10px; padding: 16px 20px; margin-top: 24px; }
  .ps-tip__icon { font-size: 20px; flex-shrink: 0; }
  .ps-tip__text { font-size: 14px; color: var(--ps-text); line-height: 1.6; }
  .cta-box { background: var(--ps-black); color: white; border-radius: 12px; padding: 32px; text-align: center; position: sticky; top: 80px; }
  .cta-box__title { font-size: 18px; font-weight: 700; margin-bottom: 4px; }
  .cta-box__sub { font-size: 13px; color: rgba(255,255,255,0.6); margin-bottom: 24px; }
  .cta-box__phone { display: block; font-size: 24px; font-weight: 700; color: var(--ps-red); text-decoration: none; margin-bottom: 12px; }
  .cta-box__book { display: block; font-size: 15px; color: white; text-decoration: none; padding: 12px; border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; margin-bottom: 16px; }
  .cta-box__book:hover { background: rgba(255,255,255,0.08); }
  .cta-box__hours { font-size: 12px; color: rgba(255,255,255,0.5); }

  /* SECTION */
  .section-title { font-size: 30px; font-weight: 700; color: var(--ps-black); margin-bottom: 8px; text-align: center; }
  .section-sub { font-size: 16px; color: var(--ps-muted); text-align: center; margin-bottom: 40px; }

  /* SERVICES */
  .ps-services { padding: 72px 0; background: var(--ps-gray); }
  .services-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
  .service-card { background: white; border: 1px solid var(--ps-border); border-radius: 12px; padding: 24px 20px; text-decoration: none; color: var(--ps-text); transition: box-shadow 0.2s, transform 0.2s; display: block; }
  .service-card:hover { box-shadow: 0 4px 24px rgba(0,0,0,0.1); transform: translateY(-2px); }
  .service-card__icon { font-size: 28px; margin-bottom: 10px; }
  .service-card__name { font-size: 16px; font-weight: 600; color: var(--ps-black); margin-bottom: 8px; }
  .service-card__issues { font-size: 13px; color: var(--ps-muted); line-height: 1.5; margin-bottom: 8px; }
  .service-card__brands { font-size: 12px; color: var(--ps-muted); margin-bottom: 12px; }
  .service-card__cta { font-size: 13px; color: var(--ps-red); font-weight: 500; }

  /* NEIGHBORHOODS */
  .ps-neighborhoods { padding: 72px 0; background: white; }
  .ps-neighborhoods h2 { font-size: 30px; font-weight: 700; color: var(--ps-black); margin-bottom: 8px; text-align: center; }
  .nh-columns { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; }
  .nh-col__title { font-size: 13px; font-weight: 600; color: var(--ps-muted); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 16px; }
  .nh-list { display: flex; flex-direction: column; gap: 8px; }
  .nh-item { font-size: 14px; color: var(--ps-text); padding: 8px 12px; background: var(--ps-gray); border-radius: 6px; }
  .nh-item.featured { background: #fff5f7; border: 1px solid var(--ps-red); color: var(--ps-black); font-weight: 500; }

  /* COMMERCIAL */
  .ps-commercial { padding: 72px 0; background: var(--ps-black); color: white; }
  .commercial-inner { display: grid; grid-template-columns: 1fr 300px; gap: 60px; align-items: start; }
  .commercial-eyebrow { font-size: 13px; font-weight: 500; color: var(--ps-red); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 12px; }
  .commercial-text h2 { font-size: 28px; font-weight: 700; color: white; margin-bottom: 20px; }
  .commercial-text p { font-size: 15px; line-height: 1.7; color: rgba(255,255,255,0.75); margin-bottom: 16px; }
  .commercial-list { list-style: none; padding: 0; margin: 0; }
  .commercial-list li { display: flex; align-items: flex-start; gap: 10px; font-size: 15px; color: rgba(255,255,255,0.85); padding: 6px 0; }
  .commercial-list li svg { flex-shrink: 0; color: var(--ps-red); margin-top: 2px; }
  .commercial-cta { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); border-radius: 12px; padding: 32px; text-align: center; position: sticky; top: 80px; }
  .commercial-cta__title { font-size: 17px; font-weight: 700; color: white; margin-bottom: 6px; }
  .commercial-cta__sub { font-size: 13px; color: rgba(255,255,255,0.5); margin-bottom: 24px; }
  .commercial-cta .btn-primary { width: 100%; justify-content: center; margin-bottom: 12px; }
  .commercial-cta__note { font-size: 12px; color: rgba(255,255,255,0.4); }

  /* RECENT */
  .ps-recent { padding: 72px 0; background: var(--ps-gray); }
  .ps-recent h2 { font-size: 30px; font-weight: 700; color: var(--ps-black); margin-bottom: 8px; text-align: center; }
  .recent-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .recent-card { background: white; border: 1px solid var(--ps-border); border-radius: 12px; padding: 24px; }
  .recent-card__header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; flex-wrap: wrap; gap: 6px; }
  .recent-badge { background: var(--ps-red); color: white; font-size: 11px; font-weight: 600; padding: 3px 10px; border-radius: 20px; }
  .recent-location { font-size: 12px; color: var(--ps-muted); }
  .recent-card__title { font-size: 15px; font-weight: 600; color: var(--ps-black); margin-bottom: 10px; font-style: italic; }
  .recent-card__desc { font-size: 14px; color: var(--ps-text); line-height: 1.6; margin-bottom: 12px; }
  .recent-card__result { font-size: 13px; color: #2a7a2a; font-weight: 500; }

  /* WHY */
  .ps-why { padding: 72px 0; background: white; }
  .ps-why h2 { font-size: 30px; font-weight: 700; color: var(--ps-black); margin-bottom: 40px; text-align: center; }
  .why-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
  .why-card { background: var(--ps-gray); border-radius: 12px; padding: 28px 24px; }
  .why-icon { font-size: 28px; margin-bottom: 14px; }
  .why-title { font-size: 16px; font-weight: 600; color: var(--ps-black); margin-bottom: 10px; }
  .why-text { font-size: 14px; color: var(--ps-muted); line-height: 1.6; }

  /* REVIEWS */
  .ps-reviews { padding: 72px 0; background: var(--ps-gray); }
  .ps-reviews h2 { font-size: 30px; font-weight: 700; color: var(--ps-black); margin-bottom: 40px; text-align: center; }
  .reviews-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .review-card { background: white; border: 1px solid var(--ps-border); border-radius: 12px; padding: 28px; }
  .review-stars { color: #FFD700; font-size: 18px; margin-bottom: 12px; }
  .review-text { font-size: 14px; color: var(--ps-text); line-height: 1.7; margin-bottom: 16px; font-style: italic; }
  .review-author { font-size: 13px; color: var(--ps-muted); font-weight: 500; }

  /* PRICING */
  .ps-pricing { padding: 72px 0; background: white; }
  .ps-pricing h2 { font-size: 30px; font-weight: 700; color: var(--ps-black); margin-bottom: 8px; text-align: center; }
  .pricing-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 20px; }
  .pricing-card { background: var(--ps-gray); border-radius: 10px; padding: 20px 24px; border: 1px solid var(--ps-border); }
  .pricing-card.featured { background: #fff5f7; border-color: var(--ps-red); }
  .pricing-card__appliance { font-size: 14px; color: var(--ps-muted); margin-bottom: 6px; }
  .pricing-card__range { font-size: 24px; font-weight: 700; color: var(--ps-black); margin-bottom: 6px; }
  .pricing-card.featured .pricing-card__range { color: var(--ps-red); }
  .pricing-card__note { font-size: 13px; color: var(--ps-muted); }
  .pricing-note { font-size: 14px; color: var(--ps-muted); text-align: center; max-width: 640px; margin: 0 auto; }

  /* FAQ */
  .ps-faq { padding: 72px 0; background: var(--ps-gray); }
  .ps-faq h2 { font-size: 30px; font-weight: 700; color: var(--ps-black); margin-bottom: 40px; text-align: center; }
  .faq-list { max-width: 800px; margin: 0 auto; }
  .faq-item { border: 1px solid var(--ps-border); border-radius: 8px; background: white; margin-bottom: 10px; overflow: hidden; }
  .faq-question { padding: 18px 24px; font-size: 16px; font-weight: 600; color: var(--ps-black); cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; }
  .faq-question::after { content: '+'; font-size: 22px; color: var(--ps-red); flex-shrink: 0; margin-left: 16px; }
  details[open] .faq-question::after { content: '−'; }
  .faq-answer { padding: 0 24px 20px; font-size: 15px; line-height: 1.7; color: var(--ps-text); }

  /* NEARBY */
  .ps-nearby { padding: 48px 0; background: white; border-top: 1px solid var(--ps-border); }
  .ps-nearby h2 { font-size: 20px; font-weight: 600; color: var(--ps-black); margin-bottom: 20px; text-align: center; }
  .nearby-grid { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; }
  .nearby-link { padding: 8px 20px; border: 1px solid var(--ps-border); border-radius: 20px; font-size: 14px; color: var(--ps-text); text-decoration: none; transition: border-color 0.2s, color 0.2s; }
  .nearby-link:hover { border-color: var(--ps-red); color: var(--ps-red); }

  /* BOTTOM CTA */
  .ps-bottom-cta { padding: 72px 0; background: var(--ps-black); color: white; }
  .bottom-cta__inner { text-align: center; }
  .bottom-cta__text h2 { font-size: 34px; font-weight: 700; color: white; margin-bottom: 12px; }
  .bottom-cta__text p { font-size: 16px; color: rgba(255,255,255,0.7); margin-bottom: 32px; }
  .bottom-cta__actions { display: flex; gap: 12px; justify-content: center; margin-bottom: 24px; flex-wrap: wrap; }
