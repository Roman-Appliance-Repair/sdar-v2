---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import CustomNarrative from '../components/cities/v2/CustomNarrative.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

const citySlug = 'villa-park';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = "Villa Park";
const zips = ["92861"];

const phone = branch.phone;
const phoneRaw = `+1${phone.replace(/\D/g, '')}`;

const title = `Appliance Repair Villa Park CA | Same Day Service | ${phone}`;
const description = "Same-day appliance repair in Villa Park, CA. Sub-Zero, Wolf, Thermador, Miele & all luxury brands. Estate home specialists. OEM parts, 90-day warranty. $89 diagnostic.";
const canonical = "https://samedayappliance.repair/villa-park/";

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  name: branch.fullName,
  image: "https://samedayappliance.repair/images/logo.webp",
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { "@type": "City", name: "Villa Park", sameAs: "https://en.wikipedia.org/wiki/Villa_Park,_California" },
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: "$$$",
  license: "CA CSLB #1138898"

};

const introParagraphs = [
  "Villa Park is the smallest city in Orange County and one of the wealthiest communities in California — six thousand residents, no apartments, no strip malls, exclusively large estate homes. The appliances in these homes are Sub-Zero, Wolf, Thermador, Miele, and Dacor as a matter of course. This isn't a city where we encounter luxury brands occasionally. It's what every kitchen here has.",
  "That changes how we approach every service call. We don't need to ask what brand you have and then figure out if we carry parts for it. We stock OEM parts for Sub-Zero, Wolf, Thermador, Miele, and the other brands common in Villa Park on every truck. Most calls finish same visit.",
  "The maintenance requirements are also specific. Sub-Zero water filters need a 6-month replacement cycle. Thermador steam ovens need periodic descaling based on usage and water hardness. Wolf dual-fuel ranges develop element wear over time that presents as slow preheating before any error code appears. We find these things proactively and tell you before they become failures.",
  `Diagnostic fee is $89, credited toward the repair. Call <a href="tel:${phoneRaw}">${phone}</a>.`,
];

const services = [
  { icon: '❄️', name: 'Sub-Zero Repair', slug: 'refrigerator' },
  { icon: '🔥', name: 'Wolf Range Repair', slug: 'oven' },
  { icon: '♨️', name: 'Thermador Repair', slug: 'cooktop' },
  { icon: '🍽️', name: 'Miele Dishwasher Repair', slug: 'dishwasher' },
  { icon: '🫧', name: 'Washer & Dryer Repair', slug: 'washer' },
  { icon: '🍷', name: 'Wine Cooler Repair', slug: 'wine-cooler' },
  { icon: '🧊', name: 'Ice Maker Repair', slug: 'ice-maker' },
  { icon: '🧊', name: 'Freezer Repair', slug: 'freezer' },
];

const villaParkContextNarrative = {
  headline: "What Every Villa Park Homeowner Should Know About Their Appliances",
  paragraphs: [],
  subSections: [
    {
      title: "Sub-Zero: filters and coils on a real schedule",
      paragraphs: [
        "Sub-Zero recommends a 6-month water filter replacement on any model with a water dispenser or ice maker. In practice, we find filters in service for 18-24 months in most homes we visit — the reminder gets ignored or forgotten. At that age, flow restriction affects ice maker output quality first (hollow cubes, reduced production), and eventually stresses the inlet valve. We replace the filter on every Sub-Zero call where it's overdue, and we set a reminder with the homeowner before we leave.",
      ]
    },
    {
      title: "Wolf: slow preheat before the error code",
      paragraphs: [
        "Wolf dual-fuel ranges with aging elements show a characteristic gradual performance decline — preheat times stretch from 12-15 minutes to 25-35 minutes before any fault code appears. By the time the code shows, the element has been running inefficiently for months. We check element resistance on every Wolf oven call and flag degraded elements even when they haven't failed yet.",
      ]
    },
    {
      title: "Thermador steam ovens: descaling is non-optional",
      paragraphs: [
        "Thermador steam ovens require periodic descaling based on usage cycles. With North OC water hardness, that's typically every 50-60 uses. Skipping the cycle leads to calcium buildup on the steam generator's internal element, which causes E118-series faults. The fix at that point is a professional descaling service — but preventing it is a quarterly 20-minute built-in program that we walk every Thermador steam oven owner through.",
      ]
    },
  ]
};

const neighborhoods = [
  { name: 'Villa Park proper', zip: '92861', featured: true },
  { name: 'Santiago Hills border area', zip: '92861' },
  { name: 'Hewes Street corridor', zip: '92861' },
  { name: 'Serrano Avenue area', zip: '92861' },
  { name: 'Vista Del Rio area', zip: '92861' },
  { name: 'Orange Park Acres border', zip: '92861' },
];

const recentJobs = [
  {
    appliance: 'Sub-Zero 700 Series',
    location: 'Villa Park',
    quote: '"Sub-Zero 700 series — ice maker producing hollow cubes, dispenser slow"',
    description: "Sub-Zero 700 series built-in — ice maker running but producing hollow, partially-formed cubes; water dispenser flow reduced. Two-part issue: water filter 20 months past the 6-month replacement cycle, and the water inlet valve diaphragm was showing early failure signs from the restricted flow. Replaced the filter, replaced the inlet valve with an OEM Sub-Zero part, ran three ice maker cycles to verify output. The filter replacement alone would have bought time, but the valve was already strained — we addressed both. This is the correct call at that filter age.",
    outcome: '✓ Same day · Sub-Zero OEM water filter + inlet valve · 1.5 hours'
  },
  {
    appliance: 'Wolf Dual-Fuel Range',
    location: 'Villa Park',
    quote: '"Wolf dual-fuel range — oven taking 35 minutes to preheat to 350°F"',
    description: "Wolf DF486G — oven preheating slowly, 35 minutes to reach 350°F instead of the normal 12-15. Both bake and broil elements tested; broil element was showing reduced resistance, contributing to slower heat recovery. Replaced the broil element with an OEM Wolf part and ran calibration at 325°F, 375°F, and 450°F. Preheat time back to 14 minutes. Customer had been assuming the oven was 'just like that' for months — it wasn't.",
    outcome: '✓ Same day · Wolf OEM broil element · 1.5 hours'
  },
  {
    appliance: 'Thermador Steam Oven',
    location: 'Villa Park',
    quote: '"Thermador steam oven — E118 error, steam function not working"',
    description: "Thermador MES301HP steam oven — E118 steam generator fault. The steam generator descaling cycle had been skipped for over a year; calcium scale from the OC water supply had built up on the heating element inside the generator to the point of failure. Performed a full professional descale cycle, cleared the fault code, tested steam generation at multiple settings. Customer wasn't aware the unit needed periodic descaling — Thermador steam ovens require it every 50-80 cycles depending on water hardness. Left with a maintenance reminder schedule.",
    outcome: '✓ Same day · Descale service + generator inspection · 2 hours'
  },
  {
    appliance: 'Miele Dishwasher',
    location: 'Villa Park',
    quote: '"Miele dishwasher — G 7000 series, F70 water intake fault"',
    description: "Miele G 7566 SCVi — F70 water intake error, cycle refusing to start. Inlet valve solenoid had failed. Replaced with an OEM Miele part. Also cleaned the intake filter screen which had accumulated mineral scale — North OC water hardness contributing. While we were there, the customer asked about the dishwasher's recommended descaling cycle; Miele recommends it every 4-6 weeks with OC water hardness. We walked them through the built-in descaling program before leaving.",
    outcome: '✓ Same day · Miele OEM inlet valve solenoid · 1.5 hours'
  },
];

const whyReasons = [
  {
    iconKey: 'parts' as const,
    title: 'Luxury brands are our standard',
    body: "Sub-Zero, Wolf, Thermador, Miele — we carry OEM parts for all of these on every OC truck. We're not calling a parts warehouse after the diagnosis. Most Villa Park calls finish same visit."
  },
  {
    iconKey: 'team' as const,
    title: 'Proactive, not reactive',
    body: 'We flag what we see before it fails — degraded Wolf elements, overdue Sub-Zero filters, Thermador steam generator scale buildup. We tell you what we find and let you decide.'
  },
  {
    iconKey: 'clock' as const,
    title: 'Correct diagnosis every time',
    body: 'A Sub-Zero ice maker making hollow cubes is a filter and valve issue, not a sealed system problem. A Wolf with slow preheat has an aging element, not a control board fault. We diagnose correctly.'
  },
  {
    iconKey: 'shield' as const,
    title: '90-day warranty',
    body: 'Every repair carries a 90-day warranty on parts and labor. Same issue returns — we come back at no charge.'
  },
];

const testimonials = [
  {
    stars: 5,
    text: '"Sub-Zero ice maker degrading for months. Same Day replaced the filter and valve, explained the 6-month filter cycle I\'d been ignoring. Also caught an issue with the coils while there. Thorough, professional, done right."',
    author: '— Catherine W., Villa Park'
  },
  {
    stars: 5,
    text: '"Thermador steam oven E118 fault — they descaled it professionally and walked me through the quarterly maintenance program I should have been doing. Oven back in full service same day."',
    author: '— David R., Villa Park'
  },
  {
    stars: 5,
    text: '"Wolf range preheating slowly for months, finally called. Broil element replaced, back to 14-minute preheat. Technician knew immediately what the issue was. This is what it looks like when a company actually knows the appliance."',
    author: '— Susan T., Villa Park'
  },
];

const pricingTiers = [
  { appliance: 'Diagnostic Fee', range: '$89', note: 'Credited toward repair · Written estimate · Proactive maintenance assessment' },
  { appliance: 'Luxury Brand Repair', range: '$250–$600+', note: 'Sub-Zero, Wolf, Thermador, Miele, Dacor · OEM parts' },
  { appliance: 'Maintenance Service', range: '$89–$200', note: 'Coil cleaning, filter replacement, descaling · Preventive care' },
  { appliance: 'Warranty', range: '90 Days', note: 'All repairs · Parts & labor · No-charge callback', featured: true },
];

const faqs = [
  {
    question: "Do you offer same-day appliance repair in Villa Park?",
    answer: "Yes — Villa Park is part of our regular Orange County route. We cover all of Villa Park's 92861 zip code. Call before noon for same-day service."
  },
  {
    question: "Do you specialize in Sub-Zero, Wolf, and Thermador repair in Villa Park?",
    answer: "Yes. Villa Park is an exclusively large-lot estate community where Sub-Zero, Wolf, Thermador, Miele, and Dacor are the standard installations rather than the exception. Our OC technicians carry OEM parts for all of these brands and service them regularly. We don't treat luxury appliance repair as a specialty — it's the majority of what we do in Villa Park."
  },
  {
    question: "What is your diagnostic fee in Villa Park?",
    answer: "Our diagnostic fee is $89. It covers the service call, full appliance inspection, and a written estimate. If you proceed with the repair, the $89 is credited toward your invoice."
  },
  {
    question: "How often should Sub-Zero refrigerators be serviced in Villa Park?",
    answer: "Sub-Zero recommends a 6-month water filter replacement cycle and an annual condenser coil inspection. In Villa Park — which has hot dry summers and is inland from the coast — the coil fouling is primarily from household dust rather than salt air. We recommend cleaning when we find meaningful buildup, which is typically every 6-12 months depending on the home."
  },
  {
    question: "Do you service Thermador steam ovens in Villa Park?",
    answer: "Yes. Thermador steam ovens require periodic descaling based on usage cycles — typically every 50-80 uses depending on water hardness. OC water hardness makes this maintenance more frequent than the general recommendation. We perform professional descaling service and can leave you with a reminder schedule calibrated to your usage."
  },
  {
    question: "What other luxury brands do you repair in Villa Park?",
    answer: "Sub-Zero, Wolf, Thermador, Miele, Dacor, Viking, La Cornue, Gaggenau, Fisher & Paykel, and Bertazzoni. If you have a brand not listed, call us — our OC technicians have experience with the full range of luxury appliance brands installed in estate homes."
  },
  {
    question: "Do you offer a warranty on repairs in Villa Park?",
    answer: "All repairs include a 90-day warranty on parts and labor. Same issue returns within 90 days — we come back at no charge."
  },
];

const nearbyCities = [
  { name: 'Anaheim', slug: 'anaheim' },
  { name: 'Yorba Linda', slug: 'yorba-linda' },
  { name: 'Tustin', slug: 'tustin' },
  { name: 'Irvine', slug: 'irvine' },
  { name: 'Fullerton', slug: 'fullerton' },
  { name: 'Santa Ana', slug: 'santa-ana' },
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair in"
    headlineCity="Villa Park, CA"
    subheadline="Sub-Zero, Wolf, Thermador, Miele & all luxury brands. Estate home specialists. OEM parts, 90-day warranty. $89 diagnostic — waived with repair."
    zips={zips}
    tier={1}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance Repair in Villa Park — Where Sub-Zero Is the Standard"
    paragraphs={introParagraphs}
    bookingTitle="Villa Park Service"
    bookingSub="92861 · Estate Homes · Same Day"
  />

  <ServicesGrid
    cityName={cityName}
    headline="Luxury Appliance Repair Services in Villa Park"
    services={services}
  />

  <CustomNarrative
    headline={villaParkContextNarrative.headline}
    paragraphs={villaParkContextNarrative.paragraphs}
    subSections={villaParkContextNarrative.subSections}
    background="white"
  />

  <ServiceArea
    cityName={cityName}
    headline="Villa Park Areas We Service"
    subheadline="All of 92861 — large-lot estate community."
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={[]}
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Repairs in Villa Park"
    jobs={recentJobs}
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="Why Villa Park Homeowners Call Us"
    reasons={whyReasons}
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What Villa Park Clients Say"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Repair Pricing in Villa Park"
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="Frequently Asked Questions — Villa Park"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby OC Cities"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Schedule Your Villa Park Repair Today"
    body="Sub-Zero, Wolf, Thermador, Miele — same-day service, OEM parts, estate home expertise. $89 diagnostic · 90-day warranty · OEM parts · Villa Park, CA 92861."
  />
</CityLayoutV2>
