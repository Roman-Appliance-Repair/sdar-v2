---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import CustomNarrative from '../components/cities/v2/CustomNarrative.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

const citySlug = 'yorba-linda';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = 'Yorba Linda';
const zips = ['92886', '92887'];

const title = `Appliance Repair Yorba Linda CA | Same Day Service | ${branch.phone}`;
const description = "Same-day appliance repair in Yorba Linda, CA. Sub-Zero, Wolf, KitchenAid & all brands. Hot dry climate expertise. OEM parts, 90-day warranty. $89 diagnostic — waived with repair.";
const canonical = 'https://samedayappliance.repair/yorba-linda/';

const phoneRaw = `+1${branch.phone.replace(/\D/g, '')}`;

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { '@type': 'City', name: 'Yorba Linda', sameAs: 'https://en.wikipedia.org/wiki/Yorba_Linda,_California' },
    { '@type': 'Place', name: 'Bryant Ranch' },
    { '@type': 'Place', name: 'Yorba Linda Hills' },
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$',
  license: 'CA CSLB #1138898'

};

const introParagraphs = [
  "Yorba Linda is one of the more spacious cities in North Orange County — large homes, generous lots, and a climate that's genuinely hot in summer. The appliances here work harder than in coastal OC cities, and the maintenance requirements are different as a result.",
  "Refrigerator compressors cycle more frequently when ambient temperatures are high. In a Yorba Linda home during a 100°F summer week, a refrigerator with fouled condenser coils is running under significant thermal stress. Coil cleaning in Yorba Linda isn't a once-a-year job — we recommend every 6 months, more often in homes with pets. The dust and debris that accumulates in an inland valley home is different from what we see at the coast, but the effect on coil performance is just as real.",
  "The larger homes also mean longer dryer vent runs. A 22-foot vent with two elbows is common in Yorba Linda estates. During Santa Ana conditions in fall, a lint-clogged dryer vent is a fire hazard. We inspect dryer vents on every dryer call here and give you an honest assessment of what we find.",
  `Diagnostic fee is $89, credited toward the repair. Call <a href="tel:${phoneRaw}">${branch.phone}</a>.`,
];

const services = [
  { icon: '❄️', name: 'Refrigerator Repair', slug: 'refrigerator' },
  { icon: '🫧', name: 'Washer Repair', slug: 'washer' },
  { icon: '💨', name: 'Dryer Repair', slug: 'dryer' },
  { icon: '🍽️', name: 'Dishwasher Repair', slug: 'dishwasher' },
  { icon: '🔥', name: 'Oven & Range Repair', slug: 'oven' },
  { icon: '♨️', name: 'Cooktop Repair', slug: 'cooktop' },
  { icon: '🍷', name: 'Wine Cooler Repair', slug: 'wine-cooler' },
  { icon: '🧊', name: 'Ice Maker Repair', slug: 'ice-maker' },
];

const heatNarrative = {
  headline: 'Heat, Dust, and Longer Vent Runs — The Yorba Linda Maintenance Picture',
  paragraphs: [
    "Appliance maintenance recommendations are usually written for average conditions. Yorba Linda isn't average. The combination of inland heat, dry air, and the larger home footprints common here creates a specific set of conditions that affect how often appliances need attention.",
    "<strong>Refrigerators:</strong> The condenser coil on your refrigerator rejects heat into the surrounding air. In a coastal city at 72°F, that's easy work. In a Yorba Linda kitchen at 80°F in August, the refrigerator is working significantly harder — and when the coils are fouled with dust and pet hair, the compressor temperature rises further. Heat is the primary enemy of compressor longevity. We clean coils on every refrigerator call in Yorba Linda and recommend a 6-month inspection cycle for homes with pets or near landscaping that generates airborne debris.",
    "<strong>Dryers:</strong> Yorba Linda homes run larger than the OC average. Larger homes mean longer dryer vent runs — and longer runs mean more lint accumulation and more restriction. The combination of longer runs and Santa Ana wind conditions in fall creates elevated fire risk. We check vents on every dryer repair here. A thermal fuse that keeps blowing is almost always a vent problem, not a dryer problem.",
    "<strong>Sub-Zero and water-connected appliances:</strong> North OC water hardness affects ice maker inlet valves and supply line screens. Sub-Zero units are particularly sensitive to flow restriction because of their precision ice mechanics. A filter left in service for 18+ months in Yorba Linda water will cause ice maker problems that look like component failures — but aren't.",
  ]
};

const neighborhoods = [
  { name: 'East Yorba Linda', zip: '92887' },
  { name: 'West Yorba Linda', zip: '92886' },
  { name: 'Yorba Linda Hills', zip: '92887' },
  { name: 'Travis Ranch area', zip: '92887' },
  { name: 'Fairmont area', zip: '92886' },
  { name: 'Lakeview area', zip: '92886' },
  { name: 'Bryant Ranch', zip: '92887' },
  { name: 'Camino de Bryant', zip: '92887' },
  { name: 'Avenida de las Flores area', zip: '92886' },
  { name: 'Woodgate area', zip: '92886' },
];

const recentJobs = [
  {
    appliance: 'KitchenAid Refrigerator',
    location: 'Bryant Ranch',
    quote: 'KitchenAid refrigerator — running constantly, warm inside',
    description: "KitchenAid KRMF706ESS — compressor cycling constantly, interior temperature rising. Condenser coils packed with dust and pet hair — this Bryant Ranch home had two dogs and the refrigerator was in a kitchen with tile floors that generated significant airborne particulate. Yorba Linda's hot summers mean the compressor works harder to begin with; add fouled coils and the unit was severely stressed. Full coil cleaning, fan motor check (healthy), temperature verified. Homeowner hadn't known coil cleaning was a thing. We recommended every 6 months given the pets and the summer heat.",
    outcome: '✓ Same day · Coil cleaning service · 1.5 hours'
  },
  {
    appliance: 'Whirlpool Dryer',
    location: 'Yorba Linda Hills',
    quote: 'Whirlpool dryer — taking two cycles, no heat on second run',
    description: "Whirlpool WED5000DW — first cycle runs warm, second cycle no heat. Classic thermal fuse failure from restricted airflow. The dryer vent run in this Yorba Linda Hills home was 22 feet with one 90-degree elbow and a downward slope — an inherently restrictive configuration. Lint had accumulated significantly. Cleared the full vent run, replaced the thermal fuse and cycling thermostat, tested airflow at the exterior cap. For long vent runs in larger Yorba Linda homes, we recommend cleaning every 4-6 months. The fire risk during Santa Ana conditions with a clogged vent is real.",
    outcome: '✓ Same day · Whirlpool OEM thermal fuse + cycling thermostat · 2.5 hours'
  },
  {
    appliance: 'Sub-Zero Refrigerator',
    location: 'East Yorba Linda',
    quote: 'Sub-Zero refrigerator — ice maker stopped, water dispenser slow',
    description: "Sub-Zero 650 — ice maker not producing, water dispenser flow reduced to a trickle. Inline water filter was 26 months past replacement (the 6-month cycle). The inlet valve screen was also partially clogged with mineral scale — North OC water hardness affecting the supply line. Replaced the water filter, cleaned the inlet valve screen, tested ice maker production through two full cycles. Customer was surprised a filter could cause this much trouble; Sub-Zero units are more sensitive to filter restriction than typical refrigerators because of their precision ice maker mechanics.",
    outcome: '✓ Same day · Sub-Zero OEM water filter + inlet screen cleaning · 1.5 hours'
  },
  {
    appliance: 'Wolf Range',
    location: 'West Yorba Linda',
    quote: 'Wolf range — two burners igniting slowly, clicking continues after lit',
    description: "Wolf 36-inch gas range — two burners taking 8-10 clicks to light, then continuing to click after the flame was established. Igniter electrodes had accumulated grease residue from cooking — not corrosion as in coastal cities, but carbon buildup from the hot, dry indoor conditions that concentrate cooking residue. Cleaned all six igniter ports and electrode tips, tested every burner. Yorba Linda heat makes kitchen ventilation less effective in summer, which concentrates cooking particulate on nearby burner components.",
    outcome: '✓ Same day · Cleaning service — no parts required · 1 hour'
  },
];

const whyReasons = [
  {
    iconKey: 'shield' as const,
    title: 'We understand inland heat',
    body: "Coastal OC and inland Yorba Linda have different maintenance needs. We calibrate our inspection and recommendation to what Yorba Linda's climate actually demands — not a generic schedule written for average conditions."
  },
  {
    iconKey: 'team' as const,
    title: 'Dryer vent always checked',
    body: "Longer vent runs in Yorba Linda homes mean more lint, more restriction, and more fire risk in Santa Ana conditions. We inspect and clear vents on every dryer repair call. A thermal fuse that keeps blowing is a vent problem — we find and fix it."
  },
  {
    iconKey: 'parts' as const,
    title: 'OEM parts for all tiers',
    body: "Sub-Zero and Wolf in the hills, KitchenAid and Samsung in the tracts — we carry OEM parts for both. Most Yorba Linda calls finish same visit."
  },
  {
    iconKey: 'clock' as const,
    title: '90-day warranty, all repairs',
    body: 'Every repair carries a 90-day warranty on parts and labor. Same issue returns — we come back at no charge.'
  },
];

const testimonials = [
  {
    stars: 5,
    text: '"KitchenAid fridge running constantly in summer. Same Day cleaned the coils — completely caked — and explained why it\'s worse in Yorba Linda heat. Never knew this needed to be done. Problem solved immediately."',
    author: '— Jennifer M., Bryant Ranch'
  },
  {
    stars: 5,
    text: '"Dryer thermal fuse replaced twice by another company, kept blowing. Same Day cleared the full vent run — 20+ feet of lint — and fixed it properly. Told me the Santa Ana wind risk with a clogged vent. That kind of information matters."',
    author: '— David K., Yorba Linda Hills'
  },
  {
    stars: 5,
    text: '"Sub-Zero ice maker stopped. They replaced the water filter — 26 months old — and cleaned the inlet screen. Running again in an hour. No expensive parts, just maintenance I\'d neglected. Honest diagnosis saves money."',
    author: '— Robert T., East Yorba Linda'
  },
];

const pricingTiers = [
  { appliance: 'Diagnostic Fee', range: '$89', note: 'Credited toward repair · Written estimate · Heat/vent assessment included' },
  { appliance: 'Standard Repair', range: '$150–$380', note: 'Parts + labor · OEM parts only · Most appliances' },
  { appliance: 'Luxury Brand', range: '$250–$600+', note: 'Sub-Zero · Wolf · Thermador · Miele · Viking · OEM parts' },
  { appliance: 'Warranty', range: '90 Days', note: 'All repairs · Parts & labor · No-charge callback if same issue returns', featured: true },
];

const faqs = [
  {
    question: 'Do you offer same-day appliance repair in Yorba Linda?',
    answer: "Yes — Yorba Linda is on our regular Orange County route. We cover both 92886 and 92887 zip codes including all neighborhoods from Bryant Ranch to Yorba Linda Hills. Call before noon for same-day service."
  },
  {
    question: 'What is your diagnostic fee in Yorba Linda?',
    answer: "Our diagnostic fee is $89. It covers the service call, full appliance inspection, and written estimate. If you proceed with the repair, the $89 is credited toward your invoice."
  },
  {
    question: "Does Yorba Linda's hot climate affect appliances?",
    answer: "It does. Yorba Linda's summer temperatures regularly exceed 95-100°F, and the Santa Ana wind conditions in fall create additional stress. Refrigerator compressors work harder in hot ambient conditions — and when condenser coils are also fouled with dust, the combined stress accelerates wear significantly. We recommend condenser coil cleaning every 6 months in Yorba Linda, especially in homes with pets or near landscaping that generates airborne debris."
  },
  {
    question: 'Are dryer vents a particular concern in Yorba Linda?',
    answer: "Yes. Yorba Linda homes tend to have larger square footage and longer vent runs than OC coastal cities. Longer vent runs accumulate lint faster and restrict airflow more severely. During Santa Ana conditions, a clogged dryer vent becomes a genuine fire hazard. We inspect dryer vents on every dryer call in Yorba Linda and clear them when needed."
  },
  {
    question: 'What brands do you repair in Yorba Linda?',
    answer: "All major brands: Samsung, LG, GE, Whirlpool, KitchenAid, Maytag, Bosch, Frigidaire, and luxury brands including Sub-Zero, Wolf, Thermador, and Miele. The Bryant Ranch and Yorba Linda Hills neighborhoods have more luxury brand installations; the central neighborhoods have mainstream brands. We carry OEM parts for both."
  },
  {
    question: 'Do you service horse properties and large-lot homes in Yorba Linda?',
    answer: "Yes. Yorba Linda has a number of horse properties and large-lot homes, particularly in the eastern sections. Dryer vent runs in these homes can be especially long. We service all Yorba Linda properties regardless of lot size."
  },
  {
    question: 'Do you offer a warranty on repairs in Yorba Linda?',
    answer: "All repairs include a 90-day warranty on parts and labor. Same issue returns within 90 days — we come back at no charge."
  },
];

const nearbyCities = [
  { name: 'Anaheim', slug: 'anaheim' },
  { name: 'Irvine', slug: 'irvine' },
  { name: 'Fullerton', slug: 'fullerton' },
  { name: 'Tustin', slug: 'tustin' },
  { name: 'Costa Mesa', slug: 'costa-mesa' },
  { name: 'Villa Park', slug: 'villa-park' },
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair in"
    headlineCity="Yorba Linda, CA"
    subheadline="Same-day service across all of Yorba Linda. Hot dry climate and dryer vent expertise. Sub-Zero, Wolf, KitchenAid & all brands. 90-day warranty."
    zips={zips}
    tier={3}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance Repair in Yorba Linda — What the Climate Does to Your Appliances"
    paragraphs={introParagraphs}
    bookingTitle="Yorba Linda Service"
    bookingSub="Available Today"
  />

  <ServicesGrid
    cityName={cityName}
    headline="Appliance Repair Services in Yorba Linda"
    services={services}
  />

  <CustomNarrative
    headline={heatNarrative.headline}
    paragraphs={heatNarrative.paragraphs}
    background="white"
  />

  <ServiceArea
    cityName={cityName}
    headline="Yorba Linda Neighborhoods We Service"
    subheadline="From Bryant Ranch to Yorba Linda Hills — every part of 92886 and 92887."
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={[]}
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Repairs in Yorba Linda"
    jobs={recentJobs}
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="Why Yorba Linda Residents Call Us"
    reasons={whyReasons}
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What Yorba Linda Clients Say"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Repair Pricing in Yorba Linda"
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="Frequently Asked Questions — Yorba Linda"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby Cities"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Schedule Your Yorba Linda Repair Today"
    body="Same-day service across all of Yorba Linda. Heat and dryer vent expertise. $89 diagnostic · 90-day warranty · OEM parts."
  />
</CityLayoutV2>
