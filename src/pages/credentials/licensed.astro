// src/pages/credentials/licensed.astro
// E-E-A-T trust page — BHGS Registration #A49573
// NOT a traffic page — conversion/trust page for users already considering us
// Key fact: BHGS (Bureau of Household Goods and Services) registration
// is the MANDATORY state registration for appliance repair in California —
// different from CSLB contractor license. Old page incorrectly called it CSLB.
// SEO: targets "licensed appliance repair los angeles", "bhgs registered appliance repair"
// Internal linking target from all service pages and brand pages

import Layout from '../../layouts/Layout.astro';

const title = "BHGS Licensed Appliance Repair Los Angeles | Registration #A49573";
const description = "Same-day repair holds California BHGS Registration #A49573 — the mandatory state registration for appliance repair companies. Serving Los Angeles.";
const phone = "(323) 870-4790";
const phoneRaw = "3238704790";
const licenseNumber = "A49573";
const schemaJsons = [
  `{
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Same Day Appliance Repair",
  "telephone": "(323) 870-4790",
  "url": "https://samedayappliance.repair/credentials/licensed-appliance-repair/",
  
  "areaServed": {"@type": "City", "name": "Los Angeles"},
  "hasCredential": {
    "@type": "EducationalOccupationalCredential",
    "credentialCategory": "State Registration",
    "recognizedBy": {
      "@type": "Organization",
      "name": "California Bureau of Household Goods and Services (BHGS)",
      "url": "https://bhgs.dca.ca.gov"
    },
    "identifier": "A49573"
  }
}`,
  `{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is a BHGS registration for appliance repair in California?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "BHGS stands for Bureau of Household Goods and Services, a division of the California Department of Consumer Affairs. In California, any business that repairs household appliances for compensation — refrigerators, washers, dryers, ovens, dishwashers, and more — must be registered with BHGS. This is not optional. Operating without a valid BHGS registration is a violation of California Business and Professions Code. The registration requires background checks, proof of business identity, and annual renewal."
      }
    },
    {
      "@type": "Question",
      "name": "What is Same Day Appliance Repair's BHGS registration number?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Our BHGS registration number is A49573. You can verify this directly on the California Department of Consumer Affairs website at bhgs.dca.ca.gov/enforcement/lookup.shtml. Look up registration number A49573 to confirm active status, registered business name, and registration details."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between a BHGS registration and a CSLB contractor license?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "These are two different state registrations from two different agencies. BHGS registration (our #A49573) is issued by the Department of Consumer Affairs specifically for appliance repair and electronic service businesses. It covers the right to repair household appliances. A CSLB contractor license (C-61/D-21) is issued by the Contractors State License Board and is primarily for construction and contracting work. Appliance repair companies are required to hold BHGS registration — not a CSLB license. Some pages online incorrectly confuse these two."
      }
    },
    {
      "@type": "Question",
      "name": "How can I verify that an appliance repair company is BHGS registered?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Go to bhgs.dca.ca.gov/enforcement/lookup.shtml — the official California DCA license lookup tool. Enter the registration number or business name. For Same Day Appliance Repair, search for registration #A49573. An active registration will show the business name, registration status, and expiration date. We encourage every customer to verify before hiring any appliance repair company."
      }
    },
    {
      "@type": "Question",
      "name": "What happens if I hire an unregistered appliance repair company in California?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Several real consequences: First, you have no formal recourse with the state if work goes wrong — registered companies are subject to BHGS oversight and can face formal complaints. Second, many appliance manufacturers require repairs to be performed by registered service companies to maintain warranty validity. Third, unregistered companies often operate without liability insurance — if a technician damages your appliance or property, you may have no legal protection. Fourth, some insurance policies require service work be done by licensed or registered contractors."
      }
    },
    {
      "@type": "Question",
      "name": "Does BHGS registration apply to commercial appliance repair?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. California BHGS registration covers both residential and commercial appliance repair. Our registration #A49573 covers the full scope of appliance repair work we perform — from residential refrigerators and washers to commercial walk-in coolers, commercial dishwashers, and commercial cooking equipment."
      }
    },
    {
      "@type": "Question",
      "name": "What other credentials does Same Day Appliance Repair hold?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "In addition to BHGS registration #A49573, our technicians hold EPA-608 certification for refrigerant handling (required by federal law for any work involving refrigerants), we carry full liability insurance, all technicians pass background checks, and we are BBB Accredited with an A+ rating. We also carry OSHA safety training certification."
      }
    }
  ]
}`
];
---

<Layout title={title} description={description}>

  <Fragment slot="head-scripts">
    {schemaJsons.map((s) => (
      <script type="application/ld+json" set:html={s}></script>
    ))}
  </Fragment>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .hero { background: var(--black); color: #fff; padding: 80px 24px 64px; text-align: center; }
  .hero-eyebrow { display: inline-block; background: var(--red); color: #fff; font-size: 0.78rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 5px 14px; border-radius: 3px; margin-bottom: 20px; }
  .hero-sub { font-size: 1.1rem; color: #ccc; max-width: 640px; margin: 0 auto 32px; line-height: 1.6; }
  .cta-row { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 16px 34px; border-radius: 5px; font-size: 1rem; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 16px 34px; border-radius: 5px; font-size: 1rem; font-weight: 600; text-decoration: none; border: 2px solid rgba(255,255,255,0.35); }
  .hero-meta { margin-top: 28px; color: #aaa; font-size: 0.9rem; display: flex; gap: 24px; justify-content: center; flex-wrap: wrap; }
  .trust-bar { background: var(--red); padding: 18px 24px; }
  .trust-inner { max-width: 1100px; margin: 0 auto; display: flex; justify-content: center; flex-wrap: wrap; gap: 10px 32px; }
  .trust-item { color: #fff; font-size: 0.88rem; font-weight: 600; }
  .section { padding: 64px 24px; }
  .section-gray { background: var(--gray); }
  .section-black { background: var(--black); color: #fff; }
  .container { max-width: 1100px; margin: 0 auto; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  h2.section-title { font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 800; margin: 0 0 16px; line-height: 1.2; }
  .section-black h2.section-title { color: #fff; }
  .lead { font-size: 1.05rem; line-height: 1.75; color: var(--text); max-width: 760px; }
  .section-black .lead { color: #ccc; }
  .intro-grid { display: grid; grid-template-columns: 1fr 320px; gap: 48px; align-items: start; }
  @media (max-width: 768px) { .intro-grid { grid-template-columns: 1fr; } }
  .intro-body p { margin: 0 0 18px; font-size: 1.05rem; line-height: 1.8; color: var(--text); }
  /* License verification block */
  .verify-block { background: #020a02; border: 2px solid #0a3010; border-radius: 10px; padding: 28px 26px; margin-top: 28px; }
  .verify-block .v-label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: #50c060; margin-bottom: 12px; }
  .verify-block h3 { font-size: 1.05rem; font-weight: 800; color: #fff; margin: 0 0 10px; }
  .license-badge { background: #030d03; border: 1px solid #0d4015; border-radius: 8px; padding: 18px 20px; margin: 16px 0; display: flex; align-items: center; gap: 20px; flex-wrap: wrap; }
  .lb-number { font-size: 2rem; font-weight: 800; color: #50d060; letter-spacing: 0.05em; }
  .lb-detail { font-size: 0.85rem; color: #305030; line-height: 1.6; }
  .lb-detail strong { color: #70b070; }
  .verify-link { display: inline-block; background: #0a3010; color: #70d070; padding: 10px 20px; border-radius: 5px; font-size: 0.88rem; font-weight: 700; text-decoration: none; margin-top: 12px; }
  .verify-link:hover { background: #0d4015; }
  /* Sticky CTA */
  .sticky-cta { position: sticky; top: 24px; background: var(--black); border-radius: 10px; padding: 28px 24px; color: #fff; text-align: center; }
  .sticky-cta .cta-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: #aaa; margin-bottom: 14px; }
  .sticky-cta .cta-phone { font-size: 1.5rem; font-weight: 800; color: #fff; text-decoration: none; display: block; margin-bottom: 12px; }
  .sticky-cta .btn-cta { display: block; background: var(--red); color: #fff; padding: 14px; border-radius: 5px; font-weight: 700; text-decoration: none; font-size: 0.95rem; margin-bottom: 10px; }
  .sticky-cta .cta-sub { font-size: 0.82rem; color: #888; }
  .cta-divider { border: none; border-top: 1px solid #222; margin: 18px 0; }
  .cta-detail li { margin-bottom: 6px; list-style: none; padding-left: 18px; position: relative; font-size: 0.85rem; color: #aaa; }
  .cta-detail li::before { content: "✓"; position: absolute; left: 0; color: var(--red); font-weight: 700; }
  /* BHGS vs CSLB comparison */
  .compare-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 32px; }
  @media (max-width: 600px) { .compare-grid { grid-template-columns: 1fr; } }
  .compare-card { background: #111; border-radius: 8px; padding: 22px 20px; }
  .compare-card.bhgs { border-top: 3px solid #50c060; }
  .compare-card.cslb { border-top: 3px solid #444; }
  .cc-badge { display: inline-block; font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; padding: 3px 10px; border-radius: 3px; margin-bottom: 10px; }
  .badge-bhgs { background: #051505; color: #50c060; }
  .badge-cslb { background: #111; color: #888; }
  .compare-card h3 { font-size: 0.95rem; font-weight: 700; color: #fff; margin: 0 0 10px; }
  .compare-card ul { list-style: none; padding: 0; margin: 0; }
  .compare-card ul li { font-size: 0.83rem; color: #888; padding: 5px 0 5px 14px; position: relative; border-top: 1px solid #1a1a1a; }
  .compare-card ul li::before { content: "→"; position: absolute; left: 0; color: var(--red); font-size: 0.75rem; }
  /* Risks grid */
  .risks-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 18px; margin-top: 36px; }
  .risk-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 22px 18px; }
  .risk-card h3 { font-size: 1rem; font-weight: 700; margin: 0 0 10px; color: var(--text); }
  .risk-card p { font-size: 0.9rem; color: var(--muted); line-height: 1.6; margin: 0; }
  /* Appliance hazards */
  .hazards-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 18px; margin-top: 32px; }
  .hazard-card { background: #111; border: 1px solid #222; border-radius: 8px; padding: 20px 18px; }
  .hazard-card h3 { font-size: 0.9rem; font-weight: 700; color: #fff; margin: 0 0 8px; }
  .hazard-item { margin-bottom: 10px; }
  .hazard-item .h-tag { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #e06030; margin-bottom: 3px; }
  .hazard-item p { font-size: 0.82rem; color: #888; line-height: 1.55; margin: 0; }
  .hazard-item .s-tag { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: #50c060; margin: 6px 0 3px; }
  /* Credentials nav */
  .creds-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 14px; margin-top: 28px; }
  .cred-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 18px 16px; text-decoration: none; display: block; }
  .cred-card:hover { border-color: var(--red); }
  .cred-card .cred-icon { font-size: 1.5rem; margin-bottom: 8px; }
  .cred-card h3 { font-size: 0.9rem; font-weight: 700; color: var(--text); margin: 0 0 4px; }
  .cred-card p { font-size: 0.8rem; color: var(--muted); margin: 0; line-height: 1.4; }
  /* FAQ */
  .faq-list { margin-top: 36px; }
  .faq-item { border-bottom: 1px solid var(--border); padding: 20px 0; }
  .faq-item:first-child { border-top: 1px solid var(--border); }
  .faq-item h3 { font-size: 1rem; font-weight: 700; color: var(--text); margin: 0 0 10px; }
  .faq-item p { font-size: 0.95rem; color: var(--muted); line-height: 1.7; margin: 0; }
  .nearby-links { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 24px; }
  .nearby-links a { background: #fff; border: 1px solid var(--border); border-radius: 4px; padding: 8px 16px; font-size: 0.87rem; color: var(--text); text-decoration: none; font-weight: 500; }
  .nearby-links a:hover { border-color: var(--red); color: var(--red); }
  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; margin: 0 0 16px; }
  .bottom-cta p { color: #aaa; margin: 0 0 32px; font-size: 1.05rem; }
</style>

<!-- HERO -->
<section class="hero">
  <div class="hero-eyebrow">California BHGS Registration #A49573 · Verifiable Online</div>
  <h1>State-Registered Appliance Repair Company in Los Angeles</h1>
  <p class="hero-sub">Same Day Appliance Repair holds California BHGS Registration #{licenseNumber} — the mandatory state registration for every appliance repair business operating in California. Verify it yourself in 30 seconds.</p>
  <div class="cta-row">
    <a href={`tel:${phoneRaw}`} class="btn-primary">Call {phone}</a>
    <a href="https://bhgs.dca.ca.gov/enforcement/lookup.shtml" target="_blank" rel="noopener" class="btn-secondary">Verify Registration →</a>
  </div>
  <div class="hero-meta">
    <span>📋 BHGS #A49573</span>
    <span>🔬 EPA-608 Certified</span>
