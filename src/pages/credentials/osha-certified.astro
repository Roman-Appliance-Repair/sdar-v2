  .sc-header { background: #0a0a0a; padding: 18px 20px; border-bottom: 1px solid #1a1a1a; }
  .sc-num { font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--red); margin-bottom: 6px; }
  .sc-header h3 { font-size: 0.95rem; font-weight: 700; color: #fff; margin: 0; line-height: 1.35; }
  .sc-body { padding: 18px 20px; }
  .sc-body p { font-size: 0.87rem; color: #c0c0c0; line-height: 1.65; margin: 0 0 12px; }
