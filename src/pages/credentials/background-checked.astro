---
// src/pages/credentials/background-checked.astro
// Background check credential page — E-E-A-T trust signal
// Angle: why home service specifically requires background checks + what we actually verify
// Note: "[Your Company Name]" was left in the original twice — not our finest hour

import Layout from '../../layouts/Layout.astro';

const title = "Background Checked Appliance Repair Technicians | Los Angeles";
const description = "Every Same Day Appliance Repair technician passes individual background checks before entering any home. Criminal history, identity, sex offender registry. (424) 325-0520.";
const phone = "(424) 325-0520";
const phoneRaw = "4243250520";
const schemaJsons = [
  `{
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Same Day Appliance Repair",
  "telephone": "(424) 325-0520",
  "url": "https://samedayappliance.repair/credentials/background-checked-appliance-repair/"
  }`,
  `{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What does a background check for appliance repair technicians include?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A thorough background check for home service technicians should include: criminal history search at county, state, and federal levels; sex offender registry check; identity verification to confirm the person is who they claim to be; and employment history verification to confirm claimed experience is real. Some companies also include driving record checks for technicians who operate service vehicles and drug screening. The depth of the search matters — a single-county check misses records from other jurisdictions, which is why multi-jurisdiction searches are the standard."
      }
    },
    {
      "@type": "Question",
      "name": "Why do background checks matter specifically for appliance repair?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Appliance repair involves access that most other professional services don't. A technician enters your home, typically when you or family members are present, sees the layout of the property, and may work in bedrooms, laundry rooms, or utility areas where valuables are visible. The work itself is legitimate — a broken dryer or refrigerator requires in-home service — but the nature of that access makes who is doing the work more important than it would be for, say, an online service. Background screening is the baseline standard for home service professionals for this reason."
      }
    },
    {
      "@type": "Question",
      "name": "What criminal history would disqualify a technician from working in homes?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Any conviction for crimes involving violence, theft, burglary, home invasion, sexual offenses, or assault would disqualify a candidate from our technician roles. Sex offender registry checks are run on every candidate — any match is an automatic disqualification with no exceptions. The standard we apply is: would we send this person into the home of someone who lives alone, an elderly homeowner, or a family with children? If there's any history that creates legitimate concern about that scenario, the candidate doesn't work for us."
      }
    },
    {
      "@type": "Question",
      "name": "How do I verify that the technician arriving at my home has been background checked?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Call us before your appointment if you want confirmation. Our technicians carry company identification that can be verified against your appointment. If at any point you're uncertain about who has arrived at your door, you're entitled to verify the technician's identity with our office before allowing entry — that's a reasonable thing to do and we support it fully. Our dispatch team can confirm the name and description of the technician assigned to your call."
      }
    },
    {
      "@type": "Question",
      "name": "Do independent appliance repair technicians go through background checks?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Background checks for independent contractors or sole proprietors in home services are voluntary — there's no California state requirement mandating them. Some independent technicians do self-screen or use third-party services, but there's no way for a consumer to verify this externally unless they ask for documentation. With a company that employs screened technicians, the background check is a company policy that applies to every person who enters a home — not a self-reported credential."
      }
    },
    {
      "@type": "Question",
      "name": "Is background checking required by law for appliance repair in California?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "California law does not currently require background checks for appliance repair technicians or household appliance servicers as a condition of state registration. The BHGS (Bureau of Household Goods and Services) requires business registration but does not mandate technician-level background screening. Background checks for home service technicians are a company policy, not a legal requirement — which is exactly why it's worth asking whether a company has one."
      }
    }
  ]
}`,
];
---

<Layout title={title} description={description}>

  <Fragment slot="head-scripts">
    {schemaJsons.map((s) => (
      <script type="application/ld+json" set:html={s}></script>
    ))}
  </Fragment>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .hero { background: var(--black); color: #fff; padding: 80px 24px 64px; text-align: center; }
  .hero-eyebrow { display: inline-block; background: var(--red); color: #fff; font-size: 0.78rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 5px 14px; border-radius: 3px; margin-bottom: 20px; }
  .hero-sub { font-size: 1.1rem; color: #ccc; max-width: 640px; margin: 0 auto 32px; line-height: 1.6; }
  .cta-row { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 16px 34px; border-radius: 5px; font-size: 1rem; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 16px 34px; border-radius: 5px; font-size: 1rem; font-weight: 600; text-decoration: none; border: 2px solid rgba(255,255,255,0.35); }
  .hero-meta { margin-top: 28px; color: #aaa; font-size: 0.9rem; display: flex; gap: 24px; justify-content: center; flex-wrap: wrap; }
  .trust-bar { background: var(--red); padding: 18px 24px; }
  .trust-inner { max-width: 1100px; margin: 0 auto; display: flex; justify-content: center; flex-wrap: wrap; gap: 10px 32px; }
  .trust-item { color: #fff; font-size: 0.88rem; font-weight: 600; }
  .section { padding: 64px 24px; }
  .section-gray { background: var(--gray); }
  .section-black { background: var(--black); color: #fff; }
  .container { max-width: 1100px; margin: 0 auto; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  h2.section-title { font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 800; margin: 0 0 16px; line-height: 1.2; }
  .section-black h2.section-title { color: #fff; }
  .intro-grid { display: grid; grid-template-columns: 1fr 320px; gap: 48px; align-items: start; }
  @media (max-width: 768px) { .intro-grid { grid-template-columns: 1fr; } }
  .intro-body p { margin: 0 0 18px; font-size: 1.05rem; line-height: 1.8; color: var(--text); }
  /* Sticky CTA */
  .sticky-cta { position: sticky; top: 24px; background: var(--black); border-radius: 10px; padding: 28px 24px; color: #fff; text-align: center; }
  .sticky-cta .cta-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: #aaa; margin-bottom: 14px; }
  .sticky-cta .cta-phone { font-size: 1.5rem; font-weight: 800; color: #fff; text-decoration: none; display: block; margin-bottom: 12px; }
  .sticky-cta .btn-cta { display: block; background: var(--red); color: #fff; padding: 14px; border-radius: 5px; font-weight: 700; text-decoration: none; font-size: 0.95rem; margin-bottom: 10px; }
  .sticky-cta .cta-sub { font-size: 0.82rem; color: #888; }
  .cta-divider { border: none; border-top: 1px solid #222; margin: 18px 0; }
  .cta-detail { list-style: none; padding: 0; margin: 0; }
  .cta-detail li { margin-bottom: 6px; padding-left: 18px; position: relative; font-size: 0.85rem; color: #aaa; }
  .cta-detail li::before { content: "✓"; position: absolute; left: 0; color: var(--red); font-weight: 700; }
  /* What's checked grid */
  .check-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 20px; margin-top: 32px; }
  .check-card { background: #111; border-radius: 8px; padding: 22px 20px; }
  .check-card.critical { border: 1px solid rgba(200,16,46,0.25); }
  .check-card.standard { border: 1px solid #1a1a1a; }
  .check-icon { font-size: 1.5rem; margin-bottom: 10px; }
  .check-card h3 { font-size: 0.95rem; font-weight: 700; color: #fff; margin: 0 0 8px; }
  .check-card p { font-size: 0.85rem; color: #666; line-height: 1.65; margin: 0; }
  /* Why it matters */
  .context-block { background: #fff; border: 1px solid var(--border); border-radius: 10px; padding: 28px; margin-top: 28px; }
  .context-block h3 { font-size: 1.05rem; font-weight: 800; margin: 0 0 14px; }
  .context-block p { font-size: 0.95rem; color: var(--muted); line-height: 1.75; margin: 0 0 14px; }
  .context-block p:last-child { margin: 0; }
  /* Compare table */
  .compare-table { width: 100%; border-collapse: collapse; margin-top: 28px; }
  .compare-table th { padding: 12px 16px; text-align: left; font-size: 0.82rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; border-bottom: 2px solid #1a1a1a; color: #555; }
  .compare-table th:first-child { width: 40%; }
  .compare-table td { padding: 14px 16px; font-size: 0.9rem; border-bottom: 1px solid #1a1a1a; vertical-align: top; }
  .compare-table tr:last-child td { border-bottom: none; }
  .compare-table .check-label { color: #fff; font-weight: 600; }
  .compare-table .yes { color: #50c060; font-weight: 700; }
  .compare-table .maybe { color: #c09030; }
  .compare-table .detail { font-size: 0.82rem; color: #555; margin-top: 3px; }
  /* Questions section */
  .question-block { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 20px 22px; margin-bottom: 14px; }
  .question-block h3 { font-size: 0.95rem; font-weight: 700; margin: 0 0 8px; color: var(--text); }
  .question-block p { font-size: 0.9rem; color: var(--muted); line-height: 1.7; margin: 0; }
  /* Credentials nav */
  .creds-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(190px, 1fr)); gap: 14px; margin-top: 28px; }
  .cred-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 18px 16px; text-decoration: none; display: block; }
  .cred-card:hover { border-color: var(--red); }
  .cred-card .cred-icon { font-size: 1.4rem; margin-bottom: 8px; }
  .cred-card h3 { font-size: 0.88rem; font-weight: 700; color: var(--text); margin: 0 0 4px; }
  .cred-card p { font-size: 0.78rem; color: var(--muted); margin: 0; line-height: 1.4; }
  /* FAQ */
  .faq-list { margin-top: 36px; }
  .faq-item { border-bottom: 1px solid var(--border); padding: 20px 0; }
  .faq-item:first-child { border-top: 1px solid var(--border); }
  .faq-item h3 { font-size: 1rem; font-weight: 700; color: var(--text); margin: 0 0 10px; }
  .faq-item p { font-size: 0.95rem; color: var(--muted); line-height: 1.7; margin: 0; }
  .nearby-links { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 24px; }
  .nearby-links a { background: #fff; border: 1px solid var(--border); border-radius: 4px; padding: 8px 16px; font-size: 0.87rem; color: var(--text); text-decoration: none; font-weight: 500; }
  .nearby-links a:hover { border-color: var(--red); color: var(--red); }
  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; margin: 0 0 16px; }
  .bottom-cta p { color: #aaa; margin: 0 0 32px; font-size: 1.05rem; }
</style>

<!-- HERO -->
