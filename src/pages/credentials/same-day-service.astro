---
// src/pages/credentials/same-day-service.astro
// Same-day service commitment page — honest framing, not false guarantee
// Angle: 90% same-day, sometimes late evening, rare exceptions on peak days
// This is a trust page, not a guarantee in the legal sense

import Layout from '../../layouts/Layout.astro';

const title = "Same-Day Appliance Repair Service Los Angeles | Same Day Appliance Repair";
const description = "Most calls placed before 2 PM reach a technician same day. Evenings available. Mon–Sat, phones 24/7. Serving LA, Pasadena, Thousand Oaks, Irvine. (424) 325-0520.";
const phone = "(424) 325-0520";
const phoneRaw = "4243250520";
const schemaJsons = [
  `{
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Same Day Appliance Repair",
  "telephone": "(424) 325-0520",
  "url": "https://samedayappliance.repair/credentials/same-day-appliance-repair-service/",
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
      "opens": "08:00",
      "closes": "20:00"
    }
  ],
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "6230 Wilshire Blvd Ste A PMB 2267",
    "addressLocality": "Los Angeles",
    "addressRegion": "CA",
    "postalCode": "90048",
    "addressCountry": "US"
  }
}`,
  `{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How quickly can you get a technician to my home?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most customers who call before 2 PM reach a technician the same day. Calls placed in the afternoon or evening are often scheduled same-day with an evening window, or first thing the following morning. On our busiest days, same-day slots fill up and we schedule for the next morning — which typically means next-day service rather than a multi-day wait. Our diagnostic fee is $89 and is waived when you proceed with the repair."
      }
    },
    {
      "@type": "Question",
      "name": "What time do your technicians work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Our technicians are available Monday through Saturday, typically from 8 AM to 8 PM. Evening appointments (6–8 PM) are available when earlier slots are full. Sunday is our day off — but phones are answered 24/7, so if you call Sunday we'll book you for Monday morning first thing. A refrigerator that stops cooling on a Saturday evening is an emergency by Sunday morning, and we'll have a technician there Monday as early as possible."
      }
    },
    {
      "@type": "Question",
      "name": "Do you offer emergency appliance repair?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For refrigerators, freezers, and commercial equipment — yes. If your refrigerator has stopped cooling, a walk-in cooler is down, or you have a gas appliance concern, call us directly and explain the situation. We prioritize same-day visits for these cases whenever possible, including evenings. Non-urgent repairs (a dishwasher with a minor drain issue, a dryer that's noisy but functional) are scheduled normally."
      }
    },
    {
      "@type": "Question",
      "name": "What if no same-day slot is available?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "On peak days — particularly Mondays and after holidays — same-day availability fills early. When same-day isn't possible, we typically schedule the first available slot the following morning, not days later. If your situation is urgent, tell us and we'll tell you honestly what we can do. We'd rather give you an accurate time than have you waiting for a technician who's overbooked."
      }
    },
    {
      "@type": "Question",
      "name": "What areas do you serve for same-day service?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Same-day service is available throughout Los Angeles County, Orange County, Ventura County, and parts of San Bernardino and Riverside Counties. Our main service hubs are Los Angeles, Pasadena, Thousand Oaks, and Irvine. For locations further out, same-day availability depends on technician routing that day — call us and we can confirm in real time."
      }
    }
  ]
}`,
];
---

<Layout title={title} description={description}>

  <Fragment slot="head-scripts">
    {schemaJsons.map((s) => (
      <script type="application/ld+json" set:html={s}></script>
    ))}
  </Fragment>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .hero { background: var(--black); color: #fff; padding: 80px 24px 64px; text-align: center; }
  .hero-eyebrow { display: inline-block; background: var(--red); color: #fff; font-size: 0.78rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 5px 14px; border-radius: 3px; margin-bottom: 20px; }
  .hero-sub { font-size: 1.1rem; color: #ccc; max-width: 640px; margin: 0 auto 32px; line-height: 1.6; }
  .cta-row { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 16px 34px; border-radius: 5px; font-size: 1rem; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 16px 34px; border-radius: 5px; font-size: 1rem; font-weight: 600; text-decoration: none; border: 2px solid rgba(255,255,255,0.35); }
  .hero-meta { margin-top: 28px; color: #aaa; font-size: 0.9rem; display: flex; gap: 24px; justify-content: center; flex-wrap: wrap; }
  .trust-bar { background: var(--red); padding: 18px 24px; }
  .trust-inner { max-width: 1100px; margin: 0 auto; display: flex; justify-content: center; flex-wrap: wrap; gap: 10px 32px; }
  .trust-item { color: #fff; font-size: 0.88rem; font-weight: 600; }
  .section { padding: 64px 24px; }
  .section-gray { background: var(--gray); }
  .section-black { background: var(--black); color: #fff; }
  .container { max-width: 1100px; margin: 0 auto; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  h2.section-title { font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 800; margin: 0 0 16px; line-height: 1.2; }
  .section-black h2.section-title { color: #fff; }
  .intro-grid { display: grid; grid-template-columns: 1fr 320px; gap: 48px; align-items: start; }
  @media (max-width: 768px) { .intro-grid { grid-template-columns: 1fr; } }
  .intro-body p { margin: 0 0 18px; font-size: 1.05rem; line-height: 1.8; color: var(--text); }
  /* Sticky CTA */
  .sticky-cta { position: sticky; top: 24px; background: var(--black); border-radius: 10px; padding: 28px 24px; color: #fff; text-align: center; }
  .sticky-cta .cta-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: #aaa; margin-bottom: 14px; }
  .sticky-cta .cta-phone { font-size: 1.5rem; font-weight: 800; color: #fff; text-decoration: none; display: block; margin-bottom: 12px; }
  .sticky-cta .btn-cta { display: block; background: var(--red); color: #fff; padding: 14px; border-radius: 5px; font-weight: 700; text-decoration: none; font-size: 0.95rem; margin-bottom: 10px; }
  .sticky-cta .cta-sub { font-size: 0.82rem; color: #888; }
  .cta-divider { border: none; border-top: 1px solid #222; margin: 18px 0; }
  .cta-detail { list-style: none; padding: 0; margin: 0; }
  .cta-detail li { margin-bottom: 6px; padding-left: 18px; position: relative; font-size: 0.85rem; color: #aaa; }
  .cta-detail li::before { content: "✓"; position: absolute; left: 0; color: var(--red); font-weight: 700; }
  /* Timeline */
  .timeline { margin-top: 32px; }
  .tl-item { display: grid; grid-template-columns: 120px 1fr; gap: 20px; padding: 20px 0; border-bottom: 1px solid #1a1a1a; align-items: start; }
  .tl-item:first-child { border-top: 1px solid #1a1a1a; }
  .tl-time { font-size: 1rem; font-weight: 800; color: var(--red); padding-top: 2px; }
  .tl-body h3 { font-size: 0.95rem; font-weight: 700; color: #fff; margin: 0 0 6px; }
  .tl-body p { font-size: 0.86rem; color: #666; line-height: 1.65; margin: 0; }
  /* Stats */
  .stats-row { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 20px; margin-top: 32px; }
  .stat-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 24px 20px; text-align: center; }
  .stat-number { font-size: 2.8rem; font-weight: 900; color: var(--red); line-height: 1; margin-bottom: 6px; }
  .stat-label { font-size: 0.85rem; color: var(--muted); line-height: 1.4; }
  /* Honest block */
  .honest-block { background: #0a0a0a; border: 1px solid #1a1a1a; border-radius: 10px; padding: 26px 24px; margin-top: 28px; }
  .honest-block .h-label { font-size: 0.73rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: #555; margin-bottom: 10px; }
  .honest-block h3 { font-size: 1rem; font-weight: 800; color: #fff; margin: 0 0 12px; }
  .honest-block p { font-size: 0.9rem; color: #666; line-height: 1.7; margin: 0 0 10px; }
  .honest-block p:last-child { margin: 0; }
  /* Service areas */
  .areas-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 16px; margin-top: 28px; }
  .area-card { background: #111; border: 1px solid #1a1a1a; border-radius: 8px; padding: 18px 16px; }
  .area-card h3 { font-size: 0.9rem; font-weight: 700; color: #fff; margin: 0 0 6px; }
  .area-card p { font-size: 0.82rem; color: #555; line-height: 1.5; margin: 0; }
  .area-badge { display: inline-block; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; padding: 2px 8px; border-radius: 3px; margin-bottom: 8px; }
  .badge-hub { background: rgba(200,16,46,0.15); color: var(--red); }
  .badge-extended { background: #1a1a1a; color: #555; }
  /* Credentials nav */
  .creds-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(190px, 1fr)); gap: 14px; margin-top: 28px; }
  .cred-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 18px 16px; text-decoration: none; display: block; }
  .cred-card:hover { border-color: var(--red); }
  .cred-card .cred-icon { font-size: 1.4rem; margin-bottom: 8px; }
  .cred-card h3 { font-size: 0.88rem; font-weight: 700; color: var(--text); margin: 0 0 4px; }
  .cred-card p { font-size: 0.78rem; color: var(--muted); margin: 0; line-height: 1.4; }
  /* FAQ */
  .faq-list { margin-top: 36px; }
  .faq-item { border-bottom: 1px solid var(--border); padding: 20px 0; }
  .faq-item:first-child { border-top: 1px solid var(--border); }
  .faq-item h3 { font-size: 1rem; font-weight: 700; color: var(--text); margin: 0 0 10px; }
  .faq-item p { font-size: 0.95rem; color: var(--muted); line-height: 1.7; margin: 0; }
  .nearby-links { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 24px; }
  .nearby-links a { background: #fff; border: 1px solid var(--border); border-radius: 4px; padding: 8px 16px; font-size: 0.87rem; color: var(--text); text-decoration: none; font-weight: 500; }
  .nearby-links a:hover { border-color: var(--red); color: var(--red); }
  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; margin: 0 0 16px; }
  .bottom-cta p { color: #aaa; margin: 0 0 32px; font-size: 1.05rem; }
</style>

<!-- HERO -->
<section class="hero">
  <div class="hero-eyebrow">Same-Day Service · 7 Days a Week · Evenings Available</div>
  <h1>Most Customers Get a Technician the Same Day They Call</h1>
  <p class="hero-sub">About 90% of customers who want same-day service get it. Calls before 2 PM almost always reach a technician that afternoon. Evening slots available when earlier windows are full. We'll tell you honestly what we can do when you call.</p>
  <div class="cta-row">
    <a href={`tel:${phoneRaw}`} class="btn-primary">Call {phone}</a>
    <a href="/book" class="btn-secondary">Schedule Online</a>
  </div>
  <div class="hero-meta">
    <span>⚡ ~90% Same-Day Rate</span>
    <span>🌙 Evenings Until 8 PM</span>
    <span>📅 Mon – Sat</span>
    <span>📞 Phones 24/7</span>
    <span>🗺️ 5 Counties Covered</span>
  </div>
</section>

<!-- TRUST BAR -->
<div class="trust-bar">
  <div class="trust-inner">
    <span class="trust-item">⚡ Same-Day Priority Dispatch</span>
    <span class="trust-item">🌙 Evening Slots Available</span>
    <span class="trust-item">📅 Mon – Sat · Phones 24/7</span>
    <span class="trust-item">🗺️ LA · OC · Ventura · SB · Riverside</span>
  </div>
</div>

<!-- INTRO -->
<section class="section">
  <div class="container">
    <div class="intro-grid">
      <div class="intro-body">
        <p class="section-number">01 — How Same-Day Service Actually Works</p>
        <h2 class="section-title">What "same day" means in practice — and when it doesn't</h2>

        <p>We get about 90% of customers who want same-day service a visit on the day they call. That's not marketing copy — it's what the numbers look like across a typical week. The other 10% are mostly peak-day situations: busy Mondays, post-holiday Tuesdays, days when the schedule fills by noon. When that happens, we're usually talking about next-morning service, not a multi-day wait.</p>

        <p>The honest version of same-day service in LA: if you call before 2 PM on a normal day, there's a strong chance we'll have someone there that afternoon or early evening. If you call at 4 PM, it might be a 6 or 7 PM arrival — our guys work until 8. If you call on a day when slots are gone, we tell you that directly and book you for the next available time, which is usually the following morning.</p>

        <p>Our diagnostic fee is $89 — waived when you proceed with the repair. That applies whether the technician arrives at 2 PM or 7 PM.</p>

        <div class="honest-block">
          <div class="h-label">📋 What We Tell You When You Call</div>
          <h3>Real availability, not optimistic estimates</h3>
          <p>When you call, our dispatcher gives you the actual window for that day — not a theoretical "we might be able to squeeze you in." If same-day is available, we confirm it. If it's not, we tell you that and give you the next earliest slot. A refrigerator that stopped cooling at 10 AM doesn't benefit from a 9 PM estimated arrival that becomes 11 PM.</p>
          <p>For refrigerators, freezers, and commercial equipment: if you tell us it's urgent, we treat it as urgent. These get priority in the same-day queue over non-critical repairs.</p>
        </div>
      </div>

      <aside class="sticky-cta">
        <div class="cta-label">Call for Same-Day Availability</div>
        <a href={`tel:${phoneRaw}`} class="cta-phone">{phone}</a>
        <a href={`tel:${phoneRaw}`} class="btn-cta">Check Today's Availability</a>
        <a href="/book" class="btn-cta" style="background:#222; margin-top:-4px;">Schedule Online</a>
        <div class="cta-sub">$89 diagnostic · waived with repair</div>
        <hr class="cta-divider" />
        <ul class="cta-detail">
          <li>~90% same-day rate</li>
          <li>Evening slots until 8 PM</li>
          <li>Mon–Sat 8 AM–8 PM · Phones 24/7</li>
          <li>Urgent cases prioritized</li>
          <li>5 counties covered</li>
          <li>90-day warranty on repairs</li>
        </ul>
      </aside>
    </div>
  </div>
</section>

<!-- SAME-DAY TIMELINE -->
<section class="section section-black">
  <div class="container">
    <p class="section-number">02 — How Call Time Affects Same-Day Availability</p>
    <h2 class="section-title">What to expect based on when you call</h2>

    <div class="timeline">
      <div class="tl-item">
        <div class="tl-time">Before 10 AM</div>
        <div class="tl-body">
          <h3>Best same-day availability</h3>
          <p>Morning calls have the widest choice of appointment windows — afternoon, late afternoon, or evening. You can usually specify a preference and we'll try to match it. Urgent calls (refrigerator down, commercial equipment) at this time almost always get same-day.</p>
        </div>
      </div>
      <div class="tl-item">
        <div class="tl-time">10 AM – 2 PM</div>
        <div class="tl-body">
          <h3>Strong same-day likelihood</h3>
          <p>Afternoon slots are usually available. You may get a later window — 4–6 PM or 6–8 PM — but same-day service is typically possible. This is when most residential calls come in and our dispatch is actively routing.</p>
        </div>
      </div>
      <div class="tl-item">
        <div class="tl-time">2 PM – 5 PM</div>
        <div class="tl-body">
          <h3>Same-day possible, evening window likely</h3>
          <p>Afternoon calls can often be accommodated with an evening arrival — 6 or 7 PM. On busier days the same-day slots may be full, in which case we schedule first thing the next morning.</p>
        </div>
      </div>
      <div class="tl-item">
        <div class="tl-time">After 5 PM</div>
        <div class="tl-body">
          <h3>Next morning by default, same-day possible for urgent</h3>
          <p>Late-day calls are typically scheduled for the following morning. For genuine emergencies — refrigerator stopped cooling, commercial equipment down before a business day — call us and explain. We'll tell you honestly if we can still make something happen that evening.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- STATS -->
<section class="section section-gray">
  <div class="container">
    <p class="section-number">03 — By the Numbers</p>
    <h2 class="section-title">What same-day service looks like across a typical week</h2>

    <div class="stats-row">
      <div class="stat-card">
        <div class="stat-number">~90%</div>
        <div class="stat-label">Customers who want same-day service and get it</div>
      </div>
      <div class="stat-card">
        <div class="stat-number">8 AM</div>
        <div class="stat-label">Earliest available appointment window</div>
      </div>
      <div class="stat-card">
        <div class="stat-number">8 PM</div>
        <div class="stat-label">Latest technician arrival time</div>
      </div>
      <div class="stat-card">
        <div class="stat-number">6</div>
        <div class="stat-label">Days per week we dispatch · Phones 24/7</div>
      </div>
      <div class="stat-card">
        <div class="stat-number">$89</div>
        <div class="stat-label">Diagnostic fee — waived with repair</div>
      </div>
      <div class="stat-card">
        <div class="stat-number">90 days</div>
        <div class="stat-label">Warranty on parts and labor</div>
      </div>
    </div>
  </div>
</section>

<!-- SERVICE AREAS -->
<section class="section section-black">
  <div class="container">
    <p class="section-number">04 — Same-Day Coverage Area</p>
    <h2 class="section-title">Where same-day service is reliably available</h2>

    <div class="areas-grid">
      <div class="area-card">
        <div class="area-badge badge-hub">Main Hub</div>
        <h3>Los Angeles</h3>
        <p>West Hollywood, Beverly Hills, Brentwood, Santa Monica, Silver Lake, Downtown, Burbank, Glendale, Pasadena, North Hollywood</p>
      </div>
      <div class="area-card">
        <div class="area-badge badge-hub">Main Hub</div>
        <h3>Thousand Oaks</h3>
        <p>Thousand Oaks, Agoura Hills, Calabasas, Westlake Village, Malibu, Simi Valley, Moorpark, Camarillo, Oxnard</p>
      </div>
      <div class="area-card">
        <div class="area-badge badge-hub">Main Hub</div>
        <h3>Irvine / Orange County</h3>
        <p>Irvine, Anaheim, Santa Ana, Costa Mesa, Newport Beach, Huntington Beach, Laguna Beach, Mission Viejo</p>
      </div>
      <div class="area-card">
        <div class="area-badge badge-extended">Extended</div>
        <h3>San Bernardino County</h3>
        <p>Ontario, Rancho Cucamonga, Fontana, San Bernardino, Redlands, Loma Linda — same-day based on routing</p>
      </div>
      <div class="area-card">
        <div class="area-badge badge-extended">Extended</div>
        <h3>Riverside County</h3>
        <p>Riverside, Corona, Temecula, Murrieta — same-day availability varies. Call to confirm for your location.</p>
      </div>
    </div>
  </div>
</section>

<!-- CREDENTIALS NAV -->
<section class="section section-gray">
  <div class="container">
    <p class="section-number">05 — Our Full Credentials</p>
    <h2 class="section-title">Same-day service backed by a complete trust stack</h2>
    <div class="creds-grid">
      <a href="/credentials/licensed-appliance-repair/" class="cred-card">
        <div class="cred-icon">📋</div>
        <h3>BHGS Registered</h3>
        <p>California #A49573 — verifiable at bhgs.dca.ca.gov</p>
      </a>
      <a href="/credentials/insured-appliance-repair/" class="cred-card">
        <div class="cred-icon">🛡</div>
        <h3>Fully Insured</h3>
        <p>GL, Workers Comp, Commercial Auto.</p>
      </a>
      <a href="/credentials/background-checked-appliance-repair/" class="cred-card">
        <div class="cred-icon">✅</div>
        <h3>Background Checked</h3>
        <p>All technicians individually screened.</p>
      </a>
      <a href="/credentials/epa-certified-appliance-repair/" class="cred-card">
        <div class="cred-icon">🔬</div>
        <h3>EPA-608 Universal</h3>
        <p>Federal refrigerant handling certification.</p>
      </a>
      <a href="/credentials/bbb-accredited-appliance-repair/" class="cred-card">
        <div class="cred-icon">⭐</div>
        <h3>BBB Accredited A+</h3>
        <p>Publicly verifiable at bbb.org.</p>
      </a>
      <a href="/credentials/same-day-appliance-repair-service/" class="cred-card" style="border-color:var(--red);">
        <div class="cred-icon">⚡</div>
        <h3>Same-Day Service</h3>
        <p>~90% same-day rate, evenings available. You are here.</p>
      </a>
    </div>
  </div>
</section>

<!-- FAQ -->
<section class="section">
  <div class="container">
    <p class="section-number">06 — Frequently Asked Questions</p>
    <h2 class="section-title">Same-day appliance repair — what to expect</h2>
    <div class="faq-list">
      <div class="faq-item">
        <h3>How quickly can you get a technician to my home?</h3>
        <p>Most customers who call before 2 PM get a same-day visit. Calls in the afternoon are often accommodated with an evening window (6–8 PM). On our busiest days, same-day fills early — in that case we typically schedule the next morning. Diagnostic fee is $89, waived with repair.</p>
      </div>
      <div class="faq-item">
        <h3>What time do your technicians work?</h3>
        <p>Monday through Saturday, 8 AM to 8 PM. Evening appointments are real slots — when earlier windows are full, 6–8 PM is a genuine option. Phones are answered 24/7: Sunday calls get booked for Monday morning.</p>
      </div>
      <div class="faq-item">
        <h3>Do you offer emergency appliance repair?</h3>
        <p>For refrigerators, freezers, and commercial equipment: yes. Tell us it's urgent when you call and we prioritize these in the same-day queue. A fridge that stopped cooling gets different treatment than a microwave with a broken turntable.</p>
      </div>
      <div class="faq-item">
        <h3>What if no same-day slot is available?</h3>
        <p>We tell you directly and book the next available slot — usually first thing the following morning. We don't put you in a holding pattern. If same-day isn't available, we say so and give you a real alternative.</p>
      </div>
      <div class="faq-item">
        <h3>What areas do you cover for same-day service?</h3>
        <p>Los Angeles County, Orange County, Ventura County reliably. San Bernardino and Riverside County same-day availability depends on routing. Call us and we can confirm for your specific location.</p>
      </div>
    </div>
  </div>
