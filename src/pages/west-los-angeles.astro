---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

const citySlug = 'west-los-angeles';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = "West Los Angeles";
const zips = ['90024', '90025', '90034', '90064', '90066', '90067'];

const phoneRaw = `+1${branch.phone.replace(/\D/g, '')}`;

const title = `Appliance Repair West Los Angeles CA | Same Day Service | ${branch.phone}`;
const description = "Same-day appliance repair in West LA. Sub-Zero, Wolf, Miele specialists. $89 dx — waived with repair.";
const canonical = 'https://samedayappliance.repair/west-los-angeles/';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { '@type': 'Place', name: 'West Los Angeles' },
    { '@type': 'Place', name: 'Westwood' },
    { '@type': 'Place', name: 'Sawtelle' },
    { '@type': 'Place', name: 'Mar Vista' },
    { '@type': 'Place', name: 'Century City' }
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$$',
  license: 'BHGS #A49573'

};

const introParagraphs = [
  "\"West LA\" covers a span of LA neighborhoods that share a postal-region but cook in completely different kitchens. Westwood and Century City are the high-rise condo end — Wilshire towers, the Century Park area near the mall, and the tower clusters along Westwood Boulevard south of UCLA. Sawtelle and Palms are mid-density apartment + small-lot single-family with the Sawtelle Japantown commercial strip running through. Rancho Park and Cheviot Hills are denser-lot single-family with mid-century housing stock and the Cheviot Hills Recreation Center anchoring the area. Mar Vista is the southwestern edge — 1940s-50s tract housing renovated heavily over the past decade, with the Mar Vista Farmers Market on Sunday and the cluster around Centinela + Venice Boulevard.",
  "Service work shifts based on which of these you're in. Westwood + Century City condo calls run luxury-brand-heavy: Sub-Zero, Wolf, Thermador, Miele installs in 2010-2018-era Wilshire towers, with concierge or property-management coordination for service-elevator access. Sawtelle + Palms apartment calls require building-side water-shutoff coordination because most pre-1990 multi-unit buildings have shared shutoffs. Rancho Park and Cheviot Hills mid-century renovations frequently have legacy electrical circuits feeding modern luxury appliances — we verify the service before energizing. Mar Vista renovations are the most diverse: 1948 footprint, 2020 Sub-Zero, 1965 service panel, 2018 PEX water lines (or 1948 galvanized still in place — both happen).",
  `Our West Hollywood branch runs all of West LA on the regular schedule. The ${branch.phone} number is the same one that reaches our dispatch for Beverly Hills, West Hollywood, Bel Air, Brentwood, Santa Monica — same technicians, same parts inventory, same OEM relationships. No distance surcharge between any of these neighborhoods. Call <a href="tel:${phoneRaw}">${branch.phone}</a> — someone with our actual Westside schedule picks up.`
];

const services = [
  { icon: '❄️', name: 'Refrigerator Repair', slug: 'refrigerator' },
  { icon: '🫧', name: 'Washer Repair', slug: 'washer' },
  { icon: '💨', name: 'Dryer Repair', slug: 'dryer' },
  { icon: '🍽️', name: 'Dishwasher Repair', slug: 'dishwasher' },
  { icon: '🔥', name: 'Oven & Range Repair', slug: 'oven' },
  { icon: '🍳', name: 'Stove Repair', slug: 'stove' },
  { icon: '📻', name: 'Microwave Repair', slug: 'microwave' },
  { icon: '🧊', name: 'Ice Maker Repair', slug: 'ice-maker' },
  { icon: '🍷', name: 'Wine Cooler Repair', slug: 'wine-cooler' },
  { icon: '🧊', name: 'Freezer Repair', slug: 'freezer' },
  { icon: '🗑️', name: 'Garbage Disposal Repair', slug: 'garbage-disposal' },
  { icon: '♨️', name: 'Cooktop Repair', slug: 'cooktop' }
];

const neighborhoods = [
  { name: 'Westwood', zip: '90024' },
  { name: 'Sawtelle / West LA', zip: '90025' },
  { name: 'Palms', zip: '90034' },
  { name: 'Rancho Park / Cheviot Hills', zip: '90064' },
  { name: 'Mar Vista', zip: '90066' },
  { name: 'Century City', zip: '90067' }
];

const recentJobs = [
  {
    appliance: 'Sub-Zero 685',
    location: 'Westwood',
    quote: "Sub-Zero 685 — Westwood condo, evaporator fan seized after move-in",
    description: "Sub-Zero 685/F built-in in a Wilshire-corridor Westwood condo near Westwood Plaza — homeowners had moved in three weeks prior, refrigerator side running 48°F instead of 38°F. Evaporator fan motor had seized — the unit had sat unused during the seller's six-month vacancy, and the fan motor bearings froze from disuse rather than wear. Replaced the fan motor (Sub-Zero OEM), defrosted the iced-over evaporator, ran a 24-hour cool-down test the next day. Westwood condo Sub-Zero installs in the Wilshire towers tend to be 2010-2018 generation; we see post-vacancy fan motor failures repeatedly when properties sit empty between owners.",
    outcome: '✓ Same day · Sub-Zero OEM evaporator fan motor · 2 hours'
  },
  {
    appliance: 'Bosch dishwasher',
    location: 'Sawtelle / West LA',
    quote: "Bosch dishwasher — Sawtelle apartment, E15 error mid-cycle",
    description: "Bosch SHX 800 series in a Sawtelle 1980s apartment building near Sawtelle + Olympic — E15 error code (water leak detected). Anti-flood pan had collected water from a slow drip at the sump-to-pump connection. Replaced the cracked sump gasket, dried the anti-flood pan, reset the float switch, ran two test cycles. Sawtelle's older multi-unit apartment buildings have water shutoffs at the building level which means we coordinate with the property manager before opening any plumbing — standard for West LA apartment service. Job spec written so the property manager could file it with the building's records.",
    outcome: '✓ Same day · Bosch OEM sump gasket · 1.5 hours'
  },
  {
    appliance: 'Miele washer',
    location: 'Mar Vista',
    quote: "Miele washer — Mar Vista 1950s home, F-19 vibration error on spin",
    description: "Miele W1 washer in a Mar Vista mid-century home off Centinela — F-19 imbalance error consistently at the high-spin extraction phase. Unit was level and balanced; the issue was the suspension bushings on the inner drum had worn enough to allow excess axial play during 1400 RPM extraction. Replaced both suspension bushings (Miele specifies pairs), recalibrated the drum-balance sensor, ran four test cycles with mixed loads. Mar Vista's older flat-pad concrete laundry rooms transmit washer vibration into the rest of the house more than newer construction does — Miele customers there notice imbalance issues earlier than they would in newer homes.",
    outcome: '✓ Same day · Miele OEM suspension bushing pair · 2.5 hours'
  }
];

const pricingTiers = [
  { appliance: 'Residential Diagnostic', range: '$89', note: 'No distance surcharge · Credited toward repair · Written estimate' },
  { appliance: 'Standard Repair Range', range: '$150–$350', note: 'Parts + labor · OEM parts · 90-day warranty' },
  { appliance: 'Luxury Brand Repair', range: '$250–$600+', note: 'Sub-Zero, Wolf, Thermador, Viking, Miele · OEM parts', featured: true },
  { appliance: '90-Day Warranty', range: 'All Repairs', note: 'Parts + labor · Same-issue return at no charge' }
];

const faqs = [
  {
    question: 'Do you service Westwood, Century City, and the rest of West LA?',
    answer: `Yes — West LA is a regular service district from our West Hollywood branch. The ${branch.phone} number reaches dispatch with our actual schedule. Coverage spans all six neighborhoods: Westwood (90024), Sawtelle / West LA (90025), Palms (90034), Rancho Park / Cheviot Hills (90064), Mar Vista (90066), and Century City (90067). Same-day service available when you call before noon.`
  },
  {
    question: 'Do you handle Westwood and Century City high-rise condos?',
    answer: "Yes. Wilshire-corridor Westwood and Century City have a high concentration of high-rise condo Sub-Zero, Wolf, Thermador, and Miele installs from the 2010-2018 build wave. We coordinate with building concierge or property management for service-elevator access when needed. Our West Hollywood truck stocks OEM parts for these brands, so we don't roll up to a Century City call empty-handed."
  },
  {
    question: 'What appliance brands are most common in West LA homes?',
    answer: "Mixed across neighborhoods. Westwood + Century City + Rancho Park / Cheviot Hills luxury homes and condos run Sub-Zero, Wolf, Thermador, Miele, Bosch. Sawtelle + Palms + Mar Vista mid-market homes (1950s-80s housing stock, many renovated) have a mix of premium-mainstream brands — KitchenAid, GE Profile, Samsung, LG, Whirlpool, Bosch dishwashers common. We carry parts for both luxury and mass-market on the West Hollywood truck."
  },
  {
    question: 'Do you charge a distance surcharge for West LA?',
    answer: "No. West LA is on our regular West Hollywood branch route. The $89 residential diagnostic is the same in West LA as it is in Beverly Hills, West Hollywood, or Brentwood. What we quote is what you pay."
  },
  {
    question: 'What is your warranty on West LA repairs?',
    answer: "All repairs carry a 90-day warranty on parts and labor. If the same issue returns within that window, we come back at no additional charge. BHGS #A49573 + BBB accredited."
  }
];

const nearbyCities = [
  { name: 'Beverly Hills', slug: 'beverly-hills' },
  { name: 'West Hollywood', slug: 'west-hollywood' },
  { name: 'Brentwood', slug: 'brentwood' },
  { name: 'Santa Monica', slug: 'santa-monica' },
  { name: 'Culver City', slug: 'culver-city' },
  { name: 'Bel Air', slug: 'bel-air' }
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair in"
    headlineCity="West Los Angeles, CA"
    subheadline="Same-day service across Westwood, Sawtelle, Palms, Mar Vista, Rancho Park, and Century City. Sub-Zero, Wolf, Miele, and all major brands. $89 diagnostic — waived with repair."
    zips={zips}
    tier={3}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="West LA's six districts — Westwood high-rises to Mar Vista mid-century"
    paragraphs={introParagraphs}
    bookingTitle="West LA Service"
    bookingSub="Available Today"
  />

  <ServicesGrid
    cityName={cityName}
    headline="Appliance Repair Services in West LA"
    services={services}
  />

  <ServiceArea
    cityName={cityName}
    headline="West LA Neighborhoods We Service"
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={[]}
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Repairs in West LA"
    jobs={recentJobs}
  />

  <PricingCards
    cityName={cityName}
    headline="Repair Pricing in West LA"
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="Frequently Asked Questions — West LA"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby Westside Cities"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Schedule Your West LA Repair Today"
    body="Same-day service across Westwood, Sawtelle, Palms, Mar Vista, Rancho Park, Century City. No distance surcharge."
  />
</CityLayoutV2>
