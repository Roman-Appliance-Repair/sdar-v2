---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import CustomNarrative from '../components/cities/v2/CustomNarrative.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES, MAIN_PHONE, isPlaceholderPhone } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

const citySlug = 'newbury-park';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = 'Newbury Park';
const zips = ['91320'];

const phone = branch.phone;
const phoneRaw = `+1${phone.replace(/\D/g, '')}`;

const title = `Appliance Repair Newbury Park CA | Same Day Service | ${phone}`;
const description = 'Same-day appliance repair in Newbury Park, CA. Conejo Valley community. Sub-Zero, Wolf, Miele & all brands. Cal-Am water expertise. OEM parts, 90-day warranty. $89 diagnostic.';
const canonical = 'https://samedayappliance.repair/newbury-park/';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { '@type': 'Place', name: 'Newbury Park' },
    { '@type': 'Place', name: 'Lang Ranch' },
    { '@type': 'Place', name: 'Conejo Valley' },
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$',
  license: 'CA CSLB #1138898'

};

const introParagraphs = [
  "Newbury Park is technically part of Thousand Oaks, and from our branch's perspective it's treated exactly that way. Our technicians are in the Conejo Valley every day. Newbury Park isn't a remote outpost that requires a travel surcharge — it's where we work.",
  "The housing in Newbury Park reflects the Conejo Valley character: well-maintained family homes, established neighborhoods like Lang Ranch, and a mix of appliances from Samsung and LG in the mid-range to Sub-Zero, Wolf, Miele, and Thermador in the larger homes. Our technicians carry OEM parts for all of these on every Conejo Valley truck.",
  "One thing we watch for specifically in Newbury Park: Cal-Am water hardness. The same water system that serves Thousand Oaks serves Newbury Park, and the mineral content affects dishwasher spray arms, refrigerator inlet valves, and ice maker components over time. We check for this proactively on every service call involving water-connected appliances — because a $20 filter replacement or inlet screen cleaning prevents the $300 pump or valve replacement it can cause.",
  `Diagnostic fee is $89, credited toward the repair. Call <a href="tel:${phoneRaw}">${phone}</a>.`,
];

const services = [
  { icon: '❄️', name: 'Refrigerator Repair', slug: 'refrigerator' },
  { icon: '🫧', name: 'Washer Repair', slug: 'washer' },
  { icon: '💨', name: 'Dryer Repair', slug: 'dryer' },
  { icon: '🍽️', name: 'Dishwasher Repair', slug: 'dishwasher' },
  { icon: '🔥', name: 'Oven & Range Repair', slug: 'oven' },
  { icon: '♨️', name: 'Cooktop Repair', slug: 'cooktop' },
  { icon: '🍷', name: 'Wine Cooler Repair', slug: 'wine-cooler' },
  { icon: '🧊', name: 'Ice Maker Repair', slug: 'ice-maker' },
];

const calAmWaterNarrative = {
  headline: 'Cal-Am Water and Luxury Appliances — What Newbury Park Homeowners Should Know',
  paragraphs: [
    "Cal-Am Water delivers moderate-to-hard water throughout the Conejo Valley, including Newbury Park. For most appliances this is background noise — but for Sub-Zero refrigerators, Miele dishwashers, and high-precision ice makers, it's a maintenance consideration that most homeowners miss until something fails.",
    'Here\'s what we see on service calls in Newbury Park:',
    'Sub-Zero refrigerators with water dispensers and ice makers accumulate scale on inlet valve screens over time. The manufacturer recommends a 6-month filter replacement cycle. When a filter goes 18-24 months, flow restriction reduces ice production, causes undersized or hollow cubes, and eventually can cause valve failure. We check the filter age on every Sub-Zero call and replace it when it\'s overdue.',
    'Miele dishwashers are particularly sensitive to hard water because of their precision spray arm design. Mineral deposits on the spray arm nozzles reduce water pressure to the upper rack, leading to poor cleaning performance before any obvious error code appears. We descale spray arms on every Miele call in the Conejo Valley — it takes 15 minutes and prevents the next call.',
    "Wolf range oven F7 errors are almost always the temperature probe, not the control board. We've seen multiple Newbury Park homeowners quoted control board replacements ($600+) when the actual failed part is the probe ($80-100). We diagnose correctly.",
  ]
};

const neighborhoods = [
  { name: 'Newbury Park proper', zip: '91320' },
  { name: 'Conejo Valley area', zip: '91320' },
  { name: 'Old Conejo Road area', zip: '91320' },
  { name: 'Wendy Drive corridor', zip: '91320' },
  { name: 'Reino Road area', zip: '91320' },
  { name: 'Borchard Road area', zip: '91320' },
  { name: 'Kimber Drive area', zip: '91320' },
  { name: 'Lynn Road corridor', zip: '91320' },
  { name: 'Hillcrest area', zip: '91320' },
  { name: 'Lang Ranch area', zip: '91320' },
];

const recentJobs = [
  {
    appliance: 'Sub-Zero Refrigerator',
    location: 'Lang Ranch area',
    quote: 'Sub-Zero refrigerator — ice maker slow, cubes smaller than normal',
    description: "Sub-Zero BI-48SID — ice maker producing undersized cubes at half the normal rate. Cal-Am water hardness had scaled the inlet valve screen significantly over 18 months without a filter change. Flow restriction was enough to reduce ice cube fill volume. Replaced the water filter (original — 18 months in service), cleaned the inlet valve screen, ran the ice maker through three full cycles to verify cube size and production rate. Also found a slow door seal leak that we caught during the service — small airflow compromise that the customer had attributed to 'the fridge running more lately.' Sealed it at no charge.",
    outcome: '✓ Sub-Zero OEM water filter + door seal adjustment · 2 hours'
  },
  {
    appliance: 'Miele Dishwasher',
    location: 'Newbury Park proper',
    quote: 'Miele dishwasher — F11 drain error, not completing cycle',
    description: 'Miele G 6365 SCVi — F11 drain fault, cycle stopping at the drain stage. Drain pump impeller had a small bone fragment lodged in it from a previous load. Cleared the obstruction, checked the pump for damage (none), ran three full cycles. Also descaled the spray arms while we were in there — Cal-Am mineral deposits were building up on the nozzle ports. Newbury Park has moderate water hardness and Miele dishwashers are particularly sensitive to spray arm restriction over time.',
    outcome: '✓ Obstruction removal + descale service · 1.5 hours'
  },
  {
    appliance: 'KitchenAid Washer',
    location: 'Conejo Valley area',
    quote: "KitchenAid washer — F5 E2 door latch error, won't start",
    description: "KitchenAid KHWS01PMT — F5 E2 door latch fault on every start attempt. Door latch assembly had failed — the latch mechanism was engaging but the electronic switch wasn't registering the closed state. Replaced the complete latch assembly with an OEM KitchenAid part. Tested through five cycles of varying load sizes. Simple fix, but only if you have the right part. We stocked it.",
    outcome: '✓ KitchenAid OEM door latch assembly · 1 hour'
  },
  {
    appliance: 'Wolf Range',
    location: 'Hillcrest area',
    quote: 'Wolf range — oven temperature inconsistent, F7 error occasionally',
    description: 'Wolf DF304 dual-fuel range — oven temperature varying 50+ degrees from setpoint, occasional F7 fault code. Temperature probe had drifted and was intermittently failing. Replaced the probe with an OEM Wolf part, recalibrated the oven temperature offset, ran verification tests at 325°F, 375°F, and 450°F. Customer had been thinking it was the control board for months — F7 errors on Wolf ovens are almost always the probe, not the board.',
    outcome: '✓ Wolf OEM oven temperature probe · 1.5 hours'
  },
];

const whyReasons = [
  {
    iconKey: 'team' as const,
    title: "We're already here",
    body: 'Our Thousand Oaks branch runs the Conejo Valley daily. Newbury Park isn\'t a detour — it\'s on our regular route. No surcharge, no "we can fit you in Thursday."'
  },
  {
    iconKey: 'parts' as const,
    title: 'Cal-Am water expertise',
    body: 'We check water filters and inlet screens proactively on every relevant service call. The $89 filter replacement that prevents a $350 valve failure is better for everyone.'
  },
  {
    iconKey: 'shield' as const,
    title: 'Luxury brands on the truck',
    body: 'Sub-Zero, Wolf, Miele, Thermador — OEM parts in our Conejo Valley trucks. Most Lang Ranch and hillside calls finish same visit.'
  },
  {
    iconKey: 'clock' as const,
    title: 'We diagnose correctly',
    body: 'Wolf F7 is the probe. Sub-Zero ice maker slowing down is probably the filter. We find the actual failed part before recommending anything.'
  },
];

const testimonials = [
  {
    stars: 5,
    text: '"Sub-Zero ice maker slowing down for months. Same Day replaced the filter, cleaned the inlet screen, and found a door seal issue while they were there. Fixed all of it same visit. Proactive service — they didn\'t just fix what I called about."',
    author: '— Patricia K., Lang Ranch'
  },
  {
    stars: 5,
    text: '"Wolf range F7 error. Another company quoted me a control board at $650. Same Day said it was the temperature probe — $160 fix. They were right. I appreciate honesty over upselling."',
    author: '— Michael R., Hillcrest area'
  },
  {
    stars: 5,
    text: '"Miele dishwasher drain error. They cleared the obstruction, descaled the spray arms, and left me with a maintenance schedule. One visit, done right. No surcharge for Newbury Park vs Thousand Oaks — just the same flat rate."',
    author: '— Susan T., Newbury Park'
  },
];

const pricingTiers = [
  { appliance: 'Diagnostic Fee', range: '$89', note: 'Same as Thousand Oaks · No distance surcharge · Water assessment included' },
  { appliance: 'Standard Repair', range: '$150–$380', note: 'Parts + labor · OEM parts · 90-day warranty' },
  { appliance: 'Luxury Brand Repair', range: '$250–$600+', note: 'Sub-Zero, Wolf, Thermador, Miele · OEM parts' },
  { appliance: 'Warranty', range: '90 Days', note: 'All repairs · Parts & labor · No-charge callback', featured: true },
];

const faqs = [
  {
    question: 'Do you offer same-day appliance repair in Newbury Park?',
    answer: 'Yes — Newbury Park is part of our Thousand Oaks branch territory. Our technicians are in the Conejo Valley daily and cover Newbury Park on regular routes. Call before noon for same-day service in most cases.'
  },
  {
    question: 'What is your diagnostic fee in Newbury Park?',
    answer: 'Our diagnostic fee is $89. It covers the service call, full appliance inspection, and a written estimate with itemized parts and labor. If you proceed with the repair, the $89 is credited toward your invoice.'
  },
  {
    question: 'Does Cal-Am water hardness affect appliances in Newbury Park?',
    answer: 'Yes. Newbury Park is served by the same Cal-Am water system as Thousand Oaks — moderate-to-hard mineral content that affects dishwasher spray arms, refrigerator inlet valves, and ice maker components over time. We include a water line and filter check on every service call involving connected appliances. Catching a clogged inlet screen or overdue filter early prevents the more expensive pump or valve failure it can cause.'
  },
  {
    question: 'Do you repair Sub-Zero, Wolf, Miele, and Thermador in Newbury Park?',
    answer: 'Yes. Newbury Park homes, particularly in Lang Ranch and the hillside neighborhoods, commonly have Sub-Zero built-in refrigerators, Wolf ranges, Miele dishwashers, and Thermador ovens. Our Thousand Oaks technicians carry OEM parts for all of these brands and service them regularly in the Conejo Valley.'
  },
  {
    question: 'Is there a surcharge for service in Newbury Park vs Thousand Oaks?',
    answer: 'No. Newbury Park is part of our standard Thousand Oaks branch service area. Our $89 diagnostic fee is the same in Newbury Park as it is in Thousand Oaks or Westlake Village. No distance markup, no travel surcharge.'
  },
  {
    question: 'What brands do you service in Newbury Park?',
    answer: 'All major brands: Sub-Zero, Wolf, Thermador, Miele, Viking, Bosch, KitchenAid, Samsung, LG, GE, Whirlpool, Maytag, and Frigidaire. OEM parts for all of these on our Conejo Valley trucks.'
  },
  {
    question: 'Do you offer a warranty on repairs in Newbury Park?',
    answer: 'All repairs include a 90-day warranty on parts and labor. Same issue returns within 90 days — we come back and fix it at no charge.'
  },
];

const nearbyCities = [
  { name: 'Thousand Oaks', slug: 'thousand-oaks' },
  { name: 'Westlake Village', slug: 'westlake-village' },
  { name: 'Moorpark', slug: 'moorpark' },
  { name: 'Agoura Hills', slug: 'agoura-hills' },
  { name: 'Simi Valley', slug: 'simi-valley' },
  { name: 'Oak Park', slug: 'oak-park' },
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair in"
    headlineCity="Newbury Park, CA"
    subheadline="Same-day service — no surcharge vs Thousand Oaks. Sub-Zero, Wolf, Miele & all brands. Cal-Am water expertise. OEM parts, 90-day warranty."
    zips={zips}
    tier={3}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance Repair in Newbury Park — Same Service as Thousand Oaks, Same Price"
    paragraphs={introParagraphs}
    bookingTitle="Newbury Park Service"
    bookingSub="Available Today"
  />

  <ServicesGrid
    cityName={cityName}
    headline="Appliance Repair Services in Newbury Park"
    services={services}
  />

  <CustomNarrative
    headline={calAmWaterNarrative.headline}
    paragraphs={calAmWaterNarrative.paragraphs}
    background="white"
  />

  <ServiceArea
    cityName={cityName}
    headline="Newbury Park Areas We Service"
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={[]}
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Repairs in Newbury Park"
    jobs={recentJobs}
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="Why Newbury Park Residents Call Us"
    reasons={whyReasons}
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What Newbury Park Clients Say"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Repair Pricing in Newbury Park"
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="Frequently Asked Questions — Newbury Park"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby Conejo Valley Cities"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Schedule Your Newbury Park Repair Today"
    body="Same-day service from our Thousand Oaks branch. Sub-Zero, Wolf, Miele, and all major brands."
  />
</CityLayoutV2>
