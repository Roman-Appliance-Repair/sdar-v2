---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import CustomNarrative from '../components/cities/v2/CustomNarrative.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES, MAIN_PHONE, isPlaceholderPhone } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

const citySlug = 'corona';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = 'Corona';
const zips = ['92879', '92880', '92881', '92882', '92883'];

const phone = branch.phone;
const phoneRaw = `+1${phone.replace(/\D/g, '')}`;

const title = `Appliance Repair Corona CA — Same Day | All Brands`;
const description = `Same-day appliance repair in Corona CA. Sycamore Creek, Eagle Glen, Terramor, Dos Lagos. Licensed. OEM parts.`;
const canonical = 'https://samedayappliance.repair/corona/';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { '@type': 'City', name: 'Corona', sameAs: 'https://en.wikipedia.org/wiki/Corona,_California' },
    { '@type': 'PostalCode', postalCode: '92879' },
    { '@type': 'PostalCode', postalCode: '92880' },
    { '@type': 'PostalCode', postalCode: '92881' },
    { '@type': 'PostalCode', postalCode: '92882' },
    { '@type': 'PostalCode', postalCode: '92883' }
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$',
  license: 'BHGS #A49573'

};

const introParagraphs = [
  "Corona is one of the most varied cities we service in the Inland Empire. Drive through enough of it and you'll see what we mean: mid-century homes near Circle City and Lincoln Avenue with 20-year-old Whirlpool and GE appliances still running strong; planned communities like Sycamore Creek and Eagle Glen with mid-2010s Samsung and LG hitting their first major failures; and the newer luxury developments at Terramor and The Retreat where Sub-Zero columns and Wolf ranges are standard. Our technicians work across all three of these worlds in the same week.",
  "Corona's climate runs hot. The city sits at the junction of the Santa Ana Mountains and the Inland Valley, and summer heat in the 95–108°F range is routine. That load matters for appliances. Condenser coils on refrigerators and freezers clog faster with the fine dust that comes off the dry hillsides, especially during Santa Ana wind events. We see a predictable surge of refrigerator calls every June and July — appliances that were managing fine all spring finally push past their threshold when the heat arrives.",
  "Hard water is a consistent factor throughout Corona and the broader Riverside County corridor. Dishwasher filters clog faster, ice maker fill tubes scale up, and washing machine door gaskets accumulate mineral deposits that accelerate mold growth. We include descaling as part of every dishwasher and ice maker repair call in this market.",
  `We dispatch to Corona with same-day coverage across all five ZIP codes — 92879, 92880, 92881, 92882, 92883. Call <a href="tel:${phoneRaw}">${phone}</a>.`
];

const services = [
  { icon: '❄️', name: 'Refrigerator Repair', slug: 'refrigerator' },
  { icon: '🌀', name: 'Washer Repair', slug: 'washer' },
  { icon: '💨', name: 'Dryer Repair', slug: 'dryer' },
  { icon: '🔥', name: 'Oven & Range Repair', slug: 'oven' },
  { icon: '🫧', name: 'Dishwasher Repair', slug: 'dishwasher' },
  { icon: '🍳', name: 'Stove & Cooktop Repair', slug: 'cooktop' },
  { icon: '🧊', name: 'Freezer Repair', slug: 'freezer' },
  { icon: '🧊', name: 'Ice Maker Repair', slug: 'ice-maker' }
];

const housingStockNarrative = {
  headline: "Corona's Housing Stock — What's in Each Part of the City",
  paragraphs: [
    "Corona is unusual in the IE because it has genuine housing diversity — older stock, mid-range planned communities, and high-end new development all within the same city limits. The appliance profile varies significantly by neighborhood, and our technicians come prepared for what's actually there."
  ],
  subSections: [
    {
      title: 'Downtown & North Corona — Circle City, Lincoln Ave (92879, 92880)',
      paragraphs: [
        "Corona's original neighborhoods near the historic circle and Lincoln Avenue corridor are older stock — homes built 1950s through 1980s, with appliances ranging from 15 to 25 years old. This is Whirlpool, GE, Maytag, and Kenmore territory. These machines are mechanically straightforward — fewer control boards, more physical components — and they're often genuinely worth repairing even at advanced age. A 20-year-old Whirlpool top-loader with a worn drive coupling is a $120 repair, not a replacement. We tell you which way the math goes after diagnosis.",
        "Rental properties are common in this part of Corona. We work with landlords on priority scheduling and understand that a tenant without a working washer or refrigerator creates urgency. Tell us it's a rental when you call — we factor that in."
      ]
    },
    {
      title: 'Sycamore Creek, Eagle Glen & Green River — Mid-Range Planned (92882, 92883)',
      paragraphs: [
        "These master-planned communities were built primarily in the 1990s and 2000s, and the appliances installed in them are now 15–25 years into their lifespan — or have been replaced with mid-range Samsung, LG, and KitchenAid in the last decade. This is the most active repair window in Corona. LG French-door refrigerators with linear inverter compressor issues, Samsung ice maker failures, KitchenAid dishwasher drain errors, front-load washer bearing wear — these are the calls we make here constantly. We keep the most common OEM parts for this generation on the truck."
      ]
    },
    {
      title: 'Terramor, The Retreat & South Corona — Luxury New Development (92883)',
      paragraphs: [
        "South Corona's newer master-planned communities are bringing a different appliance profile to the city. Terramor in particular is a high-end development where Sub-Zero, Wolf, and Thermador are standard equipment. We service these exactly as we service our Beverly Hills and Bel Air calls — OEM parts only, careful handling, verified calibration after repair. The Terramor area also has elevated dust levels during the ongoing construction buildout, which means condenser coils on Sub-Zero units here need cleaning every 4–5 months rather than the standard 6."
      ]
    },
    {
      title: 'Dos Lagos & Corona Hills — Mixed Mid-Tier',
      paragraphs: [
        "The Dos Lagos area and the Corona Hills neighborhoods run a consistent mid-range appliance profile — Samsung, LG, Whirlpool, Bosch — mostly from the 2010s, now entering the 8–12 year failure window. Heat is a specific issue here. The Dos Lagos corridor sits in a bowl that traps heat in summer, and appliances in homes without good ventilation around them run hotter than they should. We find condenser coil loading that's proportionally heavier here than in better-ventilated parts of the city."
      ]
    },
    {
      title: 'Hard Water Across All of Corona',
      paragraphs: [
        "Riverside County water is consistently hard — dissolved calcium and magnesium levels that accelerate scale in dishwashers, ice makers, and washing machines. The maintenance schedule we recommend for Corona homes: dishwasher filter every 3 months, refrigerator water filter every 4 months, ice maker descale every 12–18 months. We include descaling in every dishwasher and ice maker repair call as standard — it's not an upsell, it's part of fixing the problem correctly."
      ]
    }
  ]
};

const neighborhoods = [
  { name: 'Sycamore Creek', zip: '92883', featured: true },
  { name: 'Eagle Glen', zip: '92883', featured: true },
  { name: 'Terramor', zip: '92883', featured: true },
  { name: 'The Retreat', zip: '92883' },
  { name: 'Dos Lagos', zip: '92882' },
  { name: 'Green River', zip: '92882' },
  { name: 'Corona Hills', zip: '92882' },
  { name: 'Montecito', zip: '92881' },
  { name: 'South Corona', zip: '92882' },
  { name: 'Sierra Del Oro', zip: '92882' },
  { name: 'Downtown / Circle City', zip: '92879' },
  { name: 'Lincoln Ave Corridor', zip: '92882' }
];

const recentJobs = [
  {
    appliance: 'Sub-Zero BI-48S',
    location: 'Terramor, 92883',
    quote: 'Not cooling in July, compressor running constantly',
    description: "48-inch Sub-Zero built-in, compressor running without stopping, fridge compartment at 58°F. First call of the summer season — same pattern we see every July in south Corona. Pulled the unit and found the condenser coils completely packed with fine particulate from the construction dust that's still heavy in the Terramor area as the community builds out. Cleaned the coils thoroughly, tested the compressor load — within normal range once the coils were clear. Also found the door gasket on the left door had a hairline crack at the bottom corner, allowing warm air infiltration. Replaced the gasket with an OEM Sub-Zero part. Unit holding 38°F within two hours. New construction neighborhoods like Terramor have elevated dust levels for years during buildout. Condenser cleaning every 4–5 months, not 6.",
    outcome: '✓ Same day · Coil cleaning + OEM Sub-Zero gasket · Holding 38°F'
  },
  {
    appliance: 'Whirlpool WTW5000DW Washer',
    location: 'Downtown Corona / Circle City, 92879',
    quote: "Won't agitate, spins fine, 2004 model",
    description: "22-year-old top-load Whirlpool, still structurally solid. No agitation but spin cycle works. Classic transmission mode shift failure — the dogs in the transmission that shift between agitate and spin mode had worn down. On a machine this old, a full transmission replacement doesn't make economic sense. But the shift actuator and transmission dogs were still available as OEM parts. Replaced the actuator assembly, confirmed full agitate function. $145 parts and labor on a machine that's been running since 2004. Owner had been ready to replace it — didn't need to. Old-stock Whirlpool top-loaders are often worth repairing. Mechanical components, no circuit boards to fail.",
    outcome: '✓ Same day · OEM shift actuator · $145 vs. new washer'
  },
  {
    appliance: 'LG LRMVS3006S',
    location: 'Eagle Glen, 92883',
    quote: 'Clicking on startup, not cooling, 2017 model',
    description: "2017 LG French-door, exactly the linear inverter compressor generation with documented start relay failures. Customer had been quoted $490 for a compressor replacement by another company without a proper diagnosis. We tested the start relay — open circuit failure confirmed. Replaced the relay ($18 part), confirmed normal compressor startup under ambient conditions, unit at 38°F within 45 minutes. Total cost: $89 diagnostic + $95 labor and parts. Saved the customer $300+ and a week of waiting for a compressor order. LG 2014–2019 French-door: always test the start relay before the compressor. Same symptoms, $18 vs. $450.",
    outcome: '✓ Same day · Start relay (not compressor) · $89 + $95'
  },
  {
    appliance: 'KitchenAid KDTM354DSS',
    location: 'Sycamore Creek, 92883',
    quote: 'Not cleaning top rack, E1 F9 error',
    description: "E1 F9 on KitchenAid dishwashers is a flood switch error, but in this case it was triggered by a slow drain — water backing up into the base pan. Root cause: the drain pump impeller was partially blocked with mineral scale from Riverside County hard water. The upper spray arm ports were also 60% blocked. Cleared the pump impeller, descaled the spray arms, cleaned the filter assembly, reset the flood switch. Running clean on full cycles. We put the customer on a 3-month filter cleaning schedule — the hard water here is hard enough that annual maintenance isn't sufficient. E1 F9 is often a hard water maintenance issue, not a component failure. Diagnose before replacing the pump.",
    outcome: '✓ Same day · Hard water descale · 3-month plan'
  }
];

const whyReasons = [
  {
    iconKey: 'team' as const,
    title: 'We cover all of Corona — old and new',
    body: "From a 1975 Whirlpool in Circle City to a Sub-Zero in Terramor, we service every generation of appliance in this city. We don't specialize in only new or only old — we come prepared for whatever's actually in your home."
  },
  {
    iconKey: 'shield' as const,
    title: 'Diagnosis before the quote',
    body: "The $89 diagnostic fee means we look at the appliance before recommending anything. An LG refrigerator clicking could be an $18 relay or a $450 compressor. We find out which before quoting. What we quote is what appears on the invoice — transparent pricing."
  },
  {
    iconKey: 'parts' as const,
    title: 'Honest repair vs. replace guidance',
    body: "A 22-year-old washer with a worn coupling is often worth repairing. A 16-year-old refrigerator with a failing compressor might not be. We give you the real economics after diagnosis and let you decide. We don't push repairs that don't make financial sense."
  },
  {
    iconKey: 'clock' as const,
    title: 'OEM parts, not aftermarket',
    body: "In a hot climate with hard water, appliances are already working harder than they should be. Using the correct OEM parts matters more here than in milder markets. We don't use aftermarket parts — they fail faster and can void warranties on newer units."
  }
];

const testimonials = [
  {
    stars: 5,
    text: '"Sub-Zero stopped cooling in July and I was convinced we needed a major repair. Tech came out, cleaned the condenser coils — packed with dust from the Terramor construction — and replaced a door gasket. Done in two hours. Much less than I expected."',
    author: '— Katherine B., Terramor'
  },
  {
    stars: 5,
    text: '"Old Whirlpool washer in our rental property near Lincoln Ave stopped agitating. They came same day, diagnosed a transmission actuator, fixed it for $145. Tenant was happy and I didn\'t have to buy a new machine. Very fair and professional."',
    author: '— James O., North Corona landlord'
  },
  {
    stars: 5,
    text: '"KitchenAid dishwasher was showing an error code and another company said I needed a new pump. Same Day diagnosed it as a hard water blockage, cleaned everything out, and it\'s been running perfectly. Saved me $250 and a lot of hassle."',
    author: '— Rachel & Mike T., Sycamore Creek'
  }
];

const pricingTiers = [
  { appliance: 'Refrigerator Repair', range: '$150–$450', note: 'Coil cleaning · Door gasket · Inlet valve · Fan motor' },
  { appliance: 'Washer Repair', range: '$140–$380', note: 'Drum · Drain pump · Transmission actuator · Door boot' },
  { appliance: 'Dryer Repair', range: '$120–$320', note: 'Thermal fuse · Vent cleaning · Element · Belt' },
  { appliance: 'Dishwasher Repair', range: '$89–$360', note: 'Hard water descale · E1 F9 · Spray arm · Pump' },
  { appliance: 'Oven / Range', range: '$140–$400', note: 'Igniter · Element · Temperature calibration' },
  { appliance: 'Sub-Zero', range: '$250–$650', note: 'OEM parts · Built-in column · Estate handling', featured: true },
  { appliance: 'Ice Maker Repair', range: '$120–$280', note: 'Inlet valve · Mold descale · Solenoid' },
  { appliance: 'Condenser Coil Cleaning', range: '$89–$150', note: 'Standalone service · Pre-summer · Construction dust' }
];

const faqs = [
  {
    question: 'Do you offer same-day appliance repair in Corona?',
    answer: `Yes — same-day service is available throughout Corona including Sycamore Creek, Eagle Glen, Terramor, Dos Lagos, South Corona, and Downtown. Call ${phone} before noon for same-day availability. We cover all five Corona ZIP codes — 92879, 92880, 92881, 92882, and 92883 — without a trip surcharge.`
  },
  {
    question: "My refrigerator runs fine in winter but struggles every summer — what's happening?",
    answer: "This is one of the most predictable patterns we see in Corona. When ambient temperature hits 100–108°F in July and August, refrigerators that were managing fine in cooler months get pushed past their threshold. The two most common causes: condenser coils that are partially loaded with dust (common in Corona's dry, dusty summers) and a start relay or condenser fan motor that was already weakening. We clean and test both on every summer refrigerator call. In Corona's climate, condenser coils should be cleaned every 6 months — not once a year."
  },
  {
    question: 'What brands do you repair in Corona?',
    answer: "All of them. Downtown and older Corona neighborhoods have Whirlpool, GE, and Maytag workhorses that have been running for 15–20 years. The mid-range planned communities like Sycamore Creek and Eagle Glen run Samsung, LG, and KitchenAid from the 2010s. Terramor and The Retreat have Sub-Zero, Wolf, and Thermador as standard. We carry OEM parts for all of these and don't use aftermarket substitutes."
  },
  {
    question: 'What is your diagnostic fee?',
    answer: "$89 for residential, applied directly to the repair when you proceed. No hidden trip charge to any Corona ZIP code. We quote on-site after diagnosis — not over the phone based on symptoms. What we quote is what appears on the invoice."
  },
  {
    question: 'Is it worth repairing an older appliance in Downtown or North Corona?',
    answer: "Usually yes, if the core mechanical components are sound. A 20-year-old Whirlpool washer with a worn drive coupling or a GE refrigerator with a failing defrost heater are both worth repairing if the motor and compressor are healthy. The exception: compressor failures on refrigerators over 15 years old, where repair cost versus replacement value stops making sense. We give you the honest numbers after diagnosis."
  },
  {
    question: 'My Samsung washer shows an error code and won\'t start — do you repair that?',
    answer: "Yes. Samsung error codes on the newer front-load and top-load models are usually pointing to specific component failures — door latch, water inlet valve, drain pump, or control board. We diagnose the actual cause before recommending parts. In most cases the error code identifies the symptom, not the root cause — and the root cause is cheaper to fix than the part the code points to."
  },
  {
    question: 'Do you service appliances in Eastvale and Norco near Corona?',
    answer: `Yes — we service Eastvale and Norco as part of our Corona area coverage. Call ${phone} for availability. No surcharge for these areas.`
  }
];

const nearbyCities = [
  { name: 'Riverside', slug: 'riverside' },
  { name: 'Rancho Cucamonga', slug: 'rancho-cucamonga' },
  { name: 'Chino Hills', slug: 'chino-hills' },
  { name: 'Murrieta', slug: 'murrieta' },
  { name: 'Menifee', slug: 'menifee' },
  { name: 'Upland', slug: 'upland' }
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair"
    headlineCity="Corona, CA"
    subheadline="Same-day service in Sycamore Creek, Eagle Glen, Terramor, Dos Lagos, South Corona, and throughout the city. All appliances, all brands, OEM parts. Licensed."
    zips={zips}
    tier={2}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance Repair in Corona — Three Generations of Housing, One Service Area"
    paragraphs={introParagraphs}
    bookingTitle="Corona Service"
    bookingSub="92879 · 92880 · 92881 · 92882 · 92883 · Same-day"
  />

  <ServicesGrid
    cityName={cityName}
    headline="What We Repair in Corona"
    services={services}
  />

  <CustomNarrative
    headline={housingStockNarrative.headline}
    paragraphs={housingStockNarrative.paragraphs}
    subSections={housingStockNarrative.subSections}
    background="white"
  />

  <ServiceArea
    cityName={cityName}
    headline="Neighborhoods We Service in Corona"
    subheadline="Also serving Norco and Eastvale — same dispatch, no surcharge."
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={[]}
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Repairs in Corona"
    jobs={recentJobs}
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="Why Corona Residents Call Us"
    reasons={whyReasons}
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What Corona Clients Say"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Typical Repair Pricing in Corona"
    subhead="$89 diagnostic applied to repair. No trip charge to any Corona ZIP code."
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="Corona Appliance Repair — FAQ"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby Cities"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Need Appliance Repair in Corona Today?"
    body="Same-day service across Sycamore Creek, Eagle Glen, Terramor, Dos Lagos, South Corona, Downtown, and all Corona ZIP codes."
  />
</CityLayoutV2>
