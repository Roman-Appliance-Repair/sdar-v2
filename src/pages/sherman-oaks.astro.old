  .why-card { background: var(--so-gray); border-radius: 12px; padding: 28px 24px; }
  .why-icon { font-size: 28px; margin-bottom: 14px; }
  .why-title { font-size: 16px; font-weight: 600; color: var(--so-black); margin-bottom: 10px; }
  .why-text { font-size: 14px; color: var(--so-muted); line-height: 1.6; }
  .so-reviews { padding: 72px 0; background: var(--so-gray); }
  .so-reviews h2 { font-size: 30px; font-weight: 700; color: var(--so-black); margin-bottom: 40px; text-align: center; }
