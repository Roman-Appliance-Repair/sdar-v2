---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

const citySlug = 'toluca-lake';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = "Toluca Lake";
const zips = ['91602'];

const phoneRaw = `+1${branch.phone.replace(/\D/g, '')}`;

const title = `Appliance Repair Toluca Lake CA | Same Day Service`;
const description = "Same-day appliance repair in Toluca Lake, CA. Sub-Zero, Wolf, Viking, Miele specialists. $89 dx — waived with repair.";
const canonical = 'https://samedayappliance.repair/toluca-lake/';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { '@type': 'Place', name: 'Toluca Lake' },
    { '@type': 'Place', name: 'Toluca Estates' },
    { '@type': 'Place', name: 'Toluca Woods' },
    { '@type': 'Place', name: 'Riverside Drive corridor' }
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$$',
  license: 'BHGS #A49573'

};

const introParagraphs = [
  "Toluca Lake is a 10,000-resident affluent enclave tucked into the southeast corner of the San Fernando Valley between North Hollywood, Burbank, and Studio City. The area takes its name from the actual Toluca Lake — a private residential lake at the heart of Toluca Estates, surrounded by the most expensive homes in the neighborhood. The broader Toluca Lake area extends from the lake outward through Toluca Woods to the south and the Riverside Drive corridor to the north toward the Burbank border.",
  "The housing stock is predominantly 1940s-50s mid-century single-family with substantial 2014-2018 renovation activity driven by the entertainment-industry buyer pool — this neighborhood sits within walking distance of Disney, Warner Brothers, NBCUniversal, and CBS Studio Center. The renovated kitchens concentrate Wolf, Sub-Zero, Viking, Thermador, and Miele installs, with the typical luxury-tier service intervals now hitting the 7-12 year mark on those mid-2010s remodels. Toluca Woods and the Riverside Drive corridor run more mainstream-premium with KitchenAid, GE Profile, Bosch, Samsung, and LG common in less-recently-renovated homes.",
  `Our Pasadena branch covers Toluca Lake on the regular southeastern Valley route alongside Burbank, Studio City, Sherman Oaks, and Glendale. Same $89 residential diagnostic, no distance surcharge between any of these neighborhoods. Call <a href="tel:${phoneRaw}">${branch.phone}</a>.`
];

const services = [
  { icon: '❄️', name: 'Refrigerator Repair', slug: 'refrigerator' },
  { icon: '🫧', name: 'Washer Repair', slug: 'washer' },
  { icon: '💨', name: 'Dryer Repair', slug: 'dryer' },
  { icon: '🍽️', name: 'Dishwasher Repair', slug: 'dishwasher' },
  { icon: '🔥', name: 'Oven & Range Repair', slug: 'oven' },
  { icon: '🍳', name: 'Stove Repair', slug: 'stove' },
  { icon: '📻', name: 'Microwave Repair', slug: 'microwave' },
  { icon: '🧊', name: 'Ice Maker Repair', slug: 'ice-maker' },
  { icon: '🍷', name: 'Wine Cooler Repair', slug: 'wine-cooler' },
  { icon: '🧊', name: 'Freezer Repair', slug: 'freezer' },
  { icon: '🗑️', name: 'Garbage Disposal Repair', slug: 'garbage-disposal' },
  { icon: '♨️', name: 'Cooktop Repair', slug: 'cooktop' }
];

const neighborhoods = [
  { name: 'Toluca Lake (proper)', zip: '91602' },
  { name: 'Toluca Estates', zip: '91602' },
  { name: 'Toluca Woods', zip: '91602' },
  { name: 'Lakeside (Toluca Lake adjacent)', zip: '91602' },
  { name: 'Riverside Drive corridor', zip: '91602' },
  { name: 'Cahuenga Pass adjacent', zip: '91602' }
];

const recentJobs = [
  {
    appliance: "Wolf 36\" dual-fuel range",
    location: 'Toluca Estates',
    quote: "Wolf 36\" dual-fuel range — Toluca Estates 1940s home, oven temp drift",
    description: "Wolf DF364G dual-fuel range in a Toluca Estates 1940s home off Forman Avenue — homeowner reported the oven was running 30°F low at 350°F set point but accurate at 425°F. Temperature sensor (RTD) had drifted at the lower end of its range, a known Wolf RTD failure pattern at the 7-9 year mark. Replaced with OEM Wolf RTD probe, recalibrated the control board through the service menu, ran three test bakes at 325°F / 350°F / 425°F. Toluca Estates concentrates Wolf, Sub-Zero, and Viking installs in renovated kitchens — many of these renovations happened during the 2014-2018 entertainment-industry housing boom and we see the 7-9 year service intervals hitting now.",
    outcome: '✓ Same day · Wolf OEM RTD oven temperature sensor · 1.5 hours'
  },
  {
    appliance: 'Sub-Zero 736TR',
    location: 'Toluca Woods',
    quote: "Sub-Zero 736TR — Toluca Woods home, ice maker not making ice",
    description: "Sub-Zero 736TR side-by-side built-in in a Toluca Woods home off Riverside Drive — refrigerator + freezer temps fine, but ice maker hadn't produced ice in two weeks. Ice maker module's mold thermostat had failed (visible burn mark on the bimetal). Replaced the mold thermostat, manually triggered three harvest cycles to verify, set up a 24-hour production check. Sub-Zero ice maker module failures cluster at the 8-12 year mark — common enough that we stock the module assemblies on the Pasadena truck. Toluca Woods has a high concentration of Sub-Zero installs from the early 2010s remodel wave; they're hitting the module-replacement window now.",
    outcome: '✓ Same day · Sub-Zero OEM ice maker mold thermostat · 1.5 hours'
  },
  {
    appliance: 'Miele washer + dryer column',
    location: 'Riverside Drive corridor',
    quote: "Miele washer + dryer column — Riverside Drive corridor home, dryer F-code",
    description: "Miele W1/T1 stacked column in a 1950s home renovation off Riverside Drive — dryer half throwing F70 fault (lint filter overheat protection triggered repeatedly). Lint filter housing was clean; the fault was downstream — the exhaust ducting from the dryer to the wall had a partial blockage at the elbow. Cleared the duct, vacuumed the housing, ran a 60-minute test cycle at high heat. Confirmed temps stayed well within spec. Older Toluca Lake homes off Riverside Drive frequently have laundry rooms with original ductwork that wasn't designed for modern high-airflow dryers — we recommend annual duct inspection on Miele installs in these homes.",
    outcome: '✓ Same day · Duct clearing service + test cycle · 1.5 hours'
  }
];

const pricingTiers = [
  { appliance: 'Residential Diagnostic', range: '$89', note: 'No distance surcharge · Credited toward repair · Written estimate' },
  { appliance: 'Standard Repair Range', range: '$150–$350', note: 'Parts + labor · OEM parts · 90-day warranty' },
  { appliance: 'Luxury Brand Repair', range: '$250–$600+', note: 'Sub-Zero, Wolf, Viking, Thermador, Miele · OEM parts', featured: true },
  { appliance: '90-Day Warranty', range: 'All Repairs', note: 'Parts + labor · Same-issue return at no charge' }
];

const faqs = [
  {
    question: "Do you service Toluca Lake? It's a small neighborhood between NoHo and Burbank.",
    answer: `Yes. Our Pasadena branch runs Toluca Lake on the regular San Fernando Valley + Burbank-area route. The ${branch.phone} number reaches dispatch with our actual schedule. Coverage spans Toluca Lake proper around the Toluca Lake itself, Toluca Estates, Toluca Woods, the Riverside Drive corridor, and the Cahuenga Pass-adjacent stretch. Same-day service available when you call before noon.`
  },
  {
    question: 'What appliance brands are most common in Toluca Lake homes?',
    answer: "Wolf, Sub-Zero, Viking, Miele, and Thermador are common across Toluca Estates and Toluca Lake proper — the renovated 1940s-50s housing stock concentrated luxury kitchen installs during the 2014-2018 entertainment-industry remodel wave. Mainstream-premium brands (KitchenAid, GE Profile, Bosch, Samsung, LG) appear in Toluca Woods and the broader Riverside Drive corridor. We carry OEM parts for both luxury and mainstream on the Pasadena truck."
  },
  {
    question: 'Toluca Lake is a small neighborhood — do you have technicians who know it specifically?',
    answer: "Yes. Our Pasadena branch covers Burbank, Glendale, Studio City, Sherman Oaks, Toluca Lake, and the broader San Fernando Valley regularly. The Toluca Lake routes overlap heavily with our Burbank and Studio City scheduling — the techs working these areas know the entertainment-industry housing context, the renovated mid-century footprints, and the typical luxury appliance install patterns in this part of the Valley."
  },
  {
    question: 'Do you charge a distance surcharge for Toluca Lake?',
    answer: "No. Toluca Lake is on our regular Pasadena branch route covering the southeastern San Fernando Valley. The $89 residential diagnostic is the same in Toluca Lake as it is in Burbank, Studio City, or Pasadena. What we quote is what you pay."
  },
  {
    question: 'What is your warranty on Toluca Lake repairs?',
    answer: "All repairs carry a 90-day warranty on parts and labor. If the same issue returns within that window, we come back at no additional charge. BHGS #A49573 + BBB accredited."
  }
];

const nearbyCities = [
  { name: 'Burbank', slug: 'burbank' },
  { name: 'Studio City', slug: 'studio-city' },
  { name: 'North Hollywood', slug: 'north-hollywood' },
  { name: 'Sherman Oaks', slug: 'sherman-oaks' },
  { name: 'Glendale', slug: 'glendale' },
  { name: 'Pasadena', slug: 'pasadena' }
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair in"
    headlineCity="Toluca Lake, CA"
    subheadline="Same-day service across Toluca Lake proper, Toluca Estates, Toluca Woods, and the Riverside Drive corridor. Sub-Zero, Wolf, Viking, Miele specialists. $89 diagnostic — waived with repair."
    zips={zips}
    tier={3}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Toluca Lake — small enclave between NoHo and Burbank"
    paragraphs={introParagraphs}
    bookingTitle="Toluca Lake Service"
    bookingSub="Available Today"
  />

  <ServicesGrid
    cityName={cityName}
    headline="Appliance Repair Services in Toluca Lake"
    services={services}
  />

  <ServiceArea
    cityName={cityName}
    headline="Toluca Lake Areas We Service"
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={[]}
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Repairs in Toluca Lake"
    jobs={recentJobs}
  />

  <PricingCards
    cityName={cityName}
    headline="Repair Pricing in Toluca Lake"
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="Frequently Asked Questions — Toluca Lake"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby San Fernando Valley Areas"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Schedule Your Toluca Lake Repair Today"
    body="Same-day service across Toluca Lake. Toluca proper, Toluca Estates, Toluca Woods, Riverside Drive corridor. No distance surcharge."
  />
</CityLayoutV2>
