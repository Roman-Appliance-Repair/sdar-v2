---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import CustomNarrative from '../components/cities/v2/CustomNarrative.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

const citySlug = 'san-clemente';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = 'San Clemente';
const zips = ['92624', '92672', '92673'];

const phoneRaw = `+1${branch.phone.replace(/\D/g, '')}`;

const title = `Appliance Repair San Clemente CA | Same Day Service | ${branch.phone}`;
const description = "Same-day appliance repair in San Clemente, CA. T-Street, Cotton's Point, Talega. Salt air coastal expertise. Sub-Zero, Wolf & all brands. OEM parts, 90-day warranty. $89 diagnostic.";
const canonical = 'https://samedayappliance.repair/san-clemente/';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { '@type': 'City', name: 'San Clemente', sameAs: 'https://en.wikipedia.org/wiki/San_Clemente,_California' },
    { '@type': 'Place', name: 'Talega' },
    { '@type': 'Place', name: "Cotton's Point" },
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$',
  license: 'CA CSLB #1138898',
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.6',
    reviewCount: '37',
    bestRating: '5',
  },
};

const introParagraphs = [
  "San Clemente is the southernmost city in Orange County — a real surf town with a distinct character, Spanish colonial architecture, and a coastline that faces directly into the Pacific. It's also one of the most demanding environments for appliances in all of Southern California.",
  "The salt air that comes off the water at T-Street, Cotton's Point, and Capo Beach is just as aggressive as anything we see in Newport Beach or Dana Point — arguably more so at the most exposed properties. Condenser coils on refrigerators pack with salt particulate. Samsung ice makers freeze over from coastal humidity. Wolf range igniters corrode from the Pacific wind. These are real patterns we see on every coastal San Clemente service call.",
  "Talega and the inland neighborhoods have different conditions — hard water is the more relevant concern there, not salt air. We adjust our inspection approach based on where in San Clemente the property is.",
  `Diagnostic fee is $89, credited toward the repair. Call <a href="tel:${phoneRaw}">${branch.phone}</a>.`,
];

// Source-bug fix #2 (catalog): position 8 services array had duplicate Dishwasher Repair → replaced with Cooktop Repair.
const services = [
  { icon: '❄️', name: 'Refrigerator Repair', slug: 'refrigerator' },
  { icon: '🫧', name: 'Washer Repair', slug: 'washer' },
  { icon: '💨', name: 'Dryer Repair', slug: 'dryer' },
  { icon: '🍽️', name: 'Dishwasher Repair', slug: 'dishwasher' },
  { icon: '🔥', name: 'Oven & Range Repair', slug: 'oven' },
  { icon: '🍷', name: 'Wine Cooler Repair', slug: 'wine-cooler' },
  { icon: '🧊', name: 'Ice Maker Repair', slug: 'ice-maker' },
  { icon: '♨️', name: 'Cooktop Repair', slug: 'cooktop' },
];

const coastalNarrative = {
  headline: 'Coastal vs Inland San Clemente — Different Conditions, Different Priorities',
  subSections: [
    {
      title: 'The beach corridor: T-Street, Cotton’s Point, Capo Beach',
      paragraphs: [
        "The western side of San Clemente — the neighborhoods that sit on the bluffs and slopes above the Pacific — faces the most aggressive salt air environment in all of Orange County. Cotton's Point properties are exposed to direct ocean wind year-round. The condenser coil fouling rate in these homes is exceptional: what takes 12 months to accumulate in Irvine accumulates in 4-6 months here. Sub-Zero units within a few hundred feet of the water need semi-annual coil service. Samsung refrigerators develop the coastal ice maker freeze-out pattern faster here than anywhere else we service.",
        "Wolf and Viking range igniters in hillside homes with ocean exposure corrode in 12-18 months versus 3-5 years inland. Annual electrode inspection is the right cycle for these properties.",
      ],
    },
    {
      title: 'Talega and inland San Clemente',
      paragraphs: [
        "Talega and the newer inland developments are far enough from the ocean that salt air is a secondary concern. Hard water and general maintenance are the primary issues — similar to what we see in Mission Viejo. The water hardness in inland San Clemente is moderate; dishwasher spray arms and refrigerator filters need periodic attention but not at the coastal frequency.",
      ],
    },
    {
      title: 'Vacation rentals and second homes',
      paragraphs: [
        "San Clemente's surf culture draws renters year-round. Beach-adjacent properties managed as short-term rentals or vacation homes have appliances that see more use and less maintenance attention. We work with property managers and can prioritize calls when a rental needs to be ready for the next guest.",
      ],
    },
  ],
};

const neighborhoods = [
  { name: 'T-Street / Beach area', zip: '92672' },
  { name: "Cotton's Point area", zip: '92624' },
  { name: 'Talega', zip: '92673' },
  { name: 'Rancho San Clemente', zip: '92673' },
  { name: 'Marblehead area', zip: '92673' },
  { name: 'San Clemente Hills', zip: '92672' },
  { name: 'Southwest San Clemente', zip: '92672' },
  { name: 'Downtown / Avenida Del Mar', zip: '92672' },
  { name: 'Forster Ranch', zip: '92673' },
  { name: 'Capo Beach', zip: '92624' },
];

const recentJobs = [
  {
    appliance: 'Samsung Refrigerator',
    location: 'T-Street area',
    quote: 'Samsung refrigerator — ice maker completely frozen over, no ice production',
    description: "Samsung RF28HFEDBSR — ice maker cavity completely iced over, no production for two weeks. Classic Samsung coastal failure: the ice maker draws humid Pacific air into the cavity through the ice dispenser chute, moisture freezes around the evaporator coil inside the unit and eventually blocks the mechanism entirely. Defrosted the cavity, replaced the ice maker assembly with an OEM Samsung part, installed a duct cover kit to reduce humidity ingress. Coastal San Clemente homes see this faster than inland OC — the marine air makes the humidity problem chronic.",
    outcome: '✓ Same day · Samsung OEM ice maker assembly + duct cover kit · 2 hours',
  },
  {
    appliance: 'Sub-Zero Refrigerator',
    location: "Cotton's Point area",
    quote: 'Sub-Zero built-in refrigerator — not cooling, condenser alarm',
    description: "Sub-Zero 650 in an ocean-view Cotton's Point home — unit triggering condenser alarm, interior temperature rising. Condenser coils completely fouled with salt particulate — this home is within 200 feet of the water, the most aggressive exposure in all of South OC. After coil cleaning, we found the condenser fan motor bearing was also worn from the corrosive environment. Replaced the motor and cleaned the coils. Recommended a 4-month coil inspection cycle for this specific property — the ocean proximity is exceptional.",
    outcome: '✓ Same day · Sub-Zero OEM condenser fan motor + coil cleaning · 2 hours',
  },
  {
    appliance: 'Bosch Dishwasher',
    location: 'Talega',
    quote: 'Bosch dishwasher — E09 heating fault, dishes coming out cold',
    description: "Bosch SHPM88Z75N in Talega — E09 error, heating element failed. Replaced with OEM Bosch element, tested wash and dry cycles. Also descaled the spray arms — mineral deposits building up at the Talega water hardness level. Talega is inland enough that salt air isn't the primary concern, but the water hardness is. Left the homeowner with a quarterly filter cleaning schedule.",
    outcome: '✓ Same day · Bosch OEM heating element + descale service · 1.5 hours',
  },
  {
    appliance: 'Wolf Range',
    location: 'San Clemente Hills',
    quote: 'Wolf range — rear burners failing to ignite, clicking continuously',
    description: 'Wolf 36-inch gas range in a hillside home with ocean views — rear two burners clicking 20+ times before lighting, then continuing to click. Igniter electrodes corroded from salt air exposure. San Clemente hills homes face direct Pacific wind exposure; the igniter corrosion rate here is comparable to what we see in the most exposed Newport Beach properties. Replaced both rear electrodes with OEM Wolf parts, applied dielectric grease, tested all six burners. Recommended annual electrode inspection.',
    outcome: '✓ Same day · Wolf OEM igniter electrodes x2 · 1.5 hours',
  },
];

const whyReasons = [
  {
    iconKey: 'parts' as const,
    title: 'We know coastal failure patterns',
    body: 'Samsung ice maker freeze-out, Sub-Zero condenser fouling, Wolf igniter corrosion — these are specific, predictable failure modes in coastal San Clemente. We come prepared and resolve most calls same visit.',
  },
  {
    iconKey: 'clock' as const,
    title: 'Vacation rental priority',
    body: "Beach rentals don't have flexibility when a guest arrives Friday. We work with San Clemente property managers on short-notice repairs and tell you honestly what's possible on the timeline.",
  },
  {
    iconKey: 'team' as const,
    title: 'Location-specific maintenance',
    body: "Cotton's Point needs a 4-month coil cycle. Talega needs annual. We give you a maintenance recommendation based on where in San Clemente you actually are.",
  },
  {
    iconKey: 'shield' as const,
    title: '90-day warranty',
    body: 'Every repair carries a 90-day warranty on parts and labor. Same issue returns — we come back at no charge.',
  },
];

const testimonials = [
  {
    stars: 5,
    text: '"Sub-Zero at Cotton’s Point failing — condenser completely packed with salt residue. Same Day cleaned it, replaced the fan motor, told me this needs service every 4 months given the location. Nobody had ever told me that. Extremely professional."',
    author: "— James P., Cotton's Point",
  },
  {
    stars: 5,
    text: '"Samsung ice maker frozen over — they explained the coastal humidity issue, fixed it same day, installed the duct cover kit. Our vacation rental was back up by Friday. This team understands the beach property situation."',
    author: '— Property Manager, T-Street area',
  },
  {
    stars: 5,
    text: '"Bosch dishwasher E09 in Talega. Fast, professional, fixed same day. They mentioned the water hardness and descaled the spray arms while there. Thorough service."',
    author: '— Maria K., Talega',
  },
];

const pricingTiers = [
  { appliance: 'Diagnostic Fee', range: '$89', note: 'Credited toward repair · Written estimate · Coastal assessment included' },
  { appliance: 'Standard Repair', range: '$150–$380', note: 'Parts + labor · OEM parts · 90-day warranty' },
  { appliance: 'Luxury Brand Repair', range: '$250–$600+', note: 'Sub-Zero, Wolf, Thermador, Viking · OEM parts' },
  { appliance: 'Warranty', range: '90 Days', note: 'All repairs · Parts & labor · No-charge callback', featured: true },
];

const faqs = [
  {
    question: 'Do you offer same-day appliance repair in San Clemente?',
    answer: "Yes — San Clemente is the southern anchor of our Orange County service area. We cover all San Clemente neighborhoods including T-Street, Cotton’s Point, Talega, Rancho San Clemente, and Capo Beach. Call before noon for same-day service.",
  },
  {
    question: 'Does living near the ocean in San Clemente affect appliances?',
    answer: "Significantly. San Clemente sits directly on the Pacific, and the marine air affects appliances much like it does in Newport Beach and Dana Point. Condenser coils on refrigerators accumulate salt particulate faster than inland. Wolf and Viking range igniter electrodes corrode faster. Samsung ice makers freeze up faster due to humidity ingress. Properties within a quarter mile of the water — especially the T-Street and Cotton’s Point areas — see the most accelerated wear.",
  },
  {
    question: 'What is your diagnostic fee in San Clemente?',
    answer: 'Our diagnostic fee is $89. It covers the service call, full appliance inspection, and a written estimate. If you proceed with the repair, the $89 is credited toward your invoice.',
  },
  {
    question: 'Do you service vacation rentals in San Clemente?',
    answer: "Yes. San Clemente’s surf destination character means a significant share of the housing near the beach is used as vacation rentals or second homes. We work with property managers and rental owners on short-notice repairs. Call us and tell us the situation — we’ll tell you what we can do and when.",
  },
  {
    question: 'What brands do you repair in San Clemente?',
    answer: "All major brands: Samsung, LG, GE, Whirlpool, KitchenAid, Bosch, Maytag, and luxury brands including Sub-Zero, Wolf, Thermador, Miele, and Viking. The ocean-view homes in the hills and Cotton’s Point tend toward luxury brands. Talega and the inland neighborhoods have a broader mix. We carry OEM parts for both.",
  },
  {
    question: 'How often should I have my refrigerator coils cleaned in San Clemente?',
    answer: "For homes within a quarter mile of the water — T-Street, Cotton’s Point, Capo Beach — we recommend every 4-6 months. For inland San Clemente neighborhoods like Talega and Rancho San Clemente, every 6-12 months depending on the specific location and whether you have pets.",
  },
  {
    question: 'Do you offer a warranty on repairs in San Clemente?',
    answer: 'All repairs include a 90-day warranty on parts and labor. Same issue returns within 90 days — we come back at no charge.',
  },
];

// Audit fix: /san-juan-capistrano/ + /capistrano-beach/ are broken (no .astro). Replaced with /laguna-beach/ + /mission-viejo/.
const nearbyCities = [
  { name: 'Dana Point', slug: 'dana-point' },
  { name: 'Laguna Niguel', slug: 'laguna-niguel' },
  { name: 'Mission Viejo', slug: 'mission-viejo' },
  { name: 'Laguna Beach', slug: 'laguna-beach' },
  { name: 'Irvine', slug: 'irvine' },
  { name: 'Newport Beach', slug: 'newport-beach' },
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair in"
    headlineCity="San Clemente, CA"
    subheadline="Same-day service from T-Street to Talega. Salt air coastal expertise. Sub-Zero, Wolf, Samsung & all brands. 90-day warranty. $89 diagnostic — waived with repair."
    zips={zips}
    tier={3}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance Repair at the End of the OC Coast"
    paragraphs={introParagraphs}
    bookingTitle="San Clemente Service"
    bookingSub="Available Today"
  />

  <ServicesGrid
    cityName={cityName}
    headline="Appliance Repair Services in San Clemente"
    services={services}
  />

  <CustomNarrative
    headline={coastalNarrative.headline}
    subSections={coastalNarrative.subSections}
    background="white"
  />

  <ServiceArea
    cityName={cityName}
    headline="San Clemente Neighborhoods We Service"
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={[]}
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Repairs in San Clemente"
    jobs={recentJobs}
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="Why San Clemente Homeowners Call Us"
    reasons={whyReasons}
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What San Clemente Clients Say"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Repair Pricing in San Clemente"
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="Frequently Asked Questions — San Clemente"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby South OC Cities"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Schedule Your San Clemente Repair Today"
    body="Same-day service from T-Street to Talega. Coastal expertise, honest pricing."
  />
</CityLayoutV2>
