---
// src/pages/outdoor/patio-heater-repair.astro
// 5-niche architecture — Patio heater repair (PRIORITY: 400 vol KD 0).
import Layout from '../../layouts/Layout.astro';
import ServiceHero from '../../components/ServiceHero.astro';
import { MAIN_PHONE } from '../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;

const title = "Patio Heater Repair Los Angeles — Bromic · Infratech · Schwank | Same Day Appliance Repair";
const description = `Patio heater repair across LA, Orange, Ventura, San Bernardino & Riverside counties. Bromic, Infratech, Schwank, Fire Sense, AZ Patio Heaters. Mounted electric infrared and freestanding propane. Heating element, igniter, regulator, thermostat. Quote-based. Call ${phone}.`;
const canonical = "https://samedayappliance.repair/outdoor/patio-heater-repair/";

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Patio Heater Repair",
  "name": "Patio Heater Repair — Same Day Appliance Repair",
  "url": canonical,
  "description": "Patio heater repair across all five SoCal counties. Mounted electric infrared and freestanding propane units. Bromic, Infratech, Schwank, Fire Sense, AZ Patio Heaters, Calcana.",
  "provider": { "@type": "LocalBusiness", "name": "Same Day Appliance Repair", "url": "https://samedayappliance.repair/", "telephone": phone, "priceRange": "$$" },
  "areaServed": [
    { "@type": "AdministrativeArea", "name": "Los Angeles County" },
    { "@type": "AdministrativeArea", "name": "Orange County" },
    { "@type": "AdministrativeArea", "name": "Ventura County" },
    { "@type": "AdministrativeArea", "name": "San Bernardino County" },
    { "@type": "AdministrativeArea", "name": "Riverside County" },
  ],
};
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <ServiceHero
    eyebrow="LA · Orange · Ventura · San Bernardino · Riverside Counties"
    title="Patio Heater Repair Across Southern California"
    subtitle="Mounted electric infrared and freestanding propane units. Bromic, Infratech, Schwank, Fire Sense, AZ Patio Heaters, Calcana. Heating element, igniter, regulator, thermostat service. Quote-based pricing across five SoCal counties."
    heroImageTitle="Patio Heater Repair"
    showBranches={true}
  />

  <section class="section">
    <div class="container narrow">
      <p class="section-number">Patio heater service hub</p>
      <h2>Two patio heater categories — different failure trees, different parts.</h2>

      <p>Southern California's outdoor entertaining culture runs year-round, and patio heaters are central to it — restaurants, bars, hotels, private estates, and increasingly residential outdoor living rooms. Two distinct product categories make up the market and we service both.</p>

      <p><strong>Mounted electric infrared heaters</strong> — typically wall- or ceiling-mounted, hard-wired 240V or 120V, no fuel handling. Brands: <strong>Bromic Heating</strong> (Platinum Smart-Heat, Tungsten Smart-Heat — Australian, premium-tier dominant in LA luxury restaurant patios and Westside residential installations); <strong>Infratech</strong> (American-made dual element / single element / WD series, wide installed base across SoCal); <strong>Schwank</strong> (Canadian, ER series, common in commercial); <strong>Calcana</strong> (Patio Heater PH Series). Common service: heating element failure (infrared quartz tubes have a 5-7 year service life on heavy use), control module or relay, mounting bracket integrity, weatherproof enclosure seal degradation on coastal installs.</p>

      <p><strong>Freestanding propane patio heaters</strong> — the umbrella-style mushroom-top or pyramid-flame units running off 20-lb propane tanks. Brands: <strong>Fire Sense</strong>, <strong>AZ Patio Heaters</strong>, <strong>Hiland</strong>, <strong>Endless Summer</strong>, <strong>Belleze</strong>. Common service: failed igniter (most common, $75-$145 replacement), thermocouple failure causing repeated shutoff, regulator wear, hose damage, broken safety tilt switch, burner head corrosion.</p>

      <p>Failure-tree differs sharply between categories. Electric infrared is essentially an electrical-system service call — heating element resistance test, relay test, control board diagnostic. Freestanding propane is closer to a gas-grill service — gas supply integrity, ignition module, safety devices. Both categories should be serviced annually before peak entertaining season (October-November in SoCal).</p>

      <p>Restaurants, bars, hotels: we offer maintenance contracts on commercial installations — typically multi-unit Bromic or Infratech setups across patio dining rooms. For full outdoor kitchen integration with patio heaters, see <a href="/outdoor/kitchen-repair/">outdoor kitchen repair</a>.</p>
    </div>
  </section>

  <section class="bottom-cta">
    <div class="container">
      <h2>Patio heater not working? Same-day service across SoCal.</h2>
      <p>Quote-based pricing. Mounted electric and freestanding propane specialists.</p>
      <div class="cta-row">
        <a href={phoneHref} class="btn-primary">☎ Call {phone}</a>
        <a href="/contact/" class="btn-secondary">Schedule Service</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; }
  .section { padding: 72px 24px; }
  .container { max-width: 1100px; margin: 0 auto; }
  .container.narrow { max-width: 820px; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  .section h2 { font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 800; margin: 0 0 18px; color: var(--text); line-height: 1.2; }
  .section p { font-size: 1rem; line-height: 1.75; margin: 0 0 16px; color: var(--text); }
  .section a { color: var(--red); font-weight: 600; text-decoration: none; }
  .section a:hover { text-decoration: underline; }
  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { color: #fff; margin: 0 0 14px; font-size: 1.7rem; }
  .bottom-cta p { color: #c9c9c9; margin: 0 0 26px; }
  .cta-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 14px 28px; border-radius: 5px; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 14px 28px; border-radius: 5px; border: 2px solid rgba(255,255,255,0.35); font-weight: 600; text-decoration: none; }
</style>
