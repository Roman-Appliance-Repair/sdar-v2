---
// src/pages/outdoor/kitchen-repair.astro
// 5-niche architecture — Outdoor kitchen repair (full-suite hub).
import Layout from '../../layouts/Layout.astro';
import ServiceHero from '../../components/ServiceHero.astro';
import { MAIN_PHONE } from '../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;

const title = "Outdoor Kitchen Repair Los Angeles — Built-In Suites · Coastal Specialists | Same Day Appliance Repair";
const description = `Outdoor kitchen repair across LA, Orange, Ventura, San Bernardino & Riverside counties. Full built-in suites — grill, refrigerator, ice maker, sink, side burners. Lynx, Alfresco, DCS, Sub-Zero outdoor, Perlick. Quote-based pricing. Call ${phone}.`;
const canonical = "https://samedayappliance.repair/outdoor/kitchen-repair/";

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Outdoor Kitchen Repair",
  "name": "Outdoor Kitchen Repair — Same Day Appliance Repair",
  "url": canonical,
  "description": "Full outdoor kitchen suite repair across all five SoCal counties — built-in grill, outdoor refrigerator, ice maker, sink, side burners, pizza oven. Lynx, Alfresco, DCS, Sub-Zero outdoor, Perlick HC, Marvel.",
  "provider": { "@type": "LocalBusiness", "name": "Same Day Appliance Repair", "url": "https://samedayappliance.repair/", "telephone": phone, "priceRange": "$$$" },
  "areaServed": [
    { "@type": "AdministrativeArea", "name": "Los Angeles County" },
    { "@type": "AdministrativeArea", "name": "Orange County" },
    { "@type": "AdministrativeArea", "name": "Ventura County" },
    { "@type": "AdministrativeArea", "name": "San Bernardino County" },
    { "@type": "AdministrativeArea", "name": "Riverside County" },
  ],
};
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <ServiceHero
    eyebrow="LA · Orange · Ventura · San Bernardino · Riverside Counties"
    title="Outdoor Kitchen Repair Across Southern California"
    subtitle="Full built-in suites — grill, outdoor refrigerator, ice maker, sink, side burners. Lynx, Alfresco, Twin Eagles, DCS, Sub-Zero outdoor, Perlick HC, Marvel. Coastal salt-air specialists. Quote-based pricing across five SoCal counties."
    heroImageTitle="Outdoor Kitchen Repair"
    showBranches={true}
  />

  <section class="section">
    <div class="container narrow">
      <p class="section-number">Outdoor kitchen service hub</p>
      <h2>Full-suite outdoor kitchen repair — every component on one dispatch.</h2>

      <p>The Southern California outdoor kitchen market has matured into full built-in suites — grill plus outdoor refrigerator plus ice maker plus side burner plus sink, often integrated with patio heaters and outdoor fireplaces. We service the entire suite on a single dispatch rather than separate calls per component. Premium brand catalog: <strong>Lynx Professional</strong> (L54PSR built-ins), <strong>Alfresco</strong> (ALXE-56, ALXE-42), <strong>Twin Eagles</strong> (TEBQ36R, TEBQ54R), <strong>DCS by Fisher &amp; Paykel</strong> (BH1 series), <strong>Hestan</strong>, <strong>Fire Magic Aurora</strong>, <strong>Blaze Outdoor</strong>; outdoor refrigeration: <strong>Sub-Zero outdoor</strong> (DEL3050, UC-24RO), <strong>Marvel</strong> (ML24RAS), <strong>Perlick HC</strong> (HP24RS), <strong>U-Line outdoor</strong>; ice makers: <strong>Hoshizaki</strong>, <strong>Scotsman</strong>, <strong>U-Line outdoor ice</strong>.</p>

      <p>The single most consequential service angle for SoCal outdoor kitchens is <strong>coastal salt-air maintenance</strong>. Beachfront and ocean-adjacent installations — Carbon Beach, Malibu Colony, Point Dume, Pacific Palisades, Manhattan Beach, Newport Coast, Corona del Mar, Laguna Beach — see condenser coil corrosion 5x faster than inland units, accelerated burner igniter degradation from salt humidity, gasket and seal compression loss on outdoor refrigerators within 4-6 years vs. 12+ inland. Coastal maintenance schedule: every 6 months. Inland (Hidden Hills, Calabasas, Bel Air, Pasadena foothills, Thousand Oaks): annually. We adjust intervals based on your specific install location and exposure.</p>

      <p>City-specific outdoor kitchen pages with neighborhood and brand depth:</p>

      <ul>
        <li><a href="/outdoor/kitchen-repair-malibu/">Malibu outdoor kitchen repair</a> — Carbon Beach, Point Dume, Broad Beach, Malibu Colony</li>
        <li><a href="/outdoor/kitchen-repair-newport-beach/">Newport Beach outdoor kitchen repair</a> — Newport Coast, Corona del Mar, Pelican Hill</li>
        <li><a href="/outdoor/kitchen-repair-thousand-oaks/">Thousand Oaks outdoor kitchen repair</a> — Conejo Valley inland-heat installations</li>
      </ul>

      <p>For seasonal outdoor kitchen maintenance, see <a href="/outdoor/kitchen-maintenance/">outdoor kitchen maintenance</a>. For grill-only service, see <a href="/outdoor/grill-repair/">outdoor grill repair</a>. For wine cellar repair (often integrated into outdoor entertaining suites), see <a href="/outdoor/wine-cellar-repair-malibu/">wine cellar repair</a> coverage by city.</p>
    </div>
  </section>

  <section class="bottom-cta">
    <div class="container">
      <h2>Outdoor kitchen down? Full-suite service across all five SoCal counties.</h2>
      <p>Quote-based pricing. Coastal salt-air specialists. Same-day priority for events.</p>
      <div class="cta-row">
        <a href={phoneHref} class="btn-primary">☎ Call {phone}</a>
        <a href="/contact/" class="btn-secondary">Schedule Service</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; }
  .section { padding: 72px 24px; }
  .container { max-width: 1100px; margin: 0 auto; }
  .container.narrow { max-width: 820px; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  .section h2 { font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 800; margin: 0 0 18px; color: var(--text); line-height: 1.2; }
  .section p { font-size: 1rem; line-height: 1.75; margin: 0 0 16px; color: var(--text); }
  .section ul { margin: 0 0 18px 24px; }
  .section li { margin-bottom: 8px; line-height: 1.7; }
  .section a { color: var(--red); font-weight: 600; text-decoration: none; }
  .section a:hover { text-decoration: underline; }
  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { color: #fff; margin: 0 0 14px; font-size: 1.7rem; }
  .bottom-cta p { color: #c9c9c9; margin: 0 0 26px; }
  .cta-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 14px 28px; border-radius: 5px; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 14px 28px; border-radius: 5px; border: 2px solid rgba(255,255,255,0.35); font-weight: 600; text-decoration: none; }
</style>
