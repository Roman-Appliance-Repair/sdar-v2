      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": canonical + "#service",
    "serviceType": "Big Green Egg Repair",
    "name": "Big Green Egg Ceramic Kamado Repair Service",
    "url": canonical,
    "description": "Big Green Egg ceramic kamado repair across all five SoCal counties. Mini, MiniMax, Small, Medium, Large, XL, 2XL. Gasket replacement (felt strip), dome thermometer drift recalibration and replacement, draft door and hinge hardware service, fire ring and fire box ceramic inspection, lifetime ceramic warranty claim coordination for registered owners. Customer education on damper management and pellet quality. $120 outdoor diagnostic, waived with repair. BHGS #A49573, EPA 608 Universal certified #1346255700410.",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" },
    ],
    "offers": { "@type": "Offer", "priceRange": "$120-$800", "priceSpecification": { "@type": "PriceSpecification", "price": "120.00", "priceCurrency": "USD", "description": "Outdoor diagnostic fee, waived with repair. Often resolves at warranty navigation rather than paid repair." } },
    "brand": { "@id": canonical + "#brand" },
  },
  {
    "@context": "https://schema.org",
    "@type": "Brand",
    "@id": canonical + "#brand",
    "name": "Big Green Egg",
    "url": "https://biggreenegg.com/",
