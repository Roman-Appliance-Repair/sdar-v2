---
// src/pages/outdoor/smoker-repair/brands/primo.astro
// Wave 6a — Primo ceramic kamado brand page (Tucker GA, only US-made kamado).
// Distinctive oval shape (not round). Oval LG/JR, Round, Kamado-X.
// Premium tier, smaller market, BBQ-competition crowd.
// $120 OUTDOOR diagnostic universal (per CLAUDE.md §3, smokers = outdoor tier).
// BHGS #A49573, EPA 608 Universal #1346255700410.
// 5 schemas (LocalBusiness + Service + Brand + FAQPage + BreadcrumbList).

import Layout from '../../../../layouts/Layout.astro';
import ServiceHero from '../../../../components/ServiceHero.astro';
import { MAIN_PHONE } from '../../../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/outdoor/smoker-repair/brands/primo/";

const title = "Primo Kamado Repair LA | Oval LG/JR, Round, Kamado-X · USA-Made · $120 Outdoor Diagnostic";
const description = `Primo ceramic kamado repair across SoCal. Only US-made kamado, distinctive oval shape. Oval LG/JR, Round, Kamado-X. $120 outdoor diagnostic.`;

const faqs = [
  {
    q: "What makes Primo different from Big Green Egg and Kamado Joe?",
    a: "Two things: shape and origin. Primo is the only US-made kamado on the market (manufactured in Tucker, Georgia). BGE and Kamado Joe ceramic bodies are made overseas. Primo's distinctive oval shape (Oval LG, Oval JR, Kamado-X) lets you split the firepot into direct and indirect heat zones simultaneously, which is a serious advantage for BBQ-competition cooks running brisket and ribs at different temps. The Round model is BGE-comparable. Primo customers tend to be technically engaged BBQ-competition folks who maintain their cookers carefully; service calls are less common than the brand's market share would suggest.",
  },
  {
    q: "What fails on a Primo Oval?",
    a: "Same ceramic and gasket pattern as any other kamado: gasket compression year 4-7, dome thermometer drift year 4+, hardware service (draft door bolts, hinge spring, dampers). Plus oval-specific items: divider grates wear from heavy thermal cycling on dual-zone direct/indirect cooking ($240-380 to replace the divider set), charcoal basket warping at year 5-8 in heavy-use units ($180-280 replacement). Ceramic body cracks are uncommon on Primos in our experience, partly because owners maintain them well, partly because Primo's ceramic formulation is dense and high-quality.",
  },
  {
    q: "How is Primo's parts availability in LA?",
    a: "Primo runs a smaller distribution network than BGE or Kamado Joe, but parts are accessible through the authorized dealer network with 5-7 day standard ship from Tucker, Georgia. We stock common items on the van for the major sizes (gaskets for Oval LG and Oval JR, replacement dome thermometers, common fastener hardware). Specialty items (divider grate sets, charcoal basket replacements, fire ring) are dealer-order. We confirm part availability during the diagnostic visit and coordinate.",
  },
  {
    q: "Why is the Primo divider grate a service item?",
    a: "The divider grate is what makes the oval shape useful for dual-zone cooking. You set up direct heat on one side of the firebox and indirect on the other, with the divider grate separating the cooking surface accordingly. The divider takes serious thermal cycling because it sits in the heat path between zones. Year 5-8 typical wear on heavy-use units (BBQ-competition cooks running multiple full-day cooks per month). Replacement is $240-380 typical for the divider set. Light-use Primos can run year 12+ before divider replacement is needed.",
  },
  {
    q: "Do you understand BBQ competition cooking?",
    a: "Yes. Primo customers are usually serious BBQ folks. We speak the language at the diagnostic. Pit temp curves, low-and-slow stalls, reverse sears, dual-zone smoke roasting, the difference between competition trim and backyard trim. We don't talk down to a Primo customer who's been cooking briskets for 15 years. The diagnostic conversation about why a Primo is or isn't holding 225°F is technical, and we treat it as technical.",
  },
  {
    q: "Can Primo ceramic be left outside in the rain?",
    a: "Yes. Same as BGE and Kamado Joe: the ceramic body is weatherproof. Keep a Primo-branded vinyl cover on it to protect the metal hardware (hinge, dampers, draft door, side handle) from rust. Coastal-installed Primos (Newport Coast, Manhattan Beach, Palos Verdes) need bi-annual hardware lubrication for accelerated salt corrosion.",
  },
  {
    q: "What's your warranty?",
    a: "90 days SDAR labor and parts warranty on the work we perform. Primo component warranties (ceramic body warranty terms vary by component) are processed separately through Primo's authorized service network. We coordinate active warranty claims when we see warranty-eligible damage on the diagnostic. BHGS #A49573, BBB A+, EPA 608 Universal certified #1346255700410.",
  },
];

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": canonical + "#business",
    "name": "Same Day Appliance Repair",
    "url": canonical,
    "telephone": phone,
    "priceRange": "$$$",
    "openingHoursSpecification": [{ "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "08:00", "closes": "20:00" }],
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": canonical + "#service",
    "serviceType": "Primo Kamado Repair",
    "name": "Primo Ceramic Kamado Repair Service",
    "url": canonical,
    "description": "Primo ceramic kamado repair across all five SoCal counties. Oval LG, Oval JR, Round, Kamado-X. Only US-made kamado, manufactured in Tucker, Georgia. Distinctive oval shape enables dual-zone direct/indirect cooking. Ceramic and gasket service (parallel to BGE/Kamado Joe diagnostic), plus oval-specific items: divider grate wear (year 5-8 heavy use), charcoal basket warping (year 5-8 heavy use). Dome thermometer, hardware service, ceramic warranty coordination. BBQ-competition crowd specialty. $120 outdoor diagnostic, waived with repair. BHGS #A49573, EPA 608 Universal certified #1346255700410.",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" },
    ],
    "offers": { "@type": "Offer", "priceRange": "$120-$800", "priceSpecification": { "@type": "PriceSpecification", "price": "120.00", "priceCurrency": "USD", "description": "Outdoor diagnostic fee, applied toward repair" } },
    "brand": { "@id": canonical + "#brand" },
  },
  {
    "@context": "https://schema.org",
    "@type": "Brand",
    "@id": canonical + "#brand",
    "name": "Primo Ceramic Grills",
    "url": "https://www.primogrill.com/",
    "description": "Primo Ceramic Grills is the only US-made kamado manufacturer, headquartered in Tucker, Georgia. Distinctive oval shape sets Primo apart from round-shape competitors (Big Green Egg, Kamado Joe). Models: Oval LG (large, most common), Oval JR (smaller), Round (BGE-comparable), Kamado-X (newest). Premium tier, smaller market share with a loyal BBQ-competition following. Oval architecture enables true dual-zone direct/indirect cooking with one fire.",
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Outdoor", "item": "https://samedayappliance.repair/outdoor/" },
      { "@type": "ListItem", "position": 3, "name": "Smoker Repair", "item": "https://samedayappliance.repair/outdoor/smoker-repair/" },
      { "@type": "ListItem", "position": 4, "name": "Primo", "item": canonical },
    ],
  },
];
---

<Layout title={title} description={description} canonical={canonical}>
<Fragment slot="head-scripts">
  {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
</Fragment>

<ServiceHero
  eyebrow="Primo · Only US-Made Kamado · Oval Dual-Zone · LA Same-Day"
  title="Primo Ceramic Kamado Repair Los Angeles"
  subtitle={`Oval LG/JR, Round, Kamado-X. Only US-made kamado on the market. Divider grates, charcoal basket, gasket, ceramic, hardware service. BBQ-competition crowd specialty. $120 outdoor diagnostic. ${phone}`}
  heroImageTitle="Primo Kamado Repair"
/>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Primo service</p>
    <h2>The only US-made kamado, with a distinctive oval shape and a serious BBQ-competition following.</h2>

    <p>Primo Ceramic Grills is the only US-made kamado manufacturer, headquartered in Tucker, Georgia. The distinctive oval shape (Oval LG, Oval JR, Kamado-X) sets Primo apart from round-shape competitors and enables true dual-zone direct/indirect cooking with a single fire. The Round model is BGE-comparable. Primo holds smaller market share than BGE or Kamado Joe, but the customer base is intensely loyal: BBQ-competition cooks, dedicated low-and-slow practitioners, and serious backyard pitmasters. Service calls are less common than the brand's market share would suggest, partly because owners maintain Primos carefully and partly because the ceramic formulation is dense and high-quality.</p>

    <p>We service the full Primo lineup across LA County, Orange, Ventura, San Bernardino, Riverside. <strong>Oval LG</strong> (large, most common in our service calls). <strong>Oval JR</strong> (smaller oval). <strong>Round</strong> (BGE-comparable round shape). <strong>Kamado-X</strong> (newest model).</p>

    <p>$120 outdoor diagnostic, waived with repair. <strong>BHGS #A49573</strong>. <strong>EPA 608 Universal certified #1346255700410</strong>. BBB A+. Phones answered 24/7. Parent: <a href="/outdoor/smoker-repair/">smoker repair</a>.</p>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">Lineup and what fails</p>
    <h2 class="section-title">Primo series and common service items.</h2>

    <h3 class="series-h3">Oval LG (large oval, most common)</h3>
    <p>The Primo we touch most often. Service tree: gasket year 4-7 ($240-380 all-in), dome thermometer drift year 4+ ($160-240), divider grate wear year 5-8 on heavy use ($240-380), charcoal basket warping year 5-8 on heavy use ($180-280). Hardware service (draft door bolts, hinge spring, dampers) at year 8+ on coastal addresses or heavy use. Out-of-warranty ceramic crack is uncommon; when it happens it's typically year 10+ on first-generation Ovals and runs $440-680 paid repair.</p>

    <h3 class="series-h3">Oval JR (smaller oval)</h3>
    <p>Same architecture as Oval LG, smaller dimensions. Gasket and thermometer service same wear pattern. Smaller divider grate set runs $180-260 typical. Less common in our service calls than Oval LG.</p>

    <h3 class="series-h3">Round (BGE-comparable round shape)</h3>
    <p>Round-shape Primo, equivalent to BGE Large in cooking surface and ceramic mass. Service tree parallels BGE Large: gasket, dome thermometer, hardware. No divider grate (the round shape doesn't support dual-zone the way the oval does). Less common in our calls than the Oval LG; Primo customers usually choose the oval specifically for the dual-zone capability.</p>

    <h3 class="series-h3">Kamado-X (newest model)</h3>
    <p>Primo's newer model with updated features. Same fundamental ceramic kamado architecture; service items follow the Oval LG pattern.</p>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Common scenarios</p>
    <h2 class="section-title">Top Primo repairs in our 5-county territory.</h2>
    <ol class="num-list">
      <li><strong>Divider grate wear (year 5-8 heavy use).</strong> Oval LG specifically; oval shape only. $240-380 replacement.</li>
      <li><strong>Charcoal basket warping (year 5-8 heavy use).</strong> $180-280 replacement.</li>
      <li><strong>Gasket replacement (year 4-7).</strong> $240-380 typical depending on size.</li>
      <li><strong>Dome thermometer drift (year 4+).</strong> $160-240 all-in.</li>
      <li><strong>Hardware service (draft door, hinge, dampers).</strong> $80-280, lubrication or selective replacement.</li>
      <li><strong>Coastal hardware corrosion.</strong> Newport Coast, Manhattan Beach, Palos Verdes. Bi-annual lubrication recommended.</li>
      <li><strong>Out-of-warranty ceramic crack (year 10+, uncommon).</strong> $440-680 paid repair.</li>
    </ol>
  </div>
</section>

<section class="section section-gray">
  <div class="container">
    <p class="section-number">Real repairs</p>
    <h2 class="section-title">Composite stories from the route.</h2>
    <div class="story-grid">
      <div class="story-card">
        <h3>Pasadena, Primo Oval LG (2018 install, year 7)</h3>
        <p>BBQ-competition customer reported divider grate warped beyond use. Replaced divider grate set. Inspected fire ring for cracks (none yet, typical for year 7 on this brand with serious owner maintenance). Inspected gasket, still functional, recommended replacement at year 8-9. Total: $120 plus $300 parts plus 20 minutes labor = $440.</p>
      </div>
      <div class="story-card">
        <h3>Calabasas, Primo Oval JR (2020 install, year 5)</h3>
        <p>Customer reported smoke leaking around dome plus thermometer reading 30°F off. Replaced gasket and dome thermometer in single visit. Total: $120 plus $260 parts plus 50 minutes labor = $480.</p>
      </div>
      <div class="story-card">
        <h3>Newport Coast, Primo Round (2017 install, year 8, coastal)</h3>
        <p>Owner reported draft door bolt seized plus hinge spring weak. Hardware service: replaced 2 bolts, replaced hinge spring, lubricated all hardware throughout. Inspected ceramic, no cracks. While there, recommended bi-annual lubrication schedule for coastal exposure. Total: $120 plus $180 parts plus 75 minutes labor = $400.</p>
      </div>
      <div class="story-card">
        <h3>Beverly Hills, Primo Oval LG (2015 install, year 10, BBQ-competition use)</h3>
        <p>Heavy-use unit, customer cooks 2-3 times weekly including full overnight briskets. Charcoal basket warped, divider grate warped, gasket compressed. Replaced charcoal basket, divider grate, gasket in single visit. Inspected ceramic, small crack on fire ring. Out-of-warranty (Primo ceramic warranty already past on year 10). Quoted out-of-warranty fire ring replacement, customer chose to monitor. Total: $120 plus $620 parts plus 90 minutes labor = $880.</p>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Honest scope</p>
    <h2 class="section-title">What we do for Primo, and what we don't.</h2>

    <p><strong>We service:</strong></p>
    <ul class="bullet-list">
      <li>Oval LG, Oval JR, Round, Kamado-X (full Primo lineup)</li>
      <li>Gasket replacement</li>
      <li>Dome thermometer drift recalibration and replacement</li>
      <li>Divider grate wear (oval-specific, dual-zone cooking item)</li>
      <li>Charcoal basket warping replacement</li>
      <li>Hardware service (draft door, hinge spring, dampers)</li>
      <li>Coastal hardware lubrication and corrosion service</li>
      <li>Primo ceramic warranty coordination</li>
      <li>BBQ-competition customer technical consultation (pit temps, dual-zone setup, low-and-slow troubleshooting)</li>
    </ul>

    <p><strong>We don't do:</strong> ceramic body modifications (drilling, machining, voids warranty); custom Primo table or surround fabrication; integration of third-party automatic temp controllers (Flame Boss, BBQ Guru. We'll service the Primo itself but not those controllers; some are universal and OK to install, but the controller diagnostic is separate). On the BBQ-competition side, we don't ride along to competitions; we'll service your Primo before or after the event.</p>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">Pricing</p>
    <h2 class="section-title">Primo repair costs.</h2>
    <p class="lead">$120 outdoor diagnostic, waived with repair. Universal across all Primo models.</p>
    <table class="price-table">
      <thead><tr><th>Repair</th><th>Typical Cost</th></tr></thead>
      <tbody>
        <tr><td>Diagnostic</td><td>$120, waived with repair</td></tr>
        <tr><td>Gasket replacement (Oval LG, Round)</td><td>$240 to $380</td></tr>
        <tr><td>Gasket replacement (Oval JR)</td><td>$200 to $320</td></tr>
        <tr><td>Dome thermometer replacement</td><td>$160 to $240</td></tr>
        <tr><td>Divider grate set (Oval LG)</td><td>$240 to $380</td></tr>
        <tr><td>Divider grate set (Oval JR)</td><td>$180 to $260</td></tr>
        <tr><td>Charcoal basket replacement</td><td>$180 to $280</td></tr>
        <tr><td>Hardware service (lubrication + selective replacement)</td><td>$120 to $280</td></tr>
        <tr><td>Hinge spring replacement</td><td>$180 to $280</td></tr>
        <tr><td>Out-of-warranty fire ring (Oval LG)</td><td>$340 to $520</td></tr>
        <tr><td>Out-of-warranty dome (Oval LG)</td><td>$520 to $780</td></tr>
        <tr><td>Heavy-use multi-component repair (year 8+ unit)</td><td>$680 to $1,200</td></tr>
        <tr><td>Warranty (SDAR labor)</td><td>90 days parts and labor on our work</td></tr>
      </tbody>
    </table>
  </div>
</section>

<section class="section">
  <div class="container">
    <p class="section-number">Why us for Primo</p>
    <h2 class="section-title">What separates our Primo service.</h2>
    <ul class="reasons-list">
      <li><strong>Oval-specific service expertise.</strong> Divider grate wear and charcoal basket warping are unique to the oval architecture; we know the wear pattern and the right replacement timing.</li>
      <li><strong>BBQ-competition technical fluency.</strong> Pit temp curves, dual-zone direct/indirect setup, low-and-slow stalls, reverse sears. We talk technical with technical customers.</li>
      <li><strong>Primo dealer parts coordination.</strong> Tucker GA dealer network, 5-7 day standard ship on specialty items.</li>
      <li><strong>Parts on the van.</strong> Common gaskets, replacement dome thermometers, common fastener hardware.</li>
      <li><strong>Coastal hardware service.</strong> Newport Coast, Manhattan Beach, Palos Verdes. Bi-annual lubrication and corrosion service for Primo owners on saltwater exposure.</li>
      <li><strong>BHGS #A49573 plus EPA 608 Universal certified #1346255700410.</strong> Verifiable.</li>
      <li><strong>Same-day across LA, OC, Ventura.</strong> Next-day for Riverside and San Bernardino. 24/7 phone.</li>
      <li><strong>BBB A+ verifiable.</strong> See our <a href="/credentials/licensed/">license credentials</a>.</li>
    </ul>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">FAQ</p>
    <h2 class="section-title">Primo repair questions.</h2>
    <div class="faq-list">
      {faqs.map(f => (<details class="faq-item"><summary>{f.q}</summary><p>{f.a}</p></details>))}
    </div>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Sister smoker brands</p>
    <h2 class="section-title">Other brands we service.</h2>
    <ul class="bullet-list">
      <li><a href="/outdoor/smoker-repair/">Outdoor smoker repair (parent pillar)</a></li>
      <li><a href="/outdoor/smoker-repair/brands/traeger/">Traeger (mainstream pellet, WiFIRE)</a></li>
      <li><a href="/outdoor/smoker-repair/brands/memphis/">Memphis (premium stainless USA-made pellet)</a></li>
      <li><a href="/outdoor/smoker-repair/brands/big-green-egg/">Big Green Egg (ceramic kamado, lifetime warranty)</a></li>
      <li><a href="/outdoor/smoker-repair/brands/kamado-joe/">Kamado Joe (ceramic + Konnected Joe electric)</a></li>
      <li><a href="/outdoor/grill-repair/">Built-in grill repair</a> (sister appliance)</li>
      <li><a href="/outdoor/kitchen-repair/">Outdoor kitchen repair</a></li>
    </ul>
  </div>
</section>

<section class="bottom-cta">
  <div class="container">
    <h2>Primo issue? Call today.</h2>
    <p>Same-day across LA, OC, Ventura. $120 outdoor diagnostic waived with repair. BBQ-competition customer specialty. BHGS #A49573, EPA 608 Universal #1346255700410. Phones answered 24/7.</p>
    <div class="cta-row">
      <a href={phoneHref} class="btn-primary">☎ Call {phone}</a>
      <a href="/contact/" class="btn-secondary">Book Online</a>
    </div>
  </div>
</section>

</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .section { padding: 72px 24px; }
  .section-gray { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; }
  .container.narrow { max-width: 820px; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  .section h2 { font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 800; margin: 0 0 18px; color: var(--text); line-height: 1.2; }
  .section p { font-size: 1rem; line-height: 1.75; margin: 0 0 16px; color: var(--text); }
  .section a { color: var(--red); font-weight: 600; text-decoration: none; }
  .section a:hover { text-decoration: underline; }
  .lead { font-size: 1.05rem; line-height: 1.75; color: var(--text); margin-bottom: 22px; }
  .series-h3 { font-size: 1.1rem; font-weight: 800; margin: 28px 0 10px; color: var(--text); }
  .num-list { padding-left: 22px; margin: 14px 0 0; }
  .num-list li { font-size: 0.98rem; line-height: 1.7; color: var(--text); margin-bottom: 10px; }
  .bullet-list { padding-left: 22px; margin: 14px 0 18px; }
  .bullet-list li { font-size: 1rem; line-height: 1.65; color: var(--text); margin-bottom: 6px; }
  .story-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 22px; margin-top: 28px; }
