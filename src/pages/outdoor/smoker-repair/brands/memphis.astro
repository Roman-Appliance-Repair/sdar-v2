---
// src/pages/outdoor/smoker-repair/brands/memphis.astro
// Wave 6a — Memphis pellet smoker brand page (founded 2007, USA-made stainless premium tier).
// Pro, Pro Elite, Beale Street (electric+pellet hybrid), Advantage.
// Calabasas / Hidden Hills / Bel Air premium residential market focus.
// $120 OUTDOOR diagnostic universal (per CLAUDE.md §3, smokers = outdoor tier).
// BHGS #A49573, EPA 608 Universal #1346255700410.
// 5 schemas (LocalBusiness + Service + Brand + FAQPage + BreadcrumbList).

import Layout from '../../../../layouts/Layout.astro';
import ServiceHero from '../../../../components/ServiceHero.astro';
import { MAIN_PHONE } from '../../../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/outdoor/smoker-repair/brands/memphis/";

const title = "Memphis Smoker Repair Los Angeles — Same Day";
const description = `Memphis pellet smoker repair across SoCal. Pro Elite, Beale Street, Advantage. Calabasas, Hidden Hills, Bel Air. $120 outdoor diagnostic.`;

const faqs = [
  {
    q: "How does Memphis compare to Traeger from a service standpoint?",
    a: "Memphis is the premium tier — USA-made stainless steel construction, heavier-duty mechanical components, longer service life under repair. Memphis Pro Elite at year 8 is mid-life, not end-of-life. Continued repair through year 15 is normal. The downside is parts cost: Memphis controllers run $480-820 vs Traeger $340-540, and the auger motor is built heavier (year 8-12 typical wear vs Traeger 5-8). Net: higher up-front cost, longer service life, more expensive single repair, repair-justified math through much later in the unit's life."
  },
  {
    q: "What's special about the Memphis Beale Street?",
    a: "The Beale Street is the only smoker in the Memphis lineup that combines pellet smoke cooking with an electric heating element. Year 6-10 typical replacement on the heating element ($380-580 part). It functions as both a pellet smoker (low-and-slow) and an electric oven (steady-temp baking and roasting), which makes it popular in Calabasas, Hidden Hills, and Bel Air outdoor kitchen installations where the customer wants smoke capability plus indoor-style cooking flexibility. We service the dual architecture."
  },
  {
    q: "Memphis Wi-Fi controller died. Repair or replace the smoker?",
    a: "Repair, every time, through year 12 minimum. Memphis Pro Elite and Beale Street are $4,000-7,000 units. The controller is $480-820 plus install ($600-1,000 all-in). Replacement is a $4,000+ decision. The math is clear. Even on a Memphis Pro at year 10 with controller failure, repair makes sense ($600-1,000 repair vs $2,500-3,200 new unit). The only repair-vs-replace call we typically make on Memphis is when multiple major components have failed simultaneously (controller plus auger plus fan), which moves the math toward replacement only on units 14+ years old."
  },
  {
    q: "Where does Memphis sell well in LA?",
    a: "Calabasas, Hidden Hills, Bel Air, Beverly Hills, Pacific Palisades, Newport Coast. The premium-tier pellet smoker space is small in LA (most pellet buyers go Traeger), but Memphis has carved out a niche among residential customers building serious outdoor kitchens. We see 3 to 5 Memphis service calls per month in our 5-county territory, mostly on Pro Elite and Beale Street, mostly in those neighborhoods."
  },
  {
    q: "What's the lead time for Memphis parts?",
    a: "Memphis Grills runs a smaller distribution network than Traeger, with 5-7 day standard ship on common items (igniters, RTD probes, controllers) from authorized service network. Specialty items (Beale Street heating element, hopper assemblies) sometimes run 7-10 days. We confirm part availability during the diagnostic visit and coordinate. We don't quote a part we can't source."
  },
  {
    q: "Do you do PM service on commercial Memphis units?",
    a: "Yes. Restaurants and BBQ catering operations using Memphis Pro Elite or Beale Street commercially get the same $120 diagnostic visit. Commercial duty cycle (8-14 hr daily) compresses the service timeline by 3x: igniter year 1-2, controller year 3-5, auger year 4-6. We schedule quarterly preventive maintenance for several Calabasas and Pasadena BBQ operations running Memphis fleets."
  },
  {
    q: "What's your warranty?",
    a: "90 days SDAR labor and parts warranty on the work we perform. Memphis component warranties (controllers, RTD probes, heating element on Beale Street) where applicable are processed separately through Memphis Grills' authorized service network. BHGS #A49573, BBB A+, EPA 608 Universal certified #1346255700410."
  }
];

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": canonical + "#business",
    "name": "Same Day Appliance Repair",
    "url": canonical,
    "telephone": phone,
    "priceRange": "$$$",
    "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "08:00", "closes": "20:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "00:00", "closes": "00:00" }
      ],
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": canonical + "#service",
    "serviceType": "Memphis Pellet Smoker Repair",
    "name": "Memphis Pellet Smoker Repair Service",
    "url": canonical,
    "description": "Memphis Grills pellet smoker repair across all five SoCal counties. Memphis Pro, Pro Elite, Beale Street (pellet plus electric heating element hybrid), Advantage. Memphis Wi-Fi controller, dual-meat probe RTD pair, heavy-duty auger motor, induction fan, hot rod igniter. Beale Street electric heating element service unique to that model. Calabasas, Hidden Hills, Bel Air, Beverly Hills premium residential and commercial. $120 outdoor diagnostic, waived with repair. BHGS #A49573, EPA 608 Universal certified #1346255700410.",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "offers": { "@type": "Offer", "priceRange": "$120-$1500", "priceSpecification": { "@type": "PriceSpecification", "price": "120.00", "priceCurrency": "USD", "description": "Outdoor diagnostic fee, applied toward repair" } },
    "brand": { "@id": canonical + "#brand" }
  },
  {
    "@context": "https://schema.org",
    "@type": "Brand",
    "@id": canonical + "#brand",
    "name": "Memphis Grills",
    "url": "https://memphisgrills.com/",
    "description": "Memphis Grills is an American premium pellet smoker manufacturer founded in 2007. USA-made stainless steel construction. Premium tier alternative to Traeger mainstream. Models: Memphis Pro, Pro Elite, Beale Street (combines pellet smoke with an electric heating element for indoor-style electric cooking, unique within the brand), Advantage. Pricing $2,500-7,200. Heavier-duty mechanical components than mainstream pellet brands; longer service-justified life under repair."
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Outdoor", "item": "https://samedayappliance.repair/outdoor/" },
      { "@type": "ListItem", "position": 3, "name": "Smoker Repair", "item": "https://samedayappliance.repair/outdoor/smoker-repair/" },
      { "@type": "ListItem", "position": 4, "name": "Memphis", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>
<Fragment slot="head-scripts">
  {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
</Fragment>

<ServiceHero
  eyebrow="Memphis · Premium Stainless Pellet · USA-Made · LA Same-Day"
  title="Memphis Pellet Smoker Repair Los Angeles"
  subtitle={`Pro, Pro Elite, Beale Street (pellet plus electric hybrid), Advantage. Wi-Fi controllers, dual-probe RTD, heavy-duty auger motors, electric heating elements. Calabasas, Hidden Hills, Bel Air. $120 outdoor diagnostic. ${phone}`}
  heroImageTitle="Memphis Smoker Repair"
/>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Memphis service</p>
    <h2>Premium USA-made stainless pellet, dominant in LA luxury residential outdoor kitchens.</h2>

    <p>Memphis Grills is the American premium pellet smoker manufacturer founded in 2007. USA-made stainless steel construction, premium tier alternative to Traeger mainstream. Over the past decade Memphis has carved out a strong niche in LA luxury residential outdoor kitchens (Calabasas, Hidden Hills, Bel Air, Beverly Hills, Pacific Palisades, Newport Coast), with smaller commercial presence at high-end BBQ operations and catering kitchens in Pasadena and Calabasas. Pricing $2,500-7,200 across the lineup.</p>

    <p>We service the full Memphis lineup across LA County, Orange, Ventura, San Bernardino, Riverside. <strong>Memphis Pro</strong> ($2,500-3,200, entry premium). <strong>Pro Elite</strong> ($3,800-5,200, mid-tier with extended cabinet capacity). <strong>Beale Street</strong> ($5,800-7,200, the dual-architecture pellet smoke plus electric heating element model). <strong>Advantage</strong> (entry, simpler controller, smaller footprint).</p>

    <p>$120 outdoor diagnostic, waived with repair. <strong>BHGS #A49573</strong>. <strong>EPA 608 Universal certified #1346255700410</strong>. BBB A+. Phones answered 24/7. Parent: <a href="/outdoor/smoker-repair/">smoker repair</a>.</p>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">Lineup and what fails</p>
    <h2 class="section-title">Memphis series and common service items.</h2>

    <h3 class="series-h3">Memphis Pro (entry premium, $2,500-3,200)</h3>
    <p>Stainless steel cabinet, single-zone cook area, Wi-Fi controller. Hot rod igniter year 4-7 ($280-380). Wi-Fi controller year 6-9 ($480-720 part, $640-900 all-in). Auger motor year 8-12 (heavier-duty than Traeger). RTD probe pair drift continuously over the unit's life; recalibration or replacement at year 5+ typical.</p>

    <h3 class="series-h3">Pro Elite (mid premium, $3,800-5,200)</h3>
    <p>Larger cabinet, dual-zone cook area, dual-meat-probe RTD pair, premium Wi-Fi controller. Wi-Fi controller year 5-8 ($580-820 part, $720-1,000 all-in). Auger motor and induction fan run heavier-duty than Pro Series; year 10-14 typical replacement window. The dual probe pair is a common diagnostic point: probes drift independently, and customers report cabinet temp accuracy issues that resolve at the probe level rather than the controller.</p>

    <h3 class="series-h3">Beale Street (pellet plus electric hybrid, $5,800-7,200)</h3>
    <p>The unique unit in the Memphis lineup. Pellet smoke cooking architecture plus an electric heating element for indoor-style steady-temp cooking. Two distinct service trees on this model: pellet side (igniter, auger, fan, controller) plus electric side (heating element year 6-10, $380-580 part, $520-780 all-in). Beale Street customers tend to use the electric mode more than the pellet mode for everyday cooking; the heating element wears accordingly.</p>

    <h3 class="series-h3">Advantage (entry, smaller footprint)</h3>
    <p>Simpler controller (no app integration on early production), smaller hopper, shorter cabinet. Same hot rod, fan, auger architecture as Pro. Year 8-12 service-justified lifespan. Less common in our LA service calls than Pro Elite.</p>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Common scenarios</p>
    <h2 class="section-title">Top Memphis repairs in our 5-county territory.</h2>
    <ol class="num-list">
      <li><strong>Wi-Fi controller failure (year 5-8 on Pro Elite, year 6-9 on Pro).</strong> $580-1,000 all-in depending on tier.</li>
      <li><strong>Dual-meat probe RTD drift (Pro Elite, Beale Street).</strong> Probe-pair diagnostic; replace one or both. $260-440 typical.</li>
      <li><strong>Hot rod igniter (year 4-7).</strong> $280-380 all-in.</li>
      <li><strong>Heavy-duty auger motor (year 8-12).</strong> $440-680 typical.</li>
      <li><strong>Beale Street electric heating element (year 6-10).</strong> $520-780 all-in. Unique to this model.</li>
      <li><strong>Induction fan motor (year 8-12 on Pro Elite, year 6-9 on Pro Series).</strong> $380-560.</li>
      <li><strong>Stainless cabinet pitting (coastal addresses).</strong> Surface cleaning and re-passivation; rare to require replacement.</li>
    </ol>
  </div>
</section>

<section class="section section-gray">
  <div class="container">
    <p class="section-number">Real repairs</p>
    <h2 class="section-title">Composite stories from the route.</h2>
    <div class="story-grid">
      <div class="story-card">
        <h3>Calabasas, Memphis Pro Elite 880 (2017 install, year 7)</h3>
        <p>Owner reported app disconnection plus 50°F temperature swings. Diagnosed: RTD probe pair drift (one probe 28°F high, the other 14°F low). Replaced both probes, recalibrated cabinet, ran 4-hour test at 225°F set point. Held within 8°F. Total: $120 plus $360 parts plus 90 minutes labor = $600.</p>
      </div>
      <div class="story-card">
        <h3>Hidden Hills, Memphis Pro (2014 install, year 11)</h3>
        <p>Auger motor seizure on a year-11 unit with weekly cooking history. Replaced auger motor (heavier-duty Pro spec, not the Pro Series Traeger spec equivalent). Tested under load 30 minutes, no overheating. Total: $120 plus $480 part plus 75 minutes labor = $720. Owner declined controller replacement at the same visit; we noted year 11+ is mid-life on this brand and controller replacement isn't urgent.</p>
      </div>
      <div class="story-card">
        <h3>Bel Air, Memphis Beale Street (2018 install, year 7)</h3>
        <p>Electric heating element failure (the side that runs steady-temp cooking, not the pellet side). Replaced heating element, tested at 350°F oven mode. Pellet side cooking unaffected throughout. Total: $120 plus $440 part plus 90 minutes labor = $680.</p>
      </div>
      <div class="story-card">
        <h3>Pasadena commercial BBQ catering, Memphis Pro Elite fleet</h3>
        <p>Quarterly PM on 3 Pro Elite units running commercial duty (12 hr daily during catering season). Replaced one igniter, recalibrated 2 RTD probe pairs, cleaned 3 firepots. Total: $360 (3 diagnostics) plus $480 parts plus 4 hours labor = $1,200. Operator's previous shop had been replacing whole units at $4,500 each.</p>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Honest scope</p>
    <h2 class="section-title">What we do for Memphis, and what we don't.</h2>

    <p><strong>We service:</strong></p>
    <ul class="bullet-list">
      <li>Memphis Pro, Pro Elite, Advantage (full pellet architecture)</li>
      <li>Memphis Beale Street (pellet plus electric heating element dual architecture)</li>
      <li>Wi-Fi controller diagnostic, replacement, app pairing</li>
      <li>Dual-meat probe RTD pair calibration and replacement</li>
      <li>Heavy-duty auger motor, induction fan, hot rod igniter service</li>
      <li>Stainless cabinet pitting and corrosion repair (coastal addresses)</li>
      <li>Commercial Memphis fleet PM (BBQ catering, restaurant patio)</li>
    </ul>

    <p><strong>We don't do:</strong> new electrical infrastructure (Memphis Pro and Pro Elite run 120V; Beale Street's electric heating side may need a dedicated 240V circuit depending on configuration); custom modification of the cabinet or hopper; outdoor kitchen masonry work to integrate the smoker into stone surrounds. The Memphis math on repair-vs-replace is straightforward: continued repair through year 12 is normal, through year 15 is common, and we don't recommend replacement until year 14+ unless multiple major components have failed simultaneously.</p>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">Pricing</p>
    <h2 class="section-title">Memphis repair costs.</h2>
    <p class="lead">$120 outdoor diagnostic, waived with repair. Memphis premium parts pricing reflects USA-made stainless OEM components.</p>
    <table class="price-table">
      <thead><tr><th>Repair</th><th>Typical Cost</th></tr></thead>
      <tbody>
        <tr><td>Diagnostic</td><td>$120, waived with repair</td></tr>
        <tr><td>Hot rod igniter</td><td>$280 to $380</td></tr>
        <tr><td>RTD probe pair (Pro Elite, Beale Street)</td><td>$260 to $440</td></tr>
        <tr><td>Wi-Fi controller (Pro)</td><td>$640 to $900</td></tr>
        <tr><td>Wi-Fi controller (Pro Elite, premium tier)</td><td>$720 to $1,100</td></tr>
        <tr><td>Heavy-duty auger motor</td><td>$440 to $680</td></tr>
        <tr><td>Induction fan motor</td><td>$380 to $560</td></tr>
        <tr><td>Beale Street electric heating element</td><td>$520 to $780</td></tr>
        <tr><td>Stainless cabinet re-passivation</td><td>$240 to $440</td></tr>
        <tr><td>Multi-component repair (year 10+ unit)</td><td>$900 to $1,500</td></tr>
        <tr><td>Commercial PM visit (per unit)</td><td>$120 plus parts as needed</td></tr>
        <tr><td>Warranty</td><td>90 days parts and labor</td></tr>
      </tbody>
    </table>
  </div>
</section>

<section class="section">
  <div class="container">
    <p class="section-number">Why us for Memphis</p>
    <h2 class="section-title">What separates our Memphis service.</h2>
    <ul class="reasons-list">
      <li><strong>Beale Street dual architecture expertise.</strong> Pellet side plus electric heating element. Most LA pellet techs don't service the electric side; we do.</li>
      <li><strong>Wi-Fi controller and dual-probe RTD diagnostic.</strong> Probe-pair drift is a common Memphis-specific diagnostic; we run the probe pair against a known reference rather than blindly replacing the controller.</li>
      <li><strong>Calabasas, Hidden Hills, Bel Air, Newport Coast service.</strong> The luxury residential market where Memphis sells well is core to our service territory.</li>
      <li><strong>Repair-vs-replace honesty.</strong> Memphis at year 8 is mid-life. We don't push replacement until year 14+ unless the math actually requires it.</li>
      <li><strong>Authorized parts coordination.</strong> Memphis Grills' authorized service network, 5-7 day standard ship.</li>
      <li><strong>Commercial fleet PM.</strong> Pasadena, Calabasas, OC BBQ catering and restaurant Memphis operations on quarterly preventive maintenance.</li>
      <li><strong>BHGS #A49573 plus EPA 608 Universal certified #1346255700410.</strong> Verifiable.</li>
      <li><strong>Same-day across LA, OC, Ventura.</strong> Next-day for Riverside and San Bernardino. 24/7 phone.</li>
    </ul>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">FAQ</p>
    <h2 class="section-title">Memphis repair questions.</h2>
    <div class="faq-list">
      {faqs.map(f => (<details class="faq-item"><summary>{f.q}</summary><p>{f.a}</p></details>))}
    </div>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Sister smoker brands</p>
    <h2 class="section-title">Other brands we service.</h2>
    <ul class="bullet-list">
      <li><a href="/outdoor/smoker-repair/">Outdoor smoker repair (parent pillar)</a></li>
      <li><a href="/outdoor/smoker-repair/brands/traeger/">Traeger (mainstream pellet, WiFIRE)</a></li>
      <li><a href="/outdoor/smoker-repair/brands/big-green-egg/">Big Green Egg (ceramic kamado, lifetime warranty)</a></li>
      <li><a href="/outdoor/smoker-repair/brands/kamado-joe/">Kamado Joe (ceramic + Konnected Joe electric)</a></li>
      <li><a href="/outdoor/smoker-repair/brands/primo/">Primo (only US-made kamado, oval shape)</a></li>
      <li><a href="/outdoor/grill-repair/">Built-in grill repair</a> (sister appliance)</li>
      <li><a href="/outdoor/kitchen-repair/">Outdoor kitchen repair</a></li>
    </ul>
  </div>
</section>

<section class="bottom-cta">
  <div class="container">
    <h2>Memphis down? Call today.</h2>
    <p>Same-day across LA, OC, Ventura. $120 outdoor diagnostic waived with repair. BHGS #A49573, EPA 608 Universal #1346255700410. Phones answered 24/7.</p>
    <div class="cta-row">
      <a href={phoneHref} class="btn-primary">☎ Call {phone}</a>
      <a href="/contact/" class="btn-secondary">Book Online</a>
    </div>
  </div>
</section>

</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .section { padding: 72px 24px; }
  .section-gray { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; }
  .container.narrow { max-width: 820px; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  .section h2 { font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 800; margin: 0 0 18px; color: var(--text); line-height: 1.2; }
  .section p { font-size: 1rem; line-height: 1.75; margin: 0 0 16px; color: var(--text); }
  .section a { color: var(--red); font-weight: 600; text-decoration: none; }
  .section a:hover { text-decoration: underline; }
  .lead { font-size: 1.05rem; line-height: 1.75; color: var(--text); margin-bottom: 22px; }
  .series-h3 { font-size: 1.1rem; font-weight: 800; margin: 28px 0 10px; color: var(--text); }
  .num-list { padding-left: 22px; margin: 14px 0 0; }
  .num-list li { font-size: 0.98rem; line-height: 1.7; color: var(--text); margin-bottom: 10px; }
  .bullet-list { padding-left: 22px; margin: 14px 0 18px; }
  .bullet-list li { font-size: 1rem; line-height: 1.65; color: var(--text); margin-bottom: 6px; }
  .story-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 22px; margin-top: 28px; }
  .story-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 24px 22px; }
  .story-card h3 { font-size: 1rem; font-weight: 800; margin: 0 0 12px; color: var(--text); line-height: 1.35; }
  .story-card p { font-size: 0.95rem; color: var(--text); line-height: 1.7; margin: 0; }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 22px; background: #fff; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
  .price-table th, .price-table td { padding: 12px 16px; text-align: left; border-bottom: 1px solid var(--border); font-size: 0.95rem; }
  .price-table th { background: var(--gray); font-weight: 700; color: var(--text); }
  .price-table tr:last-child td { border-bottom: none; }
  .reasons-list { padding-left: 22px; margin: 18px 0 0; }
  .reasons-list li { font-size: 1rem; line-height: 1.75; color: var(--text); margin-bottom: 10px; }
  .faq-list { margin-top: 24px; }
  .faq-item { background: #fff; border: 1px solid var(--border); border-radius: 6px; padding: 18px 22px; margin-bottom: 12px; }
  .faq-item summary { font-weight: 700; cursor: pointer; font-size: 1rem; color: var(--text); list-style: none; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::before { content: "+ "; color: var(--red); font-weight: 800; margin-right: 6px; }
  .faq-item[open] summary::before { content: "− "; }
  .faq-item p { font-size: 0.95rem; color: var(--text); line-height: 1.75; margin: 14px 0 0; }
  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { color: #fff; margin: 0 0 14px; font-size: 1.7rem; }
  .bottom-cta p { color: #c9c9c9; margin: 0 0 26px; max-width: 720px; margin-left: auto; margin-right: auto; }
  .cta-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 14px 28px; border-radius: 5px; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 14px 28px; border-radius: 5px; border: 2px solid rgba(255,255,255,0.35); font-weight: 600; text-decoration: none; }
</style>
</content>
