      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": canonical + "#service",
    "serviceType": "Kamado Joe Repair",
    "name": "Kamado Joe Ceramic Kamado Repair Service",
    "url": canonical,
    "description": "Kamado Joe repair across all five SoCal counties. Classic II/III, Big Joe II/III (traditional ceramic kamado), Konnected Joe (electric auto-ignition, integrated digital control, iKamand smart hub, automatic damper actuator). Two distinct service trees: traditional kamado (gasket, ceramic, dome thermometer, hardware) and Konnected Joe hybrid (electric igniter system, iKamand WiFi module, damper actuator). Kamado Joe ceramic warranty coordination (5-10 year terms by component). $120 outdoor diagnostic, waived with repair. BHGS #A49573, EPA 608 Universal certified #1346255700410.",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
