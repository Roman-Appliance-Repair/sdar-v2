  },
  {
    "@context": "https://schema.org",
    "@type": "Brand",
    "@id": canonical + "#brand",
    "name": "Kamado Joe",
    "url": "https://www.kamadojoe.com/",
    "description": "Kamado Joe is an American ceramic kamado manufacturer founded in 2009 in Atlanta, Georgia. Acquired by Masterbuilt in 2018. Three live product lines: Classic II/III (Large equivalent), Big Joe II/III (XL equivalent), Konnected Joe (2023+, adds electric auto-ignition, integrated digital control, iKamand smart hub, automatic damper actuator). Konnected Joe is the only electric kamado in this brand pool. More accessory-rich than Big Green Egg (divider grates, charcoal basket, multiple deflector plates ship standard)."
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Outdoor", "item": "https://samedayappliance.repair/outdoor/" },
      { "@type": "ListItem", "position": 3, "name": "Smoker Repair", "item": "https://samedayappliance.repair/outdoor/smoker-repair/" },
