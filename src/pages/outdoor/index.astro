---
// src/pages/outdoor/index.astro
// 5-niche architecture — Outdoor appliance hub.
import Layout from '../../layouts/Layout.astro';
import ServiceHero from '../../components/ServiceHero.astro';
import { MAIN_PHONE } from '../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;

const title = "Outdoor Appliance Repair Los Angeles — Grills · Fireplaces · Patio Heaters · Outdoor Kitchens | Same Day Appliance Repair";
const description = `Outdoor appliance repair across LA, Orange, Ventura, San Bernardino & Riverside counties. BBQ grills, gas fireplaces, patio heaters, full outdoor kitchens. Lynx, Wolf, Viking, Alfresco, Bromic, Infratech. Quote-based pricing. Call ${phone}.`;
const canonical = "https://samedayappliance.repair/outdoor/";

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Outdoor Appliance Repair",
  "name": "Outdoor Appliance Repair — Same Day Appliance Repair",
  "url": canonical,
  "description": "Outdoor appliance repair across all five SoCal counties — BBQ grills, gas fireplaces, patio heaters, outdoor kitchens. Premium brands: Lynx, Wolf, Viking, Alfresco, Twin Eagles, Hestan, Bromic, Infratech.",
  "provider": { "@type": "LocalBusiness", "name": "Same Day Appliance Repair", "url": "https://samedayappliance.repair/", "telephone": phone, "priceRange": "$$$" },
  "areaServed": [
    { "@type": "AdministrativeArea", "name": "Los Angeles County" },
    { "@type": "AdministrativeArea", "name": "Orange County" },
    { "@type": "AdministrativeArea", "name": "Ventura County" },
    { "@type": "AdministrativeArea", "name": "San Bernardino County" },
    { "@type": "AdministrativeArea", "name": "Riverside County" },
  ],
};
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <ServiceHero
    eyebrow="LA · Orange · Ventura · San Bernardino · Riverside Counties"
    title="Outdoor Appliance Repair Across Southern California"
    subtitle="BBQ grills, gas fireplaces, patio heaters, full outdoor kitchens. Lynx, Wolf, Viking, Alfresco, Twin Eagles, Bromic, Infratech specialists. Quote-based pricing — every outdoor install is different. Same-day across five SoCal counties."
    heroImageTitle="Outdoor Appliance Repair"
    showBranches={true}
  />

  <section class="section">
    <div class="container narrow">
      <p class="section-number">Outdoor service hub</p>
      <h2>Outdoor appliance repair — built different from indoor service.</h2>
      <p>Southern California outdoor living is a year-round market. Our outdoor service covers four primary categories: <a href="/outdoor/grill-repair/">premium BBQ grills</a>, <a href="/outdoor/fireplace-repair/">gas fireplaces</a> (indoor and outdoor), <a href="/outdoor/patio-heater-repair/">patio heaters</a>, and full <a href="/outdoor/kitchen-repair/">outdoor kitchens</a> (built-in suites with grill + refrigeration + sink + side burners). Each has its own failure tree, brand catalog, and parts chain. We service across all five SoCal counties with same-day priority for events and entertaining bookings.</p>

      <p>Outdoor pricing is quote-based rather than flat-rate residential or commercial diagnostic. Reason: outdoor installs vary widely — a freestanding patio heater behind a Westwood condo is a different scope than a Trousdale Estate built-in BBQ + outdoor refrigerator suite. We give a written estimate at diagnostic before any work begins.</p>
    </div>
  </section>

  <section class="section section-gray">
    <div class="container">
      <h2>Outdoor service categories</h2>
      <div class="cat-grid">
        <a href="/outdoor/grill-repair/" class="cat-card">
          <h3>Outdoor Grill & BBQ Repair</h3>
          <p>Lynx, Wolf, Viking, Alfresco, Twin Eagles, Hestan, DCS, Fire Magic, TEC, Solaire. Built-in and freestanding. Igniters, burners, gas valves, rotisseries, infrared specialists.</p>
          <span class="cta">View service →</span>
        </a>
        <a href="/outdoor/fireplace-repair/" class="cat-card">
          <h3>Gas Fireplace Repair</h3>
          <p>Indoor and outdoor gas fireplaces — Heat & Glo, Mendota, Valor, Heatilator, Napoleon. Pilot light, gas valve, thermocouple, blower motor, control board service.</p>
          <span class="cta">View service →</span>
        </a>
        <a href="/outdoor/patio-heater-repair/" class="cat-card">
          <h3>Patio Heater Repair</h3>
          <p>Bromic, Infratech, Schwank, Fire Sense, AZ Patio Heaters. Mounted electric infrared and freestanding propane. Heating element, ignition, regulator, thermostat service.</p>
          <span class="cta">View service →</span>
        </a>
        <a href="/outdoor/kitchen-repair/" class="cat-card">
          <h3>Outdoor Kitchen Repair</h3>
          <p>Full outdoor kitchen suites — built-in grill + refrigeration + sink + ice maker + side burners. Coastal salt-air specialists. Lynx, Alfresco, DCS, Sub-Zero outdoor, Perlick HC.</p>
          <span class="cta">View service →</span>
        </a>
      </div>
    </div>
  </section>

  <section class="bottom-cta">
    <div class="container">
      <h2>Outdoor appliance down? We service across all five SoCal counties.</h2>
      <p>Quote-based pricing. Same-day priority for events and entertaining.</p>
      <div class="cta-row">
        <a href={phoneHref} class="btn-primary">☎ Call {phone}</a>
        <a href="/contact/" class="btn-secondary">Schedule Service</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .section { padding: 72px 24px; }
  .section-gray { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; }
  .container.narrow { max-width: 820px; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  .section h2 { font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 800; margin: 0 0 18px; color: var(--text); line-height: 1.2; }
  .section p { font-size: 1rem; line-height: 1.75; margin: 0 0 16px; color: var(--text); }
  .section a { color: var(--red); font-weight: 600; text-decoration: none; }
  .section a:hover { text-decoration: underline; }
  .cat-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 28px; }
  .cat-card { display: block; background: #fff; border: 1px solid var(--border); border-left: 4px solid var(--red); border-radius: 8px; padding: 24px 26px; text-decoration: none; color: var(--text); transition: transform .2s, box-shadow .2s; }
  .cat-card:hover { transform: translateY(-2px); box-shadow: 0 6px 18px rgba(0,0,0,0.08); }
  .cat-card h3 { font-size: 1.1rem; font-weight: 800; margin: 0 0 10px; color: var(--text); }
  .cat-card p { font-size: 0.9rem; line-height: 1.65; color: var(--muted); margin: 0 0 12px; }
  .cat-card .cta { font-size: 0.85rem; font-weight: 700; color: var(--red); }
  @media (max-width: 768px) { .cat-grid { grid-template-columns: 1fr; } }
  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { color: #fff; margin: 0 0 14px; font-size: 1.7rem; }
  .bottom-cta p { color: #c9c9c9; margin: 0 0 26px; }
  .cta-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 14px 28px; border-radius: 5px; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 14px 28px; border-radius: 5px; border: 2px solid rgba(255,255,255,0.35); font-weight: 600; text-decoration: none; }
</style>
