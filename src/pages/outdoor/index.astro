// src/pages/outdoor/index.astro
// PILLAR PAGE — outdoor cluster anchor. Parent-Read-Before-Child source for all sub-pages.
// v2.1 5-niche architecture, written per CLAUDE.md quality bar (1800-2200w, 4 schema entities).
import Layout from '../../layouts/Layout.astro';
import ServiceHero from '../../components/ServiceHero.astro';
import { MAIN_PHONE } from '../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/outdoor/";

const title = "Outdoor Appliance Repair Los Angeles — Same Day";
const description = "Premium outdoor appliance repair across SoCal: grills, gas fireplaces, patio heaters, outdoor refrigerators. Same-day service, EPA 608.";

const faqs = [
  {
    q: "How quickly can you come out for an outdoor appliance repair in LA?",
    a: "Same-day in most cases across LA, Orange, Ventura. Riverside and San Bernardino usually next-day. Phones answered 24/7. We dispatch technicians 8 AM to 8 PM Monday through Saturday."
  },
  {
    q: "Do you service Lynx, Fire Magic, DCS, and Twin Eagles?",
    a: "Yes. These are our most common premium brand calls. We carry Lynx igniter modules, Fire Magic burner kits, DCS regulators, and Twin Eagles control valves on the van for most repair scenarios."
  },
  {
    q: "My Bromic patio heater won't light. What's the typical cause?",
    a: "80% of the time it's the thermocouple (model BH8280036 on Tungsten Portable units), which corrodes from salt air on coastal patios. $36 to $80 part, 30-minute repair. The other 15% is the gas regulator, 5% is the ignition module."
  },
  {
    q: "Do you do gas conversions for old wood-burning fireplaces?",
    a: "Yes. SCAQMD Rule 445 restricts new wood-burning across most of SoCal, so most retrofits we see are gas conversions. We install new gas inserts in existing fireplace openings (Heat & Glo, Heatilator, Majestic). We don't do the masonry work; we partner with masons for that."
  },
  {
    q: "Are you EPA 608 certified for outdoor refrigerator work?",
    a: "Yes. EPA 608 Universal certification (#1346255700410) covers all refrigerant types we encounter in outdoor refrigerators (R-134a, R-290 in newer Sub-Zero outdoor units, R-600a in some U-Line models). Most outdoor-only repair shops aren't certified for this work."
  },
  {
    q: "What's your warranty?",
    a: "90 days parts and labor on every repair. If the same part fails within 90 days we come back and replace it free. No exceptions."
  },
  {
    q: "Do you work on outdoor kitchens in Malibu and Newport Beach?",
    a: "Yes. Both areas are core service territories for our West Hollywood and Irvine branches. Malibu coastal salt exposure means we stock extra thermocouples, igniters, and gasket sets. We know what fails near the water."
  }
];

