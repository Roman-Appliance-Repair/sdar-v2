---
// src/pages/outdoor/pizza-oven-repair/brands/ooni.astro
// Wave 7c — Ooni brand page (UK portable budget tier).
// Founded 2012 in Edinburgh, originally "Uuni", rebranded to Ooni in 2018.
// Models: Karu (multi-fuel), Koda (gas), Fyra (pellet), Pro (legacy multi-fuel),
// Volt (electric, newer). Year 6 replace tier conversation honesty. $120 outdoor
// universal. BHGS #A49573 + EPA 608 #1346255700410. Em-dash budget ≤2.

import Layout from '../../../../layouts/Layout.astro';
import ServiceHero from '../../../../components/ServiceHero.astro';
import { MAIN_PHONE } from '../../../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/outdoor/pizza-oven-repair/brands/ooni/";

const title = "Ooni Pizza Oven Repair LA | Karu, Koda, Fyra, Pro Service | $120";
const description = "Ooni Karu (multi-fuel), Koda (gas), Fyra (pellet), Pro (legacy) repair. UK-made portable. Year 6 replace tier honesty.";

const faqs = [
  {
    q: "My Ooni Koda 16 won't ignite. What's typically wrong?",
    a: "Three usual causes: piezo igniter clicker fatigue (most common, $40 to $80 part), regulator stuck in bypass mode after a propane tank swap (no parts, bleed-line reset), or burner orifice clogged with spider web debris ($120 dx, no parts to clear). We see these in roughly equal frequency. We test bypass mode first because it's the $0 fix."
  },
  {
    q: "Is my Ooni stone deck supposed to crack?",
    a: "Hairline cracks from thermal cycling are normal and don't affect cooking. Through-cracks where the stone is splitting into pieces mean the stone needs replacement. Most common cause of through-cracks: stone left outside through winter, absorbed moisture, then fired up cold. The thermal shock splits it. Replacement stone is $40 to $90 from Ooni's US distribution. Tip: store your Ooni indoors during the wet months, or at minimum keep the stone covered."
  },
  {
    q: "I have an Ooni Pro from 2017. Worth repairing at this point?",
    a: "Honest answer depends on the failure. Stone replacement, igniter, simple gas valve work: yes, repair on the Pro 16 still makes sense; it was a $700+ unit and remains a capable multi-fuel oven. Full burner module replacement on a year 8 Pro running $200+ in parts: probably skip. We'll tell you straight at the $120 dx whether your specific failure justifies the work or whether the Karu 16 / Pro replacement is the better call."
  },
  {
    q: "Can I convert my Ooni Karu from wood-only to gas?",
    a: "Yes on Karu 12 and Karu 16; the Ooni gas burner accessory mounts to the rear of the oven. The conversion isn't always cleanly DIY-able if the burner mounting holes don't align or if the regulator hose interferes with cabinet placement. We do gas accessory installation as a $120 dx + parts service; the burner accessory itself runs $120 to $260 from Ooni. Karu 12G ships with integrated gas, no conversion needed."
  },
  {
    q: "How long does an Ooni typically last in LA backyards?",
    a: "Ooni Fyra and Karu 12 (entry tier): 4 to 6 years of regular use before major component failure. Karu 16 and Koda 16 (mid-tier): 6 to 9 years. Pro 16 (premium portable, discontinued): 7 to 10 years. Coastal salt-air installations (Malibu, Newport, Manhattan, Laguna) shorter on the gas burner module by 1 to 2 years. Our customers in inland Beverly Hills, Encino, and Calabasas regularly hit the upper end of these ranges."
  },
  {
    q: "What's your warranty?",
    a: "90 days SDAR labor warranty on every repair. BHGS #A49573 and EPA 608 Universal certified (#1346255700410). Note: Ooni's manufacturer warranty (3 years on most current models, 5 years on registered units) may cover some failures directly through Ooni's authorized service network. We recommend checking Ooni's warranty status before paying out-of-pocket; the $120 dx covers a written diagnostic report you can submit to Ooni for warranty triage."
  }
];

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": canonical + "#business",
    "name": "Same Day Appliance Repair",
    "url": canonical,
    "telephone": phone,
    "priceRange": "$$",
    "address": {
      "@type": "PostalAddress",
      
      "addressLocality": "Los Angeles",
      "addressRegion": "CA",
      "postalCode": "90048",
      "addressCountry": "US"
    },
    "openingHoursSpecification": [
      { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "08:00", "closes": "20:00" }
    ],
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": canonical + "#service",
    "serviceType": "Ooni Pizza Oven Repair",
    "name": "Ooni Pizza Oven Diagnostic and Repair",
    "url": canonical,
    "description": "Residential Ooni pizza oven repair across all five SoCal counties. Karu (multi-fuel wood/gas/charcoal), Koda (gas), Fyra (pellet), Pro (legacy multi-fuel), Volt (electric). Piezo igniter replacement, gas burner orifice cleaning, regulator bypass reset, stone hearth replacement, gas conversion accessory installation on Karu 12 and Karu 16. Year 6+ replace-vs-repair honest conversation on entry-tier Fyra and Karu 12. Manufacturer warranty triage support (Ooni 3-year standard, 5-year registered). BHGS #A49573 and EPA 608 Universal certified (#1346255700410). $120 outdoor diagnostic.",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "offers": {
      "@type": "Offer",
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "120.00",
        "priceCurrency": "USD",
        "description": "Commercial-tier outdoor diagnostic fee, applied toward repair"
      }
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "Brand",
    "name": "Ooni",
    "description": "UK-based portable pizza oven manufacturer founded 2012 in Edinburgh (originally Uuni, rebranded 2018). Karu, Koda, Fyra, Pro, Volt model lines.",
    "url": "https://ooni.com/"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Outdoor", "item": "https://samedayappliance.repair/outdoor/" },
      { "@type": "ListItem", "position": 3, "name": "Pizza Oven Repair", "item": "https://samedayappliance.repair/outdoor/pizza-oven-repair/" },
      { "@type": "ListItem", "position": 4, "name": "Ooni", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description}>

<Fragment slot="head-scripts">
  {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
</Fragment>

<ServiceHero
  eyebrow="Karu · Koda · Fyra · Pro · Volt · UK-Made Portable · $120 Diagnostic"
  title="Ooni Pizza Oven Repair: Karu, Koda, Fyra, Pro Service"
  subtitle="Piezo igniter, gas burner orifice, stone deck, regulator bypass reset. Year 6 replace-tier honesty. Manufacturer warranty triage. $120 diagnostic across LA, OC, Ventura."
  heroImageTitle="Ooni Pizza Oven Repair"
  showBranches={true}
/>

<!-- 01 INTRO -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">01 · Ooni service</p>
    <h2 class="section-title">UK-made portable, growing fast in LA backyards.</h2>

    <p>Ooni is the dominant portable pizza oven brand in the Los Angeles backyard market. Founded 2012 in Edinburgh as Uuni (Finnish for "oven"), rebranded to Ooni in 2018. The brand owns the entry-to-mid portable tier with five active model lines: Karu (multi-fuel wood/gas/charcoal), Koda (gas), Fyra (pellet), Pro (legacy multi-fuel premium portable), and Volt (electric, newer category).</p>

    <p>We service Ooni 4 to 6 times a month from LA backyard owners. Most calls split between gas burner module issues (Koda, Karu gas-converted), stone deck cracking, and propane regulator bypass mode after tank swaps. Parts are inexpensive and well-stocked through Ooni's US distribution network — most repairs run $40 to $280 in parts.</p>

    <p><strong>$120 outdoor commercial-tier diagnostic, waived with repair.</strong> BHGS #A49573 and EPA 608 Universal certified (#1346255700410). 90-day SDAR labor warranty. Same-day across LA, OC, Ventura. Parent: <a href="/outdoor/pizza-oven-repair/">outdoor pizza oven repair pillar</a>.</p>
  </div>
</section>

<!-- 02 MODEL LINES -->
<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">02 · Ooni model lines</p>
    <h2 class="section-title">What we service across the catalog.</h2>

    <ul class="bullet-list">
      <li><strong>Karu 12 / Karu 16 / Karu 12G.</strong> Multi-fuel: wood, charcoal, and gas. Karu 12 and 16 use the optional Ooni gas burner accessory for gas mode; Karu 12G ships with integrated gas. Most flexible model line in the Ooni catalog. $400 to $700 unit cost depending on size and configuration. Most-serviced Ooni model in our area.</li>
      <li><strong>Koda 12 / Koda 16.</strong> Gas-only. Faster heat-up and easier cleanup vs multi-fuel. Most-bought Ooni model for first-time owners who don't want to deal with wood. $400 to $600.</li>
      <li><strong>Fyra 12.</strong> Pellet-fired. Entry-tier price ($300 to $400) with the wood-fire flavor without the wood-stacking complexity. Smallest cooking surface in the lineup.</li>
      <li><strong>Pro 16 (legacy).</strong> Discontinued but still common in LA backyards. Multi-fuel premium portable, $700+ at original retail. Robust build; year 7 to 10 service life realistic.</li>
      <li><strong>Volt 12.</strong> Newer electric model line. 110V, indoor-or-outdoor capable. Different service profile (no gas valve, no chimney) but heating element and control board failures eventually appear.</li>
    </ul>
  </div>
</section>

<!-- 03 COMMON FAILURES -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">03 · Common Ooni failures</p>
    <h2 class="section-title">In honest frequency order.</h2>

    <div class="cause-block">
      <h3>1. Piezo igniter clicker fatigue (year 2-4)</h3>
      <p>Most common Ooni service call. The mechanical piezo igniter wears out before electronic ignition modules would on built-in ovens. Symptom: clicker doesn't produce visible spark or the spark is weak. Replacement runs $40 to $80 part, in-line labor.</p>
    </div>

    <div class="cause-block">
      <h3>2. Propane regulator bypass mode (no parts most often)</h3>
      <p>Customer swaps propane tank, opens new tank valve too quickly, regulator clamps to bypass. Weak flame even with burner cranked high. Resolves at $120 dx with the bleed-line reset procedure (also covered on our <a href="/outdoor/grill-repair/regulator-issues/">grill regulator issues</a> page since the procedure is identical). If reset doesn't restore flame, regulator replacement runs $40 to $80.</p>
    </div>

    <div class="cause-block">
      <h3>3. Burner orifice clogged (spider webs, debris)</h3>
      <p>Outdoor pizza oven burners attract spiders and mud daubers. Webs and debris clog the burner orifice and starve flame. We clear at $120 dx with no parts. Twice-a-year inspection prevents this.</p>
    </div>

    <div class="cause-block">
      <h3>4. Stone deck cracking (thermal shock from moisture)</h3>
      <p>Stone left outside through wet months absorbs moisture, cracks when fired up cold. Hairline cracks are cosmetic and don't affect cooking; through-cracks need replacement. $40 to $90 stone, DIY-friendly install. We swap as part of $120 dx visit if you want us to.</p>
    </div>

    <div class="cause-block">
      <h3>5. Multi-fuel burner module fatigue (year 5-8 on Karu, Pro)</h3>
      <p>Gas burner accessory module on Karu and Pro develops valve creep, regulator drift, or burner block carbon fouling over years. Replacement module $120 to $260. At year 6+ on a Karu 12 ($400 unit), we have the replace-vs-repair conversation; at year 6+ on a Karu 16 or Pro 16 ($700+ unit), repair usually still makes sense.</p>
    </div>
  </div>
</section>

<!-- 04 REPLACE-TIER HONESTY -->
<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">04 · Ooni year 6+ replace conversation</p>
    <h2 class="section-title">Budget-tier portable repair math.</h2>

    <p>Ooni is the budget tier of the residential outdoor pizza oven market. That's not a knock — it's the right product for a $400 budget. But the math on year 6+ failures is different from built-in luxury repair.</p>

    <p>The replace-vs-repair line by model and failure:</p>

    <ul class="bullet-list">
      <li><strong>Year 0 to 4:</strong> any failure, repair. Parts cheap, unit value high relative to repair cost.</li>
      <li><strong>Year 5 to 6, simple failures (igniter, stone, regulator):</strong> repair. $40 to $90 in parts, makes sense on any model.</li>
      <li><strong>Year 5 to 6, complex failures (burner module, control assembly):</strong> case-by-case. Karu 12 / Fyra 12: probably replace at $400 new vs $260 repair. Karu 16 / Koda 16 / Pro 16: probably repair at $700+ unit value.</li>
      <li><strong>Year 7+, complex failures:</strong> usually replace on entry tier; repair makes sense on Karu 16 and Pro 16 if the failure is isolated.</li>
      <li><strong>Year 8+, any major failure:</strong> usually replace on any portable Ooni. The unit is at end of typical service life.</li>
    </ul>

    <p>We tell you straight at the $120 dx which side of the line your specific failure sits on. We don't push repair on units that should be replaced. We don't push replace on units that have years left. Honest math at the visit.</p>

    <p>Note on warranty: Ooni manufacturer warranty is 3 years standard, 5 years on registered units. Many failures we see fall inside that window. We charge the $120 diagnostic plus produce a written report you can submit to Ooni for warranty triage. If Ooni covers the repair, you've spent $120 to know what's wrong and have documentation; the actual fix is free. If Ooni declines or you're outside the window, we proceed with the repair and waive the $120 into the repair line.</p>
  </div>
</section>

<!-- 05 PRICING -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">05 · Pricing</p>
    <h2 class="section-title">Ooni repair costs.</h2>

    <table class="price-table">
      <thead>
        <tr><th>Repair</th><th>Cost</th></tr>
      </thead>
      <tbody>
        <tr><td>Diagnostic (outdoor commercial-tier, includes warranty report)</td><td>$120, waived with repair</td></tr>
        <tr><td>Piezo igniter replacement</td><td>$40 to $80</td></tr>
        <tr><td>Propane regulator replacement</td><td>$40 to $80</td></tr>
        <tr><td>Bypass mode reset (no parts)</td><td>Resolved at dx</td></tr>
        <tr><td>Burner orifice clean-out (spider/debris removal)</td><td>Resolved at dx, no parts</td></tr>
        <tr><td>Stone deck replacement (12-inch or 16-inch)</td><td>$40 to $90</td></tr>
        <tr><td>Gas burner accessory module (Karu 12, Karu 16)</td><td>$120 to $260</td></tr>
        <tr><td>Gas conversion installation on Karu (parts not included)</td><td>$120 dx + parts</td></tr>
        <tr><td>Hose replacement (degraded rubber)</td><td>$40 to $80</td></tr>
        <tr><td>Volt heating element (electric model)</td><td>$160 to $260</td></tr>
        <tr><td>Volt control board</td><td>$220 to $380</td></tr>
        <tr><td>Manufacturer warranty diagnostic report (no repair)</td><td>$120 dx fee only</td></tr>
        <tr><td>Warranty</td><td>90 days SDAR labor on our work</td></tr>
      </tbody>
    </table>
  </div>
</section>

<!-- 06 LA MARKET -->
<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">06 · LA backyard market</p>
    <h2 class="section-title">Ooni grew fastest in 2022-2024.</h2>

    <p>Ooni installations in LA backyards exploded during the post-pandemic outdoor entertainment investment cycle. Karu 16 and Koda 16 are the volume sellers. Pro 16 lingered through 2022 before discontinuation; we still see them regularly in service. Fyra 12 and Karu 12 dominate the entry-tier first-buy market. Volt 12 (electric) is a newer category we're now starting to see service calls on.</p>

    <p>Coverage by branch:</p>
    <ul class="bullet-list">
      <li><strong>West Hollywood, Beverly Hills, Pasadena (LA core):</strong> highest Ooni density. Karu 16 and Koda 16 dominate.</li>
      <li><strong>Thousand Oaks (Ventura):</strong> Calabasas, Westlake, Hidden Hills backyards heavy on multi-fuel Karu units.</li>
      <li><strong>Irvine (OC):</strong> Newport, Laguna, Coto. Coastal salt-air installations with shorter gas burner module life.</li>
      <li><strong>Rancho Cucamonga, Temecula:</strong> growing Ooni base 2023+. Inland heat doesn't significantly affect oven life.</li>
    </ul>

    <p>Service notes: coastal salt-air installations (Malibu, Manhattan, Newport, Laguna) see gas burner module failures 1 to 2 years earlier than inland. We stock gas burner accessory modules in Irvine and West Hollywood for same-day work on coastal Karu calls.</p>
  </div>
</section>

<!-- 07 WHY US -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">07 · Why Ooni owners call us</p>
    <h2 class="section-title">Seven reasons.</h2>

    <ul class="why-list">
      <li><strong>Year 6+ replace-vs-repair honesty.</strong> Budget-tier math; we don't push $260 repairs on $400 units past their service life.</li>
      <li><strong>Manufacturer warranty triage support.</strong> Ooni 3-year standard / 5-year registered; we produce diagnostic report for warranty submission.</li>
      <li><strong>Bypass mode checked first on low-flame calls.</strong> $0 fix when applicable; same procedure as our <a href="/outdoor/grill-repair/regulator-issues/">grill regulator</a> work.</li>
      <li><strong>Gas conversion installation on Karu 12 and Karu 16.</strong> Proper mounting, regulator hose routing, manometer pressure verification.</li>
      <li><strong>Spider/debris orifice clean-out.</strong> Recurring issue on outdoor Ooni installations; quick fix at dx.</li>
      <li><strong>BHGS #A49573 and EPA 608 Universal certified (#1346255700410).</strong> See our <a href="/credentials/licensed/">licensing page</a>.</li>
      <li><strong>$120 outdoor diagnostic, no after-hours surcharge.</strong> Same-day across LA, OC, Ventura.</li>
    </ul>
  </div>
</section>

<!-- 08 FAQ -->
<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">08 · FAQ</p>
    <h2 class="section-title">Ooni repair, common questions.</h2>

    <div class="faq-list">
      {faqs.map(f => (
        <details class="faq-item">
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- 09 BOTTOM CTA -->
<section class="bottom-cta">
  <div class="container">
    <h2>Ooni issue? Call today.</h2>
    <p>$120 outdoor diagnostic. Year 6+ replace honesty. Ooni warranty triage support. BHGS #A49573.</p>
    <div class="cta-row">
      <a href={phoneHref} class="btn-primary">☎ Call {phone}</a>
      <a href="/contact/" class="btn-secondary">Book Online</a>
    </div>
  </div>
</section>

</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .section { padding: 64px 24px; }
  .section-gray { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; }
  .container.narrow { max-width: 820px; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  h2.section-title { font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 800; margin: 0 0 16px; line-height: 1.2; color: var(--text); letter-spacing: -0.01em; }
  .section p { margin: 0 0 18px; font-size: 1rem; line-height: 1.75; color: var(--text); }
  .section a { color: var(--red); font-weight: 600; text-decoration: none; }
  .section a:hover { text-decoration: underline; }
  .cause-block { background: #fff; border: 1px solid var(--border); border-left: 4px solid var(--red); border-radius: 8px; padding: 22px 26px; margin-bottom: 16px; }
  .cause-block h3 { font-size: 1.05rem; font-weight: 800; margin: 0 0 10px; color: var(--text); }
  .cause-block p { font-size: 0.96rem; line-height: 1.7; margin: 0; }
  .cause-block strong { color: var(--text); }
  .bullet-list { padding-left: 22px; margin: 14px 0; }
  .bullet-list li { font-size: 0.98rem; line-height: 1.7; color: var(--text); margin-bottom: 10px; }
  .bullet-list strong { color: var(--text); font-weight: 700; }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 22px; background: #fff; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
  .price-table th, .price-table td { padding: 12px 16px; text-align: left; border-bottom: 1px solid var(--border); font-size: 0.95rem; }
  .price-table th { background: var(--gray); font-weight: 700; color: var(--text); letter-spacing: 0.02em; }
  .price-table tr:last-child td { border-bottom: none; }
  .why-list { padding-left: 22px; margin: 18px 0; }
  .why-list li { font-size: 1rem; line-height: 1.7; color: var(--text); margin-bottom: 12px; }
  .why-list strong { color: var(--text); font-weight: 700; }
  .faq-list { margin-top: 24px; }
  .faq-item { background: #fff; border: 1px solid var(--border); border-radius: 6px; padding: 16px 22px; margin-bottom: 10px; }
  .faq-item summary { font-weight: 700; cursor: pointer; font-size: 0.98rem; color: var(--text); list-style: none; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::before { content: "+ "; color: var(--red); font-weight: 800; margin-right: 6px; }
  .faq-item[open] summary::before { content: "− "; }
  .faq-item p { font-size: 0.93rem; color: var(--text); line-height: 1.7; margin: 12px 0 0; }
  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { color: #fff; margin: 0 0 14px; font-size: clamp(1.5rem, 3vw, 2rem); }
  .bottom-cta p { color: #aaa; margin: 0 0 28px; font-size: 1.02rem; }
  .cta-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 14px 28px; border-radius: 5px; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 14px 28px; border-radius: 5px; border: 2px solid rgba(255,255,255,0.35); font-weight: 600; text-decoration: none; }
</style>
