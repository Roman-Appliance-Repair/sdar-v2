---
// src/pages/outdoor/grill-repair.astro
// 5-niche architecture — Outdoor BBQ grill repair hub.
import Layout from '../../layouts/Layout.astro';
import ServiceHero from '../../components/ServiceHero.astro';
import { MAIN_PHONE } from '../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;

const title = "Outdoor Grill & BBQ Repair Los Angeles — Lynx · Wolf · Viking · Alfresco | Same Day Appliance Repair";
const description = `Premium BBQ grill repair across LA, Orange, Ventura, San Bernardino & Riverside counties. Built-in and freestanding. Lynx, Wolf Outdoor, Viking, Alfresco, Twin Eagles, Hestan, DCS, Fire Magic, TEC, Solaire. Beverly Hills, Malibu, Bel Air estate kitchens. Quote-based pricing. Call ${phone}.`;
const canonical = "https://samedayappliance.repair/outdoor/grill-repair/";

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Outdoor Grill and BBQ Repair",
  "name": "Outdoor Grill and BBQ Repair — Same Day Appliance Repair",
  "url": canonical,
  "description": "Premium outdoor BBQ grill repair across all five SoCal counties. Built-in and freestanding luxury grills — Lynx, Wolf Outdoor, Viking, Alfresco, Twin Eagles, Hestan, DCS, Fire Magic, TEC infrared, Solaire infrared.",
  "provider": { "@type": "LocalBusiness", "name": "Same Day Appliance Repair", "url": "https://samedayappliance.repair/", "telephone": phone, "priceRange": "$$$" },
  "areaServed": [
    { "@type": "AdministrativeArea", "name": "Los Angeles County" },
    { "@type": "AdministrativeArea", "name": "Orange County" },
    { "@type": "AdministrativeArea", "name": "Ventura County" },
    { "@type": "AdministrativeArea", "name": "San Bernardino County" },
    { "@type": "AdministrativeArea", "name": "Riverside County" },
  ],
};
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <ServiceHero
    eyebrow="LA · Orange · Ventura · San Bernardino · Riverside Counties"
    title="Outdoor Grill & BBQ Repair Across Southern California"
    subtitle="Premium built-in and freestanding grills. Lynx, Wolf Outdoor, Viking, Alfresco, Twin Eagles, Hestan, DCS, Fire Magic, TEC and Solaire infrared specialists. Beverly Hills, Malibu, Bel Air estate kitchens. Quote-based pricing — every install is different."
    heroImageTitle="Outdoor Grill Repair"
    showBranches={true}
  />

  <section class="section">
    <div class="container narrow">
      <p class="section-number">Premium outdoor grill service</p>
      <h2>Built-in BBQ repair — the LA luxury outdoor kitchen segment.</h2>

      <p>Beverly Hills, Bel Air, Trousdale Estates, Malibu, Pacific Palisades, Newport Coast — the premium outdoor kitchen market in Southern California is concentrated in a small number of high-spec installations. Our techs service across the full premium catalog: <strong>Lynx Professional</strong> (L54PSR, L36PSR, Asado series), <strong>Wolf Outdoor</strong> (OG series), <strong>Viking Outdoor</strong> (VGBQ series), <strong>Alfresco</strong> (ALXE-56, ALXE-42), <strong>Twin Eagles</strong> (TEBQ36R, TEBQ54R), <strong>Hestan</strong> (GMBR series), <strong>DCS by Fisher & Paykel</strong> (BH1 series), <strong>Fire Magic Aurora</strong>, <strong>TEC Sterling / Patio FR</strong> (infrared specialists), and <strong>Solaire</strong> (infrared dedicated). Built-in or freestanding — same diagnostic approach, different access.</p>

      <p>The most common failure tree on premium built-in grills is straightforward: corroded spark electrode (cleaning resolves about 35% of "won't ignite" calls at no parts cost), failed ignition switch under the burner knob, gas valve stuck or seized, rotisserie motor wear, and the infrared-specific failure modes on TEC and Solaire (cracked ceramic emitters that aren't field-repairable). Coastal-adjacent installations in Malibu, Pacific Palisades, and Newport Coast see accelerated burner corrosion from salt air — we recommend coastal maintenance every 6 months versus annually inland.</p>

      <p>For estate-specific service: <a href="/outdoor/grill-repair-beverly-hills/">Beverly Hills BBQ repair</a> covers Trousdale, the Flats, and Holmby Hills with discreet event-prep priority. For full-kitchen service, see <a href="/outdoor/kitchen-repair/">outdoor kitchen repair</a> (grill + refrigeration + sink suite). For coastal Malibu installations, see <a href="/outdoor/kitchen-repair-malibu/">Malibu outdoor kitchen repair</a>.</p>
    </div>
  </section>

  <section class="bottom-cta">
    <div class="container">
      <h2>BBQ down before an event? We respond same-day.</h2>
      <p>Quote-based pricing. Premium built-in and freestanding grill specialists across all five SoCal counties.</p>
      <div class="cta-row">
        <a href={phoneHref} class="btn-primary">☎ Call {phone}</a>
        <a href="/contact/" class="btn-secondary">Schedule Service</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .section { padding: 72px 24px; }
  .container { max-width: 1100px; margin: 0 auto; }
  .container.narrow { max-width: 820px; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  .section h2 { font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 800; margin: 0 0 18px; color: var(--text); line-height: 1.2; }
  .section p { font-size: 1rem; line-height: 1.75; margin: 0 0 16px; color: var(--text); }
  .section a { color: var(--red); font-weight: 600; text-decoration: none; }
  .section a:hover { text-decoration: underline; }
  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { color: #fff; margin: 0 0 14px; font-size: 1.7rem; }
  .bottom-cta p { color: #c9c9c9; margin: 0 0 26px; }
  .cta-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 14px 28px; border-radius: 5px; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 14px 28px; border-radius: 5px; border: 2px solid rgba(255,255,255,0.35); font-weight: 600; text-decoration: none; }
</style>
