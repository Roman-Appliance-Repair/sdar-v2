---
// src/pages/outdoor/fireplace-repair.astro
// 5-niche architecture — Gas fireplace repair (covers residential indoor + outdoor).
import Layout from '../../layouts/Layout.astro';
import ServiceHero from '../../components/ServiceHero.astro';
import { MAIN_PHONE } from '../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;

const title = "Gas Fireplace Repair Los Angeles — Indoor & Outdoor | Same Day Appliance Repair";
const description = `Gas fireplace repair across LA, Orange, Ventura, San Bernardino & Riverside counties. Indoor and outdoor units. Heat & Glo, Mendota, Valor, Heatilator, Napoleon, Majestic. Pilot light, gas valve, thermocouple, blower motor, control board. Quote-based pricing. Call ${phone}.`;
const canonical = "https://samedayappliance.repair/outdoor/fireplace-repair/";

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Gas Fireplace Repair",
  "name": "Gas Fireplace Repair — Same Day Appliance Repair",
  "url": canonical,
  "description": "Indoor and outdoor gas fireplace repair across all five SoCal counties. Heat & Glo, Mendota, Valor, Heatilator, Napoleon, Majestic, Lennox Hearth.",
  "provider": { "@type": "LocalBusiness", "name": "Same Day Appliance Repair", "url": "https://samedayappliance.repair/", "telephone": phone, "priceRange": "$$" },
  "areaServed": [
    { "@type": "AdministrativeArea", "name": "Los Angeles County" },
    { "@type": "AdministrativeArea", "name": "Orange County" },
    { "@type": "AdministrativeArea", "name": "Ventura County" },
    { "@type": "AdministrativeArea", "name": "San Bernardino County" },
    { "@type": "AdministrativeArea", "name": "Riverside County" },
  ],
};
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <ServiceHero
    eyebrow="LA · Orange · Ventura · San Bernardino · Riverside Counties"
    title="Gas Fireplace Repair — Indoor & Outdoor"
    subtitle="Pilot light failures, gas valve service, thermocouple replacement, blower motor wear, control board diagnostics. Heat & Glo, Mendota, Valor, Heatilator, Napoleon, Majestic. Quote-based pricing across five SoCal counties. Note: SCAQMD restrictions exclude wood-burning units — gas only."
    heroImageTitle="Gas Fireplace Repair"
    showBranches={true}
  />

  <section class="section">
    <div class="container narrow">
      <p class="section-number">Gas fireplace service</p>
      <h2>Indoor and outdoor gas fireplace repair across Southern California.</h2>

      <p>Gas fireplaces — both indoor (recessed wall, freestanding, insert) and outdoor (covered patio, pool deck, full-suite outdoor kitchens) — sit in our outdoor service category because the diagnostic and parts chain overlap. We service all major brands: <strong>Heat &amp; Glo</strong>, <strong>Mendota</strong>, <strong>Valor</strong>, <strong>Heatilator</strong>, <strong>Napoleon</strong>, <strong>Majestic</strong>, <strong>Lennox Hearth</strong>, <strong>Regency</strong>, and <strong>Empire Comfort Systems</strong> across our 5-county footprint.</p>

      <p>The most common gas fireplace service categories: <strong>pilot light won't stay lit</strong> (failed thermocouple is the #1 cause; replacement $145-$245 with cleaning), <strong>burner won't ignite</strong> (gas valve, electronic ignition module, or thermopile failure), <strong>blower motor wear</strong> on units with forced-air heat distribution, <strong>remote control or wall-switch failures</strong> (often resolves at the receiver module rather than the fireplace itself), and <strong>annual maintenance / cleaning</strong> (recommended pre-season for indoor units, every 6 months coastal for outdoor units).</p>

      <p><strong>Important note on wood-burning fireplaces:</strong> SCAQMD (South Coast Air Quality Management District) Rule 445 restricts wood-burning fireplaces in our service area — we don't service wood-burning units, gas-log conversions only. If you're unsure whether your fireplace is gas, electric ignition, or wood-burning, call us and describe the unit; we'll confirm before scheduling.</p>

      <p>For full outdoor kitchen service (grill + refrigeration + sink + fireplace), see <a href="/outdoor/kitchen-repair/">outdoor kitchen repair</a>. For patio heating dedicated to outdoor entertaining, see <a href="/outdoor/patio-heater-repair/">patio heater repair</a>. For built-in BBQ service, see <a href="/outdoor/grill-repair/">outdoor grill repair</a>.</p>
    </div>
  </section>

  <section class="bottom-cta">
    <div class="container">
      <h2>Gas fireplace not working? We service across all five SoCal counties.</h2>
      <p>Quote-based pricing. Indoor and outdoor units, all major brands.</p>
      <div class="cta-row">
        <a href={phoneHref} class="btn-primary">☎ Call {phone}</a>
        <a href="/contact/" class="btn-secondary">Schedule Service</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; }
  .section { padding: 72px 24px; }
  .container { max-width: 1100px; margin: 0 auto; }
  .container.narrow { max-width: 820px; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  .section h2 { font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 800; margin: 0 0 18px; color: var(--text); line-height: 1.2; }
  .section p { font-size: 1rem; line-height: 1.75; margin: 0 0 16px; color: var(--text); }
  .section a { color: var(--red); font-weight: 600; text-decoration: none; }
  .section a:hover { text-decoration: underline; }
  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { color: #fff; margin: 0 0 14px; font-size: 1.7rem; }
  .bottom-cta p { color: #c9c9c9; margin: 0 0 26px; }
  .cta-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 14px 28px; border-radius: 5px; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 14px 28px; border-radius: 5px; border: 2px solid rgba(255,255,255,0.35); font-weight: 600; text-decoration: none; }
</style>
