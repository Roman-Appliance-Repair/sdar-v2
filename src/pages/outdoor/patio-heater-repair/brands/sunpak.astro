// src/pages/outdoor/patio-heater-repair/brands/sunpak.astro
// Wave 5a — Sunpak patio heater brand page (Texas USA, founded 1957).
// Oldest continuously-operating US patio heater manufacturer. Gas-only specialist.
// Black series, S25, S34, TSH (Two-Stage Heat). Wall and ceiling mount.
// $120 OUTDOOR diagnostic universal. BHGS #A49573, EPA 608 #1346255700410.
import Layout from '../../../../layouts/Layout.astro';
import ServiceHero from '../../../../components/ServiceHero.astro';
import { MAIN_PHONE } from '../../../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/outdoor/patio-heater-repair/brands/sunpak/";

const title = "Sunpak Patio Heater Repair Los Angeles — Same Day";
const description = `Sunpak gas patio heater repair across SoCal. Texas-made gas specialist since 1957. Restaurants + residential. $120 outdoor diagnostic.`;

const faqs = [
  {
    q: "Sunpak is the oldest US patio heater brand?",
    a: "Yes. Sunpak (Calcana Industries, Houston Texas) has been continuously manufacturing residential and commercial gas patio heaters since 1957, making it the oldest continuously-operating US patio heater manufacturer. Pre-dates the entire modern outdoor-heating industry. Long-running gas-only specialty (no electric variants) means deep parts catalog stability and field-serviceability that newer electric-focused brands don't always match. Restaurants and residential installations from the 1980s and 1990s are still serviceable today with OEM parts."
  },
  {
    q: "Pilot light won't stay lit on my Sunpak. What's wrong?",
    a: "Thermocouple failure, almost always at year 4-7. The thermocouple is the safety device that holds the gas valve open as long as it senses pilot flame heat. When it weakens, the valve closes back, pilot extinguishes, you can't light it again until thermocouple is replaced. Replacement runs $220 to $340 typical. We carry Sunpak thermocouples on the truck because this is the most common Sunpak service item. Sometimes paired with pilot-orifice cleaning if partial blockage is preventing proper flame."
  },
  {
    q: "Black series vs S25 vs S34. What's the difference?",
    a: "Black series is the entry residential tier (25,000 BTU, basic black housing). S25 is also 25,000 BTU but with stainless or champagne housing options. S34 is mid-tier 34,000 BTU for larger residential or light commercial coverage. TSH (Two-Stage Heat) is the premium variant with high/low burner switching, lets you run lower BTU for ambient warming or full BTU for cold weather. All four use similar internal architecture (burner head, gas valve, thermocouple, pilot system); housing and BTU output are the differentiators."
  },
  {
    q: "Gas valve diaphragm degradation - what does that look like?",
    a: "Year 7-10 typical pattern. Symptoms: slow ignition response (seconds longer than usual to light pilot), uneven flame at the burner (some flames yellow instead of crisp blue), or gas pressure regulation drift (heater runs but BTU output feels reduced). Multimeter and manometer test the gas valve and confirm. Full gas valve replacement runs $480 to $680 including the valve and labor. Some valves can be rebuilt with a seal kit ($200 to $340) instead, depending on the specific model and condition."
  },
  {
    q: "Burner head corrosion on coastal install. Repair scope?",
    a: "Coastal LA installations (Santa Monica, Manhattan Beach, Marina del Rey, Pacific Palisades, parts of Malibu) see accelerated burner head corrosion at year 6+. The burner head is a stainless or aluminum casting with precisely-machined gas ports; corrosion eats into the port edges and degrades flame quality. Replacement burner head runs $260 to $440 part plus install. Sometimes the entire burner assembly (head plus venturi) is replaced together, $440 to $680."
  },
  {
    q: "Do you service old Sunpak units from the 1990s?",
    a: "Yes. Sunpak's parts catalog stability means we can service units from the 1990s (and even some 1980s installations still in operation). Common service items (thermocouple, gas valve, pilot orifice, burner head) are still available through Sunpak's authorized US distribution. Older units often need cumulative service rather than single repair: thermocouple, gas valve, burner head, igniter all reaching end-of-life simultaneously. We do the math on whether multi-component repair pencils out vs replacement on a case-by-case basis."
  },
  {
    q: "What's your warranty?",
    a: "90 days SDAR labor and parts warranty on the work we perform. Sunpak component warranties (gas valve, thermocouple, burner) where applicable processed separately. BHGS #A49573, BBB A+ accredited, EPA 608 Universal certified #1346255700410."
  }
];

const schemaJsons = [
  {
    "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair", "url": canonical, "telephone": phone, "priceRange": "$$$",
    "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "08:00", "closes": "20:00" },
