    ]
  },
  {
    "@context": "https://schema.org", "@type": "Service", "@id": canonical + "#service",
    "serviceType": "Sunpak Patio Heater Repair", "name": "Sunpak Patio Heater Repair Service", "url": canonical,
    "description": "Sunpak gas patio heater repair across all five SoCal counties. Black series (entry residential 25,000 BTU), S25 (25,000 BTU stainless/champagne), S34 (mid-tier 34,000 BTU), TSH Two-Stage Heat (premium high/low burner switching). Natural gas and propane variants. Wall and ceiling mount. Service: pilot light issues, thermocouple replacement (year 4-7 most common single failure), gas valve diaphragm degradation (year 7-10), ignition spark module on electronic ignition variants, burner head corrosion (coastal LA marine layer year 6+), two-stage burner switch (TSH series). Restaurant and residential installations. Oldest US patio heater manufacturer (Texas, founded 1957). $120 outdoor diagnostic, waived with repair. BHGS #A49573, EPA 608 Universal certified #1346255700410.",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },{ "@type": "AdministrativeArea", "name": "Orange County" },{ "@type": "AdministrativeArea", "name": "Ventura County" },{ "@type": "AdministrativeArea", "name": "San Bernardino County" },{ "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "offers": { "@type": "Offer", "priceRange": "$120-$1200", "priceSpecification": { "@type": "PriceSpecification", "price": "120.00", "priceCurrency": "USD", "description": "Outdoor diagnostic fee, applied toward repair. No emergency surcharge." } },
    "brand": { "@id": canonical + "#brand" }
  },
  {
    "@context": "https://schema.org", "@type": "Brand", "@id": canonical + "#brand",
    "name": "Sunpak",
    "url": "https://www.sunpakheaters.com/",
    "description": "Sunpak (Calcana Industries, Houston Texas) is the oldest continuously-operating US patio heater manufacturer, founded in 1957. Gas-only specialty (no electric variants), natural gas and propane. Wall and ceiling mount. Restaurant and residential markets. Product lines: Black series (entry 25,000 BTU), S25 (25,000 BTU stainless/champagne housing), S34 (mid-tier 34,000 BTU), TSH (Two-Stage Heat premium with high/low burner switching). 60+ years of restaurant industry standard for gas-powered patio heating."
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  {
    "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Outdoor", "item": "https://samedayappliance.repair/outdoor/" },
      { "@type": "ListItem", "position": 3, "name": "Patio Heater Repair", "item": "https://samedayappliance.repair/outdoor/patio-heater-repair/" },
      { "@type": "ListItem", "position": 4, "name": "Sunpak", "item": canonical }
    ]
  }
];
