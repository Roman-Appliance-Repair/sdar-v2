// src/pages/outdoor/patio-heater-repair/brands/infratech.astro
// Wave 5a — Infratech patio heater brand page (Burbank CA, USA, founded 1965).
// Pure electric infrared, ceiling/wall-mount only. Hardwired 240V.
// Comfort series (W, WD), Motif series, C/CD commercial models.
// LOCAL ANGLE: Burbank-made (LA County local manufacturer).
// $120 OUTDOOR diagnostic universal. BHGS #A49573, EPA 608 #1346255700410.
import Layout from '../../../../layouts/Layout.astro';
import ServiceHero from '../../../../components/ServiceHero.astro';
import { MAIN_PHONE } from '../../../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/outdoor/patio-heater-repair/brands/infratech/";

const title = "Infratech Patio Heater Repair LA | Comfort, Motif Series — Made in Burbank — $120 Outdoor";
const description = `Infratech patio heater repair across SoCal. Made in Burbank since 1965. Comfort, Motif, C/CD electric infrared. $120 outdoor diagnostic.`;

const faqs = [
  {
    q: "Infratech is made in Burbank? Why does that matter?",
    a: "Yes, Infratech has been manufactured in Burbank California since 1965. The local manufacturing matters in three practical ways for LA service. (1) Parts logistics: replacement elements, control panels, and dimmers ship from Burbank, often next-day delivery to LA service technicians. (2) Engineering support: when we have a model-specific question on an older unit, the company is across town rather than across an ocean. (3) Authorized service network is concentrated in Southern California, which is rarely true for outdoor heating brands. We've serviced Infratech installations from year-1 new through year-25 vintage with consistent parts availability.",
  },
  {
    q: "How long do Infratech heating elements last in LA?",
    a: "Year 8 to 12 is typical for residential duty cycle (50 to 200 hours per year). Commercial duty cycle (8 to 14 hours daily at restaurant patios or hotel installations) compresses to year 5 to 8. Element type matters too: standard tungsten elements run 8 to 12 years, sealed-quartz elements (premium W and WD models) run 10 to 15 years. Replacement runs $340 to $540 typical including the element and labor.",
  },
  {
    q: "My Infratech control dimmer doesn't work right. What's wrong?",
    a: "Infratech control panels and dimmers fail in two patterns at year 5 to 9. (1) Dimmer slider mechanical wear: physical slider becomes intermittent, doesn't track smoothly through the wattage range. (2) Solid-state relay (in commercial C and CD models) failure: digital control sends signal but relay doesn't switch, element doesn't power. Diagnostic with multimeter identifies which path. Slider replacement runs $260 to $380; solid-state relay $340 to $540.",
  },
  {
    q: "Wiring junction at my Infratech corroded. Coastal home, marine layer?",
    a: "Yes, this is a common LA marine layer pattern at year 8+. Coastal LA homes (Santa Monica, Marina del Rey, Manhattan Beach, Pacific Palisades, parts of Malibu) see accelerated corrosion at the wiring junction box where the 240V hardwire meets the heater housing. Service runs $200 to $340: clean and inspect connections, replace any corroded wire nuts or terminal blocks, sometimes replace the junction box itself if structural rust is present. We seal connections with weatherproof compound to slow recurrence.",
  },
  {
    q: "Reflector damage from impact. Replaceable?",
    a: "Yes. Infratech reflectors (the polished metal panel behind the element that directs heat downward) are replaceable as separate parts. Damage from yard equipment, ladder contact during cleaning, or hardware fall during nearby cabinet work happens. Replacement reflectors run $140 to $260 part plus install. Replacement is straightforward; we keep common reflector sizes on the truck for the more common Comfort series models.",
  },
  {
    q: "Do you do new Infratech installations?",
    a: "No. New Infratech installation requires 240V electrical rough-in (electrician trade) and ceiling structural mounting (sometimes architect/engineer involvement for cantilevered mounting). We service existing installations only. We work with several LA-area electricians experienced with Infratech installations and can refer if you need new install help. We can confirm whether your existing electrical infrastructure supports a wattage upgrade if you're considering replacing an older unit with a higher-output model.",
  },
  {
    q: "What's your warranty?",
    a: "90 days SDAR labor and parts warranty on the work we perform. Infratech component warranties (heating element, control panel, dimmer) where applicable are processed separately. BHGS #A49573, BBB A+ accredited, EPA 608 Universal certified #1346255700410.",
  },
];

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": canonical + "#business",
    "name": "Same Day Appliance Repair",
    "url": canonical,
    "telephone": phone,
    "priceRange": "$$$",
    "openingHoursSpecification": [{ "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "08:00", "closes": "20:00" }],
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": canonical + "#service",
    "serviceType": "Infratech Patio Heater Repair",
    "name": "Infratech Patio Heater Repair Service",
    "url": canonical,
    "description": "Infratech electric infrared patio heater repair across all five SoCal counties. Comfort series (W, WD single and dual element), Motif series (slim profile contemporary), C and CD commercial-rated models. Wattage variants 1,500W, 2,500W, 3,000W, 4,000W. 240V hardwired ceiling and wall mount. Service: heating element replacement, control panel and dimmer service, wiring junction corrosion (LA marine layer in coastal homes), reflector damage replacement, solid-state relay (commercial). Beverly Hills, Hidden Hills, Pacific Palisades, Bel Air estate covered patios; restaurant and hotel commercial. Local Burbank manufacturer since 1965. $120 outdoor diagnostic, waived with repair. BHGS #A49573, EPA 608 Universal certified #1346255700410.",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" },
    ],
    "offers": { "@type": "Offer", "priceRange": "$120-$1200", "priceSpecification": { "@type": "PriceSpecification", "price": "120.00", "priceCurrency": "USD", "description": "Outdoor diagnostic fee, applied toward repair. No emergency surcharge." } },
    "brand": { "@id": canonical + "#brand" },
  },
  {
    "@context": "https://schema.org",
    "@type": "Brand",
    "@id": canonical + "#brand",
    "name": "Infratech",
    "url": "https://www.infratech-usa.com/",
    "description": "Infratech is an American electric infrared outdoor heating manufacturer founded in 1965, manufactured in Burbank, California. Pure electric infrared technology, ceiling and wall mount only, hardwired 240V (no gas variants). Premium residential and commercial outdoor heating: Beverly Hills pool houses, Hidden Hills outdoor kitchens, Pacific Palisades estates, restaurant and hotel installations. Product lines: Comfort series (W single-element, WD dual-element, 1,500-4,000W), Motif series (slim contemporary profile), C and CD models (commercial-rated with solid-state relay control).",
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Outdoor", "item": "https://samedayappliance.repair/outdoor/" },
      { "@type": "ListItem", "position": 3, "name": "Patio Heater Repair", "item": "https://samedayappliance.repair/outdoor/patio-heater-repair/" },
      { "@type": "ListItem", "position": 4, "name": "Infratech", "item": canonical },
    ],
  },
];
---

<Layout title={title} description={description} canonical={canonical}>
<Fragment slot="head-scripts">
  {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
</Fragment>

<ServiceHero
  eyebrow="Infratech · Made in Burbank Since 1965 · Electric Infrared · LA Same-Day"
  title="Infratech Patio Heater Repair Los Angeles"
  subtitle={`Comfort series, Motif series, C/CD commercial. 240V hardwired ceiling and wall mount. Beverly Hills pool houses, Hidden Hills estates, restaurant and hotel installations. $120 outdoor diagnostic. ${phone}`}
  heroImageTitle="Infratech Patio Heater Repair"
/>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Infratech service</p>
    <h2>Made in Burbank since 1965. Local manufacturer, local parts logistics, local engineering support.</h2>

    <p>Infratech is the American electric infrared outdoor heating manufacturer founded in 1965 and manufactured in Burbank, California. The local manufacturing matters in practical ways for LA service. Replacement elements, control panels, and dimmers ship from Burbank often next-day to our service technicians. When we have a model-specific question on an older unit, the company is across town. Authorized service network is concentrated in Southern California. We've serviced Infratech installations from year-1 new through year-25 vintage with consistent parts availability.</p>

    <p>Pure electric infrared design (no gas, no propane), ceiling and wall mount only, hardwired 240V. Common in Beverly Hills pool houses, Hidden Hills outdoor kitchens, Pacific Palisades and Bel Air estate covered patios, plus restaurant and hotel commercial installations across the LA metro.</p>

    <p>We service the full Infratech lineup across LA County, Orange, Ventura, San Bernardino, Riverside. <strong>Comfort series</strong> (W single-element, WD dual-element, 1,500-4,000W variants). <strong>Motif series</strong> (slim contemporary profile). <strong>C and CD models</strong> (commercial-rated with solid-state relay control). Black, White, Bronze, Stainless housing options.</p>

    <p>$120 outdoor diagnostic, waived with repair. <strong>BHGS #A49573</strong>. <strong>EPA 608 Universal certified #1346255700410</strong>. BBB A+. Phones answered 24/7. Parent: <a href="/outdoor/patio-heater-repair/">patio heater repair</a>.</p>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">Lineup and what fails</p>
    <h2 class="section-title">Infratech series and common service items.</h2>

    <h3 class="series-h3">Comfort series (W, WD)</h3>
    <p>The most common Infratech residential installation. W series is single-element (1,500W, 2,500W, 3,000W variants). WD series is dual-element (3,000W, 4,000W variants for larger coverage). Standard tungsten heating element with year 8-12 residential life expectancy. Black, White, Bronze, Stainless housing.</p>

    <h3 class="series-h3">Motif series</h3>
    <p>Slim contemporary profile aimed at design-forward residential applications. Same internal architecture as Comfort but with low-profile housing. Common in Beverly Hills and Hidden Hills modern-architecture estates.</p>

    <h3 class="series-h3">C and CD commercial models</h3>
    <p>Commercial-rated variants for restaurant patios, hotel rooftops, and high-duty-cycle installations. Solid-state relay control (vs simple slider on residential), digital interface available, higher build-quality tolerances. Year 5-8 element life on commercial 8-14 hour daily duty.</p>

    <h3 class="series-h3">Common service items</h3>
    <ul class="bullet-list">
      <li><strong>Heating element burnout</strong> (year 8-12 residential, 5-8 commercial): $340-540 typical replacement.</li>
      <li><strong>Control panel / dimmer slider failure</strong> (year 5-9): $260-440.</li>
      <li><strong>Wiring junction corrosion</strong> (LA marine layer, year 8+): $200-340 service.</li>
      <li><strong>Reflector damage</strong> (impact, ladder contact): $140-260 part plus install.</li>
      <li><strong>Solid-state relay</strong> (commercial C/CD models, year 8-12): $340-540.</li>
      <li><strong>Hardwire connection at junction box</strong> (year 10+ corrosion): $180-280.</li>
    </ul>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Common scenarios</p>
    <h2 class="section-title">Top Infratech repairs in our 5-county territory.</h2>
    <ol class="num-list">
      <li><strong>Heating element burnout (year 8-12 residential, 5-8 commercial).</strong> $340 to $540 typical replacement including element and labor.</li>
      <li><strong>Control panel slider intermittent (year 5-9).</strong> Mechanical wear on the slider track. $260 to $380 dimmer replacement.</li>
      <li><strong>Wiring junction box corrosion (LA marine layer year 8+).</strong> Coastal homes specifically. $200 to $340 service.</li>
      <li><strong>Solid-state relay failure (commercial C/CD models).</strong> Year 8-12 typical. $340 to $540.</li>
      <li><strong>Reflector damage replacement.</strong> $140 to $260 part plus install.</li>
      <li><strong>Hardwire connection corrosion at year 10+.</strong> $180 to $280.</li>
    </ol>
  </div>
</section>

<section class="section section-gray">
  <div class="container">
    <p class="section-number">Real repairs</p>
    <h2 class="section-title">Composite stories from the route.</h2>
    <div class="story-grid">
      <div class="story-card">
        <h3>Beverly Hills pool house, Infratech Comfort WD-3000W, 11 years old (residential)</h3>
        <p>Element burnout on one of the dual elements (paired tungsten elements wear at slightly different rates; replace as a pair when one fails). Replaced both elements with OEM Burbank-shipped parts. Total: $120 plus $440 elements plus $260 install = $820.</p>
      </div>
      <div class="story-card">
        <h3>Hidden Hills outdoor kitchen, Infratech Motif W-2500W, 7 years old</h3>
        <p>Control panel slider intermittent, didn't track from low to high smoothly. Replaced slider/dimmer assembly. Total: $120 plus $300 dimmer = $420.</p>
      </div>
      <div class="story-card">
        <h3>Manhattan Beach beach-area covered patio, Infratech Comfort W-2500W, 9 years old</h3>
        <p>Wiring junction box corrosion from coastal marine layer. Cleaned and replaced corroded wire nuts and terminal block, sealed with weatherproof compound. Total: $120 plus $200 service = $320.</p>
      </div>
      <div class="story-card">
        <h3>West Hollywood hotel rooftop, Infratech CD-4000W (commercial), 6 years old</h3>
        <p>Solid-state relay failure (commercial duty cycle). Replaced relay assembly, tested digital control panel function. Total: $120 plus $440 relay = $560. Hotel back to evening service same day.</p>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Honest scope</p>
    <h2 class="section-title">What we do for Infratech, and what we don't.</h2>

    <p><strong>We service:</strong></p>
    <ul class="bullet-list">
      <li>Comfort series W and WD (all wattage variants)</li>
      <li>Motif series (slim contemporary profile)</li>
      <li>C and CD commercial models with solid-state relay</li>
      <li>Heating element replacement (tungsten and sealed-quartz variants)</li>
      <li>Control panel slider and dimmer service</li>
      <li>Solid-state relay service (commercial)</li>
      <li>Wiring junction box service (LA marine layer corrosion)</li>
      <li>Reflector replacement (impact damage)</li>
    </ul>

    <p><strong>We don't do:</strong> new Infratech installation (240V electrical rough-in is electrician trade; ceiling structural mounting sometimes architect/engineer involvement); wattage upgrade beyond existing electrical service capacity (electrician trade for service upgrade); custom integration with whole-home automation (low-voltage integrator trade).</p>
