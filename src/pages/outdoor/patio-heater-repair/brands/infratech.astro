<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .section { padding: 72px 24px; }
  .section-gray { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; }
  .container.narrow { max-width: 820px; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  .section h2 { font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 800; margin: 0 0 18px; color: var(--text); line-height: 1.2; }
  .section p { font-size: 1rem; line-height: 1.75; margin: 0 0 16px; color: var(--text); }
  .section a { color: var(--red); font-weight: 600; text-decoration: none; }
  .section a:hover { text-decoration: underline; }
  .lead { font-size: 1.05rem; line-height: 1.75; color: var(--text); margin-bottom: 22px; }
  .series-h3 { font-size: 1.1rem; font-weight: 800; margin: 28px 0 10px; color: var(--text); }
  .num-list { padding-left: 22px; margin: 14px 0 0; }
  .num-list li { font-size: 0.98rem; line-height: 1.7; color: var(--text); margin-bottom: 10px; }
  .bullet-list { padding-left: 22px; margin: 14px 0 18px; }
  .bullet-list li { font-size: 1rem; line-height: 1.65; color: var(--text); margin-bottom: 6px; }
  .story-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 22px; margin-top: 28px; }
  .story-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 24px 22px; }
  .story-card h3 { font-size: 1rem; font-weight: 800; margin: 0 0 12px; color: var(--text); line-height: 1.35; }
  .story-card p { font-size: 0.95rem; color: var(--text); line-height: 1.7; margin: 0; }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 22px; background: #fff; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
  .price-table th, .price-table td { padding: 12px 16px; text-align: left; border-bottom: 1px solid var(--border); font-size: 0.95rem; }
  .price-table th { background: var(--gray); font-weight: 700; color: var(--text); }
  .price-table tr:last-child td { border-bottom: none; }
  .reasons-list { padding-left: 22px; margin: 18px 0 0; }
  .reasons-list li { font-size: 1rem; line-height: 1.75; color: var(--text); margin-bottom: 10px; }
  .faq-list { margin-top: 24px; }
  .faq-item { background: #fff; border: 1px solid var(--border); border-radius: 6px; padding: 18px 22px; margin-bottom: 12px; }
  .faq-item summary { font-weight: 700; cursor: pointer; font-size: 1rem; color: var(--text); list-style: none; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::before { content: "+ "; color: var(--red); font-weight: 800; margin-right: 6px; }
  .faq-item[open] summary::before { content: "− "; }
  .faq-item p { font-size: 0.95rem; color: var(--text); line-height: 1.75; margin: 14px 0 0; }
  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { color: #fff; margin: 0 0 14px; font-size: 1.7rem; }
  .bottom-cta p { color: #c9c9c9; margin: 0 0 26px; max-width: 720px; margin-left: auto; margin-right: auto; }
  .cta-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 14px 28px; border-radius: 5px; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 14px 28px; border-radius: 5px; border: 2px solid rgba(255,255,255,0.35); font-weight: 600; text-decoration: none; }
</style>
