---
// src/pages/outdoor/patio-heater-repair/brands/schwank.astro
// Wave 5a — Schwank patio heater brand page (German heritage 1933, NA ops Mississauga ON Canada).
// Patio Schwank residential, 2300/2400 commercial, supraSchwank premium German.
// Commercial heritage: 90+ years restaurant/industrial gas infrared heating.
// $120 OUTDOOR diagnostic universal. BHGS #A49573, EPA 608 #1346255700410.
import Layout from '../../../../layouts/Layout.astro';
import ServiceHero from '../../../../components/ServiceHero.astro';
import { MAIN_PHONE } from '../../../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/outdoor/patio-heater-repair/brands/schwank/";

const title = "Schwank Patio Heater Repair LA | Patio Schwank — Commercial Heritage Since 1933 — $120 Outdoor";
const description = `Schwank gas patio heater repair across SoCal. 90+ year German/Canadian commercial heritage. $120 outdoor diagnostic.`;

const faqs = [
  {
    q: "Schwank is German or Canadian?",
    a: "Both, depending on context. Schwank GmbH was founded in 1933 in Köln (Cologne) Germany and is the original parent. North American operations run through Schwank Ltd, headquartered in Mississauga Ontario Canada, which manages distribution and service across Canada and the US. Product engineering retains German heritage; some product lines (notably supraSchwank) are still designed in Germany. The 90+ year heritage is real: Schwank pioneered gas infrared heating in restaurant and industrial applications in the 1930s and 1940s.",
  },
  {
    q: "Patio Schwank vs commercial 2300/2400 series. Which is mine?",
    a: "Patio Schwank is the residential and light-commercial line, 30,000 to 50,000 BTU, designed for residential covered patios and small-restaurant patio service. 2300 series is mid-BTU commercial (institutional restaurant, hotel patios). 2400 series is high-BTU commercial (warehouse-adjacent outdoor heating, large restaurant patios). supraSchwank is the premium German-engineered tier with higher build quality and longer service life. We identify your specific model from the data plate during the diagnostic visit.",
  },
  {
    q: "My Schwank's burner head looks eroded. How serious?",
    a: "Burner head erosion is the dominant Schwank service item, especially on commercial-duty installations. Schwank's high-BTU output (compared to typical residential brands) puts more thermal stress on the burner head; over commercial duty cycle of 8 to 14 hours daily, the head erodes at year 6 to 9. Symptom: yellow flames at the burner instead of crisp blue, uneven heat distribution, BTU output feels reduced. Replacement burner head runs $340 to $540 part plus install. Sometimes paired with heat exchanger/emitter tile replacement if thermal stress damaged adjacent components ($440 to $680 additional).",
  },
  {
    q: "Gas regulator pressure issues - what should we know?",
    a: "Schwank's high-BTU output (especially 2400 series and supraSchwank) requires tight gas pressure regulation. Many Schwank installations were done with builder-grade gas regulators that aren't sized for the BTU draw; symptoms show as uneven flames, burner cycling, or thermal cutout when multiple Schwank units run simultaneously. Diagnostic includes manometer measurement of supply pressure under load. Fix is sometimes a regulator upgrade (plumber trade, $200 to $400) rather than a Schwank-side repair. We tell you straight when this is the case rather than replacing Schwank parts to mask a regulator issue.",
  },
  {
    q: "Heat exchanger / emitter tile damage. Replace or rebuild?",
    a: "Schwank emitter tiles are ceramic radiant elements that glow when the burner heats them. Year 7-10 typical for tile replacement on commercial duty cycle (longer on residential). Symptoms: cracked tiles visible during operation, uneven glow, reduced infrared output. Tile replacement runs $440 to $680 typical depending on model. Tiles are not rebuildable; replacement only. We carry common Patio Schwank and 2300 series tile sizes; less common 2400 and supraSchwank variants we order from authorized distribution.",
  },
  {
    q: "Do you service Schwank in restaurant chain installations?",
    a: "Yes. Schwank is common at LA restaurant chain outdoor patio installations because of the 90+ year commercial heritage and the high-BTU output that handles open-patio coverage. Commercial accounts get $120 outdoor diagnostic same as residential; we coordinate around service hours and provide written documentation for facility maintenance records. Multi-unit installations (4+ Schwank units on a single restaurant patio) get cumulative service efficiency.",
  },
  {
    q: "What's your warranty?",
    a: "90 days SDAR labor and parts warranty on the work we perform. Schwank component warranties (burner, gas valve, ignition, emitter tiles) where applicable processed separately. BHGS #A49573, BBB A+ accredited, EPA 608 Universal certified #1346255700410.",
  },
];

const schemaJsons = [
  {
    "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair", "url": canonical, "telephone": phone, "priceRange": "$$$",
    "openingHoursSpecification": [{ "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "08:00", "closes": "20:00" }],
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },{ "@type": "AdministrativeArea", "name": "Orange County" },{ "@type": "AdministrativeArea", "name": "Ventura County" },{ "@type": "AdministrativeArea", "name": "San Bernardino County" },{ "@type": "AdministrativeArea", "name": "Riverside County" },
    ],
  },
  {
    "@context": "https://schema.org", "@type": "Service", "@id": canonical + "#service",
    "serviceType": "Schwank Patio Heater Repair", "name": "Schwank Patio Heater Repair Service", "url": canonical,
    "description": "Schwank gas patio heater repair across all five SoCal counties. Patio Schwank (residential / light-commercial 30,000-50,000 BTU), 2300 series (commercial mid-BTU), 2400 series (commercial high-BTU), supraSchwank (premium German-engineered). Natural gas and propane variants. Service: burner head erosion (commercial duty cycle year 6-9), gas regulator pressure diagnostic and recommendation, thermocouple replacement, ignition module failure (electronic ignition variants), heat exchanger / ceramic emitter tile damage (year 7-10 commercial), wall mount bracket corrosion (coastal commercial). 90+ years of restaurant and industrial gas infrared heating heritage. $120 outdoor diagnostic, waived with repair. BHGS #A49573, EPA 608 Universal certified #1346255700410.",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },{ "@type": "AdministrativeArea", "name": "Orange County" },{ "@type": "AdministrativeArea", "name": "Ventura County" },{ "@type": "AdministrativeArea", "name": "San Bernardino County" },{ "@type": "AdministrativeArea", "name": "Riverside County" },
    ],
    "offers": { "@type": "Offer", "priceRange": "$120-$1500", "priceSpecification": { "@type": "PriceSpecification", "price": "120.00", "priceCurrency": "USD", "description": "Outdoor diagnostic fee, applied toward repair. No emergency surcharge." } },
    "brand": { "@id": canonical + "#brand" },
  },
  {
    "@context": "https://schema.org", "@type": "Brand", "@id": canonical + "#brand",
    "name": "Schwank",
    "url": "https://www.schwankgroup.com/",
    "description": "Schwank is a German gas infrared heating manufacturer founded in 1933 in Köln (Cologne) Germany. North American operations run through Schwank Ltd in Mississauga Ontario Canada. 90+ years of restaurant and industrial gas infrared heating heritage. The Patio Schwank residential line inherits commercial-grade duty-cycle build from the parent product line. Product lines: Patio Schwank (residential / light-commercial 30,000-50,000 BTU), 2300 series (commercial mid-BTU), 2400 series (commercial high-BTU), supraSchwank (premium German-engineered tier). Natural gas and propane variants.",
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  {
    "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Outdoor", "item": "https://samedayappliance.repair/outdoor/" },
      { "@type": "ListItem", "position": 3, "name": "Patio Heater Repair", "item": "https://samedayappliance.repair/outdoor/patio-heater-repair/" },
      { "@type": "ListItem", "position": 4, "name": "Schwank", "item": canonical },
    ],
  },
];
---

<Layout title={title} description={description} canonical={canonical}>
<Fragment slot="head-scripts">
  {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
</Fragment>

<ServiceHero
  eyebrow="Schwank · German Heritage 1933 · Restaurant Commercial Specialist"
  title="Schwank Patio Heater Repair Los Angeles"
  subtitle={`Patio Schwank residential, 2300/2400 commercial, supraSchwank premium. 90+ years restaurant heritage. Natural gas and propane. $120 outdoor diagnostic, waived with repair. ${phone}`}
  heroImageTitle="Schwank Patio Heater Repair"
/>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Schwank service</p>
    <h2>90+ years of restaurant and industrial gas infrared heating. The Patio Schwank residential line inherits commercial-grade build.</h2>

    <p>Schwank is the German gas infrared heating manufacturer founded in 1933 in Köln (Cologne). North American operations run through Schwank Ltd in Mississauga Ontario Canada. Schwank pioneered commercial gas infrared heating in restaurants and industrial applications in the 1930s and 1940s; the brand has been a restaurant industry standard for nearly a century. The Patio Schwank residential line, launched later, inherits commercial-grade duty-cycle build from the parent product family.</p>

    <p>Common LA installations: restaurant chain outdoor patios (especially venues with high-BTU coverage requirements), hotel patios with cold-climate-equivalent expectations, residential covered patios in cooler microclimates (Beverly Hills, Pasadena, Hidden Hills), and warehouse-adjacent commercial outdoor heating.</p>

    <p>We service the full Schwank lineup across LA County, Orange, Ventura, San Bernardino, Riverside. <strong>Patio Schwank</strong> (residential / light-commercial, 30,000-50,000 BTU). <strong>2300 series</strong> (commercial mid-BTU). <strong>2400 series</strong> (commercial high-BTU). <strong>supraSchwank</strong> (premium German-engineered tier). Natural gas and propane variants on all lines.</p>

    <p>$120 outdoor diagnostic, waived with repair. <strong>BHGS #A49573</strong>. <strong>EPA 608 Universal certified #1346255700410</strong>. BBB A+. Phones answered 24/7. Parent: <a href="/outdoor/patio-heater-repair/">patio heater repair</a>.</p>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">Lineup and what fails</p>
    <h2 class="section-title">Schwank series and common service items.</h2>

    <h3 class="series-h3">Patio Schwank (residential / light-commercial)</h3>
    <p>The residential line. 30,000-50,000 BTU. Common at residential covered patios and small-restaurant patio installations. Service items: thermocouple, ignition module, gas valve, burner head.</p>

    <h3 class="series-h3">2300 series (commercial mid-BTU)</h3>
    <p>Mid-tier commercial for institutional restaurant and hotel patio service. Higher BTU output than Patio Schwank; commercial duty cycle expected. Burner head erosion is the dominant service item at year 6-9 commercial.</p>

    <h3 class="series-h3">2400 series (commercial high-BTU)</h3>
    <p>High-BTU commercial for warehouse-adjacent and large-restaurant-patio applications. Most demanding service profile; emitter tile and burner head wear faster than mid-BTU lines. Year 5-7 typical for commercial-duty service items on this line.</p>

    <h3 class="series-h3">supraSchwank (premium German-engineered)</h3>
    <p>Premium tier with German engineering retained. Higher build quality, longer service life under same duty cycle. Less common in LA but present at high-end installations.</p>

    <h3 class="series-h3">Common service items</h3>
    <ul class="bullet-list">
      <li><strong>Burner head erosion</strong> (commercial duty year 6-9, residential year 10-15): $340-540 head, or $440-680 burner assembly.</li>
      <li><strong>Gas regulator pressure issues</strong> (system-level, often plumber referral): manometer diagnostic, $200-400 plumber regulator upgrade.</li>
      <li><strong>Thermocouple replacement</strong> (year 4-7): $220-340.</li>
      <li><strong>Ignition module</strong> (electronic ignition variants, year 5-8): $260-440.</li>
      <li><strong>Heat exchanger / ceramic emitter tile damage</strong> (year 7-10 commercial): $440-680.</li>
      <li><strong>Wall mount bracket corrosion</strong> (coastal commercial year 6+): $200-340.</li>
    </ul>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Common scenarios</p>
    <h2 class="section-title">Top Schwank repairs in our 5-county territory.</h2>
    <ol class="num-list">
      <li><strong>Burner head erosion (commercial duty cycle year 6-9, #1 Schwank service item).</strong> $340-540 head plus install.</li>
      <li><strong>Emitter tile cracked/damaged (year 7-10 commercial).</strong> $440-680.</li>
      <li><strong>Gas regulator pressure issues.</strong> System-level diagnostic, often plumber referral for upsizing.</li>
      <li><strong>Thermocouple replacement (year 4-7).</strong> $220-340.</li>
      <li><strong>Ignition module failure.</strong> $260-440.</li>
