---
// src/pages/outdoor/patio-heater-repair/brands/bromic.astro
// Wave 5a — Bromic patio heater brand page (Australian, founded 2007).
// Smart-Heat Tungsten (electric), Platinum Smart-Heat (gas), Eclipse (electric IR).
// Premier tier: hotel rooftops, BH restaurants, Malibu beach clubs, Pacific Palisades.
// $120 OUTDOOR diagnostic universal (per CLAUDE.md §3, patio heaters = outdoor tier).
// Duty cycle (commercial 8-14hr daily vs residential 50-200hr/year) = parts wear context only.
// BHGS #A49573, EPA 608 Universal #1346255700410. 5 schemas (LocalBusiness + Service + Brand + FAQPage + BreadcrumbList).
import Layout from '../../../../layouts/Layout.astro';
import ServiceHero from '../../../../components/ServiceHero.astro';
import { MAIN_PHONE } from '../../../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/outdoor/patio-heater-repair/brands/bromic/";

const title = "Bromic Patio Heater Repair Los Angeles — Same Day";
const description = `Bromic patio heater repair across SoCal. Hotel rooftops + BH/Malibu luxury. $120 outdoor diagnostic.`;

const faqs = [
  {
    q: "How long do Bromic patio heaters last in LA?",
    a: "Tungsten Smart-Heat electric models run 8 to 12 years on the heating element with normal residential duty cycle (50 to 200 hours per year). Platinum Smart-Heat gas models run 10 to 15 years on the burner and ignition system with similar duty. Commercial installations (hotel rooftops, restaurant patios at 8 to 14 hours daily) compress those timelines: elements at year 5 to 8, gas burners at year 7 to 10. Coastal salt exposure (Malibu, Manhattan Beach, Marina del Rey) accelerates stainless mount hardware corrosion regardless of duty cycle."
  },
  {
    q: "My Smart-Heat remote control stopped pairing. Repair or replace?",
    a: "Bromic Smart-Heat uses a proprietary 4-zone wireless RF system that fails in two patterns. (1) Battery weak in the remote: replace the CR2032 coin cell, re-pair using the procedure in the manual. (2) RF receiver in the heater housing failed: requires receiver module replacement, $260 to $440 typical. We diagnose with a known-good remote first; if a fresh remote pairs, the original remote is the fault and we recommend replacement ($180 to $280 for the remote itself)."
  },
  {
    q: "What's the lead time for Bromic parts in LA?",
    a: "Bromic is Australian (Sydney HQ); North American distribution runs through authorized US distributors with 5 to 10 day standard lead time on common service parts (heating elements, ignition modules, gas valves, remote controls). Premium-tier components (full Smart-Heat receiver assemblies, Platinum gas valve cartridges) sometimes run 2 to 3 weeks if shipping direct from Australia. We confirm part availability during the diagnostic visit and coordinate."
  },
  {
    q: "Do you service Bromic at hotel and restaurant installations?",
    a: "Yes. Bromic is the dominant premier-tier brand at LA hotels (Beverly Hills, West Hollywood, Santa Monica, Marina del Rey rooftop bars), restaurant patios, and beach club installations (Malibu, Manhattan Beach). Commercial accounts get $120 outdoor diagnostic same as residential; we coordinate around service hours and provide written documentation for facility maintenance records."
  },
  {
    q: "Why does my Platinum Smart-Heat shut off in wind?",
    a: "Bromic Platinum gas heaters include a built-in wind sensor that auto-shuts the unit off when wind exceeds approximately 12 mph for safety reasons (gas flame stability and outdoor combustion safety). Coastal LA installations on Malibu and Pacific Palisades patios trigger the sensor frequently during onshore-breeze afternoons. The sensor is calibrated at the factory; if the cutoff is happening at very low wind, the sensor may have drifted and need recalibration or replacement, $200 to $360 typical."
  },
  {
    q: "Tungsten element replacement — DIY or professional?",
    a: "Tungsten Smart-Heat heating element replacement is technically a wired-component swap, but Bromic units are 240V hardwired with manufacturer-specific connector layouts. We recommend professional service for warranty preservation and electrical-code compliance. Element replacement runs $440 to $680 typical (element $200 to $340 plus install). DIY-installed aftermarket elements often have wrong wattage rating and void warranty."
  },
  {
    q: "What's your warranty?",
    a: "90 days SDAR labor and parts warranty on the work we perform. Bromic component warranties (heating element, ignition module, Smart-Heat electronics) where applicable are processed separately through Bromic's authorized US service network. BHGS #A49573, BBB A+ accredited, EPA 608 Universal certified #1346255700410."
  }
];

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": canonical + "#business",
    "name": "Same Day Appliance Repair",
    "url": canonical,
    "telephone": phone,
    "priceRange": "$$$",
    "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "08:00", "closes": "20:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "00:00", "closes": "00:00" }
      ],
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": canonical + "#service",
    "serviceType": "Bromic Patio Heater Repair",
    "name": "Bromic Patio Heater Repair Service",
    "url": canonical,
    "description": "Bromic patio heater repair across all five SoCal counties. Tungsten Smart-Heat electric (2,000-6,000W), Platinum Smart-Heat gas (39,800 BTU natural gas and propane variants), Eclipse electric infrared. Smart-Heat remote control system service (4-zone wireless RF, receiver module replacement, remote pairing diagnostic). Common service: ignition module failure, gas valve seal leaks, wind sensor calibration, Tungsten element replacement, coastal stainless mount hardware corrosion. Hotel, restaurant, beach club, and luxury residential installations. $120 outdoor diagnostic, waived with repair. BHGS #A49573, EPA 608 Universal certified #1346255700410.",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "offers": { "@type": "Offer", "priceRange": "$120-$1500", "priceSpecification": { "@type": "PriceSpecification", "price": "120.00", "priceCurrency": "USD", "description": "Outdoor diagnostic fee, applied toward repair. No emergency surcharge." } },
    "brand": { "@id": canonical + "#brand" }
  },
  {
    "@context": "https://schema.org",
    "@type": "Brand",
    "@id": canonical + "#brand",
    "name": "Bromic Heating",
    "url": "https://www.bromicheating.com/",
    "description": "Bromic Heating is an Australian outdoor heating manufacturer founded in 2007, headquartered in Sydney. Premier tier in commercial and luxury residential outdoor heating: hotel rooftops, restaurant patios, beach clubs, and high-end residential installations. Product lines: Tungsten Smart-Heat (electric, 2,000-6,000W), Platinum Smart-Heat (gas, natural gas and propane variants up to 39,800 BTU), Eclipse (electric infrared, smaller spaces). Proprietary Smart-Heat 4-zone wireless RF remote control system."
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Outdoor", "item": "https://samedayappliance.repair/outdoor/" },
      { "@type": "ListItem", "position": 3, "name": "Patio Heater Repair", "item": "https://samedayappliance.repair/outdoor/patio-heater-repair/" },
      { "@type": "ListItem", "position": 4, "name": "Bromic", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>
<Fragment slot="head-scripts">
  {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
</Fragment>

<ServiceHero
  eyebrow="Bromic · Australian Premier Tier · Smart-Heat · LA Same-Day"
  title="Bromic Patio Heater Repair Los Angeles"
  subtitle={`Tungsten Smart-Heat electric, Platinum Smart-Heat gas, Eclipse infrared. Hotel rooftops, BH restaurants, Malibu beach clubs, Pacific Palisades residential. $120 outdoor diagnostic, waived with repair. ${phone}`}
  heroImageTitle="Bromic Patio Heater Repair"
/>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Bromic service</p>
    <h2>Premier Australian outdoor heating, dominant at LA hotel rooftops and luxury residential.</h2>

    <p>Bromic Heating is the Australian outdoor heating manufacturer founded in 2007 in Sydney. Over the past decade Bromic has become the premier-tier brand in LA hotel rooftops (Beverly Hills, West Hollywood, Santa Monica, Marina del Rey), high-end restaurant patios, beach clubs (Malibu, Manhattan Beach), and luxury residential installations (Beverly Hills, Pacific Palisades, Hidden Hills). Sleek minimalist design, premium pricing ($800 to $3,500 per unit), and the proprietary Smart-Heat 4-zone wireless RF remote control system are the brand's distinctive features.</p>

    <p>We service the full Bromic lineup across LA County, Orange, Ventura, San Bernardino, Riverside. <strong>Tungsten Smart-Heat</strong> (electric, 2,000-6,000W variants for residential and light commercial). <strong>Platinum Smart-Heat</strong> (gas, natural gas and propane variants up to 39,800 BTU, residential and commercial). <strong>Eclipse</strong> (electric infrared, smaller patio applications). Plus the Smart-Heat control system service (remote pairing, RF receiver module, 4-zone configuration).</p>

    <p>$120 outdoor diagnostic, waived with repair. <strong>BHGS #A49573</strong>. <strong>EPA 608 Universal certified #1346255700410</strong>. BBB A+. Phones answered 24/7. Parent: <a href="/outdoor/patio-heater-repair/">patio heater repair</a>.</p>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">Lineup and what fails</p>
    <h2 class="section-title">Bromic series and common service items.</h2>

    <h3 class="series-h3">Tungsten Smart-Heat (electric, 2,000-6,000W)</h3>
    <p>Sleek black housing, hardwired 240V or 120V depending on wattage variant, ceiling/wall mount. Residential duty cycle (50 to 200 hours per year) sees element replacement at year 8 to 12. Commercial duty (8 to 14 hours daily at hotel rooftops or restaurant patios) compresses to year 5 to 8. Element replacement $440 to $680 (element $200 to $340 plus install).</p>

    <h3 class="series-h3">Platinum Smart-Heat (gas, natural gas / propane)</h3>
    <p>Premium gas variant up to 39,800 BTU. Built-in wind sensor auto-shuts off when wind exceeds approximately 12 mph. Common service items: ignition module (year 5-7), gas valve seal leaks (year 5-7, propane variant more common), wind sensor calibration drift, thermocouple replacement on pilot variants. Burner head and gas valve service runs $360 to $680 typical.</p>

    <h3 class="series-h3">Eclipse (electric infrared)</h3>
    <p>Smaller-format electric IR for patio coverage in tighter spaces. Lower wattage (1,500-3,000W typical), 120V plug-in or 240V hardwired variants. Element burnout typical year 6-10 residential.</p>

    <h3 class="series-h3">Smart-Heat 4-zone RF remote system</h3>
    <p>Proprietary wireless control system. Remote pairs with up to 4 heater zones. Service items: remote battery (CR2032 coin cell), remote pairing reset, RF receiver module replacement at year 5+ ($260 to $440), remote unit replacement ($180 to $280).</p>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Common scenarios</p>
    <h2 class="section-title">Top Bromic repairs in our 5-county territory.</h2>
    <ol class="num-list">
      <li><strong>Smart-Heat remote control pairing or RF issues (year 3-5).</strong> Battery, pairing reset, or receiver module replacement. $180 to $440 depending on diagnostic outcome.</li>
      <li><strong>Platinum gas ignition module failure (year 5-7).</strong> $260 to $440 module plus install.</li>
      <li><strong>Gas valve seal leaks (year 5-7, propane variant more common).</strong> $480 to $680 valve plus seal kit.</li>
      <li><strong>Wind sensor calibration drift.</strong> Auto-shutoff triggering at low wind. $200 to $360 calibration or sensor replacement.</li>
      <li><strong>Tungsten element replacement (year 8-12 residential, year 5-8 commercial).</strong> $440 to $680 typical.</li>
      <li><strong>Coastal stainless mount hardware corrosion (Marina del Rey, Malibu, Manhattan Beach).</strong> $200 to $340 hardware replacement.</li>
      <li><strong>Thermocouple on pilot-variant Platinum (year 4-7).</strong> $220 to $340.</li>
    </ol>
  </div>
</section>

<section class="section section-gray">
  <div class="container">
    <p class="section-number">Real repairs</p>
    <h2 class="section-title">Composite stories from the route.</h2>
    <div class="story-grid">
      <div class="story-card">
        <h3>Beverly Hills hotel rooftop, Bromic Platinum Smart-Heat, 6 years old (commercial 12hr daily duty)</h3>
        <p>Ignition module failure during peak season service. Diagnosed: ignition module degraded from continuous-cycle commercial duty. Replaced module, recalibrated wind sensor while there. Total: $120 plus $360 module plus $180 sensor calibration = $660. Hotel back to full service within 2 hours.</p>
      </div>
      <div class="story-card">
        <h3>Pacific Palisades residential patio, Bromic Tungsten Smart-Heat 4,000W, 9 years old</h3>
        <p>Element burnout (residential duty cycle, age 9). Customer reported gradual heat output decline over 2 weeks before complete failure. Replaced element with OEM Bromic 4,000W. Total: $120 plus $300 element plus $260 install = $680.</p>
      </div>
      <div class="story-card">
        <h3>Malibu beach club, 4× Bromic Platinum on Smart-Heat 4-zone, 4 years old (commercial)</h3>
        <p>Smart-Heat remote stopped pairing across all 4 zones. Diagnosed: RF receiver module failure on the master heater (zone 1 controller for the others). Replaced receiver module, re-paired remote to all 4 zones, tested control range. Total: $120 plus $380 receiver = $500.</p>
      </div>
      <div class="story-card">
        <h3>West Hollywood restaurant patio, Bromic Eclipse 2,500W (commercial)</h3>
        <p>Element burnout at year 6 commercial duty (compressed timeline vs residential 8-12 year typical). Replaced element. Total: $120 plus $260 element plus $180 install = $560.</p>
      </div>
    </div>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Honest scope</p>
    <h2 class="section-title">What we do for Bromic, and what we don't.</h2>

    <p><strong>We service:</strong></p>
    <ul class="bullet-list">
      <li>Tungsten Smart-Heat (all wattage variants, ceiling and wall mount)</li>
      <li>Platinum Smart-Heat (natural gas and propane variants up to 39,800 BTU)</li>
      <li>Eclipse electric infrared (120V and 240V variants)</li>
      <li>Smart-Heat 4-zone wireless RF system (remote, receiver, pairing)</li>
      <li>Wind sensor calibration on Platinum gas units</li>
      <li>Thermocouple, ignition module, gas valve service on Platinum gas</li>
      <li>Coastal corrosion repair (mount hardware, housing fasteners)</li>
      <li>Hotel, restaurant, beach club, and luxury residential installations</li>
    </ul>

    <p><strong>We don't do:</strong> new Bromic installation (specialty installer trade — gas line plumbing for Platinum requires plumber, electrical rough-in for Tungsten requires electrician); structural mount engineering for ceiling installations (architect/engineer trade); custom Smart-Heat zone controller programming for whole-property automation (low-voltage integrator trade).</p>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">Pricing</p>
    <h2 class="section-title">Bromic repair costs.</h2>
    <p class="lead">$120 outdoor diagnostic, waived with repair. Universal pricing across residential and commercial installations (per CLAUDE.md outdoor tier). Duty cycle (residential 50-200 hr/yr vs commercial 8-14 hr daily) affects parts wear timeline, not diagnostic pricing.</p>
    <table class="price-table">
      <thead><tr><th>Repair</th><th>Typical Cost</th></tr></thead>
      <tbody>
        <tr><td>Diagnostic</td><td>$120, waived with repair</td></tr>
        <tr><td>Smart-Heat remote replacement</td><td>$180 to $280</td></tr>
        <tr><td>Smart-Heat RF receiver module</td><td>$260 to $440</td></tr>
        <tr><td>Tungsten element replacement</td><td>$440 to $680</td></tr>
        <tr><td>Eclipse element replacement</td><td>$340 to $540</td></tr>
        <tr><td>Platinum ignition module</td><td>$260 to $440</td></tr>
        <tr><td>Platinum gas valve plus seal kit</td><td>$480 to $680</td></tr>
        <tr><td>Wind sensor calibration or replacement</td><td>$200 to $360</td></tr>
        <tr><td>Thermocouple (pilot variants)</td><td>$220 to $340</td></tr>
        <tr><td>Coastal mount hardware replacement</td><td>$200 to $340</td></tr>
        <tr><td>Multi-component repair (commercial 8+ year unit)</td><td>$680 to $1,200</td></tr>
        <tr><td>Warranty</td><td>90 days parts and labor</td></tr>
      </tbody>
    </table>
  </div>
</section>

<section class="section">
  <div class="container">
    <p class="section-number">Why us for Bromic</p>
    <h2 class="section-title">What separates our Bromic service.</h2>
    <ul class="reasons-list">
      <li><strong>Smart-Heat system expertise.</strong> 4-zone RF remote, receiver module, pairing diagnostic. Many LA outdoor service shops don't have this.</li>
      <li><strong>BHGS #A49573 license</strong> for primary appliance repair, plus EPA 608 Universal certified #1346255700410 for adjacent outdoor refrigeration ecosystem (Sub-Zero outdoor, Perlick HC, U-Line outdoor) common at hotel/restaurant Bromic installs.</li>
      <li><strong>Authorized parts network access.</strong> Bromic North American distribution coordination, 5 to 10 day standard part lead time on common items.</li>
      <li><strong>Hotel and restaurant priority dispatch.</strong> We understand hotel rooftop bar service hours; we work around them.</li>
      <li><strong>Coastal corrosion expertise.</strong> Marina del Rey, Malibu, Manhattan Beach, Newport Beach, Marina del Rey installations see accelerated stainless hardware wear; we stock common replacement hardware.</li>
      <li><strong>24/7 phone answering, no emergency surcharge.</strong> $120 anytime.</li>
      <li><strong>Same-day across LA, OC, Ventura.</strong> Next-day for RC and Temecula.</li>
      <li><strong>BBB A+ verifiable.</strong> See our <a href="/credentials/licensed/">license credentials</a>.</li>
    </ul>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">FAQ</p>
    <h2 class="section-title">Bromic repair questions.</h2>
    <div class="faq-list">
      {faqs.map(f => (<details class="faq-item"><summary>{f.q}</summary><p>{f.a}</p></details>))}
    </div>
  </div>
</section>

<section class="section">
