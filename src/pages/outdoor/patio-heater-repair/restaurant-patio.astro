<ServiceHero
  eyebrow="Commercial · PM Contracts · Multi-Unit Fleet · Title 24 · BH SM WeHo Pasadena"
  title="Restaurant Patio Heater Repair Los Angeles"
  subtitle={`Commercial duty cycle 8-14 hr daily. Preventive maintenance contracts. Multi-unit fleet service. CA Title 24 makeup air. Same-day across LA, Orange, Ventura, San Bernardino, Riverside. $120 outdoor diagnostic, waived with repair. ${phone}`}
  heroImageTitle="Restaurant Patio Heater Repair"
