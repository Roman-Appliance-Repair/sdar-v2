        <div class="pi"><span class="pi-label">Diagnostic fee</span><span class="pi-val">$89</span></div>
        <div class="pi"><span class="pi-label">Applied to repair</span><span class="pi-val">Yes</span></div>
        <div class="pi"><span class="pi-label">Parts</span><span class="pi-val">Quoted separately</span></div>
        <div class="pi"><span class="pi-label">Vent clearing</span><span class="pi-val">Included when needed</span></div>
        <div class="pi"><span class="pi-label">Warranty</span><span class="pi-val">90 days</span></div>
        <div class="pi"><span class="pi-label">Miele / Bosch luxury</span><span class="pi-val">$280&ndash;$560+</span></div>
      </div>
      <div class="parts-note">All prices are <strong>labor only</strong>. Parts quoted separately after diagnosis.</div>
