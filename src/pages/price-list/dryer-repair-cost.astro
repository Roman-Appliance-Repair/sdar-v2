---
// Dryer Repair Cost Los Angeles | Same Day Appliance Repair
// /price-list/dryer-repair-cost/
import Layout from '../../layouts/Layout.astro';

const title = "Dryer Repair Cost Los Angeles 2026 | Labor Rates";
const description = "Dryer repair cost — labor rates by repair type from $150. Parts quoted separately. Vent cleaning included when relevant. $89 dx.";
const schemaJson = `{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does dryer repair cost in Los Angeles?", "acceptedAnswer": { "@type": "Answer", "text": "Labor costs for dryer repair in Los Angeles typically run $150-$340 for standard brands depending on the problem. Parts are quoted separately after diagnosis. The $89 diagnostic fee is applied to the repair when you approve the work." } },
      { "@type": "Question", "name": "Why do you quote labor and parts separately?", "acceptedAnswer": { "@type": "Answer", "text": "Many appliance repair companies use flat-rate BlueBook pricing that bundles labor and parts into a single number before diagnosis. We quote them separately. A clogged dryer vent with no part needed should not cost the same as a heating element replacement. You see exactly what your specific repair actually requires." } },
      { "@type": "Question", "name": "Are parts included in the dryer repair price?", "acceptedAnswer": { "@type": "Answer", "text": "No. The prices listed are labor costs only. Parts are quoted separately after we diagnose the specific failure. OEM parts are used wherever available. You see the full quote before we start any repair work." } },
      { "@type": "Question", "name": "Why does my dryer take so long to dry clothes?", "acceptedAnswer": { "@type": "Answer", "text": "The most common cause in LA is a clogged dryer vent. Lint buildup restricts airflow, and the dryer takes two or three cycles to dry a normal load. It is also a significant fire hazard. We clear the vent and inspect the heating element. In many cases no part is needed and the labor cost is at the low end of the range." } },
      { "@type": "Question", "name": "Is dryer vent cleaning included in the repair?", "acceptedAnswer": { "@type": "Answer", "text": "When a vent blockage is causing or contributing to the failure, clearing it is part of the repair. We also inspect the vent condition and let you know if the duct routing needs attention. A thermal fuse blows for a reason - we find the cause, not just replace the fuse." } },
      { "@type": "Question", "name": "What is the $89 diagnostic fee?", "acceptedAnswer": { "@type": "Answer", "text": "We charge $89 to come out and diagnose the problem. That fee applies to the repair total when you approve the work. If you decide not to repair, you pay $89 and we leave." } },
      { "@type": "Question", "name": "What warranty do you provide on dryer repair in Los Angeles?", "acceptedAnswer": { "@type": "Answer", "text": "90 days on parts and labor. Same issue within 90 days and we come back at no charge. OEM parts wherever available." } }
    ]
  }`;
---

<Layout title={title} description={description}>
  <Fragment slot="head-scripts">
    <script type="application/ld+json" set:html={schemaJson}></script>
  </Fragment>

<style>
    :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', -apple-system, sans-serif; color: var(--text); line-height: 1.6; }
    a { color: inherit; text-decoration: none; }
    .hero { background: var(--black); color: #fff; padding: 72px 24px 64px; }
    .hero-inner { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 340px; gap: 48px; align-items: center; }
    .hero-eyebrow { font-size: 12px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--red); margin-bottom: 14px; }
    .hero-sub { font-size: 16px; color: rgba(255,255,255,.68); line-height: 1.65; margin-bottom: 28px; }
    .hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; }
