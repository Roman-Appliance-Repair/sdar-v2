---
// Range Repair Cost Los Angeles | Same Day Appliance Repair
// /price-list/range-repair-cost/
import Layout from '../../layouts/Layout.astro';

const title = "Range Repair Cost Los Angeles 2026 | Labor Rates";
const description = "Range repair cost in Los Angeles — gas and electric, all brands. Labor rates from $160. Parts quoted separately. $89 diagnostic. (424) 325-0520.";
const schemaJson = `{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does range repair cost in Los Angeles?", "acceptedAnswer": { "@type": "Answer", "text": "Labor costs for range repair in Los Angeles typically run $175-$400 for standard brands. Burner ignition issues are the most common call and run $160-$340. Parts are quoted separately after diagnosis. The $89 diagnostic fee applies to the repair when you approve the work." } },
      { "@type": "Question", "name": "Why do you quote labor and parts separately?", "acceptedAnswer": { "@type": "Answer", "text": "Many appliance repair companies use flat-rate BlueBook pricing that bundles labor and parts into a single number before diagnosis. We quote separately. A surface burner igniter replacement and a control board failure are completely different jobs. You see exactly what your specific repair requires." } },
      { "@type": "Question", "name": "How much does Wolf or Viking range repair cost in Los Angeles?", "acceptedAnswer": { "@type": "Answer", "text": "Labor for Wolf and Viking range repair in Los Angeles runs $280-$680 or more. These professional-grade ranges use proprietary high-BTU gas components, dual-fuel configurations, and custom control modules. OEM parts are premium-priced and quoted separately after diagnosis." } },
      { "@type": "Question", "name": "One burner on my gas range won't ignite. How much to fix?", "acceptedAnswer": { "@type": "Answer", "text": "A single burner not igniting is typically an igniter or spark electrode failure. Labor runs $160-$320 for standard brands. We check all burners while on site. If it's a moisture issue from a boilover, it may resolve with drying and cleaning at no parts cost." } },
      { "@type": "Question", "name": "Are parts included in the range repair price?", "acceptedAnswer": { "@type": "Answer", "text": "No. The prices listed are labor costs only. Parts are quoted separately after we diagnose the specific failure. OEM parts are used wherever available. You see the full quote before we start any repair work." } },
      { "@type": "Question", "name": "What is the $89 diagnostic fee?", "acceptedAnswer": { "@type": "Answer", "text": "We charge $89 to come out and diagnose the problem. That fee applies to the repair total when you approve the work. If you decide not to repair, you pay $89 and we leave." } },
      { "@type": "Question", "name": "What warranty do you provide on range repair in Los Angeles?", "acceptedAnswer": { "@type": "Answer", "text": "90 days on parts and labor. Same issue within 90 days and we come back at no charge. OEM parts wherever available." } }
    ]
  }`;
---

<Layout title={title} description={description}>
  <Fragment slot="head-scripts">
    <script type="application/ld+json" set:html={schemaJson}></script>
  </Fragment>

<style>
    :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', -apple-system, sans-serif; color: var(--text); line-height: 1.6; }
    a { color: inherit; text-decoration: none; }
    .hero { background: var(--black); color: #fff; padding: 72px 24px 64px; }
    .hero-inner { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 340px; gap: 48px; align-items: center; }
    .hero-eyebrow { font-size: 12px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--red); margin-bottom: 14px; }
    .hero-sub { font-size: 16px; color: rgba(255,255,255,.68); line-height: 1.65; margin-bottom: 28px; }
    .hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; }
    .btn-red { background: var(--red); color: #fff; padding: 13px 26px; border-radius: 6px; font-size: 15px; font-weight: 600; }
    .btn-outline { border: 1.5px solid rgba(255,255,255,.3); color: #fff; padding: 13px 26px; border-radius: 6px; font-size: 15px; }
