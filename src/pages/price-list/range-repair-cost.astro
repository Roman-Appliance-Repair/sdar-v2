    .price-box { background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.15); border-radius: 14px; padding: 28px 24px; }
    .price-box-label { font-size: 11px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: rgba(255,255,255,.45); margin-bottom: 16px; }
    .price-main { font-size: 42px; font-weight: 700; color: #fff; line-height: 1; margin-bottom: 6px; }
    .price-note { font-size: 13px; color: rgba(255,255,255,.5); margin-bottom: 20px; }
    .price-items { border-top: 1px solid rgba(255,255,255,.1); padding-top: 16px; display: flex; flex-direction: column; gap: 10px; }
    .pi { display: flex; justify-content: space-between; font-size: 13px; }
    .pi-label { color: rgba(255,255,255,.55); }
    .pi-val { font-weight: 600; color: #fff; }
    .parts-note { margin-top: 14px; background: rgba(200,16,46,.15); border: 1px solid rgba(200,16,46,.3); border-radius: 7px; padding: 10px 14px; font-size: 12px; color: rgba(255,255,255,.7); line-height: 1.5; }
    .trust-bar { background: var(--red); padding: 13px 24px; }
    .trust-bar-inner { max-width: 1100px; margin: 0 auto; display: flex; gap: 20px; flex-wrap: wrap; justify-content: center; }
    .ti { display: flex; align-items: center; gap: 7px; font-size: 13px; font-weight: 500; color: #fff; }
    .section { padding: 68px 24px; }
    .section-gray { background: var(--gray); }
    .section-black { background: var(--black); color: #fff; }
    .container { max-width: 1100px; margin: 0 auto; }
    .sl { font-size: 12px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--red); margin-bottom: 12px; }
    h2 { font-size: clamp(22px, 3vw, 32px); font-weight: 700; line-height: 1.2; letter-spacing: -.02em; margin-bottom: 16px; }
    .section-black h2 { color: #fff; }
    .lead { font-size: 16px; line-height: 1.7; color: var(--muted); max-width: 680px; margin-bottom: 36px; }
    .section-black .lead { color: rgba(255,255,255,.62); }
    .body-text p { font-size: 16px; line-height: 1.75; color: var(--text); margin-bottom: 16px; }
    .body-text p:last-child { margin-bottom: 0; }
    .transparency-block { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 36px; }
    .tr-card { border-radius: 10px; padding: 24px; }
    .tr-card.them { background: #fdf2f2; border: 1px solid #f5c6c6; }
    .tr-card.us { background: #f0faf0; border: 1px solid #90d090; }
    .tr-card h3 { font-size: 14px; font-weight: 700; margin-bottom: 14px; }
    .tr-card.them h3 { color: #c02020; }
    .tr-card.us h3 { color: #207020; }
    .tr-list { list-style: none; }
    .tr-list li { font-size: 14px; line-height: 1.6; padding: 5px 0; border-bottom: 1px solid rgba(0,0,0,.06); color: var(--muted); }
    .tr-list li:last-child { border-bottom: none; }
    .tr-card.them .tr-list li::before { content: "\2717  "; color: #c02020; }
    .tr-card.us .tr-list li::before { content: "\2713  "; color: #207020; }
    .type-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 32px; }
    .type-card { background: #fff; border: 1px solid var(--border); border-radius: 10px; padding: 20px; }
    .type-card h3 { font-size: 14px; font-weight: 700; margin-bottom: 8px; }
    .type-card p { font-size: 13px; color: var(--muted); line-height: 1.6; }
    .price-table-wrap { overflow-x: auto; margin-top: 8px; }
    .price-table { width: 100%; border-collapse: collapse; font-size: 15px; }
    .price-table th { text-align: left; padding: 13px 16px; background: var(--black); color: #fff; font-size: 12px; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; }
    .price-table td { padding: 14px 16px; border-bottom: 1px solid var(--border); vertical-align: top; }
    .price-table tr:last-child td { border-bottom: none; }
    .price-table tr:nth-child(even) td { background: #fafafa; }
    .price-table tr.luxury-row td { background: #fdf8f0; }
    .repair-type { font-weight: 600; }
    .repair-desc { font-size: 13px; color: var(--muted); margin-top: 3px; }
    .price-labor { font-weight: 700; color: var(--red); }
    .price-parts-note { font-size: 12px; color: var(--muted); margin-top: 3px; }
    .luxury-badge { display: inline-block; background: #f5e6c8; color: #8a5a00; font-size: 10px; font-weight: 700; padding: 2px 7px; border-radius: 4px; margin-left: 6px; }
    .gas-badge { display: inline-block; background: #e8f4fd; color: #1060a0; font-size: 10px; font-weight: 700; padding: 2px 7px; border-radius: 4px; margin-left: 6px; }
    .table-note { font-size: 13px; color: var(--muted); margin-top: 14px; padding: 13px 16px; background: var(--gray); border-radius: 6px; border-left: 3px solid var(--red); }
    .factors-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 16px; margin-top: 32px; }
    .factor-card { background: #fff; border: 1px solid var(--border); border-radius: 10px; padding: 20px; }
    .factor-icon { font-size: 24px; margin-bottom: 10px; }
    .factor-card h3 { font-size: 14px; font-weight: 700; margin-bottom: 6px; }
    .factor-card p { font-size: 13px; color: var(--muted); line-height: 1.6; }
    .rvr-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 32px; }
    .rvr-card { border-radius: 10px; padding: 24px; }
    .rvr-card.repair { background: #f0faf0; border: 1px solid #90d090; }
    .rvr-card.replace { background: #fdf2f2; border: 1px solid #f5c6c6; }
    .rvr-card h3 { font-size: 16px; font-weight: 700; margin-bottom: 12px; }
    .rvr-card.repair h3 { color: #207020; }
    .rvr-card.replace h3 { color: #c02020; }
    .rvr-list { list-style: none; }
