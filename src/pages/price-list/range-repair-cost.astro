    .example-card { background: #fff; border: 1px solid var(--border); border-radius: 10px; padding: 20px; }
    .ex-tag { display: inline-block; background: var(--gray); font-size: 11px; font-weight: 600; text-transform: uppercase; color: var(--muted); padding: 3px 8px; border-radius: 4px; margin-bottom: 10px; }
    .ex-title { font-size: 14px; font-weight: 700; margin-bottom: 8px; line-height: 1.35; }
    .ex-body { font-size: 13px; color: var(--muted); line-height: 1.6; margin-bottom: 12px; }
    .ex-cost { background: var(--gray); border-radius: 6px; padding: 10px 12px; }
    .ex-row { display: flex; justify-content: space-between; font-size: 13px; padding: 3px 0; }
    .ex-row-label { color: var(--muted); }
    .ex-row-val { font-weight: 600; }
    .ex-total { display: flex; justify-content: space-between; font-size: 14px; font-weight: 700; padding-top: 8px; margin-top: 6px; border-top: 1px solid var(--border); }
    .ex-total-val { color: var(--red); }
    .faq-list { margin-top: 32px; }
    .faq-item { border-bottom: 1px solid var(--border); padding: 18px 0; }
    .faq-item:first-child { border-top: 1px solid var(--border); }
    .faq-q { font-size: 16px; font-weight: 700; margin-bottom: 8px; }
    .faq-a { font-size: 15px; line-height: 1.7; color: var(--muted); }
    .nearby-grid { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 26px; }
    .nb { background: var(--gray); border: 1px solid var(--border); border-radius: 6px; padding: 8px 14px; font-size: 14px; }
    .bottom-cta { background: var(--black); color: #fff; padding: 68px 24px; text-align: center; }
    .bottom-cta h2 { color: #fff; margin-bottom: 12px; }
    .bottom-cta p { font-size: 16px; color: rgba(255,255,255,.62); margin-bottom: 28px; max-width: 520px; margin-left: auto; margin-right: auto; }
    .bottom-ctas { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
    @media (max-width: 768px) { .hero-inner, .transparency-block, .rvr-grid, .type-grid { grid-template-columns: 1fr; } }
  </style>

<section class="hero">
  <div class="hero-inner">
    <div>
      <p class="hero-eyebrow">Price List &middot; Los Angeles &middot; 2026</p>
      <h1>Range Repair Cost in Los Angeles</h1>
      <p class="hero-sub">Labor rates for gas and electric ranges &mdash; burner ignition, surface elements, oven failures, control boards. Parts quoted separately. The most common call &mdash; burner ignition &mdash; is often cheaper than people expect.</p>
