  <style>
    :root{--red:#C8102E;--black:#0a0a0a;--gray:#f5f5f5;--border:#e2e2e2;--text:#1a1a1a;--muted:#6b6b6b;}
    *{box-sizing:border-box;margin:0;padding:0;}
    body{font-family:'Inter',-apple-system,sans-serif;color:var(--text);line-height:1.6;}
    a{color:inherit;text-decoration:none;}
    .hero{background:var(--black);color:#fff;padding:72px 24px 64px;}
    .hero-inner{max-width:1100px;margin:0 auto;}
    .eyebrow{font-size:12px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--red);margin-bottom:14px;}
    .hero h1{font-size:clamp(28px,4vw,52px);font-weight:700;line-height:1.1;margin-bottom:20px;letter-spacing:-.02em;max-width:760px;}
    .hero-sub{font-size:17px;color:rgba(255,255,255,.68);line-height:1.65;margin-bottom:32px;max-width:620px;}
    .hero-ctas{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:32px;}
    .btn-red{background:var(--red);color:#fff;padding:14px 28px;border-radius:6px;font-size:15px;font-weight:600;}
    .btn-out{border:1.5px solid rgba(255,255,255,.3);color:#fff;padding:14px 28px;border-radius:6px;font-size:15px;}
    .stars{color:#f59e0b;}
    .diag-strip{display:flex;gap:32px;flex-wrap:wrap;padding:20px 0;border-top:1px solid rgba(255,255,255,.1);}
    .ds-item{text-align:center;}
    .ds-price{font-size:32px;font-weight:700;color:#fff;}
    .ds-label{font-size:12px;color:rgba(255,255,255,.5);margin-top:2px;}
    .tbar{background:var(--red);padding:13px 24px;}
    .tbar-inner{max-width:1100px;margin:0 auto;display:flex;gap:20px;flex-wrap:wrap;justify-content:center;}
    .ti{display:flex;align-items:center;gap:7px;font-size:13px;font-weight:500;color:#fff;}
    .sec{padding:68px 24px;}
    .sec-gray{background:var(--gray);}
    .sec-black{background:var(--black);color:#fff;}
    .con{max-width:1100px;margin:0 auto;}
    .sl{font-size:12px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--red);margin-bottom:12px;}
    h2{font-size:clamp(22px,3vw,32px);font-weight:700;line-height:1.2;letter-spacing:-.02em;margin-bottom:16px;}
    .sec-black h2{color:#fff;}
    .lead{font-size:16px;line-height:1.7;color:var(--muted);max-width:680px;margin-bottom:40px;}
    .sec-black .lead{color:rgba(255,255,255,.62);}
    .body-text p{font-size:16px;line-height:1.75;color:var(--text);margin-bottom:16px;}
    /* Category sections */
    .cat-section{margin-bottom:48px;}
    .cat-title{font-size:14px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);margin-bottom:16px;padding-bottom:8px;border-bottom:2px solid var(--red);}
    .cards-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:12px;}
    .price-card{background:#fff;border:1px solid var(--border);border-radius:10px;padding:18px;transition:border-color .15s;}
    .price-card:hover{border-color:#aaa;}
    .pc-appliance{font-size:14px;font-weight:700;color:var(--text);margin-bottom:6px;line-height:1.3;}
    .pc-range{font-size:18px;font-weight:700;color:var(--red);margin-bottom:4px;}
    .pc-note{font-size:11px;color:var(--muted);}
    .pc-arrow{font-size:11px;color:var(--red);margin-top:8px;font-weight:600;}
    /* Commercial cards — slightly different bg */
    .price-card.comm{background:#fdf8f0;}
    /* Transparency block */
    .transparency{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:36px;}
    .tr-card{border-radius:10px;padding:24px;}
    .tr-them{background:#fdf2f2;border:1px solid #f5c6c6;}
    .tr-us{background:#f0faf0;border:1px solid #90d090;}
    .tr-card h3{font-size:14px;font-weight:700;margin-bottom:14px;}
    .tr-them h3{color:#c02020;}
    .tr-us h3{color:#207020;}
    .tr-list{list-style:none;}
    .tr-list li{font-size:14px;line-height:1.6;padding:5px 0;border-bottom:1px solid rgba(0,0,0,.06);color:var(--muted);}
    .tr-list li:last-child{border-bottom:none;}
    .tr-them .tr-list li::before{content:"\2717  ";color:#c02020;}
    .tr-us .tr-list li::before{content:"\2713  ";color:#207020;}
    /* FAQ */
    .faq-list{margin-top:32px;}
    .faq-item{border-bottom:1px solid var(--border);padding:18px 0;}
    .faq-item:first-child{border-top:1px solid var(--border);}
    .faq-q{font-size:16px;font-weight:700;margin-bottom:8px;}
    .faq-a{font-size:15px;line-height:1.7;color:var(--muted);}
    /* Bottom CTA */
    .btm{background:var(--black);color:#fff;padding:68px 24px;text-align:center;}
    .btm h2{color:#fff;margin-bottom:12px;}
    .btm p{font-size:16px;color:rgba(255,255,255,.62);margin-bottom:28px;max-width:520px;margin-left:auto;margin-right:auto;}
    .btm-ctas{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;}
    @media(max-width:768px){.transparency{grid-template-columns:1fr;}.diag-strip{gap:20px;}}
