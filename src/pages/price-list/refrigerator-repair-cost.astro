const title = "Refrigerator Repair Cost Los Angeles 2026 | Labor Rates";
const description = "Refrigerator repair cost in Los Angeles — labor rates by repair type from $200. Parts quoted separately. See exactly what you pay for. $89 diagnostic. (424) 325-0520.";
