<Layout title={title} description={description}>
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does refrigerator repair cost in Los Angeles?", "acceptedAnswer": { "@type": "Answer", "text": "Labor costs typically run $200-$440 for standard brands. Parts are quoted separately after diagnosis. The $89 diagnostic fee is applied to the repair when you approve the work." } },
      { "@type": "Question", "name": "Why do you quote labor and parts separately?", "acceptedAnswer": { "@type": "Answer", "text": "Many appliance repair companies use flat-rate BlueBook pricing that bundles labor and parts into a single opaque number before diagnosis. We quote them separately so you see exactly what you are paying for. A flat rate before diagnosis is either padded for uncertainty or does not reflect the actual complexity of your repair." } },
      { "@type": "Question", "name": "Are parts included in the refrigerator repair price?", "acceptedAnswer": { "@type": "Answer", "text": "No. The prices listed are labor costs only. Parts are quoted separately after we diagnose the specific failure. OEM parts are used wherever available. You get the full quote before we start any repair work." } },
      { "@type": "Question", "name": "How much does Sub-Zero refrigerator repair cost in Los Angeles?", "acceptedAnswer": { "@type": "Answer", "text": "Labor for Sub-Zero repair in Los Angeles runs $320-$910 or more depending on the failure type. Sub-Zero uses proprietary components and sealed refrigeration systems. OEM Sub-Zero parts are priced at a premium and quoted separately after diagnosis." } },
      { "@type": "Question", "name": "Is refrigerator repair worth it vs. buying new?", "acceptedAnswer": { "@type": "Answer", "text": "If total repair cost is less than 50 percent of a comparable new unit, repair makes sense. For standard brands under 10 years old, repair almost always wins. For luxury built-in refrigerators like Sub-Zero, the 50 percent rule rarely applies since replacing a built-in means a full kitchen renovation." } },
      { "@type": "Question", "name": "What is the $89 diagnostic fee?", "acceptedAnswer": { "@type": "Answer", "text": "We charge $89 to come out and diagnose the problem. That fee is applied to the repair when you approve the work. If you decide not to repair, you pay $89 and we leave." } },
      { "@type": "Question", "name": "What warranty do you provide on refrigerator repair?", "acceptedAnswer": { "@type": "Answer", "text": "90 days on parts and labor. Same issue within 90 days and we come back at no charge. OEM parts wherever available." } }
    ]
  }
  <\/script>

