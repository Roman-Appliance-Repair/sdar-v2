---
// Freezer Repair Cost Los Angeles | Same Day Appliance Repair
// /price-list/freezer-repair-cost/
import Layout from '../../layouts/Layout.astro';

const title = "Freezer Repair Cost Los Angeles 2026 | Labor Rates";
const description = "Freezer repair cost in Los Angeles — labor rates by repair type from $150. Parts quoted separately. No flat-rate guesswork. $89 diagnostic. (424) 325-0520.";
const schemaJson = `{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does freezer repair cost in Los Angeles?", "acceptedAnswer": { "@type": "Answer", "text": "Labor costs for freezer repair in Los Angeles typically run $200-$440 for standard brands depending on the problem. Parts are quoted separately after diagnosis. The $89 diagnostic fee is applied to the repair when you approve the work." } },
      { "@type": "Question", "name": "Why do you quote labor and parts separately?", "acceptedAnswer": { "@type": "Answer", "text": "Many appliance repair companies use flat-rate BlueBook pricing that bundles labor and parts into a single opaque number before diagnosis. We quote them separately so you see exactly what you are paying for. A flat rate before diagnosis is either padded for uncertainty or does not reflect the actual complexity of your specific repair." } },
      { "@type": "Question", "name": "Are parts included in the freezer repair price?", "acceptedAnswer": { "@type": "Answer", "text": "No. The prices listed are labor costs only. Parts are quoted separately after we diagnose the specific failure. OEM parts are used wherever available. You see the full quote before we start any repair work." } },
      { "@type": "Question", "name": "Is it worth repairing a freezer or should I replace it?", "acceptedAnswer": { "@type": "Answer", "text": "If total repair cost is less than 50 percent of a comparable new unit, repair makes sense. For upright and chest freezers under 10 years old, repair almost always wins. For built-in or luxury units, the 50 percent rule rarely applies since replacement disrupts the surrounding installation." } },
      { "@type": "Question", "name": "How much does upright freezer repair cost in Los Angeles?", "acceptedAnswer": { "@type": "Answer", "text": "Labor for upright freezer repair typically runs $200-$440 depending on the failure. Common issues include defrost system failure, evaporator fan motor failure, and thermostat problems. Parts are quoted separately after diagnosis." } },
      { "@type": "Question", "name": "What is the $89 diagnostic fee?", "acceptedAnswer": { "@type": "Answer", "text": "We charge $89 to come out and diagnose the problem. That fee applies to the repair total when you approve the work. If you decide not to repair, you pay $89 and we leave." } },
      { "@type": "Question", "name": "What warranty do you provide on freezer repair in Los Angeles?", "acceptedAnswer": { "@type": "Answer", "text": "90 days on parts and labor. Same issue within 90 days and we come back at no charge." } }
    ]
  }`;
---

<Layout title={title} description={description}>
  <Fragment slot="head-scripts">
    <script type="application/ld+json" set:html={schemaJson}></script>
  </Fragment>

<style>
    :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', -apple-system, sans-serif; color: var(--text); line-height: 1.6; }
    a { color: inherit; text-decoration: none; }
    .hero { background: var(--black); color: #fff; padding: 72px 24px 64px; }
    .hero-inner { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 340px; gap: 48px; align-items: center; }
    .hero-eyebrow { font-size: 12px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--red); margin-bottom: 14px; }
    .hero-sub { font-size: 16px; color: rgba(255,255,255,.68); line-height: 1.65; margin-bottom: 28px; }
    .hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; }
    .btn-red { background: var(--red); color: #fff; padding: 13px 26px; border-radius: 6px; font-size: 15px; font-weight: 600; }
    .btn-outline { border: 1.5px solid rgba(255,255,255,.3); color: #fff; padding: 13px 26px; border-radius: 6px; font-size: 15px; }
    .stars { color: #f59e0b; }
    .price-box { background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.15); border-radius: 14px; padding: 28px 24px; }
    .price-box-label { font-size: 11px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: rgba(255,255,255,.45); margin-bottom: 16px; }
    .price-main { font-size: 42px; font-weight: 700; color: #fff; line-height: 1; margin-bottom: 6px; }
    .price-note { font-size: 13px; color: rgba(255,255,255,.5); margin-bottom: 20px; }
    .price-items { border-top: 1px solid rgba(255,255,255,.1); padding-top: 16px; display: flex; flex-direction: column; gap: 10px; }
    .pi { display: flex; justify-content: space-between; font-size: 13px; }
    .pi-label { color: rgba(255,255,255,.55); }
    .pi-val { font-weight: 600; color: #fff; }
    .parts-note { margin-top: 14px; background: rgba(200,16,46,.15); border: 1px solid rgba(200,16,46,.3); border-radius: 7px; padding: 10px 14px; font-size: 12px; color: rgba(255,255,255,.7); line-height: 1.5; }
    .trust-bar { background: var(--red); padding: 13px 24px; }
    .trust-bar-inner { max-width: 1100px; margin: 0 auto; display: flex; gap: 20px; flex-wrap: wrap; justify-content: center; }
    .ti { display: flex; align-items: center; gap: 7px; font-size: 13px; font-weight: 500; color: #fff; }
    .section { padding: 68px 24px; }
    .section-gray { background: var(--gray); }
    .section-black { background: var(--black); color: #fff; }
    .container { max-width: 1100px; margin: 0 auto; }
    .sl { font-size: 12px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--red); margin-bottom: 12px; }
    h2 { font-size: clamp(22px, 3vw, 32px); font-weight: 700; line-height: 1.2; letter-spacing: -.02em; margin-bottom: 16px; }
    .section-black h2 { color: #fff; }
    .lead { font-size: 16px; line-height: 1.7; color: var(--muted); max-width: 680px; margin-bottom: 36px; }
    .section-black .lead { color: rgba(255,255,255,.62); }
    .body-text p { font-size: 16px; line-height: 1.75; color: var(--text); margin-bottom: 16px; }
    .body-text p:last-child { margin-bottom: 0; }
    .transparency-block { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 36px; }
    .tr-card { border-radius: 10px; padding: 24px; }
    .tr-card.them { background: #fdf2f2; border: 1px solid #f5c6c6; }
    .tr-card.us { background: #f0faf0; border: 1px solid #90d090; }
    .tr-card h3 { font-size: 14px; font-weight: 700; margin-bottom: 14px; }
    .tr-card.them h3 { color: #c02020; }
    .tr-card.us h3 { color: #207020; }
    .tr-list { list-style: none; }
