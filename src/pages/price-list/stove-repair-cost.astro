<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does stove repair cost in Los Angeles?", "acceptedAnswer": { "@type": "Answer", "text": "Labor costs for stove repair in Los Angeles typically run $150-$380 for standard brands. Burner ignition issues are the most common call and often run $150-$280. Parts are quoted separately after diagnosis. The $89 diagnostic fee applies to the repair when you approve the work." } },
      { "@type": "Question", "name": "One burner on my gas stove won't ignite. How much to fix?", "acceptedAnswer": { "@type": "Answer", "text": "A single burner not igniting is typically a spark igniter or electrode issue. Labor runs $150-$280 for standard brands. If a boilover caused it, the igniter may just need drying and cleaning with no parts needed. We check all burners while on site." } },
      { "@type": "Question", "name": "Why do you quote labor and parts separately?", "acceptedAnswer": { "@type": "Answer", "text": "Many appliance repair companies use flat-rate BlueBook pricing that bundles labor and parts into a single number before diagnosis. We quote separately. A boilover cleanup with no parts should not cost the same as an ignition module replacement. You see exactly what your repair requires." } },
      { "@type": "Question", "name": "Are parts included in the stove repair price?", "acceptedAnswer": { "@type": "Answer", "text": "No. The prices listed are labor costs only. Parts are quoted separately after we diagnose the specific failure. OEM parts are used wherever available. You see the full quote before we start." } },
      { "@type": "Question", "name": "What is the $89 diagnostic fee?", "acceptedAnswer": { "@type": "Answer", "text": "We charge $89 to come out and diagnose the problem. That fee applies to the repair total when you approve the work. If you decide not to repair, you pay $89 and we leave." } },
      { "@type": "Question", "name": "What warranty do you provide on stove repair in Los Angeles?", "acceptedAnswer": { "@type": "Answer", "text": "90 days on parts and labor. Same issue within 90 days and we come back at no charge. OEM parts wherever available." } }
    ]
  }
  <\/script>

