---
// Ice Maker Repair Cost in Los Angeles | Same Day Appliance Repair
// /price-list/ice-maker-repair-cost/
import Layout from '../../layouts/Layout.astro';

const title = "Ice Maker Repair Cost Los Angeles 2026 | Labor Rates";
const description = "Ice maker repair cost — built-in refrigerator ice makers and standalone undercounter units. Labor rates from $120. Parts quoted separately. $89 dx.";
---

<Layout title={title} description={description}>
<style>
    :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', -apple-system, sans-serif; color: var(--text); line-height: 1.6; }
    a { color: inherit; text-decoration: none; }
    .hero { background: var(--black); color: #fff; padding: 72px 24px 64px; }
    .hero-inner { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 340px; gap: 48px; align-items: center; }
    .hero-eyebrow { font-size: 12px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--red); margin-bottom: 14px; }
    .hero-sub { font-size: 16px; color: rgba(255,255,255,.68); line-height: 1.65; margin-bottom: 28px; }
    .hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; }
    .btn-red { background: var(--red); color: #fff; padding: 13px 26px; border-radius: 6px; font-size: 15px; font-weight: 600; }
    .btn-outline { border: 1.5px solid rgba(255,255,255,.3); color: #fff; padding: 13px 26px; border-radius: 6px; font-size: 15px; }
    .stars { color: #f59e0b; }
    .price-box { background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.15); border-radius: 14px; padding: 28px 24px; }
    .price-box-label { font-size: 11px; font-weight: 700; letter-spacing: .12em; text-transform: uppercase; color: rgba(255,255,255,.45); margin-bottom: 16px; }
    .price-main { font-size: 42px; font-weight: 700; color: #fff; line-height: 1; margin-bottom: 6px; }
    .price-note { font-size: 13px; color: rgba(255,255,255,.5); margin-bottom: 20px; }
    .price-items { border-top: 1px solid rgba(255,255,255,.1); padding-top: 16px; display: flex; flex-direction: column; gap: 10px; }
    .pi { display: flex; justify-content: space-between; font-size: 13px; }
    .pi-label { color: rgba(255,255,255,.55); }
    .pi-val { font-weight: 600; color: #fff; }
    .parts-note { margin-top: 14px; background: rgba(200,16,46,.15); border: 1px solid rgba(200,16,46,.3); border-radius: 7px; padding: 10px 14px; font-size: 12px; color: rgba(255,255,255,.7); line-height: 1.5; }
    .trust-bar { background: var(--red); padding: 13px 24px; }
    .trust-bar-inner { max-width: 1100px; margin: 0 auto; display: flex; gap: 20px; flex-wrap: wrap; justify-content: center; }
    .ti { display: flex; align-items: center; gap: 7px; font-size: 13px; font-weight: 500; color: #fff; }
    .section { padding: 68px 24px; }
    .section-gray { background: var(--gray); }
    .section-black { background: var(--black); color: #fff; }
    .container { max-width: 1100px; margin: 0 auto; }
    .sl { font-size: 12px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--red); margin-bottom: 12px; }
    h2 { font-size: clamp(22px, 3vw, 32px); font-weight: 700; line-height: 1.2; letter-spacing: -.02em; margin-bottom: 16px; }
    .section-black h2 { color: #fff; }
    .lead { font-size: 16px; line-height: 1.7; color: var(--muted); max-width: 680px; margin-bottom: 36px; }
    .body-text p { font-size: 16px; line-height: 1.75; color: var(--text); margin-bottom: 16px; }
    .body-text p:last-child { margin-bottom: 0; }
    .tip-block { background: #fff8e7; border: 1px solid #f0d070; border-radius: 8px; padding: 18px 20px; margin-top: 32px; }
    .tip-label { font-size: 12px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: #b08000; margin-bottom: 8px; }
    .tip-block p { font-size: 14px; line-height: 1.6; color: #6b5800; }
    .price-table-wrap { overflow-x: auto; margin-top: 8px; }
    .price-table { width: 100%; border-collapse: collapse; font-size: 15px; }
    .price-table th { text-align: left; padding: 13px 16px; background: var(--black); color: #fff; font-size: 12px; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; }
    .price-table td { padding: 14px 16px; border-bottom: 1px solid var(--border); vertical-align: top; }
    .price-table tr:last-child td { border-bottom: none; }
