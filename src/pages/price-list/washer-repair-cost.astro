    .bottom-ctas { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
    @media (max-width: 768px) { .hero-inner, .transparency-block, .rvr-grid { grid-template-columns: 1fr; } }
  </style>

<section class="hero">
  <div class="hero-inner">
