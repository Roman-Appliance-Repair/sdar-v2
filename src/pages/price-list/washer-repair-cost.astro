---
// Washing Machine Repair Cost Los Angeles | Same Day Appliance Repair
// /price-list/washer-repair-cost/
import Layout from '../../layouts/Layout.astro';

const title = "Washing Machine Repair Cost Los Angeles 2026 | Labor Rates";
const description = "Washer repair cost in Los Angeles — labor rates by repair type from $150. Parts quoted separately. No flat-rate guesswork. $89 diagnostic. (424) 325-0520.";
const schemaJson = `{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does washing machine repair cost in Los Angeles?", "acceptedAnswer": { "@type": "Answer", "text": "Labor costs for washer repair in Los Angeles typically run $150-$380 for standard brands depending on the problem. Parts are quoted separately after diagnosis. The $89 diagnostic fee is applied to the repair when you approve the work." } },
      { "@type": "Question", "name": "Why do you quote labor and parts separately?", "acceptedAnswer": { "@type": "Answer", "text": "Many appliance repair companies use flat-rate BlueBook pricing that bundles labor and parts into a single number before diagnosis. We quote them separately so you see exactly what you are paying for. A drain pump replacement and a control board failure are completely different jobs with very different part costs." } },
      { "@type": "Question", "name": "Are parts included in the washer repair price?", "acceptedAnswer": { "@type": "Answer", "text": "No. The prices listed are labor costs only. Parts are quoted separately after we diagnose the specific failure. OEM parts are used wherever available. You see the full quote before we start any repair work." } },
      { "@type": "Question", "name": "How much does stacked washer-dryer repair cost in Los Angeles?", "acceptedAnswer": { "@type": "Answer", "text": "Labor for stacked washer-dryer repair runs at the same rates as individual units but may include an access surcharge for tight installations. Stacked units in WeHo and Silver Lake apartments are among our most common repair scenarios. Parts are quoted separately after diagnosis." } },
      { "@type": "Question", "name": "How much does Miele or Bosch washer repair cost in Los Angeles?", "acceptedAnswer": { "@type": "Answer", "text": "Labor for Miele and Bosch washer repair runs $280-$560 or more depending on the failure. These brands use proprietary components with premium OEM pricing. Parts are quoted separately after diagnosis so you see exactly what the European-sourced components cost." } },
      { "@type": "Question", "name": "What is the $89 diagnostic fee?", "acceptedAnswer": { "@type": "Answer", "text": "We charge $89 to come out and diagnose the problem. That fee applies to the repair total when you approve the work. If you decide not to repair, you pay $89 and we leave." } },
      { "@type": "Question", "name": "What warranty do you provide on washer repair in Los Angeles?", "acceptedAnswer": { "@type": "Answer", "text": "90 days on parts and labor. Same issue within 90 days and we come back at no charge. OEM parts wherever available." } }
    ]
  }`;
---

<Layout title={title} description={description}>
  <Fragment slot="head-scripts">
    <script type="application/ld+json" set:html={schemaJson}></script>
  </Fragment>

<style>
    :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
