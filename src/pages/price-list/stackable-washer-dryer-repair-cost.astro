    .repair-desc { font-size: 13px; color: var(--muted); margin-top: 3px; }
    .price-labor { font-weight: 700; color: var(--red); }
    .price-parts-note { font-size: 12px; color: var(--muted); margin-top: 3px; }
    .luxury-badge { display: inline-block; background: #f5e6c8; color: #8a5a00; font-size: 10px; font-weight: 700; padding: 2px 7px; border-radius: 4px; margin-left: 6px; }
    .common-badge { display: inline-block; background: #e8f4fd; color: #1060a0; font-size: 10px; font-weight: 700; padding: 2px 7px; border-radius: 4px; margin-left: 6px; }
    .table-note { font-size: 13px; color: var(--muted); margin-top: 14px; padding: 13px 16px; background: var(--gray); border-radius: 6px; border-left: 3px solid var(--red); }
    .examples-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 16px; margin-top: 32px; }
    .example-card { background: #fff; border: 1px solid var(--border); border-radius: 10px; padding: 20px; }
    .ex-tag { display: inline-block; background: var(--gray); font-size: 11px; font-weight: 600; text-transform: uppercase; color: var(--muted); padding: 3px 8px; border-radius: 4px; margin-bottom: 10px; }
