  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "How much does microwave repair cost in Los Angeles?", "acceptedAnswer": { "@type": "Answer", "text": "Labor costs for microwave repair in Los Angeles typically run $100-$360 depending on the type and failure. Built-in and over-the-range microwaves cost more to repair due to installation access. Parts are quoted separately after diagnosis. The $89 diagnostic fee applies to the repair when you approve the work." } },
      { "@type": "Question", "name": "Is it worth repairing a countertop microwave in Los Angeles?", "acceptedAnswer": { "@type": "Answer", "text": "For a basic countertop microwave under $200, repair often does not make economic sense — a magnetron or control board replacement can exceed the unit value. However, over-the-range and built-in microwaves are almost always worth repairing because replacement requires installation work and costs significantly more. We give you an honest assessment after diagnosis." } },
      { "@type": "Question", "name": "Why do you quote labor and parts separately?", "acceptedAnswer": { "@type": "Answer", "text": "Many appliance repair companies use flat-rate BlueBook pricing that bundles labor and parts into a single number before diagnosis. We quote separately. A door latch fix and a magnetron replacement are completely different jobs. You see exactly what your specific repair requires." } },
      { "@type": "Question", "name": "Are microwaves dangerous to repair?", "acceptedAnswer": { "@type": "Answer", "text": "Microwave ovens contain high-voltage capacitors that can hold a lethal charge even when unplugged. Magnetron and capacitor repairs should only be performed by trained technicians with proper discharge procedures. Our technicians are trained in high-voltage microwave safety." } },
      { "@type": "Question", "name": "Are parts included in the microwave repair price?", "acceptedAnswer": { "@type": "Answer", "text": "No. The prices listed are labor costs only. Parts are quoted separately after we diagnose the specific failure. OEM parts are used wherever available. You see the full quote before we start." } },
      { "@type": "Question", "name": "What is the $89 diagnostic fee?", "acceptedAnswer": { "@type": "Answer", "text": "We charge $89 to come out and diagnose the problem. That fee applies to the repair total when you approve the work. If you decide not to repair, you pay $89 and we leave." } }
    ]
  }
