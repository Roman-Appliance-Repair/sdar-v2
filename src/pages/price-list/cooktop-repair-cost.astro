    .rvr-card.repair .rvr-list li::before { content: "\2713  "; color: #207020; }
    .rvr-card.replace .rvr-list li::before { content: "\2717  "; color: #c02020; }
    .examples-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 16px; margin-top: 32px; }
    .example-card { background: #fff; border: 1px solid var(--border); border-radius: 10px; padding: 20px; }
