const canonical = "https://samedayappliance.repair/price-list/range-hood-repair-cost/";

const faqs = [
  { q: "How much does range hood repair cost in Los Angeles?", a: "Labor costs for range hood repair in Los Angeles typically run $100-$320 depending on the failure type. Fan motor replacement is the most common repair and runs $150-$300. Parts are quoted separately after diagnosis. The $89 diagnostic fee applies to the repair when you approve the work." },
  { q: "Why is my range hood fan so loud?", a: "Loud range hood fans in LA kitchens are most commonly caused by grease buildup on fan blades causing imbalance, worn fan motor bearings, or a loose mounting. Grease buildup is extremely common in LA cooking environments. We clean and assess before replacing any components." },
  { q: "Why do you quote labor and parts separately?", a: "Many appliance repair companies use flat-rate BlueBook pricing that bundles labor and parts into a single number before diagnosis. We quote separately. A grease cleaning with no parts needed should not cost the same as a fan motor replacement." },
  { q: "Are parts included in the range hood repair price?", a: "No. The prices listed are labor costs only. Parts are quoted separately after we diagnose the specific failure. OEM parts are used wherever available. You see the full quote before we start." },
  { q: "What is the $89 diagnostic fee?", a: "We charge $89 to come out and diagnose the problem. That fee applies to the repair total when you approve the work. If you decide not to repair, you pay $89 and we leave." },
  { q: "What about commercial kitchen exhaust hood cost?", a: "This page covers residential range hood repair cost only. Commercial kitchen exhaust hoods (restaurant, foodservice, Captive-Aire, Halton, Greenheck, Gaylord, UL-300 fire suppression) are a separate equipment category with separate pricing. See /price-list/commercial-exhaust-hood-repair-cost/ for commercial exhaust hood repair cost and /commercial/exhaust-hood-repair/ for the commercial service page." }
];

