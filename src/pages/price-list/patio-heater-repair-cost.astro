  .section { padding: 64px 24px; }
  .section-gray { background: var(--gray); }
  .section-black { background: var(--black); color: #fff; }
  .container { max-width: 1100px; margin: 0 auto; }
  .container.narrow { max-width: 820px; }
  .sl { font-size: 12px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--red); margin-bottom: 12px; }
  h2 { font-size: clamp(22px, 3vw, 30px); font-weight: 800; line-height: 1.2; margin-bottom: 16px; color: var(--text); }
  .section-black h2 { color: #fff; }
  p { font-size: 16px; line-height: 1.75; color: var(--text); margin-bottom: 16px; }
  .section-black p { color: rgba(255,255,255,.78); }
