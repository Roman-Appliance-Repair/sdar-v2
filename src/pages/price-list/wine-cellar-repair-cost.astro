        <div class="brand-card"><h3>CellarCool</h3><p>Through-wall ducted and ductless</p></div>
        <div class="brand-card"><h3>Breezaire</h3><p>WKL and WKE series cooling units</p></div>
        <div class="brand-card"><h3>Wine Guardian</h3><p>Through-wall and ducted split systems</p></div>
        <div class="brand-card"><h3>Koolspace</h3><p>Commercial-grade cellar cooling</p></div>
        <div class="brand-card"><h3>Sub-Zero / Liebherr</h3><p>Integrated wine column and cellar units</p></div>
        <div class="brand-card"><h3>EuroCave</h3><p>French wine cellar units, all models</p></div>
        <div class="brand-card"><h3>Perlick / U-Line</h3><p>Built-in undercounter wine cellars</p></div>
      </div>
    </div>
  </div>
</section>

