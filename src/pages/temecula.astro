const citySlug = 'temecula';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = "Temecula";
const zips = ['92590', '92591', '92592'];

const phone = branch.phone;
const phoneRaw = `+1${phone.replace(/\D/g, '')}`;

const title = `Appliance Repair Temecula CA — Same Day | Wine Cooler Specialists | ${phone}`;
const description = `Same-day appliance repair in Temecula. Wine cooler, refrigerator, washer, dryer, oven & more. Redhawk, Wolf Creek, Harveston. Licensed. OEM parts.`;
const canonical = 'https://samedayappliance.repair/temecula/';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { '@type': 'City', name: 'Temecula', sameAs: 'https://en.wikipedia.org/wiki/Temecula,_California' },
    { '@type': 'PostalCode', postalCode: '92590' },
    { '@type': 'PostalCode', postalCode: '92591' },
    { '@type': 'PostalCode', postalCode: '92592' },
