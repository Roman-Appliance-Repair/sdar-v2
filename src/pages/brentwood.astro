---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import CustomNarrative from '../components/cities/v2/CustomNarrative.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

import { mergeCredentials } from '../data/credentials-schema';
const citySlug = 'brentwood';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = 'Brentwood';
const zips = ['90049'];

const phoneRaw = `+1${branch.phone.replace(/\D/g, '')}`;

const title = `Appliance Repair Brentwood CA 90049 — Sub-Zero · Wolf · Cove`;
const description = `Same-day appliance repair in Brentwood, CA 90049. Sub-Zero, Wolf, Viking, Thermador, Cove specialists. Licensed, OEM parts.`;
const canonical = 'https://samedayappliance.repair/brentwood/';

const localBusinessSchema = mergeCredentials({
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { '@type': 'Neighborhood', name: 'Brentwood', sameAs: 'https://en.wikipedia.org/wiki/Brentwood,_Los_Angeles' }
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$$',
  license: 'BHGS #A49573'

});

const introParagraphs = [
  "Brentwood is one of the more consistently high-end neighborhoods we work in. The kitchens in the canyon homes — Sullivan, Mandeville, Rustic — are built around Sub-Zero columns, Wolf dual-fuel ranges, and increasingly, Cove dishwashers since Fisher & Paykel started making serious inroads on the Westside. The homes along San Vicente and in Brentwood Village tend toward the same, often with custom cabinetry that makes access more complicated than a standard kitchen.",
  "We work in these homes regularly. Our technicians know how to service built-in Sub-Zero units without pulling out surrounding cabinetry. They carry OEM Wolf parts — igniters, gas valves, oven sensors — that most general repair companies don't stock. When a Cove dishwasher throws a drainage fault or a Wolf steam oven loses its sensor calibration, that's a normal Tuesday for our team.",
  `Diagnostic fee: <strong>$89</strong> — gone when you approve the repair. Written estimate before we touch anything. <strong>90-day warranty</strong> on parts and labor. Call <a href="tel:${phoneRaw}">${branch.phone}</a>.`,
  "<strong>From our techs on Brentwood built-ins:</strong> Sub-Zero built-in columns in custom cabinetry collect condenser dust faster than freestanding units — the airflow is tighter, there's less clearance around the coils. If your built-in Sub-Zero is running loudly or the compressor cycles frequently, condenser cleaning is often the fix. It takes about 20 minutes and adds years to the compressor life. We check this on every Sub-Zero call in Brentwood. <a href=\"/brands/liebherr/\">Liebherr</a> column installs follow the same pattern."
];

const services = [
  { icon: '🧊', name: 'Refrigerator Repair', slug: 'refrigerator', issues: 'Built-in columns · Not cooling · Ice maker · Coil cleaning · Panel-ready', brands: 'Sub-Zero · Wolf · True · GE Monogram · Viking · Samsung' },
  { icon: '🍽️', name: 'Cove & Dishwasher Repair', slug: 'dishwasher', issues: 'Cove drainage errors · Wash arm · Control board · Panel-ready Miele & Bosch', brands: 'Cove · Miele · Bosch · Thermador · KitchenAid · GE' },
  { icon: '🔥', name: 'Oven, Range & Steam Oven', slug: 'oven', issues: 'Wolf dual-fuel · Steam oven calibration · Igniter · Temperature off', brands: 'Wolf · Viking · Thermador · Dacor · Miele · GE Monogram' },
  { icon: '🫧', name: 'Washer & Dryer Repair', slug: 'washer', issues: 'Not draining · Not spinning · Vibration · Stackable units', brands: 'Miele · Bosch · LG · Samsung · Whirlpool · Speed Queen' },
  { icon: '🍷', name: 'Wine Cooler & Cellar', slug: 'wine-cooler', issues: 'Temperature fluctuation · Cooling failure · Built-in wine storage', brands: 'Sub-Zero · True · Liebherr · Thermador · U-Line · EuroCave' },
  { icon: '🔆', name: 'Cooktop & Range Hood', slug: 'cooktop', issues: 'Wolf star burner · Induction · Hood motor · Vent fan', brands: 'Wolf · Thermador · Viking · Miele · GE · Broan' },
  { icon: '❄️', name: 'Freezer Repair', slug: 'freezer', issues: 'Not freezing · Frost buildup · Temperature off · Built-in', brands: 'Sub-Zero · True · GE · Samsung · Whirlpool' },
  { icon: '🧊', name: 'Ice Maker Repair', slug: 'ice-maker', issues: 'Not producing · Inconsistent output · Leaking · Under-counter', brands: 'Sub-Zero · True · U-Line · GE Monogram · Scotsman' }
];

const coveNarrative = {
  eyebrow: 'COVE DISHWASHER SPECIALISTS — BRENTWOOD',
  headline: 'Cove Dishwasher Repair in Brentwood, CA',
  paragraphs: [
    "Cove — Fisher & Paykel's luxury dishwasher line — has become a common fixture in Brentwood kitchen remodels over the past several years. It's a premium product that most appliance repair companies in the area have never worked on. Our technicians have.",
    "Common Cove issues we see in Brentwood homes: drainage fault codes (the most frequent call), wash arm failures on the upper rack, control board communication errors on connected models, and door seal replacements on older units. The panel-ready installation typical in Brentwood kitchens requires careful disassembly — we don't damage the custom front panel or the surrounding cabinetry.",
    "We also service the full Fisher & Paykel range, Miele, Bosch, Thermador, and KitchenAid dishwashers — the other brands you'll find here.",
    "Dishwasher brands we service in Brentwood: Cove (Fisher & Paykel) · Miele · Bosch · Thermador · KitchenAid · GE Monogram · Samsung · LG."
  ]
};

const neighborhoods = [
  { name: 'Sullivan Canyon', zip: '90049', featured: true },
  { name: 'Mandeville Canyon', zip: '90049', featured: true },
  { name: 'Rustic Canyon', zip: '90049', featured: true },
  { name: 'Sepulveda Pass area', zip: '90049' },
  { name: 'North Brentwood hills', zip: '90049' },
  { name: 'Brentwood Village', zip: '90049' },
  { name: 'San Vicente Blvd corridor', zip: '90049' },
  { name: 'Bundy Drive area', zip: '90049' },
  { name: 'Barrington Ave area', zip: '90049' },
  { name: 'Montana Ave (west end)', zip: '90049' }
];

const recentJobs = [
  {
    appliance: 'Sub-Zero Built-In',
    location: 'Sullivan Canyon, 90049',
    quote: '"Sub-Zero running loud, back wall is warm"',
    description: 'Classic built-in condenser dust buildup — the tight custom cabinetry around this unit restricted airflow more than usual, accelerating dust accumulation. Our tech accessed the condenser through the bottom grille (without pulling the unit), cleaned the coils thoroughly, replaced a condenser fan capacitor showing weakness, and checked door seal compression on both compartments. Noise gone, running temperature back to normal. The homeowner had been ignoring the noise for about six months.',
    outcome: '✓ Same day · Coil cleaning + capacitor · No cabinetry moved'
  },
  {
    appliance: 'Cove Dishwasher',
    location: 'Brentwood Village, 90049',
    quote: '"Fault code after every cycle, won\'t drain"',
    description: 'Cove panel-ready unit installed flush with custom cabinetry. Drainage fault — turned out to be a blocked drain hose at the garbage disposal knockout plug (installer had forgotten to remove it). Classic install error. Our tech cleared the blockage, checked the drain pump impeller (clean), ran three full cycles to confirm. Whole job took 40 minutes. The kitchen designer was apparently mortified — it had been "broken" since the remodel completed.',
    outcome: '✓ Same day · Drain cleared · Panel undamaged'
  },
  {
    appliance: 'Wolf Dual-Fuel Range',
    location: 'Mandeville Canyon, 90049',
    quote: '"Oven won\'t reach temp, one burner dead"',
    description: 'Wolf 48-inch DF range — oven igniter drawing insufficient current, one Star burner igniter module failed. Replaced both with OEM Wolf parts. Calibrated the oven temperature — it was running 28°F low (common after igniter degradation). Checked all six burners, both ovens, and the broiler. Homeowner mentioned they thought the oven "just ran cool" and had been cooking everything at a higher temperature for over a year.',
    outcome: '✓ Same day · OEM Wolf parts · Recalibrated +28°F'
  },
  {
    appliance: 'Miele Washing Machine',
    location: 'Rustic Canyon, 90049',
    quote: '"F53 error, drum intermittently not spinning"',
    description: 'Miele W1 front-load — F53 is a motor communication fault. Found a failing motor brushes assembly and a loose motor hall sensor connection. Replaced brushes with OEM Miele parts, reseated the sensor connector, ran four test cycles including a high-speed spin. The intermittent nature had made the owner think it was "maybe fine" for three weeks — it wasn\'t, and would have fully failed soon. Caught it cleanly.',
    outcome: '✓ Same day · OEM Miele motor parts · 4 test cycles'
  }
];

const whyReasons = [
  {
    iconKey: 'parts' as const,
    title: 'Built-In Specialists',
    body: 'Sub-Zero built-ins, Wolf ranges, Cove and Miele panel-ready dishwashers — these need a different approach than freestanding appliances. We service built-ins regularly in Brentwood and know how to work within custom cabinetry without damage.'
  },
  {
    iconKey: 'shield' as const,
    title: 'OEM Parts for Luxury Brands',
    body: "Sub-Zero, Wolf, Thermador, Cove, Miele, Viking — we carry OEM parts for all of them on every service vehicle. We don't order parts and come back next week. The parts are on the truck."
  },
  {
    iconKey: 'team' as const,
    title: 'We Work with Estate Staff',
    body: 'Many Brentwood properties are managed by household staff or estate managers. We coordinate with whoever handles your property — flexible scheduling, clear communication, professional service that reflects the caliber of the home.'
  },
  {
    iconKey: 'clock' as const,
    title: '90-Day Warranty, No Exceptions',
    body: 'Every repair backed by 90 days on parts and labor. OEM parts only — never aftermarket. $89 diagnostic waived with repair. Written estimate before we start. California licensed, BBB Accredited.'
  }
];

const testimonials = [
  {
    stars: 5,
    text: '"Our Sub-Zero built-in in Sullivan Canyon was running loud for weeks. Same Day came out, cleaned the condenser inside the cabinet without moving anything, replaced a capacitor, done in under an hour. They clearly know Sub-Zero units. Very impressed."',
    author: '— Patricia H., Sullivan Canyon, Brentwood'
  },
  {
    stars: 5,
    text: '"Cove dishwasher had been faulting since our kitchen remodel. Nobody would touch it. Same Day Appliance Repair actually knew the brand, came out same day, found it was a blocked drain from the install, fixed it in 40 minutes. The whole problem was there from day one."',
    author: '— Mark T., Brentwood Village, Brentwood'
  },
  {
    stars: 5,
    text: '"Wolf range in our Mandeville Canyon home — oven running low and one burner out. Tech had all the OEM Wolf parts, recalibrated the oven after the repair. Turns out it had been 28 degrees low for over a year. Everything cooks correctly now for the first time in memory."',
    author: '— Claire M., Mandeville Canyon, Brentwood'
  }
];

const pricingTiers = [
  { appliance: 'Refrigerator (standard)', range: '$200–$450', note: 'Fan motor, coil cleaning, ice maker, thermostat' },
  { appliance: 'Sub-Zero / Wolf Built-In', range: '$300–$700+', note: 'OEM parts · Built-in access · Sealed system work', featured: true },
  { appliance: 'Cove / Miele Dishwasher', range: '$200–$450', note: 'Panel-ready · OEM parts · Control board' },
  { appliance: 'Wolf / Viking Range', range: '$250–$550', note: 'Igniters, gas valves, calibration, OEM Wolf/Viking parts' },
  { appliance: 'Washer / Dryer', range: '$150–$400', note: 'Miele & European models may cost more' },
  { appliance: 'Diagnostic Fee', range: '$89', note: 'Waived when you proceed with the repair' }
];

const faqs = [
  {
    question: 'Do you offer same-day appliance repair in Brentwood, CA?',
    answer: 'Yes. Our technicians cover all of Brentwood — Sullivan Canyon, Mandeville Canyon, Rustic Canyon, Brentwood Village, San Vicente Blvd corridor, and the areas bordering West LA and Westwood. We serve ZIP code 90049. Call before noon for same-day afternoon service.'
  },
  {
    question: 'Do you repair Cove dishwashers in Brentwood?',
    answer: "Yes. Cove dishwashers — Fisher & Paykel's premium brand — appear frequently in Brentwood kitchen remodels. Our technicians are trained on Cove systems and carry parts specific to these units. Common issues include drainage errors, wash arm failures, and control board faults."
  },
  {
    question: 'Do you repair Sub-Zero and Wolf appliances in Brentwood?',
    answer: 'Yes. Sub-Zero built-in refrigerators, Wolf dual-fuel ranges, and Wolf steam ovens are standard in Brentwood kitchens. Our technicians are trained on both brands, carry OEM parts, and work in custom cabinetry installations regularly. We handle built-in panel-ready units without damaging surrounding joinery.'
  },
  {
    question: 'What is your diagnostic fee in Brentwood?',
    answer: 'Our diagnostic fee is $89, waived when you proceed with the repair. For luxury brands — Sub-Zero, Wolf, Viking, Thermador, Cove — repair costs may be higher due to OEM part pricing. We give you a full written estimate before starting any work.'
  },
  {
    question: 'Do you work with property managers and estate staff in Brentwood?',
    answer: 'Yes. Brentwood has a high proportion of managed estates and properties handled by household staff. We coordinate with estate managers, work around household schedules, and can bill through property management systems. Call us to discuss how we work with your property.'
  },
  {
    question: 'What warranty do you offer on appliance repairs in Brentwood?',
    answer: 'All repairs come with a 90-day warranty on parts and labor. We use genuine OEM parts only. If the same issue returns within 90 days, we come back and fix it at no charge.'
  },
  {
    question: 'Do you also serve Pacific Palisades, Santa Monica, and Westwood from Brentwood?',
    answer: "Yes. Our Brentwood service area extends to Pacific Palisades, Santa Monica, Westwood, West LA, Bel Air, and Mar Vista. If you're on the Westside in the 90049, 90272, 90024, or 90025 ZIP codes, we're likely your closest team."
  }
];

const nearbyCities = [
  { name: 'Pacific Palisades', slug: 'pacific-palisades' },
  { name: 'Santa Monica', slug: 'santa-monica' },
  { name: 'Beverly Hills', slug: 'beverly-hills' },
  { name: 'West Hollywood', slug: 'west-hollywood' },
  { name: 'Los Angeles', slug: 'los-angeles' },
  { name: 'Culver City', slug: 'culver-city' },
  { name: 'Malibu', slug: 'malibu' },
  { name: 'Marina del Rey', slug: 'marina-del-rey' }
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair"
    headlineCity="Brentwood, CA"
    subheadline="Sub-Zero, Wolf, Viking, Thermador, Cove — the appliances that define Brentwood kitchens. Our technicians work in this ZIP regularly, know the canyon streets, and come prepared for built-in luxury systems. Same-day service, OEM parts, 90-day warranty."
    zips={zips}
    tier={1}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance Repair in Brentwood — What Our Technicians Actually See Here"
    paragraphs={introParagraphs}
    bookingTitle="Brentwood Service Team"
    bookingSub="90049 · Sub-Zero · Wolf · Cove · Same day"
  />

  <ServicesGrid
    cityName={cityName}
    headline="What We Repair in Brentwood"
    subhead="Luxury brands & everyday appliances · Built-ins & freestanding · 90049"
    services={services}
  />

  <CustomNarrative
    eyebrow={coveNarrative.eyebrow}
    headline={coveNarrative.headline}
    paragraphs={coveNarrative.paragraphs}
    background="black"
  />

  <ServiceArea
    cityName={cityName}
    headline="We Cover All of Brentwood — 90049"
    subheadline="Every street, every canyon, every corner of the ZIP"
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={[]}
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Jobs Our Team Did in Brentwood"
    jobs={recentJobs}
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="Why Brentwood Homeowners Call Us"
    reasons={whyReasons}
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What Brentwood Clients Are Saying"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Appliance Repair Costs in Brentwood"
    subhead="Written estimate before we start. $89 diagnostic — waived with repair. OEM parts only."
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="Questions Brentwood Clients Ask"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby Areas"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance broken in Brentwood? We're on the Westside."
    body="Sub-Zero · Wolf · Cove · Miele · all brands — same-day service in 90049. $89 diagnostic waived with repair. 90-day warranty. OEM parts only."
  />
</CityLayoutV2>
