---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import CustomNarrative from '../components/cities/v2/CustomNarrative.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

const citySlug = 'torrance';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = "Torrance";
const zips = ["90501", "90502", "90503", "90504", "90505"];

const phone = branch.phone;
const phoneRaw = `+1${phone.replace(/\D/g, '')}`;

const title = `Appliance Repair Torrance CA — Same Day | Hollywood Riviera · Old Torrance · Walteria | ${phone}`;
const description = `Same-day appliance repair in Torrance, CA. Hollywood Riviera, Old Torrance, Walteria, North Torrance, South Torrance. All ZIP codes 90501–90505. Samsung, LG, GE, Whirlpool, Sub-Zero. Licensed, OEM parts, 90-day warranty. Call ${phone}.`;
const canonical = "https://samedayappliance.repair/torrance/";

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  name: branch.fullName,
  image: "https://samedayappliance.repair/images/logo.webp",
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { "@type": "City", name: "Torrance", sameAs: "https://en.wikipedia.org/wiki/Torrance,_California" },
    { "@type": "Neighborhood", name: "Hollywood Riviera" },
    { "@type": "Neighborhood", name: "Old Torrance" },
    { "@type": "Neighborhood", name: "Walteria" },
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: "$$",
  license: "CA BHGS #A49573"

};

const introParagraphs = [
  "Torrance spans more terrain than most South Bay cities. The Hollywood Riviera in the southwest sits on a coastal bluff with ocean views and correspondingly nice homes — Sub-Zero and Wolf show up here with some regularity. Old Torrance around Sartori Avenue has Craftsman bungalows from the 1910s and 1920s that are well maintained and well loved. Walteria on the eastern hills has larger mid-century homes. North Torrance along Crenshaw and Hawthorne is one of the South Bay's most active corridors with a dense mix of housing types. South Torrance near the boundary with Redondo Beach and Palos Verdes is established residential.",
  "The Hollywood Riviera does see some coastal influence — not as aggressive as oceanfront Newport Beach or Huntington Harbour, but enough that refrigerators on the bluff side can see accelerated coil wear compared to inland Torrance. We check on relevant calls. Inland Torrance is standard South Bay — no salt air factor, just reliable same-day service with an honest written estimate.",
  "Diagnostic fee: <strong>$89</strong> — waived with repair. Written estimate before we start. <strong>90-day warranty</strong>. Weekends available.",
];

const areasNarrative = {
  eyebrow: "Torrance Coverage",
  headline: "Torrance — All Neighborhoods",
  paragraphs: [
    "Hollywood Riviera to North Torrance — same commitment across all ZIP codes.",
  ],
  subSections: [
    {
      title: "Hollywood Riviera (Coastal Bluff)",
      paragraphs: [
        "Ocean-facing bluff homes in the 90277/90278 border area. Sub-Zero and premium brands common. Moderate coastal exposure — we check coils on relevant calls. ZIP 90503 · 90505.",
      ]
    },
    {
      title: "Old Torrance (Historic Core)",
      paragraphs: [
        "Craftsman bungalows and early 20th century homes around Sartori Ave and the historic downtown. Well-maintained older housing with mix of vintage and modern appliances. ZIP 90501.",
      ]
    },
    {
      title: "Walteria (Hillside)",
      paragraphs: [
        "Eastern Torrance hillside with larger mid-century homes and established landscaping. GE, Samsung, LG common. Standard same-day service profile. ZIP 90505.",
      ]
    },
    {
      title: "North Torrance (South Bay Corridor)",
      paragraphs: [
        "Dense residential along Crenshaw/Hawthorne corridor. Mix of single-family and multi-family. LG, Samsung, Whirlpool most common. ZIP 90504.",
      ]
    },
    {
      title: "South Torrance (Established Residential)",
      paragraphs: [
        "Borders Redondo Beach and PV. Well-kept mid-century and newer homes. Standard appliance profile — all brands serviced same day. ZIP 90503 · 90505.",
      ]
    },
    {
      title: "Central Torrance",
      paragraphs: [
        "Del Amo area, Madrona Ave, Anza Ave corridor. All brands, all housing types. Same-day available throughout. ZIP 90503 · 90504.",
      ]
    },
  ]
};

const services = [
  { icon: '🧊', name: 'Refrigerator Repair', slug: 'refrigerator', issues: 'Not cooling · Ice maker · Coastal coil check · Fan motor', brands: 'Samsung · LG · GE · Whirlpool · Sub-Zero · Bosch' },
  { icon: '🫧', name: 'Washer Repair', slug: 'washer', issues: 'OE / UE error · Not draining · Not spinning · Stackable', brands: 'LG · Samsung · Whirlpool · Maytag · Bosch · Speed Queen' },
  { icon: '♨️', name: 'Dryer Repair + Vent Cleaning', slug: 'dryer', issues: 'Not heating · Thermal fuse · Vent lint buildup · Gas & electric', brands: 'LG · Samsung · GE · Maytag · Whirlpool · Electrolux' },
  { icon: '🍽️', name: 'Dishwasher Repair', slug: 'dishwasher', issues: 'Not draining · E24 · Error codes · Spray arm', brands: 'Bosch · KitchenAid · Samsung · LG · GE · Miele' },
  { icon: '🔥', name: 'Oven, Range & Stove', slug: 'oven', issues: 'Not heating · Gas igniter · Temperature off · Gas & electric', brands: 'GE · Samsung · Bosch · Wolf · Viking · KitchenAid' },
  { icon: '❄️', name: 'Freezer & Ice Maker Repair', slug: 'freezer', issues: 'Not freezing · Ice stopped · Frost buildup · Sub-Zero', brands: 'Samsung · LG · GE · Whirlpool · Sub-Zero · True' },
  { icon: '🍷', name: 'Wine Cooler Repair', slug: 'wine-cooler', issues: 'Temperature off · Compressor · Under-counter · Built-in', brands: 'True · U-Line · Liebherr · Dacor · Sub-Zero' },
  { icon: '🔆', name: 'Cooktop & Range Hood', slug: 'cooktop', issues: 'Gas igniter · Burner · Induction not heating · Hood motor', brands: 'GE · Bosch · Samsung · Wolf · Thermador · Broan' },
];

const neighborhoods = [
  { name: 'Hollywood Riviera', zip: '90505', featured: true },
  { name: 'Old Torrance', zip: '90501', featured: true },
  { name: 'Walteria', zip: '90505' },
  { name: 'North Torrance', zip: '90504' },
  { name: 'South Torrance', zip: '90505' },
  { name: 'Central Torrance', zip: '90503' },
];

const recentJobs = [
  {
    appliance: 'Sub-Zero Refrigerator',
    location: 'Hollywood Riviera, 90505',
    quote: '"Running longer than it used to — cycling almost constantly"',
    description: "Bluff-side home in the Hollywood Riviera — Sub-Zero 36-inch built-in with condenser coils showing moderate salt air particulate accumulation from the coastal bluff exposure. Not as severe as oceanfront Newport Beach, but measurable. Cleaned the coil assembly thoroughly, checked the fan motor (still good), confirmed door seals on both columns. Cycling normalised within the hour. Placed on an annual coil inspection schedule — appropriate for a bluff-adjacent property with this level of exposure.",
    outcome: '✓ Same day · Coils cleaned · Normal cycling · Annual plan set'
  },
  {
    appliance: 'Samsung Washer',
    location: 'Old Torrance, 90501',
    quote: '"dc error, violent vibration — can\'t finish a spin cycle"',
    description: "Old Torrance Craftsman home — Samsung front-loader dc (unbalanced) error on every cycle. Found two rear shock absorbers failed and two more weakened — causing the drum to cant and trigger the balance sensor regardless of load distribution. Replaced all four with OEM Samsung parts, levelled the machine on the laundry room floor, ran three full spin cycles at maximum speed. Completely smooth. Family had been re-distributing loads and re-spinning for weeks.",
    outcome: '✓ Same day · OEM Samsung shocks · All four · Full spin confirmed'
  },
  {
    appliance: 'LG Dryer',
    location: 'Walteria, 90505',
    quote: '"d80 flow sense — takes forever, two full cycles every load"',
    description: "LG electric dryer in a Walteria home — d80 flow sense warning indicating 80% vent blockage. Found a significant lint accumulation inside a long vent run that terminated on the hillside wall with a plastic flap cap that had warped partially closed. Cleared the full vent run, replaced the plastic cap with a proper metal backdraft damper, confirmed strong airflow at the termination. d80 cleared immediately. Single-cycle drying confirmed on the first test load.",
    outcome: '✓ Same day · Vent cleared · Metal cap installed · d80 gone · Single cycle'
  },
  {
    appliance: 'Bosch Dishwasher',
    location: 'North Torrance, 90504',
    quote: '"E24 drain error — standing water, happened out of nowhere"',
    description: "Bosch 500 series in a North Torrance home — E24 drain error with a full tub of standing water. Combined issue: drain pump housing partially blocked by debris, and the filter trap overdue for cleaning. Cleared both, ran the Bosch diagnostic cycle, confirmed complete drain on three consecutive cycles. Also noticed the knockout plug in the garbage disposal connection had never been removed at installation — partial restriction for the full life of the machine. Removed it. First load out: completely clear tub.",
    outcome: '✓ Same day · E24 resolved · Disposal knockout removed · Full drain confirmed'
  },
];

const whyReasons = [
  {
    iconKey: 'team' as const,
    title: 'All of Torrance',
    body: 'Hollywood Riviera bluff homes to North Torrance corridor apartments to Old Torrance bungalows to Walteria hillside homes. We cover all of it with the same same-day commitment, OEM parts, and 90-day warranty regardless of the neighborhood.'
  },
  {
    iconKey: 'parts' as const,
    title: 'Coastal Factor Awareness',
    body: 'The Hollywood Riviera sits on a coastal bluff — not as aggressive as oceanfront HB or Newport, but enough to see moderately accelerated coil wear on refrigerators. We check on relevant bluff-side calls. Inland Torrance? Standard service, no coastal factor.'
  },
  {
    iconKey: 'clock' as const,
    title: 'Actually Same Day',
    body: "Torrance is a regular part of our South Bay route — not a special trip. Call before noon and we're typically there that afternoon. We don't use a national dispatch center. We're local and we cover this area consistently."
  },
  {
    iconKey: 'shield' as const,
    title: '90-Day Warranty, OEM Only',
    body: 'Every repair backed by 90 days on parts and labor. Genuine OEM parts only — never aftermarket. $89 diagnostic waived with repair. Written estimate before we start. California licensed, BBB A+ rated. Weekends available.'
  },
];

const testimonials = [
  {
    stars: 5,
    text: '"Sub-Zero in our Hollywood Riviera home was cycling constantly. Tech came out, cleaned the coastal coil buildup, confirmed everything else was fine, put us on an annual maintenance plan for our bluff location. Normal operation immediately. Really appreciated the specific coastal context rather than generic advice."',
    author: '— Patricia M., Hollywood Riviera, Torrance'
  },
  {
    stars: 5,
    text: '"LG dryer d80 flow sense in our Walteria home. Tech cleared the whole vent run, replaced the warped plastic cap with a proper metal one. d80 gone, single-cycle drying confirmed before he left. Explained the whole vent situation clearly — the hillside termination point had been restricting airflow for years."',
    author: '— Marcus K., Walteria, Torrance'
  },
  {
    stars: 5,
    text: '"Bosch E24 error in our North Torrance home. Tech cleared the pump and filter, then found the garbage disposal knockout was never removed at installation. Fixed two problems, charged for one call. Very thorough — checked things other companies would have missed and never mentioned."',
    author: '— Sandra R., North Torrance'
  },
];

const pricingTiers = [
  { appliance: 'Refrigerator / Ice Maker', range: '$150 – $400', note: 'Coastal coil check (Riviera) · Fan motor · Ice maker · OEM', featured: true },
  { appliance: 'Washer / Dryer', range: '$150 – $350', note: 'Shock absorbers · Drain pump · Thermal fuse · Vent cleaning' },
  { appliance: 'Dishwasher', range: '$150 – $320', note: 'E24 drain · Spray arm · Disposal knockout · Filter' },
  { appliance: 'Oven / Range', range: '$150 – $400', note: 'Gas igniter · Bake element · Temperature calibration' },
  { appliance: 'Sub-Zero / Wolf', range: '$300 – $700+', note: 'OEM parts · Hollywood Riviera luxury homes' },
  { appliance: 'Diagnostic Fee', range: '$89', note: 'Waived when you proceed with the repair' },
];

const faqs = [
  {
    question: "Do you offer same-day appliance repair in Torrance, CA?",
    answer: "Yes. Our technicians cover all of Torrance — Hollywood Riviera, Old Torrance, Walteria, North Torrance, South Torrance, and all ZIP codes 90501 through 90505. Call before noon for same-day afternoon service."
  },
  {
    question: "Does coastal proximity affect appliances in Torrance's Hollywood Riviera?",
    answer: "Yes, moderately. The Riviera bluff sees some coastal exposure — not as aggressive as oceanfront cities, but enough to see moderately accelerated coil wear. We check on relevant bluff-side calls. Inland Torrance has no coastal factor."
  },
  {
    question: "Are you available on weekends in Torrance?",
    answer: "Yes. Saturday 8am–7pm and Sunday 9am–5pm."
  },
  {
    question: "What appliance brands do you repair in Torrance?",
    answer: "All major brands: Samsung, LG, GE, Whirlpool, KitchenAid, Bosch, Maytag, Sub-Zero, Wolf, Viking, and more. OEM parts on every vehicle."
  },
  {
    question: "What is your diagnostic fee in Torrance?",
    answer: "Our diagnostic fee is $89, waived when you proceed with the repair. Written estimate before we start. Most Torrance repairs run $150–$400."
  },
  {
    question: "What warranty do you offer on appliance repairs in Torrance?",
    answer: "All repairs come with a 90-day warranty on parts and labor. Genuine OEM parts only. If the same issue returns within 90 days, we come back at no charge."
  },
  {
    question: "Do you also serve Redondo Beach, Manhattan Beach, and Carson?",
    answer: "Yes. Our Torrance service extends to Redondo Beach, Manhattan Beach, Lawndale, Hawthorne, Carson, Gardena, and all of the South Bay area."
  },
];

const nearbyCities = [
  { name: 'Manhattan Beach', slug: 'manhattan-beach' },
  { name: 'Los Angeles', slug: 'los-angeles' },
  { name: 'Santa Monica', slug: 'santa-monica' },
  { name: 'Culver City', slug: 'culver-city' },
  { name: 'Long Beach', slug: 'long-beach' },
  { name: 'Beverly Hills', slug: 'beverly-hills' },
  { name: 'West Hollywood', slug: 'west-hollywood' },
  { name: 'Brentwood', slug: 'brentwood' },
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair"
    headlineCity="Torrance, CA"
    subheadline="One of the South Bay's most established cities — coastal bluff homes in the Hollywood Riviera, historic Craftsman bungalows in Old Torrance, well-kept mid-century homes throughout. All appliances, all neighborhoods, same-day. OEM parts, 90-day warranty. Weekends available."
    zips={zips}
    tier={2}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance Repair in Torrance — All of It"
    paragraphs={introParagraphs}
    bookingTitle="Torrance Service"
    bookingSub="90501–90505 · All neighborhoods · Same day"
  />

  <CustomNarrative
    eyebrow={areasNarrative.eyebrow}
    headline={areasNarrative.headline}
    paragraphs={areasNarrative.paragraphs}
    subSections={areasNarrative.subSections}
    background="gray"
  />

  <ServicesGrid
    cityName={cityName}
    headline="What We Repair in Torrance"
    subhead="All brands · Coastal & inland · All ZIP codes · South Bay same-day"
    services={services}
  />

  <ServiceArea
    cityName={cityName}
    headline="Torrance Neighborhoods We Service"
    subheadline="Hollywood Riviera to North Torrance — every street in 90501–90505."
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={[]}
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Jobs in Torrance"
    subhead="Real calls from 90501–90505 — all neighborhoods, all brands."
    jobs={recentJobs}
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="Why Torrance Calls Us Back"
    reasons={whyReasons}
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What Torrance Customers Are Saying"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Appliance Repair Costs in Torrance"
    subhead="Written estimate before we start. $89 diagnostic — waived with repair."
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="Questions Torrance Customers Ask"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby Areas"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance broken in Torrance?"
    body="Hollywood Riviera · Old Torrance · Walteria · North & South Torrance · All of 90501–90505. $89 diagnostic waived with repair. 90-day warranty."
  />
</CityLayoutV2>
