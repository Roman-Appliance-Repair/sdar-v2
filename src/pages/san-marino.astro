---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import CustomNarrative from '../components/cities/v2/CustomNarrative.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

const citySlug = 'san-marino';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = 'San Marino';
const zips = ['91108'];

const phoneRaw = `+1${branch.phone.replace(/\D/g, '')}`;

const title = `Appliance Repair San Marino CA 91108 — Same Day | Estate Service · Sub-Zero · Wolf | ${branch.phone}`;
const description = `Same-day appliance repair in San Marino, CA 91108. Estate homes, Sub-Zero, Wolf, Thermador, Miele. Huntington Drive, Virginia Road, Lorain Road. Licensed, OEM parts, 90-day warranty. Call ${branch.phone}.`;
const canonical = 'https://samedayappliance.repair/san-marino/';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { '@type': 'City', name: 'San Marino', sameAs: 'https://en.wikipedia.org/wiki/San_Marino,_California' },
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$$',
  license: 'CA CSLB #1138898',
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.6',
    reviewCount: '37',
    bestRating: '5',
  },
};

const introParagraphs = [
  "San Marino is entirely residential — no commercial strips, no apartment buildings, no industrial zones. Just homes, and the kinds of homes that come with serious kitchens. The Mediterranean and Colonial Revival estates along Huntington Drive, Virginia Road, and Lorain Road have been updated and renovated over decades, and their kitchens reflect that investment: Sub-Zero column refrigerators, Wolf dual-fuel ranges, Thermador steam ovens, Miele and Gaggenau dishwashers and appliance suites.",
  "Our technicians work in San Marino regularly. We carry OEM parts for Sub-Zero, Wolf, Thermador, Miele, and Gaggenau on every service vehicle and are trained on their specific systems and failure modes. Many San Marino calls are coordinated through housekeepers or household staff — we work with them professionally, arrive as scheduled, and provide service documentation when needed.",
  "Hard water is a real factor in San Marino. The city is served by the San Gabriel Valley Municipal Water District, drawing from the mineral-rich SGV groundwater basin. Ice maker inlet valves, dishwasher spray arms, and washing machine inlet screens scale up faster here than in softer-water areas. We test for this on every relevant San Marino call.",
  `Diagnostic fee: <strong>$89</strong> — waived with repair. Written estimate before we start. <strong>90-day warranty</strong> on all parts and labor. OEM parts only — never aftermarket substitutes. Call <a href="tel:${phoneRaw}">${branch.phone}</a>.`,
];

const brandsNarrative = {
  eyebrow: 'WHAT WE SERVICE IN SAN MARINO KITCHENS',
  headline: 'The Brands Found in San Marino Homes — and What We Know About Them',
  paragraphs: [
    "Sub-Zero's dual-evaporator architecture and sealed system requirements. Wolf's star burner configuration and dual-fuel oven precision. Thermador's ProGrand range specifics and Freedom induction. Miele's dishwasher and laundry electronic control platforms. Gaggenau's steam combi oven systems.",
    "We carry OEM parts for all of these on every San Marino vehicle. We know their failure modes because we service them in homes throughout the SGV and Westside regularly — not as occasional calls, but as a consistent part of our work.",
    "Brands we service: Sub-Zero · Wolf · Thermador · Miele · Gaggenau · Monogram · Viking · True Residential · Dacor · Fisher & Paykel · Cove · La Cornue. Plus all standard brands — Samsung, LG, GE, Whirlpool, Bosch, KitchenAid, Maytag, and more.",
  ],
};

const services = [
  { icon: '🧊', name: 'Refrigerator Repair', slug: 'refrigerator', issues: 'Hard water ice maker · Built-in columns · Not cooling · Sealed system', brands: 'Sub-Zero · Wolf · True · Monogram · Samsung · LG' },
  { icon: '🔥', name: 'Oven, Range & Steam Oven', slug: 'oven', issues: 'Dual-fuel · Steam combi · Temperature off · Igniter · Calibration', brands: 'Wolf · Gaggenau · Thermador · Miele · Viking · La Cornue' },
  { icon: '🍽️', name: 'Dishwasher Repair', slug: 'dishwasher', issues: 'Hard water spray arm scale · Panel-ready · Miele errors · Error codes', brands: 'Miele · Gaggenau · Thermador · Bosch · Cove · KitchenAid' },
  { icon: '🫧', name: 'Washer & Dryer Repair', slug: 'washer', issues: 'Miele T1 heat pump · Hard water inlet · European models', brands: 'Miele · Gaggenau · LG · Samsung · Bosch · Speed Queen' },
  { icon: '🍷', name: 'Wine Cellar & Cooler Repair', slug: 'wine-cooler', issues: 'Temperature off · Humidity control · WhisperKOOL · Sub-Zero wine', brands: 'Sub-Zero · EuroCave · True · WhisperKOOL · Liebherr · U-Line' },
  { icon: '🔆', name: 'Cooktop & Range Hood', slug: 'cooktop', issues: 'Thermador Freedom induction · Wolf star burner · Hood systems', brands: 'Wolf · Thermador · Gaggenau · Miele · Viking · Dacor' },
  { icon: '🧊', name: 'Ice Machine & Ice Maker', slug: 'ice-maker', issues: 'SGVMWD hard water scale · Low production · Inlet valve · Built-in', brands: 'Sub-Zero · True · Scotsman · U-Line · GE Monogram' },
  { icon: '❄️', name: 'Freezer Repair', slug: 'freezer', issues: 'Built-in columns · Not freezing · Sealed system · Frost buildup', brands: 'Sub-Zero · True · GE Monogram · Thermador · Viking' },
];

const neighborhoods = [
  { name: 'Huntington Drive corridor', zip: '91108', featured: true },
  { name: 'Virginia Road', zip: '91108', featured: true },
  { name: 'Lorain Road', zip: '91108', featured: true },
  { name: 'San Marino Avenue', zip: '91108' },
  { name: 'Rosemead Boulevard', zip: '91108' },
  { name: 'Huntington Library adjacent', zip: '91108' },
  { name: 'Oak Knoll area', zip: '91108' },
  { name: 'Lacy Park neighborhood', zip: '91108' },
];

const recentJobs = [
  {
    appliance: 'Sub-Zero Built-In',
    location: 'Huntington Drive, 91108',
    quote: '"Ice maker stopped, fridge running constantly"',
    description: 'Coordinated through the housekeeper — access via the service entrance. Sub-Zero 48-inch column: inlet valve blocked by SGVMWD mineral scale, and the condenser coils had significant dust accumulation inside the cabinet. Replaced the inlet valve with an OEM Sub-Zero part, cleaned the condenser coil assembly, replaced the in-door filter. Ice production restored within 24 hours. Service report provided to the household. Owner put on a 6-month filter and annual coil inspection schedule.',
    outcome: '✓ Same day · Housekeeper coordinated · OEM Sub-Zero · Report delivered',
  },
  {
    appliance: 'Wolf Dual-Fuel Range',
    location: 'Virginia Road, 91108',
    quote: '"Oven not reaching temperature, three star burners sparking"',
    description: 'Wolf 48-inch dual-fuel — oven igniter drawing weak current, three surface igniter electrodes corroded. This is a large kitchen with the range installed under a custom stone hood — our tech worked in that configuration carefully. Replaced oven igniter and all three surface electrodes with OEM Wolf parts, calibrated oven (was running 25°F low). Tested all eight burners and both ovens before leaving. The household chef ran a full test meal. Approved.',
    outcome: '✓ Same day · OEM Wolf · All burners confirmed · Chef sign-off',
  },
  {
    appliance: 'Miele Dishwasher',
    location: 'Lorain Road, 91108',
    quote: '"F70 error, dishwasher not draining, water in the base"',
    description: 'Miele G 7000 panel-ready — F70 is a water intake/drainage fault. Found the drain pump partially blocked by mineral deposits from the SGV water supply, combined with a small amount of debris in the filter. Cleared the pump and filter, ran the Miele diagnostic cycle, confirmed full drain function across three cycles. The panel-front cabinetry required careful handling — came out and went back in without a mark.',
    outcome: '✓ Same day · Miele G 7000 · Panel cabinetry intact · 3 cycles confirmed',
  },
  {
    appliance: 'Samsung Refrigerator',
    location: 'Oak Knoll area, 91108',
    quote: '"Ice maker dropped to almost nothing over 4 months"',
    description: 'Gradual ice production decline — the pattern of SGVMWD hard water mineral buildup on the inlet valve. Samsung French door: valve orifice significantly restricted. Replaced the inlet valve with an OEM Samsung part, flushed the water line, replaced the in-door filter (original, never changed in 3 years). Full ice production within 24 hours. Owner now understands the water quality situation in San Marino and has a maintenance plan.',
    outcome: '✓ Same day · OEM Samsung inlet valve · Hard water cause explained',
  },
];

const whyReasons = [
  {
    iconKey: 'parts' as const,
    title: 'Luxury Brand Depth',
    body: 'Sub-Zero, Wolf, Thermador, Miele, Gaggenau — we carry OEM parts for all of these on every San Marino vehicle. We know their failure modes, service procedures, and part sourcing. Not a general company that "also does" luxury brands.',
  },
  {
    iconKey: 'team' as const,
    title: 'Household Staff Coordination',
    body: 'Many San Marino households have housekeepers or household staff who manage service calls. We coordinate with them professionally, arrive on schedule, work cleanly, and provide documentation. The homeowner stays uninvolved if preferred.',
  },
  {
    iconKey: 'shield' as const,
    title: 'SGVMWD Hard Water Aware',
    body: 'San Gabriel Valley groundwater is mineral-rich. Ice makers and dishwashers scale up faster in San Marino than in softer-water cities. We test inlet valves and check for mineral deposits on every relevant call — it consistently matters here.',
  },
  {
    iconKey: 'clock' as const,
    title: '90-Day Warranty, OEM Only',
    body: 'Every repair backed by 90 days on parts and labor. Genuine OEM parts only — critical for luxury appliance warranty compliance. $89 diagnostic waived with repair. Written estimate, no surprises. California licensed, BBB A+.',
  },
];

const testimonials = [
  {
    stars: 5,
    text: '"Our Sub-Zero on Huntington Drive had no ice for weeks. Our housekeeper coordinated the call. Same Day came through the service entrance, identified the hard water mineral blockage immediately, replaced the valve, cleaned the coils, left a full report. Professional throughout and the household was completely undisturbed."',
    author: '— M. Chen (via housekeeper), Huntington Drive, San Marino',
  },
  {
    stars: 5,
    text: '"Wolf range with oven and multiple burner issues. Tech came same day to our Virginia Road home, worked carefully in our custom stone hood installation, replaced all the igniters, recalibrated the oven. Our chef tested everything before the technician left. Thorough, professional, and clearly expert on Wolf equipment."',
    author: '— Patricia W., Virginia Road, San Marino',
  },
  {
    stars: 5,
    text: '"Miele dishwasher error, panel-front cabinetry — I was worried about the panels. Technician came out same day, fixed the drain issue, and the panel came out and went back in perfectly. Explained what caused it and the relationship to our water supply. Very knowledgeable. Would call again without hesitation."',
    author: '— David L., Lorain Road, San Marino',
  },
];

const pricingTiers = [
  { appliance: 'Sub-Zero / Wolf / Gaggenau', range: '$300–$800+', note: 'OEM parts · Built-in · SGVMWD hard water check', featured: true },
  { appliance: 'Thermador / Miele / Viking', range: '$250–$600+', note: 'OEM parts · Panel-ready · Steam oven · Heat pump dryer' },
  { appliance: 'Refrigerator (standard)', range: '$150–$450', note: 'Fan motor, SGVMWD hard water inlet valve, filter' },
  { appliance: 'Dishwasher', range: '$150–$400', note: 'Hard water scale · Miele electronics · Panel cabinetry' },
  { appliance: 'Washer / Dryer', range: '$150–$450', note: 'Miele heat pump · Hard water screens · European models' },
  { appliance: 'Diagnostic Fee', range: '$89', note: 'Waived when you proceed with the repair' },
];

const faqs = [
  {
    question: 'Do you offer same-day appliance repair in San Marino, CA?',
    answer: 'Yes. Our technicians cover all of San Marino 91108 — Huntington Drive corridor, Virginia Road, Lorain Road, San Marino Avenue, Rosemead Boulevard, and every residential street in the city. Call before noon for same-day afternoon service.',
  },
  {
    question: 'Do you repair Sub-Zero, Wolf, Thermador, and Miele appliances in San Marino?',
    answer: "Yes. San Marino's estate homes and larger residences consistently have Sub-Zero refrigerators, Wolf ranges, Thermador appliances, Miele dishwashers, and Gaggenau equipment. Our technicians are trained on these brands, carry OEM parts on every service vehicle, and are experienced with the built-in and custom cabinetry configurations common in San Marino kitchens.",
  },
  {
    question: 'Does hard water in San Marino affect appliances?',
    answer: 'Yes. San Marino is served by the San Gabriel Valley Municipal Water District, which delivers mineral-rich groundwater from the San Gabriel Valley basin. Ice maker inlet valves, dishwasher spray arms, and washing machine inlet screens accumulate scale faster than in softer-water cities. We test and check for mineral deposits proactively on every San Marino call involving ice makers and dishwashers.',
  },
  {
    question: 'Can you coordinate with household staff and property managers in San Marino?',
    answer: 'Yes. Many San Marino households have housekeepers, household staff, or property managers who coordinate service calls. We work with them professionally, arrive as scheduled, work cleanly and quietly, and can provide service documentation as needed.',
  },
  {
    question: 'What is your diagnostic fee in San Marino?',
    answer: 'Our diagnostic fee is $89, waived when you proceed with the repair. We give you a complete written estimate before starting any work. Luxury brand repairs may run higher due to OEM part pricing — always disclosed upfront, never a surprise on the invoice.',
  },
  {
    question: 'What warranty do you offer on appliance repairs in San Marino?',
    answer: 'All repairs come with a 90-day warranty on parts and labor. We use genuine OEM parts only. If the same issue returns within 90 days, we come back at no charge.',
  },
  {
    question: 'Do you also serve Pasadena, Arcadia, and South Pasadena?',
    answer: "Yes. Our San Marino service extends to Pasadena, Arcadia, South Pasadena, Alhambra, Temple City, and San Gabriel. We're the closest team for all 91108 calls.",
  },
];

const nearbyCities = [
  { name: 'Pasadena', slug: 'pasadena' },
  { name: 'Arcadia', slug: 'arcadia' },
  { name: 'South Pasadena', slug: 'south-pasadena' },
  { name: 'Glendale', slug: 'glendale' },
  { name: 'Burbank', slug: 'burbank' },
  { name: 'Los Angeles', slug: 'los-angeles' },
  { name: 'Beverly Hills', slug: 'beverly-hills' },
  { name: 'Bel Air', slug: 'bel-air' },
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair"
    headlineCity="San Marino, CA"
    subheadline="San Marino's estate kitchens are among the finest in the San Gabriel Valley — Sub-Zero, Wolf, Thermador, Miele, Gaggenau. Our technicians work here regularly. Same-day service, OEM parts, 90-day warranty. Household staff coordination welcome."
    zips={zips}
    tier={1}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance Repair in San Marino — What This City Requires"
    paragraphs={introParagraphs}
    bookingTitle="San Marino Service Team"
    bookingSub="91108 · Estate-ready · Same day"
  />

  <CustomNarrative
    eyebrow={brandsNarrative.eyebrow}
    headline={brandsNarrative.headline}
    paragraphs={brandsNarrative.paragraphs}
    background="black"
  />

  <ServicesGrid
    cityName={cityName}
    headline="What We Repair in San Marino"
    subhead="Built-ins, luxury brands, estate kitchens · SGVMWD hard water aware · 91108"
    services={services}
  />

  <ServiceArea
    cityName={cityName}
    headline="All of San Marino — 91108"
    subheadline="Every street in the city — from Huntington Drive to the Pasadena border"
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={['Huntington Dr', 'Gainsborough Rd', 'Sherwood Rd', 'Melrose Ave', 'Monterey Rd', 'Michigan Ave']}
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Jobs in San Marino"
    jobs={recentJobs}
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="Why San Marino Chooses Us"
    reasons={whyReasons}
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What San Marino Clients Are Saying"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Appliance Repair Costs in San Marino"
    subhead="Written estimate before we start. $89 diagnostic — waived with repair. OEM parts only."
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="Questions San Marino Clients Ask"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby Areas"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance issue in San Marino?"
    body="Sub-Zero · Wolf · Thermador · Miele · Gaggenau · Estate coordination · SGVMWD hard water specialists. $89 diagnostic waived with repair. 90-day warranty."
  />
</CityLayoutV2>
