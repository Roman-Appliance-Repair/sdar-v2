---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import CustomNarrative from '../components/cities/v2/CustomNarrative.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

const citySlug = 'calabasas';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = 'Calabasas';
const zips = ['91301', '91302'];

const title = `Appliance Repair Calabasas CA | Gated Community & Canyon Specialists | ${branch.phone}`;
const description = "Same-day appliance repair in Calabasas, CA 91301 & 91302. The Oaks, The Estates, Hidden Hills. Sub-Zero, Wolf, Viking, Thermador. Gated community ready. OEM parts, 90-day warranty.";
const canonical = 'https://samedayappliance.repair/calabasas/';

const phoneRaw = `+1${branch.phone.replace(/\D/g, '')}`;

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { '@type': 'City', name: 'Calabasas', sameAs: 'https://en.wikipedia.org/wiki/Calabasas,_California' },
    { '@type': 'Place', name: 'The Oaks of Calabasas' },
    { '@type': 'Place', name: 'The Estates at Calabasas' },
    { '@type': 'Place', name: 'Hidden Hills' },
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$$',
  license: 'CA CSLB #1138898'

};

const introParagraphs = [
  "Calabasas isn't a typical service call. The homes here run larger than most of LA County, and the kitchens are correspondingly complex — Sub-Zero columns, Wolf dual-fuel ranges, Thermador steam ovens, Miele panel-front dishwashers as the standard luxury suite. Many properties are inside gated communities — The Oaks, The Estates, Calabasas Park Estates — where guard gate coordination is part of how the appointment runs.",
  "The canyon environment matters too. Dry air and Santa Monica Mountains particulate, compounded by fire season, mean condenser coils accumulate dust faster than in coastal or urban LA. A coil that goes 12–18 months in Malibu or Santa Monica may need attention every 6 months in canyon-adjacent Calabasas. We see this pattern consistently in 91301 and 91302.",
  "Dryer vents are a separate fire-season concern. A lint-packed vent terminating against a canyon-facing wall is a serious hazard during Santa Ana conditions. We inspect dryer vents on every dryer call in Calabasas and tell you the truth about what we find.",
  `Diagnostic fee is $89, credited toward repair. Written estimate before we start. 90-day warranty, OEM parts only. Call <a href="tel:${phoneRaw}">${branch.phone}</a> for same-day service across all of Calabasas.`,
  "<strong>Canyon climate tip:</strong> In Calabasas and the Las Virgenes corridor, pull your refrigerator out and check the condenser coils every 6 months. Canyon dust loads coils faster than anywhere else in our service area. Clean coils prevent compressor overwork — the most expensive failure on any refrigerator. We include this inspection on every Calabasas fridge call.",
];

const services = [
  { icon: '🧊', name: 'Refrigerator Repair', slug: 'refrigerator', issues: 'Canyon dust coils · Not cooling · Ice maker · Built-in columns · Sub-Zero', brands: 'Sub-Zero · Wolf · True · Samsung · LG · GE Monogram' },
  { icon: '🔥', name: 'Oven, Range & Steam Oven', slug: 'oven', issues: 'Not heating · Igniter · Temperature off · Steam oven · Dual-fuel', brands: 'Wolf · Viking · Thermador · Miele · GE Monogram · Dacor' },
  { icon: '♨️', name: 'Dryer Repair + Vent Inspection', slug: 'dryer', issues: 'Not heating · Vent fire hazard · Canyon dust buildup · Gas & electric', brands: 'LG · Samsung · GE · Miele · Maytag · Whirlpool' },
  { icon: '🫧', name: 'Washer Repair', slug: 'washer', issues: 'Not draining · Not spinning · Miele & European · Laundry room', brands: 'Miele · LG · Samsung · Whirlpool · Bosch · Speed Queen' },
  { icon: '🍽️', name: 'Dishwasher Repair', slug: 'dishwasher', issues: 'Not draining · Panel-ready · Error codes · Miele systems · Leaking', brands: 'Miele · Bosch · Thermador · Viking · KitchenAid · GE' },
  { icon: '🍷', name: 'Wine Cooler & Cellar Cooling', slug: 'wine-cooler', issues: 'Temperature off · Canyon humidity swings · Compressor · Built-in', brands: 'Sub-Zero · True · EuroCave · Liebherr · WhisperKOOL · U-Line' },
  { icon: '🌿', name: 'Outdoor Kitchen Appliances', slug: 'bbq', issues: 'BBQ igniter · Outdoor fridge · Outdoor ice maker · Canyon corrosion', brands: 'Viking · Wolf · True · Lynx · Bull · Blaze' },
  { icon: '🔆', name: 'Cooktop & Range Hood', slug: 'cooktop', issues: 'Igniter clicking · Induction not heating · Hood motor · Filter', brands: 'Wolf · Thermador · Viking · Miele · Bosch · Dacor' },
];

const neighborhoods = [
  { name: 'The Oaks of Calabasas', zip: '91302', featured: true },
  { name: 'The Estates at Calabasas', zip: '91302', featured: true },
  { name: 'Calabasas Park Estates', zip: '91302', featured: true },
  { name: 'Park Sorrento', zip: '91302' },
  { name: 'Old Calabasas', zip: '91302' },
  { name: 'Liberty Canyon', zip: '91301' },
  { name: 'Mulholland corridor', zip: '91302' },
  { name: 'Las Virgenes Rd area', zip: '91302' },
];

const recentJobs = [
  {
    appliance: 'Sub-Zero Built-In',
    location: 'The Oaks, Calabasas 91302',
    quote: 'Running loudly, not holding temperature since fire season',
    description: "Estate in The Oaks — coordinated guard gate access before arrival. Sub-Zero 48-inch column: condenser coils heavily packed with fine canyon particulate that had accumulated over roughly 8 months. Fire season in Calabasas drives significantly more airborne dust than the rest of the year. Cleaned the coil assembly completely, replaced the condenser fan motor that had started to seize from the added load, rechecked door seals. Back to temperature within an hour. Homeowner put on a 6-month coil inspection schedule.",
    outcome: '✓ Same day · Gate coordinated · OEM Sub-Zero fan motor · 6-month plan'
  },
  {
    appliance: 'Wolf Range',
    location: 'Calabasas Park Estates, 91302',
    quote: "Oven won't come up to temperature, star burner sparking",
    description: "Wolf 36-inch dual-fuel — oven igniter drawing weak current, star burner igniter corroded from dry canyon air. Replaced oven igniter and burner electrode with OEM Wolf parts. Calibrated oven temperature (was running 22°F low). Tested all burners. The estate manager had scheduled the call and coordinated the homeowner's housekeeper for access — everything was handled smoothly without the homeowner needing to be present.",
    outcome: '✓ Same day · Estate manager coordinated · Oven calibrated'
  },
  {
    appliance: 'LG Dryer',
    location: 'Old Calabasas, 91302',
    quote: 'Two cycles to dry anything, vent looked clogged',
    description: "Older property off Calabasas Rd — dryer vent ran a long path through the garage and terminated on the east wall facing the canyon. Significant lint plus fine canyon dust in the duct. Cleared the full run, replaced the thermal fuse, confirmed exterior vent cap was functioning. Single-cycle drying from the first test. The homeowner mentioned fire season concern about the vent — we confirmed the run was clean and the termination cap had a proper fire screen.",
    outcome: '✓ Same day · Vent cleared · Fire screen confirmed'
  },
  {
    appliance: 'Outdoor Refrigerator',
    location: 'The Estates, Calabasas 91301',
    quote: 'Outdoor fridge by the pool not cooling',
    description: "True outdoor-rated undercounter refrigerator on a covered patio. Canyon conditions had accelerated coil corrosion on the exterior-exposed unit — more aggressive than we'd see on an indoor unit. Cleaned and treated the coils, replaced the condenser fan, rechecked the door gasket seal (showing UV degradation from sun exposure). Recommended annual coil maintenance for outdoor units in canyon-facing locations. Operating at 38°F by end of visit.",
    outcome: '✓ Same day · Outdoor True refrigerator · Annual plan advised'
  },
];

const whyReasons = [
  {
    iconKey: 'team' as const,
    title: 'Gated Community Ready',
    body: 'The Oaks, The Estates, Calabasas Park Estates, Hidden Hills — gate coordination is part of every appointment we run in Calabasas. We arrange access in advance with property managers, estate managers, gate guards, or housekeepers so the appointment runs smoothly.'
  },
  {
    iconKey: 'shield' as const,
    title: 'Canyon Climate Specialists',
    body: 'Dry canyon air, Santa Monica Mountains particulate, fire-season ash — all of this loads condenser coils, dryer vents, and outdoor appliances faster than coastal or urban LA. We inspect for these specific patterns on every Calabasas call.'
  },
  {
    iconKey: 'parts' as const,
    title: 'Luxury Brand Expertise',
    body: 'Sub-Zero columns, Wolf dual-fuel ranges, Thermador steam ovens, Miele panel-integrated dishwashers, Viking outdoor kitchens — we carry OEM parts for every luxury brand on every Calabasas vehicle.'
  },
  {
    iconKey: 'clock' as const,
    title: '90-Day Warranty, OEM Only',
    body: 'Every repair we do in Calabasas carries a 90-day warranty on parts and labor. We use OEM parts on every job. Same issue returns within 90 days — we come back at no charge.'
  },
];

const testimonials = [
  {
    stars: 5,
    text: '"Our Sub-Zero in The Oaks was running constantly and we couldn\'t figure out why. Same Day coordinated with our gate, came out that afternoon, found the canyon dust buildup on the coils — showed me photos. Replaced the fan motor, cleaned everything, explained the 6-month schedule for this area. Exactly the knowledgeable service we needed."',
    author: '— Jennifer M., The Oaks of Calabasas'
  },
  {
    stars: 5,
    text: '"Wolf range igniter and oven issues. Our estate manager arranged the call. Technician came same day, had all OEM Wolf parts, recalibrated the oven — turns out it had been 22 degrees low for months. The whole interaction was professional and easy. Our manager said it was the smoothest service call they\'d coordinated."',
    author: '— The Taylor Estate, Calabasas Park Estates'
  },
  {
    stars: 5,
    text: '"Dryer had been taking forever and I was worried about fire season with the canyon-facing vent. They came out, cleared the full duct run, confirmed the fire screen was intact, replaced the thermal fuse. The peace of mind on the vent situation alone was worth it. Very thorough, very professional."',
    author: '— David K., Old Calabasas'
  },
];

const pricingTiers = [
  { appliance: 'Sub-Zero / Wolf / Thermador', range: '$300–$700+', note: 'OEM parts · Built-in column · Pro range · Gate coordination', featured: true },
  { appliance: 'Refrigerator (Standard)', range: '$200–$450', note: 'Canyon coil cleaning · Ice maker · Fan motor' },
  { appliance: 'Dryer + Vent Inspection', range: '$150–$320', note: 'Vent cleaning · Thermal fuse · Fire screen check' },
  { appliance: 'Oven / Range', range: '$200–$500+', note: 'Igniter · Element · Temperature calibration · Steam oven' },
  { appliance: 'Dishwasher / Washer', range: '$150–$400', note: 'Panel-ready · Drain · Error codes' },
  { appliance: 'Diagnostic Fee', range: '$89', note: 'Credited toward repair · Written estimate' },
];

const faqs = [
  {
    question: 'Do you offer same-day appliance repair in Calabasas?',
    answer: "Yes — Calabasas is on our regular Westside route. We cover both 91301 and 91302 daily, including The Oaks, The Estates, Calabasas Park Estates, Old Calabasas, and the Las Virgenes corridor. Call before noon for same-day service."
  },
  {
    question: 'Do you service gated communities like The Oaks, The Estates, and Hidden Hills?',
    answer: "Yes. The Oaks of Calabasas, The Estates at Calabasas, Calabasas Park Estates, and Hidden Hills all have gate coordination requirements. Tell us when you call who manages access — property manager, estate manager, gate guard, or housekeeper — and we coordinate in advance so the appointment runs smoothly."
  },
  {
    question: "How does Calabasas's canyon climate affect appliances?",
    answer: "The combination of dry canyon air and Santa Monica Mountains particulate — compounded during fire season — loads refrigerator condenser coils faster than coastal or urban LA. A coil that goes 12–18 months elsewhere may need attention every 6 months in canyon-adjacent Calabasas. Outdoor appliances also see accelerated coil corrosion. We inspect for these patterns on every relevant call."
  },
  {
    question: 'Do you repair Sub-Zero, Wolf, Thermador, and Viking in Calabasas?',
    answer: "Yes. Sub-Zero columns, Wolf dual-fuel ranges, Thermador steam ovens, Miele panel-integrated dishwashers, and Viking outdoor kitchens are common in Calabasas estates. We carry OEM parts for all of these brands on every Calabasas vehicle."
  },
  {
    question: 'Do you repair outdoor BBQ and outdoor kitchen appliances in Calabasas?',
    answer: "Yes. Outdoor BBQ igniter failures, outdoor refrigerator cooling issues, outdoor ice maker problems — all common in Calabasas given the canyon corrosion environment. We service Viking, Wolf, True, Lynx, Bull, and Blaze outdoor kitchen brands."
  },
  {
    question: 'What is your diagnostic fee in Calabasas?',
    answer: "Our diagnostic fee is $89. It covers the trip, full appliance inspection, and a written estimate. If you proceed with the repair, the $89 is credited toward your invoice."
  },
  {
    question: 'Do you also serve Hidden Hills, Agoura Hills, and Thousand Oaks from Calabasas?',
    answer: "Yes — our Calabasas-area routes also cover Hidden Hills, Agoura Hills, Westlake Village, Thousand Oaks, West Hills, and Malibu. Same-day service is typically available across this corridor."
  },
];

const nearbyCities = [
  { name: 'Malibu', slug: 'malibu' },
  { name: 'Los Angeles', slug: 'los-angeles' },
  { name: 'Santa Monica', slug: 'santa-monica' },
  { name: 'Brentwood', slug: 'brentwood' },
  { name: 'Pacific Palisades', slug: 'pacific-palisades' },
  { name: 'Beverly Hills', slug: 'beverly-hills' },
  { name: 'West Hollywood', slug: 'west-hollywood' },
  { name: 'Burbank', slug: 'burbank' },
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair"
    headlineCity="Calabasas, CA"
    subheadline="Gated communities, canyon estates, luxury kitchens — and the unique appliance challenges that come with living in the Santa Monica Mountains corridor. Sub-Zero, Wolf, Viking, Thermador. Same-day service, OEM parts, 90-day warranty."
    zips={zips}
    tier={1}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance Repair in Calabasas — What's Different Here"
    paragraphs={introParagraphs}
    bookingTitle="Calabasas Service Team"
    bookingSub="91301 · 91302 · Gated ready · Same day"
  />

  <ServicesGrid
    cityName={cityName}
    headline="What We Repair in Calabasas"
    services={services}
  />

  <ServiceArea
    cityName={cityName}
    headline="Calabasas Communities We Service"
    subheadline="From The Oaks to Old Calabasas — every part of 91301 and 91302."
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={['Las Virgenes Rd', 'Mulholland Hwy', 'Calabasas Rd', 'Ventura Blvd (Calabasas)', 'Lost Hills Rd', 'Agoura Rd']}
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Repairs in Calabasas"
    jobs={recentJobs}
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="Why Calabasas Homeowners Call Us"
    reasons={whyReasons}
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What Calabasas Clients Say"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Repair Pricing in Calabasas"
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="Frequently Asked Questions — Calabasas"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby Cities"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance broken in Calabasas?"
    body="Gated communities · Canyon climate specialists · Luxury brands · All of 91301 & 91302. $89 diagnostic waived with repair. 90-day warranty. OEM parts."
  />
</CityLayoutV2>
