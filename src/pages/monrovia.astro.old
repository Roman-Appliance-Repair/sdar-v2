</Layout>

<style>
  :root { --mon-red: #C8102E; --mon-black: #0a0a0a; --mon-gray: #f5f5f5; --mon-border: #e2e2e2; --mon-text: #1a1a1a; --mon-muted: #6b6b6b; }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  .mon-hero { background: var(--mon-black); color: white; padding: 80px 0 60px; }
  .mon-hero__inner { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
  .mon-hero__eyebrow { font-size: 13px; font-weight: 500; color: var(--mon-red); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 16px; }
  .mon-hero__h1 { font-size: clamp(36px, 5vw, 52px); font-weight: 700; line-height: 1.1; margin-bottom: 20px; color: white; }
  .mon-hero__accent { color: var(--mon-red); }
  .mon-hero__sub { font-size: 17px; line-height: 1.6; color: rgba(255,255,255,0.75); margin-bottom: 32px; max-width: 520px; }
  .mon-hero__ctas { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 24px; }
  .mon-hero__rating { display: flex; align-items: center; gap: 10px; }
  .stars { color: #FFD700; font-size: 18px; letter-spacing: 2px; }
  .rating-text { font-size: 14px; color: rgba(255,255,255,0.7); }
  .mon-hero__img-wrap img { width: 100%; height: auto; border-radius: 12px; object-fit: cover; }
  .btn-primary { display: inline-flex; align-items: center; gap: 8px; background: var(--mon-red); color: white; padding: 14px 28px; border-radius: 8px; font-weight: 600; font-size: 16px; text-decoration: none; transition: background 0.2s; }
  .btn-primary:hover { background: #a50e25; }
  .btn-secondary { display: inline-flex; align-items: center; gap: 8px; background: transparent; color: white; padding: 14px 28px; border-radius: 8px; font-weight: 600; font-size: 16px; text-decoration: none; border: 1.5px solid rgba(255,255,255,0.35); }
  .btn-large { padding: 16px 36px; font-size: 17px; }
  .mon-bottom-cta .btn-secondary { color: var(--mon-text); border-color: var(--mon-border); }
  .trust-bar { background: var(--mon-red); padding: 16px 0; }
  .trust-bar__inner { display: flex; justify-content: space-between; flex-wrap: wrap; gap: 12px; }
  .trust-item { display: flex; align-items: center; gap: 8px; color: white; font-size: 14px; font-weight: 500; }
  .mon-intro { padding: 72px 0; background: white; }
  .mon-intro__inner { display: grid; grid-template-columns: 1fr 340px; gap: 60px; align-items: start; }
  .mon-intro__text h2 { font-size: 28px; font-weight: 700; color: var(--mon-black); margin-bottom: 20px; }
  .mon-intro__text p { font-size: 16px; line-height: 1.7; color: var(--mon-text); margin-bottom: 16px; }
  .mon-tip { display: flex; gap: 14px; background: #eef6ff; border: 1px solid #b8d4f0; border-radius: 10px; padding: 16px 20px; margin-top: 24px; }
  .mon-tip__icon { font-size: 20px; flex-shrink: 0; }
  .mon-tip__text { font-size: 14px; color: var(--mon-text); line-height: 1.6; }
  .cta-box { background: var(--mon-black); color: white; border-radius: 12px; padding: 32px; text-align: center; position: sticky; top: 80px; }
  .cta-box__title { font-size: 18px; font-weight: 700; margin-bottom: 4px; }
  .cta-box__sub { font-size: 13px; color: rgba(255,255,255,0.6); margin-bottom: 24px; }
  .cta-box__phone { display: block; font-size: 24px; font-weight: 700; color: var(--mon-red); text-decoration: none; margin-bottom: 12px; }
  .cta-box__book { display: block; font-size: 15px; color: white; text-decoration: none; padding: 12px; border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; margin-bottom: 16px; }
  .cta-box__hours { font-size: 12px; color: rgba(255,255,255,0.5); }
  .section-title { font-size: 30px; font-weight: 700; color: var(--mon-black); margin-bottom: 8px; text-align: center; }
  .section-sub { font-size: 16px; color: var(--mon-muted); text-align: center; margin-bottom: 40px; }
  .mon-services { padding: 72px 0; background: var(--mon-gray); }
  .services-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
  .service-card { background: white; border: 1px solid var(--mon-border); border-radius: 12px; padding: 24px 20px; text-decoration: none; color: var(--mon-text); transition: box-shadow 0.2s, transform 0.2s; display: block; }
  .service-card:hover { box-shadow: 0 4px 24px rgba(0,0,0,0.1); transform: translateY(-2px); }
  .service-card--highlight { border-color: var(--mon-red); background: #fff5f7; }
  .service-card__icon { font-size: 28px; margin-bottom: 10px; }
  .service-card__name { font-size: 16px; font-weight: 600; color: var(--mon-black); margin-bottom: 8px; }
  .service-card__issues { font-size: 13px; color: var(--mon-muted); line-height: 1.5; margin-bottom: 8px; }
  .service-card__brands { font-size: 12px; color: var(--mon-muted); margin-bottom: 12px; }
  .service-card__cta { font-size: 13px; color: var(--mon-red); font-weight: 500; }
  .mon-neighborhoods { padding: 72px 0; background: white; }
  .mon-neighborhoods h2 { font-size: 30px; font-weight: 700; color: var(--mon-black); margin-bottom: 8px; text-align: center; }
  .nh-columns { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; }
  .nh-col__title { font-size: 13px; font-weight: 600; color: var(--mon-muted); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 16px; }
  .nh-list { display: flex; flex-direction: column; gap: 8px; }
  .nh-item { font-size: 14px; color: var(--mon-text); padding: 8px 12px; background: var(--mon-gray); border-radius: 6px; }
  .nh-item.featured { background: #fff5f7; border: 1px solid var(--mon-red); color: var(--mon-black); font-weight: 500; }
  .mon-recent { padding: 72px 0; background: var(--mon-gray); }
  .mon-recent h2 { font-size: 30px; font-weight: 700; color: var(--mon-black); margin-bottom: 8px; text-align: center; }
  .recent-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .recent-card { background: white; border: 1px solid var(--mon-border); border-radius: 12px; padding: 24px; }
  .recent-card__header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; flex-wrap: wrap; gap: 6px; }
  .recent-badge { background: var(--mon-red); color: white; font-size: 11px; font-weight: 600; padding: 3px 10px; border-radius: 20px; }
  .recent-location { font-size: 12px; color: var(--mon-muted); }
  .recent-card__title { font-size: 15px; font-weight: 600; color: var(--mon-black); margin-bottom: 10px; font-style: italic; }
  .recent-card__desc { font-size: 14px; color: var(--mon-text); line-height: 1.6; margin-bottom: 12px; }
  .recent-card__result { font-size: 13px; color: #2a7a2a; font-weight: 500; }
  .mon-why { padding: 72px 0; background: white; }
  .mon-why h2 { font-size: 30px; font-weight: 700; color: var(--mon-black); margin-bottom: 40px; text-align: center; }
  .why-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
  .why-card { background: var(--mon-gray); border-radius: 12px; padding: 28px 24px; }
  .why-icon { font-size: 28px; margin-bottom: 14px; }
  .why-title { font-size: 16px; font-weight: 600; color: var(--mon-black); margin-bottom: 10px; }
  .why-text { font-size: 14px; color: var(--mon-muted); line-height: 1.6; }
  .mon-reviews { padding: 72px 0; background: var(--mon-gray); }
  .mon-reviews h2 { font-size: 30px; font-weight: 700; color: var(--mon-black); margin-bottom: 40px; text-align: center; }
  .reviews-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .review-card { background: white; border: 1px solid var(--mon-border); border-radius: 12px; padding: 28px; }
  .review-stars { color: #FFD700; font-size: 18px; margin-bottom: 12px; }
  .review-text { font-size: 14px; color: var(--mon-text); line-height: 1.7; margin-bottom: 16px; font-style: italic; }
  .review-author { font-size: 13px; color: var(--mon-muted); font-weight: 500; }
  .mon-pricing { padding: 72px 0; background: white; }
  .pricing-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 20px; }
  .pricing-card { background: var(--mon-gray); border-radius: 10px; padding: 20px 24px; border: 1px solid var(--mon-border); }
  .pricing-card.featured { background: #fff5f7; border-color: var(--mon-red); }
  .pricing-card__appliance { font-size: 14px; color: var(--mon-muted); margin-bottom: 6px; }
  .pricing-card__range { font-size: 22px; font-weight: 700; color: var(--mon-black); margin-bottom: 6px; }
  .pricing-card.featured .pricing-card__range { color: var(--mon-red); }
  .pricing-card__note { font-size: 13px; color: var(--mon-muted); }
  .mon-faq { padding: 72px 0; background: var(--mon-gray); }
  .mon-faq h2 { font-size: 30px; font-weight: 700; color: var(--mon-black); margin-bottom: 40px; text-align: center; }
  .faq-list { max-width: 800px; margin: 0 auto; }
  .faq-item { border: 1px solid var(--mon-border); border-radius: 8px; background: white; margin-bottom: 10px; overflow: hidden; }
  .faq-question { padding: 18px 24px; font-size: 16px; font-weight: 600; color: var(--mon-black); cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; }
  .faq-question::after { content: '+'; font-size: 22px; color: var(--mon-red); flex-shrink: 0; margin-left: 16px; }
  details[open] .faq-question::after { content: '−'; }
  .faq-answer { padding: 0 24px 20px; font-size: 15px; line-height: 1.7; color: var(--mon-text); }
  .mon-nearby { padding: 48px 0; background: white; border-top: 1px solid var(--mon-border); }
  .mon-nearby h2 { font-size: 20px; font-weight: 600; color: var(--mon-black); margin-bottom: 20px; text-align: center; }
  .nearby-grid { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; }
  .nearby-link { padding: 8px 20px; border: 1px solid var(--mon-border); border-radius: 20px; font-size: 14px; color: var(--mon-text); text-decoration: none; transition: border-color 0.2s, color 0.2s; }
  .nearby-link:hover { border-color: var(--mon-red); color: var(--mon-red); }
  .mon-bottom-cta { padding: 72px 0; background: var(--mon-black); color: white; }
  .bottom-cta__inner { text-align: center; }
  .bottom-cta__text h2 { font-size: 34px; font-weight: 700; color: white; margin-bottom: 12px; }
  .bottom-cta__text p { font-size: 16px; color: rgba(255,255,255,0.7); margin-bottom: 32px; }
  .bottom-cta__actions { display: flex; gap: 12px; justify-content: center; margin-bottom: 24px; flex-wrap: wrap; }
  .bottom-cta__nap { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; font-size: 13px; color: rgba(255,255,255,0.4); }
  .bottom-cta__nap a { color: rgba(255,255,255,0.4); text-decoration: none; }
  @media (max-width: 1024px) { .services-grid { grid-template-columns: repeat(2, 1fr); } .why-grid { grid-template-columns: repeat(2, 1fr); } .reviews-grid { grid-template-columns: 1fr 1fr; } .mon-intro__inner { grid-template-columns: 1fr; } .nh-columns { grid-template-columns: 1fr 1fr; } .pricing-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 768px) { .mon-hero__inner { grid-template-columns: 1fr; } .mon-hero__img-wrap { display: none; } .recent-grid { grid-template-columns: 1fr; } .reviews-grid { grid-template-columns: 1fr; } .why-grid { grid-template-columns: 1fr 1fr; } .nh-columns { grid-template-columns: 1fr; } .trust-bar__inner { justify-content: center; } }
  @media (max-width: 480px) { .services-grid { grid-template-columns: 1fr; } .why-grid { grid-template-columns: 1fr; } .pricing-grid { grid-template-columns: 1fr; } .mon-hero { padding: 48px 0 40px; } .bottom-cta__text h2 { font-size: 26px; } }
</style>
