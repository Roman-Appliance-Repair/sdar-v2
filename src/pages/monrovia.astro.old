---
// src/pages/monrovia.astro
// SDAR — samedayappliance.repair
// Monrovia, CA 91016
// Филиал: Pasadena · (626) 376-4458
// GSC: нет данных — новый город
// Конкуренты: Polar Appliance Repair (Sub-Zero certified, реальный, без местной специфики),
//             A&B Appliance Repair (local address, closed weekends),
//             спам-сайты (monroviaapplianceservice, whirlpoolappliancerepairmonrovia)
// Уникальный угол: Old Town Monrovia historic district + Craftsman/Victorian bungalows +
//                  foothill homes north + SGVMWD hard water + A&B closed weekends
// Апрель 2026

import Layout from '../layouts/Layout.astro';

const city = {
  name: "Monrovia",
  state: "CA",
  county: "Los Angeles",
  zips: ["91016"],
  phone: "(626) 376-4458",
  phoneRaw: "+16263764458",
  email: "pasadena@samedayappliance.repair",
  branch: "Pasadena",
  slug: "monrovia",
};

const title = `Appliance Repair Monrovia CA 91016 — Same Day | Old Town · Foothill · Sub-Zero | (626) 376-4458`;
const description = `Same-day appliance repair in Monrovia, CA 91016. Old Town historic district, Craftsman bungalows, foothill homes. Sub-Zero, Wolf, Samsung, LG, all brands. Licensed, OEM parts, 90-day warranty. Weekends available. Call (626) 376-4458.`;
const canonical = `https://samedayappliance.repair/monrovia/`;

const schemaLocalBusiness = {
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  "name": "Same Day Appliance Repair — Monrovia",
  "image": "https://samedayappliance.repair/images/logo.webp",
  "url": canonical,
  "telephone": city.phoneRaw,
  "email": city.email,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "55 S Lake Ave",
    "addressLocality": "Pasadena",
    "addressRegion": "CA",
    "postalCode": "91101",
    "addressCountry": "US"
  },
  "areaServed": [
    { "@type": "City", "name": "Monrovia", "sameAs": "https://en.wikipedia.org/wiki/Monrovia,_California" }
  ],
  "openingHoursSpecification": [
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "07:00", "closes": "21:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Saturday"], "opens": "08:00", "closes": "19:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Sunday"], "opens": "09:00", "closes": "17:00" }
  ],
  "priceRange": "$$",
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.6",
    "reviewCount": "37",
    "bestRating": "5"
  }
};

const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Do you offer same-day appliance repair in Monrovia, CA?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our technicians cover all of Monrovia 91016 — Old Town and the Myrtle Avenue corridor, the foothill neighborhoods north of Foothill Boulevard, Mayflower Village, and every street in the city. Call before noon for same-day afternoon service. We're also available Saturdays and Sundays." }
    },
    {
      "@type": "Question",
      "name": "Does hard water in Monrovia affect appliances?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Monrovia is served by the San Gabriel Valley Municipal Water District, which delivers mineral-rich groundwater from the SGV basin. Ice maker inlet valves, dishwasher spray arms, and washing machine inlet screens accumulate scale faster than in softer-water cities. We check for this proactively on every Monrovia call involving ice makers and dishwashers." }
    },
    {
      "@type": "Question",
      "name": "Do you repair appliances in Monrovia's older historic homes?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Old Town Monrovia has a significant stock of Victorian and Craftsman homes from the 1890s–1930s, many of which have been updated and maintained. These older homes sometimes have complex dryer vent installations, aging water supply lines that compound hard water effects, or non-standard appliance configurations. We're familiar with these situations and come prepared." }
    },
    {
      "@type": "Question",
      "name": "Do you repair Sub-Zero, Wolf, and luxury appliances in Monrovia?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. The foothill neighborhoods north of Foothill Boulevard and larger Monrovia homes frequently have Sub-Zero refrigerators, Wolf ranges, and Viking appliances. Our technicians carry OEM parts for these brands on every service vehicle." }
    },
    {
      "@type": "Question",
      "name": "Are you available on weekends in Monrovia?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Saturday 8am–7pm and Sunday 9am–5pm. Some Monrovia appliance companies close on weekends — we don't." }
    },
    {
      "@type": "Question",
      "name": "What is your diagnostic fee in Monrovia?",
      "acceptedAnswer": { "@type": "Answer", "text": "Our diagnostic fee is $89, waived when you proceed with the repair. Written estimate before we start. Most Monrovia repairs run $150–$400 depending on the appliance." }
    },
    {
      "@type": "Question",
      "name": "Do you also serve Arcadia, Duarte, and Temple City?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our Monrovia service area extends to Arcadia, Duarte, Temple City, Bradbury, Azusa, Glendora, and South Pasadena. All within our regular SGV service route from the Pasadena branch." }
    }
  ]
};
---

<Layout title={title} description={description} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(schemaLocalBusiness)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} />

  <!-- HERO -->
  <section class="mon-hero">
    <div class="mon-hero__inner container">
      <div class="mon-hero__content">
        <div class="mon-hero__eyebrow">Monrovia, CA · 91016 · Old Town · Myrtle Ave · Mayflower Village · Foothill Neighborhoods</div>
        <h1 class="mon-hero__h1">
          Appliance Repair<br>
          <span class="mon-hero__accent">Monrovia, CA</span>
        </h1>
        <p class="mon-hero__sub">
          From Craftsman bungalows in Old Town to foothill homes above Foothill Boulevard —
          all of Monrovia 91016. Sub-Zero, Wolf, Samsung, LG, all brands. Same-day service,
          OEM parts, 90-day warranty. Weekends available.
        </p>
        <div class="mon-hero__ctas">
          <a href={`tel:${city.phoneRaw}`} class="btn-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.29h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call {city.phone}
          </a>
          <a href="/book/" class="btn-secondary">Book Online</a>
        </div>
        <div class="mon-hero__rating">
          <span class="stars">★★★★★</span>
          <span class="rating-text">4.6 · Google reviews · BBB A+ · Licensed & Insured</span>
        </div>
      </div>
      <div class="mon-hero__img-wrap">
        <img
          src="/images/areas/appliance-repair-monrovia-ca.webp"
          alt="Appliance repair in Monrovia CA"
          width="560"
          height="460"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <section class="trust-bar">
    <div class="container trust-bar__inner">
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg><span>Same-Day Service</span></div>
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg><span>90-Day Warranty</span></div>
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg><span>OEM Parts</span></div>
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg><span>Licensed & Insured</span></div>
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg><span>Weekends Available</span></div>
    </div>
  </section>

  <!-- INTRO -->
  <section class="mon-intro">
    <div class="container mon-intro__inner">
      <div class="mon-intro__text">
        <h2>Appliance Repair in Monrovia — What We Know About This City</h2>
        <p>
          Monrovia divides naturally along Foothill Boulevard. South of Foothill is
          Old Town and the historic residential streets — Victorian homes and Craftsman
          bungalows from the 1890s through the 1930s along Myrtle Avenue, Mayflower
          Village, and the surrounding blocks. These homes have been lovingly maintained
          for decades, and many have been updated with modern appliances sitting alongside
          original architectural detail that requires care during service.
        </p>
        <p>
          North of Foothill, the homes get larger and newer — more recent construction
          with updated kitchens, some with Sub-Zero refrigerators, Wolf ranges, and
          Viking appliances. It's a different service call from the older south-side
          bungalows, and our technicians handle both without pretending one approach
          fits everything.
        </p>
        <p>
          Hard water is a consistent factor in Monrovia. Served by the San Gabriel Valley
          Municipal Water District — the same mineral-rich SGV groundwater that runs
          through Arcadia and San Marino — ice maker inlet valves and dishwasher spray
          arms scale up faster here than the national average. We test for this on
          every relevant Monrovia call. It comes up regularly.
        </p>
        <p>
          Diagnostic fee: <strong>$89</strong> — waived with repair. Written estimate
          before we start. <strong>90-day warranty</strong> on all parts and labor.
          Available <strong>Saturdays and Sundays</strong>.
        </p>
        <div class="mon-tip">
          <div class="mon-tip__icon">💧</div>
          <div class="mon-tip__text">
            <strong>Hard water tip for Monrovia:</strong> SGVMWD delivers mineral-rich
            groundwater throughout the SGV. If your refrigerator ice maker has been
            producing less and less ice over several months, or your dishwasher is
            leaving spots despite a clean filter — mineral scale on the inlet valve
            is the most common cause in this water district. A 6-month refrigerator
            filter replacement cycle (not 12 months) helps significantly.
          </div>
        </div>
      </div>
      <div class="mon-intro__cta-box">
        <div class="cta-box">
          <div class="cta-box__title">Monrovia Service Team</div>
          <div class="cta-box__sub">91016 · Old Town & foothill · Weekends ok</div>
          <a href={`tel:${city.phoneRaw}`} class="cta-box__phone">{city.phone}</a>
          <a href="/book/" class="cta-box__book">Schedule Online →</a>
          <div class="cta-box__hours">Mon–Fri 7am–9pm · Sat 8am–7pm · Sun 9am–5pm</div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="mon-services">
    <div class="container">
      <h2 class="section-title">What We Repair in Monrovia</h2>
      <p class="section-sub">All brands · SGVMWD hard water aware · Old Town & foothill · 91016</p>
      <div class="services-grid">

        <a href="/monrovia/refrigerator-repair/" class="service-card service-card--highlight">
          <div class="service-card__icon">🧊</div>
          <div class="service-card__name">Refrigerator Repair</div>
          <div class="service-card__issues">Hard water ice maker · Not cooling · Fan motor · Sub-Zero built-in</div>
          <div class="service-card__brands">Sub-Zero · Samsung · LG · GE · Whirlpool · Wolf</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/monrovia/dishwasher-repair/" class="service-card service-card--highlight">
          <div class="service-card__icon">🍽️</div>
          <div class="service-card__name">Dishwasher Repair</div>
          <div class="service-card__issues">Hard water spray arm scale · Not draining · Spots · Error codes</div>
          <div class="service-card__brands">Bosch · KitchenAid · Samsung · LG · Miele · GE</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/monrovia/washer-repair/" class="service-card">
          <div class="service-card__icon">🫧</div>
          <div class="service-card__name">Washer Repair</div>
          <div class="service-card__issues">Hard water inlet screens · Not draining · Not spinning · Error codes</div>
          <div class="service-card__brands">LG · Samsung · Whirlpool · Maytag · Bosch · Speed Queen</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/monrovia/dryer-repair/" class="service-card">
          <div class="service-card__icon">♨️</div>
          <div class="service-card__name">Dryer Repair + Vent Cleaning</div>
          <div class="service-card__issues">Not heating · Older vent runs · Thermal fuse · Lint buildup</div>
          <div class="service-card__brands">LG · Samsung · GE · Maytag · Whirlpool · Electrolux</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/monrovia/oven-repair/" class="service-card">
          <div class="service-card__icon">🔥</div>
          <div class="service-card__name">Oven, Range & Stove</div>
          <div class="service-card__issues">Not heating · Gas igniter · Temperature off · Wolf & Viking</div>
          <div class="service-card__brands">Wolf · Viking · Thermador · GE · Samsung · Bosch</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/monrovia/freezer-repair/" class="service-card">
          <div class="service-card__icon">❄️</div>
          <div class="service-card__name">Freezer & Ice Maker Repair</div>
          <div class="service-card__issues">Hard water inlet valve · Not freezing · Ice stopped · Frost</div>
          <div class="service-card__brands">Sub-Zero · Samsung · LG · GE · Whirlpool · Frigidaire</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/monrovia/wine-cooler-repair/" class="service-card">
          <div class="service-card__icon">🍷</div>
          <div class="service-card__name">Wine Cooler Repair</div>
          <div class="service-card__issues">Temperature off · Compressor · Under-counter · Built-in</div>
          <div class="service-card__brands">Sub-Zero · True · U-Line · Liebherr · Dacor</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/monrovia/cooktop-repair/" class="service-card">
          <div class="service-card__icon">🔆</div>
          <div class="service-card__name">Cooktop & Range Hood</div>
          <div class="service-card__issues">Igniter · Gas burner · Induction not heating · Hood motor</div>
          <div class="service-card__brands">Wolf · Viking · GE · Bosch · Samsung · Broan</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

      </div>
    </div>
  </section>

  <!-- NEIGHBORHOODS -->
  <section class="mon-neighborhoods">
    <div class="container">
      <h2>All of Monrovia — 91016</h2>
      <p class="section-sub">Old Town to foothill — every neighborhood in the city</p>
      <div class="nh-columns">
        <div class="nh-col">
          <div class="nh-col__title">Monrovia Neighborhoods</div>
          <div class="nh-list">
            <div class="nh-item featured">Old Town Monrovia</div>
            <div class="nh-item featured">Myrtle Ave historic corridor</div>
            <div class="nh-item featured">Foothill neighborhoods (north)</div>
            <div class="nh-item">Mayflower Village</div>
            <div class="nh-item">Bradbury adjacent</div>
            <div class="nh-item">South Monrovia</div>
          </div>
        </div>
        <div class="nh-col">
          <div class="nh-col__title">Key Streets</div>
          <div class="nh-list">
            <div class="nh-item">Myrtle Ave</div>
            <div class="nh-item">Foothill Blvd</div>
            <div class="nh-item">Huntington Drive</div>
            <div class="nh-item">Duarte Road</div>
            <div class="nh-item">Primrose Ave</div>
            <div class="nh-item">Colorado Blvd</div>
          </div>
        </div>
        <div class="nh-col">
          <div class="nh-col__title">Nearby We Serve</div>
          <div class="nh-list">
            <div class="nh-item">Arcadia (91006–07)</div>
            <div class="nh-item">Duarte (91010)</div>
            <div class="nh-item">Bradbury (91008)</div>
            <div class="nh-item">Azusa (91702)</div>
            <div class="nh-item">Glendora (91740)</div>
            <div class="nh-item">Temple City (91780)</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- RECENT REPAIRS -->
  <section class="mon-recent">
    <div class="container">
      <h2>Recent Jobs in Monrovia</h2>
      <p class="section-sub">Real calls from 91016 — historic bungalows, foothill homes, SGVMWD hard water.</p>
      <div class="recent-grid">

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">LG Refrigerator</span>
            <span class="recent-location">Myrtle Ave, Old Town, 91016</span>
          </div>
          <div class="recent-card__title">"Ice maker completely stopped over a few months"</div>
          <div class="recent-card__desc">
            1920s Craftsman bungalow on Myrtle — the kitchen had been updated but the
            galvanized supply lines were original, adding iron on top of the SGVMWD
            mineral content. LG French door ice maker: inlet valve completely blocked
            with calcium-iron scale deposits. Replaced with an OEM LG inlet valve,
            flushed the water line, installed a new in-door filter (original, never
            changed). Full ice production within 24 hours. Explained the combined
            effect of SGVMWD water and older pipes — owner set a 6-month filter
            reminder.
          </div>
          <div class="recent-card__result">✓ Same day · OEM LG inlet valve · Older pipe factor explained</div>
        </div>

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">Samsung Dishwasher</span>
            <span class="recent-location">Foothill neighborhood, north Monrovia</span>
          </div>
          <div class="recent-card__title">"Everything comes out with white film — spots on everything"</div>
          <div class="recent-card__desc">
            Newer construction home north of Foothill — Samsung DW80 series with
            both spray arm ports clogged from SGVMWD mineral scale. Less than 18
            months old. Descaled both arms completely, deep-cleaned the filter trap,
            ran a full citric acid maintenance cycle. Tested three loads before leaving
            — clear glasses, no spots. Advised the monthly dishwasher tablet routine
            given the SGV water supply. Owner hadn't realized how quickly scale builds
            in this water district.
          </div>
          <div class="recent-card__result">✓ Same day · Scale cleared · Three loads confirmed · Routine advised</div>
        </div>

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">Maytag Dryer</span>
            <span class="recent-location">Mayflower Village, 91016</span>
          </div>
          <div class="recent-card__title">"No heat at all, clothes still wet after full cycle"</div>
          <div class="recent-card__desc">
            Maytag electric dryer — thermal fuse blown from a partially blocked vent
            run. The vent exited through the side of the original 1940s garage
            conversion, with a 45-degree offset that had accumulated lint over years.
            Replaced the thermal fuse, cleared the vent run completely, confirmed
            strong airflow at the exterior termination. Called on a Saturday morning
            — had it done by noon. The family had laundry piling up from the week.
          </div>
          <div class="recent-card__result">✓ Saturday same day · Vent cleared · Done by noon</div>
        </div>

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">Wolf Range</span>
            <span class="recent-location">Bradbury-adjacent, north Monrovia</span>
          </div>
          <div class="recent-card__title">"Oven running at wrong temperature, two burners clicking"</div>
          <div class="recent-card__desc">
            Wolf 36-inch dual-fuel in a foothill-area home near the Bradbury border —
            oven igniter weak current (the Wolf-specific failure where the igniter
            glows without drawing enough amperage to open the gas valve), two
            surface electrodes corroded. Replaced oven igniter and both electrodes
            with OEM Wolf parts, calibrated the oven (running 18°F low). All six
            burners tested and confirmed before leaving. Homeowner had been
            compensating with oven temp adjustments for months without realizing
            the igniter was the cause.
          </div>
          <div class="recent-card__result">✓ Same day · OEM Wolf · Oven calibrated · All burners confirmed</div>
        </div>

      </div>
    </div>
  </section>

  <!-- WHY US -->
  <section class="mon-why">
    <div class="container">
      <h2>Why Monrovia Calls Us Back</h2>
      <div class="why-grid">
        <div class="why-card">
          <div class="why-icon">🏡</div>
          <div class="why-title">Old Town & Foothill Both</div>
          <div class="why-text">Craftsman bungalows in Old Town have different service situations than foothill homes north of Foothill Boulevard. We work in both without a one-size-fits-all approach — older homes get attention to aging supply lines and vent configurations; newer homes get the luxury brand focus they need.</div>
        </div>
        <div class="why-card">
          <div class="why-icon">💧</div>
          <div class="why-title">SGVMWD Hard Water</div>
          <div class="why-text">San Gabriel Valley Municipal Water District groundwater means faster scale on ice maker inlet valves and dishwasher spray arms. We test for mineral deposits proactively on every relevant Monrovia call — it consistently comes up in this water district.</div>
        </div>
        <div class="why-card">
          <div class="why-icon">📅</div>
          <div class="why-title">Open Weekends</div>
          <div class="why-text">Saturday 8am–7pm and Sunday 9am–5pm. Some Monrovia appliance companies close on weekends. We're available when you need us — including Saturday morning emergency calls before family comes over.</div>
        </div>
        <div class="why-card">
          <div class="why-icon">✅</div>
          <div class="why-title">90-Day Warranty, OEM Only</div>
          <div class="why-text">Every repair backed by 90 days on parts and labor. Genuine OEM parts only. $89 diagnostic waived with repair. Written estimate before we start. California licensed, BBB A+ rated.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="mon-reviews">
    <div class="container">
      <h2>What Monrovia Customers Are Saying</h2>
      <div class="reviews-grid">
        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <div class="review-text">"Our Craftsman home on Myrtle had no ice maker output for months. Same Day came out, identified the mineral scale from our old pipes plus the SGV water, replaced the inlet valve, explained exactly why it keeps happening. Full ice production by next morning. Very thorough and honest about the water quality issue."</div>
          <div class="review-author">— Robert K., Myrtle Ave, Old Town Monrovia</div>
        </div>
        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <div class="review-text">"Brand new Samsung dishwasher leaving white film on everything after less than 2 years. Tech showed me the mineral deposits on both spray arms — clogged by hard water. Cleared everything in an hour, explained the SGV water issue, gave me a maintenance routine. Clean dishes from the first load after. Very knowledgeable."</div>
          <div class="review-author">— Lisa M., North Monrovia</div>
        </div>
        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <div class="review-text">"Called Saturday morning — dryer completely dead, no heat, laundry piling up. Same Day came out the same morning, found the blocked vent and blown fuse, fixed it by noon. Most companies I called said Monday earliest. The weekend availability is what makes the difference."</div>
          <div class="review-author">— Angela T., Mayflower Village, Monrovia</div>
        </div>
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section class="mon-pricing">
    <div class="container">
      <h2 class="section-title">Appliance Repair Costs in Monrovia</h2>
      <p class="section-sub">Written estimate before we start. $89 diagnostic — waived with repair.</p>
      <div class="pricing-grid">
        <div class="pricing-card featured">
          <div class="pricing-card__appliance">Refrigerator / Ice Maker</div>
          <div class="pricing-card__range">$150 – $400</div>
          <div class="pricing-card__note">SGVMWD hard water inlet valve · Fan motor · OEM</div>
        </div>
        <div class="pricing-card featured">
          <div class="pricing-card__appliance">Dishwasher</div>
          <div class="pricing-card__range">$150 – $320</div>
          <div class="pricing-card__note">Hard water descaling · Drain pump · Spray arm</div>
        </div>
        <div class="pricing-card">
          <div class="pricing-card__appliance">Sub-Zero / Wolf / Viking</div>
          <div class="pricing-card__range">$300 – $700+</div>
          <div class="pricing-card__note">OEM parts · Built-in · Foothill estate service</div>
        </div>
        <div class="pricing-card">
          <div class="pricing-card__appliance">Dryer + Vent Cleaning</div>
          <div class="pricing-card__range">$150 – $320</div>
          <div class="pricing-card__note">Thermal fuse · Older vent runs · Airflow check</div>
        </div>
        <div class="pricing-card">
          <div class="pricing-card__appliance">Washer / Oven / Range</div>
          <div class="pricing-card__range">$150 – $400</div>
          <div class="pricing-card__note">Standard repair range · Gas & electric</div>
        </div>
        <div class="pricing-card">
          <div class="pricing-card__appliance">Diagnostic Fee</div>
          <div class="pricing-card__range">$89</div>
          <div class="pricing-card__note">Waived when you proceed with the repair</div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="mon-faq">
    <div class="container">
      <h2>Questions Monrovia Customers Ask</h2>
      <div class="faq-list">
        <details class="faq-item"><summary class="faq-question">Do you offer same-day appliance repair in Monrovia, CA?</summary><div class="faq-answer">Yes. Our technicians cover all of Monrovia 91016 — Old Town, Myrtle Avenue, Mayflower Village, foothill neighborhoods, and every street in the city. Call before noon for same-day afternoon service.</div></details>
        <details class="faq-item"><summary class="faq-question">Does hard water in Monrovia affect appliances?</summary><div class="faq-answer">Yes. Monrovia is served by the San Gabriel Valley Municipal Water District's mineral-rich groundwater. Ice maker inlet valves and dishwasher spray arms scale up faster than national average. We test for mineral deposits proactively on every relevant Monrovia call.</div></details>
        <details class="faq-item"><summary class="faq-question">Do you repair appliances in Monrovia's older historic homes?</summary><div class="faq-answer">Yes. Old Town's Victorian and Craftsman homes sometimes have complex vent installations and older supply lines that compound hard water effects. We're familiar with these situations and come prepared.</div></details>
        <details class="faq-item"><summary class="faq-question">Are you available on weekends in Monrovia?</summary><div class="faq-answer">Yes. Saturday 8am–7pm and Sunday 9am–5pm. Some Monrovia appliance companies close on weekends — we don't.</div></details>
        <details class="faq-item"><summary class="faq-question">Do you repair Sub-Zero, Wolf, and luxury appliances in Monrovia?</summary><div class="faq-answer">Yes. Foothill-area homes in Monrovia frequently have Sub-Zero refrigerators, Wolf ranges, and Viking appliances. We carry OEM parts for these brands on every vehicle.</div></details>
        <details class="faq-item"><summary class="faq-question">What is your diagnostic fee in Monrovia?</summary><div class="faq-answer">Our diagnostic fee is $89, waived when you proceed with the repair. Written estimate before we start. Most Monrovia repairs run $150–$400.</div></details>
        <details class="faq-item"><summary class="faq-question">Do you also serve Arcadia, Duarte, and Temple City?</summary><div class="faq-answer">Yes. Our Monrovia service extends to Arcadia, Duarte, Bradbury, Azusa, Glendora, Temple City, and South Pasadena. All within our regular SGV route.</div></details>
      </div>
    </div>
  </section>

  <!-- NEARBY -->
