---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import CustomNarrative from '../components/cities/v2/CustomNarrative.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

const citySlug = 'westlake-village';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = 'Westlake Village';
const zips = ['91361', '91362'];

const title = `Appliance Repair Westlake Village CA | Same Day Service | ${branch.phone}`;
const description = "Same-day appliance repair in Westlake Village, CA. Westlake Lake, Lake Sherwood, North Ranch. LVMWD hard water aware. OEM parts.";
const canonical = 'https://samedayappliance.repair/westlake-village/';

const phoneRaw = `+1${branch.phone.replace(/\D/g, '')}`;

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { '@type': 'City', name: 'Westlake Village', sameAs: 'https://en.wikipedia.org/wiki/Westlake_Village,_California' },
    { '@type': 'Place', name: 'Westlake Lake' },
    { '@type': 'Place', name: 'Lake Sherwood' },
    { '@type': 'Place', name: 'North Ranch' },
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$$',
  license: 'CA BHGS #A49573'

};

const introParagraphs = [
  "Westlake Village is one of the more distinctive service areas in our Conejo Valley territory. Lakefront homes around Westlake Lake and Lake Sherwood, the gated estates at North Ranch, the established residential streets along Lakeview Canyon Road — the appliance landscape skews high-end here. Sub-Zero columns, Wolf dual-fuel ranges, Thermador pro ranges, and Miele dishwashers are the standard, not the exception.",
  "The single biggest factor that affects appliances in 91361 and 91362 is LVMWD water. Las Virgenes Municipal Water District delivers water with hardness in the 200–250 mg/L range across all of Westlake Village. That mineral load shows up in specific places: ice maker inlet valves scale up faster than manufacturer schedules anticipate, dishwasher spray arms accumulate deposits that affect cleaning, and refrigerator water filters need replacement more often than every 12 months.",
  "The Conejo Valley climate is the secondary factor. Dry summer air and seasonal dust loads affect condenser coils on every refrigerator and wine cooler — the kind of fine particulate that's invisible until you pull the unit and look. Combined with LVMWD scale on the water side, refrigerators in this market need more proactive maintenance than the manufacturer's generic 12-month coil-cleaning recommendation.",
  `Diagnostic fee is $89 — credited toward the repair when you proceed. We carry OEM parts for Sub-Zero, Wolf, Thermador, and Miele on every Thousand Oaks truck, and we coordinate gated community access in advance for the lakeside and North Ranch communities. Call <a href="tel:${phoneRaw}">${branch.phone}</a> for same-day service across all of 91361 and 91362.`,
  "<strong>LVMWD water tip for Westlake Village:</strong> Las Virgenes Municipal Water District delivers 200–250 mg/L throughout Westlake Village. If your ice maker output has been declining gradually over months, LVMWD mineral scale on the inlet valve is almost certainly the cause — not a failing compressor or a faulty module. Replacing your refrigerator's in-door filter every 6 months (not 12) meaningfully slows the accumulation rate.",
];

const services = [
  { icon: '❄️', name: 'Refrigerator Repair', slug: 'refrigerator', issues: 'LVMWD hard water ice maker · Sub-Zero built-in · Not cooling · Coil inspection', brands: 'Sub-Zero · Wolf · Samsung · LG · GE · Thermador' },
  { icon: '🔥', name: 'Oven, Range & Pro Range', slug: 'oven', issues: 'Wolf dual-fuel · Thermador star burner · Gas igniter · Temperature off', brands: 'Wolf · Thermador · Viking · GE · Samsung · KitchenAid' },
  { icon: '🍽️', name: 'Dishwasher Repair', slug: 'dishwasher', issues: 'Miele · LVMWD scale · Panel-ready · Not draining · Error codes', brands: 'Miele · Bosch · Thermador · KitchenAid · Samsung · GE' },
  { icon: '🫧', name: 'Washer Repair', slug: 'washer', issues: 'OE / UE error · Not draining · Not spinning · Error codes', brands: 'LG · Samsung · Whirlpool · Maytag · Bosch · Speed Queen' },
  { icon: '💨', name: 'Dryer Repair + Vent Cleaning', slug: 'dryer', issues: 'Not heating · Thermal fuse · Vent buildup · Gas & electric', brands: 'LG · Samsung · GE · Maytag · Whirlpool · Miele' },
  { icon: '🧊', name: 'Freezer & Ice Maker Repair', slug: 'freezer', issues: 'LVMWD inlet valve scale · Not freezing · Ice stopped · Sub-Zero', brands: 'Sub-Zero · Samsung · LG · GE · True · Whirlpool' },
  { icon: '🍷', name: 'Wine Cellar & Cooler Repair', slug: 'wine-cooler', issues: 'Temperature off · WhisperKOOL · Sub-Zero wine · EuroCave', brands: 'Sub-Zero · EuroCave · True · WhisperKOOL · Liebherr' },
  { icon: '♨️', name: 'Cooktop & Range Hood', slug: 'cooktop', issues: 'Wolf star burner · Thermador igniter · Induction · Hood motor', brands: 'Wolf · Thermador · Gaggenau · Miele · Viking · Dacor' },
];

const neighborhoods = [
  { name: 'Westlake Lake waterfront', zip: '91361', featured: true },
  { name: 'Lake Sherwood estates', zip: '91361', featured: true },
  { name: 'North Ranch', zip: '91362', featured: true },
  { name: 'The Promenade area', zip: '91362' },
  { name: 'Westlake Trails', zip: '91362' },
  { name: 'Lakeview Canyon', zip: '91361' },
  { name: 'Bridgeport', zip: '91361' },
];

const recentJobs = [
  {
    appliance: 'Sub-Zero Built-In',
    location: 'Westlake Lake waterfront, 91361',
    quote: 'Ice maker producing almost nothing for three months',
    description: "Lakefront home on Westlake Lake — Sub-Zero 48-inch built-in with both LVMWD mineral scale and Conejo Valley dust load on the condenser coils. Two issues in one call: inlet valve almost completely blocked by mineral deposits, and coils overloaded with fine hillside particulate making the compressor work harder. Replaced the OEM Sub-Zero inlet valve, thoroughly cleaned the coil assembly, confirmed stable temperatures. Full ice production the next morning. Placed on a combined 6-month schedule: inlet valve filter check and coil inspection.",
    outcome: '✓ Same day · OEM Sub-Zero · Inlet valve + coils · 6-month plan'
  },
  {
    appliance: 'Thermador Pro Range',
    location: 'North Ranch, 91362',
    quote: "Oven igniter glowing but won't light — second time this year",
    description: "North Ranch estate — Thermador 48-inch pro range. Oven igniter drawing weak current, visually glowing but failing to open the gas valve — classic igniter failure pattern. Second occurrence within 12 months on this unit. Replaced with OEM Thermador igniter, tested both oven cavities at 325°F, 375°F, and 450°F — accurate within 5 degrees. Given the repeat failure, recommended checking the igniter at 12-month intervals as a maintenance item on this heavily-used kitchen range.",
    outcome: '✓ Same day · OEM Thermador · Both cavities confirmed · 12-month plan'
  },
  {
    appliance: 'Miele Dishwasher',
    location: 'Lake Sherwood, 91361',
    quote: 'F70 flood error — machine completely locked out',
    description: "Lake Sherwood estate — Miele G 7000 panel-integrated with F70 base pan flood error. Found the water inlet connection had developed a slow weep from vibration over time — water had accumulated in the base pan triggering the flood protection. Cleared the base pan, reseated and properly sealed the inlet connection, ran the Miele anti-flood reset procedure, tested three full cycles. Panel cabinetry pulled and reinstalled without a mark. All clear on the Miele diagnostics.",
    outcome: '✓ Same day · Miele F70 resolved · Panel intact · Diagnostics clear'
  },
  {
    appliance: 'LG Washer',
    location: 'Westlake Trails, 91362',
    quote: 'LE motor error — LVMWD scale blocking the pump filter too',
    description: "LG front-loader — LE motor error (hall sensor fault) presenting alongside a secondary OE drain issue. Ran SmartDiagnosis through the app first: confirmed hall sensor failure as primary, pump filter blockage as secondary. Replaced the hall sensor with OEM LG part, cleared the pump filter packed with LVMWD mineral scale and lint. Two problems, one trip. Tested three cycles — no LE, no OE. Homeowner wasn't aware LVMWD water accelerates pump filter buildup; explained the quarterly cleaning routine.",
    outcome: '✓ Same day · OEM LG hall sensor · Pump filter cleared · LVMWD explained'
  },
];

const whyReasons = [
  {
    iconKey: 'parts' as const,
    title: 'LVMWD Hard Water Aware',
    body: 'Las Virgenes water at 200–250 mg/L hardness is the single most consistent factor we deal with on Westlake Village calls. Ice maker inlet valves, dishwasher spray arms, washing machine pump filters — we know where it shows up first and how to address it correctly.'
  },
  {
    iconKey: 'shield' as const,
    title: 'Conejo Valley Climate Aware',
    body: "Dry summers and seasonal dust loads affect condenser coils faster than manufacturer schedules anticipate. We inspect coils on every refrigerator and wine cooler call in 91361 and 91362, and we recommend the right cadence for each home — not a generic schedule."
  },
  {
    iconKey: 'team' as const,
    title: 'Gated Community Ready',
    body: "Lake Sherwood, North Ranch, and the Westlake Lake waterfront communities all have gate coordination requirements. We arrange access in advance with the property manager, gate guard, or estate manager — your service appointment runs smoothly without you having to manage logistics."
  },
  {
    iconKey: 'clock' as const,
    title: '90-Day Warranty, OEM Only',
    body: 'Every repair we do in Westlake Village carries a 90-day warranty on parts and labor, and we use OEM parts on every job — Sub-Zero, Wolf, Thermador, Miele, and the rest. If the same issue returns within 90 days, we come back at no charge.'
  },
];

const testimonials = [
  {
    stars: 5,
    text: '"Sub-Zero on our lakefront home had two problems — LVMWD scale on the inlet valve and Conejo dust on the coils. Same Day found both, fixed both in one visit, put us on a 6-month plan appropriate for a lakefront hillside property. This is exactly the local expertise Westlake Village homes need."',
    author: '— Robert K., Westlake Lake, Westlake Village'
  },
  {
    stars: 5,
    text: '"Thermador range oven igniter failing again — second time in a year. Tech came same day, replaced with OEM Thermador part, tested both cavities accurately, explained the maintenance interval for a heavily-used range. We appreciate a tech who thinks about prevention, not just the immediate fix."',
    author: '— Jennifer N., North Ranch, Westlake Village'
  },
  {
    stars: 5,
    text: '"Miele dishwasher F70 error in our Lake Sherwood home. Tech cleared it, found the actual inlet connection issue, reinstalled the panel cabinetry perfectly, ran through the full Miele diagnostics before leaving. Professional, thorough, and careful with a kitchen we care about. Would absolutely use again."',
    author: '— Diana W., Lake Sherwood, Westlake Village'
  },
];

const pricingTiers = [
  { appliance: 'Sub-Zero / Wolf / Gaggenau', range: '$300–$800+', note: 'OEM parts · Lakeside & North Ranch estates · Coordinated access', featured: true },
  { appliance: 'Thermador / Miele / Viking', range: '$250–$600+', note: 'OEM parts · Pro range · Panel-ready dishwasher', featured: true },
  { appliance: 'Refrigerator (Standard)', range: '$150–$400', note: 'LVMWD inlet valve · Coil cleaning · Ice maker' },
  { appliance: 'Washer / Dryer', range: '$150–$350', note: 'OE/UE/LE errors · Pump filter · Vent cleaning' },
  { appliance: 'Dishwasher / Oven', range: '$150–$450', note: 'Spray arm descale · Igniter · Element' },
  { appliance: 'Diagnostic Fee', range: '$89', note: 'Credited toward repair · Written estimate' },
];

const faqs = [
  {
    question: 'Do you offer same-day appliance repair in Westlake Village?',
    answer: "Yes — Westlake Village is on our regular Thousand Oaks branch route. We cover both 91361 and 91362 daily, including the Westlake Lake waterfront, Lake Sherwood, North Ranch, and the surrounding neighborhoods. Call before noon for same-day service."
  },
  {
    question: 'How does LVMWD hard water affect appliances in Westlake Village?',
    answer: "LVMWD water hardness in Westlake Village runs 200–250 mg/L — high enough to noticeably affect ice maker inlet valves, dishwasher spray arms, and washing machine pump filters. We see this on most service calls in 91361 and 91362. The maintenance schedule we recommend: refrigerator water filter every 6 months (not 12), dishwasher filter cleaning every 3 months, and ice maker descaling every 12–18 months."
  },
  {
    question: 'Do you repair Sub-Zero, Wolf, Thermador, and Miele in Westlake Village?',
    answer: "Yes. Sub-Zero columns, Wolf dual-fuel ranges, Thermador pro ranges, and Miele panel-integrated dishwashers are common in Westlake Village kitchens — especially in the lakeside homes and North Ranch estates. We carry OEM parts for all four brands on every Thousand Oaks vehicle."
  },
  {
    question: 'Do you service gated communities like Lake Sherwood and North Ranch?',
    answer: "Yes. Lake Sherwood, North Ranch, and the Westlake Lake waterfront all have gate coordination requirements. Tell us when you call who manages access — property manager, estate manager, or gate guard — and we coordinate in advance so the appointment runs smoothly."
  },
  {
    question: 'Are weekend appointments available in Westlake Village?',
    answer: "Yes — we offer Saturday appointments in Westlake Village. Call to confirm the next available slot. Sunday appointments are limited but we answer the phone every day."
  },
  {
    question: 'What is your diagnostic fee in Westlake Village?',
    answer: "Our diagnostic fee is $89. It covers the trip, full appliance inspection, and a written estimate. If you proceed with the repair, the $89 is credited toward your invoice. Standard repair range in Westlake Village is $150–$500 depending on appliance and parts; luxury brand repairs run higher."
  },
  {
    question: 'Do you service nearby Conejo Valley cities like Thousand Oaks, Calabasas, and Agoura Hills?',
    answer: "Yes — our Thousand Oaks branch covers all of the Conejo Valley including Thousand Oaks, Calabasas, Agoura Hills, Oak Park, Newbury Park, and Moorpark. Same-day service is typically available across this corridor."
  },
];

const nearbyCities = [
  { name: 'Thousand Oaks', slug: 'thousand-oaks' },
  { name: 'Calabasas', slug: 'calabasas' },
  { name: 'Malibu', slug: 'malibu' },
  { name: 'Bel Air', slug: 'bel-air' },
  { name: 'Beverly Hills', slug: 'beverly-hills' },
  { name: 'Pacific Palisades', slug: 'pacific-palisades' },
  { name: 'Brentwood', slug: 'brentwood' },
  { name: 'Los Angeles', slug: 'los-angeles' },
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair"
    headlineCity="Westlake Village, CA"
    subheadline="Lakefront luxury, gated estates, and Conejo Valley living — Sub-Zero, Wolf, Thermador, Miele specialists. LVMWD hard water aware. Same-day, OEM parts, 90-day warranty across 91361 and 91362."
    zips={zips}
    tier={1}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance Repair in Westlake Village — What This Community Calls For"
    paragraphs={introParagraphs}
    bookingTitle="Westlake Village Service"
    bookingSub="91361 · 91362 · Local TO branch · Same day"
  />

  <ServicesGrid
    cityName={cityName}
    headline="What We Repair in Westlake Village"
    services={services}
  />

  <ServiceArea
    cityName={cityName}
    headline="Westlake Village Communities We Service"
    subheadline="From the Westlake Lake waterfront to Lake Sherwood and North Ranch — every part of 91361 and 91362."
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={['Lakeview Canyon Rd', 'Thousand Oaks Blvd', 'Westlake Blvd', 'Lake Sherwood Dr', 'Lindero Canyon Rd', 'Via Colinas']}
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Repairs in Westlake Village"
    jobs={recentJobs}
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="Why Westlake Village Homeowners Call Us"
    reasons={whyReasons}
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What Westlake Village Clients Say"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Repair Pricing in Westlake Village"
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="Frequently Asked Questions — Westlake Village"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby Cities"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance broken in Westlake Village?"
    body="Westlake Lake · Lake Sherwood · North Ranch · LVMWD · Sub-Zero · Wolf · Miele. $89 diagnostic waived with repair. 90-day warranty. OEM parts."
  />
</CityLayoutV2>
