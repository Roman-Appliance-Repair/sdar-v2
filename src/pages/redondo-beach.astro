---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import CustomNarrative from '../components/cities/v2/CustomNarrative.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

const citySlug = 'redondo-beach';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = 'Redondo Beach';
const zips = ['90277', '90278'];

const phone = branch.phone;
const phoneRaw = `+1${phone.replace(/\D/g, '')}`;

const title = `Appliance Repair Redondo Beach CA — Same Day | The Strand · Riviera Village · North Redondo | ${phone}`;
const description = `Same-day appliance repair in Redondo Beach, CA 90277 & 90278. The Strand, South Redondo, Riviera Village, North Redondo, Hollywood Riviera. Salt air specialists for coastal homes. Samsung, LG, GE, Sub-Zero. Licensed, OEM parts, 90-day warranty. Call ${phone}.`;
const canonical = 'https://samedayappliance.repair/redondo-beach/';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { '@type': 'City', name: 'Redondo Beach', sameAs: 'https://en.wikipedia.org/wiki/Redondo_Beach,_California' },
    { '@type': 'Neighborhood', name: 'South Redondo Beach' },
    { '@type': 'Neighborhood', name: 'North Redondo Beach' },
    { '@type': 'Neighborhood', name: 'Riviera Village' },
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$',
  license: 'CA CSLB #1138898'

};

const introParagraphs = [
  "Redondo Beach is two different cities depending on which side of Artesia Boulevard you're on. South Redondo — The Strand, Riviera Village, the oceanfront blocks — is genuinely coastal living. The salt air is real and it affects appliances in measurable ways. Refrigerator condenser coils accumulate salt particulate. Gas range igniter electrodes corrode from the moisture and salt exposure. Outdoor appliances wear faster. We've learned to check for all of this on every relevant call in the coastal ZIPs.",
  "North Redondo (90278) is a different story — inland townhomes and single-family homes where the primary need is reliable same-day service with an honest written estimate. No salt air factor, no extra complexity. LG, Samsung, GE, Whirlpool — we carry OEM parts for all of them and get there same day.",
  "Riviera Village is the sweet spot — walkable, well-kept, close enough to the water to see some coastal influence but not Strand-level exposure. The Hollywood Riviera bluff homes sit on the edge between Redondo Beach and Torrance with ocean-facing exposure and premium appliances.",
  "Diagnostic fee: <strong>$89</strong> — waived with repair. Written estimate before we start. <strong>90-day warranty</strong>. Weekends available.",
];

const services = [
  { icon: '🧊', name: 'Refrigerator Repair', slug: 'refrigerator', issues: 'Salt air coil inspection · Not cooling · Ice maker · Fan motor', brands: 'Samsung · LG · GE · Whirlpool · Sub-Zero · KitchenAid' },
  { icon: '🫧', name: 'Washer Repair', slug: 'washer', issues: 'OE / UE error · Not draining · Not spinning · Stackable', brands: 'LG · Samsung · Whirlpool · Maytag · Bosch · Speed Queen' },
  { icon: '♨️', name: 'Dryer Repair + Vent Cleaning', slug: 'dryer', issues: 'Not heating · Thermal fuse · Vent buildup · Gas & electric', brands: 'LG · Samsung · GE · Maytag · Whirlpool · Electrolux' },
  { icon: '🍽️', name: 'Dishwasher Repair', slug: 'dishwasher', issues: 'Not draining · E24 · Error codes · Spray arm', brands: 'Bosch · KitchenAid · Samsung · LG · GE · Jenn-Air' },
  { icon: '🔥', name: 'Oven, Range & Stove', slug: 'oven', issues: 'Salt air igniter corrosion · Not heating · Temperature off', brands: 'GE · Samsung · KitchenAid · Wolf · Viking · Jenn-Air' },
  { icon: '❄️', name: 'Freezer & Ice Maker Repair', slug: 'freezer', issues: 'Not freezing · Ice stopped · Frost buildup · Salt air', brands: 'Samsung · LG · GE · Whirlpool · Sub-Zero · True' },
  { icon: '🍷', name: 'Wine Cooler Repair', slug: 'wine-cooler', issues: 'Temperature off · Compressor · Coastal humidity · Built-in', brands: 'True · U-Line · Liebherr · Dacor · Sub-Zero' },
  { icon: '🔆', name: 'Cooktop & Range Hood', slug: 'cooktop', issues: 'Salt air igniter · Gas burner · Induction · Hood motor', brands: 'GE · Bosch · Samsung · Wolf · KitchenAid · Broan' },
];

const zonesNarrative = {
  headline: 'Two Redondo Beaches — One Service',
  paragraphs: [
    "The coastal/inland split matters for appliances. Here's what it means for each zone.",
  ],
  subSections: [
    {
      title: 'Coastal · Salt Air — South Redondo · The Strand · Riviera Village · Hollywood Riviera (90277)',
      paragraphs: [
        "Homes on or near The Strand and the ocean-facing blocks of South Redondo see real salt air — not just \"beach proximity\" but actual salt particulate that loads condenser coils and corrodes igniter electrodes faster than anywhere else in the South Bay except Malibu. Strand-adjacent homes may need coil cleaning every <strong>3–5 months</strong>. We inspect for salt corrosion on every coastal Redondo Beach refrigerator and range call.",
      ]
    },
    {
      title: 'Inland · Standard — North Redondo · Aviation Corridor · Artesia area (90278)',
      paragraphs: [
        "North Redondo (90278) inland of Artesia Blvd has essentially no meaningful salt air factor. The appliance profile here is standard South Bay — LG, Samsung, GE, Whirlpool in well-maintained townhomes and single-family homes. Reliable same-day service, honest estimate, 90-day warranty. No coastal maintenance surcharges or upsells.",
      ]
    },
    {
      title: 'Redondo Beach Salt Air Guide',
      paragraphs: [
        "The closer to The Strand, the more aggressive the exposure. A home on the water in South Redondo needs condenser coil cleaning every 3–5 months. A home three blocks inland in Riviera Village — every 6 months. A home in North Redondo near Artesia — standard 12-month cycle. We calibrate our maintenance recommendations to your actual distance from the water, not a blanket coastal policy.",
      ]
    },
  ]
};

const neighborhoods = [
  { name: 'The Strand', zip: '90277', featured: true },
  { name: 'South Redondo', zip: '90277', featured: true },
  { name: 'Riviera Village', zip: '90277', featured: true },
  { name: 'Hollywood Riviera', zip: '90277' },
  { name: 'North Redondo', zip: '90278' },
  { name: 'Aviation Corridor', zip: '90278' },
  { name: 'Artesia area', zip: '90278' },
];

const recentJobs = [
  {
    appliance: 'Sub-Zero Refrigerator',
    location: 'The Strand, South Redondo 90277',
    quote: 'Not keeping temperature — cycling way too often',
    description: "Strand-front home in South Redondo — Sub-Zero 42-inch built-in with condenser coils so heavily loaded with salt air particulate the compressor was working at near-continuous duty. This is the most aggressive salt air environment in Redondo Beach: direct ocean exposure at street level. Full coil cleaning, replaced a weakened condenser fan motor showing heat stress. Temperature stable and cycling normalized within 45 minutes. Placed on a 4-month coil inspection schedule appropriate for a Strand-front location.",
    outcome: '✓ Same day · Coils cleaned · Fan motor replaced · 4-month Strand schedule'
  },
  {
    appliance: 'GE Gas Range',
    location: 'Riviera Village, 90277',
    quote: "Two burners clicking constantly — won't ignite clean",
    description: "Riviera Village home three blocks from the water — GE freestanding gas range with two igniter electrodes corroded from the combination of salt air moisture and cooking steam. One electrode had a visible salt deposit at the tip. Replaced both corroded electrodes with OEM GE parts, cleaned the electrode wells, tested all four burners — all igniting cleanly on first spark. Explained the salt air igniter corrosion pattern: Riviera Village homes see this every 2–3 years, Strand homes every 12–18 months.",
    outcome: '✓ Same day · OEM GE igniters · All burners clean · Interval explained'
  },
  {
    appliance: 'LG Washer',
    location: 'North Redondo, 90278',
    quote: "LE motor error — won't spin, machine just stops",
    description: "North Redondo townhome — LG front-loader LE hall sensor error. Ran SmartDiagnosis through the app first: confirmed hall sensor on the rotor assembly. Replaced with OEM LG hall sensor, cleared the error code, ran three full cycles at maximum spin. Machine quiet and stable. Standard North Redondo call — no salt air factor, no coastal complexity. Done in under an hour.",
    outcome: '✓ Same day · OEM LG hall sensor · Smart diagnosis first · Done in 55 min'
  },
  {
    appliance: 'Samsung French Door',
    location: 'Hollywood Riviera, 90277',
    quote: 'Ice maker declining for months — almost no output now',
    description: "Hollywood Riviera bluff home — Samsung French door with gradual ice maker decline. Combined causes: salt air particulate on the condenser coils reducing cooling efficiency, and a slowly scaling water inlet valve from the coastal moisture. Cleaned the coils, replaced the OEM Samsung inlet valve, installed a fresh filter. Full ice production confirmed next morning. Riviera bluff properties sit right in the moderately aggressive salt air zone — between Strand intensity and inland calm. 6-month coil plan appropriate here.",
    outcome: '✓ Same day · Coils + inlet valve · OEM Samsung · 6-month plan set'
  },
];

const whyReasons = [
  {
    iconKey: 'team' as const,
    title: 'Genuine Salt Air Knowledge',
    body: "We know the difference between a Strand-front home (4-month coil cycle), a Riviera Village home three blocks in (6 months), and North Redondo near Artesia (standard 12 months). We don't apply a blanket \"coastal\" label to all of Redondo Beach and call it specialized service."
  },
  {
    iconKey: 'parts' as const,
    title: 'Both ZIPs, All Neighborhoods',
    body: "South Redondo coastal homes and North Redondo inland townhomes get the same same-day commitment, OEM parts, and 90-day warranty. We're on the same South Bay route as Torrance, Manhattan Beach, and Hermosa Beach — Redondo Beach is never a special trip."
  },
  {
    iconKey: 'clock' as const,
    title: 'Weekends Available',
    body: "Saturday 8am–7pm and Sunday 9am–5pm. Redondo Beach weekends are busy and appliances know it. We're available both days."
  },
  {
    iconKey: 'shield' as const,
    title: '90-Day Warranty, OEM Only',
    body: 'Every repair backed by 90 days on parts and labor. Genuine OEM parts — never aftermarket. $89 diagnostic waived with repair. Written estimate before we start. California licensed, BBB A+ rated.'
  },
];

const testimonials = [
  {
    stars: 5,
    text: "\"Sub-Zero on The Strand was cycling non-stop. Same Day cleaned the salt-loaded coils, replaced the fan motor, put us on a 4-month Strand-specific plan. Done in under an hour. The tech knew exactly what a Strand-front property looks like — this wasn't generic coastal advice.\"",
    author: '— James W., The Strand, South Redondo'
  },
  {
    stars: 5,
    text: '"Gas range igniters corroded again in our Riviera Village home. Tech replaced both electrodes with OEM GE parts, explained the 2–3 year interval for our distance from the water. Everything clean on first spark. Really appreciated that he gave us a specific interval, not just \'you live near the beach.\'"',
    author: '— Maria C., Riviera Village, Redondo Beach'
  },
  {
    stars: 5,
    text: '"LG washer LE error in our North Redondo townhome. Tech ran the SmartDiagnosis app, confirmed the hall sensor, replaced it with OEM part, tested three cycles. Done in under an hour, no fuss. Appreciated that he didn\'t try to make it complicated — it was a straightforward repair, treated as such."',
    author: '— Kevin S., North Redondo, 90278'
  },
];

const pricingTiers = [
  { appliance: 'Refrigerator + Salt Air Coil Check', range: '$150 – $400', note: 'Coastal inspection · Strand / Riviera / Hollywood Riviera', featured: true },
  { appliance: 'Washer / Dryer', range: '$150 – $350', note: 'Hall sensor · Drain pump · Thermal fuse · Vent cleaning' },
  { appliance: 'Dishwasher', range: '$150 – $320', note: 'E24 drain · Spray arm · Filter · Error codes' },
  { appliance: 'Oven / Range', range: '$150 – $400', note: 'Salt air igniter · Gas valve · Calibration · OEM' },
  { appliance: 'Sub-Zero / Wolf', range: '$300 – $700+', note: 'OEM parts · Hollywood Riviera · Strand homes' },
  { appliance: 'Diagnostic Fee', range: '$89', note: 'Waived when you proceed with the repair' },
];

const faqs = [
  {
    question: 'Do you offer same-day appliance repair in Redondo Beach, CA?',
    answer: 'Yes. Our technicians cover all of Redondo Beach — The Strand, South Redondo, Riviera Village, Hollywood Riviera, and all of North Redondo. Both ZIP codes 90277 and 90278. Call before noon for same-day afternoon service.'
  },
  {
    question: 'How does salt air affect appliances in South Redondo Beach?',
    answer: 'Significantly for homes on or near The Strand and oceanfront South Redondo. Salt air accelerates corrosion on refrigerator condenser coils, range igniter electrodes, and outdoor appliances. Strand-adjacent homes may need condenser coil cleaning every 3–5 months rather than the standard 12. We inspect for salt air corrosion on every South Redondo refrigerator call.'
  },
  {
    question: 'Is North Redondo Beach the same as South Redondo for appliance repair?',
    answer: 'For the most part, yes — same same-day service, same $89 diagnostic, same 90-day warranty. The difference is that North Redondo (90278, inland of Artesia Blvd) has no meaningful salt air factor, while South Redondo coastal homes require salt air awareness on refrigerator and range calls.'
  },
  {
    question: 'What appliance brands do you repair in Redondo Beach?',
    answer: 'All major brands: Samsung, LG, GE, Whirlpool, KitchenAid, Bosch, Maytag, Jenn-Air, Sub-Zero, Wolf, and more. We carry OEM parts on every service vehicle.'
  },
  {
    question: 'Are you available on weekends in Redondo Beach?',
    answer: 'Yes. Saturday 8am–7pm and Sunday 9am–5pm.'
  },
  {
    question: 'What is your diagnostic fee in Redondo Beach?',
    answer: 'Our diagnostic fee is $89, waived when you proceed with the repair. Written estimate before we start. Most Redondo Beach repairs run $150–$400.'
  },
  {
    question: 'Do you also serve Torrance, Manhattan Beach, and Hermosa Beach?',
    answer: 'Yes. Our Redondo Beach service extends to Torrance, Manhattan Beach, Hermosa Beach, El Segundo, Hawthorne, Lawndale, and all of the South Bay.'
  },
];

const nearbyCities = [
  { name: 'Manhattan Beach', slug: 'manhattan-beach' },
  { name: 'Torrance', slug: 'torrance' },
  { name: 'Santa Monica', slug: 'santa-monica' },
  { name: 'Marina Del Rey', slug: 'marina-del-rey' },
  { name: 'Culver City', slug: 'culver-city' },
  { name: 'Long Beach', slug: 'long-beach' },
  { name: 'Los Angeles', slug: 'los-angeles' },
  { name: 'Beverly Hills', slug: 'beverly-hills' },
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair"
    headlineCity="Redondo Beach, CA"
    subheadline="The Strand and South Redondo coastal homes live differently from North Redondo inland — salt air is real here, and we know the difference. Same-day service across all of 90277 and 90278. OEM parts, 90-day warranty. Weekends available."
    zips={zips}
    tier={2}
  />

  <TrustBadgesRow />

  <CustomNarrative
    headline={zonesNarrative.headline}
    paragraphs={zonesNarrative.paragraphs}
    subSections={zonesNarrative.subSections}
    background="black"
  />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance Repair in Redondo Beach — What We Know"
    paragraphs={introParagraphs}
    bookingTitle="Redondo Beach Service"
    bookingSub="90277 · 90278 · Coastal aware · Same day"
  />

  <ServicesGrid
    cityName={cityName}
    headline="What We Repair in Redondo Beach"
    services={services}
  />

  <ServiceArea
    cityName={cityName}
    headline="Redondo Beach Areas We Service"
    subheadline="The Strand, Riviera Village, Hollywood Riviera, North Redondo. ZIP codes 90277 and 90278."
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={[]}
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Jobs in Redondo Beach"
    subhead="Real calls from 90277 and 90278 — The Strand, Riviera Village, North Redondo."
    jobs={recentJobs}
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="Why Redondo Beach Calls Us Back"
    reasons={whyReasons}
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What Redondo Beach Customers Are Saying"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Appliance Repair Costs in Redondo Beach"
    subhead="Written estimate before we start. $89 diagnostic — waived with repair."
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="Questions Redondo Beach Customers Ask"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby Areas"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance broken in Redondo Beach?"
    body="The Strand · Riviera Village · North Redondo · Salt air specialists · All of 90277 & 90278. $89 diagnostic waived with repair. 90-day warranty."
  />
</CityLayoutV2>
