---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import CustomNarrative from '../components/cities/v2/CustomNarrative.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

const citySlug = 'westwood';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = 'Westwood';
const zips = ['90024'];

const title = `Appliance Repair Westwood CA — Same Day Service`;
const description = "Same-day appliance repair in Westwood, CA 90024. Sub-Zero, Wolf, Thermador. Tenants and building managers welcome. OEM parts.";
const canonical = 'https://samedayappliance.repair/westwood/';

const phoneRaw = `+1${branch.phone.replace(/\D/g, '')}`;

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { '@type': 'Place', name: 'Westwood', sameAs: 'https://en.wikipedia.org/wiki/Westwood,_Los_Angeles' },
    { '@type': 'Place', name: 'Little Holmby' },
    { '@type': 'Place', name: 'Westwood Village' },
    { '@type': 'Place', name: 'North Westwood Village' }
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$',
  license: 'BHGS #A49573'

};

const twoWorldsNarrative = {
  headline: 'Westwood Is Two Neighborhoods in One ZIP Code',
  paragraphs: [
    "Our technicians work in both. Same day, same quality, different situations."
  ],
  subSections: [
    {
      title: 'The Campus Corridor — Apartments, condos, and buildings along Gayley, Levering, Landfair & Wilshire',
      paragraphs: [
        "High-rise and mid-rise buildings, compact kitchens, stackable laundry, shared laundry rooms, building management logistics. Tenants on deadline, landlords who need quick turnaround, building managers who coordinate access. We work with all of them — call us and tell us your situation, we'll handle the rest.",
        "Compact kitchen appliances · Stackable washer/dryer units · Building manager coordination · Tenant & landlord calls both welcome."
      ]
    },
    {
      title: 'Little Holmby & South Westwood — Estates, single-family homes, and Wilshire Corridor high-end condos',
      paragraphs: [
        "Little Holmby's leafy residential streets south of Sunset have some of the finest kitchens in LA — Sub-Zero columns, Wolf ranges, Thermador appliances. The Wilshire Corridor buildings add luxury condo kitchens. We carry OEM parts for all of these brands and are experienced with the built-in configurations common in this part of 90024.",
        "Sub-Zero / Wolf / Thermador · Built-in & panel-ready · Estate & property manager ready · OEM parts only."
      ]
    }
  ]
};

const introParagraphs = [
  "Westwood at 90024 covers a remarkable range of housing in a single ZIP. The Gayley/Levering/Landfair corridor adjacent to UCLA is dense apartment and condo territory — compact kitchens, stackable washer/dryer units, building turnover schedules, building managers who coordinate access. The Wilshire Corridor adds panel-ready Sub-Zero refrigerators and Bosch dishwashers in luxury high-rise condos. Little Holmby and North Westwood Village have larger single-family homes with full luxury suites — Sub-Zero, Wolf, Thermador, Miele.",
  "We carry OEM parts for all of this on the same truck. The high-rise vs. estate logistics — elevator coordination, gate guards, estate managers, tenant landlord situations — is just part of how we work this part of LA. Tell us what you're dealing with when you call and we route accordingly.",
  `Diagnostic fee: $89, credited toward repair when you proceed. Written estimate before we start. 90-day warranty on parts and labor. Call <a href="tel:${phoneRaw}">${branch.phone}</a> for same-day service across all of 90024.`,
  "<strong>Tenant note:</strong> If you're renting in Westwood and your appliance is broken — you can call us directly. If the repair is the landlord's responsibility, we can prepare a diagnostic report and estimate that you can forward to your property manager. We deal with this situation regularly in 90024 and have a clean process for it."
];

const services = [
  { icon: '❄️', name: 'Refrigerator Repair', slug: 'refrigerator', issues: 'Not cooling · Ice maker · Fan motor · Built-in Sub-Zero · Apartment fridge', brands: 'Sub-Zero · Samsung · LG · GE · Whirlpool · Wolf' },
  { icon: '🫧', name: 'Washer Repair', slug: 'washer', issues: 'Stackable units · Not draining · Not spinning · Building hookups', brands: 'LG · Samsung · Bosch · Miele · Whirlpool · Maytag' },
  { icon: '💨', name: 'Dryer Repair', slug: 'dryer', issues: 'Not heating · Stackable · Ventless heat pump · Vent cleaning', brands: 'LG · Samsung · Miele · Bosch · GE · Maytag' },
  { icon: '🍽️', name: 'Dishwasher Repair', slug: 'dishwasher', issues: 'Not draining · Error codes · Panel-ready · Compact units', brands: 'Bosch · Miele · KitchenAid · Samsung · LG · GE' },
  { icon: '🔥', name: 'Oven, Range & Stove', slug: 'oven', issues: 'Not heating · Igniter · Temperature off · Gas & electric', brands: 'Wolf · Viking · Thermador · GE · Samsung · Bosch' },
  { icon: '🧊', name: 'Freezer & Ice Maker', slug: 'freezer', issues: 'Not freezing · Ice stopped · Temperature · Frost buildup', brands: 'Sub-Zero · GE · Samsung · LG · Whirlpool · True' },
  { icon: '🍷', name: 'Wine Cooler Repair', slug: 'wine-cooler', issues: 'Temperature off · Compressor · Under-counter · Built-in', brands: 'Sub-Zero · True · U-Line · Liebherr · Thermador' },
  { icon: '♨️', name: 'Cooktop & Range Hood', slug: 'cooktop', issues: 'Igniter · Induction not heating · Hood motor · Vent fan', brands: 'Wolf · Thermador · GE · Bosch · Samsung · Broan' }
];

const neighborhoods = [
  { name: 'Little Holmby', zip: '90024', featured: true },
  { name: 'Westwood Village', zip: '90024', featured: true },
  { name: 'North Westwood Village', zip: '90024', featured: true },
  { name: 'Wilshire Corridor', zip: '90024' },
  { name: 'UCLA campus adjacent', zip: '90024' },
  { name: 'South Westwood', zip: '90024' }
];

const recentJobs = [
  {
    appliance: 'Samsung Refrigerator',
    location: 'Gayley Ave apartment, 90024',
    quote: 'Fridge stopped cooling completely, everything is warm',
    description: "High-rise apartment building near campus — coordinated access with the building manager. Samsung French door: evaporator fan motor seized, leaving the fresh food section without airflow. Classic failure on this model. Replaced the fan motor with an OEM Samsung part, cleared the blocked defrost drain, ran a full defrost cycle. Back to 37°F before we left. The tenant had a grad school presentation the next morning — one less thing to worry about.",
    outcome: '✓ Same day · Building coordinated · OEM Samsung · Back to temp'
  },
  {
    appliance: 'Sub-Zero Refrigerator',
    location: 'Little Holmby, 90024',
    quote: 'Ice maker completely stopped — no ice for three weeks',
    description: "Little Holmby estate — the usual logistics: estate manager coordinated, access through the side entrance. Sub-Zero 48-inch: inlet valve scaled with mineral deposits from Westwood's hard water. LADWP water hardness plus the older supply lines in the house had left the valve almost completely blocked. Replaced with an OEM Sub-Zero inlet valve, flushed the water line, swapped the in-door filter. Ice production restored within 24 hours. Service report sent to the estate manager.",
    outcome: '✓ Same day · Estate coordinated · OEM Sub-Zero · Report delivered'
  },
  {
    appliance: 'LG Stackable Washer',
    location: 'Levering Ave condo, 90024',
    quote: 'OE error, standing water — call is a renter, landlord unresponsive',
    description: "Tenant called us directly after a week of no response from the landlord. LG stacked washer/dryer combo in a closet alcove — OE drain error from a blocked pump filter. Cleared the filter and blockage, ran test cycles, confirmed full drain. Prepared a written diagnostic report and estimate for the tenant to forward to the property management company. Drain working perfectly. Tenant had it in writing — situation resolved.",
    outcome: '✓ Same day · Renter situation handled · Written report for landlord'
  },
  {
    appliance: 'Wolf Range',
    location: 'Wilshire Corridor condo, 90024',
    quote: 'Oven running low, star burner sparking constantly',
    description: "High-rise condo on Wilshire — Wolf 36-inch dual-fuel in a custom kitchen. Oven igniter drawing weak current (Wolf-specific: igniter glows but can't draw enough amperage to reliably open the gas valve). Burner igniter electrode worn. Replaced both with OEM Wolf parts, calibrated oven temperature — was running 24°F low. Elevator coordination needed for the building; handled before arrival. Owner was a physician; appreciated the efficiency.",
    outcome: '✓ Same day · Building coordinated · OEM Wolf · Oven calibrated'
  }
];

const whyReasons = [
  {
    iconKey: 'team' as const,
    title: 'Apartments & Buildings Ready',
    body: "Compact kitchens, stackable laundry, building manager coordination, elevator scheduling — we work in dense buildings every day in Westwood. Tell us the situation when you call and we handle the access logistics."
  },
  {
    iconKey: 'parts' as const,
    title: 'Estate Service for Little Holmby',
    body: "Sub-Zero columns, Wolf ranges, Thermador appliances — we carry OEM parts for every luxury brand on every truck. Estate managers, household staff, side entrance access — all routine for our team."
  },
  {
    iconKey: 'clock' as const,
    title: 'Actually Same Day',
    body: "Call before noon and we can typically be at your door that afternoon. We give you a real arrival window — not a 6-hour block — and someone with our actual schedule answers the phone."
  },
  {
    iconKey: 'shield' as const,
    title: '90-Day Warranty, OEM Only',
    body: 'Every repair we do in Westwood carries a 90-day warranty on parts and labor. We use OEM parts on every job. Same issue returns within 90 days — we come back at no charge.'
  }
];

const testimonials = [
  {
    stars: 5,
    text: '"My fridge died the night before a big presentation. Called Same Day at 9am, tech was in my building on Gayley by 1pm, fan motor replaced, fridge back to temperature. They even coordinated with my building manager so I didn\'t have to. Exactly what I needed."',
    author: '— Alex C., Gayley Ave, Westwood'
  },
  {
    stars: 5,
    text: '"Sub-Zero in our Little Holmby home had no ice for three weeks. Estate manager arranged it, tech came through the side entrance, replaced the mineral-scaled inlet valve, left a full service report. Professional, efficient, zero friction. Our go-to from now on."',
    author: '— C. Morrison (Estate Manager), Little Holmby, Westwood'
  },
  {
    stars: 5,
    text: "\"I'm a renter and my landlord was unresponsive about the broken washer. Same Day came out, fixed the drain issue, AND gave me a written report I could send to the property manager. Problem solved within 24 hours. This is exactly how repair companies should operate.\"",
    author: '— Priya S., Levering Ave, Westwood'
  }
];

const pricingTiers = [
  { appliance: 'Refrigerator', range: '$150–$400', note: 'Built-in · Apartment · Sub-Zero column · OEM' },
  { appliance: 'Sub-Zero / Wolf', range: '$300–$700+', note: 'OEM parts · Estate & condo built-ins · Calibration', featured: true },
  { appliance: 'Washer / Dryer', range: '$150–$350', note: 'Stackable · Compact · OE/UE errors · Vent cleaning' },
  { appliance: 'Oven / Range', range: '$175–$450', note: 'Igniter · Element · Temperature · Gas & electric' },
  { appliance: 'Dishwasher', range: '$150–$320', note: 'Panel-ready · Compact · Drain · Error codes' },
  { appliance: 'Diagnostic Fee', range: '$89', note: 'Credited toward repair · Written estimate' }
];

const faqs = [
  {
    question: 'Do you offer same-day appliance repair across all of Westwood?',
    answer: "Yes — we cover the entire 90024 ZIP, from the UCLA-adjacent apartment corridor through Westwood Village, the Wilshire Corridor, Little Holmby, and South Westwood. Call before noon for same-day availability."
  },
  {
    question: 'Do you work in apartment buildings near UCLA?',
    answer: "Yes. We work with tenants, landlords, and building managers across the campus corridor on Gayley, Levering, Landfair, and surrounding streets. We coordinate building access, work in compact kitchens and shared laundry rooms, and provide written diagnostic reports when a tenant needs documentation for the landlord."
  },
  {
    question: 'Do you repair Sub-Zero, Wolf, and Thermador in Little Holmby?',
    answer: "Yes — Little Holmby and South Westwood have Sub-Zero columns, Wolf ranges, Thermador wall ovens, and Miele dishwashers as the standard luxury suite. We carry OEM parts for all of these brands on every vehicle and are experienced with the built-in and panel-ready configurations common in this part of 90024."
  },
  {
    question: 'Do you service stackable washer/dryer units and compact appliances?',
    answer: "Yes. Stackable LG, Samsung, Bosch, and Miele washer/dryer combinations are common in Westwood apartments and condos. We service all of them — drain errors, motor issues, stackable kit reassembly. Compact ranges and apartment-sized refrigerators are also standard for our team."
  },
  {
    question: 'What is your diagnostic fee in Westwood?',
    answer: "Our diagnostic fee is $89. It covers the trip, full inspection, and written estimate. If you proceed with the repair, the $89 is credited toward your invoice."
  },
  {
    question: 'Do you offer a warranty on Westwood appliance repairs?',
    answer: "All repairs include a 90-day warranty on parts and labor. If the same issue returns within 90 days, we come back at no charge."
  },
  {
    question: 'Do you also serve Beverly Hills, Bel Air, and Century City from Westwood?',
    answer: "Yes — our Westwood-area routes also cover Beverly Hills, Bel Air, Century City, Brentwood, and West LA. Tell us your address when you call and we'll confirm same-day availability for your part of the Westside."
  }
];

const nearbyCities = [
  { name: 'Beverly Hills', slug: 'beverly-hills' },
  { name: 'Bel Air', slug: 'bel-air' },
  { name: 'Brentwood', slug: 'brentwood' },
  { name: 'Los Angeles', slug: 'los-angeles' },
  { name: 'Santa Monica', slug: 'santa-monica' },
  { name: 'Culver City', slug: 'culver-city' },
  { name: 'West Hollywood', slug: 'west-hollywood' },
  { name: 'Marina Del Rey', slug: 'marina-del-rey' }
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair"
    headlineCity="Westwood, CA"
    subheadline="From compact apartment kitchens near UCLA to Sub-Zero estates in Little Holmby — all of Westwood 90024. Same-day service, OEM parts, 90-day warranty. Tenants, homeowners, building managers welcome."
    zips={zips}
    tier={1}
  />

  <TrustBadgesRow />

  <CustomNarrative
    headline={twoWorldsNarrative.headline}
    paragraphs={twoWorldsNarrative.paragraphs}
    subSections={twoWorldsNarrative.subSections}
    background="black"
  />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Same Day Appliance Repair in Westwood"
    paragraphs={introParagraphs}
    bookingTitle="Westwood Service"
    bookingSub="90024 · Apartments · Estates · Condos · Same day"
  />

  <ServicesGrid
    cityName={cityName}
    headline="What We Repair in Westwood"
    services={services}
  />

  <ServiceArea
    cityName={cityName}
    headline="Westwood Neighborhoods We Service"
    subheadline="From UCLA to the Wilshire Corridor — every part of 90024."
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={['Gayley Ave', 'Levering Ave', 'Landfair Ave', 'Wilshire Blvd', 'Sunset Blvd (south)', 'Westwood Blvd']}
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Repairs in Westwood"
    jobs={recentJobs}
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="Why Westwood Residents Call Us"
    reasons={whyReasons}
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What Westwood Clients Say"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Repair Pricing in Westwood"
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="Frequently Asked Questions — Westwood"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby Cities"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance broken in Westwood?"
    body="Campus corridor · Little Holmby · Wilshire Corridor · All of 90024. Apartments, estates, condos. $89 diagnostic waived with repair. 90-day warranty."
  />
</CityLayoutV2>
