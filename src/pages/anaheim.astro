  />

  <PricingCards
    cityName={cityName}
    headline="Repair Pricing in Anaheim"
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="Frequently Asked Questions — Anaheim"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby Cities"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Schedule Your Anaheim Repair Today"
    body="Same-day service across all of Anaheim. Call now or book online."
