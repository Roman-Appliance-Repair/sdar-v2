---
/**
 * Anaheim, CA — v2 migrated page (T11 pilot).
 * Branch: Irvine — service_area (no public street address).
 * Content source of truth: wiki/migration/content-dumps/anaheim.md
 *
 * Verbatim contract: every word, paragraph, FAQ, recent job, review,
 * neighborhood, and street from the T7 dump appears here. The unique
 * "Anaheim Hills vs. the Rest of the City" narrative is rendered through
 * <CustomNarrative>; commercial mentions are preserved in narrative.
 *
 * Pricing-discipline (narrow):
 *   - $120 commercial pricing card removed from PricingCards (only the
 *     $120 number is dropped; surrounding narrative stays intact)
 *   - FAQ Q3 about commercial: the "$120" sentence is replaced with a
 *     pricing-neutral line; the rest of Q3 stays verbatim
 *   - Custom narrative paragraph 4 about commercial: the "$120" sentence
 *     is replaced; the rest stays verbatim
 *   - Service card "Commercial Refrigerator" is preserved verbatim — it's
 *     a service category, not a $120 pricing claim
 *
 * Branch isolation:
 *   - Phone (213) 401-9019 from cities.ts → branches.ts (Irvine)
 *   - No streetAddress in schema (Irvine is service_area, not physical_pin)
 *   - All ZIPs are anaheim's (92801–92808 minus 92803)
 *   - Nearby cities are OC neighbors only
 *
 * Legacy preserved as anaheim.astro.legacy (the pre-v2 live design).
 */

import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import CustomNarrative from '../components/cities/v2/CustomNarrative.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

const citySlug = 'anaheim';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = 'Anaheim';
const zips = ['92801', '92802', '92804', '92805', '92806', '92807', '92808'];

const title = `Appliance Repair Anaheim CA | Same Day Service | ${branch.phone}`;
const description = 'Same-day appliance repair in Anaheim, CA. Anaheim Hills, Platinum Triangle, Downtown. Refrigerator, washer, dryer, oven. OEM parts, 90-day warranty. $89 diagnostic — waived with repair.';
const canonical = 'https://samedayappliance.repair/anaheim/';

const phoneRaw = `+1${branch.phone.replace(/\D/g, '')}`;

// LocalBusiness schema — service_area branch, no streetAddress.
const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  // streetAddress omitted: Irvine is service_area (NAP rule 2).
  areaServed: [
    { '@type': 'City', name: 'Anaheim', sameAs: 'https://en.wikipedia.org/wiki/Anaheim,_California' },
    { '@type': 'Place', name: 'Anaheim Hills' },
    { '@type': 'Place', name: 'Platinum Triangle' },
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$',
  license: 'CA BHGS #A49573'

};

// =====================================================================
// Section 3: INTRO — H2 "Appliance Repair in Anaheim — Two Very Different Cities in One"
// 3 paragraphs verbatim from dump, plus side booking card.
// =====================================================================
const introParagraphs = [
  "Anaheim is one of the more interesting cities we work in from an appliance standpoint. It's not a uniform market. Anaheim Hills to the east is a different world from West Anaheim or the Disneyland Resort corridor — the homes are larger, the appliances are higher-end, and the calls tend to be Sub-Zero, GE Monogram, and Wolf. The Platinum Triangle near Angel Stadium has a wave of newer construction condos where Samsung and LG are the norm. And then there's the commercial corridor near the resort, which generates its own category of calls entirely: ice machines, walk-in coolers, commercial refrigeration.",
  "Our technicians run Anaheim daily as part of our Orange County routes out of Irvine. We know the difference between a multi-family West Anaheim call and an Anaheim Hills estate, and we show up prepared for both. OEM parts for the mainstream brands and the luxury brands alike. We don't sub out anything — the technician who calls you back is the one who shows up.",
  `Diagnostic fee is $89 — goes away the moment you say yes to the repair. What we quote is what you pay. No fuel surcharges, no weekend premium, no separate charge for a second look if we need to diagnose something adjacent. Call <a href="tel:${phoneRaw}">${branch.phone}</a> and someone with our actual schedule picks up.`,
];

// =====================================================================
// Section 4: WHAT_WE_REPAIR — 8 services, 2-tier (icon + name only).
// 8th card "Commercial Refrigerator" preserved verbatim — service category, not pricing.
// =====================================================================
const services = [
  { icon: '❄️', name: 'Refrigerator Repair', slug: 'refrigerator' },
  { icon: '🫧', name: 'Washer Repair', slug: 'washer' },
  { icon: '💨', name: 'Dryer Repair', slug: 'dryer' },
  { icon: '🍽️', name: 'Dishwasher Repair', slug: 'dishwasher' },
  { icon: '🔥', name: 'Oven & Range Repair', slug: 'oven' },
  { icon: '♨️', name: 'Cooktop Repair', slug: 'cooktop' },
  { icon: '🧊', name: 'Freezer Repair', slug: 'freezer' },
  { icon: '🏪', name: 'Commercial Refrigerator', slug: 'commercial-refrigerator' },
];

// =====================================================================
// Section 5: CUSTOM_NARRATIVE — "Anaheim Hills vs. the Rest of the City — Why It Matters"
// 4 paragraphs verbatim. Paragraph 4 has the "$120" commercial-pricing
// sentence replaced (only sentence with the dollar figure); rest verbatim.
// =====================================================================
const anaheimHillsNarrative = {
  headline: 'Anaheim Hills vs. the Rest of the City — Why It Matters',
  paragraphs: [
    "Most appliance repair companies treat Anaheim as one market. It isn't. When we get a call from Anaheim Hills, our technicians load differently than when heading to West Anaheim or the Platinum Triangle. The difference isn't attitude — it's parts inventory.",
    "Anaheim Hills homes in the 92807 and 92808 zip codes tend to have kitchen suites that rival Newport Beach — Sub-Zero built-in refrigerators, GE Monogram column units, Wolf ranges, Thermador steam ovens. These are not off-the-shelf fixes. You need the right diagnostic tools, the right OEM part, and a technician who has actually worked on that model before. We stock parts for Sub-Zero, GE Monogram, Wolf, and Thermador on our OC trucks specifically because Anaheim Hills generates that volume of calls.",
    "The Platinum Triangle — the area around Angel Stadium and the Anaheim Convention Center — is a newer construction zone with mostly Samsung and LG appliances in the high-rise and mid-rise condos. These calls are different: flex drawer control boards, linear compressor issues on LG refrigerators, Samsung ice maker wire harness failures. We know these failure patterns well.",
    `And the resort area generates its own separate category: commercial ice machines, walk-in coolers for restaurants, commercial refrigerators. If you're running a food service operation near Disneyland and a unit goes down, call our commercial line at <a href="tel:${phoneRaw}">${branch.phone}</a>. We move quickly on food safety calls.`,
  ]
};

// =====================================================================
// Section 6: NEIGHBORHOODS — H2 "Anaheim Neighborhoods We Service"
// 12 entries verbatim, plus dump's intro line.
// =====================================================================
const neighborhoods = [
