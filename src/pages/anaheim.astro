// =====================================================================
const testimonials = [
  {
    stars: 5,
    text: '"Samsung refrigerator in our Platinum Triangle condo — ice maker completely dead. They came same day, had the part on the truck, done in two hours. I had called two other companies first and neither had the part."',
    author: '— Marcus T., Platinum Triangle'
  },
  {
    stars: 5,
    text: "\"Our GE Monogram fridge in Anaheim Hills wasn't cooling. Another company told us the compressor needed replacing — $1,200 quote. Same Day came out, said it was the thermistor, fixed it for $280 including parts. That's the difference between someone who actually knows the appliance and someone guessing.\"",
    author: '— Christine R., Anaheim Hills'
  },
  {
    stars: 5,
    text: "\"We run a restaurant near the resort. Ice machine was putting out bad-smelling ice. They came out the same morning I called, did a full sanitization and replaced the filter and distribution tube. Followed up two days later to check. That's the level of service a food business needs.\"",
    author: '— David L., Resort District'
  },
];

// =====================================================================
// Section 10: PRICING — H2 "Repair Pricing in Anaheim"
// Original dump had 4 cards including "Commercial Diagnostic $120". Per
