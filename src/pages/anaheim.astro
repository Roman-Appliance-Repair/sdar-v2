// 3 residential cards verbatim.
// =====================================================================
const pricingTiers = [
  { appliance: 'Diagnostic Fee', range: '$89', note: 'Home appliances · Credited toward repair · Written estimate' },
  { appliance: 'Standard Repair', range: '$150–$350', note: 'Parts + labor · OEM parts only · 90-day warranty' },
  { appliance: 'Warranty', range: '90 Days', note: 'All repairs · Parts & labor · No-charge callback if same issue returns', featured: true },
];

// =====================================================================
