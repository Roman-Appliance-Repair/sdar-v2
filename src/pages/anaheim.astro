  },
];

// =====================================================================
// Section 8: METHOD/WHY_US — H2 "Why Anaheim Residents Call Us" — 4 reasons verbatim.
// =====================================================================
const whyReasons = [
  {
    iconKey: 'parts' as const,
    title: "We don't guess",
    body: 'A compressor running constantly doesn\'t mean the compressor is bad — in a GE Monogram, it often means the thermistor failed and the board is misreading temperature. We diagnose correctly the first time, which is how we can offer a 90-day warranty without losing money on callbacks.'
  },
  {
    iconKey: 'shield' as const,
    title: 'OEM parts, not aftermarket',
    body: "We use manufacturer-original parts on every repair. On a Samsung flex drawer or an LG linear compressor, aftermarket parts are a shortcut that creates the next service call. We don't do that."
  },
  {
    iconKey: 'team' as const,
    title: 'Commercial calls treated seriously',
    body: "A restaurant ice machine near the resort that's producing contaminated ice isn't an inconvenience — it's a health code issue. We treat commercial food equipment calls with the urgency they deserve and follow manufacturer sanitation protocols completely."
  },
  {
    iconKey: 'clock' as const,
    title: 'Real phone answer',
    body: 'When you call our Anaheim line, someone who knows our OC schedule answers. You get a real arrival window — not a 6-hour block. We pick up the phone.'
  },
