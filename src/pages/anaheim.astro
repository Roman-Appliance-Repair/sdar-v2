// Section 13: FINAL_CTA verbatim.
// =====================================================================
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair in"
    headlineCity="Anaheim, CA"
    subheadline="Same-day service across all of Anaheim — from Anaheim Hills to the Platinum Triangle. OEM parts, 90-day warranty, $89 diagnostic waived with repair."
    zips={zips}
    tier={3}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance Repair in Anaheim — Two Very Different Cities in One"
    paragraphs={introParagraphs}
    bookingTitle="Anaheim Service"
    bookingSub="Available Today"
  />

  <ServicesGrid
    cityName={cityName}
    headline="Appliance Repair Services in Anaheim"
    services={services}
  />

  <CustomNarrative
    headline={anaheimHillsNarrative.headline}
    paragraphs={anaheimHillsNarrative.paragraphs}
    background="white"
  />

  <ServiceArea
    cityName={cityName}
    headline="Anaheim Neighborhoods We Service"
    subheadline={neighborhoodsSubhead}
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={[]}
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Repairs in Anaheim"
    jobs={recentJobs}
  />

  <WhyCallsUsBack
