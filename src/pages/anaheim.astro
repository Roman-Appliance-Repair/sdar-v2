// =====================================================================
// Section 12: NEARBY_LINKS — 6 OC neighbors. Replaced /orange/ (broken,
// no .astro page) with /tustin/ per audit catalog of broken nearby links.
// =====================================================================
const nearbyCities = [
  { name: 'Irvine', slug: 'irvine' },
  { name: 'Huntington Beach', slug: 'huntington-beach' },
  { name: 'Fullerton', slug: 'fullerton' },
  { name: 'Yorba Linda', slug: 'yorba-linda' },
  { name: 'Tustin', slug: 'tustin' },
  { name: 'Costa Mesa', slug: 'costa-mesa' },
