// except Q3 commercial answer where "$120" sentence is replaced (only that
// sentence — surrounding text verbatim).
// =====================================================================
const faqs = [
  {
    question: 'Do you offer same-day appliance repair in Anaheim?',
    answer: 'Yes — we cover all of Anaheim including Anaheim Hills, the Platinum Triangle, West Anaheim, and the resort district. Call before noon and we can typically be at your door that afternoon. Our OC technicians run routes throughout the city daily.'
  },
  {
    question: 'What is your diagnostic fee in Anaheim?',
