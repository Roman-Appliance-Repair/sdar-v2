      <div class="hero-ctas">
        <a href="tel:+14243250520" class="btn-red">☎ (424) 325-0520</a>
        <a href="/contact/" class="btn-outline">Request Service</a>
      </div>
      <div class="hero-rating">BHGS #A49573 · BBB A+ Accredited · 90-Day Warranty</div>
    </div>
    <div class="hero-badge-grid">
      <div class="hero-badge">
        <div class="hero-badge-icon">🔑</div>
        <h4>Key Fob & Lockbox Access</h4>
        <p>Vacant units, tenant not home — we handle access the way your building requires it</p>
      </div>
      <div class="hero-badge">
        <div class="hero-badge-icon">📋</div>
        <h4>COI Available</h4>
