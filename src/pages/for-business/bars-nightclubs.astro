      <div class="hero-ctas">
        <a href="tel:+14243250520" class="btn-red">☎ (424) 325-0520</a>
        <a href="/contact/" class="btn-outline">Request Service</a>
      </div>
      <div class="hero-rating">BHGS #A49573 · BBB Accredited Business · 90-Day Warranty</div>
    </div>
    <div class="hero-badge-grid">
      <div class="hero-badge">
        <div class="hero-badge-icon">🧊</div>
        <h4>Ice Machine Priority</h4>
        <p>No ice on a Friday night is a revenue event. We carry Manitowoc, Hoshizaki, and Scotsman parts on the truck</p>
      </div>
      <div class="hero-badge">
        <div class="hero-badge-icon">🍺</div>
