---
// Appliance Repair for Restaurants & Cafes Los Angeles | Same Day Appliance Repair
// /for-business/restaurants/
import Layout from '../../layouts/Layout.astro';

const title = "Restaurant Appliance Repair Los Angeles | Same Day Commercial Service";
const description = "Commercial kitchen appliance repair for LA restaurants & cafes. Walk-in coolers, ranges, fryers, ice machines. $120 diagnostic, same day. COI available. (424) 325-0520.";
---

<Layout title={title} description={description}>
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "HomeAndConstructionBusiness",
    "name": "Same Day Appliance Repair — Restaurant & Cafe Service Los Angeles",
    "telephone": "(424) 325-0520",
    "url": "https://samedayappliance.repair/for-business/restaurants/",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "6230 Wilshire Blvd Ste A PMB 2267",
      "addressLocality": "Los Angeles",
      "addressRegion": "CA",
      "postalCode": "90048",
      "addressCountry": "US"
    },
    "areaServed": { "@type": "City", "name": "Los Angeles" },
    "openingHoursSpecification": [
      { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "07:00", "closes": "21:00" },
      { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "08:00", "closes": "19:00" },
      { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "09:00", "closes": "17:00" }
    ],
    "priceRange": "$$",
    "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.6", "reviewCount": "37", "bestRating": "5" }
  }
  </script>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How fast can you respond to a commercial kitchen equipment failure in Los Angeles?",
