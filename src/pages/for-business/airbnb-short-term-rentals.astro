    .cta-box p { font-size: 14px; color: rgba(255,255,255,.6); margin-bottom: 20px; }
    .cta-phone { display: block; background: var(--red); color: #fff; text-align: center; padding: 14px; border-radius: 6px; font-size: 16px; font-weight: 700; margin-bottom: 10px; }
