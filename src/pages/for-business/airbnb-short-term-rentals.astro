    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', -apple-system, sans-serif; color: var(--text); line-height: 1.6; }
    a { color: inherit; text-decoration: none; }
    .hero { background: var(--black); color: #fff; padding: 80px 24px 72px; }
    .hero-inner { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: center; }
    .hero-eyebrow { font-size: 13px; font-weight: 600; letter-spacing: .12em; text-transform: uppercase; color: var(--red); margin-bottom: 14px; }
    .hero-sub { font-size: 17px; color: rgba(255,255,255,.72); margin-bottom: 32px; line-height: 1.65; }
    .hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; }
