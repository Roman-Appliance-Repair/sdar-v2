    .ti { display: flex; align-items: center; gap: 8px; font-size: 13px; font-weight: 500; color: #fff; }
    .section { padding: 72px 24px; }
    .section-gray { background: var(--gray); }
    .section-black { background: var(--black); color: #fff; }
    .container { max-width: 1100px; margin: 0 auto; }
    .sl { font-size: 12px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--red); margin-bottom: 12px; }
    h2 { font-size: clamp(24px, 3.2vw, 34px); font-weight: 700; line-height: 1.2; letter-spacing: -.02em; margin-bottom: 18px; }
    .section-black h2 { color: #fff; }
    .lead { font-size: 17px; line-height: 1.7; color: var(--muted); max-width: 680px; margin-bottom: 40px; }
    .section-black .lead { color: rgba(255,255,255,.62); }
    .two-col { display: grid; grid-template-columns: 1fr 360px; gap: 48px; align-items: start; }
    .body-text p { font-size: 16px; line-height: 1.75; color: var(--text); margin-bottom: 16px; }
    .cta-box { background: var(--black); color: #fff; border-radius: 12px; padding: 28px 24px; position: sticky; top: 24px; }
