---
// Appliance Repair for Retail & Grocery Los Angeles | Same Day Appliance Repair
// /for-business/retail-grocery/
import Layout from '../../layouts/Layout.astro';

const title = "Grocery & Retail Appliance Repair LA — Same Day";
const description = "Commercial refrigeration repair for LA grocery stores & retail — showcase fridges, walk-in coolers, reach-in units. LADPH compliance. COI. (424) 325-0520.";
const schemaJsons = [
  `{
    "@context": "https://schema.org",
    "@type": "HomeAndConstructionBusiness",
    "name": "Same Day Appliance Repair — Retail & Grocery Service Los Angeles",
    "telephone": "(424) 325-0520",
    "url": "https://samedayappliance.repair/for-business/retail-grocery/",
    
    "areaServed": { "@type": "City", "name": "Los Angeles" },
    "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "08:00", "closes": "20:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "00:00", "closes": "00:00" }
      ],
    "priceRange": "$"

  }`,
  `{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How quickly can you respond to a grocery store refrigeration failure in Los Angeles?",
        "acceptedAnswer": { "@type": "Answer", "text": "Same day in most cases. A refrigeration failure in a grocery store with product at risk is a priority dispatch — we treat it the same as a restaurant walk-in failure. Call (424) 325-0520, describe the equipment and the situation, and we give you a straight window." }
      },
      {
        "@type": "Question",
        "name": "What commercial refrigeration brands do you repair for grocery stores in LA?",
        "acceptedAnswer": { "@type": "Answer", "text": "Hussmann, Tyler, Hill Phoenix, True, Turbo Air, Beverage-Air, and Hoshizaki — the brands most common in LA grocery and retail environments. Multideck open cases, glass door reach-in merchandisers, under-counter wine coolers, and floral display coolers." }
      },
      {
        "@type": "Question",
        "name": "Do you service showcase refrigerators and open merchandising cases?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. Open multideck cases, glass door merchandisers, and showcase refrigerators — temperature failures, fan motor issues, door gasket wear, defrost system failures. These are the units that hold product visible to customers and failing product temperature is a LADPH issue." }
      },
      {
        "@type": "Question",
        "name": "Do you provide COI for retail building owners in Los Angeles?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. Full general liability insurance, named to your building owner or management company as additional insured. Ready before we arrive." }
      },
      {
        "@type": "Question",
        "name": "What is the commercial diagnostic fee for grocery and retail equipment?",
        "acceptedAnswer": { "@type": "Answer", "text": "The commercial diagnostic fee is $120 — applied to the repair the moment you approve the work. We quote before starting. The quote is the invoice." }
      },
      {
        "@type": "Question",
        "name": "Do you repair wine coolers and specialty beverage coolers in retail stores?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. Wine display cases, beverage coolers, craft beer display refrigerators — common in LA specialty grocery and wine retail. All brands serviced." }
      },
      {
        "@type": "Question",
        "name": "Can you service multiple retail locations in Los Angeles?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. We work with multi-location operators and retail chains across LA County. Call (424) 325-0520 to set up a priority service account with dispatch priority and service documentation for your locations." }
      }
    ]
  }`
];
---

<Layout title={title} description={description}>
  <Fragment slot="head-scripts">
    {schemaJsons.map((s) => (
      <script type="application/ld+json" set:html={s}></script>
    ))}
  </Fragment>

<style>
    :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', -apple-system, sans-serif; color: var(--text); line-height: 1.6; }
    a { color: inherit; text-decoration: none; }
    .hero { background: var(--black); color: #fff; padding: 80px 24px 72px; }
    .hero-inner { max-width: 1100px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: center; }
    .hero-eyebrow { font-size: 13px; font-weight: 600; letter-spacing: .12em; text-transform: uppercase; color: var(--red); margin-bottom: 14px; }
    .hero-sub { font-size: 17px; color: rgba(255,255,255,.72); margin-bottom: 32px; line-height: 1.65; }
    .hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; }
    .btn-red { background: var(--red); color: #fff; padding: 14px 28px; border-radius: 6px; font-size: 15px; font-weight: 600; }
    .btn-outline { border: 1.5px solid rgba(255,255,255,.3); color: #fff; padding: 14px 28px; border-radius: 6px; font-size: 15px; }
    .hero-rating { margin-top: 26px; font-size: 13px; color: rgba(255,255,255,.5); }
    .stars { color: #f59e0b; }
    .hero-badge-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
    .hero-badge { background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1); border-radius: 10px; padding: 16px; }
    .hero-badge-icon { font-size: 22px; margin-bottom: 8px; }
    .hero-badge h4 { font-size: 13px; font-weight: 700; color: #fff; margin-bottom: 4px; }
    .hero-badge p { font-size: 12px; color: rgba(255,255,255,.5); line-height: 1.5; }
    .trust-bar { background: var(--red); padding: 14px 24px; }
    .trust-bar-inner { max-width: 1100px; margin: 0 auto; display: flex; gap: 20px; flex-wrap: wrap; justify-content: center; }
    .ti { display: flex; align-items: center; gap: 8px; font-size: 13px; font-weight: 500; color: #fff; }
    .section { padding: 72px 24px; }
    .section-gray { background: var(--gray); }
    .section-black { background: var(--black); color: #fff; }
    .container { max-width: 1100px; margin: 0 auto; }
    .sl { font-size: 12px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--red); margin-bottom: 12px; }
    h2 { font-size: clamp(24px, 3.2vw, 34px); font-weight: 700; line-height: 1.2; letter-spacing: -.02em; margin-bottom: 18px; }
    .section-black h2 { color: #fff; }
    .lead { font-size: 17px; line-height: 1.7; color: var(--muted); max-width: 680px; margin-bottom: 40px; }
    .section-black .lead { color: rgba(255,255,255,.62); }
    .two-col { display: grid; grid-template-columns: 1fr 360px; gap: 48px; align-items: start; }
    .body-text p { font-size: 16px; line-height: 1.75; color: var(--text); margin-bottom: 16px; }
    .cta-box { background: var(--black); color: #fff; border-radius: 12px; padding: 28px 24px; position: sticky; top: 24px; }
    .cta-box h3 { font-size: 18px; font-weight: 700; margin-bottom: 8px; }
    .cta-box p { font-size: 14px; color: rgba(255,255,255,.6); margin-bottom: 20px; }
    .cta-phone { display: block; background: var(--red); color: #fff; text-align: center; padding: 14px; border-radius: 6px; font-size: 16px; font-weight: 700; margin-bottom: 10px; }
    .cta-book { display: block; border: 1px solid rgba(255,255,255,.2); color: #fff; text-align: center; padding: 12px; border-radius: 6px; font-size: 14px; }
    .cta-note { font-size: 11px; color: rgba(255,255,255,.35); text-align: center; margin-top: 10px; }
    .price-mini { margin-top: 18px; border-top: 1px solid rgba(255,255,255,.1); padding-top: 14px; }
    .pm-row { display: flex; justify-content: space-between; font-size: 13px; padding: 5px 0; border-bottom: 1px solid rgba(255,255,255,.07); }
    .pm-row:last-child { border-bottom: none; }
    .pm-label { color: rgba(255,255,255,.5); }
    .pm-val { font-weight: 600; }
    .equip-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 18px; margin-top: 36px; }
    .equip-card { background: #fff; border: 1px solid var(--border); border-radius: 10px; padding: 22px; }
    .equip-icon { font-size: 26px; margin-bottom: 10px; }
    .equip-card h3 { font-size: 15px; font-weight: 700; margin-bottom: 6px; }
    .equip-card p { font-size: 13px; line-height: 1.6; color: var(--muted); }
    .equip-brands { font-size: 12px; color: var(--red); font-weight: 600; margin-top: 8px; }
    .context-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: center; }
    .context-text p { font-size: 16px; line-height: 1.75; color: rgba(255,255,255,.72); margin-bottom: 14px; }
    .facts { display: flex; flex-direction: column; gap: 14px; }
    .fact { background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1); border-radius: 10px; padding: 18px; }
    .fact h4 { font-size: 14px; font-weight: 700; color: #fff; margin-bottom: 5px; }
    .fact p { font-size: 13px; color: rgba(255,255,255,.55); line-height: 1.55; }
    .jobs-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 18px; margin-top: 36px; }
    .job-card { background: #fff; border: 1px solid var(--border); border-radius: 10px; padding: 22px; }
    .job-tag { display: inline-block; background: var(--gray); font-size: 11px; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; color: var(--muted); padding: 3px 8px; border-radius: 4px; margin-bottom: 10px; }
    .job-card h3 { font-size: 15px; font-weight: 700; margin-bottom: 8px; line-height: 1.3; }
    .job-card p { font-size: 14px; line-height: 1.6; color: var(--muted); }
    .why-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 18px; margin-top: 36px; }
    .why-card { border: 1px solid var(--border); border-radius: 10px; padding: 22px; }
    .why-icon { font-size: 24px; margin-bottom: 10px; }
    .why-card h3 { font-size: 15px; font-weight: 700; margin-bottom: 7px; }
    .why-card p { font-size: 14px; line-height: 1.6; color: var(--muted); }
    .pricing-table { width: 100%; border-collapse: collapse; margin-top: 28px; font-size: 15px; }
    .pricing-table th { text-align: left; padding: 12px 16px; background: var(--black); color: #fff; font-size: 13px; font-weight: 600; }
    .pricing-table td { padding: 13px 16px; border-bottom: 1px solid var(--border); }
    .pricing-table tr:last-child td { border-bottom: none; }
    .pricing-table tr:nth-child(even) td { background: #fafafa; }
    .price-val { font-weight: 700; color: var(--red); }
    .pricing-note { font-size: 13px; color: var(--muted); margin-top: 14px; padding: 13px 16px; background: var(--gray); border-radius: 6px; border-left: 3px solid var(--red); }
    .faq-list { margin-top: 36px; }
    .faq-item { border-bottom: 1px solid var(--border); padding: 18px 0; }
    .faq-item:first-child { border-top: 1px solid var(--border); }
    .faq-q { font-size: 16px; font-weight: 700; margin-bottom: 8px; }
    .faq-a { font-size: 15px; line-height: 1.7; color: var(--muted); }
    .nearby-grid { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 26px; }
    .nb { background: var(--gray); border: 1px solid var(--border); border-radius: 6px; padding: 8px 14px; font-size: 14px; }
    .bottom-cta { background: var(--black); color: #fff; padding: 72px 24px; text-align: center; }
    .bottom-cta h2 { color: #fff; margin-bottom: 14px; }
    .bottom-cta p { font-size: 17px; color: rgba(255,255,255,.62); margin-bottom: 30px; max-width: 500px; margin-left: auto; margin-right: auto; }
    .bottom-ctas { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
    @media (max-width: 768px) {
      .hero-inner, .two-col, .context-grid { grid-template-columns: 1fr; }
      .hero-badge-grid { grid-template-columns: 1fr 1fr; }
    }
  </style>

