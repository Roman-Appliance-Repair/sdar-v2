      <div class="hero-ctas">
        <a href="tel:+14243250520" class="btn-red">☎ (424) 325-0520</a>
        <a href="/contact/" class="btn-outline">Request Service</a>
      </div>
      <div class="hero-rating">BHGS #A49573 · BBB Accredited Business · 90-Day Warranty</div>
    </div>
    <div class="hero-badge-grid">
      <div class="hero-badge">
        <div class="hero-badge-icon">🌡️</div>
        <h4>41°F Priority</h4>
        <p>Product temperature failures get priority dispatch — LADPH compliance has a clock on it</p>
      </div>
      <div class="hero-badge">
        <div class="hero-badge-icon">❄️</div>
        <h4>Showcase & Reach-In Specialists</h4>
        <p>Hussmann, True, Turbo Air, Beverage-Air — the brands that run LA grocery and retail floors</p>
      </div>
      <div class="hero-badge">
        <div class="hero-badge-icon">📋</div>
        <h4>COI Available</h4>
        <p>Named to your building owner — ready before we arrive</p>
      </div>
      <div class="hero-badge">
        <div class="hero-badge-icon">📄</div>
