---
import Layout from '../layouts/Layout.astro';

const title = "Outdoor Kitchen Repair Malibu | Grill · Refrigerator · Ice Maker · Sink";
const description = "Malibu outdoor kitchen repair — full outdoor kitchen suite service, coastal-aware. Wolf, Viking, Sub-Zero, Lynx, Hestan, U-Line. (424) 325-0520.";
const canonical = "https://samedayappliance.repair/outdoor-kitchen-repair-malibu/";

const faqs = [
  {
    "q": "Can you service the entire Malibu outdoor kitchen on one visit?",
    "a": "Yes — grill, fridge, ice maker, side burner, sink in a single dispatch. Common request because of Malibu drive time."
  },
  {
    "q": "How does coastal salt air affect outdoor kitchen lifespan?",
    "a": "Stainless 304 lasts 10–15 years coastal vs 20+ inland. Compressor seals 7–9 years vs 12+ inland. Annual cleaning + protective covers extend life significantly."
  },
  {
    "q": "Reach time LA to Malibu?",
    "a": "40–60 min depending on PCH. We schedule Malibu morning slots and stack multiple Malibu calls per day."
  }
];

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": "https://samedayappliance.repair/outdoor-kitchen-repair-malibu/#business",
    "name": "Same Day Appliance Repair",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": "https://samedayappliance.repair/outdoor-kitchen-repair-malibu/",
    "telephone": "+1-424-325-0520",
    "priceRange": "$$$",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "6230 Wilshire Blvd Ste A PMB 2267",
      "addressLocality": "Los Angeles",
      "addressRegion": "CA",
      "postalCode": "90048",
      "addressCountry": "US"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 34.0619,
      "longitude": -118.3692
    },
    "areaServed": [
      {
        "@type": "AdministrativeArea",
        "name": "Los Angeles County"
      },
      {
        "@type": "AdministrativeArea",
        "name": "Orange County"
      },
      {
        "@type": "AdministrativeArea",
        "name": "Ventura County"
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Outdoor Kitchen Repair",
    "provider": {
      "@id": "https://samedayappliance.repair/outdoor-kitchen-repair-malibu/#business"
    },
    "areaServed": [
      {
        "@type": "AdministrativeArea",
        "name": "Los Angeles County"
      },
      {
        "@type": "AdministrativeArea",
        "name": "Orange County"
      },
      {
        "@type": "AdministrativeArea",
        "name": "Ventura County"
      }
    ],
    "description": "Malibu outdoor kitchen repair — full outdoor kitchen suite service, coastal-aware. Wolf, Viking, Sub-Zero, Lynx, Hestan, U-Line. (424) 325-0520.",
    "offers": {
      "@type": "Offer",
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "89.00",
        "priceCurrency": "USD",
        "description": "Residential diagnostic fee, waived with repair"
      }
    }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://samedayappliance.repair/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Malibu",
      "item": "https://samedayappliance.repair/outdoor-kitchen-repair-malibu/"
    }
  ] }
];
---
<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">
    {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
  </Fragment>

  <section class="ph-hero">
    <div class="ph-wrap">
      <p class="ph-eyebrow">Placeholder · Content Coming Soon</p>
      <h1>Outdoor Kitchen Repair in Malibu</h1>
      <p class="ph-intro">Malibu outdoor kitchens are full-suite installs — grill (Wolf, Viking, Lynx, Hestan), outdoor refrigerator (Sub-Zero UC-RO, Viking VBUR, U-Line outdoor), outdoor ice maker, side burner, and sometimes a pizza oven. The unifying challenge is coastal salt air. We service the full suite on a single dispatch. LA branch (424) 325-0520.</p>
      <div class="ph-ctas">
        <a href="tel:+14243250520" class="ph-btn">Call (424) 325-0520</a>
        <a href="/contact/" class="ph-btn ph-btn-ghost">Contact Us</a>
      </div>
    </div>
  </section>

  <section class="ph-faq">
    <div class="ph-wrap">
      <h2>Frequently Asked</h2>
      {faqs.map(f => (<details class="ph-detail"><summary>{f.q}</summary><p>{f.a}</p></details>))}
    </div>
  </section>
</Layout>

<style>
  .ph-wrap { max-width: 820px; margin: 0 auto; padding: 0 24px; }
  .ph-hero { background: #0a0a0a; color: #fff; padding: 64px 0; }
  .ph-eyebrow { color: #C8102E; font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; margin: 0 0 14px; }
  .ph-hero h1 { font-size: clamp(1.6rem, 3.2vw, 2.4rem); font-weight: 800; margin: 0 0 16px; line-height: 1.2; }
  .ph-intro { color: rgba(255,255,255,0.85); font-size: 1.05rem; margin: 0 0 28px; line-height: 1.65; }
  .ph-ctas { display: flex; gap: 12px; flex-wrap: wrap; }
  .ph-btn { display: inline-block; background: #C8102E; color: #fff; padding: 12px 24px; text-decoration: none; font-weight: 700; border-radius: 4px; font-size: 0.95rem; }
  .ph-btn-ghost { background: transparent; border: 1px solid rgba(255,255,255,0.4); }
  .ph-faq { padding: 56px 0; background: #f5f5f5; }
  .ph-faq h2 { font-size: 1.5rem; margin: 0 0 20px; color: #0a0a0a; }
  .ph-detail { background: #fff; border: 1px solid #e2e2e2; padding: 14px 18px; border-radius: 4px; margin-bottom: 8px; }
  .ph-detail summary { font-weight: 600; cursor: pointer; color: #0a0a0a; }
  .ph-detail p { margin: 10px 0 0; color: #444; line-height: 1.6; }
</style>
