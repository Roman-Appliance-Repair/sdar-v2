---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

const citySlug = 'san-gabriel';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = 'San Gabriel';
const zips = ['91775', '91776'];

const phoneRaw = `+1${branch.phone.replace(/\D/g, '')}`;

const title = `Appliance Repair San Gabriel CA — Same Day | 91775 · Mission Dr · Las Tunas | ${branch.phone}`;
const description = `Same-day appliance repair in San Gabriel, CA 91775 & 91776. Samsung, LG, GE, Whirlpool, Sub-Zero. Licensed, OEM parts Weekends available.`;
const canonical = 'https://samedayappliance.repair/san-gabriel/';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { '@type': 'City', name: 'San Gabriel', sameAs: 'https://en.wikipedia.org/wiki/San_Gabriel,_California' },
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$',
  license: 'CA BHGS #A49573'

};

const introParagraphs = [
  "San Gabriel is one of the oldest cities in Los Angeles County — home to Mission San Gabriel Arcángel, founded in 1771, and the historic street grid that radiates from it. The residential neighborhoods along Mission Drive, Del Mar Avenue, and the streets around the civic center range from early 20th century bungalows to post-war ranch homes to newer construction, and the appliances inside them are as varied as the housing stock.",
  "Hard water is a consistent issue throughout San Gabriel. Served by the San Gabriel Valley Municipal Water District — the same mineral-rich SGV groundwater supply as Arcadia, San Marino, and Temple City — ice maker inlet valves and dishwasher spray arms accumulate scale significantly faster than national average. We check for this proactively on every San Gabriel call involving ice makers and dishwashers. It comes up consistently.",
  "San Gabriel is also a busy family community — the Valley Boulevard and Las Tunas Drive corridors are active, the restaurants and businesses bring foot traffic, and the residential streets behind them are full of families who need appliances working when they need them. Same-day service, weekends included, written estimate before we start.",
  "Diagnostic fee: <strong>$89</strong> — waived with repair. <strong>90-day warranty</strong> on all parts and labor. OEM parts only.",
  "<strong>Hard water tip for San Gabriel:</strong> SGVMWD groundwater is mineral-rich throughout the SGV. If your refrigerator ice maker has been gradually producing less ice over several months — not a sudden stop, but a slow decline — mineral scale on the water inlet valve is almost certainly the cause in 91775 and 91776. Replacing your refrigerator's in-door filter every 6 months (not 12) helps significantly with this water supply.",
];

const services = [
  { icon: '🧊', name: 'Refrigerator Repair', slug: 'refrigerator', issues: 'Hard water ice maker · Not cooling · Fan motor · Temperature off', brands: 'Samsung · LG · GE · Whirlpool · Sub-Zero · Bosch' },
  { icon: '🍽️', name: 'Dishwasher Repair', slug: 'dishwasher', issues: 'Hard water spray arm scale · Not draining · Spots on glasses · Error codes', brands: 'Bosch · KitchenAid · Samsung · LG · GE · Miele' },
  { icon: '🫧', name: 'Washer Repair', slug: 'washer', issues: 'Hard water inlet screens · Not draining · Not spinning · Error codes', brands: 'LG · Samsung · Whirlpool · Maytag · Bosch · Speed Queen' },
  { icon: '♨️', name: 'Dryer Repair + Vent Cleaning', slug: 'dryer', issues: 'Not heating · Thermal fuse · Vent lint buildup · Gas & electric', brands: 'LG · Samsung · GE · Maytag · Whirlpool · Electrolux' },
  { icon: '🔥', name: 'Oven, Range & Stove', slug: 'oven', issues: 'Not heating · Gas igniter · Temperature off · Gas & electric', brands: 'GE · Samsung · Bosch · Wolf · Viking · KitchenAid' },
  { icon: '❄️', name: 'Freezer & Ice Maker Repair', slug: 'freezer', issues: 'Hard water inlet valve · Not freezing · Ice stopped · Frost', brands: 'Samsung · LG · GE · Whirlpool · Sub-Zero · Frigidaire' },
  { icon: '🍷', name: 'Wine Cooler Repair', slug: 'wine-cooler', issues: 'Temperature off · Compressor · Under-counter · Built-in', brands: 'True · U-Line · Liebherr · Dacor · Sub-Zero' },
  { icon: '🔆', name: 'Cooktop & Range Hood', slug: 'cooktop', issues: 'Igniter · Gas burner · Induction not heating · Hood motor', brands: 'GE · Bosch · Samsung · Wolf · Thermador · Broan' },
];

const neighborhoods = [
  { name: 'Mission Drive corridor', zip: '91775', featured: true },
  { name: 'Las Tunas Drive area', zip: '91775', featured: true },
  { name: 'Del Mar Ave neighborhood', zip: '91776', featured: true },
  { name: 'Valley Blvd corridor', zip: '91776' },
  { name: 'Ramona Street area', zip: '91776' },
  { name: 'North San Gabriel', zip: '91775' },
  { name: 'South San Gabriel', zip: '91776' },
];

const keyStreets = ['Mission Drive', 'Las Tunas Drive', 'Valley Blvd', 'Del Mar Ave', 'Ramona St', 'San Gabriel Blvd'];

const recentJobs = [
  {
    appliance: 'LG French Door',
    location: 'Mission Drive corridor, 91775',
    quote: 'Ice maker dropped from full to almost nothing over 3 months',
    description: "LG French door refrigerator — the gradual decline is the consistent SGVMWD hard water pattern throughout the SGV. Inlet valve orifice restricted by calcium scale to about 20% capacity. Replaced with an OEM LG inlet valve, flushed the water line, replaced the in-door filter (14 months old — should have been changed at 6). Full ice production within 24 hours. Owner was surprised to learn the water hardness here is what drives the issue, not the appliance.",
    outcome: '✓ Same day · OEM LG inlet valve · SGVMWD cause explained · Full production'
  },
  {
    appliance: 'Bosch Dishwasher',
    location: 'Del Mar Ave, 91776',
    quote: 'Spots on everything and the machine smells musty',
    description: "Bosch 500 series — both spray arm ports nearly blocked with SGVMWD mineral deposits, filter trap caked with scale contributing to the odor. Less than 22 months since installation. Descaled both spray arm assemblies completely, deep-cleaned the filter trap, ran a full citric acid maintenance cycle, confirmed full spray arm rotation and clean drain. Showed the homeowner the extracted scale — striking amount for a machine under two years old. Monthly maintenance tablet routine and 6-month filter habit explained.",
    outcome: '✓ Same day · Scale cleared · Odor gone · First load clean'
  },
  {
    appliance: 'Samsung Washer',
    location: 'Las Tunas area, 91775',
    quote: 'DC error code — vibrating violently on spin cycle',
    description: "Samsung front-loader DC (unbalanced load detection) error presenting as violent vibration on every spin cycle — not just with large loads, but any load. Found two rear shock absorbers weakened and one almost completely failed. The uneven suspension was triggering the unbalance sensor. Replaced all four shock absorbers with OEM Samsung parts, leveled the machine, ran three test cycles at high spin. Quiet, smooth operation. Family had been doing half-loads and re-spinning everything — problem gone.",
    outcome: '✓ Same day · OEM Samsung shocks · All four replaced · Full spin confirmed'
  },
  {
    appliance: 'GE Range',
    location: 'Ramona St, 91776',
    quote: "Oven igniter glows but won't light — been happening for two weeks",
    description: "GE freestanding gas range — oven igniter visible orange glow but failing to draw enough amperage to open the gas valve. This is the standard GE igniter failure pattern. Replaced with an OEM GE igniter, tested oven at 325°F, 375°F, and 450°F — all accurate within 5 degrees. Done in under 30 minutes. Homeowner had been convinced the valve itself was the problem and was prepared for a much larger repair — explained the igniter amperage mechanism and why this is the more common failure.",
    outcome: '✓ Same day · OEM GE igniter · All temps accurate · Explained the failure'
  },
];

const whyReasons = [
  {
    iconKey: 'parts' as const,
    title: 'SGVMWD Hard Water',
    body: 'San Gabriel Valley Municipal Water District groundwater accelerates mineral scale on ice makers and dishwashers throughout 91775 and 91776. We test inlet valves and check for deposits on every relevant San Gabriel call — it consistently comes up with this water supply.'
  },
  {
    iconKey: 'clock' as const,
    title: 'Actually Same Day',
    body: "Call before noon and we're typically there that afternoon. San Gabriel is a regular part of our SGV route — not a special trip. We don't route calls through a dispatch center and send whoever is available; we cover this area consistently."
  },
  {
    iconKey: 'team' as const,
    title: 'Weekends Available',
    body: "Saturday 8am–7pm and Sunday 9am–5pm. Families in San Gabriel have busy weekday schedules — we're available when the appliance breaks, not just when it's convenient for us."
  },
  {
    iconKey: 'shield' as const,
    title: '90-Day Warranty, OEM Only',
    body: 'Every repair backed by 90 days on parts and labor. Genuine OEM parts only. $89 diagnostic waived with repair. Written estimate before we start. California licensed, BBB A+ rated.'
  },
];

const testimonials = [
  {
    stars: 5,
    text: '"LG refrigerator ice maker barely producing anything. Same Day came out, identified the hard water mineral buildup on the inlet valve right away, replaced it, explained why our SGV water causes this. Full production by next morning. Very knowledgeable about the actual cause, not just the symptom."',
    author: '— Michael C., Mission Drive, San Gabriel'
  },
  {
    stars: 5,
    text: `"New Bosch dishwasher with spots and a musty smell in under two years. Tech showed me the mineral scale packed into both spray arms — from our water, not anything we did wrong. Cleared everything, gave us a monthly routine. Completely clean from the first load after. Really appreciated the honest explanation."`,
    author: '— Linda W., Del Mar Ave, San Gabriel'
  },
  {
    stars: 5,
    text: `"Samsung washer vibrating violently every spin cycle. Same Day replaced all four shock absorbers with OEM parts, leveled the machine, ran three test cycles. Completely smooth and quiet. We'd been dealing with this for months — done in under 90 minutes. Professional, efficient, and fairly priced."`,
    author: '— Jenny T., Las Tunas area, San Gabriel'
  },
];

const pricingTiers = [
  { appliance: 'Refrigerator / Ice Maker', range: '$150 – $400', note: 'SGVMWD hard water inlet valve · Fan motor · OEM parts', featured: true },
  { appliance: 'Dishwasher', range: '$150 – $320', note: 'Hard water descaling · Drain pump · Spray arm', featured: true },
  { appliance: 'Washer / Dryer', range: '$150 – $350', note: 'Drain pump · Thermal fuse · Shock absorbers · Vent' },
  { appliance: 'Oven / Range', range: '$150 – $400', note: 'Gas igniter · Bake element · Temperature calibration' },
  { appliance: 'Sub-Zero / Wolf', range: '$300 – $700+', note: 'OEM parts only · Luxury brand expertise' },
  { appliance: 'Diagnostic Fee', range: '$89', note: 'Waived when you proceed with the repair' },
];

const faqs = [
  {
    question: 'Do you offer same-day appliance repair in San Gabriel, CA?',
    answer: "Yes. Our technicians cover all of San Gabriel — 91775 and 91776 — including Mission Drive, Las Tunas, Valley Boulevard, Del Mar Avenue, Ramona Street, and every residential street. Call before noon for same-day afternoon service."
  },
  {
    question: 'Does hard water in San Gabriel affect appliances?',
    answer: 'Yes. SGVMWD delivers mineral-rich groundwater throughout San Gabriel. Ice maker inlet valves and dishwasher spray arms scale up faster than national average. We test for mineral deposits proactively on every relevant San Gabriel call.'
  },
  {
    question: 'Are you available on weekends in San Gabriel?',
    answer: "Yes. Saturday 8am–7pm and Sunday 9am–5pm. If your appliance breaks on a weekend, you don't have to wait until Monday."
  },
  {
    question: 'What appliance brands do you repair in San Gabriel?',
    answer: 'All major brands: Samsung, LG, GE, Whirlpool, KitchenAid, Bosch, Maytag, Sub-Zero, Wolf, Viking, Thermador, and more. OEM parts on every vehicle.'
  },
  {
    question: 'What is your diagnostic fee in San Gabriel?',
    answer: 'Our diagnostic fee is $89, waived when you proceed with the repair. Written estimate before we start. Most San Gabriel repairs run $150–$400.'
  },
  {
    question: 'What warranty do you offer on appliance repairs in San Gabriel?',
    answer: 'All repairs come with a 90-day warranty on parts and labor. Genuine OEM parts only. If the same issue returns within 90 days, we come back at no charge.'
  },
  {
    question: 'Do you also serve Alhambra, Temple City, and Rosemead?',
    answer: 'Yes. Our San Gabriel service extends to Alhambra, Temple City, Rosemead, Monterey Park, El Monte, San Marino, and South Pasadena. All within our regular SGV route.'
  },
];

const nearbyCities = [
  { name: 'Pasadena', slug: 'pasadena' },
  { name: 'Alhambra', slug: 'alhambra' },
  { name: 'Temple City', slug: 'temple-city' },
  { name: 'San Marino', slug: 'san-marino' },
  { name: 'Arcadia', slug: 'arcadia' },
  { name: 'South Pasadena', slug: 'south-pasadena' },
  { name: 'Monrovia', slug: 'monrovia' },
  { name: 'Glendale', slug: 'glendale' },
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair"
    headlineCity="San Gabriel, CA"
    subheadline="One of the most historic cities in the San Gabriel Valley — and one where appliances need the same reliable service as anywhere else. Samsung, LG, GE, Whirlpool, Sub-Zero, all brands. Same-day service, OEM parts, 90-day warranty. Weekends available."
    zips={zips}
    tier={3}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance Repair in San Gabriel — What We Know Here"
    paragraphs={introParagraphs}
    bookingTitle="San Gabriel Service Team"
    bookingSub="91775 · 91776 · Same day · Weekends ok"
  />

  <ServicesGrid
    cityName={cityName}
    headline="What We Repair in San Gabriel"
    subhead="All brands · SGVMWD hard water aware · 91775 & 91776"
    services={services}
  />

  <ServiceArea
    cityName={cityName}
    headline="All of San Gabriel — 91775 & 91776"
    subheadline="Mission Drive to Valley Blvd — every neighborhood in the city"
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={keyStreets}
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Jobs in San Gabriel"
    subhead="Real calls from 91775 and 91776 — SGV homes, SGVMWD hard water, same-day service."
    jobs={recentJobs}
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="Why San Gabriel Calls Us Back"
    reasons={whyReasons}
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What San Gabriel Customers Are Saying"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Appliance Repair Costs in San Gabriel"
    subhead="Written estimate before we start. $89 diagnostic — waived with repair."
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="Questions San Gabriel Customers Ask"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby Areas"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance broken in San Gabriel?"
    body="SGVMWD hard water specialists · All brands · Weekends available. 91775 & 91776. $89 diagnostic waived with repair. 90-day warranty."
  />
</CityLayoutV2>
