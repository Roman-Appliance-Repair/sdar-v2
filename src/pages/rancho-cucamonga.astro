---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import CustomNarrative from '../components/cities/v2/CustomNarrative.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES, MAIN_PHONE, isPlaceholderPhone } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

import { mergeCredentials } from '../data/credentials-schema';
const citySlug = 'rancho-cucamonga';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = 'Rancho Cucamonga';
const zips = ['91701', '91730', '91737', '91739'];

const phone = branch.phone;
const phoneRaw = `+1${phone.replace(/\D/g, '')}`;

const title = `Appliance Repair Rancho Cucamonga CA — Same Day | All Brands`;
const description = `Same-day appliance repair in Rancho Cucamonga. Refrigerator, washer, dryer, oven & more. Sub-Zero, Samsung, LG, Whirlpool. Licensed. OEM parts.`;
const canonical = 'https://samedayappliance.repair/rancho-cucamonga/';

const localBusinessSchema = mergeCredentials({
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { '@type': 'City', name: 'Rancho Cucamonga', sameAs: 'https://en.wikipedia.org/wiki/Rancho_Cucamonga,_California' }
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$',
  license: 'BHGS #A49573',
  sameAs: [...(branch.sameAs ?? [])],
  hasOfferCatalog: { '@id': 'https://samedayappliance.repair/#service-catalog' }
});

const introParagraphs = [
  "Rancho Cucamonga is one of the more interesting service markets we cover. On one end of the spectrum you've got the Alta Loma tract homes — solid 1980s and '90s single-family houses where Whirlpool and Maytag are still running well past their expected lifespan. On the other end, you've got the newer estates near Victoria Gardens and Day Creek where Sub-Zero columns, Wolf ranges, and 48-inch built-in refrigerators are standard. Our techs work both worlds in the same day.",
  "The climate here is something no other part of our service area matches. Inland Empire summers hit 105–112°F regularly. That's not the same as Pasadena at 98°F or even the Valley at 102°F. At those sustained temperatures, condenser coils clog faster, compressors run hotter, and appliances that would last 15 years in a coastal climate start showing stress at year 10. We've seen Sub-Zero units in Etiwanda with coil packs that looked like they hadn't been cleaned in a decade — owners had no idea condenser maintenance was even a thing.",
  "There's also the dust factor. Rancho Cucamonga sits at the foot of the San Gabriel Mountains and gets strong Santa Ana winds that push fine particulate through everything. Dryer vent runs in the tract homes here are often 15–20 feet through the garage — longer than the recommended maximum. When you combine that run length with Inland Empire dust, lint accumulates fast. We clear blocked dryer vents on almost every third dryer call in this city.",
  `Same-day coverage is available across all four ZIP codes — 91701, 91730, 91737, and 91739. Call us at <a href="tel:${phoneRaw}">${phone}</a>.`
];

const services = [
  { icon: '❄️', name: 'Refrigerator Repair', slug: 'refrigerator' },
  { icon: '🌀', name: 'Washer Repair', slug: 'washer' },
  { icon: '💨', name: 'Dryer Repair', slug: 'dryer' },
  { icon: '🔥', name: 'Oven & Range Repair', slug: 'oven' },
  { icon: '🫧', name: 'Dishwasher Repair', slug: 'dishwasher' },
  { icon: '🍳', name: 'Stove & Cooktop Repair', slug: 'stove' },
  { icon: '🧊', name: 'Freezer Repair', slug: 'freezer' },
  { icon: '🍷', name: 'Wine Cooler Repair', slug: 'wine-cooler' }
];

const heatNarrative = {
  headline: 'What Inland Empire Heat Does to Your Appliances',
  paragraphs: [
    "This is something we talk about with almost every Rancho Cucamonga customer, because most people don't realize how much climate affects appliance lifespan and maintenance schedules.",
    "<strong>Refrigerators work harder here than anywhere else we service.</strong> When ambient temperature is 108°F, your fridge compressor is running against a 68-degree differential to hold 40°F inside. That's a sustained load that coastal California appliances rarely face. The result: condenser coils clog faster from the combination of dust and heat cycling, compressors run hotter and wear faster, and door gaskets harden and crack from the dry heat. In coastal cities, we recommend condenser cleaning every 12 months. In Rancho Cucamonga, every 6 months is the right call.",
    "<strong>Dryer vent runs are a specific problem here.</strong> The tract homes in Terra Vista and Victoria Groves were built with long internal vent routes — often through the garage or a back hallway. Runs of 15–20 feet, with one or two 90-degree bends, are common. At that length, lint accumulates quickly and restricts airflow. In Inland Empire summers, a restricted dryer vent can push exhaust temps high enough to be a genuine fire hazard. If your dryer takes more than one cycle to dry a load, that's the first thing to check.",
    "<strong>West-facing appliance placement is an underappreciated factor.</strong> In homes throughout Etiwanda and North Etiwanda, kitchens often face west — and in summer, western walls absorb significant radiant heat by mid-afternoon. A refrigerator or wine cooler sitting against a west-facing wall in a Rancho Cucamonga kitchen is working against an additional 10–15°F of ambient load compared to an interior wall. We often recommend leaving extra clearance on the back and sides, and increasing cleaning frequency accordingly."
  ],
  subSections: [
    {
      title: 'Maintenance Schedule for Rancho Cucamonga Homes',
      paragraphs: [
        "<strong>Refrigerator condenser coils:</strong> Every 6 months (not 12) — especially in homes near the foothills with heavy dust.",
        "<strong>Dryer vent:</strong> Every 12 months if your run is under 10 feet — every 6 months if longer.",
        "<strong>Refrigerator door gaskets:</strong> Check annually — heat cycling causes hardening and cracking faster here.",
        "<strong>Dishwasher filter:</strong> Monthly cleaning — hard water deposits accumulate faster in SB County water.",
        "<strong>Sub-Zero condenser:</strong> Every 6 months minimum — this is documented in the Sub-Zero owner manual for warm climates."
      ]
    }
  ]
};

const housingNarrative = {
  headline: "Rancho Cucamonga Housing Stock — What's in These Homes",
  paragraphs: [
    "Rancho Cucamonga isn't one type of city — it's three or four different markets layered on top of each other, and our technicians know all of them."
  ],
  subSections: [
    {
      title: 'Alta Loma (91701) — Older Single-Family Stock',
      paragraphs: [
        "Alta Loma is where Rancho Cucamonga got its start — hillside single-family homes mostly built between 1970 and 1995. These homes run older Whirlpool, Maytag, and GE appliances that are well past their published lifespans but often still functional. The most common calls here are worn-out dryer heating elements, refrigerator defrost system failures, and dishwasher pump assemblies. We see a lot of Kenmore (Sears-branded Whirlpool) units that people have had for 20 years and want to keep running. Usually worth repairing if the compressor or motor is still solid."
      ]
    },
    {
      title: 'Terra Vista & Victoria Groves (91730) — Planned Community, Mid-Range',
      paragraphs: [
        "Terra Vista was one of the first master-planned communities in the Inland Empire — built through the 1980s and '90s with a consistent housing stock. These homes tend to have mid-range Samsung, LG, and Whirlpool appliances from the 2010s, now aging into the 7–12 year failure window. Samsung French-door refrigerators and LG front-load washers dominate. Ice maker failures, door-in-door actuator problems, and washer bearing wear are the most common calls. We keep Samsung and LG OEM parts stocked specifically for this area."
      ]
    },
    {
      title: 'Etiwanda & North Etiwanda (91739) — Newer Tract Homes',
      paragraphs: [
        "Etiwanda has seen significant development in the last 15 years — newer tract homes, often in HOA-managed communities, with appliances in the 3–10 year range. These tend to be Samsung, LG, and Bosch. Still under manufacturer warranty in some cases — we help owners navigate warranty claims before they pay out of pocket. Common issues: Samsung ice maker problems, LG compressor failures in the newer linear inverter models (watch for the class-action relevant models), and Bosch dishwasher E24 drain errors from hard water accumulation."
      ]
    },
    {
      title: 'Victoria Gardens Area & Day Creek (91739) — Luxury Homes',
      paragraphs: [
        "The newer luxury developments near Victoria Gardens shopping center and along Day Creek Boulevard have Sub-Zero, Wolf, Viking, and Thermador as standard equipment. These homes also tend to have wine coolers and beverage centers. Sub-Zero condenser cleaning in this climate is critical — we've opened units here that are only 4–5 years old but have never been cleaned, with coil packs fully blocked. We stock OEM Sub-Zero and Wolf parts and don't sub out luxury appliance work to general technicians."
      ]
    }
  ]
};

const neighborhoods = [
  { name: 'Alta Loma', zip: '91701' },
  { name: 'Etiwanda', zip: '91739' },
  { name: 'Terra Vista', zip: '91730' },
  { name: 'Victoria Groves', zip: '91730' },
  { name: 'Victoria Gardens Area', zip: '91739' },
  { name: 'North Etiwanda', zip: '91739' },
  { name: 'Rancho Etiwanda', zip: '91739' },
  { name: 'Day Creek', zip: '91739' },
  { name: 'Haven Ave Corridor', zip: '91730' },
  { name: 'Foothill Blvd', zip: '91730' },
  { name: 'Cucamonga (Historic)', zip: '91730' },
  { name: 'Red Hill', zip: '91737' }
];

const recentJobs = [
  {
    appliance: 'Sub-Zero 650',
    location: 'Victoria Gardens area, 91739',
    quote: 'not cooling — compressor ran constantly',
    description: "Customer called early on a Thursday — Sub-Zero 650 had been cycling all night and the fridge section was sitting at 52°F. Classic condenser overload from Inland Empire summer heat. When we opened the unit, the condenser coils were packed solid — the family had never had them cleaned in seven years of living there. Cleared the coils, tested the compressor load, and found the fan blade was also cracked and causing vibration. Replaced both the fan and cleaned the coils. Unit was holding 38°F by afternoon.",
    outcome: 'Condenser cleaning in this climate is not optional. Every six months.'
  },
  {
    appliance: 'Samsung RF28',
    location: 'Terra Vista, 91730',
    quote: 'ice maker not making ice, error code 14E',
    description: "The 14E on this model points to an ice room temperature sensor — but the actual root cause here was a kinked water inlet line in the door hinge. We see this on Samsung French-door units that have been opened and closed thousands of times over five years. The line crimps gradually. Replaced the inlet valve assembly and cleared the 14E. The customer had been told by another company it was the main control board — it wasn't. Control board replacement would have been $380+. This was $145 parts and labor.",
    outcome: "Error codes tell you where to look. They don't always tell you why."
  },
  {
    appliance: 'Whirlpool Cabrio washer',
    location: 'Alta Loma, 91701',
    quote: "won't spin, F5 E2 code",
    description: "F5 E2 on the Cabrio is a lid lock failure. But on this particular unit — about eight years old — the lid lock itself was fine. The issue was the actuator tab that triggers the switch had broken off. Common failure point on this generation of Cabrio. We had the part on the truck. Repair took about an hour including diagnosis and testing.",
    outcome: 'Alta Loma has a lot of these 2015–2018 Cabrio units. We keep actuator assemblies stocked.'
  },
  {
    appliance: 'LG LRMVS3006S',
    location: 'Etiwanda, 91739',
    quote: 'French door fridge warm top section, freezer fine',
    description: "Warm fridge, cold freezer is almost always an evaporator fan issue on these dual-evaporator LG units. Pulled the back panel and found the fan motor had seized — heat stress from the Etiwanda summer had pushed the motor past its tolerance. The fridge was also positioned against a west-facing wall, which compounds the heat load. Replaced the evaporator fan motor with an OEM LG part and advised the owner to leave a few inches of clearance on the back.",
    outcome: 'West-facing walls in Rancho Cucamonga add 10–15°F of ambient heat load on appliances sitting against them.'
  }
];

const whyReasons = [
  {
    iconKey: 'team' as const,
    title: 'We pick up the phone',
    body: `Not a call center. Not a dispatch queue. When you call ${phone}, someone who actually knows the schedule picks up and gives you an honest answer about when we can be there. Usually same day if you call before noon.`
  },
  {
    iconKey: 'parts' as const,
    title: 'OEM parts — not aftermarket',
    body: "We don't use third-party parts from Amazon or off-brand suppliers. OEM parts fit correctly, last longer, and don't void manufacturer warranties. In a market with a lot of discount competitors, this is a real difference."
  },
  {
    iconKey: 'shield' as const,
    title: 'Honest diagnosis before we quote',
    body: "The $89 diagnostic fee means we actually look at your appliance before we tell you what it'll cost. We don't quote over the phone based on symptoms. What we quote is what appears on the invoice."
  },
  {
    iconKey: 'clock' as const,
    title: "We know what's in these houses",
    body: 'Rancho Cucamonga has a specific mix of appliance generations — 1990s Whirlpool in Alta Loma, mid-2010s Samsung and LG in Terra Vista, newer Sub-Zero in the luxury tracts. Our technicians come prepared for what\'s actually here, not generic brands.'
  }
];

const testimonials = [
  {
    stars: 5,
    text: '"My Samsung fridge in Terra Vista stopped making ice and the display was showing an error code. Called Same Day and they were out the same afternoon. Tech knew exactly what it was — had the part on his truck. Two hours and done. Really impressed."',
    author: '— Daniel K., Terra Vista'
  },
  {
    stars: 5,
    text: '"Sub-Zero hadn\'t been serviced in years and was running warm in the summer heat. The technician found the condenser was completely blocked. He cleaned it thoroughly and explained the 6-month maintenance schedule for our climate. Really knowledgeable."',
    author: '— Patricia M., Victoria Gardens area'
  },
  {
    stars: 4,
    text: '"Whirlpool dryer in our Alta Loma house was taking two cycles to dry everything. Turned out the vent run through our garage was partially blocked and the heating element was weak. Fixed both. Fair price, showed up on time."',
    author: '— Marcus T., Alta Loma'
  }
];

const pricingTiers = [
  { appliance: 'Refrigerator Repair', range: '$150–$450', note: 'Fan motor · Coil cleaning · Inlet valve · Compressor relay' },
  { appliance: 'Washer Repair', range: '$140–$380', note: 'Drain pump · Bearing · Actuator · Lid lock' },
  { appliance: 'Dryer Repair', range: '$120–$320', note: 'Heating element · Thermal fuse · Vent path' },
  { appliance: 'Dishwasher Repair', range: '$130–$360', note: 'Drain pump · Filter · Spray arm · E24 errors' },
  { appliance: 'Oven / Range Repair', range: '$140–$400', note: 'Igniter · Bake element · Gas valve · Calibration' },
  { appliance: 'Sub-Zero Repair', range: '$250–$650', note: 'OEM Sub-Zero parts · Coil cleaning · Fan motor' },
  { appliance: 'Condenser Coil Cleaning', range: '$89–$150', note: '6-month interval recommended for this climate' },
  { appliance: 'Dryer Vent Cleaning', range: '$89–$140', note: 'Long tract-home vent runs cleared completely' }
];

const faqs = [
  {
    question: 'Do you offer same-day appliance repair in Rancho Cucamonga?',
    answer: `Yes — same-day service is available throughout Rancho Cucamonga, including Alta Loma, Etiwanda, Terra Vista, and Victoria Gardens. Call ${phone} before noon and we'll typically have a technician out the same day. We cover ZIP codes 91701, 91730, 91737, and 91739.`
  },
  {
    question: 'Why does my refrigerator seem to struggle more in summer?',
    answer: "Rancho Cucamonga's Inland Empire heat — routinely 105–112°F in July and August — puts serious strain on condenser coils and compressors. If your fridge is working harder than usual, not maintaining temperature, or the compressor runs constantly, the condenser coil is usually the first thing we check. In this climate, it should be cleaned every 6 months, not 12."
  },
  {
    question: 'What brands do you repair in Rancho Cucamonga?',
    answer: 'All of them. Samsung and LG dominate the newer tract homes in Terra Vista and Victoria Groves. Whirlpool and Maytag are standard in older Alta Loma homes. The estates near Victoria Gardens and Red Hill tend to run Sub-Zero, Wolf, and Viking. We carry OEM parts for all of these and don\'t sub out to third parties.'
  },
  {
    question: 'What is your diagnostic fee?',
    answer: 'Our diagnostic fee is $89 — and that\'s applied directly to the repair cost the moment you say yes. No hidden trip charge. What we quote is what appears on the invoice.'
  },
  {
    question: 'Do you repair Sub-Zero refrigerators in Rancho Cucamonga?',
    answer: "Yes. Sub-Zero repair is something our technicians handle regularly. Rancho Cucamonga has a mix of Sub-Zero 700 and 600 series in the higher-end neighborhoods near Victoria Gardens. Common issues in this climate: condenser buildup from Inland Empire dust, evaporator fan failures, and door gasket wear from heat cycling. We stock OEM Sub-Zero parts and don't use aftermarket substitutes."
  },
  {
    question: "My dryer takes two cycles to dry — what's wrong?",
    answer: "In most Rancho Cucamonga homes we service, the culprit is one of two things: a clogged dryer vent (common in tract homes where vent runs can stretch 15–20 feet through the garage), or a failing heating element. We inspect both on every dryer call. A blocked vent is also a fire hazard — if you haven't had it cleaned in two years, it's time."
  },
  {
    question: 'Do you service commercial appliances in Rancho Cucamonga?',
    answer: 'Yes. We service restaurant equipment, walk-in coolers and freezers, and commercial laundry. Rancho Cucamonga has a busy commercial corridor along Foothill Blvd and near Victoria Gardens — we respond to commercial calls with priority scheduling. Call us for commercial pricing.'
  }
];

const nearbyCities = [
  { name: 'Chino Hills', slug: 'chino-hills' },
  { name: 'Upland', slug: 'upland' },
  { name: 'Ontario', slug: 'ontario' },
  { name: 'Fontana', slug: 'fontana' },
  { name: 'San Bernardino', slug: 'san-bernardino' },
  { name: 'Redlands', slug: 'redlands' }
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair"
    headlineCity="Rancho Cucamonga"
    subheadline="Same-day service in Alta Loma, Etiwanda, Terra Vista, Victoria Gardens, and throughout the Inland Empire. All brands, OEM parts, licensed technicians."
    zips={zips}
    tier={2}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance Repair in Rancho Cucamonga — What We've Learned Working Here"
    paragraphs={introParagraphs}
    bookingTitle="Rancho Cucamonga"
    bookingSub="Same-Day Service"
  />

  <ServicesGrid
    cityName={cityName}
    headline="What We Repair in Rancho Cucamonga"
    services={services}
  />

  <CustomNarrative
    headline={heatNarrative.headline}
    paragraphs={heatNarrative.paragraphs}
    subSections={heatNarrative.subSections}
    background="white"
  />

  <ServiceArea
    cityName={cityName}
    headline="Neighborhoods We Service in Rancho Cucamonga"
    subheadline="We cover all of Rancho Cucamonga — Alta Loma single-family homes, Terra Vista planned communities, Etiwanda tract neighborhoods, and the luxury estates near Victoria Gardens and Day Creek. No travel surcharge within these areas."
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={[]}
  />

  <CustomNarrative
    headline={housingNarrative.headline}
    paragraphs={housingNarrative.paragraphs}
    subSections={housingNarrative.subSections}
    background="gray"
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Repairs in Rancho Cucamonga"
    jobs={recentJobs}
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="Why Rancho Cucamonga Residents Call Us"
    reasons={whyReasons}
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What Rancho Cucamonga Customers Are Saying"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Typical Repair Pricing in Rancho Cucamonga"
    subhead="Every repair is different — these are ranges based on common repairs in this market. The $89 diagnostic fee is applied to the cost when you proceed."
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="Rancho Cucamonga Appliance Repair — FAQ"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby Cities"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Need Appliance Repair in Rancho Cucamonga Today?"
    body="Same-day service available throughout Alta Loma, Etiwanda, Terra Vista, Victoria Gardens, and all Rancho Cucamonga ZIP codes."
  />

<section class="section">
  <div class="container narrow" style="max-width:820px;margin:0 auto;padding:48px 24px;">
    <p style="font-size:0.75rem; font-weight:700; letter-spacing:0.14em; text-transform:uppercase; color:#C8102E; margin-bottom:10px;">Service-specific pages for Rancho Cucamonga</p>
    <h2 style="font-size:1.6rem; font-weight:800; margin:0 0 18px;">Rancho Cucamonga appliance repair by service.</h2>
    <p>Each service-specific page covers brand pool, failure patterns, and pricing relevant to Rancho Cucamonga home stock and local conditions.</p>
    <ul style="padding-left:22px; margin:14px 0 18px;">
      <li><a href="/rancho-cucamonga/refrigerator-repair/">Refrigerator repair in Rancho Cucamonga</a></li>
      <li><a href="/rancho-cucamonga/dryer-repair/">Dryer repair in Rancho Cucamonga</a></li>
