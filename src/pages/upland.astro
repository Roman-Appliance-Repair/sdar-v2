---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import CustomNarrative from '../components/cities/v2/CustomNarrative.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES, isPlaceholderPhone } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

const citySlug = 'upland';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branchRaw = BRANCHES.find((b) => b.slug === city.primaryBranch)!;
const fallbackBranch = BRANCHES.find((b) => b.slug === 'pasadena')!;
const branch = isPlaceholderPhone(branchRaw.phone) ? { ...branchRaw, phone: fallbackBranch.phone, email: fallbackBranch.email } : branchRaw;

const cityName = "Upland";
const zips = ["91784", "91785", "91786"];

const phone = branch.phone;
const phoneRaw = `+1${phone.replace(/\D/g, '')}`;

const title = `Appliance Repair Upland CA — Same Day | All Brands | ${phone}`;
const description = `Same-day appliance repair in Upland CA. Refrigerator, washer, dryer, oven, dishwasher & more. San Antonio Heights, North Upland, The Colonies. Licensed. OEM parts. Call ${phone}.`;
const canonical = "https://samedayappliance.repair/upland/";

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  name: branchRaw.fullName,
  image: "https://samedayappliance.repair/images/logo.webp",
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: zips.map((zip) => ({ "@type": "PostalCode", postalCode: zip })),
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: "$$",
  license: "CA CSLB #1138898",
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: "4.6",
    reviewCount: "37",
    bestRating: "5",
  },
};

const introParagraphs = [
  "Upland stands apart from every other city in our Inland Empire service area. Most of the IE is new construction — Menifee, Murrieta, parts of Corona — built out in the 2000s and 2010s with consistent builder-grade appliances. Upland is different. The historic neighborhoods along Euclid Avenue and the craftsman bungalows in central Upland date to the 1920s, '30s, and '40s. San Antonio Heights has estates and ranch homes from the 1950s and '60s. And then there's a layer of mid-century housing, and more recent developments like The Colonies in North Upland. Three or four distinct housing generations, each with its own appliance profile.",
  "What this means in practice: we make calls in Upland that run the full range from a 1995 Whirlpool top-loader that a family has kept running for 30 years, to a brand-new Sub-Zero in a North Upland estate, to a 2014 Samsung French-door in The Colonies hitting its first ice maker failure. We come prepared for all of it, and we approach older appliance calls with the same care we give newer ones — because a mechanically sound older machine is often worth keeping running.",
  "The foothills location matters too. Upland sits at the base of the San Gabriel Mountains, and the canyon winds that funnel down from Mount Baldy move fine particulate through homes near the foothill transition zone. Condenser coils on refrigerators and wine coolers in San Antonio Heights and North Upland load up faster than anywhere else in our SB County service area. We clean coils on more than half the refrigerator calls we make in upper Upland.",
  `Same-day coverage across ZIP codes 91784, 91785, and 91786. Call <a href="tel:${phoneRaw}">${phone}</a>.`,
];

const services = [
  { icon: '❄️', name: 'Refrigerator Repair', slug: 'refrigerator' },
  { icon: '🌀', name: 'Washer Repair', slug: 'washer' },
  { icon: '💨', name: 'Dryer Repair', slug: 'dryer' },
  { icon: '🔥', name: 'Oven & Range Repair', slug: 'oven' },
  { icon: '🫧', name: 'Dishwasher Repair', slug: 'dishwasher' },
  { icon: '🍳', name: 'Stove & Cooktop Repair', slug: 'cooktop' },
  { icon: '🧊', name: 'Freezer Repair', slug: 'freezer' },
  { icon: '🍷', name: 'Wine Cooler Repair', slug: 'wine-cooler' },
];

const housingNarrative = {
  eyebrow: "Upland's Housing Generations",
  headline: "Upland's Housing Stock — What's in Each Part of the City",
  paragraphs: [
    "Understanding Upland's neighborhoods is essential to understanding its appliances. This is not a one-generation city, and our approach reflects that.",
  ],
  subSections: [
    {
      title: "San Antonio Heights & North Upland (91784) — Estates and Foothills",
      paragraphs: [
        "San Antonio Heights is the most distinctive part of Upland — unincorporated hillside properties at the foot of the San Gabriel Mountains, with larger lots, estate homes, and views toward Mount Baldy. These properties run the gamut from 1950s ranch homes with original or replacement Whirlpool and GE appliances, to newer custom builds with Sub-Zero columns, Wolf ranges, and built-in Miele dishwashers. The foothill location means canyon wind exposure — fine particulate from the mountain faces loads condenser coils here faster than anywhere in our SB County territory. We recommend 5-month condenser cleaning for refrigerators in this zone, not 6.",
        "The Colonies development in North Upland is a master-planned community from the early 2000s — newer homes, newer appliances (Samsung, LG, KitchenAid), now entering the 8–15 year failure range. Ice maker issues, evaporator fan failures, and front-load washer bearings are the common calls here.",
      ],
    },
    {
      title: "Historic Central Upland & Euclid Ave Corridor (91786) — Pre-War and Mid-Century",
      paragraphs: [
        "The neighborhoods near Euclid Avenue and the historic downtown have Upland's oldest housing stock — craftsman bungalows from the 1920s and '30s, Spanish Colonials from the '40s, and ranch homes from the '50s. Appliances in these homes span a wide range. Some families have kept older Whirlpool, Maytag, and GE machines running for 20+ years — and with good reason, since these mechanical machines are simpler and often more repairable than modern electronics-heavy units.",
        "When we get a call from central Upland for an older appliance, our first check is parts availability. If OEM parts are still being manufactured or can be sourced, we quote the repair honestly. Older top-load washers with mechanical timers and direct-drive motors are often excellent candidates for repair — no control boards to fail, straightforward mechanics. We've kept 25-year-old Whirlpool Direct Drive washers running with a $60 coupler replacement.",
      ],
    },
    {
      title: "South Upland & Foothill Blvd (91786) — Mixed Stock",
      paragraphs: [
        "South Upland has a consistent mix of 1970s and '80s housing alongside newer infill development. Appliances here span from older GE and Whirlpool to mid-2010s Samsung and LG in renovated homes and newer builds. Hard water is an issue throughout this area — the Foothill Blvd corridor gets SB County water with consistently high mineral content. Dishwasher filter cleaning every three months and refrigerator water filter replacement every four months are our standard recommendations for homes throughout south Upland.",
      ],
    },
    {
      title: "Foothill Dust — Upland's Specific Climate Factor",
      paragraphs: [
        "Upland's position at the base of the San Gabriel Mountains creates a dust exposure pattern unlike the rest of the IE. During Santa Ana wind events, canyon winds accelerate down the Cucamonga Canyon and other mountain faces, carrying fine grey particulate from the decomposed granite slopes. Homes in San Antonio Heights, upper North Upland, and the Upland Hills neighborhoods directly in this wind path see condenser coils loading at nearly double the rate of homes in flat parts of the city. If you live above Foothill Blvd and your refrigerator struggles in summer, condenser coils are the first check — every time.",
      ],
    },
  ],
};

const neighborhoods = [
  { name: 'San Antonio Heights', zip: '91784', featured: true },
  { name: 'North Upland', zip: '91784' },
  { name: 'Upland Hills', zip: '91784' },
  { name: 'The Colonies', zip: '91784', featured: true },
  { name: 'Euclid Ave Corridor', zip: '91786' },
  { name: 'Foothill Blvd Area', zip: '91786' },
  { name: 'South Upland', zip: '91786' },
  { name: 'Mountain Ave Corridor', zip: '91784' },
  { name: 'Grove Ave Area', zip: '91786' },
  { name: 'Magnolia Ave', zip: '91786' },
  { name: 'Central Upland', zip: '91786' },
  { name: 'Cable Airport Area', zip: '91786' },
];

const recentJobs = [
  {
    appliance: 'KitchenAid Dishwasher (2007)',
    location: 'San Antonio Heights, 91784',
    quote: '"KitchenAid KDTM354DSS — not cleaning, E1 F6 error, 2007 model"',
    description: "18-year-old KitchenAid dishwasher in a classic 1960s San Antonio Heights ranch home. E1 F6 is a water heating error — but the actual cause here was a failed wash motor capacitor, not the heating element. The motor was drawing low amperage, causing incomplete cycles and the heating fault. Capacitor replacement on this generation of KitchenAid is a $45 part. Replaced it, ran three test cycles, confirmed full wash performance restored. Owner had been told by a big-box store technician the unit was end-of-life and needed replacement. It wasn't.",
    outcome: '✓ Older KitchenAid dishwashers are mechanical workhorses. Error codes on older units often point to secondary causes.',
  },
  {
    appliance: 'GE Profile French-Door Fridge',
    location: 'The Colonies, 91784',
    quote: '"GE Profile PFE28KBLTS — warm fridge, ice maker down, 11 years old"',
    description: "GE Profile French-door from The Colonies development, 11 years old. Fridge running at 50°F, ice maker silent. Condenser coils at the back were completely packed — the home backs up against the Upland Hills slope and gets heavy foothill dust during Santa Ana events. Once the coils were cleaned, we turned to the ice maker. Fill tube was frozen — freezer was set at -2°F, two degrees below recommended, combined with scale from the area's hard water. Cleared the fill tube, adjusted the set point to 2°F, replaced the water filter (22 months old). Both issues resolved same visit.",
    outcome: '✓ Foothill homes in Upland get significantly more coil-loading dust than valley homes. Clean every 5 months.',
  },
  {
    appliance: 'Whirlpool Top-Load Washer',
    location: 'Euclid Ave area, 91786',
    quote: '"Whirlpool WTW4816FW top-load washer — won\'t drain, F7 E1 code"',
    description: "F7 E1 on Whirlpool top-loaders is a basket speed sensor error, but this unit wasn't draining — a separate issue. The basket sensor failure was causing mid-cycle stops, and the standing water was a blocked drain pump filter that had never been cleaned (these filters aren't obvious on this generation — no access panel). Cleared the drain filter — it had a surprising quantity of coins, a hair tie, and lint buildup — then replaced the basket speed sensor. Two separate issues, one visit. Machine draining and completing cycles normally.",
    outcome: '✓ Whirlpool F7 E1 error and a drainage problem together usually means two separate issues. Address both.',
  },
  {
    appliance: 'Sub-Zero 648PRO',
    location: 'North Upland / Mountain Ave, 91784',
    quote: '"Sub-Zero 648PRO — loud compressor noise, running constantly"',
    description: "Sub-Zero 48-inch pro refrigerator in a large North Upland home. Compressor running without stopping, loud enough to hear from the adjacent room. Condenser coils had never been serviced in five years — the home is near the foothill transition zone and the coil pack was dense with fine grey particulate from canyon wind events. Cleaned the coils thoroughly. Compressor load dropped to normal, noise resolved. Also found the left door gasket had micro-tears at two corners from the dry air — replaced the gasket with an OEM Sub-Zero part. Owner had assumed the compressor was failing.",
    outcome: '✓ A continuously-running Sub-Zero compressor is almost always condenser coils before it\'s a compressor. Clean first.',
  },
];

const whyReasons = [
  {
    iconKey: 'parts' as const,
    title: 'We work on older appliances — seriously',
    body: "Most companies won't touch anything over 10 years old. We don't have that policy. If the machine is mechanically sound and parts are available, we quote the repair honestly. A 1998 Whirlpool Direct Drive washer with a worn coupler is a $60 fix. We do it.",
  },
  {
    iconKey: 'team' as const,
    title: 'We understand foothill dust',
    body: 'San Antonio Heights and North Upland homes near the mountain faces see coil-loading rates that are double the flat valley average. We account for this in every refrigerator diagnosis and recommend the right cleaning schedule for your specific location.',
  },
  {
    iconKey: 'clock' as const,
    title: 'Honest repair vs. replace',
    body: "We tell you when it doesn't make sense to repair. A 16-year-old fridge with a dying compressor in a home where the kitchen gets 100°F in summer — that math often doesn't work. We give you the numbers and our honest opinion after every diagnosis.",
  },
  {
    iconKey: 'shield' as const,
    title: 'OEM parts for every era',
    body: "We source OEM parts for current appliances through manufacturer channels, and track down OEM or equivalent-spec parts for older machines. We don't use generic aftermarket parts — they fit poorly and fail faster, especially in Upland's heat and dust environment.",
  },
];

const testimonials = [
  {
    stars: 5,
    text: '"Old KitchenAid dishwasher from 2007 showing an error code — every other company said just buy a new one. Same Day diagnosed a failed capacitor for $45 and fixed it same visit. Machine is running perfectly. So glad I called them first."',
    author: '— Patricia H., San Antonio Heights',
  },
  {
    stars: 5,
    text: '"Sub-Zero in our North Upland home was running constantly and making noise. Tech came out, cleaned the condenser coils — packed with foothill dust — and replaced a door gasket. Done in 90 minutes. Very knowledgeable about why it happens up here near the foothills."',
    author: '— Robert & Diane K., North Upland',
  },
  {
    stars: 5,
    text: '"GE refrigerator was warm and the ice maker wasn\'t working. Tech found two separate issues — clogged coils from the dust and a frozen fill tube. Fixed both in one visit. Really thorough diagnosis, didn\'t just fix the obvious thing."',
    author: '— Angela M., The Colonies',
  },
];

const pricingTiers = [
  { appliance: 'Refrigerator Repair', range: '$150–$450', note: 'Coil cleaning · Fan motor · Ice maker · Compressor diagnostics' },
  { appliance: 'Washer Repair', range: '$120–$380', note: 'Drain pump · Sensor · Direct drive coupler · Bearing' },
  { appliance: 'Dryer Repair', range: '$120–$320', note: 'Heating element · Thermal fuse · Vent cleaning' },
  { appliance: 'Dishwasher Repair', range: '$89–$360', note: 'Pump · Capacitor · Spray arm · Filter' },
  { appliance: 'Oven / Range Repair', range: '$140–$400', note: 'Igniter · Bake element · Sensor · Calibration' },
  { appliance: 'Sub-Zero Repair', range: '$250–$650', note: 'OEM parts · Gasket · Coil · Compressor diagnostics', featured: true },
  { appliance: 'Wine Cooler Repair', range: '$150–$450', note: 'Compressor · Thermostat · Door seals · Foothill dust check' },
  { appliance: 'Condenser Coil Cleaning', range: '$89–$150', note: 'Foothill dust service · Recommended 5-month interval upper Upland' },
];

const faqs = [
  {
    question: "Do you offer same-day appliance repair in Upland?",
    answer: `Yes — same-day service is available throughout Upland including San Antonio Heights, North Upland, The Colonies, Euclid Ave, Foothill Blvd, and South Upland. Call ${phone} before noon and we'll typically have a technician out the same day. We cover ZIP codes 91784, 91785, and 91786 without a trip surcharge.`,
  },
  {
    question: "You mentioned older homes — can you work on older appliances from the 1980s and 1990s?",
    answer: "Yes, and it's one of our strengths. Upland has more older housing stock than most IE cities, and the appliances in those homes reflect it. Older Whirlpool top-loaders, GE ranges from the 1990s, and early KitchenAid dishwashers are mechanical machines — fewer control boards, more physical components — and they're often genuinely worth repairing. Parts availability is our first check on every older appliance call. If we can source the OEM part, we'll quote the repair honestly and let you decide.",
  },
  {
    question: "What about newer homes in The Colonies or North Upland?",
    answer: "We service those too. The Colonies and the newer developments in North Upland and Upland Hills run Samsung, LG, Bosch, and KitchenAid from the 2010s. These are in the 7–12 year failure window now — ice maker issues, evaporator fan failures, front-load washer bearings, dishwasher drain errors. We carry OEM parts for all of these on the truck.",
  },
  {
    question: "What is your diagnostic fee?",
    answer: "$89, applied directly to the repair cost when you proceed. No hidden trip charge to Upland. We quote on-site after diagnosis — what we quote is what appears on the invoice.",
  },
  {
    question: "Why does my refrigerator struggle every summer near the foothills?",
    answer: "Upland sits at the base of the San Gabriel Mountains, and the canyon winds that funnel down from Mount Baldy carry fine particulate that loads up condenser coils faster than flat valley cities. In summer heat, partially clogged coils push refrigerators over their thermal limit. Homes near the foothills in San Antonio Heights and North Upland should clean condenser coils every 5–6 months, not annually. If your fridge runs warm every July, that's the first place we look.",
  },
  {
    question: "Do you repair Sub-Zero and Wolf appliances in Upland?",
    answer: "Yes. The older estates in San Antonio Heights and the larger homes along Mountain Avenue in North Upland tend to have Sub-Zero refrigerators and Wolf ranges. We carry OEM Sub-Zero and Wolf parts and service these the same way we service them in our LA County luxury markets — carefully, with the right parts, and verified calibration before we leave.",
  },
  {
    question: "Is it worth repairing a 15-year-old dishwasher or washer in an older Upland home?",
    answer: "Depends on the machine. A 15-year-old Whirlpool or KitchenAid dishwasher that's mechanically sound — good pump, intact tub, functioning spray arms — is often worth a $100–$180 repair. The decision changes when the cost approaches 50% of a new unit. We give you the actual numbers after diagnosis and a straight opinion on whether repair makes sense. We don't push repairs that don't.",
  },
];

const nearbyCities = [
  { name: 'Rancho Cucamonga', slug: 'rancho-cucamonga' },
  { name: 'Ontario', slug: 'ontario' },
  { name: 'Chino Hills', slug: 'chino-hills' },
  { name: 'Corona', slug: 'corona' },
  { name: 'Fontana', slug: 'fontana' },
  { name: 'San Bernardino', slug: 'san-bernardino' },
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair"
    headlineCity="Upland, CA"
    subheadline="Same-day service in San Antonio Heights, North Upland, The Colonies, Euclid Ave, and throughout the City of Gracious Living. All eras of appliances, all brands, OEM parts."
    zips={zips}
    tier={3}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance Repair in Upland — The City of Gracious Living Has a Specific Appliance Profile"
    paragraphs={introParagraphs}
    bookingTitle="Upland Service"
    bookingSub="91784 · 91785 · 91786 · Same Day"
  />

  <ServicesGrid
    cityName={cityName}
    headline="What We Repair in Upland"
    services={services}
  />

  <CustomNarrative
    eyebrow={housingNarrative.eyebrow}
    headline={housingNarrative.headline}
    paragraphs={housingNarrative.paragraphs}
    subSections={housingNarrative.subSections}
    background="white"
  />

  <ServiceArea
    cityName={cityName}
    headline="Neighborhoods We Service in Upland"
    subheadline="We cover all of Upland — from San Antonio Heights and The Colonies in the north to South Upland and the Foothill Blvd corridor. No travel surcharge to any address in 91784, 91785, or 91786."
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={[]}
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Repairs in Upland"
    jobs={recentJobs}
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="Why Upland Residents Call Us"
    reasons={whyReasons}
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What Upland Customers Say"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Typical Repair Pricing in Upland"
    subhead="Every repair is quoted on-site after diagnosis. The $89 diagnostic is applied when you proceed."
    tiers={pricingTiers}
    footnote="$89 diagnostic applied to repair. No trip charge to Upland ZIP codes."
  />

  <FAQAccordion
    cityName={cityName}
    headline="Upland Appliance Repair — FAQ"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby Cities"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Need Appliance Repair in Upland Today?"
    body="Same-day service in San Antonio Heights, North Upland, The Colonies, Euclid Ave, and all Upland ZIP codes. Old homes or new, we service them all."
  />
</CityLayoutV2>
