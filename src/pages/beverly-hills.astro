---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import CustomNarrative from '../components/cities/v2/CustomNarrative.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

const citySlug = 'beverly-hills';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = 'Beverly Hills';
const zips = ['90210', '90211', '90212'];

const phoneRaw = `+1${branch.phone.replace(/\D/g, '')}`;

const title = `Appliance Repair Beverly Hills CA — Sub-Zero · Viking · Thermador | ${branch.phone}`;
const description = `Same-day appliance repair in Beverly Hills, CA. Sub-Zero, Viking, Wolf, Thermador specialists. The Flats, The Hills, Trousdale, Bel Air. Licensed, OEM parts, 90-day warranty. Call ${branch.phone}.`;
const canonical = 'https://samedayappliance.repair/beverly-hills/';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { '@type': 'City', name: 'Beverly Hills', sameAs: 'https://en.wikipedia.org/wiki/Beverly_Hills,_California' },
    { '@type': 'City', name: 'Bel Air' },
    { '@type': 'City', name: 'Holmby Hills' },
    { '@type': 'City', name: 'Century City' },
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$$',
  license: 'CA BHGS #A49573'

};

const introParagraphs = [
  "Beverly Hills is not like the rest of our service territory. The appliances are different — built-in Sub-Zero columns, 48-inch Wolf dual-fuel ranges, Thermador steam ovens, Miele dishwashers with custom panel fronts. The homes are different — gated estates in Trousdale, Holmby Hills, and Benedict Canyon where you coordinate with estate managers and household staff, not just a homeowner who answers the door. And the expectations are different, which is fair.",
  "Our technicians have been working in Beverly Hills long enough to know what that means. We show up prepared for what we'll find. We carry OEM parts for Sub-Zero, Viking, Wolf, Thermador, and Miele — not the aftermarket substitutes that affect performance and void manufacturer warranties. We work quietly, cleanly, and professionally. We don't upsell. We give you a written estimate before touching anything, and we stand behind the work with a 90-day warranty.",
  `Diagnostic fee: <strong>$89</strong> — waived when you go ahead with the repair. Luxury brand repairs may cost more due to OEM part pricing, but that's always in the estimate before we start — never a surprise on the invoice. Call <a href="tel:${phoneRaw}">${branch.phone}</a>.`,
];

const services = [
  { icon: '🧊', name: 'Refrigerator Repair', slug: 'refrigerator', issues: 'Not cooling · Built-in · Temperature inconsistency · Ice maker · Sealed system', brands: 'Sub-Zero · Wolf · True · GE Monogram · Samsung · LG' },
  { icon: '🫧', name: 'Washer Repair', slug: 'washer', issues: 'Not spinning · Not draining · Leaking · Shaking · Miele & European models', brands: 'Miele · Bosch · LG · Samsung · Whirlpool · Speed Queen' },
  { icon: '♨️', name: 'Dryer Repair', slug: 'dryer', issues: 'Not heating · Drum issues · Takes too long · Dryer vent cleaning', brands: 'Miele · Bosch · LG · Samsung · Electrolux · Whirlpool' },
  { icon: '🔥', name: 'Oven & Range Repair', slug: 'oven', issues: 'Not heating · Igniter · Temperature off · Steam oven · Dual-fuel', brands: 'Wolf · Viking · Thermador · Miele · Dacor · GE Monogram' },
  { icon: '🍽️', name: 'Dishwasher Repair', slug: 'dishwasher', issues: 'Not draining · Panel-ready · Control board · Miele electronic systems', brands: 'Miele · Bosch · Thermador · Viking · KitchenAid · GE' },
  { icon: '🍷', name: 'Wine Cooler & Cellar Repair', slug: 'wine-cooler', issues: 'Temperature fluctuation · Cooling failure · Vibration · Built-in units', brands: 'Sub-Zero · Thermador · EuroCave · Liebherr · True · U-Line' },
  { icon: '🔆', name: 'Cooktop Repair', slug: 'cooktop', issues: 'Burner issues · Induction not heating · Precision calibration', brands: 'Wolf · Thermador · Viking · Miele · GE Monogram · Bosch' },
  { icon: '🧊', name: 'Ice Machine Repair', slug: 'ice-maker', issues: 'Not producing · Inconsistent output · Leaking · Under-counter units', brands: 'Sub-Zero · True · U-Line · GE Monogram · Scotsman' },
];

const luxuryBrandsNarrative = {
  eyebrow: 'LUXURY APPLIANCE SPECIALISTS',
  headline: 'Sub-Zero, Wolf, Viking & Thermador Repair in Beverly Hills',
  paragraphs: [
    "These are the brands that define Beverly Hills kitchens — and they require a fundamentally different level of service than standard appliances. A Sub-Zero built-in refrigerator with a failed sealed system isn't the same repair as a Whirlpool French door. A Wolf dual-fuel range with a failing ignition module needs someone who actually knows how Wolf's burner technology works, not someone who watched a YouTube video.",
    "Our technicians are trained specifically on these luxury systems — Sub-Zero's dual-evaporator architecture, Wolf's precision gas valve and star burner configurations, Thermador's ProGrand range quirks, Miele's electronic control platforms. We've serviced these appliances in The Flats off Rodeo and Carmelita, in the hillside estates in Trousdale and Benedict Canyon, in the Wilshire Corridor high-rises. We know these machines.",
    "Brands we service: Sub-Zero · Wolf · Viking · Thermador · Miele · Dacor · GE Monogram · True Residential · Bosch · Fisher & Paykel.",
  ]
};

const repairOrReplaceNarrative = {
  eyebrow: 'HONEST ADVICE ON LUXURY APPLIANCES',
  headline: 'Should You Repair or Replace a Sub-Zero or Wolf?',
  paragraphs: [
    "The standard \"50% rule\" — don't repair if it costs more than half the replacement value — almost never applies to luxury built-in appliances. Here's why our technicians think about it differently in Beverly Hills.",
    "A Sub-Zero built-in refrigerator isn't just an appliance — it's a kitchen component. Replacing it means sourcing a new unit, waiting weeks for delivery, potentially cutting into cabinetry, and doing a full installation. The disruption and cost of replacement is often three to four times what people expect. A Sub-Zero or Wolf unit that's 10–12 years old and needs a $400–600 repair is almost always worth fixing. These machines are engineered to run 20+ years with proper care.",
    "Our technicians give you a straight answer: what's the repair, what does it cost, how long should this appliance last after the repair, and what's our honest recommendation. We don't make money by telling you to replace things — we make money by doing repairs people trust us to come back for.",
    "Typical lifespans: Sub-Zero Refrigerator — 20+ years · Wolf Range — 20+ years · Thermador Cooktop — 15–20 years · Miele Dishwasher — 15–20 years · Viking Range — 15–20 years · Standard Brands — 10–15 years.",
  ]
};

const neighborhoods = [
  { name: 'The Flats (south BH)', zip: '90210', featured: true },
  { name: 'The Hills (north BH)', zip: '90210', featured: true },
  { name: 'Trousdale Estates', zip: '90210', featured: true },
  { name: 'Benedict Canyon', zip: '90210' },
  { name: 'Coldwater Canyon', zip: '90210' },
  { name: 'Wilshire Corridor', zip: '90211' },
  { name: 'South Beverly Hills', zip: '90212' },
  { name: 'Beverly Grove', zip: '90211' },
];

const recentJobs = [
  {
    appliance: 'Sub-Zero Built-In',
    location: 'The Flats, 90210',
    quote: '"Sub-Zero running constantly, temperatures drifting up"',
    description: '48-inch built-in column with a failing evaporator fan motor. The compressor was working overtime trying to compensate — which is exactly how you get a compressor failure if you wait too long. Our tech replaced the fan motor with an OEM Sub-Zero part, cleaned the condenser coils which had significant dust buildup inside the cabinet, and checked the door gasket seal on both compartments. Back to spec temperatures within 90 minutes of arrival.',
    outcome: '✓ Same day · OEM Sub-Zero fan motor · Coil cleaning done'
  },
  {
    appliance: 'Wolf Range',
    location: 'Trousdale Estates, 90210',
    quote: '"Oven not reaching temperature, one burner dead"',
    description: "Wolf dual-fuel, 48-inch ProRange. The oven igniter was drawing weak current — a Wolf-specific issue that causes intermittent heating problems before full failure. The dead surface burner had a failed igniter module. Replaced both igniters with OEM Wolf parts, tested oven temperature against a calibrated probe, recalibrated to factory spec (it was running 30°F low). All six burners confirmed. Homeowner had been adjusting recipes to compensate for months — now they don't have to.",
    outcome: '✓ Same day · OEM Wolf parts · Oven recalibrated to factory spec'
  },
  {
    appliance: 'Miele Dishwasher',
    location: 'Benedict Canyon, 90210',
    quote: '"F85 error, won\'t complete cycle"',
    description: 'F85 on Miele is a drain pump or drain path fault. Found a blocked drain pump impeller — a small bone fragment had made it through the filter and lodged in the pump. Cleared it, tested the impeller rotation, ran a full diagnostic cycle. The panel-ready unit had custom cabinetry tight around it — our tech used the proper Miele service procedure to avoid pulling the entire unit. Took 45 minutes.',
    outcome: '✓ Same day · No cabinetry damage · Full cycle confirmed'
  },
  {
    appliance: 'Thermador Cooktop',
    location: 'Holmby Hills, 90024',
    quote: '"Star burner sparking continuously after cleaning"',
    description: "This one's very common after kitchen cleaning — moisture gets into the Thermador Star burner igniter system and causes constant sparking. In this case the igniter caps had also been seated slightly off after cleaning, creating a short. Our tech dried and reseated all burner caps, replaced two worn igniter electrodes, and confirmed all five burners. Took under an hour. The housekeeper got a quick tutorial on how to dry the burners after cleaning.",
    outcome: '✓ Same day · Two igniters replaced · Housekeeper briefed'
  },
];

const whyReasons = [
  {
    iconKey: 'parts' as const,
    title: 'We Know These Machines',
    body: 'Sub-Zero, Wolf, Thermador, Viking, Miele — we work on these brands constantly in Beverly Hills. We know their failure patterns, carry their OEM parts, and diagnose them correctly on the first visit.'
  },
  {
    iconKey: 'shield' as const,
    title: 'Written Estimate, No Surprises',
    body: "Luxury brand repairs can be expensive — that's the nature of OEM parts for high-end systems. We give you the full picture in writing before we start anything. The $89 diagnostic fee disappears when you approve the repair."
  },
  {
    iconKey: 'team' as const,
    title: 'We Work in Estates Professionally',
    body: 'Gated properties, estate managers, household staff, tight access windows — our technicians are experienced with all of it. We coordinate professionally, work quietly, and leave the space exactly as we found it.'
  },
  {
    iconKey: 'clock' as const,
    title: '90-Day Warranty, OEM Only',
    body: 'Every repair we do in Beverly Hills carries a 90-day warranty. We use genuine OEM parts — never aftermarket substitutes that compromise performance or void manufacturer warranties. California licensed, BBB A+ rated.'
  },
];

const testimonials = [
  {
    stars: 5,
    text: "\"Our Sub-Zero built-in had been running constantly for weeks. Same Day Appliance Repair came to our home in The Flats same afternoon, diagnosed the issue immediately, had the OEM part on the truck, and fixed it cleanly. They also cleaned the coils inside the cabinet — something I didn't know needed doing. Very professional.\"",
    author: '— Diana M., The Flats, Beverly Hills'
  },
  {
    stars: 5,
    text: "\"Wolf range at our Trousdale property — oven wasn't heating correctly and one burner was dead. Technician came same day, had all the OEM Wolf parts, recalibrated the oven after replacing the igniter. Turns out it had been running 30 degrees low for months. Now everything is dialed in perfectly.\"",
    author: '— Robert H., Trousdale Estates, Beverly Hills'
  },
  {
    stars: 5,
    text: '"Our estate manager scheduled the repair and was very impressed by how the technician handled the service call — coordinated access perfectly, worked cleanly in our Miele kitchen, and explained everything clearly. The kind of professional service this property deserves."',
    author: '— C. Thompson (via Estate Manager), Benedict Canyon'
  },
];

const pricingTiers = [
  { appliance: 'Refrigerator (standard)', range: '$200–$450', note: 'Fan motor, thermostat, ice maker, compressor relay' },
  { appliance: 'Sub-Zero / Wolf', range: '$300–$700+', note: 'OEM parts for luxury brands · Sealed systems · Built-ins', featured: true },
  { appliance: 'Washer / Dryer', range: '$150–$400', note: 'Miele & European models may cost more · OEM parts' },
  { appliance: 'Oven / Range', range: '$200–$500+', note: 'Wolf, Viking, Thermador igniters · Calibration · Gas valves' },
  { appliance: 'Dishwasher', range: '$150–$400', note: 'Panel-ready · Miele electronic systems · Drain pump' },
  { appliance: 'Diagnostic Fee', range: '$89', note: 'Waived when you proceed with the repair' },
];

const faqs = [
  {
    question: 'Do you repair Sub-Zero, Viking, and Thermador appliances in Beverly Hills?',
    answer: 'Yes. Our technicians work in Beverly Hills constantly — the estates in The Flats and the hills, the properties in Trousdale, Holmby Hills, and Benedict Canyon. Sub-Zero, Viking, Wolf, Thermador, and Miele are what we see most here. We carry OEM parts for these brands on every service vehicle and are trained on their specific systems.'
  },
  {
    question: 'Do you offer same-day appliance repair in Beverly Hills?',
    answer: 'Yes. Call before noon and our technicians can typically be at your Beverly Hills home the same afternoon. We serve all Beverly Hills ZIP codes — 90210, 90211, and 90212 — as well as Bel Air, Holmby Hills, Trousdale Estates, and Century City.'
  },
  {
    question: 'Is it worth repairing a high-end Sub-Zero or Wolf appliance?',
    answer: "In most cases, yes — and more so than for standard appliances. Sub-Zero refrigerators and Wolf ranges are built to last 20+ years with proper maintenance. The 50% rule (don't repair if it costs more than half of replacement) rarely applies to luxury built-ins, where replacement means a full renovation project. Our technicians give you an honest recommendation based on the appliance's age, condition, and what the actual repair entails."
  },
  {
    question: 'What is your diagnostic fee in Beverly Hills?',
    answer: 'Our diagnostic fee is $89, waived when you proceed with the repair. For luxury brands (Sub-Zero, Viking, Thermador, Wolf), repair costs may run higher due to OEM part pricing — but we give you a full written estimate before starting any work. No surprises.'
  },
  {
    question: 'Do you provide discreet service for private estates in Beverly Hills?',
    answer: 'Yes. Our technicians work in Beverly Hills estates regularly and are experienced with gated properties, estate managers, and household staff. We coordinate access and scheduling professionally, work quietly and cleanly, and respect the privacy of the household.'
  },
  {
    question: 'What warranty do you offer on appliance repairs in Beverly Hills?',
    answer: 'All repairs come with a 90-day warranty on parts and labor. We use genuine OEM parts — never aftermarket substitutes. If the same issue returns within 90 days, we come back at no charge.'
  },
  {
    question: 'Do you also serve Bel Air, Holmby Hills, and Century City?',
    answer: "Yes. Our Beverly Hills service area extends to Bel Air, Holmby Hills, Trousdale Estates, Benedict Canyon, Coldwater Canyon, Century City, Westwood, and Beverly Grove. If you're in the 90210, 90077, or adjacent ZIP codes, we're your closest team."
  },
];

const nearbyCities = [
  { name: 'West Hollywood', slug: 'west-hollywood' },
  { name: 'Brentwood', slug: 'brentwood' },
  { name: 'Santa Monica', slug: 'santa-monica' },
  { name: 'Los Angeles', slug: 'los-angeles' },
  { name: 'Culver City', slug: 'culver-city' },
  { name: 'Pasadena', slug: 'pasadena' },
  { name: 'Hollywood', slug: 'hollywood' },
  { name: 'Los Feliz', slug: 'los-feliz' },
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair"
    headlineCity="Beverly Hills, CA"
    subheadline="Sub-Zero, Viking, Wolf, Thermador, Miele — these are the appliances we work on every day in Beverly Hills. Our technicians cover The Flats, The Hills, Trousdale Estates, Benedict Canyon, and Bel Air. Same-day service, OEM parts, 90-day warranty."
    zips={zips}
    tier={1}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Beverly Hills Appliance Repair — How We Actually Work"
    paragraphs={introParagraphs}
    bookingTitle="Schedule a Beverly Hills Visit"
    bookingSub="Same-day available · 90210 · 90211 · 90212"
  />

  <CustomNarrative
    eyebrow={luxuryBrandsNarrative.eyebrow}
    headline={luxuryBrandsNarrative.headline}
    paragraphs={luxuryBrandsNarrative.paragraphs}
    background="black"
  />

  <ServicesGrid
    cityName={cityName}
    headline="What We Repair in Beverly Hills"
    subhead="Built-ins, luxury brands, and everyday appliances — all of it"
    services={services}
  />

  <ServiceArea
    cityName={cityName}
    headline="We Work Across All of Beverly Hills & the Estate Areas"
    subheadline="90210 · 90211 · 90212 — and beyond into Bel Air, Holmby Hills, and the canyons"
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={['Rodeo Drive area', 'Sunset Blvd (BH)', 'Wilshire Blvd', 'Santa Monica Blvd', 'Carmelita Ave', 'Lexington Rd', 'Loma Vista Dr', 'Mulholland Dr']}
  />

  <CustomNarrative
    eyebrow={repairOrReplaceNarrative.eyebrow}
    headline={repairOrReplaceNarrative.headline}
    paragraphs={repairOrReplaceNarrative.paragraphs}
    background="gray"
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Repairs Our Team Did in Beverly Hills"
    jobs={recentJobs}
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="Why Beverly Hills Homeowners Call Us"
    reasons={whyReasons}
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What Beverly Hills Clients Say"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Appliance Repair Costs in Beverly Hills"
    subhead="Written estimate before we start. $89 diagnostic — waived with repair. OEM parts only."
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="Questions Beverly Hills Clients Ask"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby Areas"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Need Appliance Repair in Beverly Hills?"
    body="Same-day service · OEM parts · 90-day warranty · Diagnostic $89 waived with repair. We pick up the phone."
  />
</CityLayoutV2>
