  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Dryer Repair",
  "name": "Dryer Repair — Same Day Appliance Repair",
  "description": "Same-day dryer repair across Los Angeles, Orange, Ventura, San Bernardino, and Riverside counties. Gas, electric, heat pump, condenser, stackable. Dryer vent inspection included with every call.",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Same Day Appliance Repair",
    "url": "https://samedayappliance.repair/",
    "telephone": phone,
    "priceRange": "$$",
    "openingHoursSpecification": [
      { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "07:00", "closes": "21:00" },
      { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Saturday"], "opens": "08:00", "closes": "19:00" },
      { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Sunday"], "opens": "09:00", "closes": "17:00" }
    ],
    "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.6", "reviewCount": "37", "bestRating": "5" }
  },
  "areaServed": [
    { "@type": "AdministrativeArea", "name": "Los Angeles County" },
    { "@type": "AdministrativeArea", "name": "Orange County" },
    { "@type": "AdministrativeArea", "name": "Ventura County" },
    { "@type": "AdministrativeArea", "name": "San Bernardino County" },
    { "@type": "AdministrativeArea", "name": "Riverside County" }
  ],
  "offers": {
    "@type": "Offer",
    "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, applied toward repair" }
  }
})} />

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "How much does dryer repair cost?",
      "acceptedAnswer": { "@type": "Answer", "text": "Our diagnostic fee is $89, applied to the repair once you approve the work. Most dryer repairs run between $120 and $300. A thermal fuse or door switch replacement is toward the lower end. Heating element, motor, or control board replacements on premium brands like Miele or Thermador run higher. We give you a full written estimate before any work begins." } },
    { "@type": "Question", "name": "Which areas of Southern California do you cover?",
      "acceptedAnswer": { "@type": "Answer", "text": "All five counties: Los Angeles, Orange, Ventura, San Bernardino, and Riverside. We dispatch from 8 service territories — West Hollywood (HQ), Los Angeles, Beverly Hills, Pasadena, Thousand Oaks, Irvine, Rancho Cucamonga, and Temecula — so the technician on your call is coming from the closest one. Same-day is our standard." } },
    { "@type": "Question", "name": "My dryer runs but produces no heat — what's wrong?",
      "acceptedAnswer": { "@type": "Answer", "text": "On an electric dryer, a blown thermal fuse or failed heating element are the two most common causes. The thermal fuse blows for a reason — usually a clogged vent. We replace the fuse and check the vent before leaving, because a fuse replaced without clearing the vent will blow again within weeks. On a gas dryer, no heat usually means the igniter, gas valve coils, or thermal fuse." } },
    { "@type": "Question", "name": "Is a clogged dryer vent a fire hazard?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes — dryer fires are one of the leading causes of house fires in the US, and lint buildup in the vent duct is the primary reason. A clogged vent traps heat, forces the dryer to run longer, and creates conditions where lint can ignite. In SoCal condos and apartments with long or kinked duct runs, this risk is higher. We include a vent inspection with every dryer service call." } },
    { "@type": "Question", "name": "Do you repair gas dryers?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Gas and electric dryers are both standard for us. Gas dryer repairs involve the igniter, flame sensor, gas valve coils, and thermal fuse — components our technicians carry parts for. We do not work on the gas supply line itself, but everything from the dryer side of the connection is within our scope." } },
    { "@type": "Question", "name": "Do you repair heat pump and condenser (ventless) dryers?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Heat pump dryers (Miele T1, Bosch 800 Series, LG WashTower ventless) and condenser dryers are increasingly common in renovated SoCal homes where running a new vent isn't feasible. They use a closed refrigerant loop or condensation system instead of an external vent. We carry parts and have the diagnostic tooling for both — including the heat pump module on Miele T1 units." } },
    { "@type": "Question", "name": "Can you repair my dryer the same day?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Dryer repairs are one of our most straightforward same-day jobs — the failure modes are well-defined and the parts are compact. We carry thermal fuses, heating elements, drum belts, and idler pulleys for the brands we see most often. Call before noon and we can typically be there the same afternoon." } },
    { "@type": "Question", "name": "My dryer takes two or three cycles to dry clothes — is that a vent issue?",
      "acceptedAnswer": { "@type": "Answer", "text": "Almost certainly yes. Clothes that won't dry in one cycle are the clearest symptom of restricted airflow — either a clogged lint screen, a partially blocked vent duct, or a kinked flexible duct behind the machine. The dryer itself may be working fine. We check the vent system first because it's the most common cause and the cheapest fix." } },
    { "@type": "Question", "name": "Do you repair stackable dryers in apartments and condos?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Stacked dryer-over-washer configurations in laundry closets are one of the most common setups we work on. The vent run is often shorter and more constricted than in a standalone unit — which makes lint buildup faster. We come prepared for the clearance constraints and always check the vent duct condition on stackable calls." } },
    { "@type": "Question", "name": "When does it make sense to repair vs replace a dryer?",
      "acceptedAnswer": { "@type": "Answer", "text": "On a basic $700 vented dryer over 10 years old, a $400 control board replacement is borderline — replacing usually wins. On a $4,000 Miele T1 heat pump, even a $400 sensor is an obvious repair (these are built for 15-20 year service lives). Mid-market gas/electric dryers (Samsung, LG, Whirlpool, Maytag, GE) follow the 50% rule — repair under half the replacement cost, replace over. We tell you straight which side of the line your unit falls on." } }
  ]
})} />

