---
// src/pages/services/dryer-repair.astro
// Phase 3 (Tier 1) — neutral multi-county hub.
// Per audit-output/rewrite-plans/dryer.md.

import Layout from '../../layouts/Layout.astro';
import ServiceHero from '../../components/ServiceHero.astro';
import { MAIN_PHONE } from '../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;

const title = "Dryer Repair — Same-Day Service Across Southern California | Same Day Appliance Repair";
const description = "Same-day dryer repair across LA, Orange, Ventura, San Bernardino & Riverside counties. Gas, electric, heat pump, condenser, stackable. Dryer vent inspection included. BHGS #A49573, $89 diagnostic, 90-day warranty. Call (424) 325-0520.";
---

