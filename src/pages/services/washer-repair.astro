---
// src/pages/services/washer-repair.astro
// Phase 3 (Tier 1), neutral multi-county hub.
// Per audit-output/rewrite-plans/washer.md.

import Layout from '../../layouts/Layout.astro';
import ServiceHero from '../../components/ServiceHero.astro';
import { MAIN_PHONE } from '../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;

const title = "Washer Repair, Same-Day Service Across Southern California";
const description = "Same-day washer repair across LA, OC, Ventura, SB, Riverside. Front-load, top-load, stackable. Miele, Bosch, Speed Queen, LG, Samsung. $89 dx.";
---

<Layout title={title} description={description}>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Washer Repair",
  "name": "Washer Repair, Same Day Appliance Repair",
  "description": "Same-day washer repair across Los Angeles, Orange, Ventura, San Bernardino, and Riverside counties. Front-load, top-load, stackable, all major and premium brands.",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Same Day Appliance Repair",
    "url": "https://samedayappliance.repair/",
    "telephone": phone,
    "priceRange": "$$",
    "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "08:00", "closes": "20:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "00:00", "closes": "00:00" }
      ]
  },
  "areaServed": [
    { "@type": "AdministrativeArea", "name": "Los Angeles County" },
    { "@type": "AdministrativeArea", "name": "Orange County" },
    { "@type": "AdministrativeArea", "name": "Ventura County" },
    { "@type": "AdministrativeArea", "name": "San Bernardino County" },
    { "@type": "AdministrativeArea", "name": "Riverside County" }
  ],
  "offers": {
    "@type": "Offer",
    "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, applied toward repair" }
  }
})} />

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "How much does washer repair cost?",
      "acceptedAnswer": { "@type": "Answer", "text": "Our diagnostic fee is $89, applied toward the repair the moment you approve the work. Most washer repairs run between $130 and $350 depending on the part and brand. Drain pump and lid switch replacements are on the lower end. Control board, motor, or tub-bearing work on premium brands like Miele or Bosch run higher. We give you a full written estimate before any work begins, what we quote is what appears on the invoice." } },
    { "@type": "Question", "name": "Which areas of Southern California do you cover?",
      "acceptedAnswer": { "@type": "Answer", "text": "All five counties: Los Angeles, Orange, Ventura, San Bernardino, and Riverside. We dispatch from 8 service territories, West Hollywood (HQ), Los Angeles, Beverly Hills, Pasadena, Thousand Oaks, Irvine, Rancho Cucamonga, and Temecula, so the technician on your call is coming from the closest one. Same-day is our standard." } },
    { "@type": "Question", "name": "Can you repair my washer the same day?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. We have technicians running washer calls daily across all 5 SoCal counties. Call before noon and we can typically be there that afternoon. We stock parts for the brands we see most often, Samsung, LG, Whirlpool, Miele, Bosch, so most repairs are completed on the first visit." } },
    { "@type": "Question", "name": "Do you repair stackable washers in apartments and condos?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes, stackable units in closets and laundry alcoves are one of the most common washer calls we get. Working in a tight laundry closet requires a specific approach. Our technicians come prepared for it: the right tools, the right sequence for accessing components without damaging cabinetry, and experience with the brands commonly spec'd in SoCal condos, LG, Electrolux, Bosch, Samsung." } },
    { "@type": "Question", "name": "My front-load washer smells like mold, can you fix that?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Front-load washers in apartments and condos with limited ventilation are prone to mold buildup on the rubber door gasket. We clean the drum and gasket, inspect for tears or deterioration that trap water, and check whether the door seal needs replacement. We also look at the drain path to make sure residual water isn't sitting where it shouldn't be." } },
    { "@type": "Question", "name": "My washer won't drain, what's usually wrong?",
      "acceptedAnswer": { "@type": "Answer", "text": "The drain pump is the most common culprit, especially if you hear the motor running but water stays in the drum. It could also be a clogged pump filter, on front-loaders, this is the small access panel near the bottom front of the machine, and it's frequently neglected. A blocked drain hose, kinked outlet, or a faulty lid switch on top-loaders are also common. Our technicians diagnose before replacing parts." } },
    { "@type": "Question", "name": "When does it make sense to repair vs replace a washer?",
      "acceptedAnswer": { "@type": "Answer", "text": "Rule of thumb (the 50% rule): if the repair is less than half the cost of a comparable new machine, repair. If a $1,200 mid-market washer needs $700 in repairs and is over 8 years old, replace. Premium brands (Miele, Bosch, Speed Queen, Electrolux Professional) flip the math, they're built for 15-20 year service lives and worth repairing well past year 10. We tell you straight which side of the line your unit falls on." } },
    { "@type": "Question", "name": "What does the 90-day warranty cover on washer repairs?",
      "acceptedAnswer": { "@type": "Answer", "text": "Our 90-day warranty covers both the part and the labor on every repair we complete. If the same issue returns within that period, we come back at no charge. That's in writing before we leave." } },
    { "@type": "Question", "name": "Do you repair high-efficiency (HE) and commercial washers?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. High-efficiency front-load and top-load washers are the majority of what we service. For commercial washers, laundromat units, multi-family building machines, hotel laundry, our commercial diagnostic fee is $120. We work on Speed Queen, Electrolux Professional, Huebsch, and other commercial-grade brands." } }
  ]
})} />

<style>
  :root {
    --red: #C8102E;
    --black: #0a0a0a;
    --gray: #f5f5f5;
    --border: #e2e2e2;
    --text: #1a1a1a;
    --muted: #6b6b6b;
  }
  .section { padding: 72px 24px; }
  .section-gray { background: var(--gray); }
  .section-black { background: var(--black); color: #fff; }
  .container { max-width: 1100px; margin: 0 auto; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  h2.section-title { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; margin: 0 0 16px; line-height: 1.2; }
  .section-black h2.section-title { color: #fff; }
  .lead { font-size: 1.05rem; line-height: 1.75; color: var(--text); max-width: 720px; }
  .section-black .lead { color: #ccc; }
  .intro-grid { display: grid; grid-template-columns: 1fr 320px; gap: 48px; align-items: start; }
  @media (max-width: 768px) { .intro-grid { grid-template-columns: 1fr; } }
  .intro-body p { margin: 0 0 18px; font-size: 1.05rem; line-height: 1.8; color: var(--text); }
  .tip-box { background: #fff8e7; border: 1px solid #f0d070; border-radius: 8px; padding: 18px 20px; margin-top: 28px; }
  .tip-box .tip-label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #a07000; margin-bottom: 8px; }
  .tip-box p { font-size: 0.95rem; color: #5a4000; margin: 0; line-height: 1.65; }
  .tip-box-blue { background: #f0f7ff; border: 1px solid #b8d4f0; border-radius: 8px; padding: 18px 20px; margin-top: 18px; }
  .tip-box-blue .tip-label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #1a5a9a; margin-bottom: 8px; }
  .tip-box-blue p { font-size: 0.95rem; color: #1a3a5a; margin: 0; line-height: 1.65; }
  .diy-box { background: #f0fdf4; border: 1px solid #86efac; border-radius: 8px; padding: 22px 24px; margin-top: 18px; }
  .diy-box .diy-label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #166534; margin-bottom: 12px; }
  .diy-box h3 { font-size: 1.05rem; margin: 0 0 8px; color: #14532d; }
  .diy-box ol { margin: 12px 0 0; padding-left: 22px; color: #14532d; font-size: 0.95rem; line-height: 1.7; }
  .diy-box ol li { margin-bottom: 8px; }
  .diy-box ol li strong { color: #14532d; }
  .sticky-cta { position: sticky; top: 24px; background: var(--black); border-radius: 10px; padding: 28px 24px; color: #fff; text-align: center; }
  .sticky-cta .cta-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: #aaa; margin-bottom: 14px; }
  .sticky-cta .cta-phone { font-size: 1.5rem; font-weight: 800; color: #fff; text-decoration: none; display: block; margin-bottom: 12px; }
  .sticky-cta .btn-cta { display: block; background: var(--red); color: #fff; padding: 14px; border-radius: 5px; font-weight: 700; text-decoration: none; font-size: 0.95rem; margin-bottom: 10px; }
  .sticky-cta .cta-sub { font-size: 0.82rem; color: #888; }
  .cta-divider { border: none; border-top: 1px solid #222; margin: 18px 0; }
  .cta-detail { font-size: 0.85rem; color: #aaa; text-align: left; }
  .cta-detail li { margin-bottom: 6px; list-style: none; padding-left: 18px; position: relative; }
  .cta-detail li::before { content: "✓"; position: absolute; left: 0; color: var(--red); font-weight: 700; }
  .problems-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 20px; margin-top: 36px; }
  .problem-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 24px 20px; }
  .problem-card h3 { font-size: 1rem; font-weight: 700; margin: 0 0 10px; color: var(--text); }
  .problem-card p { font-size: 0.9rem; color: var(--muted); line-height: 1.6; margin: 0 0 10px; }
  .problem-card ul { margin: 8px 0 0; padding-left: 18px; font-size: 0.85rem; color: var(--muted); line-height: 1.55; }
  .brands-grid { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 28px; }
  .brand-chip { background: #fff; border: 1px solid var(--border); border-radius: 4px; padding: 8px 18px; font-size: 0.88rem; font-weight: 600; color: var(--text); }
  .brand-chip.dark { background: #1a1a1a; color: #ddd; border-color: #333; }
  .repairs-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 24px; margin-top: 36px; }
  .repair-card { background: #111; border: 1px solid #222; border-radius: 8px; padding: 24px 20px; }
  .repair-card .repair-title { font-size: 0.85rem; font-weight: 700; color: #aaa; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 8px; }
  .repair-card h3 { font-size: 1rem; font-weight: 700; color: #fff; margin: 0 0 10px; line-height: 1.3; }
  .repair-card p { font-size: 0.88rem; color: #888; line-height: 1.6; margin: 0 0 14px; }
  .repair-card .repair-detail { font-size: 0.8rem; color: #555; border-top: 1px solid #1e1e1e; padding-top: 12px; }
  .pricing-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 20px; margin-top: 36px; }
  .price-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 24px 20px; text-align: center; }
  .price-card .price-label { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); margin-bottom: 10px; }
  .price-card .price-amount { font-size: 2rem; font-weight: 800; color: var(--text); line-height: 1; margin-bottom: 8px; }
  .price-card .price-desc { font-size: 0.85rem; color: var(--muted); line-height: 1.5; }
  .price-note { margin-top: 20px; font-size: 0.9rem; color: var(--muted); line-height: 1.6; }
  .rvr-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 32px; }
  @media (max-width: 768px) { .rvr-grid { grid-template-columns: 1fr; } }
  .rvr-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 24px 22px; }
  .rvr-card h3 { font-size: 1.05rem; font-weight: 700; margin: 0 0 12px; color: var(--text); }
  .rvr-card .rvr-verdict { display: inline-block; font-size: 0.7rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.12em; padding: 3px 10px; border-radius: 3px; margin-bottom: 12px; }
  .rvr-card .rvr-verdict.repair { background: #dcfce7; color: #166534; }
  .rvr-card .rvr-verdict.judge { background: #fef3c7; color: #92400e; }
  .rvr-card p { font-size: 0.92rem; color: var(--muted); line-height: 1.65; margin: 0 0 8px; }
  .rvr-card ul { font-size: 0.9rem; color: var(--muted); line-height: 1.65; margin: 8px 0 0; padding-left: 20px; }
  .faq-list { margin-top: 36px; }
  .faq-item { border-bottom: 1px solid var(--border); padding: 22px 0; }
  .faq-item:first-child { border-top: 1px solid var(--border); }
  .faq-item h3 { font-size: 1rem; font-weight: 700; color: var(--text); margin: 0 0 10px; }
  .faq-item p { font-size: 0.95rem; color: var(--muted); line-height: 1.7; margin: 0; }
  .nearby-links { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 24px; }
  .nearby-links a { background: #fff; border: 1px solid var(--border); border-radius: 4px; padding: 8px 16px; font-size: 0.87rem; color: var(--text); text-decoration: none; font-weight: 500; }
  .nearby-links a:hover { border-color: var(--red); color: var(--red); }
  .counties-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 20px; margin-top: 32px; }
  .county-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 20px 22px; }
  .county-card a.county-name { font-size: 0.95rem; font-weight: 700; color: var(--text); text-decoration: none; display: block; margin-bottom: 8px; }
  .county-card a.county-name:hover { color: var(--red); }
  .county-card .county-cities { font-size: 0.85rem; color: var(--muted); line-height: 1.6; }
  .county-card .county-cities a { color: var(--muted); text-decoration: none; }
  .county-card .county-cities a:hover { color: var(--red); text-decoration: underline; }
  .all-cities-link { display: inline-block; margin-top: 22px; font-size: 0.95rem; color: var(--red); text-decoration: none; font-weight: 700; border-bottom: 1px solid var(--red); padding-bottom: 2px; }
  .bottom-cta { background: var(--black); color: #fff; padding: 72px 24px; text-align: center; }
  .bottom-cta h2 { font-size: clamp(1.8rem, 3vw, 2.4rem); font-weight: 800; margin: 0 0 16px; }
  .bottom-cta p { color: #aaa; margin: 0 0 32px; font-size: 1.05rem; }
  .cta-row { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 16px 34px; border-radius: 5px; font-size: 1rem; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 16px 34px; border-radius: 5px; font-size: 1rem; font-weight: 600; text-decoration: none; border: 2px solid rgba(255,255,255,0.35); }
  .type-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 24px; margin-top: 32px; }
  .type-card { background: #111; border: 1px solid #222; border-radius: 8px; padding: 26px 22px; }
  .type-card .type-icon { font-size: 1.8rem; margin-bottom: 12px; }
  .type-card h3 { font-size: 1rem; font-weight: 700; color: #fff; margin: 0 0 10px; }
  .type-card p { font-size: 0.88rem; color: #888; line-height: 1.65; margin: 0; }
  .type-card ul { margin: 10px 0 0; padding-left: 18px; }
  .type-card ul li { font-size: 0.85rem; color: #777; margin-bottom: 4px; }
</style>

<ServiceHero
  title="Washer Repair Across Southern California"
  subtitle="Front-load, top-load, stackable washer-dryer combo in a closet, our technicians run washing machine calls daily across LA, Orange, Ventura, San Bernardino, and Riverside counties and carry parts for the brands they see most."
  heroImageTitle="Washer Repair"
/>

<!-- INTRO -->
<section class="section">
  <div class="container">
    <div class="intro-grid">
      <div class="intro-body">
        <p class="section-number">01, About This Service</p>
        <h2 class="section-title">The washer breakdown is never convenient. We know.</h2>

        <p>A washing machine going out means laundry piling up, a trip to the laundromat, and, if you live in an apartment or condo, the particular stress of a broken stackable unit crammed into a closet that barely fits one person, let alone a technician with tools.</p>

        <p>Washer calls are one of the higher-volume repairs we run across SoCal. From a West Hollywood high-rise stackable to a Newport Beach front-loader in a renovated kitchen, from a Thousand Oaks family laundry room with a top-loader to a Temecula commercial multi-family building, we see the full range. Our technicians know the configurations, the brands common in each market, and what fails first on each.</p>

        <p>We carry parts on the van. For the Samsung, LG, Whirlpool, Bosch, Miele, and Speed Queen units that make up the majority of washer calls, we can usually complete the repair on the first visit. No "we need to order the part", unless it's something genuinely unusual.</p>

        <div class="tip-box">
          <div class="tip-label">🏢 Stackable &amp; Condo Units</div>
          <p>A significant portion of washer calls involve stackable units in closets or laundry alcoves with minimal clearance, common in WeHo high-rises, Newport Beach condos, and Pasadena bungalow conversions. Working in tight spaces requires the right approach. If you have a stacked unit, let us know when you call so we send the right technician with the right tools.</p>
        </div>

        <div class="tip-box-blue">
          <div class="tip-label">🌀 Front-Load Mold Note</div>
          <p>Front-load washers in apartments with limited ventilation are prone to mold and odor buildup on the door gasket. It's not a major repair, but it's worth addressing, a torn or mold-saturated gasket can also cause water leaks. We inspect the gasket on every front-load service call.</p>
        </div>

        <div class="diy-box">
          <div class="diy-label">🔧 Before You Call, 4 Quick Checks</div>
          <h3>Try these in 10 minutes, they fix maybe 25% of "won't drain" / "won't start" calls before we even dispatch.</h3>
          <ol>
            <li><strong>Clean the drain pump filter.</strong> Front-loaders have an access panel near the bottom front. You'll find lint, coins, hair clips. Empty it, run a drain cycle, see if the issue clears.</li>
            <li><strong>Reset the breaker and the machine.</strong> Power-cycle the machine at the wall for 60 seconds. Modern washers occasionally lock up on their control board; a hard reset clears it.</li>
            <li><strong>Check the door latch / lid switch.</strong> Front-loader: door must click positively to register locked. Top-loader: lid switch needs to spring back firmly. If either is mushy, that's your problem.</li>
            <li><strong>Level the machine.</strong> Vibration / banging usually means a leg loosened or the machine walked. Adjust the feet, lock the nuts; bubble level should sit dead center.</li>
          </ol>
        </div>
      </div>

      <aside class="sticky-cta">
        <div class="cta-label">Same Day Washer Repair</div>
        <a href={phoneHref} class="cta-phone">{phone}</a>
        <a href={phoneHref} class="btn-cta">Call Now, We Pick Up</a>
        <a href="/book" class="btn-cta" style="background:#222; margin-top:-4px;">Book Online</a>
        <div class="cta-sub">Mon–Fri 7am–9pm · Sat Mon–Sat 8am–8pm · Sun closed · Phone answered 24/7</div>
        <hr class="cta-divider" />
        <ul class="cta-detail">
          <li>$89 diagnostic, applied to repair</li>
          <li>90-day warranty on parts &amp; labor</li>
          <li>OEM parts for all major brands</li>
          <li>Written estimate before we start</li>
          <li>Stackable units welcome</li>
          <li>BHGS #A49573, EPA 608 Universal certified #1346255700410, · Insured</li>
        </ul>
      </aside>
    </div>
  </div>
</section>

<!-- MACHINE TYPES -->
<section class="section section-black">
  <div class="container">
    <p class="section-number">02, Machine Types We Service</p>
    <h2 class="section-title">Every washing machine configuration in the SoCal market</h2>
    <p class="lead">The same failure can present differently depending on whether you have a front-loader, top-loader, washer-dryer combo, or stacked unit. Our technicians know the difference and come prepared.</p>

    <div class="type-grid">
      <div class="type-card">
        <div class="type-icon">🔄</div>
        <h3>Front-Load Washers</h3>
        <p>The most common configuration in SoCal condos and renovated homes. More energy-efficient, but more complex, and more prone to specific issues.</p>
        <ul>
          <li>Door gasket mold and deterioration</li>
          <li>Door lock / latch failure (won't start)</li>
          <li>Drum bearing wear (loud grinding)</li>
          <li>Drain pump blockage or failure</li>
          <li>Control board and error codes</li>
        </ul>
      </div>
      <div class="type-card">
        <div class="type-icon">⬆️</div>
        <h3>Top-Load Washers</h3>
        <p>Common in single-family homes and older rental units throughout SoCal. Simpler mechanically, with their own set of typical failure points.</p>
        <ul>
          <li>Lid switch failure (won't spin or drain)</li>
          <li>Agitator problems</li>
          <li>Water pump and drain issues</li>
          <li>Tub bearing noise</li>
          <li>Drive belt and motor coupling</li>
        </ul>
      </div>
      <div class="type-card">
        <div class="type-icon">📦</div>
        <h3>Stackable &amp; Washer-Dryer Combos</h3>
        <p>Dominant in WeHo, Newport Beach condos, and Pasadena conversions. Tight spaces, stacked configurations, often front-loaders on a pedestal or stacked dryer bracket.</p>
        <ul>
          <li>All front-load failure types apply</li>
          <li>Vibration and shaking during spin</li>
          <li>Access constraints require planning</li>
          <li>Pedestal drawer issues</li>
          <li>Stacking kit bracket problems</li>
        </ul>
      </div>
      <div class="type-card">
        <div class="type-icon">⚡</div>
        <h3>High-Efficiency (HE) Washers</h3>
        <p>Most modern washers, front-load or top-load, are HE. They use less water and more sensors, which means a different diagnostic approach when something goes wrong.</p>
        <ul>
          <li>Error code diagnosis (brand-specific)</li>
          <li>Pressure sensor and water level issues</li>
          <li>Excessive vibration from drum imbalance</li>
          <li>Slow fill or no-fill water inlet valve</li>
          <li>Control board failures</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- PROBLEMS — with cause-list bullets per gap-term recommendation -->
<section class="section section-gray">
  <div class="container">
    <p class="section-number">03, Common Problems</p>
    <h2 class="section-title">What our technicians fix most often</h2>
    <p class="lead">Every repair starts with a real diagnosis, not a parts swap on a guess. We identify the cause, give you a written quote, then fix it.</p>

    <div class="problems-grid">
      <div class="problem-card">
        <h3>Washer Not Draining</h3>
        <p>The drain pump is the most common cause, especially on front-loaders where the pump filter gets clogged with lint, coins, and debris.</p>
        <ul>
          <li>Drain pump motor failure</li>
          <li>Pump filter clogged (lint, coin trap)</li>
          <li>Drain hose kinked or blocked</li>
          <li>Lid switch failure (top-loaders)</li>
          <li>Drain hose installed too low (siphon effect)</li>
        </ul>
      </div>
      <div class="problem-card">
        <h3>Won't Start / Door Lock Error</h3>
        <p>One of the most frustrating front-loader failures: the latch closes but doesn't register as locked, and the cycle won't begin.</p>
        <ul>
          <li>Door latch / lid switch failed</li>
          <li>Thermal fuse blown (line voltage protection)</li>
          <li>Control board or timer failure</li>
          <li>Power cord damaged or outlet fault</li>
          <li>Wiring harness disconnected at the latch</li>
        </ul>
      </div>
      <div class="problem-card">
        <h3>Won't Spin or Agitate</h3>
        <p>On top-loaders, a failed lid switch is the first thing to check. On front-loaders, it's often the door latch, motor coupling, drive belt, or pump belt.</p>
        <ul>
          <li>Lid switch / door latch failure</li>
          <li>Drive belt or pump belt broken</li>
          <li>Motor coupling worn out</li>
          <li>Direct-drive motor failure</li>
          <li>Drum overweight from off-balance load</li>
        </ul>
      </div>
      <div class="problem-card">
        <h3>Water Leaking</h3>
        <p>Front-loaders leak most often from a torn door gasket. Top-loaders leak from a failed water pump or cracked hose.</p>
        <ul>
          <li>Door gasket torn or deteriorated</li>
          <li>Drain pump cracked / leaking</li>
          <li>Inlet hose split or fitting loose</li>
          <li>Tub seal worn through</li>
          <li>Detergent dispenser overflow</li>
        </ul>
      </div>
      <div class="problem-card">
        <h3>Loud Noise or Vibration</h3>
        <p>Grinding or rumbling during spin usually points to worn tub bearings, this gets worse over time and eventually damages the drum shaft.</p>
        <ul>
          <li>Tub bearings worn out</li>
          <li>Shock absorbers / suspension rods worn</li>
          <li>Drive belt loose or worn</li>
          <li>Motor coupling damaged</li>
          <li>Object lodged between drum and tub</li>
        </ul>
      </div>
      <div class="problem-card">
        <h3>Mold and Odor (Front-Loaders)</h3>
        <p>Front-loaders develop mold on the rubber door gasket and inside the drum. We clean the gasket thoroughly and inspect for tears.</p>
        <ul>
          <li>Door gasket mold (clean / replace)</li>
          <li>Detergent dispenser residue buildup</li>
          <li>Drain pump filter neglected</li>
          <li>Tub sump retains water (drain path issue)</li>
        </ul>
      </div>
      <div class="problem-card">
        <h3>Error Codes / Display Issues</h3>
        <p>Modern washers display error codes that tell a specific story. Our technicians are current on diagnostic codes for Samsung, LG, Whirlpool, Bosch, Miele, and Electrolux.</p>
        <ul>
          <li>Brand-specific code lookup (LE, DE, OE, SE, F-codes)</li>
          <li>Sensor or thermistor failure</li>
          <li>Control board fault</li>
          <li>Communication error between modules</li>
        </ul>
      </div>
      <div class="problem-card">
        <h3>Control Board Issues</h3>
        <p>A control board failure usually presents as erratic behavior, cycles that won't complete, random error codes, buttons that don't respond. We verify the board is actually the problem before recommending it.</p>
      </div>
    </div>
  </div>
</section>

