<!-- 01 HERO + TRUST BAR (unified ServiceHero) -->
<ServiceHero
  title="Washer Repair Los Angeles"
  subtitle="Front-load, top-load, stackable in a closet — our technicians run washing machine calls across LA daily and carry parts for the brands they see most."
  heroImageTitle="Washer Repair"
