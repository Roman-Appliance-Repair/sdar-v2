// T2, Residential range repair pillar (~6,000 vol/mo).
// Distinct from /services/stove-repair/ and /services/cooktop-repair/:
// range = freestanding/slide-in COMBO unit (cooktop + oven in one chassis).
// Brand pool: 12 residential brands existing as /brands/<x>-range-repair/.
// BlueStar, Capital, KitchenAid mentioned in prose without link (no /brands/ entry).
// $89 residential diagnostic. BHGS #A49573 + EPA 608 Universal #1346255700410.
// SSOT: NO aggregateRating, NO streetAddress (per 2026-04-27 policy).
import Layout from '../../layouts/Layout.astro';
import ServiceHero from '../../components/ServiceHero.astro';
import { MAIN_PHONE } from '../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
