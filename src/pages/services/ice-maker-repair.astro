---
// src/pages/services/ice-maker-repair.astro
// Phase 3 Tier 2 (2026-04-28), neutral multi-county hub.
// title/H1/description/phone neutralized to 5 SoCal counties; Service schema with 5-county
// areaServed (was HomeAndConstructionBusiness with 8 LA cities); aggregateRating REMOVED per
// wiki/decisions/nap-rating-policy-ssot.md; Recent Repairs distributed 2 LA + 1 OC + 1 Ventura;
// Cities-served block → 5-county Counties block; SoCal hard-water + luxury standalone angle preserved.

import Layout from '../../layouts/Layout.astro';
import ServiceHero from '../../components/ServiceHero.astro';
import { MAIN_PHONE } from '../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;

const title = "Ice Maker Repair Los Angeles — Same Day";
const description = "Same-day ice maker repair across LA, OC, Ventura, SB, Riverside. Sub-Zero, GE Profile, Scotsman, Frigidaire. Hard water, EPA 608. BHGS #A49573. $89 dx.";
---

<Layout title={title} description={description}>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Ice Maker Repair",
  "name": "Ice Maker Repair, Same Day Appliance Repair",
  "description": "Same-day ice maker repair across Los Angeles, Orange, Ventura, San Bernardino, and Riverside counties. Built-in fridge ice makers, standalone undercounter, commercial machines, all major and luxury brands.",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Same Day Appliance Repair",
    "url": "https://samedayappliance.repair/",
    "telephone": phone,
    "priceRange": "$$",
    "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "08:00", "closes": "20:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "00:00", "closes": "00:00" }
      ]
  },
  "areaServed": [
    { "@type": "AdministrativeArea", "name": "Los Angeles County" },
    { "@type": "AdministrativeArea", "name": "Orange County" },
    { "@type": "AdministrativeArea", "name": "Ventura County" },
    { "@type": "AdministrativeArea", "name": "San Bernardino County" },
    { "@type": "AdministrativeArea", "name": "Riverside County" }
  ],
  "offers": {
    "@type": "Offer",
    "priceSpecification": {
      "@type": "PriceSpecification",
      "price": "89.00",
      "priceCurrency": "USD",
      "description": "Residential diagnostic fee, applied toward repair"
    }
  }
})} />

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much does ice maker repair cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Our diagnostic fee is $89, applied toward the repair once you approve the work. Most residential ice maker repairs run between $120 and $280. A water inlet valve, water filter, or bin sensor replacement is toward the lower end. Control board issues or sealed system work run higher. On luxury standalone units like Scotsman or Sub-Zero, parts costs are higher, we provide a written estimate before any work begins."
      }
    },
    {
      "@type": "Question",
      "name": "Which areas of Southern California do you cover?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "All five counties: Los Angeles, Orange, Ventura, San Bernardino, and Riverside. We dispatch from 8 service territories, West Hollywood (HQ), Los Angeles, Beverly Hills, Pasadena, Thousand Oaks, Irvine, Rancho Cucamonga, and Temecula, so the technician on your call is coming from the closest one. Same-day is our standard."
      }
    },
    {
      "@type": "Question",
      "name": "My ice maker stopped making ice completely, what's the most likely cause?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The water inlet valve is the most common culprit, it controls water flow into the ice maker, and when it fails or gets blocked with mineral scale, no water enters and no ice is made. Other likely causes: a clogged water filter restricting flow, a failed ice maker module or control board, or a frozen water line. In SoCal's hard water environment, mineral scale in the inlet valve is more common than in most regions. We check the valve and filter first."
      }
    },
    {
      "@type": "Question",
      "name": "My ice is coming out cloudy or small, is the ice maker broken?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Not necessarily. Cloudy, small, or misshapen ice is almost always a water quality issue, not a machine malfunction. Southern California has among the hardest municipal water in the country, high mineral content produces cloudy ice and can cause scale buildup inside the ice maker that reduces the size of cubes. If the machine is producing ice but it looks wrong, we inspect the water line, inlet valve screen, and ice mold for mineral deposits before concluding the machine itself has failed."
      }
    },
    {
      "@type": "Question",
      "name": "Do you repair standalone undercounter ice makers like Scotsman and Sub-Zero?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Standalone undercounter ice makers, Scotsman, Sub-Zero, True, Hoshizaki, U-Line, are a significant part of what we service in SoCal's premium home market (Beverly Hills, Newport Coast, Pacific Palisades, Pasadena estates, Thousand Oaks hill homes). These units require brand-specific OEM parts and a different diagnostic approach than refrigerator-mounted ice makers. We carry parts for Sub-Zero and service the other luxury brands with parts sourced from authorized distributors."
      }
    },
    {
      "@type": "Question",
      "name": "My ice maker is leaking water onto the floor, what's wrong?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A leaking ice maker usually has one of three causes: a failed water inlet valve that won't close fully and drips continuously, a cracked or loose water supply line connection, or a clogged drain line that backs up and overflows. On standalone undercounter units, a clogged drain is the most frequent cause, these units generate warm, humid exhaust that can cause algae and scale growth in the drain. We locate the source before replacing anything."
      }
    },
    {
      "@type": "Question",
      "name": "How often should an ice maker be cleaned and descaled?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Across Southern California specifically, every 6 months. SoCal's hard water (typically 300+ mg/L total dissolved solids; Inland Empire wells often run higher) deposits mineral scale inside ice makers faster than most US regions. Scale accumulates in the water inlet valve screen, the ice mold, the evaporator, and the water lines. It affects ice clarity, ice size, and eventually machine operation. Standalone units like Scotsman recommend descaling every 6 months as a maintenance standard. We offer a descaling service alongside repair calls."
      }
    },
    {
      "@type": "Question",
      "name": "When does it make sense to repair vs replace an ice maker?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For fridge-mounted ice makers: under 8 years old and the repair is under $250, fix it. Over 12 years and the failure is the ice maker module or sealed system, the math often favors a new fridge. For standalone undercounter units (Scotsman, Sub-Zero, U-Line, Hoshizaki): almost always worth repairing, these units are $2,500–$6,000+ to replace and built for 12-15 year service lives. We tell you straight which side of that line your unit falls on."
      }
    },
    {
      "@type": "Question",
      "name": "What does the 90-day warranty cover on ice maker repairs?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Every ice maker repair we complete carries a 90-day warranty on both parts and labor. If the same issue returns within that window, we come back at no charge. That's in writing before we leave."
      }
    }
  ]
})} />

