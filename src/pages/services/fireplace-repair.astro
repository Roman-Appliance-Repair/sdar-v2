const phone = MAIN_PHONE.display;
const phoneRaw = MAIN_PHONE.raw;
const phoneHref = MAIN_PHONE.href;
---

<Layout title={title} description={description}>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Fireplace Repair",
  "serviceType": "Fireplace Repair",
  "description": "Same-day fireplace repair across Southern California, gas fireplaces, electric inserts, wood-burning appliances. Pilot light, thermocouple/thermopile, blower motor, remote receiver. Heat & Glo, Heatilator, Majestic, Napoleon, Regency, Mendota, Dimplex. Gas-certified technicians. BHGS #A49573. $89 diagnostic.",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Same Day Appliance Repair",
    "telephone": phone,
    "url": "https://samedayappliance.repair/",
    "priceRange": "$$"
  },
  "areaServed": [
    {"@type":"AdministrativeArea","name":"Los Angeles County"},
    {"@type":"AdministrativeArea","name":"Orange County"},
    {"@type":"AdministrativeArea","name":"Ventura County"},
    {"@type":"AdministrativeArea","name":"San Bernardino County"},
    {"@type":"AdministrativeArea","name":"Riverside County"}
  ],
  "offers": {
    "@type": "Offer",
    "priceSpecification": {
      "@type": "PriceSpecification",
      "price": "89.00",
      "priceCurrency": "USD",
      "description": "Diagnostic fee, applied toward the repair when approved."
    }
  }
})} />

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much does fireplace repair cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Our diagnostic fee is $89, waived when you approve the repair. Most gas fireplace repairs run between $120 and $380. Thermocouple, thermopile, igniter, gas valve, or remote receiver replacement is toward the lower end. Blower motor or control board runs higher. Electric fireplace repairs typically run $120–$280. We provide a written estimate before any work begins."
      }
    },
    {
      "@type": "Question",
      "name": "Which areas of Southern California do you cover for fireplace repair?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Same-day across Los Angeles, Orange, Ventura, San Bernardino, and Riverside counties, Silver Lake and Los Feliz Craftsman bungalows, Pasadena and San Marino historic homes, Beverly Hills and Hollywood Hills modernist builds, Newport Beach and Newport Coast OC homes, Thousand Oaks and Westlake Village suburban builds, Riverside and Temecula estate homes. Eight service territories total. Heat & Glo, Heatilator, Majestic, Napoleon, gas-certified across the entire footprint. BHGS #A49573."
      }
    },
    {
      "@type": "Question",
      "name": "My gas fireplace pilot light won't stay lit, what causes that?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Almost always a failed thermocouple or thermopile. The thermocouple is a safety sensor that detects the pilot flame and holds the gas valve open, when it fails, the pilot lights but the gas valve closes 15-30 seconds later and the flame goes out. A thermopile does the same job on systems with a remote or wall switch, generating millivoltage to power the valve. Try this first: hold the pilot button down for a full 45-60 seconds before releasing, sometimes a thermocouple that's slow to heat needs extra time. If it still won't stay lit, call us."
      }
    },
    {
      "@type": "Question",
      "name": "My gas fireplace smells like gas, what do I do?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Turn off the fireplace immediately and open windows. Call your gas utility, SoCalGas at 1-800-427-2200 across most of LA, OC, Ventura, and parts of SB; Southwest Gas at 1-877-860-6020 for Riverside, Anaheim, Long Beach, and parts of SB. They respond quickly, locate the source, and confirm the area is safe at no charge. Then call us for the mechanical repair. Do not attempt to relight the fireplace until the utility has verified the gas smell is resolved."
      }
    },
    {
      "@type": "Question",
      "name": "Do you repair electric fireplaces as well as gas?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Electric fireplace repairs cover the heating element, blower fan motor, flame effect LED/motor system, remote receiver, and control board. Most electric fireplace failures are the heating element or blower motor, both are straightforward same-day repairs. We service all major electric fireplace brands including Dimplex, ClassicFlame, and Napoleon."
      }
    },
    {
      "@type": "Question",
      "name": "Do you repair Heat & Glo, Heatilator, and Majestic gas fireplaces?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Heat & Glo, Heatilator, and Majestic are the three most common gas fireplace brands across SoCal homes. We also service Napoleon, Regency, Mendota, Lennox, and Superior. Parts sourced through fireplace equipment distributors. Gas-certified technicians for all gas fireplace work across all five counties."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between a thermocouple and thermopile in a gas fireplace?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A thermocouple generates a small millivolt signal (around 25 mV) from the pilot flame heat, just enough to hold a simple gas valve open. It's used on basic manual-ignition systems with no electronic controls. A thermopile generates more millivoltage (around 750 mV) and is used on fireplaces with remote controls, wall switches, or electronic ignition systems. Both fail in similar ways, degraded output that can no longer hold the gas valve open. We test both with a millivolt meter to confirm failure before replacing."
      }
    },
    {
      "@type": "Question",
      "name": "My fireplace worked fine last year but won't light this season, why?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "This is the most common fireplace service call across Southern California, the 'first use of the season' failure. After 8-9 months of sitting unused (SoCal's mild climate means fireplaces typically run only November–January), thermocouples and thermopiles can develop surface oxidation that reduces their millivolt output below the threshold needed to hold the gas valve open. Remote receivers can lose battery charge. Spider webs and debris can block pilot orifices. A seasonal service call (under $89) clears all of these issues and tests the full system before you need it on a cold evening."
      }
    }
  ]
})} />

