---
// src/pages/services/laundry-repair.astro
// C12 Laundry umbrella, service-hub CREATE (primary cluster-12 deliverable)
// Navigation-umbrella architecture aggregating washer + dryer + stackable + all-in-one
// + Amana value-tier combo. Schema Pattern A. Phone (424) 325-0520.

import Layout from '../../layouts/Layout.astro';
import ServiceHero from '../../components/ServiceHero.astro';
import { MAIN_PHONE } from '../../data/branches';

const title = "Residential Laundry Repair Across SoCal | Washer + Dryer + Stackable";
const description = "Residential laundry repair across LA, OC, Ventura, SB, Riverside, washer, dryer, stackable, all-in-one combo. BHGS #A49573. EPA 608. $89 dx waived.";
const canonical = "https://samedayappliance.repair/services/laundry-repair/";
const phone = MAIN_PHONE.display;
const phoneRaw = MAIN_PHONE.raw;
const phoneHref = MAIN_PHONE.href;

const faqs = [
  { q: "Which service hub do I need, laundry, washer, dryer, or stackable?", a: "Use this laundry umbrella page if you're not sure yet, or if you own a matched washer + dryer pair and one of them has failed. If you know the washer is the problem, go to /services/washer-repair/. If the dryer is the problem, go to /services/dryer-repair/. If you have a stacked unit, either a factory stacked combo like an LG WashTower or a separate washer physically stacked on top of a dryer, go to /services/stackable-washer-dryer-repair/ for the specific install-geometry considerations. All three service hubs route to our same technician network with the same $89 residential diagnostic waived with repair." },
  { q: "Which areas of Southern California do you cover for laundry repair?", a: "Same-day across Los Angeles, Orange, Ventura, San Bernardino, and Riverside counties, Beverly Hills and Brentwood Miele W1/T1 column pairs, Newport Beach and Irvine OC LG WashTowers, Thousand Oaks and Westlake Village townhome stacks, Long Beach high-rise WashCombos, Rancho Cucamonga and Riverside ADU laundry centers. Eight service territories total. BHGS Licensed #A49573, every residential laundry brand and architecture covered with one diagnostic." },
  { q: "My washer and dryer are a matched set, can you service both in one visit?", a: "Yes. Matched-set service in one visit is one reason to book through the laundry umbrella rather than the individual washer or dryer hub. The diagnostic applies once, not per unit, and the technician can evaluate both units during the same appointment. Common scenario: the dryer is the presenting problem but we notice the washer's fill hoses are swelling at the rubber seams, we'll flag that before it fails. Second common scenario: both units are 10+ years old and one has failed; we give you honest repair-vs-replace math on the whole pair rather than just the failed unit. Matched pairs don't always need matched replacement, but the decision deserves to be informed." },
  { q: "Do you repair all-in-one washer/dryer combos like the LG WashCombo?", a: "Yes. All-in-one combos are a single drum that washes and then tumble-dries the same load without a transfer step, LG WashCombo WM6998HBA (ventless heat-pump single drum), GE Profile UltraFast PFQ97HSPVDS, Whirlpool Combo All-in-One (WFC8090GX legacy). These units combine washer and dryer mechanics in one cabinet and have their own failure modes: heat-pump condenser fouling, drain pump coordinating wash + dry cycles, the control board running both programs. Separate from stackable units (two units stacked) and separate from laundry-center unitized units (Frigidaire FLCE, GE GUD, single cabinet with separate washer chamber above dryer chamber). We service all three architectures." },
  { q: "Is Amana laundry the same as Whirlpool laundry?", a: "Close enough for service-parts purposes. Amana has been Whirlpool-owned since 2001 and operates as Whirlpool's value-tier brand alongside Whirlpool (premium), Maytag (mass-market), and Roper (entry-level). Amana washers and dryers use the same chassis platforms as Whirlpool and Maytag equivalents with different cosmetic panels and simpler electronics. Parts interchange substantially, the drive system, motor, belt, pump, and often the control board on an Amana washer are the same parts used on comparable Whirlpool and Maytag models. For a full Amana laundry-specific write-up see /brands/amana-laundry-repair/." },
  { q: "What brands of laundry equipment do you service?", a: "All major residential laundry brands. Luxury + premium European (Miele, Asko, Fisher & Paykel, Bosch, Electrolux). Premium Korean (LG including WashTower, Samsung including FlexWash). Mass-market domestic (Whirlpool, Maytag, GE including GE Profile, Frigidaire). Value-tier (Amana, Roper, Crosley). Some retailer-exclusive brands (Kenmore chassis-shared with Whirlpool / LG / Samsung depending on model year, Hotpoint chassis-shared with GE). Luxury European parts like Miele often require ordering from specialty distributors with 5-10 day lead times, we confirm availability before scheduling when that applies." },
  { q: "Do you service commercial laundry equipment or coin-operated laundromats?", a: "No, our scope is residential laundry only. Commercial coin-op laundromats, multi-unit apartment building laundry rooms, and commercial plant laundry use industrial Speed Queen, Huebsch, Continental Girbau, Milnor, Dexter, Unimac, and commercial-spec Maytag / Whirlpool / GE equipment with different parts channels, different electrical service (often 220V 3-phase), and different service economics ($120 commercial diagnostic minimum, different warranty structure). For commercial laundry, contact a commercial-specialist service provider. The $89 residential diagnostic on this page applies only to residential-spec equipment in single-family homes, condos, apartments, and ADUs." }
];

const schemaJsons = [
  { "@context": "https://schema.org", "@type": "Service", "serviceType": "Residential Laundry Repair",
    "name": "Residential Laundry Repair",
    "description": "Residential laundry umbrella service across Southern California, washer, dryer, stackable, all-in-one combo, laundry-center unitized. LG WashTower + Samsung FlexWash + LG WashCombo + Amana value-tier + Whirlpool + Maytag + GE + Frigidaire + Miele + Electrolux. BHGS Licensed #A49573. $89 residential diagnostic waived with repair.",
    "provider": {
      "@type": "LocalBusiness",
      "name": "Same Day Appliance Repair",
      "telephone": phone,
      "url": "https://samedayappliance.repair/",
      "priceRange": "$$"
    },
    "areaServed": [
      {"@type":"AdministrativeArea","name":"Los Angeles County"},
      {"@type":"AdministrativeArea","name":"Orange County"},
      {"@type":"AdministrativeArea","name":"Ventura County"},
      {"@type":"AdministrativeArea","name":"San Bernardino County"},
      {"@type":"AdministrativeArea","name":"Riverside County"}
    ],
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, waived with repair" } }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://samedayappliance.repair/services/" },
      { "@type": "ListItem", "position": 3, "name": "Laundry Repair", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>

<Fragment slot="head-scripts">{schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}</Fragment>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .section { padding: 72px 24px; }
  .section-gray { background: var(--gray); }
  .section-black { background: var(--black); color: #fff; }
  .container { max-width: 1100px; margin: 0 auto; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  h2.section-title { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; margin: 0 0 16px; line-height: 1.2; }
  .section-black h2.section-title { color: #fff; }
  .lead { font-size: 1.05rem; line-height: 1.75; color: var(--text); max-width: 720px; }
  .section-black .lead { color: #ccc; }
  .intro-grid { display: grid; grid-template-columns: 1fr 320px; gap: 48px; align-items: start; }
  @media (max-width: 768px) { .intro-grid { grid-template-columns: 1fr; } }
  .intro-body p { margin: 0 0 18px; font-size: 1.05rem; line-height: 1.8; color: var(--text); }
  .tip-box { background: #fff8e7; border: 1px solid #f0d070; border-radius: 8px; padding: 18px 20px; margin-top: 24px; }
  .tip-box .tip-label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #a07000; margin-bottom: 8px; }
  .tip-box p { font-size: 0.95rem; color: #5a4000; margin: 0; line-height: 1.65; }
  .sticky-cta { position: sticky; top: 24px; background: var(--black); border-radius: 10px; padding: 28px 24px; color: #fff; text-align: center; }
  .sticky-cta .cta-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: #aaa; margin-bottom: 14px; }
  .sticky-cta .cta-phone { font-size: 1.5rem; font-weight: 800; color: #fff; text-decoration: none; display: block; margin-bottom: 12px; }
  .sticky-cta .btn-cta { display: block; background: var(--red); color: #fff; padding: 14px; border-radius: 5px; font-weight: 700; text-decoration: none; font-size: 0.95rem; margin-bottom: 10px; }
  .sticky-cta .cta-sub { font-size: 0.82rem; color: #888; }
  .cta-divider { border: none; border-top: 1px solid #222; margin: 18px 0; }
  .cta-detail { font-size: 0.85rem; color: #aaa; text-align: left; }
  .cta-detail li { margin-bottom: 6px; list-style: none; padding-left: 18px; position: relative; }
  .cta-detail li::before { content: "✓"; position: absolute; left: 0; color: var(--red); font-weight: 700; }
  .category-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 22px; margin-top: 32px; }
  .category-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 28px 24px; }
  .category-card.dark { background: #111; border-color: #222; color: #fff; }
  .category-card .cat-label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--red); margin-bottom: 10px; }
  .category-card h3 { font-size: 1.15rem; font-weight: 800; margin: 0 0 12px; line-height: 1.3; }
  .category-card.dark h3 { color: #fff; }
  .category-card p { font-size: 0.92rem; line-height: 1.65; margin: 0 0 14px; color: var(--text); }
  .category-card.dark p { color: #c8c8c8; }
  .category-card .cat-link { color: var(--red); font-weight: 700; text-decoration: none; font-size: 0.9rem; display: inline-block; margin-top: 4px; }
  .category-card .cat-link:hover { text-decoration: underline; }
  .category-card .cat-brands { font-size: 0.82rem; color: var(--muted); margin-bottom: 14px; border-top: 1px solid var(--border); padding-top: 10px; }
  .category-card.dark .cat-brands { color: #888; border-color: #222; }
  .brands-grid { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 18px; }
  .brand-chip { background: #fff; border: 1px solid var(--border); border-radius: 4px; padding: 8px 18px; font-size: 0.88rem; font-weight: 600; color: var(--text); text-decoration: none; }
  .brand-chip:hover { border-color: var(--red); color: var(--red); }
  .brand-chip.dark { background: #1a1a1a; color: #ddd; border-color: #333; }
  .combo-block { background: #0a0f14; border: 1px solid #1a2028; border-radius: 10px; padding: 36px 32px; margin-top: 32px; color: #fff; }
  .combo-block .combo-label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: #80a8d0; margin-bottom: 14px; }
  .combo-block h3 { font-size: 1.25rem; font-weight: 800; margin: 0 0 14px; }
  .combo-block p { font-size: 0.95rem; color: #c8d0d8; line-height: 1.7; margin: 0 0 14px; }
  .combo-block .combo-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 14px; margin-top: 20px; }
  .combo-block .combo-item { background: #080a0e; border: 1px solid #1a2028; border-radius: 6px; padding: 16px 18px; }
  .combo-block .combo-item strong { display: block; font-size: 0.9rem; color: #a0c8e8; margin-bottom: 4px; }
  .combo-block .combo-item span { font-size: 0.82rem; color: #708090; line-height: 1.5; }
  .commercial-note { background: #f6f2ea; border-left: 4px solid #a07030; padding: 22px 26px; border-radius: 6px; margin-top: 28px; }
  .commercial-note h3 { font-size: 1.05rem; font-weight: 800; margin: 0 0 10px; color: #5a4000; }
  .commercial-note p { font-size: 0.93rem; line-height: 1.65; color: #333; margin: 0; }
  .pricing-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 18px; margin-top: 32px; }
  .price-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 22px 18px; text-align: center; }
  .price-card .price-label { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); margin-bottom: 8px; }
  .price-card .price-amount { font-size: 1.8rem; font-weight: 800; color: var(--text); line-height: 1; margin-bottom: 8px; }
  .price-card .price-desc { font-size: 0.84rem; color: var(--muted); line-height: 1.5; }
  .price-note { margin-top: 18px; font-size: 0.9rem; color: var(--muted); line-height: 1.6; }
  .faq-list { margin-top: 36px; }
  .faq-item { border-bottom: 1px solid var(--border); padding: 22px 0; }
  .faq-item:first-child { border-top: 1px solid var(--border); }
  .faq-item h3 { font-size: 1rem; font-weight: 700; color: var(--text); margin: 0 0 10px; }
  .faq-item p { font-size: 0.95rem; color: var(--muted); line-height: 1.7; margin: 0; }
  .nearby-links { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 24px; }
  .nearby-links a { background: #fff; border: 1px solid var(--border); border-radius: 4px; padding: 8px 16px; font-size: 0.87rem; color: var(--text); text-decoration: none; font-weight: 500; }
  .nearby-links a:hover { border-color: var(--red); color: var(--red); }
  .bottom-cta { background: var(--black); color: #fff; padding: 72px 24px; text-align: center; }
  .bottom-cta h2 { font-size: clamp(1.8rem, 3vw, 2.4rem); font-weight: 800; margin: 0 0 16px; }
  .bottom-cta p { color: #c9c9c9; margin: 0 0 32px; font-size: 1.05rem; }
  .btn-primary { background: var(--red); color: #fff; padding: 16px 34px; border-radius: 5px; font-size: 1rem; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 16px 34px; border-radius: 5px; font-size: 1rem; font-weight: 600; text-decoration: none; border: 2px solid rgba(255,255,255,0.35); }
  .cta-row { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
</style>

<ServiceHero
  title="Residential Laundry Repair Across Southern California"
  subtitle="Same-day across LA, Orange, Ventura, San Bernardino & Riverside counties. Washer, dryer, stackable, all-in-one combo, one diagnostic, every laundry architecture. LG, Samsung, Whirlpool, Maytag, Amana, Miele. BHGS Licensed #A49573. $89 diagnostic."
  heroImageTitle="Laundry Repair"
/>

<!-- INTRO -->
<section class="section">
  <div class="container">
    <div class="intro-grid">
      <div class="intro-body">
        <p class="section-number">01, About This Service</p>
        <h2 class="section-title">One laundry umbrella for every washer + dryer architecture in SoCal homes.</h2>

        <p>Residential laundry in a Southern California home takes more shapes than it used to. Twenty years ago most households had a front-loader or top-loader washer in a dedicated laundry room with a matched dryer beside it, and that was the whole conversation. Today a single apartment in DTLA or downtown Long Beach might have an LG WashCombo single-drum heat-pump unit; a Silver Lake or Costa Mesa duplex might have a Frigidaire FLCE laundry center stacked in a closet; a Westside condo or Newport Coast home might have a Samsung FlexWash twin-drum; and a Bel Air, Westlake Village, or Newport Beach custom-laundry room might have a Miele W1/T1 heat-pump pair with separate stacked columns. Each architecture has its own failure modes, its own parts channels, and its own install-geometry considerations.</p>

        <p>This umbrella page routes you to the right service hub. If you know exactly what you own and what's failing, jump directly to the washer, dryer, or stackable hub linked below. If you're not sure, or if you own a matched pair and one of them failed and you want an honest look at both, this is the right page to start from. One $89 residential diagnostic, one technician dispatch, and we'll evaluate the specific architecture in your laundry space. Same-day across all five SoCal counties, BHGS Licensed #A49573.</p>

        <div class="tip-box">
          <div class="tip-label">🧺 One Diagnostic, Matched Pairs</div>
          <p>If your washer and dryer are a matched set and one has failed, the diagnostic fee applies once, not per unit. The technician evaluates both during the same visit. Common finding on pairs 10+ years old: the presenting failure isn't the whole story, and the other unit has a developing issue worth knowing about before it becomes an emergency.</p>
        </div>
      </div>

      <aside class="sticky-cta">
        <div class="cta-label">Same Day Laundry Repair</div>
        <a href={phoneHref} class="cta-phone">{phone}</a>
        <a href={phoneHref} class="btn-cta">Call Now, We Pick Up</a>
        <a href="/book" class="btn-cta" style="background:#222; margin-top:-4px;">Book Online</a>
        <div class="cta-sub">Mon–Fri 7am–9pm · Sat 8am–7pm · Sun 9am–5pm</div>
        <hr class="cta-divider" />
        <ul class="cta-detail">
          <li>$89 residential diagnostic</li>
          <li>Applied toward repair if you proceed</li>
          <li>BHGS Licensed #A49573</li>
          <li>Matched-pair service one visit</li>
          <li>Washer + dryer + stackable + combo</li>
          <li>5-county SoCal coverage</li>
        </ul>
      </aside>
    </div>
  </div>
</section>

<!-- CATEGORY ROUTING -->
<section class="section section-gray">
  <div class="container">
    <p class="section-number">02, Route Me to the Right Hub</p>
    <h2 class="section-title">Four residential laundry categories, pick the one that matches your unit</h2>
    <p class="lead">Each category below has its own dedicated service hub with category-specific diagnostics, common-failure detail, and brand coverage. If you're not sure, start here, the technician will confirm at diagnostic.</p>

    <div class="category-grid">
      <div class="category-card">
        <div class="cat-label">Category 01 · Washer</div>
        <h3>Washer Repair</h3>
        <p>Standalone front-load or top-load washers. Not spinning, not draining, leaking, error codes, loud on spin, won't start. Every residential washer brand serviced, LG, Samsung, Whirlpool, Maytag, Kenmore, GE, Frigidaire, Speed Queen residential, Miele, Electrolux, Bosch, Asko, Fisher &amp; Paykel, Amana.</p>
        <div class="cat-brands">Most common in LA: LG WM-series, Samsung WF-series, Whirlpool Duet + Cabrio, Maytag Bravos + Maxima</div>
        <a href="/services/washer-repair/" class="cat-link">Washer repair service hub →</a>
      </div>

      <div class="category-card">
        <div class="cat-label">Category 02 · Dryer</div>
        <h3>Dryer Repair</h3>
        <p>Standalone gas or electric dryers. Not heating, not tumbling, taking multiple cycles to dry, error codes, burning smell, squealing or thumping. Every major brand plus heat-pump ventless dryers that have become common in LA condos and apartments without exterior venting.</p>
        <div class="cat-brands">Most common in LA: LG DLE/DLG, Samsung DVE/DVG, Whirlpool WED/WGD, Maytag MED/MGD</div>
        <a href="/services/dryer-repair/" class="cat-link">Dryer repair service hub →</a>
      </div>

      <div class="category-card">
        <div class="cat-label">Category 03 · Stackable</div>
        <h3>Stackable Washer + Dryer Repair</h3>
        <p>Two separate units physically stacked with a stacking kit, or factory stacked combos where the two units ship together as one cabinet. LG WashTower (factory stacked one-piece column) and Samsung FlexWash (twin drums, vertical) are the premium Korean stackable architectures. Install geometry matters, access, stack decoupling, and unit alignment all affect service.</p>
        <div class="cat-brands">Factory stacked: LG WashTower WKEX / WKHC · Samsung FlexWash WV-series. Kit-stacked: any matched pair</div>
        <a href="/services/stackable-washer-dryer-repair/" class="cat-link">Stackable repair service hub →</a>
      </div>

      <div class="category-card">
        <div class="cat-label">Category 04 · All-in-One</div>
        <h3>All-in-One Combo &amp; Laundry Center</h3>
        <p>Single-drum combo units that wash and dry the same load in one drum (no transfer step), LG WashCombo, GE Profile UltraFast, Whirlpool Combo legacy. Plus laundry-center unitized units with separate wash chamber above dryer chamber in one cabinet, Frigidaire FLCE, GE Unitized GUD. Different architecture, different repair approach.</p>
        <div class="cat-brands">Single-drum combo: LG WashCombo WM6998HBA · GE Profile PFQ97HSPVDS. Unitized: Frigidaire FLCE · GE GUD</div>
        <a class="cat-link">Combo + unitized serviced under washer + dryer hubs</a>
      </div>
    </div>
  </div>
</section>

<!-- WASHER FOCUS -->
<section class="section">
  <div class="container">
    <p class="section-number">03, Washer Scope</p>
    <h2 class="section-title">Washer-side failures, drive, pump, valve, control</h2>
    <p class="lead">Residential washers fail in a handful of predictable ways. The brand and the architecture (front-load vs top-load, direct-drive vs belt-drive) affect the parts channel but not the failure modes.</p>

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:32px; margin-top:28px;">
      <div>
        <h3 style="font-size:1.05rem; font-weight:700; margin-bottom:12px;">Common presenting failures</h3>
        <ul style="line-height:1.9; padding-left:20px; color:var(--text);">
          <li><b>Not spinning</b>, drive belt, motor coupler, clutch, motor control board, or off-balance sensor triggered</li>
          <li><b>Not draining</b>, drain pump, drain hose kink, clogged pump filter (common on LG + Samsung front-loaders)</li>
          <li><b>Not filling or filling slowly</b>, water inlet valve, screen blockage, low water pressure, fill sensor</li>
          <li><b>Leaking</b>, door boot seal (front-load), tub seal, pump, hose connections, dispenser assembly</li>
          <li><b>Error codes</b>, brand-specific fault codes pointing to a specific component</li>
          <li><b>Loud bang / loud spin</b>, drum bearings, shock absorber failure, off-balance from unbalanced load</li>
        </ul>
      </div>
      <div>
        <h3 style="font-size:1.05rem; font-weight:700; margin-bottom:12px;">SoCal-specific considerations</h3>
        <p style="font-size:0.95rem; line-height:1.7; color:var(--text);">Hard water across SoCal (San Fernando Valley, San Gabriel Valley, Pasadena, parts of OC, and especially Inland Empire and parts of Riverside/San Bernardino on Colorado River supply) accelerates valve scaling and pump fouling. Front-loaders with door boot mold, common on LG + Samsung + Whirlpool Duet in SoCal's coastal humidity (LA Westside, OC coastal, Ventura corridor), need routine door-open drying and periodic boot cleaning, not replacement, unless the boot is actually torn.</p>
        <p style="font-size:0.95rem; line-height:1.7; color:var(--text); margin-top:12px;">Full washer-specific detail on failures, brand-specific parts channels, and pricing is on the dedicated washer hub.</p>
        <a href="/services/washer-repair/" class="cat-link" style="color:var(--red); font-weight:700;">Full washer service hub →</a>
      </div>
    </div>
  </div>
</section>

<!-- DRYER FOCUS -->
<section class="section section-gray">
  <div class="container">
    <p class="section-number">04, Dryer Scope</p>
    <h2 class="section-title">Dryer-side failures, heat, airflow, drive, electronics</h2>
    <p class="lead">Residential dryers come in three flavors: electric vented, gas vented, and heat-pump ventless (more common in SoCal condo, apartment, and ADU installs without exterior venting, across all five counties). Each has distinct heat-source failure modes.</p>

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:32px; margin-top:28px;">
      <div>
        <h3 style="font-size:1.05rem; font-weight:700; margin-bottom:12px;">Common presenting failures</h3>
        <ul style="line-height:1.9; padding-left:20px; color:var(--text);">
          <li><b>Not heating</b>, heating element (electric), igniter (gas), gas valve coil, thermal fuse, high-limit thermostat</li>
          <li><b>Taking 2–3 cycles to dry</b>, partial lint or vent blockage restricting airflow; often a vent-side issue rather than dryer-side</li>
          <li><b>Not tumbling</b>, drive belt, idler pulley, drum rollers, drive motor</li>
          <li><b>Error codes</b>, brand-specific fault codes on LG, Samsung, Whirlpool, Maytag, GE</li>
          <li><b>Squealing or thumping</b>, drum rollers, idler pulley, rear drum bearing</li>
          <li><b>Overheating / burning smell</b>, restricted vent + failed high-limit; real fire-safety concern</li>
        </ul>
      </div>
      <div>
        <h3 style="font-size:1.05rem; font-weight:700; margin-bottom:12px;">Vent-side disambiguation</h3>
        <p style="font-size:0.95rem; line-height:1.7; color:var(--text);">The #1 cause of "dryer not working right" calls that turn out not to be a dryer problem: restricted venting. If the transition duct from the dryer to the wall is crushed or clogged, or if the home's dryer vent system itself has lint accumulation, the dryer operates correctly but clothes take forever to dry. We do the appliance-side portion of this work, transition duct + lint-trap housing + appliance connection points. Full home dryer-vent-system cleaning is a cleaning-specialist service.</p>
        <p style="margin-top:12px;"><a href="/services/dryer-vent-repair/" class="cat-link" style="color:var(--red); font-weight:700;">Dryer vent repair (appliance-side) →</a></p>
        <p style="margin-top:10px;"><a href="/services/dryer-repair/" class="cat-link" style="color:var(--red); font-weight:700;">Full dryer service hub →</a></p>
      </div>
    </div>
  </div>
</section>

<!-- STACKABLE FOCUS -->
<section class="section">
  <div class="container">
    <p class="section-number">05, Stackable Scope</p>
    <h2 class="section-title">Stackable washer + dryer, factory stacked vs kit stacked</h2>
    <p class="lead">Stackable installs are common in SoCal's constrained laundry spaces, condo closets, half-bathroom conversions, tight utility rooms, ADU laundry zones across LA, OC, Ventura, and IE. Two distinct architectures with different service implications.</p>

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:28px; margin-top:28px;">
      <div style="background:#fff; border:1px solid var(--border); border-radius:8px; padding:26px 24px;">
        <h3 style="font-size:1.05rem; font-weight:800; margin:0 0 12px;">Factory-stacked one-piece columns</h3>
        <p style="font-size:0.92rem; line-height:1.7; margin:0 0 12px;">LG WashTower (WKEX + WKHC series) and Samsung FlexWash (WV-series) ship from the factory as a single vertical cabinet. Washer and dryer share a unified control panel at the middle, a single Center Control interface manages both. The unit arrives as one piece and cannot be separated for individual replacement.</p>
        <p style="font-size:0.92rem; line-height:1.7; margin:0;">Service implication: control panel failures affect both halves. Common failure: the unified control board on WashTower goes out, and both wash and dry lose their electronics simultaneously. Parts-channel is LG or Samsung direct.</p>
      </div>
      <div style="background:#fff; border:1px solid var(--border); border-radius:8px; padding:26px 24px;">
        <h3 style="font-size:1.05rem; font-weight:800; margin:0 0 12px;">Kit-stacked separate units</h3>
        <p style="font-size:0.92rem; line-height:1.7; margin:0 0 12px;">Any matched front-load washer + dryer pair can be stacked with a manufacturer-specific stacking kit. This preserves two individual units that can be separated for individual service or replacement. Most common in LA: LG, Samsung, Whirlpool Duet, Maytag Maxima, Miele W1/T1 column pairs.</p>
        <p style="font-size:0.92rem; line-height:1.7; margin:0;">Service implication: access is the hard part. The dryer on top usually has to come down (or at least have the back exposed) for major service. We bring the lift equipment for this on stacked calls.</p>
      </div>
    </div>

    <p style="margin-top:24px; text-align:center;"><a href="/services/stackable-washer-dryer-repair/" class="cat-link" style="color:var(--red); font-weight:700; font-size:0.95rem;">Stackable service hub, install-geometry detail and pricing →</a></p>
  </div>
</section>

<!-- ALL-IN-ONE COMBO + LAUNDRY CENTER -->
<section class="section section-black">
  <div class="container">
    <p class="section-number">06, All-in-One &amp; Laundry Center</p>
    <h2 class="section-title">Single-drum combos and unitized laundry centers</h2>
    <p class="lead">Distinct from stackable, these are single-cabinet units that integrate both wash and dry functions. Two architectures.</p>

    <div class="combo-block">
      <div class="combo-label">🌀 Single-drum all-in-one combo</div>
      <h3>One drum, one load, wash + dry without transfer</h3>
      <p>Heat-pump single-drum combos wash and then tumble-dry the same load without moving it between drums. The LG WashCombo WM6998HBA is the current flagship, ventless heat-pump architecture, no exterior venting required, common in DTLA lofts, downtown Long Beach high-rises, OC condos, and Westside LA buildings without laundry-venting provisions. GE Profile UltraFast PFQ97HSPVDS is the domestic competitor. Older Whirlpool WFC8090GX combo units appear in legacy installs.</p>
      <p>Failure modes specific to combo units: the heat-pump condenser fouls with lint + detergent residue (combo units can't flush residue out between wash and dry the way separate units can), the drain pump has to coordinate between wash-cycle drain and dry-cycle condensate drain, and the unified control board runs both cycle logics. When a combo fails, the unit is dead for both functions, not just one.</p>
      <div class="combo-grid">
        <div class="combo-item"><strong>LG WashCombo WM6998HBA</strong><span>Ventless heat-pump · single drum · 4.5 cu ft</span></div>
        <div class="combo-item"><strong>GE Profile UltraFast</strong><span>PFQ97HSPVDS · heat-pump · single drum</span></div>
        <div class="combo-item"><strong>Whirlpool Combo (legacy)</strong><span>WFC8090GX · older ventless single-drum</span></div>
        <div class="combo-item"><strong>Typical failure</strong><span>Heat-pump condenser fouling + control board</span></div>
      </div>
    </div>

    <div class="combo-block" style="margin-top:24px;">
      <div class="combo-label">📦 Laundry center unitized unit</div>
      <h3>Two chambers, one cabinet, factory-built as a single appliance</h3>
      <p>Laundry-center unitized units ship from the factory as a single appliance with a wash chamber above a separate dryer chamber in one vertical cabinet. Distinct from stacked separate units because the wash and dryer halves are built into the same frame, they cannot be separated. Frigidaire Affinity FLCE (electric) and FLCG (gas) and GE Unitized GUD are the common domestic examples. Narrower footprint than stacked separates, common in apartment installations.</p>
      <p>Failure modes: the wash and dry chambers have separate mechanicals (separate motors, separate heat sources) but often share a single control panel and single power connection. A control-panel failure on a unitized unit takes both halves out. Service access is different from stacked separates, the cabinet is a single unit, so removing "one half" isn't an option for repair.</p>
      <div class="combo-grid">
        <div class="combo-item"><strong>Frigidaire FLCE (electric)</strong><span>Affinity laundry center · unitized cabinet</span></div>
        <div class="combo-item"><strong>Frigidaire FLCG (gas)</strong><span>Affinity laundry center · gas dryer half</span></div>
        <div class="combo-item"><strong>GE Unitized GUD</strong><span>Space-saver laundry center · unitized</span></div>
        <div class="combo-item"><strong>Service implication</strong><span>Single cabinet + shared panel; not separable</span></div>
      </div>
    </div>
  </div>
</section>

<!-- AMANA VALUE-TIER -->
<section class="section section-gray">
  <div class="container">
    <p class="section-number">07, Amana Value-Tier</p>
    <h2 class="section-title">Amana laundry, Whirlpool value-tier, domestic parts chain</h2>
    <p class="lead">Amana has been Whirlpool-owned since 2001 and functions as the value-tier brand alongside Whirlpool (premium), Maytag (mass-market), and Roper (entry). Amana laundry equipment shares significant parts commonality with the Whirlpool and Maytag chassis it's derived from.</p>

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:32px; margin-top:28px;">
      <div>
        <p style="font-size:1rem; line-height:1.75; color:var(--text);">Amana washers and dryers use the same drive systems, motors, belts, pumps, valves, and often the same control boards as comparable Whirlpool and Maytag models. Where they differ is trim, cosmetic panels, fewer programmable cycles, simpler electronic displays. For a homeowner comparing Amana vs Whirlpool vs Maytag pricing at purchase time, the mechanical guts are largely the same.</p>
        <p style="font-size:1rem; line-height:1.75; color:var(--text); margin-top:14px;">For repair service, the good news is parts-chain advantage: Amana parts interchange with Whirlpool + Maytag parts substantially, so the parts availability for an Amana washer or dryer is as good as for a premium Whirlpool. The trade-off is that less-common trim pieces (cosmetic panels, Amana-specific control-board variants on older models) are occasionally harder to find than their Whirlpool-branded equivalents.</p>
        <p style="margin-top:14px;"><a href="/brands/amana-laundry-repair/" class="cat-link" style="color:var(--red); font-weight:700;">Full Amana laundry repair page →</a></p>
      </div>
      <div style="background:#fff; border:1px solid var(--border); border-radius:8px; padding:24px 22px;">
        <h3 style="font-size:1rem; font-weight:700; margin:0 0 14px;">Whirlpool family tier map</h3>
        <ul style="list-style:none; padding:0; margin:0; font-size:0.92rem; line-height:1.85;">
          <li style="padding:8px 0; border-bottom:1px solid var(--border);"><b>Whirlpool</b>, premium tier flagship</li>
          <li style="padding:8px 0; border-bottom:1px solid var(--border);"><b>Maytag</b>, mass-market / heavy-duty positioning</li>
          <li style="padding:8px 0; border-bottom:1px solid var(--border);"><b>KitchenAid</b>, premium cooking (not laundry)</li>
          <li style="padding:8px 0; border-bottom:1px solid var(--border);"><b>Amana</b>, value-tier laundry + kitchen</li>
          <li style="padding:8px 0;"><b>Roper</b>, entry-tier basic washer + dryer</li>
        </ul>
        <p style="margin-top:14px; font-size:0.85rem; color:var(--muted); line-height:1.6;">All five brands share the Whirlpool North America parts-distribution network. Sibling brand cross-references: <a href="/brands/whirlpool-washer-repair/" style="color:var(--red); font-weight:700;">Whirlpool washer</a> · <a href="/brands/whirlpool-dryer-repair/" style="color:var(--red); font-weight:700;">Whirlpool dryer</a> · <a href="/brands/maytag-washer-repair/" style="color:var(--red); font-weight:700;">Maytag washer</a> · <a href="/brands/maytag-dryer-repair/" style="color:var(--red); font-weight:700;">Maytag dryer</a>.</p>
      </div>
    </div>
  </div>
</section>

