---
import Layout from '../../layouts/Layout.astro';

const title = "Outdoor Refrigerator Repair Los Angeles | Sub-Zero · Viking · U-Line · Perlick";
const description = "Outdoor kitchen refrigeration repair across LA — weather-rated compressors, sealed-stainless cabinetry, dual-zone undercounter units. $89 residential diagnostic waived with repair. (424) 325-0520.";
const canonical = "https://samedayappliance.repair/services/outdoor-refrigerator-repair/";

const faqs = [
  {
    "q": "How is an outdoor refrigerator different from an indoor unit?",
    "a": "Outdoor units are UL-listed for outdoor use with sealed stainless cabinetry, weather-rated compressors, and dual-pane glass on showcase variants. Indoor units in outdoor installations void warranty and fail in 2–3 years."
  },
  {
    "q": "Can you service Sub-Zero, Viking, U-Line, and Perlick?",
    "a": "Yes — these are the four most-specified outdoor refrigeration brands in LA outdoor kitchens. Factory-trained service, OEM parts via authorized distribution."
  },
  {
    "q": "What’s the most common failure on outdoor units?",
    "a": "Compressor start-relay and condenser fouling top the list. Coastal Malibu installs see salt-corrosion damage by 5–7 years; inland units last 10–15 years. Door gaskets second-most-common."
  }
];

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": "https://samedayappliance.repair/services/outdoor-refrigerator-repair/#business",
    "name": "Same Day Appliance Repair",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": "https://samedayappliance.repair/services/outdoor-refrigerator-repair/",
    "telephone": "+1-424-325-0520",
    "priceRange": "$$$",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "6230 Wilshire Blvd Ste A PMB 2267",
      "addressLocality": "Los Angeles",
      "addressRegion": "CA",
      "postalCode": "90048",
      "addressCountry": "US"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": 34.0619,
      "longitude": -118.3692
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.6",
      "reviewCount": "37"
    },
    "areaServed": [
      {
        "@type": "AdministrativeArea",
        "name": "Los Angeles County"
      },
      {
        "@type": "AdministrativeArea",
        "name": "Orange County"
      },
      {
        "@type": "AdministrativeArea",
        "name": "Ventura County"
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Outdoor Refrigerator Repair",
    "provider": {
      "@id": "https://samedayappliance.repair/services/outdoor-refrigerator-repair/#business"
    },
    "areaServed": [
      {
        "@type": "AdministrativeArea",
        "name": "Los Angeles County"
      },
      {
        "@type": "AdministrativeArea",
        "name": "Orange County"
      },
      {
        "@type": "AdministrativeArea",
        "name": "Ventura County"
      }
    ],
    "description": "Outdoor kitchen refrigeration repair across LA — weather-rated compressors, sealed-stainless cabinetry, dual-zone undercounter units. $89 residential diagnostic waived with repair. (424) 325-0520.",
    "offers": {
      "@type": "Offer",
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "89.00",
        "priceCurrency": "USD",
        "description": "Residential diagnostic fee, waived with repair"
      }
    }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://samedayappliance.repair/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Services",
      "item": "https://samedayappliance.repair/services/"
    },
    {
      "@type": "ListItem",
