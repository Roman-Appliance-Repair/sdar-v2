---
// src/pages/services/oven-repair.astro
// Phase 3 Tier 2 (2026-04-28), neutral multi-county hub.
// title/H1/description/phone neutralized to 5 SoCal counties; Service schema with 5-county
// areaServed (was HomeAndConstructionBusiness with 7 LA cities); aggregateRating REMOVED per
// wiki/decisions/nap-rating-policy-ssot.md; Recent Repairs distributed 2 LA + 1 OC + 1 Ventura;
// Cities-served block → 5-county Counties block; pro-grade range angle preserved.

import Layout from '../../layouts/Layout.astro';
import ServiceHero from '../../components/ServiceHero.astro';
import { MAIN_PHONE } from '../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;

const title = "Oven Repair Los Angeles — Same Day";
const description = "Same-day oven + range repair across LA, OC, Ventura, SB, Riverside. Gas, electric, dual-fuel, wall ovens. Wolf, Thermador, Viking. $89 dx.";
---

<Layout title={title} description={description}>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Oven & Range Repair",
  "name": "Oven & Range Repair, Same Day Appliance Repair",
  "description": "Same-day oven and range repair across Los Angeles, Orange, Ventura, San Bernardino, and Riverside counties. Gas, electric, dual-fuel, wall ovens, all major and luxury brands.",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Same Day Appliance Repair",
    "url": "https://samedayappliance.repair/",
    "telephone": phone,
    "priceRange": "$$",
    "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "08:00", "closes": "20:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "00:00", "closes": "00:00" }
      ]
  },
  "areaServed": [
    { "@type": "AdministrativeArea", "name": "Los Angeles County" },
    { "@type": "AdministrativeArea", "name": "Orange County" },
    { "@type": "AdministrativeArea", "name": "Ventura County" },
    { "@type": "AdministrativeArea", "name": "San Bernardino County" },
    { "@type": "AdministrativeArea", "name": "Riverside County" }
  ],
  "offers": {
    "@type": "Offer",
    "priceSpecification": {
      "@type": "PriceSpecification",
      "price": "89.00",
      "priceCurrency": "USD",
      "description": "Residential diagnostic fee, applied toward repair"
    }
  }
})} />

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much does oven or range repair cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Our diagnostic fee is $89, applied toward the repair once you approve the work. Most residential oven and range repairs run between $150 and $350. A bake element or igniter replacement is toward the lower end. Control board repairs and dual-fuel range work run higher. On professional-grade ranges like Wolf, Thermador, or Viking, parts costs are higher and the repair range reflects that, we give you a full written estimate before any work begins."
      }
    },
    {
      "@type": "Question",
      "name": "Which areas of Southern California do you cover?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "All five counties: Los Angeles, Orange, Ventura, San Bernardino, and Riverside. We dispatch from 8 service territories, West Hollywood (HQ), Los Angeles, Beverly Hills, Pasadena, Thousand Oaks, Irvine, Rancho Cucamonga, and Temecula, so the technician on your call is coming from the closest one. Same-day is our standard."
      }
    },
    {
      "@type": "Question",
      "name": "My oven heats but the temperature is way off, what's wrong?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The oven temperature sensor (probe) is almost always the culprit. It's a thin metal probe that extends into the oven cavity and measures temperature, when it fails or drifts, the oven under- or over-shoots. It can also be a faulty control board misreading a functioning sensor, but we test the sensor first since it's the most common cause and a straightforward replacement."
      }
    },
    {
      "@type": "Question",
      "name": "My gas burner won't ignite, is that a repair or can I fix it myself?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "First check whether the burner cap and ports are clean, food debris blocking the gas ports is the most common reason a burner won't light. If clean and still won't ignite, the spark electrode, igniter module, or gas valve could be the issue. A burner that clicks constantly without lighting often means a faulty spark electrode. We carry these for the major brands."
      }
    },
    {
      "@type": "Question",
      "name": "My oven won't come out of self-clean mode and the door is locked, what do I do?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The door lock motor assembly has usually failed. In some cases, letting the oven cool completely and cutting power at the breaker will release it. If not, the door lock motor needs replacement, we carry these for the brands we see most across SoCal."
      }
    },
    {
      "@type": "Question",
      "name": "Do you repair Wolf, Thermador, and Viking ranges?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Wolf, Thermador, and Viking are three of the brands our technicians work on most frequently across SoCal. We source OEM parts directly from authorized suppliers for all three. LaCanche, BlueStar, Bertazzoni, ILVE, and Miele are also within our scope."
      }
    },
    {
      "@type": "Question",
      "name": "My oven bakes unevenly, is it the element or the sensor?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "It could be either. A partially failed bake element heats unevenly across its length, food near the failed section underbakes. A drifting temperature sensor causes the oven to cycle incorrectly throughout. We run a temperature test across multiple positions before concluding the cause."
      }
    },
    {
      "@type": "Question",
      "name": "When does it make sense to repair vs replace an oven or range?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Rule of thumb: under 10 years old and the repair is under $400, fix it. Over 12 years old AND the repair is over $500, consider replacing, but pro-grade brands flip the math. Wolf, Thermador, Viking, La Cornue, Lacanche, BlueStar are almost always worth repairing through year 20+, replacement runs $8,000–$25,000+ and parts continue to be supported. We tell you straight which side of that line your unit falls on."
      }
    },
    {
      "@type": "Question",
      "name": "What does the 90-day warranty cover on oven repairs?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Every oven and range repair we complete carries a 90-day warranty on both parts and labor. If the same issue returns within that window, we come back at no charge. That's in writing before we leave."
      }
    }
  ]
})} />

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
