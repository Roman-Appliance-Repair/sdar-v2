  .brand-chip.dark { background: #1a1a1a; color: #ddd; border-color: #333; }
  .repairs-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 24px; margin-top: 36px; }
  .repair-card { background: #111; border: 1px solid #222; border-radius: 8px; padding: 24px 20px; }
