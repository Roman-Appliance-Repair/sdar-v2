  .cta-divider { border: none; border-top: 1px solid #222; margin: 18px 0; }
  .cta-detail { font-size: 0.85rem; color: #aaa; text-align: left; }
  .cta-detail li { margin-bottom: 6px; list-style: none; padding-left: 18px; position: relative; }
  .cta-detail li::before { content: "✓"; position: absolute; left: 0; color: var(--red); font-weight: 700; }
  .type-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 20px; margin-top: 32px; }
  .type-card { background: #111; border: 1px solid #222; border-radius: 8px; padding: 24px 20px; }
  .type-card .type-badge { display: inline-block; background: var(--red); color: #fff; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; padding: 3px 10px; border-radius: 3px; margin-bottom: 12px; }
  .type-card h3 { font-size: 0.95rem; font-weight: 700; color: #fff; margin: 0 0 10px; }
  .type-card p { font-size: 0.87rem; color: #888; line-height: 1.6; margin: 0; }
