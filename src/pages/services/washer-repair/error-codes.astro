      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": canonical + "#service",
    "serviceType": "Washer Error Codes Repair",
    "name": "Washer Error Code Diagnostic and Repair Service",
    "url": canonical,
    "description": "Residential washer error code decoding and repair across all five SoCal counties. Brand-specific code lookup and on-site verification for Samsung (4C/5C/DC/UE/LE/OE/tE), LG (OE/IE/UE/LE/PE/CE/FE/tE), Whirlpool / Maytag / KitchenAid (F-code system including F2E2 UI board failure on 2014-2019 model years), Bosch (E18/E13/E04/F21/F25), GE (older ER series + newer alphanumeric), Frigidaire / Electrolux (E20/E10/E40/E60/E70/E90), Miele (F-code with service mode reset), Speed Queen (E-01/E-LD/E-FL/E-DR/E-OF/E-bA). $89 residential diagnostic, waived with repair. BHGS #A49573, EPA 608 Universal certified #1346255700410.",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, waived with repair" } }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://samedayappliance.repair/services/" },
      { "@type": "ListItem", "position": 3, "name": "Washer Repair", "item": "https://samedayappliance.repair/services/washer-repair/" },
      { "@type": "ListItem", "position": 4, "name": "Error Codes", "item": canonical }
    ]
  }
];
