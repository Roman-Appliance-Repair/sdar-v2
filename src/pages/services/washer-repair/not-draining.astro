    "url": canonical,
    "description": "Residential washer won't-drain diagnostic and repair across all five SoCal counties. Drain pump filter clog (front-load, customer-accessible on most brands), drain pump motor failure, drain hose kink and clog service, pressure switch / water level sensor diagnostic, hard-water mineral buildup on pump impeller (LA-specific). LG, Samsung, Whirlpool, Maytag, KitchenAid, GE, Bosch, Electrolux, Frigidaire, Miele and other major brands. $89 residential diagnostic, waived with repair. BHGS #A49573, EPA 608 Universal certified #1346255700410.",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" },
