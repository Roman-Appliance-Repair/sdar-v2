---
// src/pages/services/refrigerator-repair.astro
// Phase 3 pilot rewrite — neutral multi-county hub.
// Scope per audit-output/rewrite-plans/refrigerator.md:
//   - Title / H1 / eyebrow / subtitle / phone neutralized to all 5 SoCal counties
//   - Schema: Service type with areaServed = 5 counties (was HomeAndConstructionBusiness with 7 LA cities)
//   - LA-content kept but recast as "1 of 5" — Newport Beach (Orange) and Thousand Oaks (Ventura) added
//   - New sections: Refrigerator Types, DIY Self-Check, Water Dispenser/Filter, Repair-vs-Replace
//   - Cities-served block: replaced 11 LA cities with 5-county clusters + /areas/ link

import Layout from '../../layouts/Layout.astro';
import ServiceHero from '../../components/ServiceHero.astro';
import { MAIN_PHONE } from '../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;

const title = "Refrigerator Repair — Same-Day Service Across Southern California | Same Day Appliance Repair";
const description = "Same-day refrigerator repair across LA, Orange, Ventura, San Bernardino & Riverside counties. Sub-Zero, Thermador, Samsung, LG, GE — all brands. Licensed BHGS #A49573, $89 diagnostic, 90-day warranty. Call (424) 325-0520.";
---

<Layout title={title} description={description}>

<!-- ============================================================
     SCHEMA MARKUP — Service with 5-county areaServed
     ============================================================ -->
<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Refrigerator Repair",
  "name": "Refrigerator Repair — Same Day Appliance Repair",
  "description": "Same-day refrigerator repair across Los Angeles, Orange, Ventura, San Bernardino, and Riverside counties. All major and luxury brands, OEM parts, 90-day warranty.",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Same Day Appliance Repair",
    "url": "https://samedayappliance.repair/",
    "telephone": phone,
    "priceRange": "$$",
    "openingHoursSpecification": [
      { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "07:00", "closes": "21:00" },
      { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Saturday"], "opens": "08:00", "closes": "19:00" },
      { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Sunday"], "opens": "09:00", "closes": "17:00" }
    ],
    "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.6", "reviewCount": "37", "bestRating": "5" }
  },
  "areaServed": [
    { "@type": "AdministrativeArea", "name": "Los Angeles County" },
    { "@type": "AdministrativeArea", "name": "Orange County" },
    { "@type": "AdministrativeArea", "name": "Ventura County" },
    { "@type": "AdministrativeArea", "name": "San Bernardino County" },
    { "@type": "AdministrativeArea", "name": "Riverside County" }
  ],
  "offers": {
    "@type": "Offer",
    "priceSpecification": {
      "@type": "PriceSpecification",
      "price": "89.00",
      "priceCurrency": "USD",
      "description": "Residential diagnostic fee, applied toward repair"
    }
  }
})} />

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much does refrigerator repair cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Our diagnostic fee is $89 — applied toward the repair the moment you approve the work. Most refrigerator repairs run between $150 and $400 depending on the part and the brand. Compressor replacements on luxury brands like Sub-Zero or Thermador run higher. We give you a full written estimate before any work begins. No surprises on the invoice."
      }
    },
    {
      "@type": "Question",
      "name": "Which areas of Southern California do you cover?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "All five counties: Los Angeles, Orange, Ventura, San Bernardino, and Riverside. We dispatch from 8 service territories — West Hollywood (HQ), Los Angeles, Beverly Hills, Pasadena, Thousand Oaks, Irvine, Rancho Cucamonga, and Temecula — so the technician on your call is coming from the closest one. From Newport Beach to Pasadena to Thousand Oaks to Temecula, same-day is our standard."
      }
    },
    {
      "@type": "Question",
      "name": "Can you repair my refrigerator the same day?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes — same day is our standard, not a premium. With 8 service territories across SoCal, we have technicians dispatched daily across LA, Orange, Ventura, San Bernardino, and Riverside counties. Call us before noon and we can typically be there that afternoon. We stock the most commonly needed parts so the majority of repairs are completed on the first visit."
      }
    },
    {
      "@type": "Question",
      "name": "Do you repair Sub-Zero and Thermador refrigerators?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Sub-Zero and Thermador are two of the brands our technicians work on most frequently. We use OEM parts specifically sourced for these units — not generic substitutes. Sub-Zero sealed system issues, Thermador cooling failures, Viking compressor problems — we carry parts for these on the van so most repairs don't require a second visit."
      }
    },
    {
      "@type": "Question",
      "name": "What does your refrigerator repair warranty cover?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Every refrigerator repair we complete comes with a 90-day warranty on both parts and labor. If the same issue comes back within that window, we come back and fix it at no charge. We back this up in writing before we leave."
      }
    },
    {
      "@type": "Question",
      "name": "My refrigerator is making a loud noise — is it serious?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "It depends on where the noise is coming from and what it sounds like. A buzzing from the back usually points to the condenser fan motor. Clicking from inside means evaporator fan or defrost timer. A grinding or knocking sound from the bottom can be the compressor — that one you don't want to ignore. Call us and describe what you're hearing — we can often narrow it down before we arrive."
      }
    },
    {
      "@type": "Question",
      "name": "My fridge runs but doesn't cool — what's wrong?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "This is the most common call we get. In SoCal's warm, dry climate, condenser coils clogged with dust are a major culprit — the fridge works hard but can't shed heat. Beyond that: evaporator fan failure, a sealed system problem (refrigerant leak or compressor), or a faulty thermostat. Our technicians carry diagnostic tools to identify the root cause, not just patch the symptom."
      }
    },
    {
      "@type": "Question",
      "name": "When does it make sense to repair vs replace a refrigerator?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Rule of thumb: under 10 years old and the repair is under $400, fix it. Over 10 years old AND the repair is over $500, consider replacing. Luxury brands (Sub-Zero, Thermador, Viking, Wolf, Miele) are almost always worth repairing — they're built for 20+ year service lives and replacement runs $5,000–$15,000+. We tell you straight which side of that line your unit falls on."
      }
    },
    {
      "@type": "Question",
      "name": "Do you repair commercial refrigerators and restaurant equipment?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. We repair commercial refrigerators, walk-in coolers, and restaurant refrigeration throughout Southern California. Our commercial diagnostic fee is $120. We work on True, Traulsen, Turbo Air, Hoshizaki, and other commercial brands. Business downtime is a real cost — we treat commercial calls with the same urgency as residential."
      }
    }
  ]
})} />

