---
// src/pages/services/index.astro
// Wave 8a — Residential Services Hub (DNS cutover blocker resolution).
// Production-tier hub for /services/ entry-point. Replaces prior stub.
// Hub for residential appliance repair across all SoCal counties.
// $89 residential diagnostic. BHGS #A49573 + EPA 608 #1346255700410.
// Em-dash budget ≤2.

import Layout from '../../layouts/Layout.astro';
import { MAIN_PHONE } from '../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/services/";

const title = "Appliance Repair Services Los Angeles — Same Day";
const description = "Same-day residential appliance repair across LA, OC, Ventura, SB, Riverside. Refrigerator, oven, washer, dryer, more. $89 diagnostic. BHGS #A49573.";

const ACRONYMS = new Set(['bbq', 'hvac', 'ac', 'oem', 'led', 'gfci']);
function slugFromPath(p) { return (p.split('/').pop() ?? '').replace(/\.astro$/, ''); }
function slugToLabel(slug) {
  return slug.split('-').map((w) =>
    ACRONYMS.has(w.toLowerCase()) ? w.toUpperCase() : w.charAt(0).toUpperCase() + w.slice(1)
  ).join(' ');
}

const files = Object.keys(import.meta.glob('./*.astro'));
const allItems = files
  .map(slugFromPath)
  .filter((s) => s !== 'index')
  .sort()
  .map((slug) => ({ slug, label: slugToLabel(slug), href: `/services/${slug}/` }));

const faqs = [
  {
    q: "How fast can you come out?",
    a: "Same-day across LA, Orange, and Ventura counties on calls received before 4 PM most weekdays. Inland Bernardino and Riverside next-morning standard. Saturday service runs across all branches; phones answered 24/7 for booking."
  },
  {
    q: "What's the residential diagnostic fee?",
    a: "$89 flat-rate diagnostic, waived when you authorize the repair. We diagnose the actual fault, quote parts and labor in writing, and you decide whether to proceed. No diagnostic surcharges, no after-hours upcharge on standard hours."
  },
  {
    q: "Do you charge after-hours surcharges?",
    a: "Standard hours are 8 AM to 8 PM Monday through Saturday across all branches. We don't add after-hours surcharges on weekend or evening calls within standard hours. Sunday calls and post-8 PM emergency calls are case-by-case; we'll quote any additional charge in writing before dispatching."
  },
  {
    q: "What's included in the 90-day warranty?",
    a: "Every repair includes 90 days parts and labor warranty. If the same part fails or the same fault recurs within 90 days, we replace it free. No fine print, no exclusions on parts we installed. BBB Accredited Business."
  },
  {
    q: "Which appliance brands do you service?",
    a: "Premium tier (Sub-Zero, Wolf, Miele, Thermador, Gaggenau, Viking, La Cornue, BlueStar), mid-premium (Bosch, KitchenAid, JennAir, GE Monogram, GE Profile), and mid-tier mass-market (Whirlpool, GE, Frigidaire, Samsung, LG, Maytag, Amana). Authorized parts pipelines for premium tier; faster sourcing on mid-tier through standard distribution."
  },
  {
    q: "What's the difference between residential and commercial repair?",
    a: "Residential service is $89 diagnostic, covers home appliances under home electrical (120V single-phase, residential gas pressure). Commercial service is $120 diagnostic, covers restaurant and food-service equipment with three-phase electrical, commercial gas line pressure, FDA Food Code compliance, and faster scheduling priority for revenue-impacting equipment. If you're operating a restaurant, hotel, or commercial kitchen, see <a href='/commercial/'>commercial appliance repair</a>."
  },
  {
    q: "Are you licensed and insured?",
    a: "Yes. BHGS #A49573 (California Bureau of Household Goods and Services, the state's appliance repair license) and EPA 608 Universal certified (#1346255700410) for refrigerant work on residential and commercial systems. Fully insured. BBB Accredited Business. License verification details on our <a href='/credentials/licensed/'>licensing page</a>."
  }
];

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": canonical + "#business",
    "name": "Same Day Appliance Repair",
    "url": canonical,
    "telephone": phone,
    "priceRange": "$$",
    "address": {
      "@type": "PostalAddress",
      
      "addressLocality": "Los Angeles",
      "addressRegion": "CA",
      "postalCode": "90048",
      "addressCountry": "US"
    },
    "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "08:00", "closes": "20:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "00:00", "closes": "00:00" }
      ],
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": canonical + "#service",
    "serviceType": "Residential Appliance Repair",
    "name": "Residential Appliance Repair Services",
    "url": canonical,
    "description": "Residential appliance repair across all five SoCal counties. Refrigerator, freezer, oven, range, cooktop, wall oven, dishwasher, washer, dryer, microwave, range hood, garbage disposal, ice maker, wine cooler, water dispenser. Premium brands (Sub-Zero, Wolf, Miele, Thermador, Gaggenau, Viking) and mid-tier (Bosch, KitchenAid, GE, Whirlpool, Samsung, LG). $89 diagnostic, waived with repair. 90-day warranty. BHGS #A49573 and EPA 608 Universal certified (#1346255700410).",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "offers": {
      "@type": "Offer",
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "89.00",
        "priceCurrency": "USD",
        "description": "Residential diagnostic fee, applied toward repair"
      }
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Services", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description}>

<Fragment slot="head-scripts">
  {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
</Fragment>

<!-- HERO -->
<section class="hero">
  <div class="container">
    <p class="eyebrow">Residential Appliance Repair · BHGS #A49573 · EPA 608 Certified</p>
    <h1>Same-Day Residential Appliance Repair Across Southern California.</h1>
    <p class="hero-sub">Refrigerator, oven, dishwasher, washer, dryer, and {allItems.length - 1}+ more appliance categories. $89 diagnostic, waived with repair. 90-day warranty. Phones answered 24/7.</p>
    <div class="hero-cta">
      <a href={phoneHref} class="btn-primary">☎ Call {phone}</a>
      <a href="/contact/" class="btn-secondary">Book Online</a>
    </div>
  </div>
</section>

<!-- 01 INTRO -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">01 · What this hub covers</p>
    <h2 class="section-title">Every residential appliance category, one license, one diagnostic.</h2>

    <p>This is the entry point for residential appliance repair across all five Southern California counties we serve: Los Angeles, Orange, Ventura, San Bernardino, and Riverside. We service home appliances under residential electrical (120V single-phase) and residential gas pressure standards. Premium brands (Sub-Zero, Wolf, Miele, Thermador, Gaggenau, Viking, La Cornue, BlueStar), mid-premium (Bosch, KitchenAid, JennAir, GE Monogram, GE Profile), and mid-tier mass-market (Whirlpool, GE, Frigidaire, Samsung, LG, Maytag, Amana).</p>

    <p>Our license: <strong>BHGS #A49573</strong> (California Bureau of Household Goods and Services), the state's appliance repair license. Plus <strong>EPA 608 Universal certification (#1346255700410)</strong> for refrigerant work on residential and commercial refrigeration. BBB Accredited Business.</p>

    <p>For commercial restaurant and food-service equipment, see <a href="/commercial/">commercial appliance repair</a>; different service tier ($120 diagnostic), different scope, faster scheduling priority for revenue-impacting equipment. For built-in outdoor grills, pizza ovens, and patio heaters, see <a href="/outdoor/">outdoor repair</a>.</p>
  </div>
</section>

<!-- 02 SERVICE CATEGORIES -->
<section class="section section-gray">
  <div class="container">
    <p class="section-number">02 · Service categories</p>
    <h2 class="section-title">All residential appliance categories we service.</h2>

    <div class="card-grid">
      {allItems.map((item) => (
        <a href={item.href} class="card">
          <h3>{item.label}</h3>
          <span class="card-cta">View →</span>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- 03 PRICING -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">03 · Pricing</p>
    <h2 class="section-title">Residential diagnostic and repair pricing.</h2>

    <table class="price-table">
      <thead>
        <tr><th>Service</th><th>Cost</th></tr>
      </thead>
      <tbody>
        <tr><td>Residential diagnostic</td><td>$89, waived with repair</td></tr>
        <tr><td>Mid-tier appliance typical repair (parts + labor)</td><td>$180 to $480</td></tr>
        <tr><td>Premium-tier appliance typical repair</td><td>$340 to $1,200</td></tr>
        <tr><td>Major component (compressor, control board, motor)</td><td>$440 to $2,400</td></tr>
        <tr><td>Multi-component refresh (premium-tier)</td><td>$1,200 to $3,800</td></tr>
        <tr><td>After-hours surcharge (within 8 AM-8 PM)</td><td>None</td></tr>
        <tr><td>Warranty</td><td>90 days parts and labor</td></tr>
      </tbody>
    </table>

    <p>Diagnostic is flat-rate $89, applied toward the repair when you approve the work. We diagnose the actual fault, quote parts and labor in writing, and you decide. No diagnostic surcharges. No surprise charges after the unit is open.</p>
  </div>
</section>

<!-- 04 LA MARKET -->
<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">04 · LA market context</p>
    <h2 class="section-title">Eight branches across the SoCal residential service map.</h2>

    <p>Eight dispatch branches cover the metro residential service map:</p>
    <ul class="bullet-list">
      <li><strong>Los Angeles (Main).</strong> LA County core, Downtown, Mid-Wilshire, Hollywood adjacency.</li>
      <li><strong>West Hollywood.</strong> WeHo, Mid-City, Beverly Grove, Hancock Park.</li>
      <li><strong>Beverly Hills.</strong> BH, Bel Air, Holmby Hills, Westwood, Brentwood.</li>
      <li><strong>Pasadena.</strong> Pasadena, San Marino, La Cañada, Altadena, San Gabriel Valley west.</li>
      <li><strong>Thousand Oaks.</strong> Ventura County, Westlake, Calabasas, Hidden Hills, Agoura.</li>
      <li><strong>Irvine.</strong> Orange County core, Newport, Costa Mesa, Tustin, Anaheim.</li>
      <li><strong>Rancho Cucamonga.</strong> San Bernardino County, Upland, Ontario, Fontana.</li>
      <li><strong>Temecula.</strong> Riverside County, Murrieta, Lake Elsinore, southwest IE.</li>
    </ul>

    <p>Service profile by region: coastal homes (Malibu, Newport, Manhattan Beach, Pacific Palisades) see faster wear on outdoor and indirect-coastal-influenced appliances. Inland (Calabasas, Encino, San Marino, Pasadena) sees longer service life. Hard water in inland and Ventura zones (Calleguas Municipal Water District) accelerates dishwasher and ice maker mineral buildup; we treat with descaling protocols.</p>
  </div>
</section>

<!-- 05 PREMIUM TIER -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">05 · Premium tier specialty</p>
    <h2 class="section-title">Sub-Zero, Wolf, Miele, Thermador, Gaggenau, Viking, BlueStar.</h2>

    <p>About 35% of our residential service load is premium tier appliances in Beverly Hills, Bel Air, Holmby Hills, Pacific Palisades, Brentwood, Newport Coast, Calabasas, and Hidden Hills. Premium-tier service requires authorized parts pipelines, brand-specific diagnostic protocols, and recognition that these units are designed for 18 to 25 year service life. Repair-vs-replace math is almost always tilted toward repair through year 15 to 18 because unit replacement costs $14,000+ for built-in fridges and $9,000+ for built-in wall ovens.</p>

    <p>Sub-Zero Group authorized service path covers Sub-Zero refrigerators, Wolf wall ovens, Wolf cooking, and Cove dishwashers. BSH Group covers Bosch, Thermador, and Gaggenau. Miele USA covers Miele direct. We hold authorized service relationships for these pipelines and produce diagnostic reports compatible with manufacturer warranty submission when units are within coverage windows.</p>
  </div>
</section>

<!-- 06 WHY US -->
<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">06 · Why homeowners call us</p>
    <h2 class="section-title">Seven reasons.</h2>

    <ul class="why-list">
      <li><strong>BHGS #A49573 and EPA 608 Universal certified (#1346255700410).</strong> California's appliance repair license + universal refrigerant cert. See <a href="/credentials/licensed/">licensing page</a>.</li>
      <li><strong>Eight branches, same-day across LA, OC, Ventura.</strong> Inland Bernardino and Riverside next-morning standard.</li>
      <li><strong>$89 flat-rate diagnostic.</strong> Waived with repair. No diagnostic surcharges, no after-hours upcharge in standard hours.</li>
      <li><strong>Premium-tier specialty.</strong> Sub-Zero, Wolf, Miele, Thermador, Gaggenau authorized parts pipelines.</li>
      <li><strong>Manufacturer warranty submission help.</strong> When your unit's still in coverage, we produce diagnostic reports for warranty triage instead of pushing out-of-pocket repair.</li>
      <li><strong>90-day parts and labor warranty.</strong> Same part fails again within 90 days, we replace it free.</li>
      <li><strong>BBB Accredited Business.</strong> Phones answered 24/7.</li>
    </ul>
  </div>
</section>

<!-- 07 FAQ -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">07 · FAQ</p>
    <h2 class="section-title">Common residential service questions.</h2>

    <div class="faq-list">
      {faqs.map(f => (
        <details class="faq-item">
          <summary>{f.q}</summary>
          <p set:html={f.a} />
        </details>
      ))}
    </div>
  </div>
</section>

<!-- 08 RELATED HUBS -->
<section class="section section-gray">
  <div class="container">
    <p class="section-number">08 · Related hubs</p>
    <h2 class="section-title">Other service categories.</h2>

    <div class="related-grid">
      <a href="/commercial/" class="related-card">
        <h3>Commercial Appliance Repair</h3>
        <p>Restaurant, hotel, food-service equipment. $120 diagnostic. Three-phase electrical, commercial gas pressure, FDA Food Code compliance.</p>
      </a>
      <a href="/commercial/refrigeration/" class="related-card">
        <h3>Commercial Refrigeration</h3>
        <p>Reach-in coolers, walk-in cooler/freezer, prep tables, display cases. EPA 608 certified.</p>
      </a>
      <a href="/commercial/ice-machines/" class="related-card">
        <h3>Commercial Ice Machines</h3>
        <p>Hoshizaki, Scotsman, Manitowoc, Ice-O-Matic. Cube, flake, nugget, dispenser models.</p>
      </a>
      <a href="/outdoor/" class="related-card">
        <h3>Outdoor Living</h3>
        <p>Built-in grills, pizza ovens, patio heaters, outdoor kitchen, outdoor refrigeration.</p>
      </a>
      <a href="/credentials/licensed/" class="related-card">
        <h3>License & Credentials</h3>
        <p>BHGS #A49573, EPA 608, BBB Accredited. Verification details and contractor lookup.</p>
      </a>
      <a href="/contact/" class="related-card">
        <h3>Book Service</h3>
        <p>Same-day across LA, OC, Ventura. Online booking, phones answered 24/7.</p>
      </a>
    </div>
  </div>
</section>

<!-- 09 BOTTOM CTA -->
<section class="bottom-cta">
  <div class="container">
    <h2>Appliance down? Call today.</h2>
    <p>$89 residential diagnostic waived with repair. 8 branches, same-day across LA, OC, Ventura. BHGS #A49573 and EPA 608 Universal certified.</p>
    <div class="cta-row">
      <a href={phoneHref} class="btn-primary">☎ Call {phone}</a>
      <a href="/contact/" class="btn-secondary">Book Online</a>
    </div>
  </div>
</section>

</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --white: #fff; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; --ease: cubic-bezier(0.4, 0, 0.2, 1); --font-body: inherit; }
  .hero { background: var(--black); color: #fff; padding: 80px 24px 64px; }
  .hero .container { max-width: 1100px; margin: 0 auto; }
  .hero .eyebrow { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin: 0 0 16px; }
  .hero h1 { font-size: clamp(1.9rem, 4.5vw, 3rem); font-weight: 800; margin: 0 0 16px; line-height: 1.1; letter-spacing: -0.02em; max-width: 880px; color: #fff; }
  .hero-sub { font-size: 1.05rem; line-height: 1.6; color: #c9c9c9; max-width: 720px; margin: 0 0 28px; }
  .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; }
  .section { padding: 64px 24px; }
  .section-gray { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; }
  .container.narrow { max-width: 820px; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  h2.section-title { font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 800; margin: 0 0 16px; line-height: 1.2; color: var(--text); letter-spacing: -0.01em; }
  .section p { margin: 0 0 18px; font-size: 1rem; line-height: 1.75; color: var(--text); }
  .section a { color: var(--red); font-weight: 600; text-decoration: none; }
  .section a:hover { text-decoration: underline; }
  .bullet-list { padding-left: 22px; margin: 14px 0; }
  .bullet-list li { font-size: 0.98rem; line-height: 1.7; color: var(--text); margin-bottom: 10px; }
  .bullet-list strong { color: var(--text); font-weight: 700; }
  .why-list { padding-left: 22px; margin: 18px 0; }
  .why-list li { font-size: 1rem; line-height: 1.7; color: var(--text); margin-bottom: 12px; }
  .why-list strong { color: var(--text); font-weight: 700; }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 22px; background: #fff; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
  .price-table th, .price-table td { padding: 12px 16px; text-align: left; border-bottom: 1px solid var(--border); font-size: 0.95rem; }
  .price-table th { background: var(--gray); font-weight: 700; color: var(--text); letter-spacing: 0.02em; }
  .price-table tr:last-child td { border-bottom: none; }
  .card-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 14px; margin-top: 22px; }
  .card { display: flex; flex-direction: column; justify-content: space-between; padding: 22px; background: #fff; border: 1px solid var(--border); border-radius: 8px; color: var(--text); text-decoration: none; transition: all 0.2s var(--ease); min-height: 110px; }
  .card:hover { border-color: var(--red); transform: translateY(-2px); box-shadow: 0 4px 14px rgba(0,0,0,0.06); }
  .card h3 { font-size: 0.98rem; font-weight: 800; margin: 0 0 10px; color: var(--text); letter-spacing: -0.01em; }
  .card-cta { font-size: 0.78rem; font-weight: 700; color: var(--red); letter-spacing: 0.05em; }
  .related-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 18px; margin-top: 22px; }
  .related-card { display: block; background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 22px; text-decoration: none; color: var(--text); transition: all 0.2s; }
  .related-card:hover { border-color: var(--red); transform: translateY(-2px); box-shadow: 0 4px 14px rgba(0,0,0,0.06); }
  .related-card h3 { font-size: 1rem; font-weight: 800; margin: 0 0 8px; color: var(--text); }
  .related-card p { font-size: 0.85rem; color: var(--muted); margin: 0; line-height: 1.6; }
  .faq-list { margin-top: 24px; }
  .faq-item { background: #fff; border: 1px solid var(--border); border-radius: 6px; padding: 16px 22px; margin-bottom: 10px; }
  .faq-item summary { font-weight: 700; cursor: pointer; font-size: 0.98rem; color: var(--text); list-style: none; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::before { content: "+ "; color: var(--red); font-weight: 800; margin-right: 6px; }
  .faq-item[open] summary::before { content: "− "; }
  .faq-item p { font-size: 0.93rem; color: var(--text); line-height: 1.7; margin: 12px 0 0; }
  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { color: #fff; margin: 0 0 14px; font-size: clamp(1.5rem, 3vw, 2rem); }
  .bottom-cta p { color: #aaa; margin: 0 0 28px; font-size: 1.02rem; }
  .cta-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 14px 28px; border-radius: 5px; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 14px 28px; border-radius: 5px; border: 2px solid rgba(255,255,255,0.35); font-weight: 600; text-decoration: none; }
</style>
