---
import Layout from '../../layouts/Layout.astro';

const title = "Wine Cellar Cooling Repair Los Angeles | WhisperKOOL · CellarPro · Breezaire";
const description = "Wine cellar cooling repair across LA — split, ducted, self-contained refrigeration units. EPA-certified refrigerant service. $89 diagnostic waived with repair. (424) 325-0520.";
const canonical = "https://samedayappliance.repair/services/wine-cellar-cooling-repair/";

const faqs = [
  {
    "q": "What brands of wine cellar cooling do you service?",
    "a": "WhisperKOOL, CellarPro, Breezaire, Wine Guardian, KoolR, US Cellar Systems, and HVAC-grade Carrier/Trane custom-cellar systems. EPA 608 certified for R-404A, R-134a, and R-513A."
  },
  {
    "q": "My cellar runs but room won’t hold temperature — what now?",
    "a": "Common cause is refrigerant charge drift, condenser fouling, or envelope failure (missing vapor barrier, door seal). We diagnose with superheat/subcooling readings before recommending parts."
  },
  {
    "q": "Do you provide temporary cooling while parts arrive?",
    "a": "Yes. For at-risk collections, we can deploy portable spot cooling to stabilize the room while we wait for parts — typically 1–3 days for OEM components."
  }
];

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": "https://samedayappliance.repair/services/wine-cellar-cooling-repair/#business",
    "name": "Same Day Appliance Repair",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": "https://samedayappliance.repair/services/wine-cellar-cooling-repair/",
    "telephone": "+1-424-325-0520",
    "priceRange": "$$$",
    "areaServed": [
      {
        "@type": "AdministrativeArea",
        "name": "Los Angeles County"
      },
      {
        "@type": "AdministrativeArea",
        "name": "Orange County"
      },
      {
        "@type": "AdministrativeArea",
        "name": "Ventura County"
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Wine Cellar Cooling Repair",
    "provider": {
      "@id": "https://samedayappliance.repair/services/wine-cellar-cooling-repair/#business"
    },
    "areaServed": [
      {
        "@type": "AdministrativeArea",
        "name": "Los Angeles County"
      },
      {
        "@type": "AdministrativeArea",
        "name": "Orange County"
      },
      {
        "@type": "AdministrativeArea",
        "name": "Ventura County"
      }
    ],
    "description": "Wine cellar cooling repair across LA — split, ducted, self-contained refrigeration units. EPA-certified refrigerant service. $89 diagnostic waived with repair. (424) 325-0520.",
    "offers": {
      "@type": "Offer",
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "89.00",
        "priceCurrency": "USD",
        "description": "Residential diagnostic fee, waived with repair"
      }
    }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://samedayappliance.repair/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Services",
      "item": "https://samedayappliance.repair/services/"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "Wine Cellar Cooling Repair",
      "item": "https://samedayappliance.repair/services/wine-cellar-cooling-repair/"
    }
  ] }
];
---
<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">
    {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
  </Fragment>

  <section class="ph-hero">
    <div class="ph-wrap">
      <p class="ph-eyebrow">Placeholder · Content Coming Soon</p>
      <h1>Wine Cellar Cooling Repair in Los Angeles</h1>
      <p class="ph-intro">Cellar-grade refrigeration units (WhisperKOOL, CellarPro, Breezaire, Wine Guardian, KoolR) keep climate-controlled wine rooms within tight temperature and humidity bands. We repair split systems, ducted air handlers, and self-contained through-wall units across LA, Orange, and Ventura counties — refrigerant leak detection, evaporator fan service, control board replacement, condensate pump rebuilds. EPA 608 certified. Same-day diagnostic.</p>
      <div class="ph-ctas">
        <a href="tel:+14243250520" class="ph-btn">Call (424) 325-0520</a>
        <a href="/contact/" class="ph-btn ph-btn-ghost">Contact Us</a>
      </div>
    </div>
  </section>

  <section class="ph-faq">
    <div class="ph-wrap">
      <h2>Frequently Asked</h2>
      {faqs.map(f => (<details class="ph-detail"><summary>{f.q}</summary><p>{f.a}</p></details>))}
    </div>
  </section>
</Layout>

<style>
  .ph-wrap { max-width: 820px; margin: 0 auto; padding: 0 24px; }
  .ph-hero { background: #0a0a0a; color: #fff; padding: 64px 0; }
  .ph-eyebrow { color: #C8102E; font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; margin: 0 0 14px; }
  .ph-hero h1 { font-size: clamp(1.6rem, 3.2vw, 2.4rem); font-weight: 800; margin: 0 0 16px; line-height: 1.2; }
  .ph-intro { color: rgba(255,255,255,0.85); font-size: 1.05rem; margin: 0 0 28px; line-height: 1.65; }
  .ph-ctas { display: flex; gap: 12px; flex-wrap: wrap; }
  .ph-btn { display: inline-block; background: #C8102E; color: #fff; padding: 12px 24px; text-decoration: none; font-weight: 700; border-radius: 4px; font-size: 0.95rem; }
  .ph-btn-ghost { background: transparent; border: 1px solid rgba(255,255,255,0.4); }
  .ph-faq { padding: 56px 0; background: #f5f5f5; }
  .ph-faq h2 { font-size: 1.5rem; margin: 0 0 20px; color: #0a0a0a; }
  .ph-detail { background: #fff; border: 1px solid #e2e2e2; padding: 14px 18px; border-radius: 4px; margin-bottom: 8px; }
  .ph-detail summary { font-weight: 600; cursor: pointer; color: #0a0a0a; }
  .ph-detail p { margin: 10px 0 0; color: #444; line-height: 1.6; }
</style>
