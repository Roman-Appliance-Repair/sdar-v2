---
// src/pages/services/microwave-repair/plate-not-rotating.astro
// Wave 4b — failure-mode sub-service under residential microwave pillar.
// SEO: "microwave turntable not spinning", "microwave plate stuck", "turntable motor".
// Lower urgency than other 3 sub-pages: microwave still heats, just creates hot
// spots without rotation. ~25% resolve at $89 dx with re-alignment or coupler.
// $89 residential. BHGS #A49573 + EPA 608 Universal #1346255700410.
import Layout from '../../../layouts/Layout.astro';
import ServiceHero from '../../../components/ServiceHero.astro';
import { MAIN_PHONE } from '../../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/services/microwave-repair/plate-not-rotating/";

const title = "Microwave Turntable Not Spinning, Plate Stuck, Motor, Coupler, $89 Diagnostic";
const description = "Microwave plate not rotating across LA, OC, Ventura. Turntable motor, drive coupler, support roller, alignment. Customer-side checks first. $89 diagnostic. (424) 325-0520.";

const faqs = [
  {
    q: "My microwave plate isn't spinning. Is this dangerous?",
    a: "Not immediately dangerous. The microwave still heats food without rotation, but creates hot spots (some areas overcooked, others undercooked). Worth booking a service call when convenient, but no urgent stop required. Distinct from sparking issues, which are an immediate safety concern, see <a href=\"/services/microwave-repair/sparking-arcing/\">sparking / arcing</a> for that scope.",
  },
  {
    q: "What's the cheapest fix?",
    a: "Drive coupler replacement. The drive coupler is the small plastic clutch that connects the motor shaft (under the cavity floor) to the bottom of the glass plate. $20 to $60 part, 5-minute install. Plus $89 diagnostic = $129 total. About year 4 to 7 wear pattern, plastic fatigues from heat cycles. Most common cheap fix on this category.",
  },
  {
    q: "Customer-side checks before booking?",
    a: "Three quick checks. (1) Is the plate seated correctly on the coupling? Lift, rotate, set down on the three coupling tabs (you'll feel it click into the right position). (2) Is the drive coupler under the plate snug on the motor shaft, or has it slipped off? (3) Is the support roller ring intact under the plate? Cracks or breaks in the plastic ring stop rotation. About 25% of 'plate not spinning' calls resolve at one of these three steps.",
  },
  {
    q: "Turntable motor versus drive coupler, how do you tell which is failing?",
    a: "Listen with the door open and microwave off. Press the door switch lever down with one finger to simulate door closed (some models will spin the motor with door open in this 'paused' state). If you hear the motor humming or spinning under the cavity, the motor is fine and the coupler is broken. If silent, the motor is the failure. Replacement costs differ significantly: coupler $20 to $60, motor $200 to $340.",
  },
  {
    q: "My Panasonic NN-SN microwave plate suddenly stopped spinning but heats fine. Motor?",
    a: "Possibly, but Panasonic NN-SN and NN-SD inverter models tie rotation to the control board signal rather than a standalone motor circuit. If the motor tests fine when manually powered, the control board's rotation-control output may have failed. Diagnostic distinguishes between motor failure ($200 to $340) and control board signal issue ($440 to $680). We test motor first, then board.",
  },
  {
    q: "What's your warranty?",
    a: "90 days parts and labor on every repair. BHGS #A49573, EPA 608 Universal certified (#1346255700410), BBB A+ accredited.",
  },
];

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": canonical + "#business",
    "name": "Same Day Appliance Repair",
    "url": canonical,
    "telephone": phone,
    "priceRange": "$$",
    "description": "Microwave turntable not rotating diagnostic and repair across all five SoCal counties. Drive coupler ($20 to $60 part, 5-minute install), turntable motor (year 4 to 7 typical), support roller, plate alignment. Inverter-model integration on Panasonic NN-SN/NN-SD and Samsung. BHGS #A49573. EPA 608 Universal certified #1346255700410.",
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": canonical + "#service",
    "serviceType": "Microwave Turntable Repair",
    "name": "Microwave Plate Not Rotating Diagnostic and Repair",
    "url": canonical,
    "description": "Residential microwave turntable diagnostic across all five SoCal counties. Drive coupler (cheapest fix, year 4 to 7 typical), turntable synchronous motor, support roller ring, plate alignment (~25% of calls resolve at $89 dx). Inverter-model rotation control on Panasonic NN-SN / NN-SD and Samsung inverter (some models tie rotation to control board signal). $89 residential diagnostic, applied toward repair.",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" },
    ],
    "offers": {
      "@type": "Offer",
      "priceRange": "$89-$700",
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "89.00",
        "priceCurrency": "USD",
        "description": "Residential diagnostic fee, applied toward repair. No emergency surcharge.",
      },
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map((f) => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://samedayappliance.repair/services/" },
      { "@type": "ListItem", "position": 3, "name": "Microwave Repair", "item": "https://samedayappliance.repair/services/microwave-repair/" },
      { "@type": "ListItem", "position": 4, "name": "Plate Not Rotating", "item": canonical },
    ],
  },
];
---

<Layout title={title} description={description} canonical={canonical}>

<Fragment slot="head-scripts">
  {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
</Fragment>

<ServiceHero
  eyebrow="Failure mode · Drive Coupler · Turntable Motor · Support Roller · Alignment"
  title="Microwave Turntable Not Spinning, Plate Stuck"
  subtitle="Residential microwaves across LA, OC, Ventura, Riverside. Microwave still heats without rotation; not urgent. Drive coupler often fixes for $129 total ($89 dx + $40 part). (424) 325-0520"
  heroImageTitle="Microwave Turntable Repair"
  showBranches={true}
/>

<section class="section">
  <div class="container narrow">
    <p class="section-number">01 · Lower urgency, often a cheap fix</p>
    <h2 class="section-title">The microwave still heats. Just creates hot spots without rotation.</h2>

    <p>Plate-not-spinning is the lowest-urgency category in microwave service. The unit still heats food, the magnetron is fine, all the high-voltage components are working. The plate just isn't rotating, which means cold spots in some areas of the food while others get overcooked. Worth booking a service call when convenient, but no urgent stop required.</p>

    <p>(For urgent issues, see <a href="/services/microwave-repair/sparking-arcing/">sparking / arcing</a> if you've seen sparks inside the cavity, or <a href="/services/microwave-repair/no-power/">no power</a> if the microwave is completely dead.)</p>

    <p>About 25% of plate-not-spinning calls resolve at the $89 diagnostic with re-alignment or a quick drive coupler swap. Most others are turntable motor replacement at $200 to $340.</p>

    <p>BHGS #A49573, EPA 608 Universal certified (#1346255700410). Phones answered 24/7.</p>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">02 · Customer-side first checks</p>
    <h2 class="section-title">Three quick checks before booking.</h2>

    <ol class="num-list">
      <li><strong>Plate seated correctly?</strong> Lift, rotate, set down on the three coupling tabs. You'll feel it click into the right position when the tabs engage. Misalignment alone stops rotation.</li>
      <li><strong>Drive coupler intact?</strong> The small plastic clutch under the plate, sits on the motor shaft. If it's slipped off or broken, lift the plate to inspect. A new coupler is $20 to $60 from any parts supplier and takes 5 minutes to install if you can identify the part number from your model.</li>
      <li><strong>Support roller ring intact?</strong> The plastic ring with three small wheels under the plate. Cracks or broken wheels stop rotation. $40 to $90 part, easy customer install if you confirm the model number.</li>
    </ol>

    <p>If those three don't resolve it, the motor is likely the cause and we can replace it.</p>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">03 · Drive coupler (cheapest fix)</p>
    <h2 class="section-title">$20 to $60 part, 5-minute install. Year 4 to 7 typical.</h2>

    <p>The drive coupler is a small plastic clutch that connects the motor shaft (which protrudes through the cavity floor) to the bottom of the glass turntable plate. Plastic fatigues from years of heat cycles inside a microwave; cracks form, eventually breaks. Symptom: motor humming or spinning under the cavity, plate stationary above.</p>

    <p>Replacement is the cheapest residential microwave repair we do: $20 to $60 part, 5-minute install. With $89 diagnostic, $129 typical total. We carry common couplers on the van for the top six brands (GE, Whirlpool, Samsung, LG, Panasonic, Sharp).</p>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">04 · Turntable motor (most common parts replacement)</p>
    <h2 class="section-title">Year 4 to 7 typical. Small synchronous motor.</h2>

    <p>The turntable motor is a small synchronous motor mounted under the cavity floor. Year 4 to 7 typical wear pattern, fails open or seizes mechanically. With the door switch lever depressed (simulating closed door, on models that allow), you can sometimes hear whether the motor is humming silently (failed) or spinning audibly (working, coupler at fault).</p>

    <p>Replacement $200 to $340. Common across virtually all brands; we carry generic-spec replacement motors that fit GE, Whirlpool, Samsung, LG, Panasonic, Sharp, and most mid-tier microwaves.</p>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">05 · Inverter-model integration (Panasonic NN-SN/NN-SD, Samsung)</p>
    <h2 class="section-title">Some inverter models tie rotation to the control board.</h2>

    <p>On Panasonic NN-SN, NN-SD, and some newer Samsung inverter models, the rotation drive is integrated into the control board's signal output rather than running on a standalone motor circuit. If the motor tests fine when manually powered (we bench-test it on the van), the control board's rotation-control output is the failure.</p>

    <p>Diagnostic distinguishes motor failure ($200 to $340 replacement) from control board signal issue ($440 to $680 board replacement). We test the motor first; replacing the control board on a year-9+ unit is a replace-conversation moment given the cost approaches new-microwave territory.</p>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">06 · Recent jobs</p>
    <h2 class="section-title">Real diagnostic stories from the last few weeks.</h2>

    <p class="lead">Composite examples; model numbers, ages, and prices are accurate to typical scope.</p>

    <div class="story">
      <h3>Pasadena · GE Profile OTR microwave, 5 years old</h3>
      <p>Plate stopped spinning. Diagnosed: drive coupler cracked at the motor-shaft hub. Replaced coupler ($40 part), 5-minute install. Total: $89 plus $40 plus 15 minutes = $129. Cheapest microwave repair we did that week.</p>
    </div>

    <div class="story">
      <h3>West Hollywood · Whirlpool countertop microwave, 7 years old</h3>
      <p>Plate stationary, motor silent under the cavity. Diagnosed: turntable motor failed (year 7 typical). Replaced motor. Total: $89 plus $210 plus 45 minutes = $290.</p>
    </div>

    <div class="story">
      <h3>Beverly Hills · Miele M Touch built-in microwave, 6 years old</h3>
      <p>Plate not rotating, motor humming but stuck. Diagnosed: motor bearings seized plus support roller ring cracked (heavy dish over the years). Replaced both. Total: $89 plus $260 parts plus 1 hour = $390.</p>
    </div>

    <div class="story">
      <h3>Marina del Rey · Panasonic NN-SN686S countertop inverter, 8 years old</h3>
      <p>Customer reported plate not rotating. Bench-tested motor on the van: motor functional. Diagnosed: control board rotation-control signal output failed. Quoted $89 plus $480 plus 1 hour = $640. Customer chose replacement (countertop microwave at year 8, $640 repair on $250 unit doesn't pencil out). Total: $89 diagnostic, customer left with honest answer and pursued replacement.</p>
    </div>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">07 · Honest opinion</p>
    <h2 class="section-title">Not urgent. Often $129 to fix. Don't replace the microwave for a $40 part.</h2>

    <p>Plate-not-spinning is one of the easiest microwave repairs in the field, and one of the most-overpriced when customers don't have a reliable shop. We've heard customers say a previous shop quoted them $300 for a coupler swap. The part is $40, the install is 5 minutes, our charge for that work is $89 diagnostic plus the $40 part = $129.</p>

    <p>Same tier framing applies as the rest of microwave service. Year-8+ countertop with motor failure may pencil as a replacement decision, $290 motor on a $250 unit. OTR and pro-style/built-in always justify repair. Inverter-model control board failure year 9+ is a replacement conversation regardless of tier.</p>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">08 · Pricing</p>
    <h2 class="section-title">What microwave-plate-not-rotating repair actually costs.</h2>

    <table class="price-table">
      <thead>
        <tr><th>Service</th><th>Cost</th></tr>
      </thead>
      <tbody>
        <tr><td>Diagnostic visit (includes alignment check)</td><td>$89, waived with repair</td></tr>
        <tr><td>Drive coupler replacement (cheapest fix)</td><td>$129 typical ($89 plus $40 coupler)</td></tr>
        <tr><td>Support roller ring</td><td>$40 to $90 plus $89 dx</td></tr>
        <tr><td>Turntable motor replacement</td><td>$200 to $340 plus dx</td></tr>
        <tr><td>Motor plus support roller (combined)</td><td>$340 to $440</td></tr>
        <tr><td>Control board signal issue (Panasonic NN inverter)</td><td>$440 to $680</td></tr>
        <tr><td>Multi-component repair</td><td>$340 to $580</td></tr>
        <tr><td>Warranty</td><td>90 days parts and labor</td></tr>
      </tbody>
    </table>
    <p class="price-note">Residential $89 diagnostic, applied toward repair. About 25% of these calls resolve at the diagnostic with re-alignment or coupler-only fix.</p>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">09 · Why us</p>
    <h2 class="section-title">Five reasons.</h2>

    <ul class="why-list">
      <li><strong>Coupler-first diagnostic.</strong> Cheap fix is checked before motor-replacement quote.</li>
      <li><strong>Common parts on the van.</strong> Drive couplers and turntable motors for top six brands (GE, Whirlpool, Samsung, LG, Panasonic, Sharp).</li>
      <li><strong>Inverter-model awareness.</strong> Panasonic NN-SN/NN-SD and Samsung inverter rotation diagnosed correctly.</li>
      <li><strong>BHGS #A49573 plus EPA 608 Universal certified (#1346255700410).</strong> Verifiable.</li>
      <li><strong>Same-day across LA, OC, Ventura.</strong> 24/7 phones, no emergency surcharge.</li>
    </ul>

    <p>Sister sub-services: <a href="/services/microwave-repair/not-heating/">not heating</a>, <a href="/services/microwave-repair/no-power/">no power</a>, <a href="/services/microwave-repair/sparking-arcing/">sparking / arcing (safety)</a>. Parent: <a href="/services/microwave-repair/">microwave repair</a>. Credentials: <a href="/credentials/licensed/">BHGS license</a>, <a href="/credentials/epa-certified/">EPA 608</a>.</p>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">10 · FAQ</p>
    <h2 class="section-title">Microwave plate not rotating, common questions.</h2>

    <div class="faq-list">
      {faqs.map((f) => (
        <details class="faq-item">
          <summary>{f.q}</summary>
          <p set:html={f.a} />
        </details>
      ))}
    </div>
  </div>
</section>

<section class="bottom-cta">
  <div class="container">
    <h2>Plate Not Spinning? Call When Convenient.</h2>
    <p>Not urgent. $89 residential diagnostic, waived with repair. Drive coupler often fixes for $129 total. Same-day across LA, OC, Ventura. BHGS #A49573, EPA 608 Universal certified (#1346255700410).</p>
    <div class="cta-row">
      <a href={phoneHref} class="btn-primary">☎ Call {phone}</a>
      <a href="/contact/" class="btn-secondary">Book Online</a>
    </div>
  </div>
</section>

</Layout>

<style>
