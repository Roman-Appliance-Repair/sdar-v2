import Layout from '../../../layouts/Layout.astro';
import ServiceHero from '../../../components/ServiceHero.astro';
import { MAIN_PHONE } from '../../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/services/microwave-repair/sparking-arcing/";

const title = "Microwave Sparking, Arcing Inside, SAFETY First, $89 Diagnostic";
const description = "Microwave sparking or arcing across LA, OC, Ventura. STOP USE IMMEDIATELY — fire risk. Magnetron, waveguide cover diagnosis. BHGS #A49573. $89 dx waived.";

const faqs = [
  {
    q: "Is it dangerous to use my microwave once before service?",
    a: "Yes, do not use it. Sparking or arcing inside a microwave can ignite plastic interior parts (the waveguide cover is mica with plastic edge bonding) or cause a kitchen fire on the next cycle. We've seen the damage progress from 'small spark' to 'burnt cavity' in one or two more uses. Unplug the microwave immediately and use a toaster oven or stovetop until we arrive.",
  },
  {
    q: "What's that small panel inside that's burning, and what's it called?",
    a: "Mica waveguide cover. Customers often call it 'the wax paper thing' or 'the cardboard piece', it's actually mica (a heat-resistant mineral). It covers the opening where microwaves enter the cavity from the magnetron, protecting the magnetron from food splatter. Year 6 to 10 wear: food splashes (cheese, soup, sauce) bake onto the mica, eventually ignite during operation. The cover itself is $40 to $120 part, $89 dx plus 15-minute install. Most common sparking-microwave repair we run.",
  },
  {
    q: "My waveguide cover is white and discolored but not burnt. Replace?",
    a: "Probably not yet. White discoloration on mica waveguide cover is typically food residue or mineral deposit from steam, not burn damage. Wipe gently with a damp cloth (no abrasive cleaners on mica), assess. If the surface is intact and clean wipes off, the cover is still functional. Brown or black burn marks, with crusty residue or visible carbonization, indicate active arcing damage and replacement is required. We make the call at $89 dx.",
  },
  {
    q: "I noticed a metal twist-tie inside, is that what was sparking?",
    a: "Yes. Foreign metal in a running microwave arcs immediately and aggressively. Aluminum foil scraps, twist-ties, decorative china with metallic gold or silver trim, all cause sparking. Customer-side cause, no mechanical fault on the unit itself. $89 diagnostic confirms the cooktop interior is undamaged from the arcing event (sometimes the foil scratched the cavity paint, see next question). No parts billed if cavity is intact, just the diagnostic.",
  },
  {
    q: "Can the cavity coating be repaired if it's damaged?",
    a: "Yes for surface-level paint damage, $120 to $280 cavity coating repair. Pro-style/built-in (Wolf, Miele, Thermador, GE Monogram, Sharp drawer) cavity repair always justified given the replacement cost. Mid-tier countertop year 10+ with extensive cavity damage is a replace conversation. Repair cost $200 to $400 on a $150 to $300 unit doesn't pencil out at year-10+.",
  },
  {
    q: "Can I run the microwave empty to test it?",
    a: "No, never. Running a microwave empty (no water or food in the cavity) damages the magnetron because the produced microwaves have nothing to absorb them, the energy reflects back and overheats the magnetron. If you want to test after waveguide cover replacement, use a cup of water (8 oz minimum) to absorb the energy.",
  },
  {
    q: "What's your warranty?",
    a: "90 days parts and labor on every repair. BHGS #A49573, EPA 608 Universal certified (#1346255700410), BBB A+ accredited.",
  },
];

