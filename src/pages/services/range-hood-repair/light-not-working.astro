---
// src/pages/services/range-hood-repair/light-not-working.astro
// Wave 4a — Range Hood Light sub-service. Failure-mode pattern.
// Halogen burnout DIY-able + LED conversion path. Wolf/Thermador halogen 2-3wk lead time.
// Bulb socket corrosion (LA marine layer humidity coastal homes).
// Capacitive-touch switch glass damage from grease scrubbing.
// $89 residential, BHGS #A49573, EPA 608 #1346255700410. 4 schema entities.
import Layout from '../../../layouts/Layout.astro';
import ServiceHero from '../../../components/ServiceHero.astro';
import { MAIN_PHONE } from '../../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/services/range-hood-repair/light-not-working/";

const title = "Range Hood Light Not Working Repair LA — Same Day";
const description = `Range hood light not working? LA same-day. Bulb burnout, socket corrosion, switch failure, LED retrofit option. Wolf, Thermador, Vent-A-Hood. BHGS #A49573.`;

const faqs = [
  {
    q: "My range hood light stopped working. What's the first thing to check?",
    a: "The bulb. Halogen bulbs in range hoods burn out at year 1 to 3 typical, the most common cause of a dead light. Pull the lens cover (twist or unclip depending on hood model), inspect the bulb for darkening or visible filament break, replace with the same wattage and base type. Bulbs run $5 to $20 at hardware stores or appliance parts suppliers. If you have a pro-style hood (Wolf, Thermador, Vent-A-Hood) the bulbs are specialty parts, $30 to $80, often 2 to 3 week lead time from authorized distributors. We carry common bulb types on the truck."
  },
  {
    q: "Should I convert my halogen lights to LED while I'm at it?",
    a: "If your hood was made before 2018, probably yes. LED bulbs that fit halogen sockets (G4, G9, GU10 base types) cost more upfront ($15 to $35 each vs $5 to $20 for halogen) but last 8 to 12 years instead of 1 to 3 years. They run cooler (no impact on grease filter heat), use 80% less energy, and don't risk shattering when grease droplets hit a hot bulb. We do retrofit on the same visit for $89 diagnostic plus parts (typically $30 to $80 for two LED bulbs in a standard hood). Hoods made 2018+ usually came LED from factory, no retrofit needed."
  },
  {
    q: "I replaced the bulb and it still doesn't work. Now what?",
    a: "Two next stops in order. (1) Bulb socket corrosion. Kitchen humidity (especially in coastal LA homes in Santa Monica, Marina del Rey, Manhattan Beach, Pacific Palisades) corrodes the brass or chrome contacts inside the bulb socket at year 5+. The bulb makes intermittent contact or no contact. Socket replacement runs $80 to $180. (2) Switch failure. The light switch (rocker on older hoods, capacitive touch on newer pro-style hoods) can fail mechanically or electronically. Rocker switch replacement $120 to $240, capacitive touch panel replacement $260 to $440 depending on integration with main control board."
  },
  {
    q: "My capacitive touch glass cracked or doesn't respond. Can I just clean it?",
    a: "Cleaning rarely fixes it once cracked or unresponsive. Capacitive touch glass on pro-style hoods (Wolf, Thermador, Bosch, Miele, Zephyr) takes damage from aggressive grease scrubbing with steel wool or coarse cleaning pads. The capacitive sensors live behind the glass; once the glass surface is etched or cracked, the touch detection drifts or fails. Replacement panel runs $260 to $440 typical, $440 to $680 on premium pro-style integration with main control board. We diagnose whether it's the glass, the underlying sensor board, or the main control board sending signals."
  },
  {
    q: "Wolf and Thermador halogen bulbs are unusual. Why is sourcing slow?",
    a: "Pro-style hoods use specialty halogen bulbs that aren't carried at hardware stores or general appliance parts suppliers. Wolf uses 12V xenon-halogen capsule bulbs, Thermador uses GY6.35 base 12V halogen, Vent-A-Hood often uses bi-pin G4 halogen specific to their fixture. Sourcing requires authorized distributor channels, 2 to 3 week lead time typical. We can stock on truck for the brands we service most often if you're a recurring customer; otherwise we order during the diagnostic visit and return for install on the lead-time window. The customer can also order direct and we install on a follow-up if preferred."
  },
  {
    q: "Will my home insurance cover bulb replacement after a kitchen grease fire?",
    a: "Usually yes if the bulb damage was caused by the fire or its smoke. Kitchen fires that involve the cooktop almost always damage the hood: bulbs shatter, switch electronics fail from heat exposure, capacitive touch glass cracks from rapid temperature change, and the motor itself can be compromised. Homeowner's insurance typically covers the appliance damage as part of the claim. We provide written assessment and itemized replacement quotes for insurance documentation. Claim management is between you and your carrier; we focus on the assessment and repair."
  },
  {
    q: "What's your warranty?",
    a: "90 days SDAR labor and parts warranty on the work we perform. If the same component fails within 90 days, we replace it free. BHGS #A49573, BBB Accredited Business, EPA 608 Universal certified #1346255700410."
  }
];

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": canonical + "#business",
    "name": "Same Day Appliance Repair",
    "url": canonical,
    "telephone": phone,
    "priceRange": "$$",
    "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "08:00", "closes": "20:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "00:00", "closes": "00:00" }
      ],
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": canonical + "#service",
    "serviceType": "Range Hood Light Repair",
    "name": "Range Hood Light Diagnostic and Repair Service",
    "url": canonical,
    "description": "Residential range hood light diagnostic and repair across all five SoCal counties. Halogen bulb burnout (year 1 to 3 typical), LED retrofit conversion, bulb socket corrosion (coastal LA marine layer humidity), rocker switch and capacitive touch switch failure, wiring junction box corrosion, pro-style halogen sourcing (Wolf 12V xenon-halogen, Thermador GY6.35 base, Vent-A-Hood bi-pin G4, 2 to 3 week lead time from authorized distributors), kitchen fire damage assessment for insurance documentation. Wolf, Viking, Thermador, Vent-A-Hood, Best, Zephyr, Bosch, Miele, Gaggenau, Broan, KitchenAid, GE, Samsung, LG. $89 residential diagnostic, waived with repair. BHGS #A49573, EPA 608 Universal certified #1346255700410.",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, waived with repair" } }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://samedayappliance.repair/services/" },
      { "@type": "ListItem", "position": 3, "name": "Range Hood Repair", "item": "https://samedayappliance.repair/services/range-hood-repair/" },
      { "@type": "ListItem", "position": 4, "name": "Light Not Working", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>
<Fragment slot="head-scripts">
  {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
</Fragment>

<ServiceHero
  eyebrow="Light · Halogen · LED Retrofit · Switch · LA Same-Day"
  title="Range Hood Light Not Working Repair Los Angeles"
  subtitle={`Bulb burnout, socket corrosion, switch failure, capacitive touch unresponsive. Same-day across LA, Orange, Ventura, San Bernardino, Riverside. $89 residential, waived with repair. ${phone}`}
  heroImageTitle="Range Hood Light Repair"
/>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Light service</p>
    <h2>Halogen burnout is a $5 to $80 bulb. We tell you that on the phone.</h2>

    <p>The single most common range hood light call is bulb burnout, year 1 to 3 typical on halogen bulbs. Most customers can replace the bulb in 5 minutes if they have the right replacement and access to the lens cover. We tell every caller this on the phone before scheduling, especially for mid-tier hoods (Broan, KitchenAid, GE) where the bulbs are standard hardware-store parts $5 to $20. For pro-style hoods (Wolf, Viking, Thermador, Vent-A-Hood) the bulbs are specialty parts, $30 to $80 with 2 to 3 week lead time from authorized distributors; those calls we schedule.</p>

    <p>Beyond bulb burnout: bulb socket corrosion (LA marine layer humidity at year 5+ in coastal homes), switch failure (rocker mechanical or capacitive touch electronic), wiring junction box corrosion at year 8+, capacitive-touch glass damage from aggressive grease scrubbing. The LED retrofit conversation comes up on every halogen replacement visit because LEDs last 8 to 12 years instead of 1 to 3, run cooler, and don't shatter from grease droplet exposure.</p>

    <p>Our techs service the full residential range hood lineup across LA County, Orange, Ventura, San Bernardino, Riverside. <strong>BHGS #A49573</strong>, <strong>EPA 608 Universal certified #1346255700410</strong>. $89 residential diagnostic waived with repair. BBB Accredited. Phones answered 24/7. Parent: <a href="/services/range-hood-repair/">range hood repair</a>.</p>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">Field observations</p>
    <h2 class="section-title">Top causes by frequency.</h2>
    <ol class="num-list">
      <li><strong>Halogen bulb burnout (#1, year 1 to 3, customer-DIY-able).</strong> Standard halogen run $5 to $20. Pro-style specialty halogen $30 to $80 with 2 to 3 week lead time.</li>
      <li><strong>Bulb socket corrosion (year 5+, coastal LA homes).</strong> Brass or chrome contacts oxidize from kitchen humidity plus marine layer exposure. $80 to $180 socket replacement.</li>
      <li><strong>Rocker switch mechanical failure.</strong> Older hoods (pre-2015 typical). $120 to $240 switch plus install.</li>
      <li><strong>Capacitive touch panel failure.</strong> Newer pro-style hoods. Glass damage from grease scrubbing or sensor board failure. $260 to $440 panel, $440 to $680 with main board integration.</li>
      <li><strong>Wiring junction box corrosion.</strong> Year 8+, especially coastal LA. $180 to $300 service.</li>
      <li><strong>LED retrofit conversion (proactive, not failure).</strong> $89 + $30 to $80 LED bulbs for hoods made pre-2018; saves bulb-replacement frequency.</li>
    </ol>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">LED retrofit conversation</p>
    <h2 class="section-title">Why we recommend LED on most halogen replacement visits.</h2>

    <p>On a typical mid-tier hood with two halogen bulbs, the bulb-replacement frequency is once every 18 months to 3 years. Over a 10-year hood lifespan that's 4 to 6 bulb replacement events: each event involves climbing a ladder, removing the lens cover, replacing two bulbs, reinstalling the cover. Or one $89 service call if the customer doesn't want to do it themselves. Total bulb cost over 10 years: $40 to $240 plus 6 service calls at $89 if applicable.</p>

    <p>LED retrofit at first replacement: $30 to $80 in LED bulbs (G4, G9, or GU10 base types depending on hood model), one-time install during the visit. LED bulbs last 8 to 12 years; one set typically lasts the rest of the hood's useful life. They run 80% cooler than halogen, which means grease droplet impact doesn't shatter the glass, and they use 80% less energy.</p>

    <p>Hoods made 2018 or later usually came LED from factory; no retrofit conversation needed. Hoods made pre-2018 are candidates. We do the retrofit on the same visit if the customer agrees; we don't push it but we explain the math. Most customers who hear the math choose LED.</p>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">Pro-style halogen sourcing</p>
    <h2 class="section-title">Wolf, Thermador, Vent-A-Hood specialty bulbs are real lead-time items.</h2>

    <p>Pro-style hoods use specialty halogen bulbs that aren't stocked at hardware stores. Wolf uses 12V xenon-halogen capsule bulbs (often 35W or 50W) on its 600 to 1,200 CFM models. Thermador uses GY6.35 base 12V halogen on Masterpiece and Professional series. Vent-A-Hood typically uses bi-pin G4 halogen specific to their fixture mounting. Sourcing requires authorized distributor channels and 2 to 3 week lead time is normal.</p>

    <p>We carry common bulb types on the truck for the brands we service most often. For less common models or premium pro-style we order during the diagnostic visit and return for install on the lead-time window. The customer can also order direct from authorized distributors and have us install on a follow-up call if preferred. We don't substitute generic equivalents for pro-style fixtures because the heat tolerance and beam angle specs matter for proper hood-light function.</p>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Brand notes</p>
    <h2 class="section-title">Common brands and their light architecture.</h2>
    <ul class="bullet-list">
      <li><strong>Wolf:</strong> 12V xenon-halogen capsule bulbs (35W or 50W), specialty sourcing. <a href="/brands/wolf-range-hood-repair/">Wolf range hood repair</a>.</li>
      <li><strong>Thermador:</strong> GY6.35 base 12V halogen on Masterpiece and Professional. <a href="/brands/thermador-range-hood-repair/">Thermador range hood repair</a>.</li>
      <li><strong>Vent-A-Hood:</strong> bi-pin G4 halogen, fixture-specific. Premium tier; $89 diagnostic plus parts.</li>
      <li><strong>Viking, Best, Zephyr Pro:</strong> typically GU10 or G4 halogen on older models, LED on 2018+ models. <a href="/brands/viking-range-hood-repair/">Viking</a> · <a href="/brands/zephyr-range-hood-repair/">Zephyr</a>.</li>
      <li><strong>Broan, KitchenAid, GE Profile/Café, Samsung, LG:</strong> standard hardware-store halogen bulbs ($5 to $20) on older models, LED on 2018+. <a href="/brands/broan-range-hood-repair/">Broan</a> · <a href="/brands/kitchenaid-range-hood-repair/">KitchenAid</a>.</li>
      <li><strong>Bosch, Miele, Gaggenau:</strong> capacitive-touch switches common; glass damage from grease scrubbing more frequent than mid-tier rocker switches. <a href="/brands/bosch-range-hood-repair/">Bosch</a> · <a href="/brands/miele-range-hood-repair/">Miele</a>.</li>
    </ul>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">Diagnostic walkthrough</p>
    <h2 class="section-title">Practitioner sequence on every light call.</h2>
    <ol class="num-list">
      <li><strong>Pull lens cover, inspect bulb visually.</strong> Darkening or filament break is obvious; replace and retest.</li>
      <li><strong>If bulb is fine, check socket contacts.</strong> Visual corrosion or oxidation; clean or replace socket.</li>
      <li><strong>Test switch with multimeter.</strong> Rocker switch continuity; capacitive touch sensor board response.</li>
      <li><strong>Inspect wiring junction box at hood top.</strong> Loose connection or corrosion at year 8+.</li>
      <li><strong>Discuss LED retrofit if hood is pre-2018.</strong> Math-based recommendation, no pressure.</li>
      <li><strong>Pro-style bulb sourcing.</strong> Order during visit, schedule return for install on lead-time window.</li>
    </ol>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Honest opinion</p>
    <h2 class="section-title">If the bulb is the only issue and you can climb a ladder, you should DIY.</h2>
    <p>Range hood bulb replacement on a mid-tier hood (Broan, KitchenAid, GE, Samsung, LG) is a 5-minute DIY task with a $5 to $20 hardware-store bulb. We don't profit from telling customers this on the phone, but we'd rather be the company you trust to call when something more involved breaks than the company that overcharges for a 5-minute bulb swap. For pro-style hoods with specialty bulbs and 2 to 3 week sourcing, the calculus is different: schedule us, we'll handle it. For LED retrofits and switch failures, schedule us, that's real labor.</p>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">Pricing</p>
    <h2 class="section-title">Light repair costs.</h2>
    <p class="lead">$89 residential diagnostic, waived with repair. No emergency surcharge: same $89 anytime.</p>
    <table class="price-table">
      <thead><tr><th>Repair</th><th>Typical Cost</th></tr></thead>
      <tbody>
        <tr><td>Diagnostic</td><td>$89, waived with repair</td></tr>
        <tr><td>Halogen bulb (mid-tier, parts only)</td><td>$5 to $20 (DIY-able)</td></tr>
        <tr><td>Pro-style specialty halogen (parts only)</td><td>$30 to $80 (2 to 3 week lead time)</td></tr>
        <tr><td>LED retrofit (2 bulbs plus install)</td><td>$30 to $80 parts plus $89 diagnostic</td></tr>
        <tr><td>Bulb socket replacement</td><td>$80 to $180</td></tr>
        <tr><td>Rocker switch replacement</td><td>$120 to $240</td></tr>
        <tr><td>Capacitive touch panel replacement</td><td>$260 to $440</td></tr>
        <tr><td>Capacitive touch with main board integration (pro-style)</td><td>$440 to $680</td></tr>
        <tr><td>Wiring junction box service</td><td>$180 to $300</td></tr>
        <tr><td>Insurance assessment for kitchen fire damage</td><td>$89 plus written report (no extra charge)</td></tr>
        <tr><td>Warranty</td><td>90 days parts and labor</td></tr>
      </tbody>
    </table>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">FAQ</p>
    <h2 class="section-title">Light repair questions.</h2>
    <div class="faq-list">
      {faqs.map(f => (<details class="faq-item"><summary>{f.q}</summary><p>{f.a}</p></details>))}
    </div>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">Sister sub-services</p>
    <h2 class="section-title">Other range hood issues we service.</h2>
    <ul class="bullet-list">
      <li><a href="/services/range-hood-repair/">Range hood repair (parent pillar)</a></li>
      <li><a href="/services/range-hood-repair/not-venting/">Not venting (ducted, ductless, CFM)</a></li>
      <li><a href="/services/range-hood-repair/fan-noise/">Fan noise (loud, rattling, vibration)</a></li>
      <li><a href="/services/range-hood-repair/filter-issues/">Filter issues (grease, baffle, charcoal)</a></li>
      <li><a href="/credentials/licensed/">License credentials</a></li>
    </ul>
  </div>
</section>

<section class="bottom-cta">
  <div class="container">
    <h2>Range Hood Light Out? Call Today.</h2>
    <p>Same-day across LA, OC, Ventura. $89 diagnostic waived with repair. BHGS #A49573, EPA 608 Universal #1346255700410. Phones answered 24/7.</p>
    <div class="cta-row">
      <a href={phoneHref} class="btn-primary">☎ Call {phone}</a>
      <a href="/contact/" class="btn-secondary">Book Online</a>
    </div>
  </div>
</section>

</Layout>

