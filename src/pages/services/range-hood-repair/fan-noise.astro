<ServiceHero
  eyebrow="Loud · Rattling · Grinding · Vibration · LA Same-Day"
  title="Range Hood Fan Noise Repair Los Angeles"
  subtitle={`Loud humming, grinding bearings, rattling damper, vibration through the cabinet. Same-day across LA, Orange, Ventura, San Bernardino, Riverside. $89 residential, waived with repair. ${phone}`}
  heroImageTitle="Range Hood Fan Noise Repair"
