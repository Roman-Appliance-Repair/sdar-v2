// Pro-style acoustic dampening (Wolf, Vent-A-Hood) — deviation more dramatic when quiet hood gets loud.
// $89 residential, BHGS #A49573, EPA 608 #1346255700410. 4 schema entities.
import Layout from '../../../layouts/Layout.astro';
import ServiceHero from '../../../components/ServiceHero.astro';
import { MAIN_PHONE } from '../../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
