// module + electrode + cap alignment.
// $89 residential. BHGS #A49573 + EPA 608 Universal #1346255700410.
// SSOT: NO aggregateRating, NO streetAddress.
import Layout from '../../../layouts/Layout.astro';
import ServiceHero from '../../../components/ServiceHero.astro';
import { MAIN_PHONE } from '../../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/services/cooktop-repair/burner-not-igniting/";

const title = "Gas Cooktop Burner Not Igniting, Won't Light, Clicks No Flame, $89 Diagnostic";
const description = "Gas cooktop burner won't light across LA, OC, Ventura. Wolf, Viking, Thermador, BlueStar. ~30% resolved at $89 dx.";

const faqs = [
  {
    q: "My gas burner clicks but won't light. Why?",
    a: "Click means the spark electrode is firing. If you see the click but no flame, three causes in order of likelihood: (1) burner cap misaligned, the cap and head must seat exactly, even a small offset disrupts gas flow; re-seat and try again. (2) Spark electrode fouled or wet, common after cleaning or dishwasher splash, dry it 30 minutes. (3) Spark module has weakened, sparking but not at the energy needed to ignite gas. We test module output at the diagnostic.",
  },
  {
    q: "All four burners click at once when I turn one knob. Module or wiring?",
    a: "Spark module. Modules drive multiple burners simultaneously when one knob is turned, then individual burner switches isolate which one actually fires the gas valve. When all click together but the activated burner won't light, the module is firing but losing energy to the dead burner's electrode. Module replacement $260 to $420. Diagnostic confirms by isolating each electrode.",
  },
  {
    q: "Do you service Wolf SRT, Viking VGSU, Thermador Masterpiece, BlueStar RBCT, Capital cooktops?",
    a: "Yes. These pro-style sealed-burner cooktops use premium spark modules and ceramic electrodes. Module replacement runs higher than mid-tier ($380 to $580 versus $260 to $420), but the diagnostic logic is identical: test module output, test electrode resistance, check cap alignment, verify gas valve function. We carry common Wolf and Viking ignition components on the van.",
  },
  {
    q: "Burner ignites but flame is yellow or weak. Why?",
    a: "Yellow flame means incomplete combustion, almost always a clogged burner port (food spills baked into the brass). Cleaning resolves most cases at the diagnostic. If burner ports are damaged from corrosion (year 10+ unit, especially if hood ventilation was undersized), burner head replacement is needed, $200 to $440 depending on brand.",
  },
  {
    q: "How much does this typically cost?",
    a: "$89 diagnostic, applied toward repair. About 30% of 'won't light' calls resolve at the diagnostic with cap re-seat plus port cleaning, no parts billed. The other 70% are spark module ($260 to $420), electrode ($200 to $340 per zone), or rare gas valve ($440 to $680). We quote on-site after diagnosis.",
  },
  {
    q: "What's your warranty?",
    a: "90 days parts and labor on every repair. BHGS #A49573, EPA 608 Universal certified (#1346255700410), BBB A+ accredited.",
  },
];

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": canonical + "#business",
    "name": "Same Day Appliance Repair",
    "url": canonical,
    "telephone": phone,
    "priceRange": "$$",
    "description": "Gas cooktop burner not igniting diagnostic and repair across all five SoCal counties. Spark module, ceramic electrode, burner cap alignment, gas valve safety. Pro-style (Wolf, Viking, Thermador, BlueStar, Capital) and mid-tier brands. BHGS #A49573. EPA 608 Universal certified #1346255700410.",
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" },
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": canonical + "#service",
    "serviceType": "Gas Cooktop Burner Ignition Repair",
    "name": "Gas Cooktop Burner Not Igniting Diagnostic and Repair",
    "url": canonical,
    "description": "Residential gas cooktop burner ignition diagnostic across all five SoCal counties. Spark module failure (single-burner vs all-burners-clicking), ceramic spark electrode (cracked, fouled, wet), burner cap misalignment (often resolved at diagnostic), gas valve safety, port cleaning. Pro-style (Wolf SRT, Viking VGSU, Thermador Masterpiece, BlueStar RBCT, Capital) and mid-tier (GE, Whirlpool, Samsung, JennAir, KitchenAid, Bosch). $89 residential diagnostic, applied toward repair.",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" },
    ],
    "offers": {
      "@type": "Offer",
      "priceRange": "$89-$900",
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "89.00",
        "priceCurrency": "USD",
        "description": "Residential diagnostic fee, applied toward repair. No emergency surcharge.",
      },
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map((f) => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://samedayappliance.repair/services/" },
      { "@type": "ListItem", "position": 3, "name": "Cooktop Repair", "item": "https://samedayappliance.repair/services/cooktop-repair/" },
      { "@type": "ListItem", "position": 4, "name": "Burner Not Igniting", "item": canonical },
    ],
  },
];
---

<Layout title={title} description={description} canonical={canonical}>

<Fragment slot="head-scripts">
  {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
</Fragment>

<ServiceHero
  eyebrow="Failure mode · Spark Module · Electrode · Cap Alignment · Gas Valve"
  title="Gas Cooktop Burner Not Igniting, Won't Light"
  subtitle="Residential gas cooktops across LA, OC, Ventura, Riverside. About 30% of these calls resolve at the diagnostic with cap re-seat plus cleaning, no parts. $89 diagnostic, waived with repair. (424) 325-0520"
