    "serviceType": "Wine Cooler Temperature Fluctuating Repair",
    "name": "Wine Cooler Temperature Stability Diagnostic",
    "url": canonical,
    "description": "Residential wine cooler temperature-fluctuating diagnostic across all five SoCal counties. Thermostat hysteresis miscalibration (year 5-8), temperature sensor drift, dual-zone damper or zone-control fan cross-contamination (year 7-12 on Sub-Zero, U-Line, Marvel), door seal warm-air infiltration, ambient temperature outside design range (LA garage installations), evaporator fan cycling. Sub-Zero, U-Line, Marvel, Perlick, Liebherr, EuroCave premium plus Frigidaire, Whirlpool, GE mid-tier. $89 residential diagnostic, applied toward repair. BHGS #A49573, EPA 608 Universal #1346255700410.",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, applied toward repair" } }
