import Layout from '../../../layouts/Layout.astro';
import ServiceHero from '../../../components/ServiceHero.astro';
import { MAIN_PHONE } from '../../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/services/wine-cooler-repair/door-seal-issues/";

const title = "Wine Cooler Door Seal Issues Repair LA | Gasket, Hinge Sag, Condensation, $89 Diagnostic";
const description = "Wine cooler door seal failing? LA same-day. Gasket compression, hinge sag, glass condensation, UV-tinted glass. Sub-Zero, U-Line, Marvel. BHGS #A49573, $89.";

const faqs = [
  {
    q: "How do I tell if my door seal is failing?",
    a: "Three tests, simplest first. (1) Visual inspection of the gasket, look for cracks, hard spots, or sections where the rubber has lost compression and doesn't spring back when pressed. (2) Dollar-bill test, close the door on a dollar bill at multiple points around the perimeter. If the bill slides out easily, the seal at that point has failed. (3) Hand-feel test, close the door, run your hand around the outside of the door perimeter. If you feel cold air escaping at any point, the seal has gapped there.",
  },
  {
    q: "Why does my wine cooler glass door fog up?",
    a: "Condensation on the glass means warm room air is meeting the cold cabinet surface and condensing, same physics as a cold glass on a humid day. Three causes ranked by frequency. (1) Door seal failure letting warm air infiltrate the cabinet, raising humidity inside. (2) Wine cooler operating in a high-humidity environment (LA coastal homes during summer marine layer or after hot showers in nearby bathrooms). (3) Failed double-pane glass insulation, the inert gas between the panes has leaked out and the inside pane runs colder than designed. Glass replacement on premium units (Sub-Zero 424FS, EuroCave Premiere) is OEM-only and runs $785 to $1,485.",
  },
  {
    q: "My door doesn't close all the way. What's that?",
    a: "Hinge sag, almost always. Wine cooler doors carry significant weight, glass front plus interior shelving plus bottle weight when stocked. Years of opening and closing fatigues the hinges. Symptoms: door doesn't close to flush, you have to push it firmly to engage the latch, or the door tilts visibly when fully open. Repair: hinge realignment if pins and bushings are still good ($185 to $285), full hinge replacement if components are worn ($385 to $585). Premium-tier units have heavier hinges that last longer; mid-tier units more often need replacement at year 8 to 10.",
  },
  {
    q: "What about UV-tinted glass, does that fail?",
    a: "Not the tint itself, but premium wine cooler glass is laminated for UV protection of bottles, and the lamination layer can fail (delamination) at year 10+ on high-UV-exposure installations. Symptom: visible cloudiness or rainbow-pattern haze in the glass that wasn't there originally. Replacement is OEM-only and expensive, same range as fogged double-pane glass ($785 to $1,485). On freestanding units in direct sunlight (kitchen islands with skylights, sunrooms), we sometimes recommend repositioning rather than replacement because the UV exposure will fail the new glass on the same timeline.",
  },
  {
    q: "Can I replace the gasket myself?",
    a: "Mechanically possible on most freestanding units, the gasket is held in a press-fit channel around the door perimeter. The challenge is sourcing the correct OEM part. Premium tier (Sub-Zero, U-Line, Marvel, Perlick) gaskets are model-specific and only available through authorized parts channels. Mid-tier brands often have generic-fit gaskets that are close-but-not-exact and either don't seal correctly or don't fit flush. We confirm part numbers from the model tag and order through OEM channels.",
  },
  {
    q: "What's the typical cost?",
    a: "Door gasket replacement: $245 to $385 mid-tier, $385 to $585 premium. Hinge realignment: $185 to $285. Hinge replacement: $385 to $585. Glass replacement (fogged double-pane or delaminated UV-laminate): $785 to $1,485 OEM. Combined gasket + hinge on a year 10+ unit: $385 to $585. The $89 diagnostic is waived with repair.",
  },
  {
    q: "What's your warranty?",
    a: "90 days SDAR labor and parts on every repair. New OEM gaskets carry the manufacturer warranty plus our 90-day labor. BHGS #A49573, EPA 608 Universal #1346255700410.",
  },
];

const schemaJsons = [
  {
    "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair", "url": canonical, "telephone": phone, "priceRange": "$$",
    "openingHoursSpecification": [{ "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "08:00", "closes": "20:00" }],
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" },
    ],
  },
  {
    "@context": "https://schema.org", "@type": "Service", "@id": canonical + "#service",
    "serviceType": "Wine Cooler Door Seal Repair",
    "name": "Wine Cooler Gasket, Hinge, and Glass Repair",
    "url": canonical,
    "description": "Residential wine cooler door diagnostic across all five SoCal counties. Door gasket compression and hardening (year 7-10), hinge sag and replacement, glass-door condensation diagnostic (gasket failure vs ambient humidity vs failed double-pane insulation), UV-tinted laminated glass delamination on freestanding sun-exposure installations. Sub-Zero, U-Line, Marvel, Perlick, Liebherr, EuroCave premium plus mid-tier. $89 residential diagnostic, applied toward repair. BHGS #A49573, EPA 608 Universal #1346255700410.",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" },
    ],
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, applied toward repair" } },
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  {
    "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://samedayappliance.repair/services/" },
      { "@type": "ListItem", "position": 3, "name": "Wine Cooler Repair", "item": "https://samedayappliance.repair/services/wine-cooler-repair/" },
      { "@type": "ListItem", "position": 4, "name": "Door Seal Issues", "item": canonical },
    ],
  },
];
---

<Layout title={title} description={description} canonical={canonical}>

<Fragment slot="head-scripts">
  {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
</Fragment>

<ServiceHero
  eyebrow="Door Seal · Gasket · Hinge · Glass · LA · OC · Ventura · IE"
  title="Wine Cooler Door Seal Issues Repair Los Angeles"
  subtitle={`Gasket compression, hinge sag, glass condensation? Door seal directly affects temperature stability and bottle aging. Sub-Zero, U-Line, Marvel, Liebherr, EuroCave. ${phone}`}
  heroImageTitle="Wine Cooler Door Seal Repair"
  showBranches={true}
/>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Door diagnostic</p>
    <h2>Door seal failure is the second-leading cause of temperature fluctuation we see.</h2>

    <p>A failed door seal lets warm room air infiltrate the cabinet, which forces the compressor to run longer cycles, raises cabinet humidity, and ultimately destabilizes the bottle storage environment. After thermostat issues, gasket failure is the most common reason wine coolers can't hold setpoint within design tolerance. Year 7 to 10 typical for first gasket replacement on premium tier (Sub-Zero, U-Line, Marvel, Perlick, Liebherr, EuroCave). Year 5 to 8 on mid-tier (Frigidaire, Whirlpool, GE, NewAir, Edgestar).</p>

    <p>Three components share door responsibility: the gasket (rubber seal around the door perimeter), the hinges (load-bearing pivots that hold door alignment), and the glass itself on glass-door units (single-pane, double-pane insulated, UV-laminated). Each fails on its own timeline and produces distinct symptoms. We diagnose at the visit and quote the specific repair.</p>

    <p>$89 residential diagnostic, waived with repair. BHGS #A49573 + EPA 608 Universal #1346255700410. We service residential wine coolers across LA, Orange, Ventura, San Bernardino, and Riverside.</p>
  </div>
</section>

<section class="section section-gray">
  <div class="container">
    <p class="section-number">Three failure modes</p>
    <h2>Gasket, hinge, glass, separate repair tiers.</h2>

    <h3 class="series-h3">Gasket compression / hardening (year 7 to 10)</h3>
    <p>The rubber gasket around the door perimeter loses elasticity over years. Two failure modes: (1) Compression, gasket no longer springs back to design height after closing, leaves gaps. (2) Hardening, rubber stiffens and develops cracks, creating direct air paths into the cabinet. The gasket failure produces gradual temperature drift, increased compressor runtime, and on glass-door units increasing interior fog or condensation. Replacement runs $245 to $385 mid-tier, $385 to $585 premium tier. OEM-only on premium because third-party gaskets don't fit the door profile correctly.</p>

    <h3 class="series-h3">Hinge sag / wear (year 8 to 12)</h3>
    <p>Wine cooler doors carry significant weight: glass front, interior shelving, bottle weight when stocked. Years of cycling fatigue the hinge pins and bushings. Symptom: door doesn't close flush, has to be pushed firmly to engage latch, tilts visibly when fully open. The sag also stresses the gasket unevenly, accelerating gasket failure. Repair: hinge realignment $185 to $285 if pins and bushings are still good; full hinge replacement $385 to $585 if components are worn.</p>

    <h3 class="series-h3">Glass condensation / fogging (humidity issue or insulation failure)</h3>
    <p>Glass-door wine coolers can develop visible condensation on the glass surface or fogging between panes (on double-pane insulated glass). Three causes:</p>
    <ul class="reasons-list">
      <li><strong>Gasket failure raising interior humidity.</strong> Repair the gasket; condensation resolves.</li>
      <li><strong>High-humidity room environment.</strong> Coastal LA homes during summer marine layer; bathrooms or kitchens with poor ventilation. Solution is improving room ventilation, not the cooler.</li>
      <li><strong>Double-pane insulation failure.</strong> The inert argon gas between the panes has leaked out, the inside pane runs colder than designed, and condensation forms between the panes. Glass replacement is OEM-only on premium units, $785 to $1,485 typical.</li>
    </ul>

    <h3 class="series-h3">UV-tinted glass delamination (year 10+, sun-exposure installations)</h3>
    <p>Premium wine coolers use laminated glass for UV protection of bottles. The lamination can delaminate at year 10+ on freestanding units in direct sun (kitchen islands with skylights, sunrooms, west-facing kitchens). Symptom: visible cloudiness or rainbow-pattern haze. Glass replacement is the only fix; we sometimes recommend repositioning the unit if UV exposure was the root cause, because new glass will fail on the same timeline.</p>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Pricing</p>
    <h2>Repair costs by failure mode.</h2>
    <table class="price-table">
