---
// src/pages/services/pizza-oven-repair.astro
const title = "Pizza Oven Repair Los Angeles — Wolf ICBOGP + Ooni + Gozney";
const description = "Pizza oven repair LA — Wolf ICBOGP built-in, Ooni, Gozney, Breville Pizzaiolo, Alfa, Fontana. Gas, wood, electric. $89 diagnostic. (424) 325-0520.";
const canonicalUrl = "https://samedayappliance.repair/services/pizza-oven-repair/";

const faqItems = [
  {
    question: "Do you repair Ooni pizza ovens?",
    answer: "Yes — we service the full Ooni lineup including Karu 12, Karu 16, Koda 12, Koda 16, Volt 12, and Pro 16. Common issues: igniter failure on Koda models, temperature sensor errors, and burner assembly clogs. We carry Ooni-compatible parts and can usually complete the repair same visit."
  },
  {
    question: "Can you fix a Gozney Dome or Roccbox?",
    answer: "Absolutely. Gozney ovens are well-built but not immune to problems. Roccbox burner issues, temperature regulator failures, and gas connection problems are the most common calls we get. Dome ovens occasionally need thermocouple replacement or door seal work. We handle both gas and wood-fired configurations."
  },
  {
    question: "What does pizza oven repair cost in Los Angeles?",
    answer: "Diagnostic fee is $89 — waived when you move forward with the repair. Most residential pizza oven repairs run $150–$350 depending on the brand and what's wrong. Igniter replacements tend to be on the lower end; burner assembly work or control board failures run higher. We give you a written estimate before any work starts."
  },
  {
    question: "Do you repair wood-fired pizza ovens?",
    answer: "Yes, including dome-style wood ovens from Alfa, Forno Bravo, Chicago Brick Oven, and custom-built units. Wood oven repairs often involve flue damper adjustment, floor tile replacement, insulation work, or door hinge repair. These are different from gas ovens and we approach them accordingly."
  },
  {
    question: "My pizza oven won't get hot enough. What's usually wrong?",
    answer: "On gas ovens the most common culprits are a partially clogged burner, a failing thermocouple, or a worn regulator that's not delivering full pressure. On pellet/wood ovens it's often a flue draft issue or thermal mass damage. We diagnose on-site and tell you exactly what's happening before we fix anything."
  },
  {
    question: "Do you repair Breville Pizzaiolo?",
    answer: "Yes. The Pizzaiolo is a countertop electric oven that hits 750°F — when it stops reaching temperature or starts throwing error codes, it usually needs heating element inspection, thermal fuse replacement, or control board diagnostics. We work on the full Breville Pizzaiolo lineup."
  },
  {
    question: "How fast can you get here?",
    answer: "Same-day appointments are available throughout Los Angeles County, Orange County, and Ventura County. Call us before noon and there's a strong chance we can make it out the same day. We serve Malibu, Beverly Hills, Pacific Palisades, Silver Lake, Los Feliz, and all surrounding areas."
  }
];

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Pizza Oven Repair Los Angeles",
  "serviceType": "Pizza Oven Repair",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Same Day Appliance Repair",
    "telephone": "(424) 325-0520",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "6230 Wilshire Blvd Ste A PMB 2267",
      "addressLocality": "Los Angeles",
      "addressRegion": "CA",
      "postalCode": "90048"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.6",
      "reviewCount": "37"
    }
  },
  "areaServed": {
    "@type": "City",
    "name": "Los Angeles"
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};

const brands = [
  { name: "Wolf ICBOGP (luxury built-in)", models: "ICBOGP 24\" · ICBOGP 30\" · older Outdoor Living", issues: "Dual-flame burner, infrared ceramic, gas valve, rotisserie" },
  { name: "Ooni", models: "Karu 12/16 · Koda 12/16 · Volt 12 · Pro 16", issues: "Igniter failure, burner clog, temp sensor" },
  { name: "Gozney", models: "Dome · Dome S1 · Roccbox", issues: "Thermocouple, regulator, gas connection" },
  { name: "Breville Pizzaiolo", models: "BOV900BSS · BOV900SST", issues: "Heating element, thermal fuse, error codes" },
  { name: "Bertello", models: "Grande · Bertello 12.5", issues: "Gas valve, stone cracking, door seal" },
  { name: "Alfa", models: "Forni 4 Pizze · Moderno 5 · Nano", issues: "Flue damper, insulation, floor tile" },
  { name: "Fontana", models: "Mangiafuoco · Marinara · Riviera", issues: "Wood-fired hearth, flue, door seal, insulation" },
  { name: "Forno Bravo (residential)", models: "Primavera · Casa · Artigiano", issues: "Dome cracks, door hinges, arch repair" },
  { name: "Chicago Brick Oven", models: "CBO-500 · CBO-750 · CBO-1000", issues: "Burner, dome, flue assembly" },
  { name: "Kalamazoo", models: "K750FS · Hybrid Fire", issues: "Ignition, gas manifold, pizza stone" },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <style>
    :root {
      --red: #C8102E;
      --black: #0a0a0a;
      --gray: #f5f5f5;
      --border: #e2e2e2;
      --text: #1a1a1a;
      --muted: #6b6b6b;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', system-ui, sans-serif; color: var(--text); line-height: 1.65; }
    a { color: var(--red); text-decoration: none; }
    a:hover { text-decoration: underline; }

    /* HERO */
    .hero {
      background: var(--black);
      color: #fff;
      padding: 80px 24px 72px;
    }
    .hero-inner { max-width: 1080px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: center; }
    .hero-eyebrow { font-size: 13px; letter-spacing: .1em; text-transform: uppercase; color: var(--red); margin-bottom: 16px; }
    .hero h1 { font-size: clamp(32px, 5vw, 52px); font-weight: 700; line-height: 1.15; margin-bottom: 20px; }
    .hero h1 span { color: var(--red); }
    .hero-sub { font-size: 17px; color: #ccc; margin-bottom: 32px; line-height: 1.6; }
    .hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; }
    .btn-primary { background: var(--red); color: #fff; padding: 14px 28px; font-size: 16px; font-weight: 600; border-radius: 4px; }
    .btn-ghost { border: 1.5px solid #555; color: #fff; padding: 14px 28px; font-size: 16px; border-radius: 4px; }
    .hero-image-placeholder { background: #1a1a1a; border: 1px solid #333; border-radius: 8px; aspect-ratio: 4/3; display: flex; align-items: center; justify-content: center; color: #555; font-size: 14px; }
    @media (max-width: 768px) { .hero-inner { grid-template-columns: 1fr; } .hero-image-placeholder { display: none; } }

    /* TRUST BAR */
    .trust-bar { background: var(--red); color: #fff; padding: 16px 24px; }
    .trust-bar-inner { max-width: 1080px; margin: 0 auto; display: flex; gap: 32px; flex-wrap: wrap; justify-content: center; }
    .trust-item { font-size: 14px; font-weight: 500; display: flex; align-items: center; gap: 8px; }

    /* SECTIONS */
    .section { padding: 72px 24px; }
    .section-inner { max-width: 1080px; margin: 0 auto; }
    .section-gray { background: var(--gray); }
    .section-black { background: var(--black); color: #fff; }
    .section-label { font-size: 12px; letter-spacing: .1em; text-transform: uppercase; color: var(--red); margin-bottom: 12px; font-weight: 600; }
    .section-black .section-label { color: #ff6b6b; }
    h2 { font-size: clamp(24px, 4vw, 38px); font-weight: 700; line-height: 1.2; margin-bottom: 20px; }
    h3 { font-size: 20px; font-weight: 600; margin-bottom: 10px; }
    p { margin-bottom: 16px; font-size: 16px; line-height: 1.7; }
    p:last-child { margin-bottom: 0; }

    /* BRANDS GRID */
    .brands-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 20px; margin-top: 40px; }
    .brand-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 22px; }
    .brand-card h3 { font-size: 17px; color: var(--text); margin-bottom: 6px; }
    .brand-card .models { font-size: 13px; color: var(--muted); margin-bottom: 10px; }
    .brand-card .issues { font-size: 13px; background: #fff8f8; border-left: 3px solid var(--red); padding: 8px 10px; border-radius: 0 4px 4px 0; color: var(--text); }

    /* PROBLEMS GRID */
    .problems-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 16px; margin-top: 32px; }
    .problem-card { background: #fff; border: 1px solid var(--border); border-radius: 6px; padding: 18px; }
    .problem-card .icon { font-size: 24px; margin-bottom: 10px; }
    .problem-card h4 { font-size: 14px; font-weight: 600; margin-bottom: 6px; }
    .problem-card p { font-size: 13px; color: var(--muted); margin: 0; }

    /* REPAIR TYPES */
    .types-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 24px; margin-top: 36px; }
    @media (max-width: 768px) { .types-grid { grid-template-columns: 1fr; } }
    .type-card { border-top: 3px solid var(--red); padding-top: 20px; }
    .type-card h3 { font-size: 18px; margin-bottom: 10px; }
    .type-card p { font-size: 15px; color: var(--muted); }

    /* CASES */
    .cases-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-top: 32px; }
    @media (max-width: 768px) { .cases-grid { grid-template-columns: 1fr; } }
    .case-card { background: #111; border: 1px solid #2a2a2a; border-radius: 8px; padding: 24px; }
    .case-card .case-quote { font-size: 14px; font-style: italic; color: #aaa; margin-bottom: 16px; border-left: 3px solid var(--red); padding-left: 14px; }
    .case-card .case-brand { font-size: 12px; text-transform: uppercase; letter-spacing: .08em; color: var(--red); margin-bottom: 8px; }
    .case-card h4 { font-size: 16px; color: #fff; font-weight: 600; margin-bottom: 10px; }
    .case-card .case-body { font-size: 14px; color: #bbb; line-height: 1.6; }

    /* PRICING */
    .pricing-table { width: 100%; border-collapse: collapse; margin-top: 28px; }
    .pricing-table th { text-align: left; padding: 12px 16px; background: var(--black); color: #fff; font-size: 13px; font-weight: 600; }
    .pricing-table td { padding: 14px 16px; border-bottom: 1px solid var(--border); font-size: 15px; }
    .pricing-table tr:last-child td { border-bottom: none; }
    .pricing-table .price { font-weight: 700; color: var(--red); }

    /* WHY US */
    .why-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 32px; }
    @media (max-width: 768px) { .why-grid { grid-template-columns: 1fr; } }
    .why-item { display: flex; gap: 16px; align-items: flex-start; }
    .why-icon { width: 40px; height: 40px; background: var(--red); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #fff; font-size: 18px; flex-shrink: 0; }
    .why-text h4 { font-size: 15px; font-weight: 600; margin-bottom: 6px; }
    .why-text p { font-size: 14px; color: var(--muted); margin: 0; }

    /* REVIEWS */
    .reviews-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-top: 32px; }
    @media (max-width: 768px) { .reviews-grid { grid-template-columns: 1fr; } }
    .review-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 20px; }
    .review-stars { color: #f5a623; font-size: 14px; margin-bottom: 10px; }
    .review-text { font-size: 14px; color: var(--text); line-height: 1.6; margin-bottom: 12px; }
    .review-author { font-size: 13px; color: var(--muted); font-weight: 600; }

    /* FAQ */
    .faq-list { margin-top: 32px; display: flex; flex-direction: column; gap: 2px; }
    .faq-item { border: 1px solid var(--border); border-radius: 6px; overflow: hidden; }
    .faq-question { padding: 18px 20px; font-size: 15px; font-weight: 600; cursor: pointer; background: #fff; display: flex; justify-content: space-between; align-items: center; }
    .faq-question:hover { background: var(--gray); }
    .faq-answer { padding: 0 20px 18px; font-size: 15px; color: var(--muted); line-height: 1.7; background: #fff; }

    /* NEARBY */
    .nearby-grid { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 24px; }
    .nearby-link { font-size: 14px; padding: 8px 14px; border: 1px solid var(--border); border-radius: 20px; color: var(--text); }
    .nearby-link:hover { background: var(--gray); }

    /* BOTTOM CTA */
    .bottom-cta { background: var(--black); color: #fff; padding: 80px 24px; text-align: center; }
    .bottom-cta h2 { color: #fff; margin-bottom: 16px; }
    .bottom-cta p { color: #aaa; font-size: 17px; margin-bottom: 32px; max-width: 580px; margin-left: auto; margin-right: auto; }
    .phone-big { font-size: clamp(28px, 5vw, 46px); font-weight: 800; color: var(--red); display: block; margin-bottom: 20px; letter-spacing: -.01em; }
  </style>
</head>
<body>

<!-- HERO -->
<section class="hero">
  <div class="hero-inner">
    <div>
      <p class="hero-eyebrow">Same Day · Los Angeles</p>
      <h1>Pizza Oven Repair<br /><span>Los Angeles</span></h1>
      <p class="hero-sub">
        Ooni, Gozney, Breville Pizzaiolo, Bertello, Alfa, and wood-fired custom builds.
        Gas, pellet, and electric. Most repairs completed same day.
      </p>
      <div class="hero-ctas">
        <a href="tel:4243250520" class="btn-primary">Call (424) 325-0520</a>
        <a href="#contact" class="btn-ghost">Book Online</a>
      </div>
    </div>
    <div class="hero-image-placeholder">[Pizza oven repair photo]</div>
  </div>
</section>

<!-- TRUST BAR -->
<div class="trust-bar">
  <div class="trust-bar-inner">
    <div class="trust-item">⚡ Same-Day Appointments</div>
    <div class="trust-item">🔧 All Brands Serviced</div>
    <div class="trust-item">💰 $89 Diagnostic — Waived With Repair</div>
    <div class="trust-item">📍 All of LA County</div>
    <div class="trust-item">⭐ 4.6 Rating · 37 Reviews</div>
  </div>
</div>

<!-- INTRO -->
<section class="section">
  <div class="section-inner">
    <div style="max-width: 720px;">
      <p class="section-label">About This Service</p>
      <h2>Pizza ovens are their own animal. We treat them that way.</h2>
      <p>
        Outdoor pizza ovens have taken over LA backyards — and they break in ways that most appliance
        companies aren't set up for. A Gozney Dome runs at 950°F. A Breville Pizzaiolo tops out at 750°F
        and talks in error codes. An Ooni Koda 16 has a gas burner system that's nothing like a kitchen range.
        Wood-fired dome ovens are a discipline entirely unto themselves.
      </p>
      <p>
        We've built out the knowledge and parts inventory to work on all of it. Our techs know the difference
        between a thermocouple failure and a regulator pressure problem on a Roccbox. They know which
        Ooni models have igniter issues from the factory. They know how to approach a custom wood-fired
        dome without breaking the insulation dome shell.
      </p>
      <p>
        The diagnostic is $89 and it gets waived the moment you say yes to the repair. Most pizza oven jobs
        are done same visit — we carry the common parts.
      </p>
    </div>
  </div>
</section>

<!-- BRANDS WE REPAIR -->
<section class="section section-gray">
  <div class="section-inner">
    <p class="section-label">Brands</p>
    <h2>Pizza oven brands we repair</h2>
    <p style="max-width: 640px; color: var(--muted);">
      From the Ooni Karu you grabbed at Costco to the custom brick dome in Malibu —
      we service residential and outdoor pizza ovens across the full spectrum.
    </p>
    <div class="brands-grid">
      {brands.map(brand => (
        <div class="brand-card">
          <h3>{brand.name}</h3>
          <p class="models">{brand.models}</p>
          <div class="issues">Common: {brand.issues}</div>
        </div>
      ))}
    </div>
    <p style="margin-top: 24px; font-size: 14px; color: var(--muted);">
      Don't see your brand? Call us — if it heats up and cooks pizza, we've likely worked on it.
    </p>
    <p style="margin-top: 16px; font-size: 14px; color: var(--muted);">
      <strong>Luxury outdoor built-in:</strong> see our dedicated <a href="/brands/wolf-pizza-oven-repair/" style="color: var(--red); font-weight: 600;">Wolf ICBOGP pizza oven repair</a> page — Sub-Zero Group matched-suite integration with Wolf BBQ grills + Sub-Zero outdoor refrigerators + Cove outdoor dishwashers.
    </p>
  </div>
</section>

<!-- RESIDENTIAL vs COMMERCIAL SCOPE DISAMBIG (Gap #86 cross-track) -->
<section class="section">
  <div class="section-inner">
    <div style="max-width: 820px;">
      <p class="section-label">Residential vs Commercial Scope</p>
      <h2>Residential pizza oven vs commercial restaurant production oven</h2>
      <p>
        This page covers <strong>residential</strong> pizza oven repair — LA backyard outdoor built-in (Wolf ICBOGP),
        luxury outdoor kitchen integration (Sub-Zero Group matched-suite), outdoor portable wood-fired + gas
        (Ooni, Gozney, Alfa, Fontana, Bertello), wood-fired domes (custom brick, Forno Bravo residential), and
        countertop electric (Breville Pizzaiolo). Typical LA install runs 500–5,000 pizzas per year at residential
        scale.
      </p>
      <p>
        <strong>Commercial restaurant pizza oven repair</strong> is a separate category — production-scale equipment
        running 100–500+ pizzas per day with conveyor ovens (<strong>Middleby Marshall</strong>, <strong>Lincoln Impinger</strong>),
        deck ovens (<strong>Bakers Pride</strong>, <strong>Blodgett</strong>), hearth ovens (<strong>Wood Stone</strong>),
        and wood-fired hearth (<strong>Forno Bravo commercial</strong>). Different parts chains, different health-department
        code scope (NFPA 96 ventilation + Type I hood integration), different service windows. For restaurant/foodservice
        production units see <a href="/commercial/pizza-oven-repair/" style="color: var(--red); font-weight: 600;">commercial pizza oven repair</a>.
      </p>
      <p>
        <strong>Cleaning vs repair scope:</strong> we cover <em>functional repair</em> — burner + ignition + temperature
        control + gas valve + heating element + thermocouple + door seal + flue/damper + stone replacement. We do
        not cover deep grease/soot/carbon cleaning on wood-fired or BBQ-adjacent units — that's BBQ-specialist
        territory. If you need both, we coordinate with a grill-cleaning vendor so repair work and deep cleaning
        align on timing.
      </p>
    </div>
  </div>
</section>

<!-- OVEN TYPES -->
<section class="section">
  <div class="section-inner">
    <p class="section-label">Oven Types</p>
    <h2>Gas, wood-fired, and electric — we handle all three</h2>
    <div class="types-grid">
      <div class="type-card">
        <h3>🔥 Gas Pizza Ovens</h3>
        <p>
          Ooni Koda, Gozney Roccbox, Bertello Grande, most Alfa models. Gas ovens fail at the
          burner, the thermocouple, the regulator, or the ignition system. We diagnose the actual
          cause — not just swap parts until something works.
        </p>
      </div>
      <div class="type-card">
        <h3>🪵 Wood-Fired Ovens</h3>
        <p>
          Ooni Karu (multi-fuel), Gozney Dome, Alfa Forni, Forno Bravo, Chicago Brick Oven,
          and custom-built units. Wood ovens need different attention — flue draft, floor tile
          integrity, dome insulation, door seals. We know the difference.
        </p>
      </div>
      <div class="type-card">
        <h3>⚡ Electric Pizza Ovens</h3>
        <p>
          Breville Pizzaiolo is in more LA kitchens than you'd think. Countertop electric at 750°F
          means serious heating elements and thermal management. Error codes, temperature
          failures, and heating element replacements — we have the parts.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- COMMON PROBLEMS -->
<section class="section section-gray">
  <div class="section-inner">
    <p class="section-label">What We Fix</p>
    <h2>Common pizza oven problems we see in LA</h2>
    <div class="problems-grid">
      <div class="problem-card">
        <div class="icon">🌡️</div>
        <h4>Oven won't reach temperature</h4>
        <p>Regulator pressure, clogged burner, faulty thermocouple, or thermal mass damage. We test all three before any parts.</p>
      </div>
      <div class="problem-card">
        <div class="icon">🔴</div>
        <h4>Igniter not firing</h4>
        <p>Ooni Koda igniters have a known failure rate. Gozney piezo units go too. Usually a 30-minute repair.</p>
      </div>
      <div class="problem-card">
        <div class="icon">💨</div>
        <h4>Uneven heat / hotspots</h4>
        <p>Often burner clog or uneven flame distribution. On wood ovens — flue draft or damaged floor tiles affecting airflow.</p>
      </div>
      <div class="problem-card">
        <div class="icon">💡</div>
        <h4>Error codes (Breville / electric)</h4>
        <p>Breville Pizzaiolo throws codes when the heating element or thermal fuse fails. We read the codes, don't guess.</p>
      </div>
      <div class="problem-card">
        <div class="icon">🚪</div>
        <h4>Door seal / hinge damage</h4>
        <p>Wood oven doors take abuse. Seal failure means heat loss and uneven cooking. We replace seals on all major models.</p>
      </div>
      <div class="problem-card">
        <div class="icon">🪨</div>
        <h4>Cracked stone or floor tile</h4>
        <p>Thermal shock from rapid heating or water exposure cracks cooking surfaces. Floor replacement is usually a same-day job.</p>
      </div>
      <div class="problem-card">
        <div class="icon">⛽</div>
        <h4>Gas connection problems</h4>
        <p>Regulator failures, flex line leaks, manifold issues. We pressure-test before and after every gas repair.</p>
      </div>
      <div class="problem-card">
        <div class="icon">🌬️</div>
        <h4>Flue / draft issues (wood ovens)</h4>
        <p>Poor draw, smoke backdraft, or damper failure. These affect cooking temperature as much as the fire itself.</p>
      </div>
    </div>
  </div>
</section>

<!-- RECENT REPAIRS -->
<section class="section section-black">
  <div class="section-inner">
    <p class="section-label">Recent Work</p>
    <h2>Recent pizza oven repairs in LA</h2>
    <div class="cases-grid">
      <div class="case-card">
        <div class="case-brand">Ooni Koda 16 · Malibu</div>
        <h4>"Flame keeps going out after about 5 minutes"</h4>
        <p class="case-body">
          Thermocouple on the Koda 16 was reading low and cutting gas flow as a safety measure.
          Classic sign: oven lights, runs for a few minutes, shuts off. Replaced the thermocouple,
          tested for 20 minutes — held steady at 900°F. Client was back to cooking the same night.
        </p>
      </div>
      <div class="case-card">
        <div class="case-brand">Gozney Roccbox · Silver Lake</div>
        <h4>"Clicks but won't light, and sometimes smells like gas"</h4>
        <p class="case-body">
          Gas was flowing but the piezo igniter wasn't producing a consistent spark. The smell told us
          there was also a small regulator o-ring issue releasing trace gas before ignition.
          Replaced the igniter assembly and regulator seal. Pressure-tested the full gas path before signing off.
        </p>
      </div>
      <div class="case-card">
        <div class="case-brand">Breville Pizzaiolo · Brentwood</div>
        <h4>"E3 error code, stopped heating halfway through preheat"</h4>
        <p class="case-body">
          E3 on the Pizzaiolo typically means a thermal fuse has blown — usually triggered by a preceding
          heating element failure running the unit too hot. Replaced both the fuse and the upper element.
          Unit now reliably hits 750°F in about 12 minutes as spec'd.
        </p>
      </div>
      <div class="case-card">
        <div class="case-brand">Custom Wood Dome · Pacific Palisades</div>
        <h4>"Takes 3 hours to get to temperature, used to take 45 minutes"</h4>
        <p class="case-body">
          Insulation had absorbed moisture over two wet winters — common in outdoor wood ovens left
          uncovered. The dome was losing heat faster than the wood could build it. We addressed the
          compromised insulation layer and rebuilt the door seal. Preheat time dropped back to under an hour.
        </p>
      </div>
    </div>
