        <tr><td>Drum rollers (full set replacement)</td><td>$145 to $245</td></tr>
        <tr><td>Belt plus idler plus rollers (year 10+ multi-component)</td><td>$285 to $445</td></tr>
        <tr><td>Drive motor replacement</td><td>$345 to $525</td></tr>
        <tr><td>Drum bearing or rear seal</td><td>$245 to $385</td></tr>
        <tr><td>Drive pulley</td><td>$125 to $185</td></tr>
        <tr><td>Door switch (if no-tumble caused by safety lockout)</td><td>$125 to $185</td></tr>
        <tr><td>Warranty</td><td>90 days parts and labor</td></tr>
      </tbody>
