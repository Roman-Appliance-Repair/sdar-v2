---
// src/pages/services/bbq-grill-repair.astro
// GSC cluster: 1,800+ impressions/quarter
// "bbq repair near me" 54 imp pos 11.6 — near top-10 without page
// "bbq repair service near me" 31 imp pos 12.2
// "electrical bbq repair" 252 imp pos 28
// "portable bbq repair" 218 imp pos 32
// "weber bbq repair" 108 imp pos 54 — massive brand keyword
// "alfresco bbq repair" 34 imp pos 16.2 — luxury LA brand
// Unique angles:
// 1. LA = year-round grilling capital — 3-4x wear vs seasonal climates
// 2. Luxury built-in (Lynx/Alfresco/Fire Magic) vs portable (Weber/Napoleon) — different repair
// 3. Gas safety SoCalGas first + outdoor kitchen full-service

import Layout from '../../layouts/Layout.astro';
import ServiceHero from '../../components/ServiceHero.astro';
import { MAIN_PHONE } from '../../data/branches';

const title = "BBQ Grill Repair Across SoCal — Gas, Built-In & Outdoor Kitchen";
const description = "Same-day BBQ grill repair across LA, Orange, Ventura, San Bernardino & Riverside counties. Gas grills, built-in outdoor kitchens, pellet grills — Lynx, Alfresco, Weber, Wolf, Fire Magic. Gas-certified, BHGS Licensed #A49573. $89 diagnostic.";
const phone = MAIN_PHONE.display;
const phoneRaw = MAIN_PHONE.raw;
const phoneHref = MAIN_PHONE.href;
---

<Layout title={title} description={description}>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "BBQ Grill Repair",
  "serviceType": "BBQ Grill Repair",
  "description": "Same-day BBQ grill repair across Southern California — gas grills, built-in outdoor kitchens, pellet grills. Lynx, Alfresco, Fire Magic, Twin Eagles, Wolf, Capital, Weber, Napoleon, Traeger. Gas-certified technicians. BHGS Licensed #A49573. $89 diagnostic.",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Same Day Appliance Repair",
    "telephone": phone,
    "url": "https://samedayappliance.repair/",
    "priceRange": "$$"
  },
  "areaServed": [
    {"@type":"AdministrativeArea","name":"Los Angeles County"},
    {"@type":"AdministrativeArea","name":"Orange County"},
    {"@type":"AdministrativeArea","name":"Ventura County"},
    {"@type":"AdministrativeArea","name":"San Bernardino County"},
    {"@type":"AdministrativeArea","name":"Riverside County"}
  ],
  "offers": {
    "@type": "Offer",
    "priceSpecification": {
      "@type": "PriceSpecification",
      "price": "89.00",
      "priceCurrency": "USD",
      "description": "Diagnostic fee, applied toward the repair when approved."
    }
  }
})} />

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much does BBQ grill repair cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Our diagnostic fee is $89, waived when you approve the repair. Most BBQ grill repairs run between $120 and $400. Igniter replacement, gas valve, burner, regulator, or heat plate is toward the lower end. Gas line work or full burner bank replacement on a large built-in runs higher. For luxury built-in grills (Lynx, Alfresco, Fire Magic), parts cost more — we give you a written estimate before starting."
      }
    },
    {
      "@type": "Question",
      "name": "Which areas of Southern California do you cover for BBQ grill repair?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Same-day across Los Angeles, Orange, Ventura, San Bernardino, and Riverside counties — Malibu, Bel Air, Beverly Hills, and Pacific Palisades luxury outdoor kitchens; Newport Coast and Newport Beach OC outdoor kitchens; Westlake Village, Hidden Hills-adjacent, and Thousand Oaks outdoor kitchens; Temecula wine-country and IE estate outdoor kitchens. Eight service territories total. Lynx, Alfresco, Fire Magic, Wolf Outdoor — gas-certified across the entire footprint. BHGS Licensed #A49573."
      }
    },
    {
      "@type": "Question",
      "name": "My BBQ grill smells like gas — what do I do first?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Turn off the grill and the gas supply valve immediately. Call your gas utility — SoCalGas at 1-800-427-2200 across most of LA, OC, Ventura, and parts of SB; Southwest Gas at 1-877-860-6020 for Riverside, Anaheim, Long Beach, and parts of SB. They respond quickly, verify the source of the smell, and confirm the area is safe at no charge. Once the utility has cleared the area, call us for the repair. Gas utility first, appliance repair second — always."
      }
    },
    {
      "@type": "Question",
      "name": "My BBQ burners won't ignite — what causes that?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Three causes in order of frequency: (1) failed igniter or spark module — no clicking sound when you press the ignition; (2) clogged burner ports from grease and debris — spark present but flame won't sustain; (3) failed gas valve not allowing gas to the burner. Before calling, try cleaning the burner ports with a wire brush — grease-clogged ports are the most common cause across SoCal where grills run year-round and accumulate buildup faster."
      }
    },
    {
      "@type": "Question",
      "name": "Do you repair Lynx, Alfresco, Fire Magic, and Wolf built-in BBQ grills?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Lynx, Alfresco, Fire Magic, Twin Eagles, Wolf, and Capital are the luxury built-in brands we service most across SoCal outdoor kitchens — Malibu, Bel Air, Beverly Hills, Pacific Palisades, Newport Coast, Newport Beach, Westlake Village, and Temecula wine-country estates. These grills have more complex ignition systems and infrared burner assemblies than standard portable grills. Parts are sourced through commercial kitchen and specialty outdoor equipment distributors."
      }
    },
    {
      "@type": "Question",
      "name": "Do you repair Weber, Napoleon, and Traeger grills?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Weber, Napoleon, Char-Broil, and Nexgrill are the most common portable and freestanding grills we service across SoCal. Weber parts are carried on service vehicles — Weber is the dominant portable grill brand across the region. For Traeger and other pellet grills, we service the auger motor, igniter, and temperature controller — the mechanical and electrical systems."
      }
    },
    {
      "@type": "Question",
      "name": "How often should a BBQ grill be serviced?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Annually minimum — twice a year for grills used heavily year-round. SoCal's year-round grilling culture means most outdoor grills here accumulate grease, carbon, and wear at 3-4x the rate of grills used seasonally. Coastal markets (Malibu, Newport Beach, Pacific Palisades) need extra attention to corrosion. A service visit includes burner cleaning, igniter test, gas valve check, heat plate inspection, grate condition, and regulator pressure verification. Built-in outdoor kitchen grills should also have their gas line connections inspected annually."
      }
    },
    {
      "@type": "Question",
      "name": "Can you repair my outdoor kitchen appliances in addition to the grill?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. We service the full range of outdoor kitchen equipment: BBQ grills, outdoor refrigerators, outdoor wine coolers, side burners, and warming drawers. For Malibu, Bel Air, Newport Coast, Westlake Village, and Temecula properties with full outdoor kitchens, we can service multiple appliances on the same visit."
      }
    }
  ]
})} />

<style>
