---
// src/pages/services/oven-repair/temperature-off.astro
// Phase B-4 — failure-mode sub-service under residential oven pillar.
// SEO: "oven temperature off", "oven not reaching temperature", "oven calibration",
// "oven runs hot", "oven cold spots", "oven thermostat".
// Practitioner angle: customer-side oven thermometer test ($15) + built-in user
// calibration menu (resolves +/-25°F drift no parts) before sensor swap.
// Smart-oven sensor vs app display mismatch FAQ (Roman tweak).
// $89 residential. BHGS #A49573 + EPA 608 Universal #1346255700410.
import Layout from '../../../layouts/Layout.astro';
import ServiceHero from '../../../components/ServiceHero.astro';
import { MAIN_PHONE } from '../../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/services/oven-repair/temperature-off/";

const title = "Oven Temperature Off, Runs Hot or Cold | Sensor, Calibration, Cold Spots, $89 Diagnostic";
const description = "Oven temperature off across LA, OC, Ventura. Sensor drift, user calibration, element failure, door seal. Wolf, Viking, Thermador. $89 dx.";

const faqs = [
  {
    q: "How do I test if my oven temperature is actually off?",
    a: "Buy a $15 oven thermometer (any kitchen store carries them), set the oven to 350°F, let it preheat 20 minutes, place the thermometer on the center rack, wait 10 minutes, read it. If the reading is within +/-15°F of 350, your oven is in mid-market spec. If +/-5°F, that's pro-style spec. Anything beyond that is a real drift. Bring us the reading on the call."
  },
  {
    q: "My oven runs 25°F hot. Sensor or calibration?",
    a: "Try the built-in user calibration menu first. Most ovens (GE, Samsung, LG, Whirlpool, KitchenAid, Maytag) have a user-accessible calibration adjustment in the +/-25°F range. Owner's manual or quick search of your model number gives the menu sequence. If the unit is already at max calibration adjustment and still off, the temperature sensor has drifted, replacement is the call ($200 to $340)."
  },
  {
    q: "Why does the bottom of my oven cook hotter than the top?",
    a: "Two common causes. (1) Bake element partially failed, heats unevenly across its length, hot spots concentrate where the element is healthy. Visual plus resistance test. (2) Door seal leak at the top of the door, hot air escapes, temperature gradient develops. Replacement gasket $180 to $340 if that's the cause."
  },
  {
    q: "Pro-style oven (Wolf, Viking, Thermador) tolerance vs mid-tier?",
    a: "Pro-style ovens hold +/-5°F at setpoint when properly calibrated, mid-market ovens hold +/-15°F. When a Wolf customer says 'running 20°F off', that's well outside spec and a real repair. When a mid-market customer says the same, it might be inside tolerance, verify with a thermometer first before assuming parts failure."
  },
  {
    q: "Smart oven app display says 350°F but oven thermometer reads 380°F. Which is right?",
    a: "Trust the physical thermometer. Smart oven apps (GE Profile WiFi, Samsung Bespoke, LG ThinQ) show the temperature reported by the RTD sensor, which is the same number the control board uses. App display can also lag the actual oven by 30 to 60 seconds during ramp-up. If the physical thermometer reads 380°F while the app says 350°F at steady state (10+ minutes after preheat), the RTD sensor has drifted. Replace the sensor, the app will read correctly again. Smart oven app and physical sensor are connected, an app-vs-thermometer gap is the sensor side, not a connectivity issue."
  },
  {
    q: "Can I just recalibrate it myself?",
    a: "Yes, if the drift is within the +/-25°F user-adjustable range and you've verified the drift with a thermometer. Owner's manual or model-number search gives the exact menu sequence for your brand. If you're outside +/-25°F, the unit's max user calibration is exhausted, sensor or board repair is needed."
  },
  {
    q: "What's your warranty?",
    a: "90 days parts and labor on every repair. BHGS #A49573, EPA 608 Universal certified (#1346255700410), BBB A+ accredited."
  }
];

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": canonical + "#business",
    "name": "Same Day Appliance Repair",
    "url": canonical,
    "telephone": phone,
    "priceRange": "$$",
    "description": "Oven temperature accuracy diagnostic and repair across all five SoCal counties. Temperature sensor (RTD) drift, user calibration walkthrough, partial element failure, door seal leak, control board compensation. Pro-style and mid-market brands. BHGS #A49573. EPA 608 Universal certified #1346255700410.",
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": canonical + "#service",
    "serviceType": "Oven Temperature Diagnostic and Calibration",
    "name": "Oven Temperature Off Diagnostic and Repair",
    "url": canonical,
    "description": "Residential oven temperature accuracy diagnostic across all five SoCal counties. Temperature RTD sensor drift (year 5 to 8), user-accessible calibration menu (resolves up to +/-25°F drift no parts), bake or broil element partial failure causing cold spots, door gasket leak, control board temperature compensation fault. Pro-style ovens (Wolf +/-5°F spec, Viking, Thermador) and mid-market (+/-15°F spec). $89 residential diagnostic, applied toward repair.",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "offers": {
      "@type": "Offer",
      "priceRange": "$89-$1100",
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "89.00",
        "priceCurrency": "USD",
        "description": "Residential diagnostic fee, applied toward repair. No emergency surcharge."
      }
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map((f) => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://samedayappliance.repair/services/" },
      { "@type": "ListItem", "position": 3, "name": "Oven Repair", "item": "https://samedayappliance.repair/services/oven-repair/" },
      { "@type": "ListItem", "position": 4, "name": "Oven Temperature Off", "item": canonical }
    ]
