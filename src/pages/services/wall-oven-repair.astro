---
// src/pages/services/wall-oven-repair.astro
// Wave 5 — Service Pages
// Vector gaps: double wall oven, steam oven/descaling, door hinge/spring/seal,
// broil element, self-clean locked, error codes, touchscreen, Samsung, KitchenAid,
// Viking, OEM parts, 90-day warranty
// Unique angles: steam oven descaling (LA hard water); double oven zone diagnostics;
// built-in cabinetry access knowledge

import Layout from '../../layouts/Layout.astro';
import ServiceHero from '../../components/ServiceHero.astro';
import { MAIN_PHONE } from '../../data/branches';

const title = "Wall Oven Repair — Same-Day Service Across Southern California";
const description = "Same-day wall oven repair across LA, Orange, Ventura, San Bernardino & Riverside counties. Single, double, steam, combination — Wolf, Thermador, Miele, GE, Samsung. Built-in cabinetry access handled carefully. BHGS Licensed #A49573. $89 diagnostic.";
const phone = MAIN_PHONE.display;
const phoneRaw = MAIN_PHONE.raw;
const phoneHref = MAIN_PHONE.href;
---

<Layout title={title} description={description}>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Wall Oven Repair",
  "serviceType": "Wall Oven Repair",
  "description": "Same-day wall oven repair across Southern California — single, double, steam, combination units. Wolf, Thermador, Miele, GE, Samsung, KitchenAid, Jenn-Air. Built-in cabinetry access handled carefully. BHGS Licensed #A49573. $89 diagnostic.",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Same Day Appliance Repair",
    "telephone": phone,
    "url": "https://samedayappliance.repair/",
    "priceRange": "$$"
  },
  "areaServed": [
    {"@type": "AdministrativeArea", "name": "Los Angeles County"},
    {"@type": "AdministrativeArea", "name": "Orange County"},
    {"@type": "AdministrativeArea", "name": "Ventura County"},
    {"@type": "AdministrativeArea", "name": "San Bernardino County"},
    {"@type": "AdministrativeArea", "name": "Riverside County"}
  ],
  "offers": {
    "@type": "Offer",
    "priceSpecification": {
      "@type": "PriceSpecification",
      "price": "89.00",
      "priceCurrency": "USD",
      "description": "Diagnostic fee, applied toward the repair when approved."
    }
  }
})} />

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much does wall oven repair cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Our diagnostic fee is $89, applied toward the repair once you approve the work. Most wall oven repairs run between $150 and $380. A bake element, broil element, temperature sensor, or door part replacement is toward the lower end. Control board replacement on premium brands like Miele, Thermador, or Wolf runs higher. We provide a full written estimate before any work begins."
      }
    },
    {
      "@type": "Question",
      "name": "Which areas of Southern California do you cover for wall oven repair?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Same-day across Los Angeles, Orange, Ventura, San Bernardino, and Riverside counties — Beverly Hills and Brentwood luxury kitchens, Newport Beach and Irvine OC homes, Thousand Oaks and Westlake Village in Ventura County, Rancho Cucamonga and Riverside in the Inland Empire. Eight service territories total. Wolf, Thermador, Miele, Gaggenau, GE, Samsung, KitchenAid — every brand running SoCal kitchens. BHGS Licensed #A49573."
      }
    },
    {
      "@type": "Question",
      "name": "My wall oven self-clean cycle ran and now the door won't open — what do I do?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The door lock motor assembly has failed to retract after the self-clean cycle. First, let the oven cool completely — at least 2-3 hours — and try cutting power at the breaker, waiting 5 minutes, then restoring power. This sometimes triggers a reset. If the door remains locked, the door lock motor or its control board signal has failed and needs replacement. We carry door lock assemblies for the major brands and see this failure regularly after self-clean cycles."
      }
    },
    {
      "@type": "Question",
      "name": "Do you repair steam ovens and combination steam ovens?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Steam and combi-steam ovens from Thermador, Miele, Wolf, and Gaggenau are a significant part of what we service in SoCal's premium kitchen market. Steam ovens require periodic descaling — Southern California's hard water (300+ mg/L TDS in LA, even harder in Inland Empire and parts of Riverside/San Bernardino) accelerates scale buildup in the water reservoir, steam generator, and distribution lines. Ignoring descaling eventually causes steam generator failure, which is a preventable and expensive repair. We service both the mechanical failures and descaling maintenance on these units."
      }
    },
    {
      "@type": "Question",
      "name": "My double wall oven — only one oven is working. Is it the control board?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Not necessarily. Double wall ovens have two independently controlled oven cavities, each with its own bake element, broil element, temperature sensor, and zone control. When one stops working while the other functions normally, the failed element or temperature sensor in that zone is the most likely cause — not the main control board. We diagnose each zone independently before recommending a board replacement, which is the more expensive repair."
      }
    },
    {
      "@type": "Question",
      "name": "Is accessing a wall oven for repair going to damage my cabinetry?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Not if it's done correctly. Wall ovens are mounted in a cabinet cutout and held in place by screws through the oven's trim frame. The correct removal sequence varies by brand and installation — some have anti-tip brackets, some have specific screw patterns, some have integrated trim kits that must be removed first. Our technicians know the removal sequence for the brands we work on most across SoCal and won't force a unit out in a way that damages the surrounding cabinetry."
      }
    },
    {
      "@type": "Question",
      "name": "My wall oven bakes unevenly — food burns on one side. Is that the element?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Either the bake element or the temperature sensor, and sometimes both. A partially failed bake element heats unevenly along its length, creating hot spots near the failed section. A drifting temperature sensor causes the oven to cycle incorrectly, which can also produce uneven results throughout the cavity. We run a temperature test at multiple positions before concluding which component is at fault."
      }
    },
    {
      "@type": "Question",
      "name": "When does it make sense to repair vs replace a wall oven?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Wall ovens last 12–18 years with normal use. Under 8 years old: repair almost always wins. 8–12 years with a single component failure (element, sensor, door part): repair. 12+ years with multiple failures, control-board failure on a premium brand, or a steam-generator failure on a chronically undescaled unit: we'll quote both repair and replacement. A new wall oven is $1,500–$8,000+ depending on brand, plus install — and built-in replacement requires careful cabinetry sizing. We'll tell you directly which makes more financial sense."
      }
    },
    {
      "@type": "Question",
      "name": "What does the 90-day warranty cover on wall oven repairs?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Every wall oven repair we complete carries a 90-day warranty on both parts and labor. If the same issue returns within that window, we come back at no charge. That's in writing before we leave."
      }
    }
  ]
})} />

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .hero { background: var(--black); color: #fff; padding: 80px 24px 64px; text-align: center; }
  .hero-eyebrow { display: inline-block; background: var(--red); color: #fff; font-size: 0.78rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 5px 14px; border-radius: 3px; margin-bottom: 20px; }
  .hero h1 { font-size: clamp(2rem, 4vw, 3rem); font-weight: 800; line-height: 1.15; margin: 0 0 20px; max-width: 820px; margin-left: auto; margin-right: auto; }
  .hero-sub { font-size: 1.15rem; color: #ccc; max-width: 620px; margin: 0 auto 32px; line-height: 1.6; }
  .cta-row { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 16px 34px; border-radius: 5px; font-size: 1rem; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 16px 34px; border-radius: 5px; font-size: 1rem; font-weight: 600; text-decoration: none; border: 2px solid rgba(255,255,255,0.35); }
  .hero-rating { margin-top: 28px; color: #aaa; font-size: 0.9rem; }
  .hero-rating strong { color: #fff; }
  .stars { color: #f5b800; margin-right: 6px; }
  .trust-bar { background: var(--red); padding: 18px 24px; }
  .trust-inner { max-width: 1100px; margin: 0 auto; display: flex; justify-content: center; flex-wrap: wrap; gap: 10px 32px; }
  .trust-item { color: #fff; font-size: 0.88rem; font-weight: 600; display: flex; align-items: center; gap: 7px; }
  .section { padding: 72px 24px; }
  .section-gray { background: var(--gray); }
  .section-black { background: var(--black); color: #fff; }
  .container { max-width: 1100px; margin: 0 auto; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  h2.section-title { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; margin: 0 0 16px; line-height: 1.2; }
