---
// src/pages/services/stackable-washer-dryer-repair.astro
// Wave 5, Service Pages
// Vector gaps: laundry closet/tight space, front-load only, ventless/heat pump dryer,
// door seal/mold, thermal fuse, drum belt/roller, dryer vent, Bosch/Miele/Blomberg/Electrolux,
// Maytag, Frigidaire, 90-day warranty
// Unique angles: LA condo/apartment laundry closet access; ventless heat-pump dryers
// (LA electrification); front-load mold in closed closets

import Layout from '../../layouts/Layout.astro';
import ServiceHero from '../../components/ServiceHero.astro';
import { MAIN_PHONE } from '../../data/branches';

const title = "Stackable Washer & Dryer Repair, Closet, Compact, Ventless | Across SoCal";
const description = "Stackable + combo + heat-pump washer-dryer repair across LA, OC, Ventura, SB, Riverside. Laundry closets. BHGS #A49573. EPA 608. $89 dx.";
const canonical = "https://samedayappliance.repair/services/stackable-washer-dryer-repair/";
const phone = MAIN_PHONE.display;
const phoneRaw = MAIN_PHONE.raw;
const phoneHref = MAIN_PHONE.href;
---

<Layout title={title} description={description} canonical={canonical}>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Stackable Washer and Dryer Repair",
