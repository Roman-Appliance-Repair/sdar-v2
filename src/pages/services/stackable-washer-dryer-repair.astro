  .problem-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 22px 18px; }
  .problem-card h3 { font-size: 1rem; font-weight: 700; margin: 0 0 10px; color: var(--text); }
  .problem-card p { font-size: 0.9rem; color: var(--muted); line-height: 1.6; margin: 0; }
  /* LA closet spotlight */
  .closet-block { background: #0a100a; border: 1px solid #1a2a1a; border-radius: 10px; padding: 34px 30px; margin-top: 36px; }
