  .closet-block h3 { font-size: 1.2rem; font-weight: 800; color: #fff; margin: 0 0 12px; }
  .closet-block p { font-size: 0.93rem; color: #80a080; line-height: 1.7; margin: 0 0 12px; }
  .cl-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 10px; margin-top: 16px; }
  .cl-item { background: #060c06; border: 1px solid #101a10; border-radius: 6px; padding: 12px 14px; }
  .cl-item strong { display: block; font-size: 0.85rem; color: #90d090; margin-bottom: 3px; }
  .cl-item span { font-size: 0.8rem; color: #304030; line-height: 1.4; }
  /* Brands */
  .brands-grid { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 28px; }
  .brand-chip { background: #fff; border: 1px solid var(--border); border-radius: 4px; padding: 8px 18px; font-size: 0.88rem; font-weight: 600; color: var(--text); }
  .brand-chip.dark { background: #1a1a1a; color: #ddd; border-color: #333; }
  /* Repairs */
  .repairs-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(255px, 1fr)); gap: 22px; margin-top: 36px; }
  .repair-card { background: #111; border: 1px solid #222; border-radius: 8px; padding: 22px 18px; }
