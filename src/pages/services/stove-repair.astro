    { "@type": "AdministrativeArea", "name": "Los Angeles County" },
    { "@type": "AdministrativeArea", "name": "Orange County" },
    { "@type": "AdministrativeArea", "name": "Ventura County" },
    { "@type": "AdministrativeArea", "name": "San Bernardino County" },
    { "@type": "AdministrativeArea", "name": "Riverside County" }
  ],
  "offers": {
    "@type": "Offer",
    "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, applied toward repair" }
  }
})} />

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "How much does stove repair cost?",
      "acceptedAnswer": { "@type": "Answer", "text": "Our diagnostic fee is $89, waived when you approve the repair. Most stove and range repairs run between $150 and $420. Igniter, spark module, infinite switch, gas valve, or single heating element is toward the lower end. Control board replacement runs $200–$450 depending on brand. For luxury ranges (Wolf, Thermador, Viking, BlueStar), parts cost more, $300–$600 is common, but repair almost always makes sense given the cost of replacement." } },
    { "@type": "Question", "name": "Which areas of Southern California do you cover?",
      "acceptedAnswer": { "@type": "Answer", "text": "All five counties: Los Angeles, Orange, Ventura, San Bernardino, and Riverside. We dispatch from 8 service territories, West Hollywood (HQ), Los Angeles, Beverly Hills, Pasadena, Thousand Oaks, Irvine, Rancho Cucamonga, and Temecula, so the technician on your call is coming from the closest one. Same-day or next-day is our standard." } },
    { "@type": "Question", "name": "My gas stove burner won't light, what should I check first?",
      "acceptedAnswer": { "@type": "Answer", "text": "Clean the burner first. Remove the burner cap and clean the ports with a toothpick or thin wire, clogged ports from food debris and grease are the most common cause of a burner that won't light or lights weakly. Also clean the igniter ceramic with a dry toothbrush, food residue on the igniter tip prevents the spark from jumping the gap. If the burner is clean, clicking but no flame, that's a gas valve or igniter module issue. If there's no clicking at all, that's the spark module or wiring." } },
    { "@type": "Question", "name": "My gas stove smells like gas, what do I do?",
      "acceptedAnswer": { "@type": "Answer", "text": "Turn off all burners and leave the house. Call SoCalGas at 1-800-427-2200 immediately, they respond quickly and verify the source at no charge. Once SoCalGas confirms the area is safe, call us at (424) 325-0520 for the mechanical repair. Do not attempt to use the stove until the gas smell has been identified and resolved." } },
    { "@type": "Question", "name": "Is it worth repairing a stove or should I replace it?",
      "acceptedAnswer": { "@type": "Answer", "text": "The general rule: if the repair cost is less than 50% of the replacement cost for a comparable appliance, repair makes sense. For budget brands (LG, GE, Samsung, Whirlpool) a $400 repair on a stove that would cost $700–$900 to replace is borderline, we'll tell you honestly. For luxury ranges (Wolf, Thermador, Viking, Dacor, BlueStar, Capital) that cost $4,000–$12,000, a $400 repair is almost always worth it. We diagnose first and give you the repair cost before you decide, no pressure either way." } },
    { "@type": "Question", "name": "What is the difference between repairing a gas stove vs electric stove vs induction?",
      "acceptedAnswer": { "@type": "Answer", "text": "Gas stoves: failures are in the ignition system (igniter, spark module), gas supply (valve, regulator), or burner ports (clogged). Electric stoves: failures are in the heating elements (coil or radiant), infinite switch that controls heat level, or control board. Induction stoves: failures are in the induction coil, power inverter board, or control electronics, more complex and typically more expensive to repair than conventional electric. We service all three types." } },
    { "@type": "Question", "name": "Do you repair Wolf, Thermador, Viking, BlueStar, and Capital ranges?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Wolf, Thermador, Viking, Dacor, BlueStar, Capital Cooking, and Bertazzoni are among the luxury range brands we service most across SoCal, Beverly Hills, Newport Beach, Calabasas, Pasadena. These ranges have commercial-grade components and longer service lives, repair almost always makes more sense than replacement. Parts are sourced same-day through specialty appliance distributors." } },
    { "@type": "Question", "name": "Do you also repair wall ovens?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Wall ovens share heating-element, control-board, and igniter failure modes with ranges, many of the same diagnostic and repair skills apply. See our dedicated wall-oven page for details specific to single, double, and combi wall-oven configurations." } },
    { "@type": "Question", "name": "My electric stove has one burner that stopped working, is that a simple fix?",
      "acceptedAnswer": { "@type": "Answer", "text": "Usually yes, one dead burner on an electric stove is almost always either the heating element (coil or radiant disc) or the infinite switch (the control that regulates power to that burner). Both are straightforward same-day repairs. Swap the element to another position first: if the problem follows the element, it's the element. If the problem stays at the same position, it's the switch or wiring." } }
  ]
})} />

