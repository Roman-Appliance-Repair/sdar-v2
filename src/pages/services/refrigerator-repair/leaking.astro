// src/pages/services/refrigerator-repair/leaking.astro
// Wave 3a — Refrigerator Leaking Water sub-service. Failure-mode pattern.
// #1 cause: defrost drain clogged (40-50% of calls).
// Visual diagnostic: water location (inside vs outside front vs outside back).
// Built-in unit complexity: Sub-Zero, Thermador Freedom, Liebherr drain routing.
// LA marine layer angle (Roman's addition): Santa Monica/Palisades/Malibu morning fog
// mistaken for leak — "Sometimes the puddle on Monday morning is actually fog."
// $89 residential, BHGS #A49573, EPA 608 #1346255700410. 4 schema entities.
import Layout from '../../../layouts/Layout.astro';
import ServiceHero from '../../../components/ServiceHero.astro';
import { MAIN_PHONE } from '../../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/services/refrigerator-repair/leaking/";

const title = "Refrigerator Leaking Repair LA — Same Day";
const description = `Refrigerator leaking water inside or under the unit? LA same-day. Defrost drain (#1 cause), water inlet valve, ice maker line, drain pan. BHGS #A49573.`;

const faqs = [
  {
    q: "My refrigerator leaks water onto the floor. Where do I start?",
    a: "Pay attention to where the puddle appears. Water on the floor INSIDE the fridge (collecting at the bottom of the fresh-food compartment, sometimes pooling under the crisper drawers) means defrost drain clogged. Water on the floor OUTSIDE the fridge in front (under the door, especially at the door dispenser corner) means ice maker fill tube cracked or door dispenser tray leaking. Water on the floor OUTSIDE the fridge BEHIND the unit means water inlet valve dripping or supply line connection loose. Different causes, different repairs. We diagnose by location."
  },
  {
    q: "What is the defrost drain and why does it clog?",
    a: "The defrost drain is a small tube that carries melt water from the freezer's defrost cycle down to a pan near the compressor, where compressor heat evaporates it. Year 5+ is when the drain typically clogs with food particles, ice, or biofilm. Symptom: water collects inside the fresh-food compartment (the drain backs up and overflows there) or under the crisper drawers. The clear is straightforward but requires accessing the drain, $200 to $300 service typical. About 40 to 50 percent of all 'refrigerator leaking' calls trace to this."
  },
  {
    q: "Sometimes I find a puddle on Monday morning but the fridge seems fine. Is it broken?",
    a: "If you live in Santa Monica, Pacific Palisades, Malibu, or anywhere along the marine layer corridor, sometimes the puddle is actually morning fog condensing on cold metal surfaces overnight, not a leak from the refrigerator. This is real and we don't charge for it. Diagnostic: dry the area thoroughly, watch for 24 hours, observe whether moisture returns during high-humidity hours (5 AM to 9 AM marine layer is densest) vs steady weeping throughout the day. Steady weeping is a leak. Morning-only mist that dries by noon is condensation. We'll tell you on the diagnostic visit if that's what's happening."
  },
  {
    q: "I see water at the back of the fridge. Different problem from defrost drain?",
    a: "Yes. Water at the back of the fridge (sometimes visible only when you pull the unit out) almost always traces to the water inlet valve at the back-bottom of the cabinet, slowly dripping. Year 6 to 10 typical for the valve to develop a slow drip from mineral deposits on the diaphragm. Symptom is intermittent: drip rate varies with house water pressure and the valve's open/close cycle. Replacement runs $260 to $380. Less commonly, the supply line connection at the wall valve is loose; we tighten it on the same visit if needed."
  },
  {
    q: "We have a built-in Sub-Zero. Drain leaks are different on those?",
    a: "Yes. Built-in Sub-Zero, Thermador Freedom, and Liebherr units have more complex drain line routing because the unit is integrated into cabinetry rather than freestanding. The defrost drain often routes through the toe-kick area or behind cabinet panels, and access requires careful disassembly to avoid damaging the surrounding millwork. Service tier is different: we have authorized service relationships for these brands and the experience to access drain lines without scratching cabinet faces or damaging panel hardware. Same diagnostic logic, more careful execution."
  },
  {
    q: "My ice maker line is dripping inside the freezer. How do I fix that?",
    a: "Ice maker fill tube cracked or developed a small leak at its connection. The fill tube is the small plastic line that delivers water from the inlet valve to the ice maker mold. Year 5+ typical for the tube to crack from temperature cycling, especially in LA garage installs that swing 35°F to 110°F ambient. Replacement $200 to $340. Sometimes we also find an ice block on the fill tube end (water freezes in the tube during cold-snap nights), which gets thawed and the underlying tube replaced if cracked."
  },
  {
    q: "What's your warranty?",
    a: "90 days SDAR labor and parts warranty on the work we perform. If the same component fails within 90 days, we replace it free. BHGS #A49573, BBB Accredited Business, EPA 608 Universal certified #1346255700410."
  }
];

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": canonical + "#business",
    "name": "Same Day Appliance Repair",
    "url": canonical,
    "telephone": phone,
    "priceRange": "$$",
    "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "08:00", "closes": "20:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "00:00", "closes": "00:00" }
      ],
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": canonical + "#service",
    "serviceType": "Refrigerator Leaking Water Repair",
    "name": "Refrigerator Water Leak Diagnostic and Repair Service",
    "url": canonical,
    "description": "Residential refrigerator water leak diagnostic and repair across all five SoCal counties. Defrost drain clogged (#1 cause, 40 to 50 percent of leak calls), water inlet valve slow drip, ice maker fill tube crack, water filter housing seal failure, drain pan overflow, door seal condensation, marine layer condensation false-positive education for coastal LA neighborhoods. Built-in Sub-Zero, Thermador Freedom, Liebherr drain line routing complexity, freestanding Whirlpool, KitchenAid, GE Profile / Café / Monogram (Haier-owned since 2016), LG, Samsung, Frigidaire, Maytag, Bosch, Miele. $89 residential diagnostic, waived with repair. BHGS #A49573, EPA 608 Universal certified #1346255700410.",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, waived with repair" } }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Services", "item": "https://samedayappliance.repair/services/" },
      { "@type": "ListItem", "position": 3, "name": "Refrigerator Repair", "item": "https://samedayappliance.repair/services/refrigerator-repair/" },
      { "@type": "ListItem", "position": 4, "name": "Leaking Water", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>
