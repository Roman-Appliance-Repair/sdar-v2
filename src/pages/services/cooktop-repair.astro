---
// src/pages/services/cooktop-repair.astro
// Phase 3 Tier 2 (2026-04-28), neutral multi-county hub.
// title/H1/description/phone neutralized to 5 SoCal counties; Service schema with 5-county
// areaServed (was HomeAndConstructionBusiness with 8 LA cities); aggregateRating REMOVED per
// wiki/decisions/nap-rating-policy-ssot.md; Recent Repairs distributed 2 LA + 1 OC + 1 Ventura;
// Cities-served block → 5-county Counties block; induction electrification angle preserved.

import Layout from '../../layouts/Layout.astro';
import ServiceHero from '../../components/ServiceHero.astro';
import { MAIN_PHONE } from '../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;

const title = "Cooktop Repair, Same-Day Service Across Southern California";
const description = "Same-day cooktop repair across LA, OC, Ventura, SB, Riverside. Cracked glass assessment included. BHGS #A49573, $89 dx.";
---

<Layout title={title} description={description}>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Cooktop Repair",
  "name": "Cooktop Repair, Same Day Appliance Repair",
  "description": "Same-day cooktop repair across Los Angeles, Orange, Ventura, San Bernardino, and Riverside counties. Gas, electric, induction, all major and luxury brands.",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Same Day Appliance Repair",
    "url": "https://samedayappliance.repair/",
    "telephone": phone,
    "priceRange": "$$",
    "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "08:00", "closes": "20:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "00:00", "closes": "00:00" }
      ]
  },
  "areaServed": [
    { "@type": "AdministrativeArea", "name": "Los Angeles County" },
    { "@type": "AdministrativeArea", "name": "Orange County" },
    { "@type": "AdministrativeArea", "name": "Ventura County" },
    { "@type": "AdministrativeArea", "name": "San Bernardino County" },
    { "@type": "AdministrativeArea", "name": "Riverside County" }
  ],
  "offers": {
    "@type": "Offer",
    "priceSpecification": {
      "@type": "PriceSpecification",
      "price": "89.00",
      "priceCurrency": "USD",
      "description": "Residential diagnostic fee, applied toward repair"
    }
  }
})} />

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much does cooktop repair cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Our diagnostic fee is $89, applied toward the repair once you approve the work. Most cooktop repairs run between $120 and $320. A burner igniter, spark electrode, or heating element replacement is toward the lower end. Control board replacement on premium brands like Thermador, Wolf, or Gaggenau runs higher. We provide a written estimate before any work begins."
      }
    },
    {
      "@type": "Question",
      "name": "Which areas of Southern California do you cover?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "All five counties: Los Angeles, Orange, Ventura, San Bernardino, and Riverside. We dispatch from 8 service territories, West Hollywood (HQ), Los Angeles, Beverly Hills, Pasadena, Thousand Oaks, Irvine, Rancho Cucamonga, and Temecula, so the technician on your call is coming from the closest one. Same-day is our standard."
      }
    },
    {
      "@type": "Question",
      "name": "My gas burner clicks but won't light, what's wrong?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The most common cause is a clogged burner port or dirty burner cap, food debris blocks the gas ports and the igniter sparks but can't light the gas. This is often a cleaning issue, not a repair. If cleaning doesn't resolve it, the spark electrode, igniter module, or gas valve is the next thing to check. We look at the burner condition before recommending parts."
      }
    },
    {
      "@type": "Question",
      "name": "Is it safe to use a cooktop with a cracked glass surface?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. A cracked glass or ceramic cooktop surface is a safety hazard and should not be used until the glass is replaced. Cracks can expose the heating elements or electronics beneath to spills. On a gas cooktop, a crack can allow gas accumulation in unsafe areas. The crack will also worsen with heat cycling, what starts as a hairline crack typically propagates with continued use. We assess glass damage on every cooktop call and advise honestly on whether repair or replacement makes more sense."
      }
    },
    {
      "@type": "Question",
      "name": "My induction cooktop shows an error code and won't heat, what does that mean?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Induction cooktops display error codes that point to specific failure modes. E0 or E1 errors typically indicate power supply or sensor issues. E6 or similar codes often indicate the induction coil or the control board has a fault. Some errors are triggered simply by using incompatible cookware, induction requires ferromagnetic pans. We diagnose induction-specific failures correctly, which requires familiarity with the error code systems for the brands we service: Bosch, Thermador, Miele, Wolf, and Samsung."
      }
    },
    {
      "@type": "Question",
      "name": "Do you repair Wolf, Thermador, and Gaggenau cooktops?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. These are three of the professional-grade cooktop brands we work on most frequently across SoCal premium kitchen markets. Wolf sealed burner cooktops, Thermador Star Burner gas and induction, and Gaggenau's full-surface induction all require brand-specific OEM parts and familiarity with their specific configurations. We source parts from authorized distributors."
      }
    },
    {
      "@type": "Question",
      "name": "I smell gas near my cooktop, what should I do?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "If you smell gas, turn off all burners, open windows, and leave the space without using any electrical switches. Call SoCalGas at 1-800-427-2200 from outside or from a cell phone away from the house. Do not schedule a repair call until the gas supplier has assessed the situation. Once cleared, we handle the appliance-side repair, gas valves, burner assemblies, and ignition systems. We do not work on the gas supply line itself."
      }
    },
    {
      "@type": "Question",
      "name": "When does it make sense to repair vs replace a cooktop?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Rule of thumb: under 8 years old and the repair is under $300, fix it. Over 12 years old AND the repair is over $500, consider replacing. Pro-grade brands flip the math, Wolf, Thermador, Gaggenau, Miele, BlueStar are almost always worth repairing through year 20+; replacement runs $3,000–$8,000+ before installation. Cracked glass on consumer-grade smooth-tops is often a replace decision; pro-grade glass is usually replaceable. We tell you straight which side of that line your unit falls on."
      }
    },
    {
      "@type": "Question",
      "name": "What does the 90-day warranty cover on cooktop repairs?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Every cooktop repair we complete carries a 90-day warranty on both parts and labor. If the same issue returns within that window, we come back at no charge. That's in writing before we leave."
      }
    }
  ]
})} />

<style>
