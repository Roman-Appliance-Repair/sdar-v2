    <h2>Disposal jam questions.</h2>
    <div class="faq-list">
      {faqs.map(f => (<details class="faq-item"><summary>{f.q}</summary><p set:html={f.a}></p></details>))}
    </div>
  </div>
</section>

<section class="section section-gray">
  <div class="container">
    <p class="section-number">Related</p>
    <h2>Disposal service across the catalog.</h2>
    <div class="related-grid">
      <a href="/services/garbage-disposal-repair/" class="related-card"><h3>Disposal Repair Hub</h3><p>Parent pillar.</p></a>
      <a href="/services/garbage-disposal-repair/not-working/" class="related-card"><h3>Disposal Not Working</h3><p>Reset switch, capacitor, motor diagnostic.</p></a>
      <a href="/services/garbage-disposal-repair/leaking/" class="related-card"><h3>Disposal Leaking</h3><p>Flange seal, housing crack, drain connection.</p></a>
      <a href="/credentials/licensed/" class="related-card"><h3>License + Credentials</h3><p>BHGS #A49573, EPA 608 Universal #1346255700410.</p></a>
    </div>
  </div>
</section>

<section class="bottom-cta">
  <div class="container">
    <h2>Disposal jammed? Try the Allen wrench first.</h2>
