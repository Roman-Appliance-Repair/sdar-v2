        <tr><td>Broken impeller arm replacement</td><td>$185 to $285</td></tr>
        <tr><td>Flywheel replacement</td><td>$245 to $345</td></tr>
        <tr><td>Full disposal replacement (mid-tier)</td><td>$345 to $525</td></tr>
        <tr><td>Full disposal replacement (premium)</td><td>$525 to $785</td></tr>
        <tr><td>Warranty</td><td>90 days parts and labor</td></tr>
      </tbody>
    </table>
  </div>
</section>

<section class="section">
  <div class="container narrow">
