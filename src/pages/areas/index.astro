---
import Layout from '../../layouts/Layout.astro';
import CountyMap from '../../components/CountyMap.astro';
import BranchNAP from '../../components/BranchNAP.astro';
import { BRANCHES } from '../../data/branches';
import { CITIES, COUNTIES, type CountySlug } from '../../data/cities';

// County order (rendering top-down)
const COUNTY_ORDER: CountySlug[] = [
  'los-angeles',
  'orange',
  'ventura',
  'san-bernardino',
  'riverside'
];

// Build county → branch → cities hierarchy from data layer.
// Each city is uniquely owned by ONE branch (primaryBranch field), so no
// dedup is needed. Empty-cities branches still render с BranchNAP block.
const branchesByCounty = COUNTY_ORDER.map((countySlug) => {
  const county = COUNTIES[countySlug];
  const branches = BRANCHES.filter((b) => b.primaryCounty === countySlug);
  const branchSections = branches.map((branch) => {
    const cities = CITIES
      .filter((c) => c.primaryBranch === branch.slug)
      .sort((a, b) => a.name.localeCompare(b.name));
    return { branch, cities };
  });
  const totalCities = branchSections.reduce((sum, s) => sum + s.cities.length, 0);
  return {
    countySlug,
    countyName: county.name,
    countyHref: county.hubUrl,
    branchSections,
    totalCities,
    branchCount: branches.length
  };
});

// Summary cards (top-level "Five counties" block) — derived counts from same data.
const counties = branchesByCounty.map((c) => ({
  href: c.countyHref,
  name: c.countyName,
  cities: c.totalCities,
  branches: c.branchCount
}));

const totalCities = counties.reduce((sum, c) => sum + c.cities, 0);
const totalBranches = BRANCHES.length;

const title = 'Service Areas — LA, OC, Ventura, SB, Riverside';
const description = `Same-day appliance repair across LA, OC, Ventura, SB, Riverside. ${totalCities} cities served from ${totalBranches} branch locations. BHGS #A49573, EPA 608, CSLB C-20. $89 / $120 dx.`;

const residentialServices = [
  { label: 'Refrigerator Repair', href: '/services/refrigerator-repair/' },
  { label: 'Washer Repair',       href: '/services/washer-repair/' },
  { label: 'Dryer Repair',        href: '/services/dryer-repair/' },
  { label: 'Dishwasher Repair',   href: '/services/dishwasher-repair/' },
  { label: 'Oven & Range Repair', href: '/services/oven-repair/' },
  { label: 'Freezer Repair',      href: '/services/freezer-repair/' },
  { label: 'Cooktop Repair',      href: '/services/cooktop-repair/' },
  { label: 'Wine Cooler Repair',  href: '/services/wine-cooler-repair/' },
  { label: 'All Services →',      href: '/services/' }
];

const commercialServices = [
  { label: 'Walk-In Cooler Repair',     href: '/commercial/refrigeration/walk-in-cooler-repair/' },
  { label: 'Commercial Refrigerator',   href: '/commercial/refrigerator-repair/' },
  { label: 'Ice Machine Repair',        href: '/commercial/ice-machines/' },
  { label: 'Commercial Dishwasher',     href: '/commercial/dishwasher-repair/' },
  { label: 'Commercial Oven Repair',    href: '/commercial/oven-repair/' },
  { label: 'Exhaust Hood Repair',       href: '/commercial/exhaust-hood-repair/' },
  { label: 'Commercial Laundry',        href: '/commercial/laundry-repair/' },
  { label: 'Commercial Fryer Repair',   href: '/commercial/fryer-repair/' },
  { label: 'All Commercial →',          href: '/commercial/' }
];
---

<Layout title={title} description={description}>
  <section class="hero">
    <div class="container">
      <p class="eyebrow">Service Areas · Southern California</p>
      <h1>Appliance Repair Across Southern California</h1>
      <p class="subtitle">{totalCities} cities across 5 counties. {totalBranches} branch locations. Same day available. Residential and commercial.</p>
    </div>
  </section>

  <section class="map-section">
    <div class="container">
      <p class="sl">Our {totalBranches} Branches</p>
      <h2 class="map-h2">Click any branch pin to view its territory</h2>
    </div>
  </section>
  <CountyMap county="all" height="380px" />

  <section class="section">
    <div class="container">
      <p class="sl">County Hubs</p>
      <h2>Five counties across Southern California</h2>
      <div class="county-grid">
        {counties.map((c) => (
          <a href={c.href} class="county-card">
            <h3>{c.name}</h3>
            <p class="county-meta">{c.cities} cities · {c.branches} {c.branches === 1 ? 'branch' : 'branches'}</p>
            <span class="card-cta">View county →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section section-services">
    <div class="container">
      <p class="sl">Services</p>
      <h2>Residential & Commercial Appliance Repair</h2>
      <div class="services-cols">
        <div class="svc-col">
          <h3>Home Appliances</h3>
          <ul>
            {residentialServices.map((s) => (
              <li><a href={s.href}>{s.label}</a></li>
            ))}
          </ul>
        </div>
        <div class="svc-col">
          <h3>Commercial Equipment</h3>
          <ul>
            {commercialServices.map((s) => (
              <li><a href={s.href}>{s.label}</a></li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="sl">All Service Cities by Branch</p>
      <h2>{totalCities} cities, organized by county and branch</h2>
      <p class="section-intro">
        Each city below links to its dedicated service page. Branches grouped by county show
        the territory each location dispatches from — for fastest response, call the branch
        nearest you.
      </p>

      {branchesByCounty.map((county) => (
        <div class="county-block">
          <a href={county.countyHref} class="county-heading">
            {county.countyName} <span class="county-count">— {county.branchCount} {county.branchCount === 1 ? 'branch' : 'branches'} · {county.totalCities} {county.totalCities === 1 ? 'city' : 'cities'}</span>
            <span class="county-arrow">→</span>
          </a>

          {county.branchSections.map(({ branch, cities }) => (
            <section class="county-branch">
              <div class="branch-nap-wrap">
                <BranchNAP branch={branch} showHeading={true} showEmail={true} showCities={false} />
              </div>

              {cities.length > 0 && (
                <div class="branch-cities-grid">
                  {cities.map((city) => (
                    <a href={`/${city.slug}/`} class="city-link">{city.name}</a>
                  ))}
                </div>
              )}
            </section>
          ))}
        </div>
      ))}
    </div>
  </section>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }

  .container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }

  .hero { background: #0a0a0a; color: #fff; padding: 80px 24px 56px; }
  .hero .eyebrow { font-size: 13px; font-weight: 600; letter-spacing: .12em; text-transform: uppercase; color: var(--red); margin-bottom: 14px; }
  .hero h1 { font-size: clamp(30px, 4vw, 50px); font-weight: 700; line-height: 1.1; margin: 0 0 16px; letter-spacing: -.02em; max-width: 820px; color: #fff; }
  .hero .subtitle { font-size: 18px; line-height: 1.65; color: rgba(255, 255, 255, .85); max-width: 640px; margin: 0; }

  .sl { font-size: 12px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--red); margin: 0 0 12px; }
  .map-section { padding: 56px 24px 24px; text-align: center; }
  .map-h2 { font-size: clamp(20px, 2.6vw, 28px); font-weight: 700; line-height: 1.2; margin: 0 0 28px; color: var(--text); }

  .section { padding: 64px 24px; }
  .section h2 { font-size: clamp(22px, 3vw, 32px); font-weight: 700; line-height: 1.2; margin: 0 0 16px; color: var(--text); }
  .section-intro { font-size: 15px; line-height: 1.65; color: var(--muted); max-width: 720px; margin: 0 0 32px; }

  .county-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 16px; }
  .county-card { display: flex; flex-direction: column; gap: 6px; padding: 24px 22px; background: #0a0a0a; border-radius: 8px; color: #fff; text-decoration: none; transition: transform .2s, background .2s; }
  .county-card:hover { background: var(--red); transform: translateY(-2px); }
  .county-card h3 { font-size: 19px; font-weight: 700; margin: 0 0 4px; color: #fff; font-family: var(--font-body); letter-spacing: -.01em; }
  .county-meta { font-size: 13px; color: rgba(255, 255, 255, .7); margin: 0 0 12px; }
  .card-cta { font-size: 13px; font-weight: 600; color: rgba(255, 255, 255, .85); letter-spacing: .04em; }

  .section-services { background: #fafafa; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .services-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 28px; margin-top: 12px; }
  .svc-col { background: #fff; border: 1px solid var(--border); border-radius: 10px; padding: 26px 28px; }
  .svc-col h3 { font-size: 13px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--red); margin: 0 0 16px; padding-bottom: 12px; border-bottom: 1px solid var(--border); }
  .svc-col ul { list-style: none; margin: 0; padding: 0; }
  .svc-col li { padding: 6px 0; border-bottom: 1px solid #f0f0f0; }
  .svc-col li:last-child { border-bottom: none; padding-top: 12px; font-weight: 600; }
  .svc-col a { font-size: 14.5px; color: var(--text); text-decoration: none; transition: color .15s, padding-left .15s; display: block; }
  .svc-col a:hover { color: var(--red); padding-left: 4px; }

  /* ─── County → branch → cities hierarchy ─── */
  .county-block { margin-top: 48px; }
  .county-block:first-of-type { margin-top: 24px; }

  .county-heading {
    display: inline-flex;
    align-items: baseline;
    gap: 10px;
    font-size: 18px;
    font-weight: 700;
    color: var(--text);
    text-decoration: none;
    padding-bottom: 12px;
    margin-bottom: 24px;
    border-bottom: 2px solid var(--red);
    transition: color .15s;
  }
  .county-heading:hover { color: var(--red); }
  .county-count {
    font-size: 13px;
    font-weight: 500;
    color: var(--muted);
    letter-spacing: .02em;
  }
  .county-arrow {
    font-size: 14px;
    color: var(--red);
    margin-left: 4px;
  }

  .county-branch {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 32px;
    padding: 24px 0;
    border-bottom: 1px solid var(--border);
  }
  .county-branch:last-child { border-bottom: none; }

  .branch-nap-wrap {
    background: var(--gray);
    border-radius: 8px;
    padding: 20px 22px;
  }

  .branch-cities-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 4px 18px;
    align-content: start;
  }
  .city-link {
    padding: 6px 0;
    font-size: 14.5px;
    color: var(--text);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: color .15s, border-bottom-color .15s;
  }
  .city-link:hover {
    color: var(--red);
    border-bottom-color: var(--red);
  }

  @media (max-width: 768px) {
    .county-branch {
      grid-template-columns: 1fr;
      gap: 16px;
    }
    .branch-nap-wrap {
      padding: 18px 20px;
    }
  }
  @media (max-width: 640px) {
    .services-cols { grid-template-columns: 1fr; }
    .branch-cities-grid { grid-template-columns: repeat(2, 1fr); }
  }
</style>
