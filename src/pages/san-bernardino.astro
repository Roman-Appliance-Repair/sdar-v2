---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import CustomNarrative from '../components/cities/v2/CustomNarrative.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES, MAIN_PHONE, isPlaceholderPhone } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

const citySlug = 'san-bernardino';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = 'San Bernardino';
const zips = ['92401', '92404', '92405', '92407', '92408', '92410', '92411'];

const phone = branch.phone;
const phoneRaw = `+1${phone.replace(/\D/g, '')}`;

const title = `Appliance Repair San Bernardino CA — Same Day | All Brands | ${phone}`;
const description = `Same-day appliance repair in San Bernardino CA. Refrigerator, washer, dryer, oven, dishwasher & more. Del Rosa, Verdemont, CSUSB area. Licensed. OEM parts. Call ${phone}.`;
const canonical = 'https://samedayappliance.repair/san-bernardino/';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { '@type': 'City', name: 'San Bernardino', sameAs: 'https://en.wikipedia.org/wiki/San_Bernardino,_California' },
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$',
  license: 'CA CSLB #1138898'

};

const introParagraphs = [
  "San Bernardino is the largest city in the IE and the county seat of San Bernardino County — the largest county by land area in the contiguous United States. It's also one of the most diverse cities we service, with housing stock that spans from 1940s bungalows in Del Rosa and Arrowhead Farms to newer development in Verdemont and the university corridor near CSUSB. That housing diversity creates a service profile unlike any other city in the county.",
  "The oldest neighborhoods in San Bernardino — Del Rosa, Muscoy, the Baseline Street corridor — have 1950s and '60s homes with appliances that have been replaced once or twice since original construction. A significant share of the calls we make in these neighborhoods are for older Whirlpool, GE, and Maytag machines that are 15–25 years old and still fundamentally sound. We approach these differently than newer appliance calls: the first question is always whether the core mechanical components are worth repairing. Usually they are. We tell you honestly when they aren't.",
  "California State University San Bernardino anchors a rental market in the university corridor that creates a specific service dynamic — active occupancy, heavier-than-normal appliance use, and landlords who need issues resolved quickly. We work with both landlords and property managers on priority scheduling for occupied rental properties.",
  "The climate here matches Fontana and the broader IE: 100–108°F summers, dry and dusty conditions, hard water throughout. Condenser coil cleaning every 6 months and dishwasher filter cleaning every 3 months are standard recommendations for San Bernardino homes.",
  `Same-day coverage across all San Bernardino ZIP codes. Call <a href="tel:${phoneRaw}">${phone}</a>.`,
];

const services = [
  { icon: '❄️', name: 'Refrigerator Repair', slug: 'refrigerator' },
  { icon: '🌀', name: 'Washer Repair', slug: 'washer' },
  { icon: '💨', name: 'Dryer Repair', slug: 'dryer' },
  { icon: '🔥', name: 'Oven & Range Repair', slug: 'oven' },
  { icon: '🫧', name: 'Dishwasher Repair', slug: 'dishwasher' },
  { icon: '🍳', name: 'Stove & Cooktop Repair', slug: 'stove' },
  { icon: '🧊', name: 'Freezer Repair', slug: 'freezer' },
  { icon: '🧊', name: 'Ice Maker Repair', slug: 'ice-maker' },
];

const housingNarrative = {
  headline: "San Bernardino's Housing Stock — What We Find in Each Part of the City",
  subSections: [
    {
      title: 'Del Rosa, Arrowhead Farms & North San Bernardino — Historic Stock',
      paragraphs: [
        "Del Rosa and Arrowhead Farms are among the oldest established residential neighborhoods in San Bernardino — primarily homes built in the 1940s, '50s, and '60s. These are solid mid-century construction homes with appliances ranging from 15-year-old replacements to original vintage machines still in service. Whirlpool, GE, Hotpoint, and Maytag dominate. These machines are often worth keeping — mechanical simplicity, strong motors, parts still available for most. A $130 repair on a 1998 GE refrigerator that's cooling properly and has a sound compressor is almost always better economics than a $1,000+ replacement.",
        "We approach repair-versus-replace conversations in this part of San Bernardino differently than newer housing areas. The question isn't the machine's age — it's the condition of its core components. We diagnose before advising, and we don't push replacement on machines worth repairing.",
      ]
    },
    {
      title: 'Verdemont & North Kendall — Newer Development',
      paragraphs: [
        "Verdemont is one of San Bernardino's newer residential areas — hillside development from the 1980s through 2000s with more recent appliance profiles. Samsung, LG, Whirlpool, and KitchenAid from the 2010s are the most common. These are now in the 7–12 year failure window: LG linear inverter start relay failures, Samsung ice maker issues, front-load washer bearing wear. We carry OEM parts for all of these on the truck.",
      ]
    },
    {
      title: 'CSUSB University Corridor — Rental Market',
      paragraphs: [
        "California State University San Bernardino sits in the northwest part of the city, and the surrounding streets have a dense rental market supporting students, faculty, and staff. Appliances in rental units near CSUSB see higher-than-normal use and need service more frequently than owner-occupied homes. We work directly with landlords and property managers throughout this area. When a tenant calls about a broken appliance, we coordinate the scheduling to minimize disruption and aim to close the call the same day we open it.",
      ]
    },
    {
      title: 'Baseline St, Waterman Ave & Central San Bernardino — Mixed Stock',
      paragraphs: [
        "The central corridors of San Bernardino have a consistent mix of mid-century and 1970s–1980s housing alongside apartments and multi-family properties. Appliances here span from older machines worth repairing to newer mid-range units from the 2010s. Hard water is consistent throughout — San Bernardino's municipal water supply has high mineral content, and we include descaling as standard on every dishwasher and ice maker call in this market.",
      ]
    },
    {
      title: 'Climate — Inland Valley Heat and Hard Water',
      paragraphs: [
        "San Bernardino's summers run hot — 100–108°F in July and August, with occasional spikes higher. Condenser coils load up faster in the dry, dusty conditions than in coastal climates. We recommend 6-month coil cleaning for refrigerators throughout San Bernardino, and 5-month intervals for homes near unimproved roads or industrial areas. Dishwasher filter cleaning every 3 months is not optional with San Bernardino County water — it's maintenance. We leave every customer with the right schedule for their specific usage and water quality.",
      ]
    },
  ]
};

const neighborhoods = [
  { name: 'Del Rosa', zip: '92404' },
  { name: 'Verdemont', zip: '92407' },
  { name: 'Arrowhead Farms', zip: '92405' },
  { name: 'University / CSUSB Area', zip: '92407' },
  { name: 'Muscoy', zip: '92405' },
  { name: 'Highland Ave Corridor', zip: '92404' },
  { name: 'Kendall Drive Area', zip: '92407' },
  { name: 'Baseline St Area', zip: '92410' },
  { name: 'E Street Corridor', zip: '92401' },
  { name: 'Waterman Ave', zip: '92408' },
  { name: 'Downtown San Bernardino', zip: '92401' },
  { name: 'North San Bernardino', zip: '92405' },
];

const recentJobs = [
  {
    appliance: 'Whirlpool WTW4855HW top-loader',
    location: 'Del Rosa, 92404',
    quote: "won't agitate, spins fine, 18 years old",
    description: "18-year-old Whirlpool top-loader in a Del Rosa home that the owner had maintained well. No agitation, spin cycle working. Classic transmission shift actuator failure — the actuator dogs had worn down enough that the transmission couldn't engage agitate mode. Checked the motor — solid. Drive belt — intact. Transmission — functional. Just the actuator. Had the OEM part on the truck. Repair: $89 diagnostic + $95 actuator and labor. Owner had been quoted a new machine at $750 by a big-box store. Machine has years left in it.",
    outcome: 'Old Whirlpool top-loaders: simple mechanics, strong motors, worth repairing when the core components are sound.'
  },
  {
    appliance: 'Samsung RF23M8570SR',
    location: 'University area, 92407',
    quote: 'not cooling, 21E error, CSUSB rental property',
    description: "Landlord called — tenant in a CSUSB-area rental reporting warm refrigerator. 21E on Samsung French-door units is a freezer sensor error, but the actual cause here was an iced-over evaporator from a failed defrost heater — the sensor was reading correctly, but the evaporator coil had frosted solid. Replaced the defrost heater assembly with OEM Samsung parts, manually defrosted the coil, confirmed 38°F recovery. Done same afternoon — landlord needed it resolved before the tenant got home from class.",
    outcome: 'Samsung 21E: diagnose the defrost system first. Sensor replacement without finding the root cause is a callback.'
  },
  {
    appliance: 'LG DLEX3700W dryer',
    location: 'Verdemont, 92407',
    quote: 'no heat, thermal fuse blown, Verdemont home',
    description: "LG dryer in a newer Verdemont home, no heat. Confirmed blown thermal fuse. Traced the root cause: 20-foot vent run through the garage wall with a lint trap that had never been cleaned in four years. Cleared the full vent, replaced the thermal fuse and high-limit thermostat as a set (on LG dryers, always replace both together), confirmed airflow at the exterior vent before leaving. Also found the heating element was operating at 85% — borderline. Replaced it while everything was open rather than come back in six months for an element call.",
    outcome: 'LG thermal fuse: replace with the high-limit thermostat as a set. Clear the vent. Confirm airflow at exit.'
  },
  {
    appliance: 'GE GFSS2HCYSS',
    location: 'Baseline St area, 92410',
    quote: 'ice maker not making ice, water dispenser fine, 2012 model',
    description: "12-year-old GE side-by-side, ice maker silent, water dispenser working normally. Isolated to the ice maker inlet valve secondary solenoid — independent failure from the water solenoid. Also found the ice maker mold had significant hard water scale — 12 years of San Bernardino water without descaling. Replaced the inlet valve assembly with OEM GE parts, descaled the ice maker mold thoroughly, adjusted the freezer set point from 0°F to 2°F (was too cold, contributing to fill tube icing risk). Water filter was 26 months old — replaced. Ice production restored same visit.",
    outcome: '12 years of SB County hard water without descaling creates significant ice maker mold scale. Always descale on ice maker calls here.'
  },
];

const whyReasons = [
  {
    iconKey: 'team' as const,
    title: 'We work on older appliances — honestly',
    body: "San Bernardino has more older housing stock than most IE cities, and that means more older appliances worth keeping. We don't have a policy of refusing machines over 10 years old. If the core components are sound and parts are available, we quote the repair honestly and let you decide. We don't push replacement when repair is the right call."
  },
  {
    iconKey: 'shield' as const,
    title: 'Rental property priority',
    body: "CSUSB-area landlords know that a broken appliance in an occupied rental needs same-day attention. We coordinate directly with landlords and tenants, and we treat rental calls with the urgency they deserve. A habitability issue shouldn't wait until tomorrow."
  },
  {
    iconKey: 'parts' as const,
    title: 'Root cause, not just symptoms',
    body: 'A blown thermal fuse means something caused it to blow. A Samsung error code points to a system, not a cause. We find the actual problem before recommending parts — because replacing the symptom without fixing the cause means a callback in 6 weeks.'
  },
  {
    iconKey: 'clock' as const,
    title: 'The $89 diagnostic means something',
    body: 'We look at the actual appliance before quoting. An 18-year-old Whirlpool not agitating could be a $120 actuator or a worn transmission — we find out which before recommending anything. What we quote is what appears on the invoice.'
  },
];

const testimonials = [
  {
    stars: 5,
    text: '"Old Whirlpool washer in our Del Rosa home stopped agitating. Every other company said just replace it. Same Day fixed an actuator for $95. Machine is running perfectly. Really appreciate that they actually tried to fix it instead of selling me a new one."',
    author: '— Diana M., Del Rosa'
  },
  {
    stars: 5,
    text: '"Landlord for two CSUSB-area rentals. Tenant called about a warm fridge — Samsung showing an error code. Same Day was there same afternoon, found a defrost heater failure, fixed it. Done before the tenant got home. Exactly the response I needed."',
    author: '— Robert K., CSUSB area landlord'
  },
  {
    stars: 5,
    text: '"LG dryer in our Verdemont home stopped heating. Tech found a blocked vent AND a blown fuse, replaced both together and cleared the whole 20-foot run. Said replacing just the fuse would blow it again. Very thorough, fair price."',
    author: '— Angela & James T., Verdemont'
  },
];

const pricingTiers = [
  { appliance: 'Refrigerator Repair', range: '$120–$420', note: 'Compressor relay · Coil cleaning · Defrost heater · Fan motor' },
  { appliance: 'Washer Repair', range: '$120–$360', note: 'Drive coupling · Drain pump · Actuator · Bearing' },
  { appliance: 'Dryer Repair', range: '$120–$300', note: 'Thermal fuse + limiter · Heating element · Vent path' },
  { appliance: 'Dishwasher Repair', range: '$89–$340', note: 'Drain pump · Filter · Spray arm · Hard water descaling' },
  { appliance: 'Oven / Range Repair', range: '$130–$380', note: 'Igniter · Bake element · Gas valve · Calibration' },
  { appliance: 'Ice Maker Repair', range: '$120–$260', note: 'Inlet valve · Descaling · Fill tube · Mold' },
  { appliance: 'Condenser Coil Cleaning', range: '$89–$140', note: '6-month interval recommended' },
  { appliance: 'Dryer Vent Cleaning', range: '$89–$140', note: 'Full vent run cleared completely' },
];

const faqs = [
  {
    question: 'Do you offer same-day appliance repair in San Bernardino?',
    answer: `Yes — same-day service is available throughout San Bernardino including Del Rosa, Verdemont, Arrowhead Farms, CSUSB area, and all city neighborhoods. Call ${phone} before noon for same-day scheduling. We cover all San Bernardino ZIP codes without a trip surcharge.`
  },
  {
    question: 'Is it worth repairing an older appliance in San Bernardino?',
    answer: "Very often, yes. San Bernardino has some of the oldest residential housing stock in the IE — homes from the 1950s, '60s, and '70s where older Whirlpool, GE, and Maytag appliances have been running for 15–25 years. These machines are mechanically simpler than modern units with fewer electronics to fail, and they're frequently worth repairing. A 20-year-old Whirlpool Direct Drive with a worn drive coupling costs $120–$140 to fix. A replacement is $700–$900. We tell you honestly which way the math goes after diagnosis."
  },
  {
    question: 'Do you service rental properties near CSUSB?',
    answer: 'Yes. California State University San Bernardino generates significant student rental demand in the surrounding neighborhoods. We work with landlords and property managers throughout the CSUSB corridor and the university area. Rental calls get priority scheduling — a tenant without a working washer or refrigerator is a habitability issue. We coordinate directly with landlords and aim to close every occupied rental call same-day.'
  },
  {
    question: 'What brands do you repair in San Bernardino?',
    answer: "All major brands. San Bernardino's housing stock spans from older Whirlpool, GE, and Maytag in the established neighborhoods to mid-range Samsung, LG, and KitchenAid in renovated or newer builds. Verdemont and the newer North San Bernardino developments have more recent appliances. We carry OEM parts for all generations."
  },
  {
    question: 'What is your diagnostic fee?',
    answer: '$89, applied directly to the repair cost when you proceed. No hidden trip charge to San Bernardino. We quote on-site after diagnosis — what we quote is what appears on the invoice.'
  },
  {
    question: 'Why does my fridge run warm every summer?',
    answer: "San Bernardino sits in the Inland Valley and regularly hits 100–108°F in summer. At those ambient temperatures, refrigerators that were managing fine in spring get pushed past their threshold. Condenser coils in San Bernardino's dry, dusty environment load up faster than coastal cities. We see the summer refrigerator surge start in June and peak in July. Every summer refrigerator call in San Bernardino starts with condenser coil cleaning before anything else."
  },
  {
    question: 'Do you service commercial appliances for San Bernardino businesses?',
    answer: 'Yes. As the county seat of San Bernardino County, the city has significant commercial, government, and institutional activity. We service commercial refrigerators, walk-in coolers, commercial ice machines, and commercial laundry. Call us for commercial pricing.'
  },
];

const nearbyCities = [
  { name: 'Fontana', slug: 'fontana' },
  { name: 'Redlands', slug: 'redlands' },
  { name: 'Loma Linda', slug: 'loma-linda' },
  { name: 'Rancho Cucamonga', slug: 'rancho-cucamonga' },
  { name: 'Ontario', slug: 'ontario' },
  { name: 'Riverside', slug: 'riverside' },
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair"
    headlineCity="San Bernardino"
    subheadline="Same-day service in Del Rosa, Verdemont, Arrowhead Farms, CSUSB area, and throughout the city. All ages of appliances welcome. All brands, OEM parts, licensed."
    zips={zips}
    tier={2}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance Repair in San Bernardino — The County Seat Has Its Own Service Profile"
    paragraphs={introParagraphs}
    bookingTitle="San Bernardino"
    bookingSub="Same-Day Service"
  />

  <ServicesGrid
    cityName={cityName}
    headline="What We Repair in San Bernardino"
    services={services}
  />

  <CustomNarrative
    headline={housingNarrative.headline}
    subSections={housingNarrative.subSections}
    background="white"
  />

  <ServiceArea
    cityName={cityName}
    headline="Neighborhoods We Service in San Bernardino"
    subheadline="We cover all of San Bernardino — from Del Rosa and Arrowhead Farms to Verdemont, CSUSB, and Downtown. No travel surcharge to any San Bernardino ZIP code."
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={[]}
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Repairs in San Bernardino"
    jobs={recentJobs}
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="Why San Bernardino Residents Call Us"
    reasons={whyReasons}
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What San Bernardino Customers Are Saying"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Typical Repair Pricing in San Bernardino"
    subhead="Every repair is quoted on-site after diagnosis. The $89 diagnostic is applied when you proceed."
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="San Bernardino Appliance Repair — FAQ"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby Cities"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Need Appliance Repair in San Bernardino Today?"
    body="Same-day service in Del Rosa, Verdemont, CSUSB area, Baseline St, and all San Bernardino neighborhoods. Old homes or new, we service them all."
  />
</CityLayoutV2>
