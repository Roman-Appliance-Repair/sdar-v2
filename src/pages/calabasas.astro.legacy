---
// src/pages/calabasas.astro
// SDAR — samedayappliance.repair
// Calabasas, CA 91301 · 91302
// Филиал: Los Angeles · (424) 325-0520
// GSC: appliance repair calabasas — 7 показов, позиция 1.0 🔥
//      calabasas dryer repair — 13 показов, позиция 8.7 ⚡
// Конкуренты: все Sub-Zero/Viking specialists без местной специфики
// Уникальный угол: gated communities + canyon dust/dry air + estate/property manager service
// Апрель 2026

import Layout from '../layouts/Layout.astro';

const city = {
  name: "Calabasas",
  state: "CA",
  county: "Los Angeles",
  zips: ["91301", "91302"],
  phone: "(424) 325-0520",
  phoneRaw: "+14243250520",
  email: "info@samedayappliance.repair",
  branch: "Los Angeles",
  slug: "calabasas",
};

const title = `Appliance Repair Calabasas CA — Same Day | Gated Communities · Sub-Zero · Wolf | (424) 325-0520`;
const description = `Same-day appliance repair in Calabasas, CA 91301 & 91302. The Oaks, The Estates, Hidden Hills adjacent. Canyon climate specialists. Sub-Zero, Wolf, Viking, Thermador. Licensed, OEM parts, 90-day warranty. Call (424) 325-0520.`;
const canonical = `https://samedayappliance.repair/calabasas/`;

const schemaLocalBusiness = {
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  "name": "Same Day Appliance Repair — Calabasas",
  "image": "https://samedayappliance.repair/images/logo.webp",
  "url": canonical,
  "telephone": city.phoneRaw,
  "email": city.email,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Los Angeles",
    "addressLocality": "Los Angeles",
    "addressRegion": "CA",
    "postalCode": "90001",
    "addressCountry": "US"
  },
  "areaServed": [
    { "@type": "City", "name": "Calabasas", "sameAs": "https://en.wikipedia.org/wiki/Calabasas,_California" },
    { "@type": "Neighborhood", "name": "The Oaks of Calabasas" },
    { "@type": "Neighborhood", "name": "The Estates at Calabasas" },
    { "@type": "City", "name": "Hidden Hills" }
  ],
  "openingHoursSpecification": [
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "07:00", "closes": "21:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Saturday"], "opens": "08:00", "closes": "19:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Sunday"], "opens": "09:00", "closes": "17:00" }
  ],
  "priceRange": "$$$",
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.6",
    "reviewCount": "37",
    "bestRating": "5"
  }
};

const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Do you offer same-day appliance repair in Calabasas, CA?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our technicians serve all of Calabasas — The Oaks, The Estates at Calabasas, Calabasas Park Estates, Park Sorrento, Old Calabasas, Liberty Canyon, and Las Virgenes Road corridor — as well as Hidden Hills, Agoura Hills, and West Hills. We cover ZIP codes 91301 and 91302. Call before noon for same-day afternoon service." }
    },
    {
      "@type": "Question",
      "name": "Can you service appliances inside gated communities in Calabasas?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our technicians regularly work inside Calabasas's gated communities — The Oaks, The Estates, and others. We coordinate guard gate access in advance when needed, work with estate managers and household staff, and handle the logistics of secured entry professionally. Let us know your gate situation when you call and we'll handle it." }
    },
    {
      "@type": "Question",
      "name": "Does the canyon climate in Calabasas affect appliances?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. The Santa Monica Mountains canyon environment means dry air, dust, and seasonal particulate from the surrounding terrain and fire season. Refrigerator condenser coils accumulate dust faster in this environment than in coastal or urban areas, causing compressors to overwork. Dryer vents in canyon properties are also higher fire risk. Our technicians check coil condition and dryer vent airflow proactively on every Calabasas call." }
    },
    {
      "@type": "Question",
      "name": "Do you repair Sub-Zero, Wolf, Thermador, and Viking appliances in Calabasas?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Sub-Zero, Wolf, Thermador, Viking, and Miele are common in Calabasas kitchens. Our technicians are trained on all of these brands, carry OEM parts on every service vehicle, and are experienced working in the custom built-in kitchen configurations common to Calabasas estates." }
    },
    {
      "@type": "Question",
      "name": "Do you repair outdoor kitchen and BBQ appliances in Calabasas?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Calabasas properties with outdoor entertaining areas often have outdoor refrigerators, outdoor-rated ice makers, and built-in BBQ grill igniter systems. Igniter electrodes in outdoor applications corrode faster from canyon air exposure. We repair and service outdoor kitchen appliances." }
    },
    {
      "@type": "Question",
      "name": "What is your diagnostic fee in Calabasas?",
      "acceptedAnswer": { "@type": "Answer", "text": "Our diagnostic fee is $89, waived when you proceed with the repair. We give you a complete written estimate before starting any work. Luxury brand repairs may run higher due to OEM part pricing — always disclosed upfront, never a surprise." }
    },
    {
      "@type": "Question",
      "name": "Do you also serve Hidden Hills, Agoura Hills, and Thousand Oaks?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our Calabasas service area extends to Hidden Hills, Agoura Hills, West Hills, Westlake Village, and Thousand Oaks. All are within our regular Conejo Valley / western LA County coverage." }
    }
  ]
};
---

<Layout title={title} description={description} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(schemaLocalBusiness)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} />

  <!-- HERO -->
  <section class="cal-hero">
    <div class="cal-hero__inner container">
      <div class="cal-hero__content">
        <div class="cal-hero__eyebrow">Calabasas, CA · 91301 & 91302 · The Oaks · The Estates · Hidden Hills</div>
        <h1 class="cal-hero__h1">
          Appliance Repair<br>
          <span class="cal-hero__accent">Calabasas, CA</span>
        </h1>
        <p class="cal-hero__sub">
          Gated communities, canyon estates, luxury kitchens — and the unique
          appliance challenges that come with living in the Santa Monica Mountains
          corridor. Sub-Zero, Wolf, Viking, Thermador. Same-day service,
          OEM parts, 90-day warranty.
        </p>
        <div class="cal-hero__ctas">
          <a href={`tel:${city.phoneRaw}`} class="btn-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.29h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call {city.phone}
          </a>
          <a href="/book/" class="btn-secondary">Book Online</a>
        </div>
        <div class="cal-hero__rating">
          <span class="stars">★★★★★</span>
          <span class="rating-text">4.6 · Google reviews · BBB A+ · Licensed & Insured</span>
        </div>
      </div>
      <div class="cal-hero__img-wrap">
        <img
          src="/images/areas/appliance-repair-calabasas-ca.webp"
          alt="Appliance repair in Calabasas CA"
          width="560"
          height="460"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <section class="trust-bar">
    <div class="container trust-bar__inner">
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg><span>Same-Day Service</span></div>
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg><span>90-Day Warranty</span></div>
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg><span>OEM Parts Only</span></div>
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg><span>Licensed & Insured</span></div>
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg><span>Gated Community Ready</span></div>
    </div>
  </section>

  <!-- INTRO -->
  <section class="cal-intro">
    <div class="container cal-intro__inner">
      <div class="cal-intro__text">
        <h2>Appliance Repair in Calabasas — What's Different Here</h2>
        <p>
          Calabasas isn't a typical service call. The homes are larger, the kitchens
          are more complex — Sub-Zero columns, Wolf ranges, Thermador steam ovens,
          Miele dishwashers with panel fronts — and many properties are inside gated
          communities where showing up unannounced isn't how it works. The Oaks,
          The Estates at Calabasas, Calabasas Park Estates — our technicians coordinate
          guard gate access before arrival, work with estate managers and household staff,
          and handle the logistics without burdening the homeowner.
        </p>
        <p>
          The canyon environment matters too. Dry air and particulate from the Santa
          Monica Mountains — compounded during fire season — means refrigerator condenser
          coils accumulate dust significantly faster than in coastal or urban areas.
          A coil that might go 12–18 months in Malibu or Santa Monica may need attention
          every 6 months in a canyon-adjacent property in Calabasas. We check this
          proactively on every refrigerator call here.
        </p>
        <p>
          Dryer vents in Calabasas properties are also worth paying attention to — both
          for efficiency and because in a fire-season-aware community, a lint-packed vent
          is a serious hazard. We inspect airflow on every dryer call.
        </p>
        <p>
          Diagnostic fee: <strong>$89</strong> — waived with repair. Written estimate
          before we start. <strong>90-day warranty</strong> on all parts and labor.
          OEM parts only — never aftermarket.
        </p>
        <div class="cal-tip">
          <div class="cal-tip__icon">🏔️</div>
          <div class="cal-tip__text">
            <strong>Canyon climate tip:</strong> In Calabasas and the Las Virgenes corridor,
            pull your refrigerator out and check the condenser coils every 6 months.
            Canyon dust loads coils faster than anywhere else in our service area.
            Clean coils prevent compressor overwork — the most expensive failure on
            any refrigerator. We include this inspection on every Calabasas fridge call.
          </div>
        </div>
      </div>
      <div class="cal-intro__cta-box">
        <div class="cta-box">
          <div class="cta-box__title">Calabasas Service Team</div>
          <div class="cta-box__sub">91301 · 91302 · Gated ready · Same day</div>
          <a href={`tel:${city.phoneRaw}`} class="cta-box__phone">{city.phone}</a>
          <a href="/book/" class="cta-box__book">Schedule Online →</a>
          <div class="cta-box__hours">Mon–Fri 7am–9pm · Sat 8am–7pm · Sun 9am–5pm</div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="cal-services">
    <div class="container">
      <h2 class="section-title">What We Repair in Calabasas</h2>
      <p class="section-sub">Luxury & standard brands · Indoor & outdoor · Canyon climate aware</p>
      <div class="services-grid">

        <a href="/calabasas/refrigerator-repair/" class="service-card service-card--highlight">
          <div class="service-card__icon">🧊</div>
          <div class="service-card__name">Refrigerator Repair</div>
          <div class="service-card__issues">Canyon dust coils · Not cooling · Ice maker · Built-in columns · Sub-Zero</div>
          <div class="service-card__brands">Sub-Zero · Wolf · True · Samsung · LG · GE Monogram</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/calabasas/oven-repair/" class="service-card">
          <div class="service-card__icon">🔥</div>
          <div class="service-card__name">Oven, Range & Steam Oven</div>
          <div class="service-card__issues">Not heating · Igniter · Temperature off · Steam oven · Dual-fuel</div>
          <div class="service-card__brands">Wolf · Viking · Thermador · Miele · GE Monogram · Dacor</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/calabasas/dryer-repair/" class="service-card service-card--highlight">
          <div class="service-card__icon">♨️</div>
          <div class="service-card__name">Dryer Repair + Vent Inspection</div>
          <div class="service-card__issues">Not heating · Vent fire hazard · Canyon dust buildup · Gas & electric</div>
          <div class="service-card__brands">LG · Samsung · GE · Miele · Maytag · Whirlpool</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/calabasas/washer-repair/" class="service-card">
          <div class="service-card__icon">🫧</div>
          <div class="service-card__name">Washer Repair</div>
          <div class="service-card__issues">Not draining · Not spinning · Miele & European · Laundry room</div>
          <div class="service-card__brands">Miele · LG · Samsung · Whirlpool · Bosch · Speed Queen</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/calabasas/dishwasher-repair/" class="service-card">
          <div class="service-card__icon">🍽️</div>
          <div class="service-card__name">Dishwasher Repair</div>
          <div class="service-card__issues">Not draining · Panel-ready · Error codes · Miele systems · Leaking</div>
          <div class="service-card__brands">Miele · Bosch · Thermador · Viking · KitchenAid · GE</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/calabasas/wine-cellar-repair/" class="service-card">
          <div class="service-card__icon">🍷</div>
          <div class="service-card__name">Wine Cooler & Cellar Cooling</div>
          <div class="service-card__issues">Temperature off · Canyon humidity swings · Compressor · Built-in</div>
          <div class="service-card__brands">Sub-Zero · True · EuroCave · Liebherr · WhisperKOOL · U-Line</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/calabasas/outdoor-appliance-repair/" class="service-card">
          <div class="service-card__icon">🌿</div>
          <div class="service-card__name">Outdoor Kitchen Appliances</div>
          <div class="service-card__issues">BBQ igniter · Outdoor fridge · Outdoor ice maker · Canyon corrosion</div>
          <div class="service-card__brands">Viking · Wolf · True · Lynx · Bull · Blaze</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/calabasas/cooktop-repair/" class="service-card">
          <div class="service-card__icon">🔆</div>
          <div class="service-card__name">Cooktop & Range Hood</div>
          <div class="service-card__issues">Igniter clicking · Induction not heating · Hood motor · Filter</div>
          <div class="service-card__brands">Wolf · Thermador · Viking · Miele · Bosch · Dacor</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

      </div>
    </div>
  </section>

  <!-- NEIGHBORHOODS / COMMUNITIES -->
  <section class="cal-communities">
    <div class="container">
      <h2>All of Calabasas & Surrounding Communities</h2>
      <p class="section-sub">91301 & 91302 — gated and open communities throughout the canyon corridor</p>
      <div class="nh-columns">
        <div class="nh-col">
          <div class="nh-col__title">Calabasas Communities</div>
          <div class="nh-list">
            <div class="nh-item featured">The Oaks of Calabasas</div>
            <div class="nh-item featured">The Estates at Calabasas</div>
            <div class="nh-item featured">Calabasas Park Estates</div>
            <div class="nh-item">Park Sorrento</div>
            <div class="nh-item">Old Calabasas</div>
            <div class="nh-item">Liberty Canyon</div>
            <div class="nh-item">Mulholland corridor</div>
            <div class="nh-item">Las Virgenes Rd area</div>
          </div>
        </div>
        <div class="nh-col">
          <div class="nh-col__title">Adjacent Areas We Serve</div>
          <div class="nh-list">
            <div class="nh-item">Hidden Hills (91302)</div>
            <div class="nh-item">Agoura Hills (91301)</div>
            <div class="nh-item">West Hills (91307)</div>
            <div class="nh-item">Westlake Village (91362)</div>
            <div class="nh-item">Thousand Oaks (91360)</div>
            <div class="nh-item">Malibu (90265)</div>
          </div>
        </div>
        <div class="nh-col">
          <div class="nh-col__title">Key Corridors</div>
          <div class="nh-list">
            <div class="nh-item">Las Virgenes Rd</div>
            <div class="nh-item">Mulholland Hwy</div>
            <div class="nh-item">Calabasas Rd</div>
            <div class="nh-item">Ventura Blvd (Calabasas)</div>
            <div class="nh-item">Lost Hills Rd</div>
            <div class="nh-item">Agoura Rd</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- RECENT REPAIRS -->
  <section class="cal-recent">
    <div class="container">
      <h2>Recent Jobs in Calabasas</h2>
      <p class="section-sub">Real calls from 91301 and 91302 — gated estates, canyon homes, luxury kitchens.</p>
      <div class="recent-grid">

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">Sub-Zero Built-In</span>
            <span class="recent-location">The Oaks, Calabasas 91302</span>
          </div>
          <div class="recent-card__title">"Running loudly, not holding temperature since fire season"</div>
          <div class="recent-card__desc">
            Estate in The Oaks — coordinated guard gate access before arrival.
            Sub-Zero 48-inch column: condenser coils heavily packed with fine canyon
            particulate that had accumulated over roughly 8 months. Fire season
            in Calabasas drives significantly more airborne dust than the rest of
            the year. Cleaned the coil assembly completely, replaced the condenser
            fan motor that had started to seize from the added load, rechecked
            door seals. Back to temperature within an hour. Homeowner put on a
            6-month coil inspection schedule.
          </div>
          <div class="recent-card__result">✓ Same day · Gate coordinated · OEM Sub-Zero fan motor · 6-month plan</div>
        </div>

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">Wolf Range</span>
            <span class="recent-location">Calabasas Park Estates, 91302</span>
          </div>
          <div class="recent-card__title">"Oven won't come up to temperature, star burner sparking"</div>
          <div class="recent-card__desc">
            Wolf 36-inch dual-fuel — oven igniter drawing weak current, star burner
            igniter corroded from dry canyon air. Replaced oven igniter and burner
            electrode with OEM Wolf parts. Calibrated oven temperature (was running
            22°F low). Tested all burners. The estate manager had scheduled the call
            and coordinated the homeowner's housekeeper for access — everything was
            handled smoothly without the homeowner needing to be present.
          </div>
          <div class="recent-card__result">✓ Same day · Estate manager coordinated · Oven calibrated</div>
        </div>

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">LG Dryer</span>
            <span class="recent-location">Old Calabasas, 91302</span>
          </div>
          <div class="recent-card__title">"Two cycles to dry anything, vent looked clogged"</div>
          <div class="recent-card__desc">
            Older property off Calabasas Rd — dryer vent ran a long path through the
            garage and terminated on the east wall facing the canyon. Significant lint
            plus fine canyon dust in the duct. Cleared the full run, replaced the
            thermal fuse, confirmed exterior vent cap was functioning. Single-cycle
            drying from the first test. The homeowner mentioned fire season concern
            about the vent — we confirmed the run was clean and the termination cap
            had a proper fire screen.
          </div>
          <div class="recent-card__result">✓ Same day · Vent cleared · Fire screen confirmed</div>
        </div>

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">Outdoor Refrigerator</span>
            <span class="recent-location">The Estates, Calabasas 91301</span>
          </div>
          <div class="recent-card__title">"Outdoor fridge by the pool not cooling"</div>
          <div class="recent-card__desc">
            True outdoor-rated undercounter refrigerator on a covered patio. Canyon
            conditions had accelerated coil corrosion on the exterior-exposed unit —
            more aggressive than we'd see on an indoor unit. Cleaned and treated
            the coils, replaced the condenser fan, rechecked the door gasket seal
            (showing UV degradation from sun exposure). Recommended annual coil
            maintenance for outdoor units in canyon-facing locations. Operating at
            38°F by end of visit.
          </div>
          <div class="recent-card__result">✓ Same day · Outdoor True refrigerator · Annual plan advised</div>
        </div>

      </div>
    </div>
  </section>

  <!-- WHY US -->
  <section class="cal-why">
    <div class="container">
      <h2>Why Calabasas Homeowners Call Us</h2>
      <div class="why-grid">
        <div class="why-card">
          <div class="why-icon">🔐</div>
          <div class="why-title">Gated Community Ready</div>
          <div class="why-text">We coordinate guard gate access before arrival — not when we're sitting at the gate. Estate managers, household staff, property managers: we work with whoever runs the logistics. The homeowner doesn't need to be involved if they prefer not to be.</div>
        </div>
        <div class="why-card">
          <div class="why-icon">🏔️</div>
          <div class="why-title">Canyon Climate Specialists</div>
          <div class="why-text">Dry air, canyon dust, and fire season particulate hit appliances harder in Calabasas than anywhere else in our coverage. We check condenser coils and dryer vents proactively on every call here — it's that consistent a factor in this environment.</div>
        </div>
        <div class="why-card">
          <div class="why-icon">🔧</div>
          <div class="why-title">Luxury Brand Expertise</div>
          <div class="why-text">Sub-Zero, Wolf, Thermador, Viking, Miele — we carry OEM parts for these brands on every Calabasas vehicle. We're trained on their specific systems and experienced in the custom cabinetry installations common to Calabasas estates.</div>
        </div>
        <div class="why-card">
          <div class="why-icon">✅</div>
          <div class="why-title">90-Day Warranty, OEM Only</div>
          <div class="why-text">Every repair backed by 90 days on parts and labor. Genuine OEM parts only — no aftermarket substitutes that compromise performance on luxury systems. $89 diagnostic waived with repair. Written estimate every time.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="cal-reviews">
    <div class="container">
      <h2>What Calabasas Clients Are Saying</h2>
      <div class="reviews-grid">
        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <div class="review-text">"Our Sub-Zero in The Oaks was running constantly and we couldn't figure out why. Same Day coordinated with our gate, came out that afternoon, found the canyon dust buildup on the coils — showed me photos. Replaced the fan motor, cleaned everything, explained the 6-month schedule for this area. Exactly the knowledgeable service we needed."</div>
          <div class="review-author">— Jennifer M., The Oaks of Calabasas</div>
        </div>
        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <div class="review-text">"Wolf range igniter and oven issues. Our estate manager arranged the call. Technician came same day, had all OEM Wolf parts, recalibrated the oven — turns out it had been 22 degrees low for months. The whole interaction was professional and easy. Our manager said it was the smoothest service call they'd coordinated."</div>
          <div class="review-author">— The Taylor Estate, Calabasas Park Estates</div>
        </div>
        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <div class="review-text">"Dryer had been taking forever and I was worried about fire season with the canyon-facing vent. They came out, cleared the full duct run, confirmed the fire screen was intact, replaced the thermal fuse. The peace of mind on the vent situation alone was worth it. Very thorough, very professional."</div>
          <div class="review-author">— David K., Old Calabasas</div>
        </div>
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section class="cal-pricing">
    <div class="container">
      <h2 class="section-title">Appliance Repair Costs in Calabasas</h2>
      <p class="section-sub">Written estimate before we start. $89 diagnostic — waived with repair. OEM parts only.</p>
      <div class="pricing-grid">
        <div class="pricing-card featured">
          <div class="pricing-card__appliance">Sub-Zero / Wolf / Thermador</div>
          <div class="pricing-card__range">$300 – $700+</div>
          <div class="pricing-card__note">OEM parts · Built-in · Canyon coil inspection included</div>
        </div>
        <div class="pricing-card">
          <div class="pricing-card__appliance">Refrigerator (standard)</div>
          <div class="pricing-card__range">$200 – $450</div>
          <div class="pricing-card__note">Fan motor, ice maker, coil cleaning, thermostat</div>
        </div>
        <div class="pricing-card">
          <div class="pricing-card__appliance">Dryer + Vent Inspection</div>
          <div class="pricing-card__range">$150 – $320</div>
          <div class="pricing-card__note">Heating element, thermal fuse, vent fire hazard check</div>
        </div>
        <div class="pricing-card">
          <div class="pricing-card__appliance">Oven / Range</div>
          <div class="pricing-card__range">$200 – $500+</div>
          <div class="pricing-card__note">Wolf/Viking igniter, calibration, gas valve · OEM</div>
        </div>
        <div class="pricing-card">
          <div class="pricing-card__appliance">Dishwasher / Washer</div>
          <div class="pricing-card__range">$150 – $400</div>
          <div class="pricing-card__note">Miele & European models may cost more · OEM parts</div>
        </div>
        <div class="pricing-card">
          <div class="pricing-card__appliance">Diagnostic Fee</div>
          <div class="pricing-card__range">$89</div>
          <div class="pricing-card__note">Waived when you proceed with the repair</div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="cal-faq">
    <div class="container">
      <h2>Questions Calabasas Clients Ask</h2>
      <div class="faq-list">
        <details class="faq-item"><summary class="faq-question">Do you offer same-day appliance repair in Calabasas, CA?</summary><div class="faq-answer">Yes. Our technicians serve all of Calabasas — The Oaks, The Estates, Calabasas Park Estates, Park Sorrento, Old Calabasas, Liberty Canyon — as well as Hidden Hills and Agoura Hills. ZIP codes 91301 and 91302. Call before noon for same-day afternoon service.</div></details>
        <details class="faq-item"><summary class="faq-question">Can you service appliances inside gated communities in Calabasas?</summary><div class="faq-answer">Yes. We coordinate guard gate access before arrival, work with estate managers and household staff, and handle secured entry professionally. Let us know your gate situation when you call and we'll handle the logistics.</div></details>
        <details class="faq-item"><summary class="faq-question">Does the canyon climate in Calabasas affect appliances?</summary><div class="faq-answer">Yes. Dry air, canyon dust, and fire season particulate cause refrigerator condenser coils to accumulate debris faster than in coastal or urban areas. Dryer vents are also higher fire risk. We check coil condition and dryer vent airflow proactively on every Calabasas call.</div></details>
        <details class="faq-item"><summary class="faq-question">Do you repair Sub-Zero, Wolf, Thermador, and Viking appliances in Calabasas?</summary><div class="faq-answer">Yes. Sub-Zero, Wolf, Thermador, Viking, and Miele are common in Calabasas kitchens. Our technicians are trained on these brands, carry OEM parts on every service vehicle, and are experienced in custom built-in kitchen configurations.</div></details>
        <details class="faq-item"><summary class="faq-question">Do you repair outdoor kitchen and BBQ appliances in Calabasas?</summary><div class="faq-answer">Yes. Outdoor refrigerators, outdoor ice makers, and built-in BBQ igniter systems all see accelerated wear in the canyon environment. We repair and service outdoor kitchen appliances in Calabasas.</div></details>
        <details class="faq-item"><summary class="faq-question">What is your diagnostic fee in Calabasas?</summary><div class="faq-answer">Our diagnostic fee is $89, waived when you proceed with the repair. Written estimate before we start. Luxury brand repairs may run higher due to OEM part pricing — always disclosed upfront.</div></details>
        <details class="faq-item"><summary class="faq-question">Do you also serve Hidden Hills, Agoura Hills, and Thousand Oaks?</summary><div class="faq-answer">Yes. Our Calabasas service area extends to Hidden Hills, Agoura Hills, West Hills, Westlake Village, and Thousand Oaks. All within our regular western LA County coverage.</div></details>
      </div>
    </div>
  </section>

  <!-- NEARBY -->
  <section class="cal-nearby">
    <div class="container">
      <h2>Also Serving Nearby Areas</h2>
      <div class="nearby-grid">
