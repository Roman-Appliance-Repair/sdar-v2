---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import CustomNarrative from '../components/cities/v2/CustomNarrative.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES, MAIN_PHONE, isPlaceholderPhone } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

const citySlug = 'oak-park';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = 'Oak Park';
const zips = ['91377'];

const phone = branch.phone;
const phoneRaw = `+1${phone.replace(/\D/g, '')}`;

const title = `Appliance Repair Oak Park CA | Same Day Service | ${phone}`;
const description = 'Same-day appliance repair in Oak Park, CA. Conejo foothills community. All brands, OEM parts, 90-day warranty. No surcharge vs Thousand Oaks. $89 diagnostic — waived with repair.';
const canonical = 'https://samedayappliance.repair/oak-park/';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { '@type': 'Place', name: 'Oak Park' },
    { '@type': 'Place', name: 'Lindero Canyon' },
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$',
  license: 'CA CSLB #1138898'

};

const introParagraphs = [
  "Oak Park is an unincorporated community tucked into the Conejo foothills between Agoura Hills and Thousand Oaks. Our Thousand Oaks branch covers this corridor every day — Oak Park isn't a detour that requires a surcharge. It's where we work.",
  "The community is predominantly established family homes from the 1970s and 80s with good-quality appliance installations. Samsung, LG, KitchenAid, Whirlpool, and Bosch are the brands we see most often. For LG refrigerators in the 5-8 year range, we always check linear compressor warranty coverage before quoting a full repair — a significant portion of calls in that age range are still under LG's extended warranty, which changes the cost equation significantly.",
  `Diagnostic fee is $89, the same as in Thousand Oaks or Westlake Village. No distance markup. Call <a href="tel:${phoneRaw}">${phone}</a>.`,
];

const services = [
  { icon: '❄️', name: 'Refrigerator Repair', slug: 'refrigerator' },
  { icon: '🫧', name: 'Washer Repair', slug: 'washer' },
  { icon: '💨', name: 'Dryer Repair', slug: 'dryer' },
  { icon: '🍽️', name: 'Dishwasher Repair', slug: 'dishwasher' },
  { icon: '🔥', name: 'Oven & Range Repair', slug: 'oven' },
  { icon: '♨️', name: 'Cooktop Repair', slug: 'cooktop' },
  { icon: '🧊', name: 'Freezer Repair', slug: 'freezer' },
  { icon: '🍷', name: 'Wine Cooler Repair', slug: 'wine-cooler' },
];

const lgWarrantyNarrative = {
  headline: 'One Thing Worth Knowing: LG Compressor Warranty',
  paragraphs: [
    "Oak Park has a lot of LG appliances — the brand was very popular when most of the community's homes were last kitchen-renovated. If you have an LG French door refrigerator that's stopped cooling and it's between 5 and 10 years old, the first thing we check is warranty coverage.",
    "LG extended its linear compressor warranty to 10 years on affected model years following class action settlements. Many homeowners don't know this. A full linear compressor replacement out of warranty runs $400-600+ in parts alone. Under warranty, the homeowner pays diagnostic and labor only — a significant difference. We check coverage on every LG compressor call in Oak Park as a matter of course, before we quote anything.",
    'The same principle applies to Samsung ice maker wire harness failures in the 3-5 year range — we check what coverage exists before starting. It costs us a few minutes and can save you hundreds.',
  ]
};

const neighborhoods = [
  { name: 'Oak Park proper', zip: '91377' },
  { name: 'Lindero Canyon area', zip: '91377' },
  { name: 'Medea Creek area', zip: '91377' },
  { name: 'Kanan Road corridor', zip: '91377' },
  { name: 'Chesebro Road area', zip: '91377' },
  { name: 'Oak Canyon area', zip: '91377' },
];

const recentJobs = [
  {
    appliance: 'LG Refrigerator',
    location: 'Oak Park',
    quote: 'LG refrigerator — not cooling, linear compressor failure',
    description: 'LG LRMVS3006S — not cooling at all, compressor not running. Linear compressor failure — the most common significant repair on LG French door refrigerators in the 5-7 year range. Replaced the compressor assembly with an OEM LG part under LG\'s extended compressor warranty (this model year was covered). Cost to homeowner was the diagnostic and labor only. Always worth checking warranty coverage on LG linear compressor failures before quoting a full repair — a significant portion of calls in this age range are still covered.',
    outcome: '✓ LG OEM linear compressor (warranty covered) · 3 hours'
  },
  {
    appliance: 'KitchenAid Oven',
    location: 'Lindero Canyon area',
    quote: "KitchenAid oven — oven not heating, broil works but bake doesn't",
    description: "KitchenAid KFGG500ESS — broil element functional, bake element completely failed. Classic single-element failure. Replaced the bake element with an OEM KitchenAid part, tested all oven modes including convection. Also checked the door gasket — slight compression loss beginning at the lower corners, flagged for the homeowner as a 6-12 month replacement item. The door seal affects temperature accuracy and efficiency; better to know early.",
    outcome: '✓ KitchenAid OEM bake element · 1.5 hours'
  },
  {
    appliance: 'Whirlpool Washer',
    location: 'Medea Creek area',
    quote: 'Whirlpool washer — F21 drain error, standing water after cycle',
    description: 'Whirlpool WFW5000FW — F21 drain fault, water in the drum at cycle end. Coin trap filter packed with lint, a small sock, and three quarters — completely blocking the drain pump. Cleaned the filter and pump impeller housing, confirmed the impeller was undamaged, ran three drain cycles. Showed the homeowner the filter location and the quarterly cleaning procedure. Simple, common, 100% preventable with routine maintenance.',
    outcome: '✓ Filter cleaning service · 45 minutes'
  },
  {
    appliance: 'Samsung Dishwasher',
    location: 'Kanan Road corridor',
    quote: 'Samsung dishwasher — LC error, leak detected',
    description: "Samsung DW80R9950UG — LC leak sensor error, anti-flood device activated. Water in the base tray from a slow leak at the door gasket lower seal. Replaced the door gasket with an OEM Samsung part, cleared and dried the base tray, reset the leak sensor, ran six test cycles monitoring for any seepage. The gasket had developed a small crack — more common in the 3-5 year range on this Samsung line than the manufacturer's published data suggests.",
    outcome: '✓ Samsung OEM door gasket · 2 hours'
  },
];

const whyReasons = [
  {
    iconKey: 'parts' as const,
    title: 'We check warranty first',
    body: 'LG linear compressor, Samsung harness, other covered failures — we verify warranty coverage before quoting. One call can save hundreds.'
  },
  {
    iconKey: 'team' as const,
    title: 'No surcharge',
    body: 'Oak Park is on our route. The $89 diagnostic is flat, same as Thousand Oaks or Westlake Village. No distance fee, no travel markup.'
  },
  {
    iconKey: 'shield' as const,
    title: 'We teach maintenance',
    body: "Washer drain filter location, dishwasher descaling schedule, refrigerator coil cycle — we show you what needs attention before we leave so you don't call us back for the same thing."
  },
  {
    iconKey: 'clock' as const,
    title: '90-day warranty',
    body: 'Every repair in Oak Park carries a 90-day warranty on parts and labor. Same issue returns — we come back at no charge.'
  },
];

const testimonials = [
  {
    stars: 5,
    text: '"LG fridge stopped cooling — they checked warranty coverage first, found it was covered, replaced the compressor for just the labor cost. Saved us over $400. That kind of honesty is rare in any service industry."',
    author: '— Robert M., Oak Park'
  },
  {
    stars: 5,
    text: '"Whirlpool washer drain error. They cleared the filter in 45 minutes, showed me where it is and how to clean it quarterly. No parts needed. Transparent, fast, done right."',
    author: '— Jennifer K., Medea Creek area'
  },
  {
    stars: 5,
    text: '"KitchenAid oven, bake element failed. Fixed same day, no surcharge for Oak Park vs Thousand Oaks. Exactly what was promised. Will use again."',
    author: '— Sandra T., Lindero Canyon'
  },
];

const pricingTiers = [
  { appliance: 'Diagnostic Fee', range: '$89', note: 'Same as Thousand Oaks · No surcharge · Warranty check included' },
  { appliance: 'Standard Repair', range: '$150–$380', note: 'Parts + labor · OEM parts · 90-day warranty' },
  { appliance: 'Luxury Brand Repair', range: '$250–$600+', note: 'Sub-Zero, Wolf, Thermador · OEM parts' },
  { appliance: 'Warranty', range: '90 Days', note: 'All repairs · Parts & labor · No-charge callback', featured: true },
];

const faqs = [
  {
    question: 'Do you offer same-day appliance repair in Oak Park?',
    answer: 'Yes — Oak Park is part of our Thousand Oaks branch service area. Our technicians run the Conejo Valley corridor regularly and cover Oak Park on the same routes as Agoura Hills and Newbury Park. Call before noon for same-day service in most cases.'
  },
  {
    question: 'What is your diagnostic fee in Oak Park?',
    answer: 'Our diagnostic fee is $89 — the same as in Thousand Oaks and Newbury Park. There is no distance surcharge or travel fee for Oak Park. $89 diagnostic, credited toward the repair if you proceed.'
  },
  {
    question: 'Is there a surcharge for service in Oak Park vs Thousand Oaks?',
    answer: 'No. Oak Park is within our standard Thousand Oaks branch service territory. The $89 diagnostic fee is flat regardless of where in the Conejo Valley corridor you are.'
  },
  {
    question: 'What appliance brands do you repair in Oak Park?',
    answer: 'All major brands: Samsung, LG, GE, Whirlpool, KitchenAid, Bosch, Maytag, Frigidaire, and luxury brands including Sub-Zero, Wolf, and Thermador. OEM parts for all of these on our Conejo Valley trucks.'
  },
  {
    question: 'Does Oak Park have any specific appliance maintenance concerns?',
    answer: 'Oak Park is served by local water with moderate mineral content. Like the rest of the Conejo Valley, dishwasher spray arms and refrigerator water filters benefit from regular attention. The Conejo foothills setting also means seasonal winds can carry particulate into outdoor-adjacent appliance vents — dryer vent inspection is worth doing annually.'
  },
  {
    question: 'Do you check LG linear compressor warranty coverage in Oak Park?',
    answer: "Yes. LG extended its linear compressor warranty on affected models to 10 years. If you have an LG refrigerator that's not cooling and is in the 5-8 year range, it's worth a warranty check before paying for a full compressor replacement. We verify coverage as part of every LG compressor diagnosis."
  },
  {
    question: 'Do you offer a warranty on repairs in Oak Park?',
    answer: 'All repairs include a 90-day warranty on parts and labor. Same issue returns within 90 days — we come back at no charge.'
  },
];

const nearbyCities = [
  { name: 'Agoura Hills', slug: 'agoura-hills' },
  { name: 'Thousand Oaks', slug: 'thousand-oaks' },
  { name: 'Westlake Village', slug: 'westlake-village' },
  { name: 'Newbury Park', slug: 'newbury-park' },
  { name: 'Moorpark', slug: 'moorpark' },
  { name: 'Calabasas', slug: 'calabasas' },
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair in"
    headlineCity="Oak Park, CA"
    subheadline="Same-day service from our Thousand Oaks branch — no surcharge. All brands, OEM parts, 90-day warranty. $89 diagnostic — waived with repair."
    zips={zips}
    tier={3}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance Repair in Oak Park — On Our Route, Same Price"
    paragraphs={introParagraphs}
    bookingTitle="Oak Park Service"
    bookingSub="Available Today"
  />

  <ServicesGrid
    cityName={cityName}
    headline="Appliance Repair Services in Oak Park"
    services={services}
  />

  <CustomNarrative
    headline={lgWarrantyNarrative.headline}
    paragraphs={lgWarrantyNarrative.paragraphs}
    background="white"
  />

  <ServiceArea
    cityName={cityName}
    headline="Oak Park Areas We Service"
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={[]}
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Repairs in Oak Park"
    jobs={recentJobs}
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="Why Oak Park Residents Call Us"
    reasons={whyReasons}
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What Oak Park Clients Say"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Repair Pricing in Oak Park"
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="Frequently Asked Questions — Oak Park"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby Conejo Valley Cities"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Schedule Your Oak Park Repair Today"
    body="Same-day service from our Thousand Oaks branch. No surcharge. All brands."
  />
</CityLayoutV2>
