---
// src/pages/blog/index.astro
// Wave 25c — Blog landing page (greenfield).
// Featured articles + category nav + ItemList schema for article inventory.
import Layout from '../../layouts/Layout.astro';

const title = "Appliance Repair Blog | Same Day Appliance Repair Los Angeles";
const description = "Repair tips, maintenance guides, brand-specific knowledge from LA appliance repair technicians. Field observations. $89 / $120 diagnostic.";
const canonical = "https://samedayappliance.repair/blog/";

const articles = [
  {
    slug: "repair-vs-replace-refrigerator-la-guide",
