---
// src/pages/blog/index.astro
// Wave 25c — Blog landing page (greenfield).
// Featured articles + category nav + ItemList schema for article inventory.
import Layout from '../../layouts/Layout.astro';

const title = "Appliance Repair Blog | Same Day Appliance Repair Los Angeles";
const description = "Repair tips, maintenance guides, and brand-specific knowledge from LA appliance repair technicians. Honest answers, field observations, $89 residential / $120 commercial diagnostic.";
const canonical = "https://samedayappliance.repair/blog/";

const articles = [
  {
    slug: "repair-vs-replace-refrigerator-la-guide",
    title: "When to Repair vs Replace Your Refrigerator: A Honest Guide for LA Homeowners",
    excerpt: "Year-pattern decision tree, premium vs mid-tier service-life math, the 50% rule, and what LADWP hard water does to your ice maker. From SDAR field technicians.",
    category: "Repair Tips",
    date: "2026-05-04",
    readingTime: "8 min read",
    featured: true,
  },
  {
    slug: "why-dryer-takes-2-hours-diagnosis-guide",
    title: "Why Your Dryer Is Taking 2 Hours: Diagnosis Guide from LA Repair Techs",
    excerpt: "Vent obstruction is the #1 cause; heating element failure, thermostat drift, and drum bearings cover the rest. Field observations and what to check yourself.",
    category: "Diagnosis",
    date: "2026-05-04",
    readingTime: "7 min read",
    featured: true,
  },
  {
    slug: "la-hard-water-killing-dishwasher",
    title: "Hard Water in LA Is Killing Your Dishwasher: Here's What to Do",
    excerpt: "LADWP at 5-9 grains, Calleguas at 8-14. What scale buildup does to heating elements and spray arms, the annual descale routine, and which brands tolerate hard water best.",
    category: "Maintenance",
    date: "2026-05-04",
    readingTime: "6 min read",
    featured: true,
  },
];

const categories = [
  { name: "Repair Tips", count: 1 },
  { name: "Diagnosis", count: 1 },
  { name: "Maintenance", count: 1 },
];

const itemListSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Same Day Appliance Repair Blog",
  "description": "Repair tips, diagnosis guides, maintenance and brand articles from LA technicians.",
  "numberOfItems": articles.length,
  "itemListElement": articles.map((a, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "name": a.title,
    "url": `https://samedayappliance.repair/blog/${a.slug}/`,
  })),
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": canonical },
  ],
};
---

<Layout title={title} description={description}>

<Fragment slot="head-scripts">
  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Fragment>

<section class="hero">
  <div class="container">
    <p class="eyebrow">SDAR Blog · Field-Level Knowledge from LA Appliance Repair</p>
    <h1>Honest answers from the techs who do the work.</h1>
    <p class="hero-sub">Repair tips, diagnosis guides, and maintenance routines written by the field technicians who service appliances across LA, OC, Ventura, San Bernardino, and Riverside counties. No marketing fluff, no sales-funnel tricks. The actual answers we give customers on the phone.</p>
  </div>
</section>

<section class="categories">
  <div class="container">
    <p class="section-label">Browse by category</p>
    <div class="cat-row">
      {categories.map(c => (
        <span class="cat-chip">{c.name} · {c.count}</span>
      ))}
    </div>
  </div>
</section>

<section class="articles">
  <div class="container">
    <p class="section-label">Latest articles</p>
    <h2>Featured posts</h2>
    <div class="articles-grid">
      {articles.map(a => (
        <a href={`/blog/${a.slug}/`} class="article-card">
          <p class="article-cat">{a.category}</p>
          <h3>{a.title}</h3>
          <p class="article-excerpt">{a.excerpt}</p>
          <p class="article-meta">
            <span>{new Date(a.date).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</span>
            <span class="meta-sep">·</span>
            <span>{a.readingTime}</span>
          </p>
        </a>
      ))}
    </div>
  </div>
</section>

<section class="cta-block">
  <div class="container narrow">
    <h2>Need a repair right now?</h2>
    <p>$89 residential diagnostic · $120 commercial diagnostic · Same-day across LA, OC, Ventura · BHGS Licensed #A49573 · EPA 608 Universal certified · BBB A+.</p>
    <div class="cta-row">
      <a href="tel:+14243250520" class="btn-red">☎ Call (424) 325-0520</a>
      <a href="/contact/" class="btn-outline">Book Online</a>
    </div>
  </div>
</section>

</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .hero { background: var(--black); color: #fff; padding: 80px 24px 64px; }
  .container { max-width: 1100px; margin: 0 auto; }
  .container.narrow { max-width: 820px; }
  .eyebrow { font-size: 12px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--red); margin: 0 0 14px; }
  h1 { font-size: clamp(32px, 4.5vw, 48px); font-weight: 800; line-height: 1.1; margin: 0 0 18px; letter-spacing: -0.02em; color: #fff; max-width: 800px; }
  .hero-sub { font-size: 17px; color: rgba(255,255,255,.72); line-height: 1.65; max-width: 720px; margin: 0; }

  .categories { background: var(--gray); padding: 32px 24px; border-bottom: 1px solid var(--border); }
  .section-label { font-size: 12px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--red); margin: 0 0 12px; }
  .cat-row { display: flex; flex-wrap: wrap; gap: 10px; }
  .cat-chip { background: #fff; border: 1px solid var(--border); border-radius: 16px; padding: 7px 16px; font-size: 13px; font-weight: 600; color: var(--text); }

  .articles { padding: 56px 24px; background: #fff; }
  .articles h2 { font-size: clamp(24px, 3vw, 32px); font-weight: 800; margin: 0 0 28px; color: var(--text); letter-spacing: -0.01em; }
  .articles-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 22px; }
  .article-card { display: flex; flex-direction: column; background: #fff; border: 1px solid var(--border); border-radius: 10px; padding: 28px 26px; text-decoration: none; color: var(--text); transition: border-color .2s, transform .2s, box-shadow .2s; }
  .article-card:hover { border-color: var(--red); transform: translateY(-3px); box-shadow: 0 6px 18px rgba(0,0,0,.06); }
  .article-cat { font-size: 11px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--red); margin: 0 0 12px; }
  .article-card h3 { font-size: 19px; font-weight: 800; line-height: 1.3; margin: 0 0 14px; color: var(--text); letter-spacing: -0.01em; }
  .article-excerpt { font-size: 14px; line-height: 1.65; color: var(--muted); margin: 0 0 18px; flex: 1; }
  .article-meta { font-size: 12px; color: var(--muted); margin: 0; display: flex; gap: 8px; align-items: center; }
  .article-meta .meta-sep { color: rgba(0,0,0,.2); }

  .cta-block { background: var(--red); color: #fff; padding: 56px 24px; text-align: center; }
  .cta-block h2 { font-size: clamp(22px, 3vw, 28px); font-weight: 800; color: #fff; margin: 0 0 14px; }
  .cta-block p { font-size: 15px; color: rgba(255,255,255,.92); margin: 0 0 26px; }
  .cta-row { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; }
  .btn-red { background: #fff; color: var(--red); padding: 14px 28px; border-radius: 6px; font-weight: 700; text-decoration: none; }
  .btn-outline { background: transparent; color: #fff; padding: 14px 28px; border-radius: 6px; border: 2px solid rgba(255,255,255,.55); font-weight: 600; text-decoration: none; }
</style>
