    category: "Maintenance",
    date: "2026-05-05",
    readingTime: "6 min read",
  },
  {
    slug: "premium-vs-mid-tier-refrigerator-15-year-tco",
    title: "Premium vs Mid-Tier Refrigerator: Total Cost of Ownership over 15 Years",
