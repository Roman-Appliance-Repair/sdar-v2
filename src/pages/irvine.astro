<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair"
    headlineCity="Irvine, CA"
    subheadline="Irvine's master-planned communities, HOA requirements, and tech-forward homes call for a service company that knows the city. Local Irvine branch, same-day service, HOA-compliant, OEM parts, 90-day warranty. All communities covered."
    zips={zips}
    tier={1}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance Repair in Irvine — Built for This City"
    paragraphs={introParagraphs}
    bookingTitle="Irvine Local Branch"
    bookingSub="All communities · HOA-ready"
  />

  <ServicesGrid
    cityName={cityName}
    headline="What We Repair in Irvine"
    services={services}
  />

  <CustomNarrative
    headline={communitiesNarrative.headline}
    paragraphs={communitiesNarrative.paragraphs}
    subSections={communitiesNarrative.subSections}
    background="gray"
  />

  <ServiceArea
    cityName={cityName}
    headline="Irvine Communities We Serve"
    subheadline="Every neighborhood across all six ZIP codes."
