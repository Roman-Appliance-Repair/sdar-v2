const citySlug = 'irvine';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = 'Irvine';
const zips = ['92602', '92604', '92606', '92612', '92618', '92620'];

const title = `Appliance Repair Irvine CA — Same Day | Shady Canyon · Woodbridge · Great Park | ${branch.phone}`;
const description = `Same-day appliance repair in Irvine, CA. All communities — Woodbridge, Turtle Rock, Northpark, Shady Canyon, Great Park, Orchard Hills. HOA-compliant service. Sub-Zero, Wolf, Samsung, LG. Licensed, OEM parts, 90-day warranty. Call ${branch.phone}.`;
const canonical = 'https://samedayappliance.repair/irvine/';

const phoneRaw = `+1${branch.phone.replace(/\D/g, '')}`;

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  // streetAddress omitted: Irvine is service_area.
  areaServed: [
    { '@type': 'City', name: 'Irvine', sameAs: 'https://en.wikipedia.org/wiki/Irvine,_California' },
    { '@type': 'Place', name: 'Woodbridge' },
    { '@type': 'Place', name: 'Shady Canyon' },
    { '@type': 'Place', name: 'Turtle Rock' },
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$',
  license: 'CA BHGS #A49573'

};

