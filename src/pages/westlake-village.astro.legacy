---
// src/pages/westlake-village.astro
// SDAR — samedayappliance.repair
// Westlake Village, CA · 91361 · 91362
// Филиал: Thousand Oaks · (424) 208-0228
// GSC: appliance repair westlake village — 7 показов, позиция 30
// Конкуренты: A&Y Appliances (strong — LVMWD, lakeside, Sub-Zero, 39 repairs data),
//             InstaFix (3835 E TO Blvd, WLV 91362, local physical address, 31yr),
//             Krupo/Rodeo (Sub-Zero brand-specific)
// Уникальный угол: lake community identity (Westlake Lake / Lake Sherwood) +
//                  LVMWD hard water (200-250 mg/L) + luxury lakeside estates +
//                  Conejo dry climate dust (shared с TO) + gated communities
// Апрель 2026

import Layout from '../layouts/Layout.astro';

const city = {
  name: "Westlake Village",
  state: "CA",
  county: "Los Angeles / Ventura",
  zips: ["91361", "91362"],
  phone: "(424) 208-0228",
  phoneRaw: "+14242080228",
  email: "thousandoaks@samedayappliance.repair",
  branch: "Thousand Oaks",
  slug: "westlake-village",
};

const title = `Appliance Repair Westlake Village CA — Same Day | Lake Sherwood · Westlake Lake · Gated Estates | (424) 208-0228`;
const description = `Same-day appliance repair in Westlake Village, CA 91361 & 91362. Lakeside estates, gated communities, all neighborhoods. Sub-Zero, Wolf, Thermador, Miele, Samsung, LG. Licensed, OEM parts, 90-day warranty. Call (424) 208-0228.`;
const canonical = `https://samedayappliance.repair/westlake-village/`;

const schemaLocalBusiness = {
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  "name": "Same Day Appliance Repair — Westlake Village",
  "image": "https://samedayappliance.repair/images/logo.webp",
  "url": canonical,
  "telephone": city.phoneRaw,
  "email": city.email,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Thousand Oaks",
    "addressRegion": "CA",
    "postalCode": "91360",
    "addressCountry": "US"
  },
  "areaServed": [
    { "@type": "City", "name": "Westlake Village", "sameAs": "https://en.wikipedia.org/wiki/Westlake_Village,_California" }
  ],
  "openingHoursSpecification": [
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "07:00", "closes": "21:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Saturday"], "opens": "08:00", "closes": "19:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Sunday"], "opens": "09:00", "closes": "17:00" }
  ],
  "priceRange": "$$$",
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.6",
    "reviewCount": "37",
    "bestRating": "5"
  }
};

const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Do you offer same-day appliance repair in Westlake Village, CA?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our Thousand Oaks branch covers all of Westlake Village — lakeside communities around Westlake Lake, Lake Sherwood estates, North Ranch, the Promenade area, and all ZIP codes 91361 and 91362. Call before noon for same-day afternoon service." }
    },
    {
      "@type": "Question",
      "name": "Does the Las Virgenes water in Westlake Village affect appliances?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Westlake Village is served by Las Virgenes Municipal Water District at approximately 200–250 mg/L hardness. Ice maker inlet valves and dishwasher spray arms accumulate mineral deposits faster than in soft-water cities. We test for this proactively on every relevant Westlake Village call involving ice makers and dishwashers." }
    },
    {
      "@type": "Question",
      "name": "Do you repair Sub-Zero, Wolf, Thermador, and Miele appliances in Westlake Village?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Sub-Zero, Wolf, Thermador, Miele, and Viking are standard throughout Westlake Village's lakeside and estate homes. Our technicians carry OEM parts for these brands on every service vehicle." }
    },
    {
      "@type": "Question",
      "name": "Can you service appliances in Westlake Village's gated communities?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Westlake Village has several gated communities with guard gate access. We coordinate entry in advance and work with property managers and estate staff as needed." }
    },
    {
      "@type": "Question",
      "name": "Are you available on weekends in Westlake Village?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Saturday 8am–7pm and Sunday 9am–5pm." }
    },
    {
      "@type": "Question",
      "name": "What is your diagnostic fee in Westlake Village?",
      "acceptedAnswer": { "@type": "Answer", "text": "Our diagnostic fee is $89, waived when you proceed with the repair. Written estimate before we start. Most Westlake Village repairs run $150–$500 depending on brand and appliance." }
    },
    {
      "@type": "Question",
      "name": "Do you also serve Thousand Oaks, Calabasas, and Agoura Hills?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our Westlake Village service extends to Thousand Oaks, Calabasas, Agoura Hills, Oak Park, Newbury Park, and all of the Conejo Valley." }
    }
  ]
};
---

<Layout title={title} description={description} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(schemaLocalBusiness)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} />

  <!-- HERO -->
  <section class="wv-hero">
    <div class="wv-hero__inner container">
      <div class="wv-hero__content">
        <div class="wv-hero__eyebrow">Westlake Village, CA · 91361 & 91362 · Westlake Lake · Lake Sherwood · North Ranch</div>
        <h1 class="wv-hero__h1">
          Appliance Repair<br>
          <span class="wv-hero__accent">Westlake Village, CA</span>
        </h1>
        <p class="wv-hero__sub">
          Lakeside luxury living at the edge of the Conejo Valley — Sub-Zero, Wolf,
          Thermador are the standard here, and they deserve service that matches.
          Same-day, OEM parts, 90-day warranty. Gated communities welcome.
          Local Thousand Oaks branch.
        </p>
        <div class="wv-hero__ctas">
          <a href={`tel:${city.phoneRaw}`} class="btn-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.29h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call {city.phone}
          </a>
          <a href="/book/" class="btn-secondary">Book Online</a>
        </div>
        <div class="wv-hero__rating">
          <span class="stars">★★★★★</span>
          <span class="rating-text">4.6 · Google reviews · BBB A+ · Licensed & Insured</span>
        </div>
      </div>
      <div class="wv-hero__img-wrap">
        <img
          src="/images/areas/appliance-repair-westlake-village-ca.webp"
          alt="Appliance repair in Westlake Village CA"
          width="560"
          height="460"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <section class="trust-bar">
    <div class="container trust-bar__inner">
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg><span>Same-Day Service</span></div>
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg><span>90-Day Warranty</span></div>
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg><span>OEM Parts Only</span></div>
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg><span>Licensed & Insured</span></div>
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg><span>Gated Community Ready</span></div>
    </div>
  </section>

  <!-- INTRO -->
  <section class="wv-intro">
    <div class="container wv-intro__inner">
      <div class="wv-intro__text">
        <h2>Appliance Repair in Westlake Village — What This Community Calls For</h2>
        <p>
          Westlake Village is built around its lakes — Westlake Lake and Lake Sherwood
          anchor communities where the homes are serious and the kitchens reflect that.
          Sub-Zero refrigeration, Wolf ranges, Thermador wall ovens, Miele dishwashers —
          these are standard in the lakeside estates, the gated hillside communities,
          and the North Ranch homes. Our technicians carry OEM parts for all of them
          on every service vehicle.
        </p>
        <p>
          Water quality is a specific factor in Westlake Village. Served by Las Virgenes
          Municipal Water District at approximately 200–250 mg/L hardness, the
          mineral content here is meaningful — ice maker inlet valves and dishwasher
          spray arms accumulate scale faster than in soft-water cities. We test for
          this proactively on every relevant call. A&Y notes this; we check it on
          every job rather than only when it's obvious.
        </p>
        <p>
          The Conejo Valley climate adds a second factor shared with neighbouring
          Thousand Oaks: hot, dry summers with hillside particulate load on
          condenser coils. Refrigerators in Westlake Village — particularly in
          the hillside communities — benefit from coil cleaning every 6–9 months
          rather than the 12-month recommendation written for temperate climates.
          We include this inspection on every Westlake Village refrigerator call.
        </p>
        <p>
          Diagnostic fee: <strong>$89</strong> — waived with repair. Written estimate
          before we start. <strong>90-day warranty</strong>. Weekends available.
        </p>
        <div class="wv-tip">
          <div class="wv-tip__icon">💧</div>
          <div class="wv-tip__text">
            <strong>LVMWD water tip for Westlake Village:</strong> Las Virgenes
            Municipal Water District delivers 200–250 mg/L throughout Westlake Village.
            If your ice maker output has been declining gradually over months, LVMWD
            mineral scale on the inlet valve is almost certainly the cause — not a
            failing compressor or a faulty module. Replacing your refrigerator's
            in-door filter every 6 months (not 12) meaningfully slows the
            accumulation rate.
          </div>
        </div>
      </div>
      <div class="wv-intro__cta-box">
        <div class="cta-box">
          <div class="cta-box__title">Westlake Village Service</div>
          <div class="cta-box__sub">91361 · 91362 · Local TO branch · Same day</div>
          <a href={`tel:${city.phoneRaw}`} class="cta-box__phone">{city.phone}</a>
          <a href="/book/" class="cta-box__book">Schedule Online →</a>
          <div class="cta-box__hours">Mon–Fri 7am–9pm · Sat 8am–7pm · Sun 9am–5pm</div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="wv-services">
    <div class="container">
      <h2 class="section-title">What We Repair in Westlake Village</h2>
      <p class="section-sub">Luxury & all brands · LVMWD hard water aware · 91361 & 91362</p>
      <div class="services-grid">

        <a href="/westlake-village/refrigerator-repair/" class="service-card service-card--highlight">
          <div class="service-card__icon">🧊</div>
          <div class="service-card__name">Refrigerator Repair</div>
          <div class="service-card__issues">LVMWD hard water ice maker · Sub-Zero built-in · Not cooling · Coil inspection</div>
          <div class="service-card__brands">Sub-Zero · Wolf · Samsung · LG · GE · Thermador</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/westlake-village/oven-repair/" class="service-card service-card--highlight">
          <div class="service-card__icon">🔥</div>
          <div class="service-card__name">Oven, Range & Pro Range</div>
          <div class="service-card__issues">Wolf dual-fuel · Thermador star burner · Gas igniter · Temperature off</div>
          <div class="service-card__brands">Wolf · Thermador · Viking · GE · Samsung · KitchenAid</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/westlake-village/dishwasher-repair/" class="service-card service-card--highlight">
          <div class="service-card__icon">🍽️</div>
          <div class="service-card__name">Dishwasher Repair</div>
          <div class="service-card__issues">Miele · LVMWD scale · Panel-ready · Not draining · Error codes</div>
          <div class="service-card__brands">Miele · Bosch · Thermador · KitchenAid · Samsung · GE</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/westlake-village/washer-repair/" class="service-card">
          <div class="service-card__icon">🫧</div>
          <div class="service-card__name">Washer Repair</div>
          <div class="service-card__issues">OE / UE error · Not draining · Not spinning · Error codes</div>
          <div class="service-card__brands">LG · Samsung · Whirlpool · Maytag · Bosch · Speed Queen</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/westlake-village/dryer-repair/" class="service-card">
          <div class="service-card__icon">♨️</div>
          <div class="service-card__name">Dryer Repair + Vent Cleaning</div>
          <div class="service-card__issues">Not heating · Thermal fuse · Vent buildup · Gas & electric</div>
          <div class="service-card__brands">LG · Samsung · GE · Maytag · Whirlpool · Miele</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/westlake-village/freezer-repair/" class="service-card">
          <div class="service-card__icon">❄️</div>
          <div class="service-card__name">Freezer & Ice Maker Repair</div>
          <div class="service-card__issues">LVMWD inlet valve scale · Not freezing · Ice stopped · Sub-Zero</div>
          <div class="service-card__brands">Sub-Zero · Samsung · LG · GE · True · Whirlpool</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/westlake-village/wine-cellar-repair/" class="service-card">
          <div class="service-card__icon">🍷</div>
          <div class="service-card__name">Wine Cellar & Cooler Repair</div>
          <div class="service-card__issues">Temperature off · WhisperKOOL · Sub-Zero wine · EuroCave</div>
          <div class="service-card__brands">Sub-Zero · EuroCave · True · WhisperKOOL · Liebherr</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/westlake-village/cooktop-repair/" class="service-card">
          <div class="service-card__icon">🔆</div>
          <div class="service-card__name">Cooktop & Range Hood</div>
          <div class="service-card__issues">Wolf star burner · Thermador igniter · Induction · Hood motor</div>
          <div class="service-card__brands">Wolf · Thermador · Gaggenau · Miele · Viking · Dacor</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

      </div>
    </div>
  </section>

  <!-- NEIGHBORHOODS -->
  <section class="wv-neighborhoods">
    <div class="container">
      <h2>All of Westlake Village — 91361 & 91362</h2>
      <p class="section-sub">Lakeside communities to hillside estates — every neighborhood</p>
      <div class="nh-columns">
        <div class="nh-col">
          <div class="nh-col__title">WLV Communities</div>
          <div class="nh-list">
            <div class="nh-item featured">Westlake Lake waterfront</div>
            <div class="nh-item featured">Lake Sherwood estates</div>
            <div class="nh-item featured">North Ranch</div>
            <div class="nh-item">The Promenade area</div>
            <div class="nh-item">Westlake Trails</div>
            <div class="nh-item">Lakeview Canyon</div>
            <div class="nh-item">Bridgeport</div>
          </div>
        </div>
        <div class="nh-col">
          <div class="nh-col__title">Key Roads</div>
          <div class="nh-list">
            <div class="nh-item">Lakeview Canyon Rd</div>
            <div class="nh-item">Thousand Oaks Blvd</div>
            <div class="nh-item">Westlake Blvd</div>
            <div class="nh-item">Lake Sherwood Dr</div>
            <div class="nh-item">Lindero Canyon Rd</div>
            <div class="nh-item">Via Colinas</div>
          </div>
        </div>
        <div class="nh-col">
          <div class="nh-col__title">Nearby We Serve</div>
          <div class="nh-list">
            <div class="nh-item">Thousand Oaks (91360–62)</div>
            <div class="nh-item">Calabasas (91302)</div>
            <div class="nh-item">Agoura Hills (91301)</div>
            <div class="nh-item">Oak Park (91377)</div>
            <div class="nh-item">Newbury Park (91320)</div>
            <div class="nh-item">Moorpark (93021)</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- RECENT REPAIRS -->
  <section class="wv-recent">
    <div class="container">
      <h2>Recent Jobs in Westlake Village</h2>
      <p class="section-sub">Real calls from 91361 and 91362 — lakeside estates, luxury brands, LVMWD hard water.</p>
      <div class="recent-grid">

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">Sub-Zero Built-In</span>
            <span class="recent-location">Westlake Lake waterfront, 91361</span>
          </div>
          <div class="recent-card__title">"Ice maker producing almost nothing for three months"</div>
          <div class="recent-card__desc">
            Lakefront home on Westlake Lake — Sub-Zero 48-inch built-in with both
            LVMWD mineral scale and Conejo Valley dust load on the condenser coils.
            Two issues in one call: inlet valve almost completely blocked by mineral
            deposits, and coils overloaded with fine hillside particulate making
            the compressor work harder. Replaced the OEM Sub-Zero inlet valve,
            thoroughly cleaned the coil assembly, confirmed stable temperatures.
            Full ice production the next morning. Placed on a combined 6-month
            schedule: inlet valve filter check and coil inspection.
          </div>
          <div class="recent-card__result">✓ Same day · OEM Sub-Zero · Inlet valve + coils · 6-month plan</div>
        </div>

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">Thermador Pro Range</span>
            <span class="recent-location">North Ranch, 91362</span>
          </div>
          <div class="recent-card__title">"Oven igniter glowing but won't light — second time this year"</div>
          <div class="recent-card__desc">
            North Ranch estate — Thermador 48-inch pro range. Oven igniter drawing
            weak current, visually glowing but failing to open the gas valve —
            classic igniter failure pattern. Second occurrence within 12 months on
            this unit. Replaced with OEM Thermador igniter, tested both oven
            cavities at 325°F, 375°F, and 450°F — accurate within 5 degrees.
            Given the repeat failure, recommended checking the igniter at 12-month
            intervals as a maintenance item on this heavily-used kitchen range.
          </div>
          <div class="recent-card__result">✓ Same day · OEM Thermador · Both cavities confirmed · 12-month plan</div>
        </div>

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">Miele Dishwasher</span>
            <span class="recent-location">Lake Sherwood, 91361</span>
          </div>
          <div class="recent-card__title">"F70 flood error — machine completely locked out"</div>
          <div class="recent-card__desc">
            Lake Sherwood estate — Miele G 7000 panel-integrated with F70 base
            pan flood error. Found the water inlet connection had developed a slow
            weep from vibration over time — water had accumulated in the base pan
            triggering the flood protection. Cleared the base pan, reseated and
            properly sealed the inlet connection, ran the Miele anti-flood reset
            procedure, tested three full cycles. Panel cabinetry pulled and
            reinstalled without a mark. All clear on the Miele diagnostics.
          </div>
          <div class="recent-card__result">✓ Same day · Miele F70 resolved · Panel intact · Diagnostics clear</div>
        </div>

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">LG Washer</span>
            <span class="recent-location">Westlake Trails, 91362</span>
          </div>
          <div class="recent-card__title">"LE motor error — LVMWD scale blocking the pump filter too"</div>
          <div class="recent-card__desc">
            LG front-loader — LE motor error (hall sensor fault) presenting alongside
            a secondary OE drain issue. Ran SmartDiagnosis through the app first:
            confirmed hall sensor failure as primary, pump filter blockage as
            secondary. Replaced the hall sensor with OEM LG part, cleared the
            pump filter packed with LVMWD mineral scale and lint. Two problems,
            one trip. Tested three cycles — no LE, no OE. Homeowner wasn't
            aware LVMWD water accelerates pump filter buildup; explained the
            quarterly cleaning routine.
          </div>
          <div class="recent-card__result">✓ Same day · OEM LG hall sensor · Pump filter cleared · LVMWD explained</div>
        </div>

      </div>
    </div>
  </section>

  <!-- WHY US -->
  <section class="wv-why">
    <div class="container">
      <h2>Why Westlake Village Calls Us Back</h2>
      <div class="why-grid">
        <div class="why-card">
          <div class="why-icon">💧</div>
          <div class="why-title">LVMWD Hard Water Aware</div>
          <div class="why-text">Las Virgenes Municipal Water District delivers 200–250 mg/L throughout Westlake Village. Ice maker inlet valves and dishwasher spray arms scale faster here than in soft-water cities. We test for mineral deposits proactively on every relevant call — not just when a customer mentions it.</div>
        </div>
        <div class="why-card">
          <div class="why-icon">🌡️</div>
          <div class="why-title">Conejo Valley Climate Aware</div>
          <div class="why-text">The same hot, dry hillside particulate that affects Thousand Oaks condenser coils applies to Westlake Village's hillside communities. We include a coil inspection on every Westlake Village refrigerator call — especially in the elevated lake communities with active landscaping.</div>
        </div>
        <div class="why-card">
          <div class="why-icon">🔐</div>
          <div class="why-title">Gated Community Ready</div>
          <div class="why-text">Westlake Village has several gated communities and lakefront estates that require coordinated access. We handle the logistics professionally — gate coordination, estate staff, property managers — and arrive on time.</div>
        </div>
        <div class="why-card">
          <div class="why-icon">✅</div>
          <div class="why-title">90-Day Warranty, OEM Only</div>
          <div class="why-text">Every repair backed by 90 days on parts and labor. Genuine OEM parts for Sub-Zero, Wolf, Thermador, Miele — never aftermarket. $89 diagnostic waived with repair. Written estimate before we start. Local Thousand Oaks branch, California licensed, BBB A+.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="wv-reviews">
    <div class="container">
      <h2>What Westlake Village Customers Are Saying</h2>
      <div class="reviews-grid">
        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <div class="review-text">"Sub-Zero on our lakefront home had two problems — LVMWD scale on the inlet valve and Conejo dust on the coils. Same Day found both, fixed both in one visit, put us on a 6-month plan appropriate for a lakefront hillside property. This is exactly the local expertise Westlake Village homes need."</div>
          <div class="review-author">— Robert K., Westlake Lake, Westlake Village</div>
        </div>
        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <div class="review-text">"Thermador range oven igniter failing again — second time in a year. Tech came same day, replaced with OEM Thermador part, tested both cavities accurately, explained the maintenance interval for a heavily-used range. We appreciate a tech who thinks about prevention, not just the immediate fix."</div>
          <div class="review-author">— Jennifer N., North Ranch, Westlake Village</div>
        </div>
        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <div class="review-text">"Miele dishwasher F70 error in our Lake Sherwood home. Tech cleared it, found the actual inlet connection issue, reinstalled the panel cabinetry perfectly, ran through the full Miele diagnostics before leaving. Professional, thorough, and careful with a kitchen we care about. Would absolutely use again."</div>
          <div class="review-author">— Diana W., Lake Sherwood, Westlake Village</div>
        </div>
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section class="wv-pricing">
    <div class="container">
      <h2 class="section-title">Appliance Repair Costs in Westlake Village</h2>
      <p class="section-sub">Written estimate before we start. $89 diagnostic — waived with repair. OEM parts only.</p>
      <div class="pricing-grid">
        <div class="pricing-card featured">
          <div class="pricing-card__appliance">Sub-Zero / Wolf / Gaggenau</div>
          <div class="pricing-card__range">$300 – $800+</div>
          <div class="pricing-card__note">OEM parts · LVMWD coil + inlet check · Lakeside estates</div>
        </div>
        <div class="pricing-card featured">
          <div class="pricing-card__appliance">Thermador / Miele / Viking</div>
          <div class="pricing-card__range">$250 – $600+</div>
          <div class="pricing-card__note">OEM parts · Panel-ready · Pro-style ranges · North Ranch</div>
        </div>
        <div class="pricing-card">
