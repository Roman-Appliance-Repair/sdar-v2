---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import CustomNarrative from '../components/cities/v2/CustomNarrative.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES, MAIN_PHONE, isPlaceholderPhone } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

const citySlug = 'moorpark';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = 'Moorpark';
const zips = ['93021'];

const phone = branch.phone;
const phoneRaw = `+1${phone.replace(/\D/g, '')}`;

const title = `Appliance Repair Moorpark CA | Same Day Service | ${phone}`;
const description = 'Same-day appliance repair in Moorpark, CA. Country Club Estates, Campus Park, Spring Road area. All brands. OEM parts, 90-day warranty. $89 diagnostic — waived with repair.';
const canonical = 'https://samedayappliance.repair/moorpark/';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { '@type': 'City', name: 'Moorpark' },
    { '@type': 'Place', name: 'Country Club Estates' },
    { '@type': 'Place', name: 'Campus Park' },
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$',
  license: 'CA CSLB #1138898'

};

const introParagraphs = [
  "Moorpark is one of the quieter cities in Ventura County — a family community that's grown steadily from its agricultural roots into a mix of established neighborhoods and newer developments. Our Thousand Oaks branch covers Moorpark regularly; it's a natural stop on our Ventura County routes between Thousand Oaks and Simi Valley.",
  "Two things we see in Moorpark that aren't common elsewhere: agricultural dust on condenser coils, and hard water damage on dishwashers and refrigerator water systems. Moorpark sits in the Tierra Rejada Valley, surrounded by citrus orchards and berry farms. Seasonal winds move topsoil off those fields into residential areas — and into the mechanical compartments of refrigerators. We find condenser coil fouling in Moorpark homes at rates closer to what we see in agricultural communities than in suburban Thousand Oaks. The maintenance cycle here is 6 months, not 12.",
  "The Calleguas hard water compounds this on any appliance that uses water — dishwashers, refrigerator ice makers, washing machines. We address both at every service call in Moorpark and leave you with a practical maintenance plan.",
  `Diagnostic fee is $89, credited toward the repair. Call <a href="tel:${phoneRaw}">${phone}</a>.`,
];

const services = [
  { icon: '❄️', name: 'Refrigerator Repair', slug: 'refrigerator' },
  { icon: '🫧', name: 'Washer Repair', slug: 'washer' },
  { icon: '💨', name: 'Dryer Repair', slug: 'dryer' },
  { icon: '🍽️', name: 'Dishwasher Repair', slug: 'dishwasher' },
  { icon: '🔥', name: 'Oven & Range Repair', slug: 'oven' },
  { icon: '♨️', name: 'Cooktop Repair', slug: 'cooktop' },
  { icon: '🧊', name: 'Freezer Repair', slug: 'freezer' },
  { icon: '🧊', name: 'Ice Maker Repair', slug: 'ice-maker' },
];

const valleyDustNarrative = {
  headline: 'Tierra Rejada Valley Dust and Calleguas Hard Water',
  paragraphs: [
    "Moorpark's location in the Tierra Rejada Valley between the Santa Susana Mountains and the Simi Hills creates a specific microenvironment that affects appliance maintenance. The valley floor has historically been farmland — citrus groves, strawberry fields, nurseries — and while residential development has grown steadily, the agricultural character of the surrounding land persists. Seasonal winds, particularly in fall and spring, carry fine topsoil and agricultural particulate across residential neighborhoods.",
    "For refrigerators, this means condenser coils accumulate grit and dust faster than in a city like Thousand Oaks or Camarillo. The coils are the primary heat rejection surface for the refrigeration system — when they're coated with particulate, the compressor works harder and runs hotter. At the extremes, this shortens compressor life. In practice, it means Moorpark refrigerators need coil cleaning every 6 months rather than the standard 12.",
    "Calleguas Municipal Water District water hardness in Moorpark runs moderate to moderately high. The practical impact: dishwasher spray arm ports clog with mineral deposits, heating elements scale up, and refrigerator ice maker inlet valve screens accumulate calcium that eventually causes reduced ice production or complete valve failure. We address all of this when we're on site — a quick filter flush and spray arm cleaning takes 15 minutes and prevents the next service call.",
  ]
};

const neighborhoods = [
  { name: 'Country Club Estates', zip: '93021' },
  { name: 'Campus Park', zip: '93021' },
  { name: 'Spring Road corridor', zip: '93021' },
  { name: 'Tierra Rejada Road area', zip: '93021' },
  { name: 'High Street area', zip: '93021' },
  { name: 'Moorpark Highlands', zip: '93021' },
  { name: 'Hidden Creek area', zip: '93021' },
  { name: 'Peach Hill', zip: '93021' },
  { name: 'West Ranch', zip: '93021' },
  { name: 'Mountain Meadows', zip: '93021' },
];

const recentJobs = [
  {
    appliance: 'GE Refrigerator',
    location: 'Country Club Estates',
    quote: 'GE refrigerator — not cooling, compressor running but warm inside',
    description: "GE Profile PFE28KYNFS — running but not cooling below 55°F. Condenser coils had accumulated a thick layer of fine agricultural dust from the Tierra Rejada Valley — Moorpark's agricultural surroundings mean coil buildup happens faster than in urban cities, especially with the seasonal winds that carry topsoil off the citrus and berry fields. Full coil cleaning, fan motor inspection (healthy), temperature verified before leaving. Homeowner was surprised — didn't know condenser coil cleaning was a thing. We explained the Moorpark-specific maintenance cycle.",
    outcome: '✓ Coil cleaning service · 1.5 hours'
  },
  {
    appliance: 'Samsung Washer',
    location: 'Campus Park',
    quote: 'Samsung washer — ND error, not draining after cycle',
    description: 'Samsung WF45R6100AW — ND (no drain) error code, water sitting in the drum after every cycle. Drain pump filter completely clogged with lint and — unusually — fine grit from what appeared to be gardening clothes. Cleaned the filter and the pump impeller, tested drainage. Also checked the drain hose for kinks — clear. Ran two full cycles before leaving. Moorpark families with outdoor hobbies put interesting things through their washers; we see it.',
    outcome: '✓ Drain pump filter cleaning + inspection · 1 hour'
  },
  {
    appliance: 'Bosch Dishwasher',
    location: 'Moorpark Highlands',
    quote: 'Bosch dishwasher — E09 error, water not heating',
    description: 'Bosch SHPM88Z75N — E09 fault code, dishes coming out cold and with a greasy residue. Heating element had failed. Replaced with an OEM Bosch element. Before closing up, we also descaled the spray arms — Calleguas water hardness in Moorpark is significant, and the mineral buildup on the spray arm ports was already noticeable at this unit\'s age. Left the homeowner with a rinse-aid and descaling schedule.',
    outcome: '✓ Bosch OEM heating element + descale · 2 hours'
  },
  {
    appliance: 'Whirlpool Dryer',
    location: 'Spring Road corridor',
    quote: 'Whirlpool dryer — no heat, squealing noise on drum',
    description: 'Whirlpool WED4815EW — no heat and a squealing sound that had developed over several weeks. Heating element had burned out, and the drum bearing was the source of the squeal. Replaced both in one visit — the element and the drum bearing support kit. When a dryer is open, we check everything that shows wear. Customer had been ignoring the squeal for two months; by the time they called, the bearing was close to seizing.',
    outcome: '✓ Whirlpool OEM heating element + drum bearing kit · 2 hours'
  },
];

const whyReasons = [
  {
    iconKey: 'team' as const,
    title: 'We know the valley',
    body: "Tierra Rejada agricultural dust on condenser coils isn't a surprise to us — it's something we expect and check for on every refrigerator call in Moorpark. We don't just fix what broke; we look at what's about to break."
  },
  {
    iconKey: 'parts' as const,
    title: 'Hard water maintenance included',
    body: "On every dishwasher and refrigerator call in Moorpark, we inspect for mineral scale buildup and address it if present. We leave you with a practical maintenance schedule — monthly rinse-aid, periodic descaling — that's specific to Calleguas water hardness."
  },
  {
    iconKey: 'shield' as const,
    title: "When it's open, we look at everything",
    body: "That Whirlpool dryer with a failed heating element also had a drum bearing showing wear. We replaced both. One visit, done right, warranty on both parts. That's how we avoid a callback six weeks later."
  },
  {
    iconKey: 'clock' as const,
    title: '90-day warranty, all repairs',
    body: 'Every repair in Moorpark carries a 90-day warranty on parts and labor. Same issue returns — we come back at no charge.'
  },
];

const testimonials = [
  {
    stars: 5,
    text: '"GE fridge running warm, turned out to be coil dust — they cleaned it and explained the 6-month cycle for Moorpark given the farmland nearby. Never knew that was an issue. Fast, professional, informative."',
    author: '— Robert M., Country Club Estates'
  },
  {
    stars: 5,
    text: "\"Bosch dishwasher E09 error. They replaced the element, descaled the spray arms without being asked, and left me with a maintenance schedule. One hour, done. That's the kind of service I'll call back.\"",
    author: '— Sandra K., Moorpark Highlands'
  },
  {
    stars: 5,
    text: "\"Dryer repair — no heat and a squeal I'd been ignoring. They found the bearing failing too and replaced both in one visit. Told me I'd waited a bit too long on the bearing but no lecture, just fixed it. Great team.\"",
    author: '— James T., Spring Road area'
  },
];

const pricingTiers = [
  { appliance: 'Diagnostic Fee', range: '$89', note: 'Credited toward repair · Written estimate · Agricultural dust assessment included' },
  { appliance: 'Standard Repair', range: '$150–$380', note: 'Parts + labor · OEM parts · 90-day warranty' },
  { appliance: 'Luxury Brand Repair', range: '$250–$600+', note: 'Sub-Zero, Wolf, Thermador · OEM parts' },
  { appliance: 'Warranty', range: '90 Days', note: 'All repairs · Parts & labor · No-charge callback', featured: true },
];

const faqs = [
  {
    question: 'Do you offer same-day appliance repair in Moorpark?',
    answer: 'Yes — Moorpark is covered by our Thousand Oaks branch and is on our regular Ventura County route. We service Moorpark multiple times per week. Call before noon for same-day service in most cases. We cover all Moorpark neighborhoods including Country Club Estates, Campus Park, and Spring Road.'
  },
  {
    question: 'What is your diagnostic fee in Moorpark?',
    answer: 'Our diagnostic fee is $89. It covers the service call, complete appliance inspection, and written estimate. If you proceed with the repair, the $89 is credited toward your invoice.'
  },
  {
    question: "Does Moorpark's agricultural setting affect appliances?",
    answer: 'It does — more than most homeowners realize. The Tierra Rejada Valley and surrounding agricultural areas generate fine dust particulate that accumulates on refrigerator condenser coils faster than in purely urban cities. Seasonal winds off the citrus and berry fields carry topsoil into mechanical spaces. We recommend condenser coil inspection every 6 months in Moorpark rather than the standard 12-month cycle.'
  },
  {
    question: 'Does hard water in Moorpark affect dishwashers and refrigerators?',
    answer: 'Yes. Moorpark is served by the Calleguas Municipal Water District, which delivers moderately hard water. Dishwasher spray arms, heating elements, and inlet valves accumulate mineral scale. Refrigerator water filters and ice maker inlet valves need more frequent attention than in softer-water areas. We address this proactively on every relevant service call.'
  },
  {
    question: 'What appliance brands do you repair in Moorpark?',
    answer: 'All major brands: GE, Samsung, LG, Whirlpool, KitchenAid, Bosch, Maytag, Frigidaire, and luxury brands including Sub-Zero, Wolf, and Thermador in the Country Club Estates and Moorpark Highlands neighborhoods. OEM parts for all of these on our trucks.'
  },
  {
    question: 'Do you service rental properties near Moorpark College?',
    answer: 'Yes. Moorpark College generates a rental market in the surrounding neighborhoods. We work with landlords and property managers in Moorpark on appliance repairs for rental units. Same-day availability, written documentation, professional service.'
  },
  {
    question: 'Do you offer a warranty on repairs in Moorpark?',
    answer: 'All repairs include a 90-day warranty on parts and labor. Same issue returns within 90 days — we come back at no charge.'
  },
];

const nearbyCities = [
  { name: 'Thousand Oaks', slug: 'thousand-oaks' },
  { name: 'Simi Valley', slug: 'simi-valley' },
  { name: 'Camarillo', slug: 'camarillo' },
  { name: 'Agoura Hills', slug: 'agoura-hills' },
  { name: 'Newbury Park', slug: 'newbury-park' },
  { name: 'Ventura', slug: 'ventura' },
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair in"
    headlineCity="Moorpark, CA"
    subheadline="Same-day service across all of Moorpark. Agricultural valley dust and hard water expertise. OEM parts, 90-day warranty. $89 diagnostic — waived with repair."
    zips={zips}
    tier={3}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance Repair in Moorpark — What the Valley Setting Actually Means"
    paragraphs={introParagraphs}
    bookingTitle="Moorpark Service"
    bookingSub="Available Today"
  />

  <ServicesGrid
    cityName={cityName}
    headline="Appliance Repair Services in Moorpark"
    services={services}
  />

  <CustomNarrative
    headline={valleyDustNarrative.headline}
    paragraphs={valleyDustNarrative.paragraphs}
    background="white"
  />

  <ServiceArea
    cityName={cityName}
    headline="Moorpark Neighborhoods We Service"
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={[]}
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Repairs in Moorpark"
    jobs={recentJobs}
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="Why Moorpark Residents Call Us"
    reasons={whyReasons}
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What Moorpark Clients Say"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Repair Pricing in Moorpark"
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="Frequently Asked Questions — Moorpark"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby Ventura County Cities"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Schedule Your Moorpark Repair Today"
    body="Same-day service from our Thousand Oaks branch. All brands, all neighborhoods."
  />
</CityLayoutV2>
