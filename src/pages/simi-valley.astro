---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import CustomNarrative from '../components/cities/v2/CustomNarrative.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

const citySlug = 'simi-valley';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = 'Simi Valley';
const zips = ['93063', '93065'];

const phoneRaw = `+1${branch.phone.replace(/\D/g, '')}`;

const title = `Appliance Repair Simi Valley CA | Same Day Service | ${branch.phone}`;
const description = "Same-day appliance repair in Simi Valley, CA. Hard water, Santa Ana wind expertise. Refrigerator, washer, dryer, oven repair. OEM parts, 90-day warranty. $89 diagnostic — waived with repair.";
const canonical = 'https://samedayappliance.repair/simi-valley/';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { '@type': 'City', name: 'Simi Valley', sameAs: 'https://en.wikipedia.org/wiki/Simi_Valley,_California' },
    { '@type': 'Place', name: 'Wood Ranch' },
    { '@type': 'Place', name: 'Santa Susana Knolls' },
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$',
  license: 'CA CSLB #1138898'

};

const introParagraphs = [
  "Simi Valley is one of the larger cities in Ventura County — 126,000 residents, a lot of families, a lot of appliances working hard. Our Thousand Oaks technicians cover Simi Valley regularly, and there are two things we see here more than anywhere else in our service area: hard water damage and dryer vent problems.",
  "The Calleguas Municipal Water District supplies most of Simi Valley with some of the hardest water in the region. That's not an abstract concern — it shows up as clogged dishwasher spray arms, failed refrigerator water inlet valves, and scaled washing machine components on a regular basis. We fix the immediate problem and explain what caused it so you're not calling us back for the same thing in 18 months.",
  "Simi Valley's hot dry summers and Santa Ana wind conditions also create a dryer vent fire risk that's real and underreported. We inspect dryer vents on every dryer call in Simi Valley. A thermal fuse that keeps blowing isn't a dryer problem — it's a vent problem, and we'll tell you that clearly.",
  `Diagnostic fee is $89, credited toward the repair. Call <a href="tel:${phoneRaw}">${branch.phone}</a> — our Ventura County line, answered by someone who knows the schedule.`,
];

const services = [
  { icon: '❄️', name: 'Refrigerator Repair', slug: 'refrigerator' },
  { icon: '🫧', name: 'Washer Repair', slug: 'washer' },
  { icon: '💨', name: 'Dryer Repair', slug: 'dryer' },
  { icon: '🍽️', name: 'Dishwasher Repair', slug: 'dishwasher' },
  { icon: '🔥', name: 'Oven & Range Repair', slug: 'oven' },
  { icon: '♨️', name: 'Cooktop Repair', slug: 'cooktop' },
  { icon: '🧊', name: 'Freezer Repair', slug: 'freezer' },
  { icon: '🧊', name: 'Ice Maker Repair', slug: 'ice-maker' },
];

const twoThingsNarrative = {
  headline: 'Two Things Simi Valley Homeowners Should Know',
  subSections: [
    {
      title: '1. Your water is hard — and it affects every water-connected appliance',
      paragraphs: [
        "The Calleguas Municipal Water District serves most of Simi Valley, and its water hardness levels are among the highest in Southern California. Hard water leaves calcium and magnesium deposits on every surface it touches. In appliances, that means:",
        "Dishwashers accumulate scale on spray arms, inlet valves, and heating elements — resulting in poor cleaning, white film on dishes, and eventually component failure. Refrigerators with ice makers and water dispensers have their inlet valves clog and fail faster than in softer-water cities. Washing machine drum seals and inlet valve screens need more frequent attention.",
        "We fix the immediate failure, but we also tell you what maintenance prevents the next one: consistent rinse-aid in every dishwasher cycle, a quarterly filter clean, and an inline water filter on your refrigerator supply line. These are cheap preventive measures that extend appliance lifespan significantly in Simi Valley.",
      ]
    },
    {
      title: '2. Dryer vents and fire risk in Santa Ana conditions',
      paragraphs: [
        "Simi Valley's location — surrounded by hills and exposed to Santa Ana wind patterns — creates elevated fire risk conditions during late summer and fall. A dryer vent clogged with lint is a fire hazard under normal conditions. In Simi Valley during a Santa Ana event, it's a more serious one.",
        "We inspect dryer vents on every dryer repair call in Simi Valley. If the thermal fuse is failing repeatedly, we look at the vent before we replace anything. A restricted vent will keep blowing fuses indefinitely — it's not the fuse's fault. We clear the vent, replace the failed components, and document the vent condition in our service report.",
      ]
    },
  ]
};

// Source-bug fix #1 (catalog): Madera Road corridor entry had stray `slug:"93063"` field — kept just { name, zip }.
const neighborhoods = [
  { name: 'Simi Valley East', zip: '93065' },
  { name: 'Simi Valley West', zip: '93063' },
  { name: 'Wood Ranch', zip: '93065' },
  { name: 'Bridle Path', zip: '93065' },
  { name: 'Berylwood', zip: '93063' },
  { name: 'Knolls area', zip: '93063' },
  { name: 'Santa Susana Knolls', zip: '93063' },
  { name: 'Madera Road corridor', zip: '93063' },
  { name: 'Cochran Street area', zip: '93065' },
  { name: 'Tapo Canyon area', zip: '93063' },
];

const recentJobs = [
  {
    appliance: 'Whirlpool Dryer',
    location: 'Wood Ranch',
    quote: 'Whirlpool dryer — overheating, shutting off mid-cycle',
    description: "Whirlpool WED5000DW — cycling off before the load finished, thermal fuse tripping repeatedly. The dryer vent run in this Wood Ranch home was 18 feet with two 90-degree bends, and lint had accumulated to the point where airflow was severely restricted. We cleared the vent completely, replaced the thermal fuse and the cycling thermostat (both had failed from repeated overheating), and tested air flow at the exterior vent cap. We also flagged the vent routing to the homeowner — that configuration needs cleaning every 6 months, not annually. In Santa Ana wind conditions, a restricted dryer vent in Simi Valley is a genuine fire hazard.",
    outcome: '✓ Same day · Whirlpool OEM thermal fuse + cycling thermostat · 2.5 hours'
  },
  {
    appliance: 'LG Dishwasher',
    location: 'Simi Valley East',
    quote: 'LG dishwasher — white film on dishes, spray arm clogged',
    description: 'LG LDTS5552S — heavy white mineral film on all dishes, spray arm barely rotating. Calleguas Municipal Water District water is among the hardest in the region, and without consistent rinse-aid use, mineral scale accumulates fast. Full descale of the spray arms, cleaning of the filter assembly and drain path, replacement of the inlet screen. Left the homeowner with a maintenance schedule: monthly rinse-aid refill, quarterly filter clean, annual descale treatment. This is a routine issue in Simi Valley, not a defect.',
    outcome: '✓ Same day · Descale service + inlet screen replacement · 1.5 hours'
  },
  {
    appliance: 'Samsung Refrigerator',
    location: 'Berylwood',
    quote: 'Samsung refrigerator — ice maker producing no ice for two weeks',
    description: 'Samsung RF28R7351SR — ice maker had completely stopped. The water inlet valve had failed, a known failure point on this Samsung generation. Hard water mineral deposits had partially blocked the valve screen, then the valve solenoid failed under the strain. Replaced the inlet valve assembly with an OEM Samsung part and cleaned the supply line screen. Recommended the homeowner install an inline water filter upstream of the refrigerator — the Calleguas hard water will hit this valve again in 3-4 years without filtration.',
    outcome: '✓ Same day · Samsung OEM water inlet valve assembly · 1.5 hours'
  },
  {
    appliance: 'GE Range',
    location: 'Knolls area',
    quote: 'GE range — oven not heating, bake element visible crack',
    description: "GE JS760SLSS — oven refusing to heat, bake element visibly cracked in two places. Straightforward element replacement, but we found the broil element was also discolored and showing signs of imminent failure — replaced both in one visit. Homeowner said they'd noticed the oven 'not getting as hot as it used to' for six months before the element finally gave out. These are early warning signs. We document what we observe so the customer has context.",
    outcome: '✓ Same day · GE OEM bake element + broil element · 1.5 hours'
  },
];

const whyReasons = [
  {
    iconKey: 'parts' as const,
    title: 'We explain the root cause',
    body: 'A Samsung ice maker that failed because the inlet valve clogged from hard water deposits is a different problem than a Samsung ice maker with a failed module. We tell you which it is and why — so you know what to prevent next time.'
  },
  {
    iconKey: 'shield' as const,
    title: 'Dryer vent always inspected',
    body: "We check the dryer vent on every dryer repair in Simi Valley. A restricted vent that's been causing thermal fuse failures needs to be cleared — not just have its fuse replaced again. We fix the actual problem."
  },
  {
    iconKey: 'team' as const,
    title: 'Landlord-friendly',
    body: "We work with Simi Valley landlords on rental property appliance repairs. We show up when we say we will, provide written service documentation, and don't leave until the job is done right. Call us if you manage multiple units."
  },
  {
    iconKey: 'clock' as const,
    title: 'OEM parts, 90-day warranty',
    body: 'All repairs use manufacturer-original parts and carry a 90-day warranty on parts and labor. Same issue returns within 90 days — we come back at no charge.'
  },
];

const testimonials = [
  {
    stars: 5,
    text: '"Dryer kept shutting off. Two other companies replaced the thermal fuse twice without fixing it. Same Day came out, cleared the vent, replaced the fuse and thermostat, and explained why the vent was the real problem. It’s been running fine for four months."',
    author: '— Kevin M., Wood Ranch'
  },
  {
    stars: 5,
    text: '"Dishwasher leaving white film on everything. They cleaned the spray arms, replaced the inlet screen, and explained the hard water issue in Simi Valley. Told me to use rinse-aid every cycle. That simple advice has made a huge difference."',
    author: '— Sandra T., Simi Valley East'
  },
  {
    stars: 5,
    text: '"I manage 8 rental units in Simi Valley. Same Day is the only appliance company I call now. They pick up, show up same day, and give me written documentation. Everything a landlord needs."',
    author: '— Robert H., Property Manager, Simi Valley'
  },
];

const pricingTiers = [
  { appliance: 'Diagnostic Fee', range: '$89', note: 'Credited toward repair · Written estimate · Hard water assessment included' },
  { appliance: 'Standard Repair', range: '$150–$380', note: 'Parts + labor · OEM parts · 90-day warranty' },
  { appliance: 'Dryer Vent Service', range: '$95–$150', note: 'Cleaning + inspection · Fire safety documentation · Recommended annually in Simi Valley' },
  { appliance: 'Warranty', range: '90 Days', note: 'All repairs · Parts & labor · No-charge callback', featured: true },
];

const faqs = [
  {
    question: 'Do you offer same-day appliance repair in Simi Valley?',
    answer: 'Yes — Simi Valley is covered by our Thousand Oaks branch. We run Ventura County routes regularly and can typically have a technician at your door same-day if you call before noon. We cover both 93063 and 93065 zip codes.'
  },
  {
    question: 'Does hard water in Simi Valley cause extra appliance problems?',
    answer: 'Yes, notably. The Calleguas Municipal Water District, which serves most of Simi Valley, delivers some of the hardest water in the region. Mineral scale accumulates on dishwasher spray arms and heating elements, clogs refrigerator water inlet valves, and builds up in washing machine drum seals. We deal with water-related appliance issues in Simi Valley at higher rates than in softer-water cities. The fix is mostly preventive: consistent rinse-aid use, periodic descaling, and an inline water filter on refrigerators.'
  },
  {
    question: 'Are dryer vents a bigger concern in Simi Valley?',
    answer: "They are. Simi Valley's hot, dry summers and Santa Ana wind conditions create a fire risk when dryer vents are clogged or restricted. We inspect dryer vents on every dryer repair call in Simi Valley, and we're straightforward about what we find. A restricted vent that causes a dryer to repeatedly overheat and trip its thermal fuse is not a dryer problem — it's a vent problem, and the vent needs to be cleared before the dryer will stay fixed."
  },
  {
    question: 'What is your diagnostic fee in Simi Valley?',
    answer: 'Our diagnostic fee is $89. It covers the service call, complete appliance inspection, and written estimate. If you approve the repair, the $89 is credited against your invoice.'
  },
  {
    question: 'Do you work with landlords and property managers in Simi Valley?',
    answer: 'Yes. We work with landlords who own multi-family properties and single-family rentals in Simi Valley. If you manage multiple units and need a reliable repair service, call us. We understand that a broken appliance in a rental property needs attention quickly.'
  },
  {
    question: 'What appliance brands do you repair in Simi Valley?',
    answer: 'All major brands: Samsung, LG, GE, Whirlpool, KitchenAid, Maytag, Bosch, Frigidaire, and luxury brands including Sub-Zero, Wolf, and Thermador in the Wood Ranch and higher-end neighborhoods. OEM parts on the truck for the brands we see most often in Simi Valley.'
  },
  {
    question: 'Do you offer a warranty on repairs in Simi Valley?',
    answer: 'All repairs include a 90-day warranty on parts and labor. Same issue returns within 90 days — we come back at no charge.'
  },
];

// Audit fix: /chatsworth/ broken — replaced with /oak-park/.
const nearbyCities = [
  { name: 'Thousand Oaks', slug: 'thousand-oaks' },
  { name: 'Moorpark', slug: 'moorpark' },
  { name: 'Oak Park', slug: 'oak-park' },
  { name: 'Agoura Hills', slug: 'agoura-hills' },
  { name: 'Newbury Park', slug: 'newbury-park' },
  { name: 'Camarillo', slug: 'camarillo' },
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair in"
    headlineCity="Simi Valley, CA"
    subheadline="Same-day service across all of Simi Valley. Hard water and dryer vent expertise. OEM parts, 90-day warranty. $89 diagnostic — waived with repair."
    zips={zips}
    tier={3}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance Repair in Simi Valley — Hard Water, Big Families, Real Answers"
    paragraphs={introParagraphs}
    bookingTitle="Simi Valley Service"
    bookingSub="Available Today"
  />

  <ServicesGrid
    cityName={cityName}
    headline="Appliance Repair Services in Simi Valley"
    services={services}
  />

  <CustomNarrative
    headline={twoThingsNarrative.headline}
    subSections={twoThingsNarrative.subSections}
    background="white"
  />

  <ServiceArea
    cityName={cityName}
    headline="Simi Valley Neighborhoods We Service"
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={[]}
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Repairs in Simi Valley"
    jobs={recentJobs}
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="Why Simi Valley Residents Call Us"
    reasons={whyReasons}
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What Simi Valley Clients Say"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Repair Pricing in Simi Valley"
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="Frequently Asked Questions — Simi Valley"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby Ventura County Cities"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Schedule Your Simi Valley Repair Today"
    body="Same-day service across all of Simi Valley. Hard water and dryer vent expertise."
  />
</CityLayoutV2>
