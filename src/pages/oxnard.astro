---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import CustomNarrative from '../components/cities/v2/CustomNarrative.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

const citySlug = 'oxnard';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = 'Oxnard';
const zips = ['93030', '93033', '93035', '93036'];

const phone = branch.phone;
const phoneRaw = `+1${phone.replace(/\D/g, '')}`;

const title = `Appliance Repair Oxnard CA | Same Day Service | ${phone}`;
const description = 'Same-day appliance repair in Oxnard, CA. Channel Islands Harbor, Oxnard Shores, River Ridge, Silverstrand. Sub-Zero, Wolf & all brands. Commercial + residential. $89 diagnostic.';
const canonical = 'https://samedayappliance.repair/oxnard/';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { '@type': 'City', name: 'Oxnard', sameAs: 'https://en.wikipedia.org/wiki/Oxnard,_California' },
    { '@type': 'Place', name: 'Oxnard Shores' },
    { '@type': 'Place', name: 'Channel Islands Harbor' },
    { '@type': 'Place', name: 'River Ridge' },
    { '@type': 'Place', name: 'Silverstrand Beach' },
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$',
  license: 'CA CSLB #1138898',
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.6',
    reviewCount: '37',
    bestRating: '5',
  },
};

const introParagraphs = [
  "Oxnard is the largest city in Ventura County by population (200,000+ residents) and the most service-diverse city in our route. The reason: Oxnard isn't one community — it's three or four overlapping ones, and the appliance work changes meaningfully based on which neighborhood you're in.",
  "Beachfront Oxnard sits on the Pacific from Hollywood Beach down through Silverstrand and Mandalay Bay to Channel Islands Harbor and Oxnard Shores — direct marine-air exposure, condo + beach-house housing, Sub-Zero / Wolf / Thermador kitchens common. Inland to the east, RiverPark Estates and the River Ridge / Windsor North area is newer-construction Ventura County luxury — RiverPark Marketplace shopping, golf-course communities, mainstream-luxury appliance brand mix. Downtown Oxnard around Heritage Square + Carnegie Art Museum + the Plaza Park has older homes and small commercial kitchens (restaurants, the Channel Islands Harbor marina businesses). South Oxnard around Rose Park is mid-market residential with mainstream appliance brands.",
  "Our Thousand Oaks branch covers all four sub-markets on a regular schedule. Beachfront condos get Sub-Zero coil cleanings on a 4-5 month cycle (not the 8-12 month interval that works inland). RiverPark calls are typically 5-7 year-old Wolf and Sub-Zero installs hitting their first major service. Downtown commercial is restaurants and small-business kitchens running residential-grade equipment at commercial duty cycles. South Oxnard is the standard mainstream brand mix that any LA-area technician handles routinely.",
  "Oxnard also has a meaningful commercial appliance footprint — restaurant kitchens, the Port of Hueneme-adjacent operations, agricultural cold-storage, hotels (Embassy Suites, Residence Inn near Channel Islands Harbor). Call us for commercial pricing.",
  `Call <a href="tel:${phoneRaw}">${phone}</a> — someone with our actual Ventura County schedule picks up.`,
];

const services = [
  { icon: '❄️', name: 'Refrigerator Repair', slug: 'refrigerator' },
  { icon: '🫧', name: 'Washer Repair', slug: 'washer' },
  { icon: '💨', name: 'Dryer Repair', slug: 'dryer' },
  { icon: '🍽️', name: 'Dishwasher Repair', slug: 'dishwasher' },
  { icon: '🔥', name: 'Oven & Range Repair', slug: 'oven' },
  { icon: '🍳', name: 'Stove Repair', slug: 'stove' },
  { icon: '📻', name: 'Microwave Repair', slug: 'microwave' },
  { icon: '🧊', name: 'Ice Maker Repair', slug: 'ice-maker' },
  { icon: '🍷', name: 'Wine Cooler Repair', slug: 'wine-cooler' },
  { icon: '🧊', name: 'Freezer Repair', slug: 'freezer' },
  { icon: '🗑️', name: 'Garbage Disposal Repair', slug: 'garbage-disposal' },
  { icon: '♨️', name: 'Cooktop Repair', slug: 'cooktop' },
];

const marineNarrative = {
  headline: 'Marine-air corrosion in Oxnard — where it actually matters',
  paragraphs: [
    "Oxnard's coastal exposure is more direct than Camarillo's or Thousand Oaks's. Hollywood Beach, Silverstrand, Mandalay Bay, and Oxnard Shores condos sit within blocks of the open Pacific — there's no Conejo Valley or hill range buffering the marine air. The result: refrigerator condenser coils accumulate fine salt particulate at roughly 2-3x the inland rate. Sub-Zero coils in beachfront Oxnard Shores units that we've serviced over multiple visits show inspection-cleaning intervals of 4-5 months as the realistic target — not the 8-12 month interval Sub-Zero's manual suggests for typical residential service.",
    "Range and cooktop igniters are similarly affected. Wolf and Viking burner electrodes show coastal-air corrosion patterns within 2-3 years on direct-beachfront installs. We catch these proactively during any service call — it's a cheap fix at the early stage and a no-ignition emergency at the late stage. Outdoor-adjacent appliances (BBQ grills, outdoor refrigerators, ice makers in pool cabanas) compound the issue further.",
    "Channel Islands Harbor and the marina-adjacent properties have a slightly different exposure profile — sheltered water, less direct ocean spray, but heavier humidity year-round from the harbor itself. Service intervals here run between Oxnard Shores beachfront and inland River Ridge. We adjust the maintenance recommendations based on the specific micro-climate of where the property sits.",
  ],
};

const commercialNarrative = {
  headline: 'Commercial appliance work in Oxnard — restaurants, agriculture, hospitality',
  paragraphs: [
    "Oxnard has a real commercial appliance footprint that most Ventura County service companies under-serve. The reasons: Oxnard is the strawberry capital of the country (one of the largest US producers, with the California Strawberry Festival every spring), the Port of Hueneme is the only deep-water commercial port between LA and SF, and major employers including Haas Automation, Seminis, Raypak, and Drum Workshop run substantial facilities here. That commercial activity means restaurants, hotels, agricultural-processing kitchens, and small-business food operations need appliance service that goes beyond residential scope.",
    "<strong>What we handle on the commercial side:</strong> walk-in coolers and freezers (compressor service, evaporator cleaning, defrost-timer issues), commercial refrigeration including True, Beverage-Air, and Continental units in restaurants and convenience stores, commercial dishwashers from Hobart, Champion, and Jackson in restaurants near Channel Islands Harbor and Heritage Square, commercial ranges and ovens (Vulcan, Garland, Wolf commercial), ice machines for restaurants and bars (Hoshizaki, Manitowoc, Scotsman). Call us for commercial pricing.",
    "For agricultural operations specifically, we don't service field equipment or process-specific industrial machinery. We do service the cold-storage refrigeration that supports strawberry packing and post-harvest holding (these are typically commercial walk-ins or reach-ins, same equipment categories we service in restaurants). For pure industrial machinery, we route customers to Quinn Company or specialty industrial service.",
    "Oxnard hospitality customers — Embassy Suites Mandalay Bay, Residence Inn Channel Islands, smaller boutique properties downtown — get the same diagnostic + repair workflow as residential, just with the commercial pricing tier. We coordinate with property managers when units need to be off-line for service.",
  ],
};

const neighborhoods = [
  { name: 'Oxnard Shores', zip: '93035' },
  { name: 'Channel Islands Harbor', zip: '93035' },
  { name: 'Silverstrand Beach', zip: '93035' },
  { name: 'Hollywood Beach', zip: '93035' },
  { name: 'Mandalay Bay', zip: '93035' },
  { name: 'River Ridge / RiverPark', zip: '93036' },
  { name: 'Windsor North', zip: '93036' },
  { name: 'Downtown Oxnard', zip: '93030' },
  { name: 'Heritage Square area', zip: '93030' },
  { name: 'Rose Park / Wilson', zip: '93033' },
  { name: 'South Oxnard', zip: '93033' },
  { name: 'Strickland Acres', zip: '93030' },
];

const recentJobs = [
  {
    appliance: 'Sub-Zero 648PRO',
    location: 'Oxnard Shores',
    quote: 'beachfront condo, compressor short-cycling',
    description: "Sub-Zero 648PRO built-in in a beachfront Oxnard Shores condo — direct beach exposure, three blocks from the sand. Compressor short-cycling and front evaporator running warmer than the back. Condenser coils were so packed with salt-laden particulate they looked grey instead of stainless. Full coil cleaning + condenser fan motor inspection (still healthy). What we found and explained to the homeowner: oceanfront Oxnard Shores condos need coil service every 4-5 months, not the 8-12 month interval typical for inland units. The marine-air corrosion accelerates buildup meaningfully on direct beachfront installs.",
    outcome: '✓ Coil cleaning service + filter replacement · 2.5 hours',
  },
  {
    appliance: 'Wolf 48" dual-fuel range',
    location: 'River Ridge / RiverPark',
    quote: 'RiverPark home, oven not maintaining temp',
    description: "Wolf DF486G in a RiverPark Estates home — oven temperature drifting 25-40°F low at all set points. Oven temperature sensor (RTD) had failed. Replaced with OEM Wolf RTD probe, recalibrated the control board, ran three test bakes at different temps. RiverPark is one of the newer Oxnard developments with a high concentration of luxury kitchens — Wolf, Sub-Zero, Thermador are common spec. Our Thousand Oaks technicians carry Wolf RTD probes on the truck specifically because we see this failure pattern in newer Oxnard developments at the 5-7 year mark.",
    outcome: '✓ Wolf OEM RTD oven temperature sensor · 1.5 hours',
  },
  {
    appliance: 'LG washer + dryer stack',
    location: 'Channel Islands Harbor',
    quote: 'vibration walking dryer',
    description: "LG WashTower stack in a Channel Islands Harbor townhouse — washer running fine on its own, dryer above it walking across the laundry closet during washer spin cycles. Diagnosed as washer shock-absorber wear (one of two had degraded). Replaced both shocks (we recommend pairs for balance), checked the stacking-kit hardware, verified the dryer was correctly anchored. Channel Islands Harbor's stacked-laundry installs in townhouses can amplify washer vibration meaningfully into the dryer above — single-failed-shock catches you off guard because the unit looks structurally fine.",
    outcome: '✓ LG OEM shock absorber pair + stacking-kit re-anchor · 2 hours',
  },
  {
    appliance: 'Bosch dishwasher',
    location: 'Downtown Oxnard / Heritage Square',
    quote: 'restaurant near Heritage Square, no drain',
    description: "Bosch SHX-series commercial-grade residential dishwasher in a small restaurant kitchen near Heritage Square — wouldn't drain at end of cycle, water sitting in the sump. Drain pump fully clogged with food debris that had bypassed the filter. Cleared the pump impeller, deep-cleaned the filter assembly + sump, replaced the drain hose check valve (cracked from age). Tested with three full cycles. Small-restaurant kitchens running residential dishwashers at commercial duty cycles see this 2-3 year mark on the drain pump. We discussed switching to a Hobart or Champion commercial unit but the volume didn't justify the capex yet.",
    outcome: '✓ Bosch OEM drain check valve + pump cleaning · 2 hours',
  },
];

const whyReasons = [
  {
    iconKey: 'team' as const,
    title: 'Coastal climate experience that matches Oxnard reality',
    body: 'We know the difference between Oxnard Shores beachfront (4-5 month coil cycle), Channel Islands Harbor marina-adjacent (6-month cycle), and inland River Ridge (8-12 month cycle). When we recommend maintenance intervals, they\'re based on which Oxnard neighborhood you\'re actually in.',
  },
  {
    iconKey: 'parts' as const,
    title: 'RiverPark and River Ridge luxury brand inventory',
    body: "Wolf, Sub-Zero, Thermador OEM parts on the Thousand Oaks truck. RiverPark Estates calls don't require waiting on a parts order from out-of-state distributors. Same applies to beachfront Oxnard Shores luxury condos.",
  },
  {
    iconKey: 'shield' as const,
    title: 'Commercial appliance scope alongside residential',
    body: 'Oxnard restaurants near Channel Islands Harbor + Heritage Square + the Plaza Park area get commercial dishwasher, walk-in cooler, and ice-machine service from the same dispatch as our residential customers.',
  },
  {
    iconKey: 'clock' as const,
    title: 'No distance surcharge — Oxnard is on our regular route',
    body: "Thousand Oaks branch runs the Ventura County loop including Oxnard daily. The $89 residential diagnostic is the same in Oxnard as it is in Thousand Oaks or Westlake Village. What we quote is what you pay.",
  },
];

const testimonials = [
  {
    stars: 5,
    text: '"Sub-Zero in our beachfront unit was struggling. Three other companies told us we needed a new compressor. Same Day came out, cleaned the coils — apparently completely packed with salt-laden buildup that ten years of beachfront living put there — and said the compressor was fine. Saved us thousands."',
    author: '— David M., Oxnard Shores',
  },
  {
    stars: 5,
    text: "\"Wolf range stopped reaching temperature. Same Day's Thousand Oaks tech showed up the same afternoon, had the OEM RTD probe on the truck, replaced it, recalibrated. Two-hour service call. Other places quoted us a week-long parts order.\"",
    author: '— Jennifer L., RiverPark Estates',
  },
  {
    stars: 5,
    text: '"Restaurant near the harbor — our walk-in stopped cooling on a Friday evening. Most appliance shops don\'t take commercial calls. Same Day did, came out Saturday morning, fixed the evaporator fan motor, got us back open before lunch service. They\'ve been our service company since."',
    author: '— Carlos R., Channel Islands Harbor (restaurant operator)',
  },
];

const pricingTiers = [
  { appliance: 'Residential Diagnostic', range: '$89', note: 'No distance surcharge · Credited toward repair · Written estimate' },
  { appliance: 'Standard Repair Range', range: '$150–$350', note: 'Parts + labor · OEM parts · 90-day warranty' },
  { appliance: 'Luxury Brand Repair', range: '$250–$600+', note: 'Sub-Zero, Wolf, Thermador, Viking · OEM parts', featured: true },
];

const faqs = [
  {
    question: 'Do you offer same-day appliance repair in Oxnard?',
    answer: 'Yes — Oxnard is one of our regular service cities. Our Thousand Oaks branch runs Ventura County routes daily, and Oxnard is the largest population center in the county at 200,000+ residents. Call before noon and we can typically dispatch a technician that afternoon. Coverage spans all four ZIP codes (93030, 93033, 93035, 93036) and the major neighborhoods from Oxnard Shores to River Ridge to Downtown.',
  },
  {
    question: 'Do you cover beachfront Oxnard Shores and Channel Islands Harbor?',
    answer: 'Yes — and beachfront properties are a specific specialty for us. Oxnard Shores, Channel Islands Harbor, Silverstrand Beach, Hollywood Beach, and Mandalay Bay all sit within direct marine-air influence, which accelerates corrosion on refrigerator condenser coils, range igniters, and outdoor-adjacent appliances. We service these neighborhoods regularly and know what to look for. Sub-Zero, Wolf, Thermador beach-condo installs are common.',
  },
  {
    question: "Does Oxnard's coastal climate really affect appliances differently?",
    answer: 'Yes, more than people expect. The marine layer rolling in from the Pacific carries fine salt-laden particulate that deposits on outdoor-facing appliance components. In direct-beachfront Oxnard Shores or Channel Islands Harbor properties, refrigerator condenser coils need cleaning every 4-5 months versus 8-12 months inland. Range burner igniters show corrosion patterns we recognize on sight in these neighborhoods. We tell homeowners about this proactively rather than letting it become the next service call.',
  },
  {
    question: 'Do you service commercial appliances for Oxnard restaurants and businesses?',
    answer: "Yes — Oxnard's commercial scope includes restaurants, hotels (Embassy Suites, Residence Inn), agricultural processing facilities, the Channel Islands Harbor marina businesses, and Port of Hueneme-adjacent operations. We service commercial refrigeration, walk-in coolers, commercial dishwashers (Hobart, Champion, Jackson), commercial ranges, and ice machines. Call us for commercial pricing. Our Thousand Oaks branch dispatches commercial-trained technicians for these calls.",
  },
  {
    question: 'What appliance brands are most common in Oxnard homes?',
    answer: "Mixed. Beachfront Oxnard Shores + Channel Islands Harbor luxury homes have Sub-Zero, Wolf, Thermador, Miele installations. RiverPark Estates and newer River Ridge developments concentrate Wolf + Sub-Zero + Bosch + KitchenAid. Mainstream mid-market neighborhoods (South Oxnard, Rose Park, downtown adjacent) have Samsung, LG, GE, Whirlpool, Maytag, Frigidaire. Our trucks carry OEM parts for both luxury and mass-market brands so we don't roll up empty-handed on either type of call.",
  },
  {
    question: 'Do you charge a distance surcharge for Oxnard?',
    answer: 'No. Oxnard is a regular Ventura County route city for our Thousand Oaks branch — we built it into the schedule specifically so we don\'t need to add distance fees. The $89 residential diagnostic is the same in Oxnard as it is in Thousand Oaks or Camarillo. What we quote is what you pay.',
  },
  {
    question: 'What is your warranty on Oxnard repairs?',
    answer: 'All residential and commercial repairs carry a 90-day warranty on parts and labor. If the same issue returns within that window, we come back at no additional charge. CSLB License #1138898 + BBB accredited.',
  },
];

const nearbyCities = [
  { name: 'Camarillo', slug: 'camarillo' },
  { name: 'Ventura', slug: 'ventura' },
  { name: 'Thousand Oaks', slug: 'thousand-oaks' },
  { name: 'Westlake Village', slug: 'westlake-village' },
  { name: 'Newbury Park', slug: 'newbury-park' },
  { name: 'Simi Valley', slug: 'simi-valley' },
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair in"
    headlineCity="Oxnard, CA"
    subheadline="Same-day service across Oxnard Shores, Channel Islands Harbor, River Ridge, and Downtown. Sub-Zero, Wolf, Viking, and all major brands. Residential + commercial. $89 diagnostic — waived with repair."
    zips={zips}
    tier={2}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Oxnard's split — beachfront luxury, RiverPark new-builds, downtown working-class kitchens"
    paragraphs={introParagraphs}
    bookingTitle="Oxnard Service"
    bookingSub="Available Today"
  />

  <ServicesGrid
    cityName={cityName}
    headline="Appliance Repair Services in Oxnard"
    services={services}
  />

  <CustomNarrative
    headline={marineNarrative.headline}
    paragraphs={marineNarrative.paragraphs}
    background="white"
  />

  <ServiceArea
    cityName={cityName}
    headline="Oxnard Neighborhoods We Service"
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={[]}
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Repairs in Oxnard"
    jobs={recentJobs}
  />

  <CustomNarrative
    headline={commercialNarrative.headline}
    paragraphs={commercialNarrative.paragraphs}
    background="gray"
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="Why Oxnard Residents and Businesses Call Us"
    reasons={whyReasons}
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What Oxnard Clients Say"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Repair Pricing in Oxnard"
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="Frequently Asked Questions — Oxnard"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby Ventura County Cities"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Schedule Your Oxnard Repair Today"
    body="Same-day service across all four Oxnard ZIPs. Beachfront, RiverPark, downtown, commercial. No distance surcharge."
  />
</CityLayoutV2>
