---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import CustomNarrative from '../components/cities/v2/CustomNarrative.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES, MAIN_PHONE, isPlaceholderPhone } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

const citySlug = 'newport-beach';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = 'Newport Beach';
const zips = ['92660', '92661', '92662', '92663', '92657', '92625'];

const phone = branch.phone;
const phoneRaw = `+1${phone.replace(/\D/g, '')}`;

const title = `Appliance Repair Newport Beach CA — Same Day | Balboa Island · Corona del Mar · Newport Coast | ${phone}`;
const description = `Same-day appliance repair in Newport Beach, CA. Balboa Island, Corona del Mar, Newport Coast, Lido Isle, The Peninsula. Salt air specialists. Sub-Zero, Wolf, Miele. Licensed, OEM parts, 90-day warranty. Call ${phone}.`;
const canonical = 'https://samedayappliance.repair/newport-beach/';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { '@type': 'City', name: 'Newport Beach', sameAs: 'https://en.wikipedia.org/wiki/Newport_Beach,_California' },
    { '@type': 'Neighborhood', name: 'Balboa Island' },
    { '@type': 'Neighborhood', name: 'Corona del Mar' },
    { '@type': 'Neighborhood', name: 'Newport Coast' },
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$$',
  license: 'CA BHGS #A49573'

};

const introParagraphs = [
  "Newport Beach is one of the most desirable addresses in California — and the Pacific Ocean is about 200 feet from most of it. That proximity is wonderful for residents. It's harder on appliances.",
  "Salt air is the defining environmental factor for appliance maintenance in Newport Beach. Refrigerator condenser coils that would last 12–18 months in an inland city accumulate salt-laden particulate much faster here — particularly in oceanfront properties on Balboa Island, The Peninsula, and the waterfront homes in Corona del Mar. A coil that's overloaded makes the compressor work harder, shortens its life, and drives up energy costs. We inspect and clean condenser coils on every Newport Beach refrigerator call — it's consistently relevant here in a way it isn't inland.",
  "Outdoor kitchen appliances — outdoor-rated refrigerators, ice makers, BBQ igniter systems — see this effect even more acutely. Salt air exposure on an outdoor unit is dramatically more aggressive than on indoor equipment. Igniter electrode corrosion, coil degradation, and control board moisture ingress are all accelerated in an oceanfront outdoor kitchen. We service and repair outdoor appliances throughout Newport Beach.",
  "Inside, the kitchens are serious: Sub-Zero, Wolf, Thermador, Miele, Gaggenau — standard in Newport Beach estates and high-rise units alike. Our technicians carry OEM parts for all of these on every service vehicle. We're also familiar with the access logistics for Newport Coast, Pelican Hill, Crystal Cove, and other gated communities.",
  `Diagnostic fee: <strong>$89</strong> — waived with repair. Written estimate before we start. <strong>90-day warranty</strong> on all parts and labor. Call <a href="tel:${phoneRaw}">${phone}</a>.`,
];

const services = [
  { icon: '🧊', name: 'Refrigerator Repair', slug: 'refrigerator', issues: 'Salt air coil inspection · Not cooling · Ice maker · Sub-Zero built-in', brands: 'Sub-Zero · Wolf · True · Samsung · LG · Thermador' },
  { icon: '🔥', name: 'Oven, Range & Steam Oven', slug: 'oven', issues: 'Dual-fuel · Steam combi · Temperature off · Salt air igniter corrosion', brands: 'Wolf · Thermador · Gaggenau · Miele · Viking · La Cornue' },
  { icon: '🌿', name: 'Outdoor Kitchen Appliances', slug: 'outdoor-appliance', issues: 'BBQ igniter corrosion · Outdoor fridge · Outdoor ice maker · Coastal wear', brands: 'Viking · Wolf · True · Lynx · Bull · Blaze · Hoshizaki' },
  { icon: '🍽️', name: 'Dishwasher Repair', slug: 'dishwasher', issues: "Panel-ready · Error codes · Control board · Not draining · Miele", brands: 'Miele · Gaggenau · Thermador · Bosch · Cove · KitchenAid' },
  { icon: '🫧', name: 'Washer & Dryer Repair', slug: 'washer', issues: 'Miele heat pump · Not draining · European models · Stackable', brands: 'Miele · LG · Samsung · Bosch · Whirlpool · Speed Queen' },
  { icon: '🍷', name: 'Wine Cellar & Cooler Repair', slug: 'wine-cellar', issues: 'Temperature off · Coastal humidity · WhisperKOOL · Sub-Zero wine', brands: 'Sub-Zero · EuroCave · True · WhisperKOOL · Liebherr · U-Line' },
  { icon: '🧊', name: 'Ice Machine & Ice Maker', slug: 'ice-machine', issues: 'Low production · Salt air corrosion · Built-in · Outdoor ice maker', brands: 'Sub-Zero · True · Scotsman · Hoshizaki · U-Line · GE' },
  { icon: '🔆', name: 'Cooktop & Range Hood', slug: 'cooktop', issues: 'Wolf star burner · Thermador induction · Hood systems · Igniter', brands: 'Wolf · Thermador · Gaggenau · Miele · Viking · Dacor' },
];

const saltAirTipNarrative = {
  headline: 'Salt Air Tip for Newport Beach',
  paragraphs: [
    "<strong>Salt air tip for Newport Beach:</strong> If your refrigerator has been running louder than usual, or cycling on and off more frequently — especially in an oceanfront property — the most likely cause is condenser coils loaded with salt-air particulate. Clean coils every 4–6 months in a coastal property, not the 12-month recommendation written for inland environments. We include this inspection on every Newport Beach fridge call.",
  ]
};

const neighborhoods = [
  { name: 'Balboa Island', zip: '92662', featured: true },
  { name: 'Corona del Mar', zip: '92625', featured: true },
  { name: 'Newport Coast', zip: '92657', featured: true },
  { name: 'Lido Isle', zip: '92663' },
  { name: 'The Peninsula', zip: '92661' },
  { name: 'Dover Shores', zip: '92660' },
  { name: 'Back Bay', zip: '92660' },
  { name: "Mariner's Mile", zip: '92660' },
  { name: 'Newport Coast / Pelican Hill', zip: '92657', featured: true },
  { name: 'Crystal Cove', zip: '92657', featured: true },
  { name: 'Harbor Ridge', zip: '92660' },
  { name: 'Big Canyon', zip: '92660' },
  { name: 'Bonita Canyon', zip: '92660' },
  { name: 'Belcourt', zip: '92660' },
];

const recentJobs = [
  {
    appliance: 'Sub-Zero Built-In',
    location: 'Balboa Island, 92662',
    quote: 'Running constantly, cycling every few minutes — much louder than usual',
    description: 'Balboa Island waterfront home — the Sub-Zero 48-inch column had condenser coils packed with salt-air particulate. In an oceanfront property this close to the bay, coil accumulation can happen in 4–5 months rather than the 12–18 months typical inland. Removed and thoroughly cleaned the coil assembly, replaced the condenser fan motor that had begun to seize from the added thermal load, confirmed door seals. Compressor cycling normalized immediately. Homeowner now on a 5-month coil inspection schedule for this property.',
    outcome: '✓ Same day · Salt air coils cleaned · Fan motor replaced · 5-month plan'
  },
  {
    appliance: 'Wolf Dual-Fuel Range',
    location: 'Corona del Mar, 92625',
    quote: "Three burners sparking constantly, oven won't come to temperature",
    description: 'CdM oceanfront estate — Wolf 48-inch dual-fuel in a custom kitchen with ocean-facing windows left open regularly. Three surface igniter electrodes corroded from salt air moisture ingress; oven igniter drawing weak current. Replaced all three surface electrodes and the oven igniter with OEM Wolf parts, sealed the electrode wells against moisture, calibrated the oven (running 20°F low). Recommended keeping the kitchen ventilated with the hood rather than the windows when cooking — reduces direct salt air exposure to the igniter surfaces.',
    outcome: '✓ Same day · OEM Wolf · Salt air cause explained · Calibrated'
  },
  {
    appliance: 'True Outdoor Refrigerator',
    location: 'Newport Coast, 92657',
    quote: 'Outdoor fridge by the pool not cooling — two years old',
    description: 'Newport Coast estate — True outdoor-rated undercounter refrigerator on a covered terrace. Even with the roofline coverage, coastal air had accelerated coil corrosion significantly for a two-year-old unit. Cleaned and treated the condenser coil assembly, replaced the fan, inspected and reseated the door gasket showing early UV degradation. Back to 38°F. Recommended annual coil maintenance for outdoor units in coastal locations — the difference between 2-year and 6-year service life.',
    outcome: '✓ Same day · Outdoor True · Coastal wear explained · Annual plan set'
  },
  {
    appliance: 'Miele Dishwasher',
    location: 'Lido Isle, 92663',
    quote: 'F70 error, water in the base — machine completely locked out',
    description: 'Miele G 7000 panel-front on Lido Isle — F70 flood protection error from water in the base pan. Found the water inlet connection had developed a slow seep from vibration over time. Cleared the base pan, tightened and re-sealed the inlet connection, ran the Miele anti-flood reset procedure, tested three full cycles. Panel cabinetry came out and went back without a mark. Homeowner uses the home as a seasonal residence — explained how to run a maintenance cycle at the start of each season to prevent standing water issues.',
    outcome: '✓ Same day · Miele F70 resolved · Panel intact · Seasonal maintenance explained'
  },
];

const whyReasons = [
  {
    iconKey: 'team' as const,
    title: 'Salt Air Specialists',
    body: 'Coastal corrosion affects condenser coils, igniter electrodes, and outdoor appliance components faster than any other factor in Newport Beach. We check for salt-air damage proactively on every relevant NB call — and we know the maintenance schedule that actually works in a coastal environment.'
  },
  {
    iconKey: 'parts' as const,
    title: 'Outdoor Kitchen Experts',
    body: 'Outdoor refrigerators, outdoor ice makers, BBQ igniter systems — coastal exposure accelerates wear dramatically. We repair and service outdoor kitchen appliances throughout Newport Beach, and advise on the maintenance that extends their life near the ocean.'
  },
  {
    iconKey: 'shield' as const,
    title: 'Gated Community Ready',
    body: 'Newport Coast, Pelican Hill, Crystal Cove, Harbor Ridge — we coordinate gate access before arrival, work with property managers and household staff, and handle the logistics professionally. Estate managers welcome.'
  },
  {
    iconKey: 'clock' as const,
    title: '90-Day Warranty, OEM Only',
    body: 'Every repair backed by 90 days on parts and labor. Genuine OEM parts only — never aftermarket on luxury systems. $89 diagnostic waived with repair. Written estimate before we start. California licensed, BBB A+.'
  },
];

const testimonials = [
  {
    stars: 5,
    text: '"Sub-Zero was running constantly and getting loud. Same Day came to our Balboa Island home, cleaned the salt-air coils, replaced the fan motor, and explained the 5-month maintenance schedule for a waterfront property. Immediately quieter. We had no idea the ocean proximity was the issue — very knowledgeable."',
    author: '— Sarah K., Balboa Island, Newport Beach'
  },
  {
    stars: 5,
    text: '"Wolf range in our CdM home — three burners sparking constantly and oven temperature way off. Tech came same day, identified the salt air corrosion on the igniters, replaced everything with OEM Wolf parts, calibrated the oven. Also explained how the ocean windows were contributing. Professional, thorough, and genuinely expert on the coastal factor."',
    author: '— Michael T., Corona del Mar, Newport Beach'
  },
  {
    stars: 5,
    text: "\"Miele dishwasher with F70 error at our Lido Isle home. Tech came out, cleared the issue, handled the panel cabinetry perfectly, and gave us a seasonal maintenance plan since we're not here year-round. Everything you want from a luxury appliance service — knowledgeable, clean, efficient, transparent pricing.\"",
    author: '— Jennifer L., Lido Isle, Newport Beach'
  },
];

const pricingTiers = [
  { appliance: 'Sub-Zero / Wolf / Gaggenau', range: '$300 – $800+', note: 'OEM parts · Salt air coil inspection · Coastal maintenance', featured: true },
  { appliance: 'Outdoor Kitchen Appliances', range: '$200 – $600', note: 'Coastal corrosion · Outdoor fridge · BBQ igniter · Ice maker', featured: true },
  { appliance: 'Thermador / Miele / Viking', range: '$250 – $600+', note: 'OEM parts · Panel-ready · Steam oven · Built-in' },
  { appliance: 'Refrigerator (standard)', range: '$200 – $450', note: 'Salt air coil clean · Fan motor · Ice maker · Thermostat' },
  { appliance: 'Dishwasher / Washer / Dryer', range: '$150 – $450', note: 'Panel-ready · Miele heat pump · European models' },
  { appliance: 'Diagnostic Fee', range: '$89', note: 'Waived when you proceed with the repair' },
];

const faqs = [
  {
    question: 'Do you offer same-day appliance repair in Newport Beach, CA?',
    answer: 'Yes. Our technicians cover all of Newport Beach — Balboa Island, Corona del Mar, Newport Coast, Lido Isle, The Peninsula, Dover Shores, Back Bay, and all ZIP codes 92660, 92661, 92662, 92663, 92657, and 92625. Call before noon for same-day afternoon service.'
  },
  {
    question: 'Does salt air in Newport Beach affect appliances faster than inland?',
    answer: 'Yes, significantly. Salt air accelerates corrosion on refrigerator condenser coils, dishwasher control boards, and outdoor appliance components. In Newport Beach — particularly on Balboa Island, The Peninsula, and oceanfront homes in Corona del Mar — condenser coils that would last 12–18 months inland may need attention every 4–6 months. We check coil condition and inspect for salt-related corrosion on every Newport Beach refrigerator call.'
  },
  {
    question: 'Do you repair Sub-Zero, Wolf, Miele, and Thermador appliances in Newport Beach?',
    answer: 'Yes. Sub-Zero, Wolf, Thermador, Miele, Gaggenau, and Viking are standard in Newport Beach kitchens. Our technicians carry OEM parts for these brands on every service vehicle and are experienced with the built-in and panel-ready configurations common in Newport Beach estates and high-rise condos.'
  },
  {
    question: 'Can you service appliances in Newport Beach gated communities?',
    answer: 'Yes. Our technicians are familiar with the access protocols for Newport Coast, Pelican Hill, Crystal Cove, and other gated communities in the Newport Beach area. We coordinate guard gate access before arrival and work with property managers and household staff when needed.'
  },
  {
    question: 'Do you repair outdoor kitchen appliances in Newport Beach?',
    answer: 'Yes. Newport Beach properties frequently have outdoor entertaining areas with outdoor-rated refrigerators, ice makers, and BBQ igniter systems. Outdoor appliances in a coastal environment see accelerated wear from salt air — we repair and service these and advise on protective maintenance.'
  },
  {
    question: 'What is your diagnostic fee in Newport Beach?',
    answer: 'Our diagnostic fee is $89, waived when you proceed with the repair. We provide a complete written estimate before starting any work. Luxury brand repairs may run higher due to OEM part pricing — always disclosed upfront.'
  },
  {
    question: 'Do you also serve Irvine, Laguna Beach, and Costa Mesa?',
    answer: 'Yes. Our Newport Beach service area extends to Irvine, Laguna Beach, Costa Mesa, Huntington Beach, and all of coastal Orange County.'
  },
];

const nearbyCities = [
  { name: 'Irvine', slug: 'irvine' },
  { name: 'Laguna Beach', slug: 'laguna-beach' },
  { name: 'Costa Mesa', slug: 'costa-mesa' },
  { name: 'Huntington Beach', slug: 'huntington-beach' },
  { name: 'Laguna Niguel', slug: 'laguna-niguel' },
  { name: 'Dana Point', slug: 'dana-point' },
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair"
    headlineCity="Newport Beach, CA"
    subheadline="Coastal living puts unique demands on appliances — salt air accelerates coil corrosion, outdoor kitchen equipment weathers hard, and luxury kitchens deserve expert service. Sub-Zero, Wolf, Miele, Thermador. Same-day service, OEM parts, 90-day warranty. Gated communities welcome."
    zips={zips}
    tier={2}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance Repair in Newport Beach — What the Coast Changes"
    paragraphs={introParagraphs}
    bookingTitle="Newport Beach Service"
    bookingSub="All ZIP codes · Gated ready · Same day"
  />

  <ServicesGrid
    cityName={cityName}
    headline="What We Repair in Newport Beach"
    services={services}
  />

  <CustomNarrative
    headline={saltAirTipNarrative.headline}
    paragraphs={saltAirTipNarrative.paragraphs}
    background="white"
  />

  <ServiceArea
    cityName={cityName}
    headline="All of Newport Beach"
    subheadline="From Balboa Island to Newport Coast — every neighborhood and ZIP code"
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={[]}
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Jobs in Newport Beach"
    subhead="Real calls from the Newport Beach area — coastal homes, gated estates, outdoor kitchens."
    jobs={recentJobs}
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="Why Newport Beach Calls Us Back"
    reasons={whyReasons}
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What Newport Beach Clients Are Saying"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Appliance Repair Costs in Newport Beach"
    subhead="Written estimate before we start. $89 diagnostic — waived with repair. OEM parts only."
    tiers={pricingTiers}
    footnote="OEM parts for luxury brands are manufacturer-priced. Part cost and labor are disclosed separately in every written estimate — transparent pricing."
  />

  <FAQAccordion
    cityName={cityName}
    headline="Questions Newport Beach Clients Ask"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby Areas"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance issue in Newport Beach?"
    body="Balboa Island · Corona del Mar · Newport Coast · Salt air specialists · Sub-Zero · Wolf · Outdoor kitchens. $89 diagnostic waived with repair. 90-day warranty."
  />
</CityLayoutV2>
