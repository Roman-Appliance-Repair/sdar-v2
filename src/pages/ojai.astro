---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

const citySlug = 'ojai';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = "Ojai";
const zips = ['93022', '93023'];

const phoneRaw = `+1${branch.phone.replace(/\D/g, '')}`;

const title = `Appliance Repair Ojai CA | Same Day Service | ${branch.phone}`;
const description = "Same-day appliance repair in Ojai, CA. Downtown, Meiners Oaks, East End, Mira Monte, Oak View. Sub-Zero, Wolf, Viking, Miele specialists. $89 diagnostic — waived with repair.";
const canonical = 'https://samedayappliance.repair/ojai/';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { '@type': 'City', name: 'Ojai', sameAs: 'https://en.wikipedia.org/wiki/Ojai,_California' },
    { '@type': 'Place', name: 'Downtown Ojai' },
    { '@type': 'Place', name: 'East End' },
    { '@type': 'Place', name: 'Meiners Oaks' },
    { '@type': 'Place', name: 'Oak View' },
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$$',
  license: 'CA BHGS #A49573'

};

const introParagraphs = [
  "Ojai is a 7,500-resident town tucked into a valley about 15 miles inland from Ventura. The character of the appliance work here is meaningfully different from anywhere else in our service area: the housing stock is dominated by ranch properties on the East End, restored Downtown craftsman bungalows along Signal + Matilija + Montgomery, Meiners Oaks farmhouses west of downtown along El Roblar, mid-market homes in Mira Monte, and the Oak View community south down the 33. The kitchens, however, are not what a 7,500-person town suggests. Sub-Zero, Wolf, Viking, Thermador, and Miele installs are common across Ojai's higher-end properties — the East End in particular has a long-running concentration of luxury kitchens.",
  "Two things shape the service work here. First, Santa Ana wind events and year-round agricultural dust from surrounding citrus and avocado operations push valley dust deep into outdoor-facing appliance components — we recommend 4-6 month refrigerator coil intervals for East End and Upper Ojai properties versus the 8-12 month interval that works for most inland service. Second, Ojai's older Downtown and Meiners Oaks housing stock has been renovated repeatedly over the decades, which means modern luxury appliances frequently sit on legacy electrical and plumbing — we verify the service before energizing a new control board, and we tell homeowners up front when something is appliance-side scope versus when it needs an electrician or plumber separately.",
  `Our Thousand Oaks branch covers Ojai on the regular Ventura County schedule. The 30-minute drive from Thousand Oaks via the 33 is short enough that we don't add a distance surcharge — same $89 residential diagnostic in Ojai as in Thousand Oaks, Camarillo, or Ventura. Call <a href="tel:${phoneRaw}">${branch.phone}</a> — someone with our actual Ventura County schedule picks up.`,
];

const services = [
  { icon: '❄️', name: 'Refrigerator Repair', slug: 'refrigerator' },
  { icon: '🫧', name: 'Washer Repair', slug: 'washer' },
  { icon: '💨', name: 'Dryer Repair', slug: 'dryer' },
  { icon: '🍽️', name: 'Dishwasher Repair', slug: 'dishwasher' },
  { icon: '🔥', name: 'Oven & Range Repair', slug: 'oven' },
  { icon: '🍳', name: 'Stove Repair', slug: 'stove' },
  { icon: '📻', name: 'Microwave Repair', slug: 'microwave' },
  { icon: '🧊', name: 'Ice Maker Repair', slug: 'ice-maker' },
  { icon: '🍷', name: 'Wine Cooler Repair', slug: 'wine-cooler' },
  { icon: '🧊', name: 'Freezer Repair', slug: 'freezer' },
  { icon: '🗑️', name: 'Garbage Disposal Repair', slug: 'garbage-disposal' },
  { icon: '♨️', name: 'Cooktop Repair', slug: 'cooktop' },
];

const neighborhoods = [
  { name: 'Downtown Ojai', zip: '93023' },
  { name: 'East End', zip: '93023' },
  { name: 'Meiners Oaks', zip: '93023' },
  { name: 'Mira Monte', zip: '93023' },
  { name: 'Oak View', zip: '93022' },
  { name: 'Upper Ojai', zip: '93023' },
];

const recentJobs = [
  {
    appliance: 'Sub-Zero 736TR',
    location: 'East End',
    quote: "Sub-Zero 736TR — East End estate, dual-zone temp drift after dust storm",
    description: "Sub-Zero 736TR built-in in an East End ranch property off Reeves Road — Santa Ana wind event the prior week had pushed fine valley dust deep into the condenser cabinet. Refrigerator zone tracking 4°F warm, freezer zone fine. Coil cleaning was substantially overdue (estate had been unoccupied for two months). Full coil + condenser cabinet cleaning, fan motor inspection (healthy), 24-hour temperature monitoring confirmed both zones recovered to spec. Ojai's East End and Upper Ojai sit in the path of seasonal Santa Ana wind events that drive valley + agricultural dust into outdoor-facing appliance components — we tell East End owners to expect 4-6 month coil intervals rather than 8-12 month, especially after major wind weeks.",
    outcome: '✓ Same day · Coil + cabinet cleaning service · 2.5 hours'
  },
  {
    appliance: "Viking 48\" range",
    location: 'Downtown Ojai',
    quote: "Viking 48\" range — Downtown Ojai bungalow, oven igniter failure",
    description: "Viking VGR548 48\" gas range in a Downtown Ojai craftsman bungalow off Signal Street — oven side wouldn't ignite, cooktop burners working fine. Oven igniter (glow-bar type) had failed at the 9-year mark — element was visibly broken at the central section. Replaced with Viking OEM glow-bar igniter, verified gas-valve sequencing, ran two test bakes. Downtown Ojai's older bungalow housing stock has a meaningful concentration of Viking + Wolf installs — kitchens here were the early adopters of pro-grade residential cooking equipment back in the 1990s-2000s. We see Viking igniter failures clustering at the 8-12 year mark on these original installs.",
    outcome: '✓ Same day · Viking OEM glow-bar oven igniter · 1.5 hours'
  },
  {
    appliance: 'Miele dishwasher',
    location: 'Meiners Oaks',
    quote: "Miele dishwasher — Meiners Oaks farmhouse, F70 water leak code",
    description: "Miele G7000 series dishwasher in a Meiners Oaks farmhouse off El Roblar — F70 fault code (water leak detected by float). Pan was dry; the false trigger turned out to be the float-switch wire harness routing where it had migrated against a sharp edge of the pan support and worn through the insulation, intermittently grounding the float circuit. Re-routed the harness, applied protective sleeving, reset the F70 fault, ran two test cycles. Meiners Oaks farmhouses tend to have older detached laundry/utility-room construction where the appliance sits on slightly uneven flooring — vibration over time can migrate wiring out of original routing. Worth knowing for older Ojai-area service work.",
    outcome: '✓ Same day · Miele harness re-routing + protective sleeve · 2 hours'
  },
];

const pricingTiers = [
  { appliance: 'Residential Diagnostic', range: '$89', note: 'No distance surcharge · Credited toward repair · Written estimate' },
  { appliance: 'Standard Repair Range', range: '$150–$350', note: 'Parts + labor · OEM parts · 90-day warranty' },
  { appliance: 'Luxury Brand Repair', range: '$250–$600+', note: 'Sub-Zero, Wolf, Viking, Thermador, Miele · OEM parts', featured: true },
  { appliance: '90-Day Warranty', range: 'All Repairs', note: 'Parts + labor · Same-issue return at no charge' },
];

const faqs = [
  {
    question: "Do you service Ojai? It's a small town off the main valley.",
    answer: "Yes. Our Thousand Oaks branch runs Ojai on the regular Ventura County route. Ojai is a 30-minute drive from Thousand Oaks via the 33 — short enough that we don't add a distance surcharge. Coverage spans Downtown Ojai, the East End, Meiners Oaks, Mira Monte, Oak View, and Upper Ojai. Same-day service available when you call before noon."
  },
  {
    question: 'What appliance brands are most common in Ojai homes?',
    answer: "Sub-Zero, Wolf, Viking, Miele, and Thermador are common across Ojai's higher-end ranch properties (East End, Upper Ojai), restored Downtown bungalows, and Meiners Oaks farmhouses. Mainstream brands (KitchenAid, GE Profile, Bosch, LG, Samsung) appear regularly in Mira Monte and Oak View. Our Thousand Oaks truck stocks OEM parts for both luxury and mainstream so we don't roll up to an Ojai call empty-handed."
  },
  {
    question: "Does Ojai's climate affect appliance service intervals?",
    answer: "Yes — and differently than the LA basin. Ojai sits in a valley that gets seasonal Santa Ana wind events plus year-round agricultural dust from surrounding citrus and avocado operations. Outdoor-facing appliance components (refrigerator condenser coils, range igniters, outdoor BBQ grills, ice makers in pool cabanas) accumulate dust faster than typical inland exposure. We recommend 4-6 month coil-cleaning intervals on East End and Upper Ojai properties, especially after major wind weeks. Downtown and Meiners Oaks see more typical 6-9 month intervals."
  },
  {
    question: 'Do you charge a distance surcharge for Ojai?',
    answer: "No. Ojai is on our regular Thousand Oaks branch Ventura County route. The $89 residential diagnostic is the same in Ojai as it is in Thousand Oaks, Camarillo, or Ventura. What we quote is what you pay."
  },
  {
    question: 'What is your warranty on Ojai repairs?',
    answer: "All repairs carry a 90-day warranty on parts and labor. If the same issue returns within that window, we come back at no additional charge. BHGS #A49573 + BBB accredited."
  },
];

const nearbyCities = [
  { name: 'Ventura', slug: 'ventura' },
  { name: 'Oxnard', slug: 'oxnard' },
  { name: 'Camarillo', slug: 'camarillo' },
  { name: 'Thousand Oaks', slug: 'thousand-oaks' },
  { name: 'Westlake Village', slug: 'westlake-village' },
  { name: 'Newbury Park', slug: 'newbury-park' },
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair in"
    headlineCity="Ojai, CA"
    subheadline="Same-day service across Downtown Ojai, the East End, Meiners Oaks, Mira Monte, and Oak View. Sub-Zero, Wolf, Viking, Miele specialists. $89 diagnostic — waived with repair."
    zips={zips}
    tier={3}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Ojai's character — small valley town with big-kitchen appliances"
    paragraphs={introParagraphs}
    bookingTitle="Ojai Service"
    bookingSub="Available Today"
  />

  <ServicesGrid
    cityName={cityName}
    headline="Appliance Repair Services in Ojai"
    services={services}
  />

  <ServiceArea
    cityName={cityName}
    headline="Ojai Neighborhoods We Service"
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={[]}
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Repairs in Ojai"
    jobs={recentJobs}
  />

  <PricingCards
    cityName={cityName}
    headline="Repair Pricing in Ojai"
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="Frequently Asked Questions — Ojai"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby Ventura County Cities"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Schedule Your Ojai Repair Today"
    body="Same-day service across Ojai. Downtown, East End, Meiners Oaks, Mira Monte, Oak View. No distance surcharge."
  />
</CityLayoutV2>
