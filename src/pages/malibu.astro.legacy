        <a href="/west-hollywood/" class="nearby-link">West Hollywood</a>
        <a href="/burbank/" class="nearby-link">Burbank</a>
      </div>
    </div>
  </section>

  <!-- BOTTOM CTA -->
  <section class="ml-bottom-cta">
    <div class="container">
      <div class="bottom-cta__inner">
        <div class="bottom-cta__text">
          <h2>Appliance broken in Malibu?</h2>
          <p>Beach house · Canyon estate · Vacation rental · BBQ · All of 90265. $89 diagnostic waived with repair. 90-day warranty. OEM parts. Salt air experts.</p>
        </div>
        <div class="bottom-cta__actions">
          <a href={`tel:${city.phoneRaw}`} class="btn-primary btn-large">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.29h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            {city.phone}
          </a>
          <a href="/book/" class="btn-secondary btn-large">Book Online</a>
        </div>
        <div class="bottom-cta__nap">
          <span>Same Day Appliance Repair — Malibu, CA 90265</span>
          <span>·</span>
          <a href={`mailto:${city.email}`}>{city.email}</a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  :root {
    --ml-red: #C8102E;
    --ml-black: #0a0a0a;
    --ml-gray: #f5f5f5;
    --ml-border: #e2e2e2;
    --ml-text: #1a1a1a;
    --ml-muted: #6b6b6b;
  }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }

  .ml-hero { background: var(--ml-black); color: white; padding: 80px 0 60px; }
  .ml-hero__inner { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
  .ml-hero__eyebrow { font-size: 13px; font-weight: 500; color: var(--ml-red); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 16px; }
  .ml-hero__h1 { font-size: clamp(36px, 5vw, 52px); font-weight: 700; line-height: 1.1; margin-bottom: 20px; color: white; }
  .ml-hero__accent { color: var(--ml-red); }
  .ml-hero__sub { font-size: 17px; line-height: 1.6; color: rgba(255,255,255,0.75); margin-bottom: 32px; max-width: 520px; }
  .ml-hero__ctas { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 24px; }
  .ml-hero__rating { display: flex; align-items: center; gap: 10px; }
  .stars { color: #FFD700; font-size: 18px; letter-spacing: 2px; }
  .rating-text { font-size: 14px; color: rgba(255,255,255,0.7); }
  .ml-hero__img-wrap img { width: 100%; height: auto; border-radius: 12px; object-fit: cover; }

  .btn-primary { display: inline-flex; align-items: center; gap: 8px; background: var(--ml-red); color: white; padding: 14px 28px; border-radius: 8px; font-weight: 600; font-size: 16px; text-decoration: none; transition: background 0.2s; }
  .btn-primary:hover { background: #a50e25; }
  .btn-secondary { display: inline-flex; align-items: center; gap: 8px; background: transparent; color: white; padding: 14px 28px; border-radius: 8px; font-weight: 600; font-size: 16px; text-decoration: none; border: 1.5px solid rgba(255,255,255,0.35); }
  .btn-large { padding: 16px 36px; font-size: 17px; }
  .ml-bottom-cta .btn-secondary { color: var(--ml-text); border-color: var(--ml-border); }

  .trust-bar { background: var(--ml-red); padding: 16px 0; }
  .trust-bar__inner { display: flex; justify-content: space-between; flex-wrap: wrap; gap: 12px; }
  .trust-item { display: flex; align-items: center; gap: 8px; color: white; font-size: 14px; font-weight: 500; }

  .ml-intro { padding: 72px 0; background: white; }
  .ml-intro__inner { display: grid; grid-template-columns: 1fr 340px; gap: 60px; align-items: start; }
  .ml-intro__text h2 { font-size: 28px; font-weight: 700; color: var(--ml-black); margin-bottom: 20px; }
  .ml-intro__text p { font-size: 16px; line-height: 1.7; color: var(--ml-text); margin-bottom: 16px; }
  .ml-tip { display: flex; gap: 14px; background: #f0f7ff; border: 1px solid #b8d4f0; border-radius: 10px; padding: 16px 20px; margin-top: 24px; }
  .ml-tip__icon { font-size: 20px; flex-shrink: 0; }
  .ml-tip__text { font-size: 14px; color: var(--ml-text); line-height: 1.6; }
  .cta-box { background: var(--ml-black); color: white; border-radius: 12px; padding: 32px; text-align: center; position: sticky; top: 80px; }
  .cta-box__title { font-size: 18px; font-weight: 700; margin-bottom: 4px; }
  .cta-box__sub { font-size: 13px; color: rgba(255,255,255,0.6); margin-bottom: 24px; }
  .cta-box__phone { display: block; font-size: 24px; font-weight: 700; color: var(--ml-red); text-decoration: none; margin-bottom: 12px; }
  .cta-box__book { display: block; font-size: 15px; color: white; text-decoration: none; padding: 12px; border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; margin-bottom: 16px; }
  .cta-box__hours { font-size: 12px; color: rgba(255,255,255,0.5); }

  .section-title { font-size: 30px; font-weight: 700; color: var(--ml-black); margin-bottom: 8px; text-align: center; }
  .section-sub { font-size: 16px; color: var(--ml-muted); text-align: center; margin-bottom: 40px; }

  .ml-services { padding: 72px 0; background: var(--ml-gray); }
  .services-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
  .service-card { background: white; border: 1px solid var(--ml-border); border-radius: 12px; padding: 24px 20px; text-decoration: none; color: var(--ml-text); transition: box-shadow 0.2s, transform 0.2s; display: block; }
  .service-card:hover { box-shadow: 0 4px 24px rgba(0,0,0,0.1); transform: translateY(-2px); }
  .service-card--highlight { border-color: var(--ml-red); background: #fff5f7; }
  .service-card__icon { font-size: 28px; margin-bottom: 10px; }
  .service-card__name { font-size: 16px; font-weight: 600; color: var(--ml-black); margin-bottom: 8px; }
  .service-card__issues { font-size: 13px; color: var(--ml-muted); line-height: 1.5; margin-bottom: 8px; }
  .service-card__brands { font-size: 12px; color: var(--ml-muted); margin-bottom: 12px; }
  .service-card__cta { font-size: 13px; color: var(--ml-red); font-weight: 500; }

  /* LOCATIONS */
  .ml-locations { padding: 72px 0; background: var(--ml-black); color: white; }
  .locations-inner { display: grid; grid-template-columns: 1fr 260px; gap: 60px; align-items: start; }
  .locations-eyebrow { font-size: 13px; font-weight: 500; color: var(--ml-red); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 12px; }
  .locations-text h2 { font-size: 28px; font-weight: 700; color: white; margin-bottom: 20px; }
  .locations-text p { font-size: 15px; line-height: 1.7; color: rgba(255,255,255,0.75); margin-bottom: 24px; }
  .location-zones { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .lz-card { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); border-radius: 10px; padding: 16px; }
  .lz-title { font-size: 12px; font-weight: 600; color: var(--ml-red); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 10px; }
  .lz-items { display: flex; flex-direction: column; gap: 6px; }
  .lz-items span { font-size: 13px; color: rgba(255,255,255,0.75); }
  .locations-cta { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.15); border-radius: 14px; padding: 28px; text-align: center; position: sticky; top: 80px; }
  .lc-title { font-size: 16px; font-weight: 700; color: white; margin-bottom: 8px; }
  .lc-sub { font-size: 13px; color: rgba(255,255,255,0.6); margin-bottom: 24px; }
  .locations-cta .btn-primary { width: 100%; justify-content: center; margin-bottom: 12px; }
  .lc-note { font-size: 12px; color: rgba(255,255,255,0.4); }

  /* VACATION HOME */
  .ml-vacation { padding: 72px 0; background: white; }
  .vacation-inner { display: grid; grid-template-columns: 1fr 280px; gap: 60px; align-items: start; }
  .vacation-eyebrow { font-size: 13px; font-weight: 500; color: var(--ml-red); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 12px; }
  .vacation-text h2 { font-size: 28px; font-weight: 700; color: var(--ml-black); margin-bottom: 20px; }
  .vacation-text p { font-size: 15px; line-height: 1.7; color: var(--ml-text); margin-bottom: 16px; }
  .vacation-stats { display: flex; flex-direction: column; gap: 16px; }
  .vs-item { display: flex; gap: 14px; align-items: flex-start; background: var(--ml-gray); border-radius: 10px; padding: 16px; }
  .vs-icon { font-size: 22px; flex-shrink: 0; }
  .vs-text { font-size: 14px; color: var(--ml-text); line-height: 1.5; }

  .ml-recent { padding: 72px 0; background: var(--ml-gray); }
  .ml-recent h2 { font-size: 30px; font-weight: 700; color: var(--ml-black); margin-bottom: 8px; text-align: center; }
  .recent-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .recent-card { background: white; border: 1px solid var(--ml-border); border-radius: 12px; padding: 24px; }
  .recent-card__header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; flex-wrap: wrap; gap: 6px; }
  .recent-badge { background: var(--ml-red); color: white; font-size: 11px; font-weight: 600; padding: 3px 10px; border-radius: 20px; }
  .recent-location { font-size: 12px; color: var(--ml-muted); }
  .recent-card__title { font-size: 15px; font-weight: 600; color: var(--ml-black); margin-bottom: 10px; font-style: italic; }
  .recent-card__desc { font-size: 14px; color: var(--ml-text); line-height: 1.6; margin-bottom: 12px; }
  .recent-card__result { font-size: 13px; color: #2a7a2a; font-weight: 500; }

  .ml-why { padding: 72px 0; background: white; }
  .ml-why h2 { font-size: 30px; font-weight: 700; color: var(--ml-black); margin-bottom: 40px; text-align: center; }
  .why-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
  .why-card { background: var(--ml-gray); border-radius: 12px; padding: 28px 24px; }
  .why-icon { font-size: 28px; margin-bottom: 14px; }
  .why-title { font-size: 16px; font-weight: 600; color: var(--ml-black); margin-bottom: 10px; }
  .why-text { font-size: 14px; color: var(--ml-muted); line-height: 1.6; }

  .ml-reviews { padding: 72px 0; background: var(--ml-gray); }
  .ml-reviews h2 { font-size: 30px; font-weight: 700; color: var(--ml-black); margin-bottom: 40px; text-align: center; }
  .reviews-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .review-card { background: white; border: 1px solid var(--ml-border); border-radius: 12px; padding: 28px; }
  .review-stars { color: #FFD700; font-size: 18px; margin-bottom: 12px; }
  .review-text { font-size: 14px; color: var(--ml-text); line-height: 1.7; margin-bottom: 16px; font-style: italic; }
  .review-author { font-size: 13px; color: var(--ml-muted); font-weight: 500; }

  .ml-pricing { padding: 72px 0; background: white; }
  .pricing-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 20px; }
  .pricing-card { background: var(--ml-gray); border-radius: 10px; padding: 20px 24px; border: 1px solid var(--ml-border); }
  .pricing-card.featured { background: #fff5f7; border-color: var(--ml-red); }
  .pricing-card__appliance { font-size: 14px; color: var(--ml-muted); margin-bottom: 6px; }
  .pricing-card__range { font-size: 22px; font-weight: 700; color: var(--ml-black); margin-bottom: 6px; }
  .pricing-card.featured .pricing-card__range { color: var(--ml-red); }
  .pricing-card__note { font-size: 13px; color: var(--ml-muted); }

  .ml-faq { padding: 72px 0; background: var(--ml-gray); }
  .ml-faq h2 { font-size: 30px; font-weight: 700; color: var(--ml-black); margin-bottom: 40px; text-align: center; }
  .faq-list { max-width: 800px; margin: 0 auto; }
  .faq-item { border: 1px solid var(--ml-border); border-radius: 8px; background: white; margin-bottom: 10px; overflow: hidden; }
  .faq-question { padding: 18px 24px; font-size: 16px; font-weight: 600; color: var(--ml-black); cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; }
  .faq-question::after { content: '+'; font-size: 22px; color: var(--ml-red); flex-shrink: 0; margin-left: 16px; }
  details[open] .faq-question::after { content: '−'; }
  .faq-answer { padding: 0 24px 20px; font-size: 15px; line-height: 1.7; color: var(--ml-text); }

  .ml-nearby { padding: 48px 0; background: white; border-top: 1px solid var(--ml-border); }
  .ml-nearby h2 { font-size: 20px; font-weight: 600; color: var(--ml-black); margin-bottom: 20px; text-align: center; }
  .nearby-grid { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; }
  .nearby-link { padding: 8px 20px; border: 1px solid var(--ml-border); border-radius: 20px; font-size: 14px; color: var(--ml-text); text-decoration: none; transition: border-color 0.2s, color 0.2s; }
  .nearby-link:hover { border-color: var(--ml-red); color: var(--ml-red); }

  .ml-bottom-cta { padding: 72px 0; background: var(--ml-black); color: white; }
  .bottom-cta__inner { text-align: center; }
  .bottom-cta__text h2 { font-size: 34px; font-weight: 700; color: white; margin-bottom: 12px; }
  .bottom-cta__text p { font-size: 16px; color: rgba(255,255,255,0.7); margin-bottom: 32px; }
  .bottom-cta__actions { display: flex; gap: 12px; justify-content: center; margin-bottom: 24px; flex-wrap: wrap; }
  .bottom-cta__nap { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; font-size: 13px; color: rgba(255,255,255,0.4); }
  .bottom-cta__nap a { color: rgba(255,255,255,0.4); text-decoration: none; }

  @media (max-width: 1024px) {
    .services-grid { grid-template-columns: repeat(2, 1fr); }
