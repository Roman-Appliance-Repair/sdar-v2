---
// /ai-diagnostic/ — "Coming Soon" stub for the AI Appliance Diagnostic tool.
//
// Step 6: target page for the homepage Diagnostics teaser CTA. Full interactive
// widget (4-step wizard, brand selectors, AI mock results, PDF report, booking
// flow) lands post-launch as its own project.

import Layout from '../layouts/Layout.astro';
import { MAIN_PHONE } from '../data/branches';

const phoneE164 = '+1' + MAIN_PHONE.replace(/\D/g, '');
---

<Layout
  title="AI Appliance Diagnostic — Coming Soon | Same Day Appliance Repair"
  description="Get an instant likely-cause diagnosis and ballpark cost estimate for your appliance issue. Free AI-powered diagnostic tool launching soon."
>
  <section class="ai-diag-coming-soon">
    <div class="container">
      <div class="content">

        <div class="badge">
          <span class="ai-badge">AI</span>
          <span>Coming Soon</span>
        </div>

        <h1 class="page-title">
          Free AI <span class="text-gold">Appliance Diagnostic</span>
        </h1>

        <p class="page-subtitle">
          Our AI-powered diagnostic tool is in final development.
          Soon you'll be able to describe your appliance issue and
          get an instant likely-cause diagnosis, recommended fix,
          and ballpark cost estimate — all before you schedule a visit.
        </p>

        <div class="features-grid">
          <div class="feature">
            <div class="feature-icon" aria-hidden="true">◆</div>
            <div class="feature-text">
              <strong>Instant diagnosis</strong>
              <span>Symptom-based AI analysis</span>
            </div>
          </div>
          <div class="feature">
            <div class="feature-icon" aria-hidden="true">◆</div>
            <div class="feature-text">
              <strong>Cost estimate</strong>
              <span>Ballpark range before visit</span>
            </div>
          </div>
          <div class="feature">
            <div class="feature-icon" aria-hidden="true">◆</div>
            <div class="feature-text">
              <strong>PDF report</strong>
              <span>Share with technician</span>
            </div>
          </div>
          <div class="feature">
            <div class="feature-icon" aria-hidden="true">◆</div>
            <div class="feature-text">
              <strong>No commitment</strong>
              <span>Free, no signup required</span>
            </div>
          </div>
        </div>

        <div class="meantime-block">
          <h2 class="meantime-title">In the meantime</h2>
          <p class="meantime-desc">
            Speak directly with our team — we can usually identify
            the issue over the phone in 60 seconds.
          </p>
          <div class="cta-row">
            <a href={`tel:${phoneE164}`} class="cta-primary">
              Call {MAIN_PHONE}
            </a>
            <a href="/book/" class="cta-secondary">
              Book Online →
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>
</Layout>

<style>
  .ai-diag-coming-soon {
    --bg: #0a0a0a;
    --bg2: #151515;
    --bg3: #1a1a1a;
    --gold: #D4AF37;
    --red: #C8102E;
    --red-dark: #a00d24;
    --text: #ffffff;
    --text2: #d4d4d4;
    --text3: #888888;
    --border: rgba(255, 255, 255, 0.08);
    --border-gold: rgba(212, 175, 55, 0.4);

    background: var(--bg);
    color: var(--text);
    min-height: 80vh;
    padding: 120px 24px;
    display: flex;
    align-items: center;
  }

  .ai-diag-coming-soon .container {
    max-width: 880px;
    margin: 0 auto;
    width: 100%;
  }

  .content {
    text-align: center;
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: 'Cinzel', 'Playfair Display', serif;
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: var(--gold);
    margin-bottom: 32px;
  }

  .ai-badge {
    background: var(--red);
    color: #fff;
    font-family: 'Montserrat', sans-serif;
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.15em;
    padding: 5px 10px;
    border-radius: 2px;
  }

  .page-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(36px, 5vw, 56px);
    font-weight: 600;
    line-height: 1.1;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0 0 24px 0;
    color: var(--text);
  }

  .text-gold {
    color: var(--gold);
    font-style: italic;
  }

  .page-subtitle {
    font-family: 'Montserrat', sans-serif;
    font-size: 17px;
    line-height: 1.75;
    color: var(--text2);
    max-width: 640px;
    margin: 0 auto 56px auto;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    max-width: 640px;
    margin: 0 auto 56px auto;
  }

  .feature {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 20px;
    background: var(--bg2);
    border: 1px solid var(--border);
    text-align: left;
  }

  .feature-icon {
    color: var(--gold);
    font-size: 16px;
    line-height: 1;
  }

  .feature-text strong {
    display: block;
    font-family: 'Playfair Display', serif;
    font-size: 16px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 4px;
  }

  .feature-text span {
    font-family: 'Montserrat', sans-serif;
    font-size: 13px;
    color: var(--text3);
  }

  .meantime-block {
    margin-top: 64px;
    padding-top: 56px;
    border-top: 1px solid var(--border);
  }

  .meantime-title {
    font-family: 'Cinzel', 'Playfair Display', serif;
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.25em;
    color: var(--gold);
    margin: 0 0 16px 0;
  }

  .meantime-desc {
    font-family: 'Montserrat', sans-serif;
    font-size: 16px;
    color: var(--text2);
    margin: 0 0 32px 0;
    line-height: 1.7;
  }

  .cta-row {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta-primary,
  .cta-secondary {
    display: inline-flex;
    align-items: center;
    padding: 16px 32px;
    font-family: 'Montserrat', sans-serif;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .cta-primary {
    background: var(--red);
    color: #fff;
  }
  .cta-primary:hover,
  .cta-primary:focus-visible {
    background: var(--red-dark);
  }

  .cta-secondary {
    border: 1px solid var(--gold);
    color: var(--gold);
  }
  .cta-secondary:hover,
  .cta-secondary:focus-visible {
    background: var(--gold);
    color: var(--bg);
  }

  @media (max-width: 768px) {
    .ai-diag-coming-soon { padding: 80px 16px; }
    .features-grid { grid-template-columns: 1fr; }
    .cta-row { flex-direction: column; }
    .cta-primary,
    .cta-secondary { width: 100%; justify-content: center; }
  }

  @media (prefers-reduced-motion: reduce) {
    .cta-primary,
    .cta-secondary { transition: none; }
  }
</style>
