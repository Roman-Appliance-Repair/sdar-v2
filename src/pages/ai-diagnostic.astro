---
import Layout from '../layouts/Layout.astro';
import AIDiagnostic from '../components/AIDiagnostic.jsx';
import { BRANCHES } from '../data/branches';

const mainPhone = BRANCHES.find(b => b.slug === 'west-hollywood')?.phone ?? '(323) 870-4790';

const title = "Free Appliance Diagnostic — Same Day Appliance Repair";
const description = "Describe your appliance problem and get the most likely causes plus an estimated repair range — free, no obligation.";
---

<Layout title={title} description={description}>
  <main class="ai-diag-page">
    <div class="container">
      <header class="page-header">
        <div class="eyebrow"><span class="ai-tag">AI</span> Free Diagnostic</div>
        <h1>Free Appliance Diagnostic</h1>
        <p class="lede">
          Answer a few questions — we'll identify the most likely causes and give you an
          honest repair estimate. Free, no obligation.
        </p>
      </header>

      <AIDiagnostic phone={mainPhone} client:load />
    </div>
  </main>
</Layout>

<style>
  .ai-diag-page {
    background: #fafafa;
    padding: 64px 16px 96px;
    min-height: 70vh;
  }
  .container {
    max-width: 680px;
    margin: 0 auto;
  }
  .page-header {
    text-align: center;
    margin-bottom: 32px;
  }
  .eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #6b6b6b;
    margin-bottom: 16px;
  }
  .ai-tag {
    background: #C8102E;
    color: #fff;
    font-size: 10px;
    letter-spacing: 0.15em;
    padding: 4px 8px;
    border-radius: 3px;
  }
  h1 {
    font-size: clamp(1.8rem, 4vw, 2.4rem);
    font-weight: 800;
    line-height: 1.2;
    margin: 0 0 12px 0;
    color: #0a0a0a;
  }
  .lede {
    color: #6b6b6b;
    font-size: 1.05rem;
    line-height: 1.7;
    max-width: 540px;
    margin: 0 auto;
  }
  @media (max-width: 640px) {
    .ai-diag-page { padding: 40px 12px 64px; }
  }
</style>
