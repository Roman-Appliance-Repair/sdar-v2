---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import CustomNarrative from '../components/cities/v2/CustomNarrative.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

const citySlug = 'koreatown';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = 'Koreatown';
const zips = ['90005', '90006', '90020'];

const title = `Appliance Repair Koreatown LA | Apartments + Commercial Refrigeration`;
const description = "Same-day appliance repair in Koreatown, Los Angeles. Written tenant reports. LADWP hard water aware. OEM parts.";
const canonical = 'https://samedayappliance.repair/koreatown/';

const phoneRaw = `+1${branch.phone.replace(/\D/g, '')}`;

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { '@type': 'Place', name: 'Koreatown', sameAs: 'https://en.wikipedia.org/wiki/Koreatown,_Los_Angeles' }
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$',
  license: 'BHGS #A49573'

};

const introParagraphs = [
  "Koreatown is one of the densest neighborhoods in LA — high-density apartments and condos along Wilshire, Vermont, and the cross streets, layered over an exceptionally active commercial restaurant corridor. The appliance work here covers both worlds: in-unit stackable washers in apartment laundry closets, compact galley kitchens, and the commercial refrigeration that the restaurant density along 6th Street and Wilshire depends on.",
  "Tenants and building managers are most of our residential calls. The pattern we see often: a tenant's appliance breaks, the landlord needs documentation to authorize the repair, and the diagnostic report has to be in writing. We provide written tenant reports as standard — brand, model, what failed, what the repair involves, and the cost. Most property managers accept this as the basis for repair approval.",
  "On the commercial side — Wilshire, 6th Street, Vermont — Koreatown's restaurant density means commercial refrigeration calls move quickly. A reach-in cooler holding at 48°F isn't an inconvenience; it's a food-safety threshold and a lost-product clock. We treat these calls accordingly.",
  `LADWP water hardness across 90005, 90006, and 90020 runs 230–310 mg/L, and many of the older Koreatown buildings have galvanized supply lines that add iron to the baseline. The combined effect on dishwasher filters, washing machine pump filters, and ice maker inlet valves is real and consistent. Diagnostic fee is $89, credited toward repair. Call <a href="tel:${phoneRaw}">${branch.phone}</a> for same-day service.`,
  "<strong>Tenant tip for Koreatown:</strong> If your appliance is in a rental unit and your landlord needs to authorise the repair, call us first for the diagnostic. We'll give you a written report you can forward directly — brand, model, what failed, what the repair involves, and the cost. Most property managers accept this as the basis for repair approval. The $89 diagnostic fee is waived when the repair proceeds."
];

const twoContextsNarrative = {
  headline: 'Two Koreatown Contexts',
  paragraphs: [
    "Residential apartments and the restaurant corridor — we serve both."
  ],
  subSections: [
    {
      title: 'Residential — Apartments & Condos',
      paragraphs: [
        "In-unit stackable washers, compact galley kitchens, older building plumbing — the appliance landscape in Koreatown's residential buildings requires care with space and documentation. We work in tight spaces and provide written tenant diagnostic reports as standard. Samsung, LG, GE, Whirlpool — OEM parts on every vehicle.",
        "Written tenant reports · Compact kitchens · Stackable units."
      ]
    },
    {
      title: 'Commercial — Restaurant Corridor',
      paragraphs: [
        "Wilshire Blvd, 6th Street, Vermont Ave — Koreatown's restaurant density is among the highest in LA. When a reach-in cooler or commercial refrigerator fails during service, the cost of lost product exceeds the repair. We service commercial refrigeration in restaurant settings throughout the Koreatown corridor.",
        "Commercial refrigeration · Restaurant priority · Same day."
      ]
    }
  ]
};

const services = [
  { icon: '❄️', name: 'Refrigerator Repair', slug: 'refrigerator', issues: 'LADWP ice maker · Not cooling · Commercial reach-in · Fan motor', brands: 'Samsung · LG · GE · Whirlpool · True · Turbo Air' },
  { icon: '🫧', name: 'Washer Repair', slug: 'washer', issues: 'In-unit stackable · OE error · Not draining · Compact kitchen', brands: 'LG · Samsung · Whirlpool · Maytag · Bosch · Electrolux' },
  { icon: '💨', name: 'Dryer Repair + Vent Cleaning', slug: 'dryer', issues: 'Not heating · Thermal fuse · In-unit vent · Gas & electric', brands: 'LG · Samsung · GE · Maytag · Whirlpool · Electrolux' },
  { icon: '🍽️', name: 'Dishwasher Repair', slug: 'dishwasher', issues: 'LADWP scale · Not draining · E24 · Older building plumbing', brands: 'Bosch · Samsung · LG · GE · KitchenAid · Whirlpool' },
  { icon: '🔥', name: 'Oven, Range & Stove', slug: 'oven', issues: 'Not heating · Gas igniter · Temperature off · Compact range', brands: 'GE · Samsung · LG · KitchenAid · Whirlpool · Bosch' },
  { icon: '🧊', name: 'Freezer & Ice Maker Repair', slug: 'freezer', issues: 'LADWP inlet valve · Not freezing · Ice stopped · Commercial', brands: 'Samsung · LG · GE · Whirlpool · True · Manitowoc' },
  { icon: '🏪', name: 'Commercial Refrigeration', slug: 'commercial-refrigerator', issues: 'Reach-in cooler · Restaurant priority · Not cooling · Condenser', brands: 'True · Turbo Air · Beverage-Air · Hoshizaki · Manitowoc' },
  { icon: '♨️', name: 'Cooktop & Range Hood', slug: 'cooktop', issues: 'Gas igniter · Burner · Induction · Hood motor', brands: 'GE · Samsung · Bosch · KitchenAid · LG · Broan' }
];

const neighborhoods = [
  { name: 'Wilshire Blvd corridor', zip: '90005', featured: true },
  { name: 'Vermont Ave corridor', zip: '90006', featured: true },
  { name: '6th Street restaurant row', zip: '90005', featured: true },
  { name: 'Western Ave area', zip: '90005' },
  { name: 'Oxford Ave / Serrano Ave', zip: '90020' },
  { name: 'Olympic Blvd corridor', zip: '90006' }
];

const recentJobs = [
  {
    appliance: 'LG Stackable Washer',
    location: 'Wilshire corridor, 90005',
    quote: 'OE error — machine stopped mid-cycle, laundry room flooded',
    description: "Mid-rise apartment on the Wilshire corridor — LG stackable unit in a narrow in-unit laundry closet, OE drain error with standing water. Access was tight but manageable. Cleared the pump filter packed with LADWP mineral scale and lint, confirmed drain on three cycles. The galvanized supply lines in this 1960s building added iron to the LADWP baseline — explained to the tenant that quarterly filter cleaning matters more in this building than a newer one. Provided a written diagnostic summary at the tenant's request for the building manager.",
    outcome: '✓ Same day · OE resolved · Written report · Quarterly plan explained'
  },
  {
    appliance: 'True Reach-In Cooler',
    location: '6th Street restaurant, 90005',
    quote: 'Not holding temp — holding at 48°F, need it fixed today',
    description: "Korean BBQ restaurant on 6th Street — True T-49 reach-in with condenser coils loaded from the kitchen environment and a condenser fan motor starting to fail. Temperature had drifted to 48°F — above the 41°F food safety threshold. Cleaned the condenser coils thoroughly, replaced the condenser fan motor with an OEM True part. Unit confirmed at 38°F within 90 minutes. Restaurant stayed open. Lost product avoided. Recommended a quarterly coil cleaning schedule — commercial kitchen environments load coils significantly faster than residential.",
    outcome: '✓ Same day · 38°F confirmed · Restaurant open · Quarterly plan'
  },
  {
    appliance: 'Samsung Refrigerator',
    location: 'Vermont Ave area, 90006',
    quote: 'Ice maker not working — tenant needs written report for landlord',
    description: "Vermont Ave condo — Samsung French door with no ice production. LADWP mineral scale on the inlet valve had restricted flow completely. Replaced with OEM Samsung inlet valve, confirmed full production. Tenant specifically needed a written diagnostic report — their lease specifies the landlord is responsible for appliance repairs. Provided full written documentation: brand/model, failure cause (LADWP mineral scale), repair performed, parts cost, labor cost, total. Tenant forwarded to property management same day.",
    outcome: '✓ Same day · OEM Samsung · Full production · Written report for landlord'
  },
  {
    appliance: 'Bosch Dishwasher',
    location: 'Oxford Ave, 90005',
    quote: 'E24 drain error — older building, not sure about the pipes',
    description: "Oxford Ave apartment — Bosch 300 series E24 drain error in a 1950s building with original galvanized supply and drain connections. Found: pump filter scaled by LADWP mineral content compounded by iron from the building's galvanized pipes, and a partial drain hose restriction from a connection fitting that had partially corroded. Cleared the filter, replaced the corroded drain hose fitting, confirmed three full drain cycles. Explained the dual water quality factor — this building's plumbing adds to the baseline LADWP hardness in every appliance it feeds.",
    outcome: '✓ Same day · E24 resolved · Corroded fitting replaced · Dual factor explained'
  }
];

const whyReasons = [
  {
    iconKey: 'shield' as const,
    title: 'Written Tenant Reports',
    body: "When a tenant's appliance breaks and the landlord needs documentation to authorize the repair, we provide written diagnostic reports as standard — brand, model, failure cause, repair scope, parts and labor cost. Most Koreatown property managers accept these as the basis for approval."
  },
  {
    iconKey: 'team' as const,
    title: 'Apartment & Dense Building Experience',
    body: "Compact kitchens, stackable laundry closets, narrow access, building manager coordination — we work in dense Koreatown buildings every day. We know the older 1950s and 60s buildings, the galvanized plumbing that compounds LADWP hardness, and the access logistics that make these calls run smoothly."
  },
  {
    iconKey: 'parts' as const,
    title: 'Restaurant Refrigeration',
    body: "When a reach-in cooler fails during service, the lost-product clock starts immediately and food-safety thresholds matter. We service True, Turbo Air, Beverage-Air, Hoshizaki, and Manitowoc commercial refrigeration in Koreatown restaurants with the urgency these calls require."
  },
  {
    iconKey: 'clock' as const,
    title: '90-Day Warranty, OEM Only',
    body: 'Every repair we do in Koreatown carries a 90-day warranty on parts and labor. We use OEM parts on every job — residential and commercial. Same issue returns within 90 days — we come back at no charge.'
  }
];

const testimonials = [
  {
    stars: 5,
    text: '"LG washer OE error in my Wilshire corridor apartment — tight laundry closet. Tech worked in the space without damaging anything, fixed the drain, gave me a written report for my building manager, explained the LADWP water issue in our older building. Professional from start to finish."',
    author: '— Jennifer K., Wilshire corridor, Koreatown 90005'
  },
  {
    stars: 5,
    text: '"True reach-in cooler at our restaurant on 6th Street holding at 48°F on a Saturday. Called Same Day, they came same afternoon. Cleaned the coils, replaced the fan motor, confirmed 38°F before leaving. Restaurant stayed open, no product lost. This is what commercial refrigeration service needs to look like."',
    author: '— (restaurant owner), 6th Street, Koreatown'
  },
  {
    stars: 5,
    text: '"My Samsung fridge ice maker stopped and I needed a written report for my landlord. Tech fixed the inlet valve with OEM parts and gave me a complete written diagnostic document I could forward directly. Landlord approved the repair cost immediately. Exactly the process I needed."',
    author: '— David P., Vermont Ave, Koreatown 90006'
  }
];

const pricingTiers = [
  { appliance: 'Refrigerator / Ice Maker', range: '$150–$400', note: 'LADWP inlet valve · Ice maker module · Fan motor · Coil cleaning', featured: true },
  { appliance: 'Commercial Reach-In Cooler', range: '$200–$600+', note: 'OEM parts · Restaurant priority · Coil cleaning · Condenser fan', featured: true },
  { appliance: 'Washer / Dryer (incl. stackable)', range: '$150–$350', note: 'OE error · Pump filter · Vent cleaning · Compact units' },
  { appliance: 'Dishwasher', range: '$150–$320', note: 'LADWP descale · E24 · Drain hose · Older buildings' },
  { appliance: 'Oven / Range', range: '$150–$400', note: 'Igniter · Element · Compact range · Gas & electric' },
  { appliance: 'Diagnostic Fee', range: '$89', note: 'Credited toward repair · Written estimate' }
];

const faqs = [
  {
    question: 'Do you offer same-day appliance repair in Koreatown?',
    answer: "Yes — we cover all of Koreatown including the Wilshire Blvd, Vermont Ave, 6th Street, and Western Ave corridors. Call before noon for same-day service across 90005, 90006, and 90020."
  },
  {
    question: 'Do you work in apartment buildings and high-rises in Koreatown?',
    answer: "Yes — most of our Koreatown residential work is in apartments and condos. We work with tenants, landlords, and building managers across the dense building stock here. We coordinate building access, work in compact kitchens and narrow laundry closets, and provide written diagnostic reports when a tenant needs documentation for the landlord."
  },
  {
    question: 'Do you repair commercial refrigeration for Koreatown restaurants?',
    answer: "Yes. We service commercial reach-in coolers, freezers, and refrigeration units in restaurant settings throughout the Koreatown corridor — Wilshire Boulevard, Vermont Avenue, 6th Street, Western Avenue. Call with your equipment brand and symptoms for same-day availability."
  },
  {
    question: "Can you provide a written diagnostic report I can forward to my landlord?",
    answer: "Yes — written tenant reports are standard in Koreatown. After the diagnostic, we provide a document with brand, model, failure cause, repair scope, and itemized parts and labor cost. Most property managers accept this as the basis for repair authorization. The $89 diagnostic fee is waived when the repair proceeds."
  },
  {
    question: 'Are weekend appointments available in Koreatown?',
    answer: "Yes — we offer Saturday appointments. Commercial refrigeration is prioritized including weekends. Sunday appointments are limited but we answer the phone every day."
  },
  {
    question: 'What is your diagnostic fee in Koreatown?',
    answer: "Our diagnostic fee is $89. It covers the trip, full appliance inspection, and a written estimate. If you proceed with the repair, the $89 is credited toward your invoice. We service commercial appliances — call us for commercial pricing."
  },
  {
    question: 'Do you also serve Mid-Wilshire, Hancock Park, and Silver Lake from Koreatown?',
    answer: "Yes — our Koreatown-area routes also cover Mid-Wilshire, Hancock Park, Hollywood, Silver Lake, Echo Park, and West Hollywood. Same-day service is typically available across this corridor."
  }
];

const nearbyCities = [
  { name: 'Silver Lake', slug: 'silver-lake' },
  { name: 'Los Feliz', slug: 'los-feliz' },
  { name: 'Hollywood', slug: 'hollywood' },
  { name: 'West Hollywood', slug: 'west-hollywood' },
  { name: 'Beverly Hills', slug: 'beverly-hills' },
  { name: 'Brentwood', slug: 'brentwood' },
  { name: 'Culver City', slug: 'culver-city' },
  { name: 'Los Angeles', slug: 'los-angeles' }
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair"
    headlineCity="Koreatown, LA"
    subheadline="One of LA's densest and most vibrant neighbourhoods — apartments, condos, restaurants, and a community that runs on appliances that work. In-unit washers, compact kitchens, commercial refrigeration. Same-day, written tenant reports, OEM parts, 90-day warranty."
    zips={zips}
    tier={1}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance Repair in Koreatown — Built for This Neighbourhood"
    paragraphs={introParagraphs}
    bookingTitle="Koreatown Service"
    bookingSub="90005 · 90006 · 90020 · Tenant reports · Same day"
  />

  <CustomNarrative
    headline={twoContextsNarrative.headline}
    paragraphs={twoContextsNarrative.paragraphs}
    subSections={twoContextsNarrative.subSections}
    background="gray"
  />

  <ServicesGrid
    cityName={cityName}
    headline="What We Repair in Koreatown"
    services={services}
  />

  <ServiceArea
    cityName={cityName}
    headline="Koreatown Areas We Service"
    subheadline="From the Wilshire and Vermont corridors to the 6th Street restaurant row — every part of 90005, 90006, and 90020."
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={['Wilshire Blvd', 'Vermont Ave', '6th St', 'Western Ave', '8th St', 'Olympic Blvd']}
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Repairs in Koreatown"
    jobs={recentJobs}
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="Why Koreatown Residents and Restaurants Call Us"
    reasons={whyReasons}
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What Koreatown Clients Say"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Repair Pricing in Koreatown"
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="Frequently Asked Questions — Koreatown"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby Cities"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance broken in Koreatown?"
    body="Apartments · Restaurants · Written tenant reports · LADWP hard water aware · All of 90005 & 90006. $89 diagnostic waived with repair. 90-day warranty."
  />
</CityLayoutV2>
