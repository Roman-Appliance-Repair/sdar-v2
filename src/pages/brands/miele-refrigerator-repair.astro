    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Miele Refrigerator Repair",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "description": "Miele refrigerator repair across Los Angeles — MasterCool column refrigerators (K2000, K2700, F2412, F2672), PerfectCool freestanding line, PerfectFresh humidity-controlled drawers, integrated panel-ready installs, EcoBoard control electronics, ice-maker service on combination columns. Family-owned German premium refrigeration. $89 residential diagnostic waived with repair.",
    "offers": {
      "@type": "Offer",
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "89.00",
        "priceCurrency": "USD",
