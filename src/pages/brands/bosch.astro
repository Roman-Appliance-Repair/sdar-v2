---
import Layout from '../../layouts/Layout.astro';

const title = "Bosch Appliance Repair Los Angeles | Factory-Trained, Same-Day";
const description = "Bosch appliance repair across LA. Factory-Trained specialists for 800 Series, Benchmark, 500, 300. Dishwasher, washer, dryer, refrigerator, oven, cooktop. $89 diagnostic waived with repair. Call (424) 325-0520.";

/* 5 BRANCH PHONES */
const branches = [
  { name: "West Hollywood",  phone: "(323) 870-4790", tel: "+13238704790", areas: "WeHo · Beverly Hills · Hollywood · Mid-City" },
  { name: "Los Angeles",     phone: "(424) 325-0520", tel: "+14243250520", areas: "Mid-Wilshire · Brentwood · Santa Monica · Culver City" },
  { name: "Thousand Oaks",   phone: "(424) 208-0228", tel: "+14242080228", areas: "Ventura County · Calabasas · Agoura · Westlake · Malibu" },
  { name: "Pasadena",        phone: "(626) 376-4458", tel: "+16263764458", areas: "Pasadena · San Marino · Arcadia · Glendale · SGV" },
  { name: "Irvine",          phone: "(213) 401-9019", tel: "+12134019019", areas: "Orange County · Newport Beach · Irvine · Anaheim" },
];
const mainPhone = branches[1];

const namedTechs = [
  { name: "Mikhail V.", role: "Bosch/Thermador Specialist · 12 yrs", photo: "/images/techs/placeholder-1.jpg", areas: "Westside · West Hollywood · Beverly Hills" },
  { name: "Artur S.",   role: "Built-in Installation & Repair · 9 yrs", photo: "/images/techs/placeholder-2.jpg", areas: "Pasadena · San Marino · Arcadia" },
  { name: "David K.",   role: "European Appliance Specialist · 14 yrs", photo: "/images/techs/placeholder-3.jpg", areas: "Malibu · Pacific Palisades · Calabasas" },
];

/* 6 BOSCH CATEGORIES — core hub content */
const categories = [
  {
    slug: "/brands/bosch-dishwasher-repair/",
    title: "Bosch Dishwasher Repair",
    tag: "Most common — 800 Series pump failures year 7–8",
    blurb: "AquaStop E15, drain pump jams, door spring, Benchmark CrystalDry. 800, Benchmark, 500, 300 Series.",
    series: "800 · Benchmark · 500 · 300",
  },
  {
    slug: "/brands/bosch-refrigerator-repair/",
    title: "Bosch Refrigerator Repair",
    tag: "800 Series French-door, Counter-depth, Benchmark built-in",
    blurb: "Inverter compressor, ice maker, temperature drift, condenser fan. French-door and counter-depth models.",
    series: "800 · 500 · 300 · Benchmark built-in",
  },
  {
    slug: "/brands/bosch-washer-repair/",
    title: "Bosch Washer Repair",
    tag: "300/500/800 Series front-load — drum, bearings, E-codes",
    blurb: "Drum bearing wear, drain pump, water inlet valve, door boot seal, E04 / E18 / E23 error diagnosis.",
    series: "300 · 500 · 800 · Axxis compact",
  },
  {
    slug: "/brands/bosch-dryer-repair/",
    title: "Bosch Dryer Repair",
    tag: "Heat-pump dryers, condensation dryers, compact 24\"",
    blurb: "Heat-pump compressor, condenser, moisture sensor, lint filter. Ventless 24\" compact dryers for LA condos.",
    series: "300 · 500 · 800 heat-pump · Axxis",
  },
  {
    slug: "/brands/bosch-oven-repair/",
    title: "Bosch Wall Oven Repair",
    tag: "Single, double, combi-steam, speed oven",
    blurb: "Convection fan, heating element, control board, door hinge, self-clean lock. 500/800 Series wall ovens.",
    series: "500 · 800 · Benchmark",
  },
  {
    slug: "/brands/bosch-cooktop-repair/",
    title: "Bosch Cooktop Repair",
    tag: "Gas sealed-burner, induction, electric glass-top",
    blurb: "Induction inverter board, gas igniter, burner valve, control panel. 500/800 Series and Benchmark induction.",
    series: "500 · 800 · Benchmark induction",
  },
];

const faqs = [
  {
    q: "What Bosch appliances do you repair in Los Angeles?",
    a: "Our Factory-Trained technicians service Bosch dishwashers, washers, dryers, refrigerators, wall ovens, and cooktops across Los Angeles. We don't service Bosch microwaves or ranges — Bosch doesn't sell those as a mainline category in the US market. Each appliance category has its own dedicated page with model lists, common failures, and pricing."
  },
  {
    q: "Are you a Bosch Factory-Trained repair company?",
    a: "Our technicians complete manufacturer training on Bosch platforms each year — 800 Series, Benchmark, 500 Series, 300 Series. We're licensed (CA), insured ($2M liability), BBB A+ rated, and EPA-certified. We're an independent repair company, not a Bosch Factory Service subcontractor, which is why our pricing structure is different: no separate $179 call-out fee, no 6-minute metered labor, and the $89 diagnostic is waived when you approve the repair."
  },
  {
    q: "Do you work on Bosch appliances after the factory warranty expires?",
    a: "Post-warranty Bosch service is our primary practice. Bosch's factory warranty covers one year on most parts and labor. After that, owners are directed to Factory Service at $179 call-out plus metered labor. We focus on units aged 2–15 years — the window where dishwasher pumps, washer drum bearings, and fridge inverter boards tend to fail in LA conditions."
  },
  {
    q: "Do you use genuine Bosch parts?",
    a: "Yes — manufacturer-approved Bosch parts only, sourced through authorized distributors. Aftermarket substitutes fail early on hard water and void the 10-year EcoSilence motor warranty on qualifying models. Using manufacturer-approved parts is not negotiable for us."
  },
  {
    q: "Do you service panel-ready built-in Bosch appliances without damaging cabinetry?",
    a: "Yes. Built-in and panel-ready Bosch units — common in Bel Air, Holmby Hills, and Pacific Palisades custom kitchens — get our non-invasive service protocol: protective covering, photographed pre-service setup, controlled extraction, reinstall to exact original fit. Built-in service takes 20–30 minutes longer than a standard call. Price is the same — we don't charge extra for doing it properly."
  },
  {
    q: "How fast can you come out?",
    a: "Same-day service is the default for calls received before 2 PM on weekdays. Emergency slots stay open for leaks and cooling failures into the evening. For non-urgent repairs, next business day is standard. Call your closest branch: West Hollywood (323) 870-4790, LA (424) 325-0520, Thousand Oaks (424) 208-0228, Pasadena (626) 376-4458, Irvine (213) 401-9019."
  },
  {
    q: "How much does Bosch appliance repair cost in LA?",
    a: "Most Bosch repairs land $180–$480 all-in depending on the appliance and specific failure. Dishwasher drain pump: $180–$260. Washer drum bearing: $380–$520. Refrigerator inverter board: $350–$480. Wall oven element: $220–$310. Full pricing per category on each appliance page. $89 diagnostic waived when you approve the repair — no separate call-out fee on top."
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
};

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Same Day Appliance Repair",
  "image": "https://samedayappliance.repair/logo.png",
  "telephone": "(424) 325-0520",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "6230 Wilshire Blvd Ste A PMB 2267",
    "addressLocality": "Los Angeles",
    "addressRegion": "CA",
    "postalCode": "90048",
    "addressCountry": "US"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.6",
    "reviewCount": "37"
  }
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Bosch Appliance Repair",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Same Day Appliance Repair",
    "telephone": "(424) 325-0520"
  },
  "areaServed": { "@type": "City", "name": "Los Angeles" }
};
---

<Layout title={title} description={description}>
  <Fragment slot="head-scripts">
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  </Fragment>

  <!-- 0. CALL BANNER -->
  <div class="call-banner">
    <div class="container call-banner-inner">
      <span class="cb-label">Same-Day Bosch Appliance Repair —</span>
      <a href={`tel:${mainPhone.tel}`} class="cb-phone">Call {mainPhone.phone}</a>
      <span class="cb-sep">·</span>
      <a href={`sms:${mainPhone.tel}`} class="cb-sms">Text us a photo</a>
    </div>
  </div>

  <!-- 1. HERO -->
  <section class="bosch-hero">
    <div class="container hero-grid">
      <div class="hero-text">
        <div class="hero-eyebrow">Factory-Trained · Post-Warranty Bosch Specialists</div>
        <h1>Bosch Appliance Repair in Los Angeles</h1>
        <p class="hero-sub">
          Dishwashers, washers, dryers, refrigerators, wall ovens, cooktops. Our
          Factory-Trained technicians work on Bosch appliances every day across
          LA — 800 Series, Benchmark, 500, 300. Manufacturer-approved parts on
          the truck. Same-day appointments.
        </p>

        <div class="branch-select">
          <label for="branchPicker" class="bs-label">Your area:</label>
          <select id="branchPicker" class="bs-dropdown" onchange="
            const b = this.options[this.selectedIndex];
            const phoneEl = document.getElementById('heroPhoneBtn');
            phoneEl.href = 'tel:' + b.dataset.tel;
            phoneEl.textContent = 'Call ' + b.dataset.phone;
          ">
            {branches.map((b, i) => (
              <option value={b.name} data-tel={b.tel} data-phone={b.phone} selected={i === 1}>
                {b.name} — {b.areas}
              </option>
            ))}
          </select>
        </div>

        <div class="hero-ctas">
          <a id="heroPhoneBtn" href={`tel:${mainPhone.tel}`} class="btn btn-red">Call {mainPhone.phone}</a>
          <a href="/schedule/" class="btn btn-hero-outline">Schedule Online</a>
          <a href={`sms:${mainPhone.tel}?body=Bosch appliance photo — `} class="btn btn-hero-outline btn-sms">📷 Text Photo</a>
        </div>

        <div class="hero-badge">
          <span class="badge-amount">$89</span>
          <span class="badge-text">Diagnostic — <strong>waived</strong> when you approve the repair. No $179 call-out fee.</span>
        </div>
      </div>
      <div class="hero-image">
        <div class="image-frame">
          <div class="image-ring"></div>
          <img src="/images/bosch-hub.jpg" alt="Bosch appliance repair Los Angeles — dishwasher, washer, dryer, refrigerator, oven" loading="eager" />
        </div>
      </div>
    </div>
  </section>

  <!-- 2. CREDS BAR -->
  <section class="creds-bar">
    <div class="container">
      <div class="creds-grid">
        <div class="cred"><span class="cred-icon">★</span><div><strong>BBB A+ Rated</strong><span>Accredited business</span></div></div>
        <div class="cred"><span class="cred-icon">✓</span><div><strong>Factory-Trained</strong><span>All Bosch series</span></div></div>
        <div class="cred"><span class="cred-icon">⚖</span><div><strong>Licensed &amp; Insured</strong><span>CA Lic. · $2M liability</span></div></div>
        <div class="cred"><span class="cred-icon">⚡</span><div><strong>EPA-Certified</strong><span>Refrigerant-safe</span></div></div>
        <div class="cred"><span class="cred-icon">⌚</span><div><strong>Same-Day Service</strong><span>Calls before 2 PM</span></div></div>
      </div>
    </div>
  </section>

  <!-- 3. BRAND STORY -->
  <section class="story">
    <div class="container container-narrow">
      <div class="pos-eyebrow">Who We Are for Bosch Owners</div>
      <h2>LA's Post-Warranty Bosch Appliance Specialists</h2>
      <p>
        Bosch brings a specific customer to our door: someone who chose German
        engineering for a reason and expects their appliance to run another ten
        years. Factory warranty covers the first. After that, the choice is
        Factory Service at $179 per call plus $25 every 6 minutes — or an
        independent shop that actually knows the 800 Series and Benchmark
        platforms.
      </p>
      <p>
        We built our practice around the second option. Most of our Bosch calls
        are units aged 2–15 years, post-warranty, still thousands from
        replacement. The failures follow patterns — dishwasher pumps at year 7–8,
        washer drum bearings around year 8, refrigerator inverter boards at 6–9.
        We carry the manufacturer-approved parts for all of these on the truck,
        so your repair happens today, not after a 3-day parts order.
      </p>
      <p>
        Bosch is part of the BSH Hausgeräte group, alongside Thermador and
        Gaggenau — the same engineering, the same service architecture. Our
        technicians are trained across all three. If you have a Bosch dishwasher
        and a Thermador range, one tech handles both.
      </p>
    </div>
  </section>

  <!-- 4. CATEGORIES GRID — core of hub -->
  <section class="categories">
    <div class="container">
      <div class="section-heading">
        <span class="section-num">01</span>
        <h2>Bosch Appliances We Service</h2>
      </div>
      <p class="section-lead">
        Six categories, each with dedicated model lists, common failures, and
        pricing. Click through to the category that matches your issue — or
        call us and we'll route you.
      </p>
      <div class="cat-grid">
        {categories.map(cat => (
          <a href={cat.slug} class="cat-card">
            <div class="cat-header">
              <h3>{cat.title}</h3>
              <div class="cat-tag">{cat.tag}</div>
            </div>
            <p class="cat-blurb">{cat.blurb}</p>
            <div class="cat-series">Series: {cat.series}</div>
            <span class="cat-link">View repair details →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- 5. NAMED TECHS -->
  <section class="techs">
    <div class="container">
      <div class="section-heading">
        <span class="section-num">02</span>
        <h2>Meet the Technicians Who Service Your Bosch</h2>
      </div>
      <p class="section-lead">
        You'll know the name and face of the tech before they arrive. Our Bosch
        specialists are Factory-Trained, background-checked, and assigned by
        neighborhood — the same person who serviced your Beverly Hills neighbor
        last month is likely coming to you.
      </p>
      <div class="techs-grid">
        {namedTechs.map(t => (
          <div class="tech-card">
            <div class="tech-photo">
              <img src={t.photo} alt={`${t.name} — ${t.role}`} loading="lazy" />
            </div>
            <div class="tech-info">
              <h3>{t.name}</h3>
              <div class="tech-role">{t.role}</div>
              <div class="tech-areas">Primary areas: {t.areas}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 6. BUILT-IN / PANEL-READY mention (briefer than on DW page) -->
  <section class="builtin-brief">
    <div class="container container-narrow">
      <div class="section-heading">
        <span class="section-num">03</span>
        <h2>Panel-Ready &amp; Built-In Bosch — Non-Invasive Service</h2>
      </div>
      <p>
        Half of the Bosch dishwashers, refrigerators, and wall ovens we service
        in Bel Air, Holmby Hills, Pacific Palisades, and Beverly Hills flats
        are panel-ready — custom millwork integrated flush with surrounding
        cabinetry. One scratch to adjacent wood is a $2,000–$8,000 cabinet-maker
        callback.
      </p>
      <p>
        Our built-in protocol: protective floor covering before anything else,
        custom panel documented and detached with photographs of original fit,
        controlled extraction on protective sliders, reinstall to exact original
        gap tolerances. Built-in service takes 20–30 minutes longer than
        standard. Price is the same.
      </p>
    </div>
  </section>

  <!-- 7. WHY US -->
  <section class="why">
    <div class="container">
      <div class="section-heading">
        <span class="section-num">04</span>
        <h2>Why Bosch Owners in LA Call Us</h2>
      </div>
      <div class="why-grid">
        <div class="why-card">
          <h3>Factory-Trained, Post-Warranty Specialists</h3>
          <p>Annual training on every current Bosch platform. Units aged 2–15
          years are our primary work — we know the age-related failure patterns
          cold.</p>
        </div>
        <div class="why-card">
          <h3>Manufacturer-Approved Parts</h3>
          <p>Bosch parts from authorized distributors only. Aftermarket
          substitutes fail early in LA hard water and void the 10-year
          EcoSilence motor warranty on qualifying models.</p>
        </div>
        <div class="why-card">
          <h3>Non-Invasive Built-In Protocol</h3>
          <p>Panel-ready and fully integrated units get documented, extracted
          carefully, reinstalled to exact original fit. No cabinet damage is the
          standard, not a hope.</p>
        </div>
        <div class="why-card">
          <h3>Flat Pricing, Not Metered</h3>
          <p>No $179 call-out fee stacked on top. No labor in 6-minute
          increments. One all-in price you approve before we turn a screw.</p>
        </div>
        <div class="why-card">
          <h3>5 Branches Across Southern California</h3>
          <p>WeHo, LA, Thousand Oaks, Pasadena, Irvine — technicians routed to
          your neighborhood, not driving 90 minutes across town.</p>
        </div>
        <div class="why-card">
          <h3>Cross-Brand BSH Expertise</h3>
          <p>Same techs service Bosch, Thermador, and Gaggenau — same engineering
          platform. One call covers your whole BSH-family kitchen.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 8. SERVICE AREAS -->
  <section class="areas">
    <div class="container container-narrow">
      <div class="section-heading">
        <span class="section-num">05</span>
        <h2>Where We Service Bosch Appliances</h2>
      </div>
      <p>
        Our technicians service Bosch across five counties in Southern
        California, routed from the closest branch to your neighborhood:
      </p>
      <div class="area-groups">
        <div class="area-group">
          <h3>Westside &amp; Hillside</h3>
          <p>Bel Air · Beverly Hills (90210) · Brentwood (90049) · Holmby Hills · Pacific Palisades (90272) · Malibu (90265) · Santa Monica (90401, 90402, 90405) · West Hollywood (90046, 90069)</p>
        </div>
        <div class="area-group">
          <h3>San Fernando Valley</h3>
          <p>Studio City (91604) · Sherman Oaks (91403, 91423) · Encino (91436) · Tarzana (91356) · Calabasas (91302) · Woodland Hills (91364)</p>
        </div>
        <div class="area-group">
          <h3>San Gabriel Valley</h3>
          <p>Pasadena (91101, 91103, 91106) · San Marino (91108) · Arcadia (91006) · South Pasadena (91030) · La Cañada (91011)</p>
        </div>
        <div class="area-group">
          <h3>Orange County &amp; Ventura</h3>
          <p>Newport Beach · Irvine · Laguna Beach · Thousand Oaks · Westlake Village · Agoura Hills · Ventura County coastal</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 9. REVIEWS — placeholder for real GMB quotes -->
  <!--
    PLACEHOLDER: Pull 3 real reviews from GMB that mention Bosch across different
    categories (ideally dishwasher + washer/dryer + refrigerator or oven) and
    different branch-areas. Keep customer name + first letter of surname,
    neighborhood. AggregateRating stays 4.6 / 37. Section hidden until real
    reviews are in.
  -->

  <!-- 10. FAQ -->
  <section class="faq">
    <div class="container container-narrow">
      <div class="section-heading">
        <span class="section-num">06</span>
        <h2>Bosch Appliance Repair FAQ</h2>
      </div>
      <div class="faq-list">
        {faqs.map((f) => (
          <details class="faq-item">
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- 11. RELATED -->
  <section class="related">
    <div class="container">
      <div class="section-heading">
        <span class="section-num">07</span>
        <h2>Related Pages</h2>
      </div>
      <div class="related-grid">
        <a href="/brands/" class="related-card">
          <h3>All Brands</h3>
          <p>Complete brand catalog across appliance categories.</p>
        </a>
        <a href="/brands/thermador/" class="related-card">
          <h3>Thermador Repair</h3>
          <p>Same BSH platform. Star Burner ranges, Masterpiece ovens.</p>
        </a>
        <a href="/brands/miele/" class="related-card">
          <h3>Miele Repair</h3>
          <p>Other European premium. Dishwashers, washers, dryers.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- 12. FINAL CTA — ALL 5 BRANCHES -->
  <section class="bottom-cta">
    <div class="container">
      <h2>Bosch Appliance Down? Reach Your Closest Branch.</h2>
      <p class="cta-sub">
        Same-day appointments across LA, OC, Ventura, SB, and Riverside. $89
        diagnostic — waived with approved repair. Flat pricing, no metered labor.
      </p>
      <div class="branches-grid">
        {branches.map(b => (
          <a href={`tel:${b.tel}`} class="branch-card">
            <div class="branch-name">{b.name}</div>
            <div class="branch-phone">{b.phone}</div>
            <div class="branch-areas">{b.areas}</div>
          </a>
        ))}
      </div>
      <div class="cta-buttons">
        <a href="/schedule/" class="btn btn-outline-light btn-lg">Schedule Online</a>
        <a href={`sms:${mainPhone.tel}?body=Bosch appliance photo — `} class="btn btn-outline-light btn-lg">📷 Text a Photo</a>
      </div>
    </div>
  </section>

  <!-- 13. FLOATING CALL -->
  <a href={`tel:${mainPhone.tel}`} class="floating-call" aria-label="Call for Bosch appliance repair">
    <span class="fc-icon">📞</span>
    <span class="fc-text">{mainPhone.phone}</span>
  </a>
</Layout>

<style>
  .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  .container-narrow { max-width: 860px; }

  .section-heading {
    display: flex; align-items: baseline; gap: 20px;
    margin-bottom: 40px; padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
  }
  .section-num {
    font-size: 14px; font-weight: 700; color: var(--red);
    letter-spacing: 0.15em; font-family: var(--font-body);
  }
  .section-heading h2 { font-size: clamp(28px, 3.5vw, 38px); line-height: 1.15; margin: 0; }
  .section-lead { font-size: 18px; color: var(--muted); margin-bottom: 32px; max-width: 720px; }

  /* 0. CALL BANNER */
  .call-banner {
    background: var(--black); color: #fff; padding: 10px 0;
    border-bottom: 2px solid var(--red); font-size: 15px;
    position: sticky; top: 0; z-index: 50;
  }
  .call-banner-inner { display: flex; align-items: center; justify-content: center; gap: 12px; flex-wrap: wrap; }
  .cb-label { opacity: 0.85; }
  .cb-phone { color: var(--red); font-weight: 700; text-decoration: none; font-size: 16px; }
  .cb-phone:hover { text-decoration: underline; }
  .cb-sep { opacity: 0.4; }
  .cb-sms { color: #fff; text-decoration: none; opacity: 0.85; }
  .cb-sms:hover { opacity: 1; text-decoration: underline; }

  /* 1. HERO */
  .bosch-hero { background: var(--black); color: #fff; padding: 80px 0 70px; }
  .hero-grid { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 60px; align-items: center; }
  .hero-eyebrow {
    font-size: 13px; font-weight: 700; color: var(--red);
    letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 20px;
    font-family: var(--font-body);
  }
  .bosch-hero h1 {
    font-size: clamp(34px, 5vw, 54px); line-height: 1.05;
    margin: 0 0 24px; color: #fff; letter-spacing: -0.02em;
  }
  .hero-sub { font-size: 19px; line-height: 1.55; color: rgba(255,255,255,0.8); margin-bottom: 28px; }

  .branch-select {
    display: flex; align-items: center; gap: 12px; margin-bottom: 20px;
    padding: 12px 16px; background: rgba(255,255,255,0.05);
