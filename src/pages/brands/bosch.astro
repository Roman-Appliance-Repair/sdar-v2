---
import Layout from '../../layouts/Layout.astro';
import BrandBranchesGrid from '../../components/BrandBranchesGrid.astro';
import { MAIN_PHONE, MAIN_PHONE_TEL } from '../../data/branches';

const title = "Bosch Appliance Repair | Southern California | 800 Series, Benchmark, Home Connect";
const description = "Bosch appliance repair across Southern California. 800 Series and Benchmark dishwashers, wall ovens, cooktops, refrigerators, washers, dryers. 100/300/500/800/Benchmark platforms. CrystalDry, PrecisionWash, AquaStop, Home Connect. Factory-trained. Post-warranty specialists. $89 diagnostic waived with repair. Call (424) 325-0520.";

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": "https://samedayappliance.repair/brands/bosch/#business",
    "name": "Same Day Appliance Repair, Bosch Service",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": "https://samedayappliance.repair/brands/bosch/",
    "telephone": MAIN_PHONE_TEL,
    "priceRange": "$$$",
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What Bosch appliances do you service?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Bosch's full US residential product line: dishwashers (100, 300, 500, 800 Series, Benchmark), wall ovens (single, double, SideOpening Benchmark, combi-steam), cooktops (gas, FlexInduction, electric), refrigerators (counter-depth, French-door, built-in Benchmark), washers (300, 500, 800 compact 24\" front-load), and dryers (compact 24\" heat-pump and ventless condenser). We don't service Bosch freestanding ranges because Bosch doesn't make them for the US market, Bosch cooking architecture is cooktop + separate wall oven. We also don't service Bosch microwaves as a standalone category (component replacement on built-in microwaves is handled case-by-case)."
        }
      },
      {
        "@type": "Question",
        "name": "What's the difference between 100, 300, 500, 800 and Benchmark series?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Same engineering foundation, different feature tiers. 100 Series is entry, basic functionality, plastic tub on some dishwashers. 300 Series is mid-entry with stainless tub and improved drying. 500 Series is mid with PureDry drying technology and better racks. 800 Series is premium, CrystalDry zeolite drying (Bosch's best), 42-44 dB operation, PrecisionWash sensors, Home Connect WiFi. Benchmark is flagship, 38 dB (quietest), ball-bearing rack systems, interior lighting, Benchmark-exclusive features like SideOpening wall ovens and FlexInduction cooktops. All series pass Bosch's 485-point quality checks, so service components are largely shared across tiers, a 500 Series circulation pump is the same assembly as an 800 Series pump in most cases. Feature differences are in sensors, controls, and exterior trim."
        }
      },
      {
        "@type": "Question",
        "name": "Are you Bosch-authorized?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No, we're factory-trained but independent. Bosch has their own Authorized Service network for in-warranty dispatch. Inside the 1-year Bosch base warranty, call Bosch customer service at 1-800-944-2904 for authorized service dispatch at no parts cost. Post-warranty, we're the better call: faster response, lower labor rate, same training on all Bosch platforms. Most of our Bosch calls are 2-to-10-year-old units past the base warranty. For in-warranty issues, call Bosch first; for post-warranty service, call us."
        }
      },
      {
        "@type": "Question",
        "name": "How much does Bosch appliance repair cost?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Diagnostic is $89, waived with repair. Costs vary by category. Dishwasher: circulation pump $285-$385, drain pump $165-$245, heating element $185-$265, CrystalDry zeolite canister $225-$325. Washer: shock absorber set $385-$540, drain pump $245-$345, door lock $195-$285. Dryer: heat-pump assembly $685-$985, NTC sensor $145-$215, drum belt $125-$185. Refrigerator: compressor start relay $95-$155, evaporator fan $285-$385, control board $480-$680, VitaFreshPro drawer sensor $125-$185. Wall oven: bake element $245-$345, convection fan $345-$485, door hinge pair $320-$460. Cooktop: induction inverter $485-$685, spark module $245-$345. Labor and parts quoted before work starts. Full pricing tables on each category page."
        }
      },
      {
        "@type": "Question",
        "name": "Does my Bosch dishwasher qualify for the Home Connect app?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Most 2020+ 500, 800, and Benchmark Series dishwashers are Home Connect enabled. Look for the Home Connect logo on the inside of the door frame or the model specs on your receipt. Home Connect enables remote start, cycle monitoring, notifications, and firmware updates. We use Home Connect during service calls when available, firmware updates resolve about 15% of 'intermittent error' complaints without parts, particularly on 2021-2022 units. If your model is Home Connect capable but not enabled, we can walk you through the setup as part of any service visit."
        }
      },
      {
        "@type": "Question",
        "name": "Can you service Bosch built-in refrigerators (Benchmark)?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Bosch Benchmark built-in refrigerators are less common in LA than Sub-Zero but show up in contemporary modernist kitchens where the owner wanted integrated refrigeration with a different aesthetic from Sub-Zero. Common issues: compressor start relay, evaporator fan motor, VitaFreshPro humidity-controlled drawer sensor, control board, door gasket. Sealed-system service requires EPA 608 certification, all our technicians are certified. Benchmark counter-depth and French-door models from the 800 Series are the more common service category in LA condos."
        }
      }
    ]
  }
];
---
<Layout title={title} description={description}>
  <Fragment slot="head-scripts">
    {schemaJsons.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </Fragment>

  <section class="hero">
    <div class="hero-inner">
      <div class="hero-content">
        <p class="hero-eyebrow">LA · Orange · Ventura · San Bernardino · Riverside Counties</p>
        <h1>Bosch Appliance Repair</h1>
        <p class="hero-sub">Factory-trained service on the full Bosch US residential line, dishwashers (100/300/500/800/Benchmark), wall ovens, cooktops, refrigerators, compact washers and dryers. CrystalDry, PrecisionWash, AquaStop, Home Connect. Post-warranty specialists for 2-to-10-year-old Bosch units across LA, Orange, Ventura, San Bernardino, and Riverside counties.</p>
        <div class="hero-ctas">
          <a href={`tel:${MAIN_PHONE_TEL}`} class="btn-primary">☎ {MAIN_PHONE}</a>
          <a href="/contact/" class="btn-outline">Book Online</a>
        </div>
      </div>
      <div class="hero-img-wrap">
        <div class="hero-img-placeholder">
          <p>Bosch Appliance Repair</p>
          <p>Across Southern California</p>
        </div>
      </div>
    </div>
  </section>

  <div class="trust-bar">
    <div class="trust-bar-inner">
      <div class="trust-item"><span class="trust-icon">🏅</span> BHGS Licensed #A49573</div>
      <div class="trust-item"><span class="trust-icon">❄</span> EPA 608 Certified</div>
      <div class="trust-item"><span class="trust-icon">⚡</span> Same Day Available</div>
      <div class="trust-item"><span class="trust-icon">🔩</span> OEM Parts on Truck</div>
      <div class="trust-item"><span class="trust-icon">💬</span> $89 Diagnostic, Waived With Repair</div>
    </div>
  </div>

  <!-- ── ABOUT ── -->
  <section class="section">
    <div class="container">
      <p class="eyebrow-sub">About the brand</p>
      <h2>German engineering, widely deployed across Southern California, from Wilshire condos to Brentwood estates to Newport Beach contemporary builds and Westlake Village remodels.</h2>
      <p>Bosch occupies a distinctive position in the LA appliance market. More widespread than Sub-Zero or Viking, Bosch dishwashers dominate new-construction kitchens across mid-luxury and upper-luxury builds in West Hollywood, Hollywood Hills, Westwood, Brentwood, and the Wilshire Corridor. Not quite flagship-priced like Miele, but engineered to a level that owners who tried Whirlpool or GE before usually don't go back. The <strong>Bosch 800 Series dishwasher is arguably the best residential dishwasher in North America</strong> under $1,800, quieter operation, better drying (zeolite CrystalDry technology), and tighter build quality than any mass-market competitor.</p>
      <p>Bosch's US product structure has a specific quirk that matters for service: <strong>Bosch does not make freestanding ranges for the US market</strong>. Bosch cooking architecture is cooktop + separate wall oven, following the European model where these appliances are sold independently rather than as an integrated range. Many homeowners assume "Bosch makes everything" and are surprised by this gap. Viking, Wolf, and Thermador serve the range category; Bosch serves the cooktop + wall oven category. For service, this means a "Bosch range repair" call is usually actually a Bosch cooktop or a Bosch wall oven repair, we clarify on booking.</p>
      <p>Most of our Bosch calls are 2-to-10-year-old units where the base 1-year Bosch warranty has closed. Service demand is highest on dishwashers (the category Bosch sells most of) followed by washers/dryers (compact 24" units in condos across our service area, Wilshire Corridor, Newport Beach high-rises, Long Beach towers, Marina del Rey, downtown Long Beach, Irvine apartments) then refrigerators and wall ovens. We're factory-trained on all Bosch series, 100, 300, 500, 800, and Benchmark, and carry common parts on every truck.</p>
    </div>
  </section>

  <!-- ── CATEGORIES ── -->
  <section class="section section-alt">
    <div class="container">
      <p class="eyebrow-sub">What we repair</p>
      <h2>Bosch categories we service</h2>
      <div class="cat-grid">
        <a href="/brands/bosch-dishwasher-repair/" class="cat-card">
          <h3>Bosch Dishwasher Repair</h3>
          <p>100, 300, 500, 800 Series, Benchmark. SHP/SHX/SHE model prefixes. CrystalDry zeolite technology, PrecisionWash, AquaStop leak protection, Home Connect WiFi. Circulation pump, drain pump, heating element, spray arm service.</p>
          <span class="cat-cta">View dishwasher repair →</span>
        </a>
        <a href="/brands/bosch-washer-repair/" class="cat-card">
          <h3>Bosch Washer Repair</h3>
          <p>300, 500, 800 Series compact 24" front-load washers. WAT/WAW models. Shock absorbers, drain pump, door lock, heating element, control board. Dedicated 120V circuit service.</p>
          <span class="cat-cta">View washer repair →</span>
        </a>
        <a href="/brands/bosch-dryer-repair/" class="cat-card">
          <h3>Bosch Dryer Repair</h3>
          <p>Compact 24" ventless condenser and heat-pump dryers. WTG/WTW/WTE models. 120V operation, no exterior vent required. Heat-pump assembly, NTC sensors, drum belt, condenser coil cleaning.</p>
          <span class="cat-cta">View dryer repair →</span>
        </a>
        <a href="/brands/bosch-refrigerator-repair/" class="cat-card">
          <h3>Bosch Refrigerator Repair</h3>
          <p>800 Series counter-depth, French-door, bottom-mount freezer. Benchmark built-in. B36/B30/B09/B20 model prefixes. VitaFreshPro humidity-controlled drawers, compressor, evaporator, control board service.</p>
          <span class="cat-cta">View refrigerator repair →</span>
        </a>
        <a href="/brands/bosch-oven-repair/" class="cat-card">
          <h3>Bosch Wall Oven Repair</h3>
          <p>500, 800 Series single and double wall ovens. Benchmark SideOpening. Combi-steam units. HBL/HBN/HSL models. EcoClean pyrolytic, convection fan, RTD temperature probe, door hinge, control board service.</p>
          <span class="cat-cta">View wall oven repair →</span>
        </a>
        <a href="/brands/bosch-cooktop-repair/" class="cat-card">
          <h3>Bosch Cooktop Repair</h3>
          <p>Gas, FlexInduction, electric ceramic cooktops. NIT/NGM/NET models. FlexInduction zone combining, AutoChef temperature regulation, SpeedBoost. Spark module, induction inverter, ceramic glass, sensor grid service.</p>
          <span class="cat-cta">View cooktop repair →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ── TIER GUIDE ── -->
  <section class="section">
    <div class="container narrow">
      <p class="eyebrow-sub">Series guide</p>
      <h2>Understanding Bosch's five-tier structure</h2>
      <p>Bosch organizes its US product line in five tiers across most categories (most prominent on dishwashers and cooking): 100, 300, 500, 800, and Benchmark. All share Bosch's 485-point quality check process, meaning core engineering is consistent across tiers. Differences are in features, sensors, aesthetics, and noise levels rather than fundamental build quality.</p>
      <p><strong>100 Series (entry).</strong> Basic functionality, fewest cycle options, sometimes plastic tub on dishwashers. Most common in rental properties and budget-conscious builds. Parts availability excellent; repairs typically the cheapest across the tiers because the platform is simpler.</p>
      <p><strong>300 Series (mid-entry).</strong> Stainless tub on dishwashers, improved drying, more cycle options. Common in mid-market new construction across our service area, builder-spec units in condos and townhomes from 2018-2024 (Westside LA, Newport Beach, Irvine, Thousand Oaks, Rancho Cucamonga, Temecula). Solid workhorse tier with excellent parts availability.</p>
      <p><strong>500 Series (mid).</strong> PureDry drying technology on dishwashers, improved rack systems, Home Connect WiFi on newer units. Mid-luxury builds specify 500 Series to balance performance and cost. Strong service economics, repairs usually pencil out favorably.</p>
      <p><strong>800 Series (premium).</strong> CrystalDry zeolite drying (Bosch's best drying technology, dries plastics properly), 42-44 dB operation (barely audible), PrecisionWash sensor technology, Home Connect WiFi standard. Most common Bosch dishwasher in luxury kitchens across our service area. Wall ovens and cooktops in 800 Series carry similar feature depth.</p>
      <p><strong>Benchmark (flagship).</strong> 38 dB dishwasher operation (quietest Bosch makes), ball-bearing rack systems, interior lighting, full-color LCD displays. SideOpening wall ovens (unique to Benchmark, door swings sideways for easier cavity access). FlexInduction cooktops (combine zones for large pans). Premium paid for build refinement and features rather than fundamentally different engineering.</p>
      <p>Service reality: 800 Series is the sweet spot for cost, features, and service economics. Benchmark repairs cost slightly more due to specialty parts like ball-bearing rack replacements, but fundamental sealed-system and motor components are shared with 800 Series and priced similarly.</p>
    </div>
  </section>

  <!-- ── LA CONTEXT ── -->
  <section class="section section-alt">
    <div class="container narrow">
      <p class="eyebrow-sub">Bosch in Southern California</p>
      <h2>Where Bosch fits in the LA appliance landscape</h2>
      <p>LA appliance demographics split Bosch across three distinct customer segments. First: <strong>new-construction mid-luxury builds</strong>, townhomes, condos, and attached housing where builders specify Bosch 300/500 Series across the whole kitchen for cost-consistent quality. These are owners 3-7 years into ownership seeing first post-warranty service needs now.</p>
      <p>Second: <strong>renovations targeting mid-to-high luxury</strong>, owners who chose Bosch over Miele to save $2,000-4,000 across a full kitchen package while still getting genuinely good engineering. Common in Brentwood, Santa Monica, Mid-Wilshire, Westwood, and Hollywood Hills. These owners usually spec 800 Series dishwasher, 800 Series cooktop, 500 Series wall oven, and Bosch or Samsung refrigerator.</p>
      <p>Third: <strong>full-luxury owners</strong> who chose Bosch Benchmark for specific features (quietest dishwasher, SideOpening ovens, FlexInduction cooktops) rather than going with the obvious Sub-Zero/Wolf/Miele tier. Less common but important, these owners expect premium service and carry reasonable expectations about what refinement costs.</p>
      <p>For compact 24" washers and dryers, Bosch competes directly with Miele's W1/T1 line. Bosch compact laundry is typically half the price of Miele, owners choosing Bosch did so knowingly, accepting shorter warranty (1 year vs Miele's 10-year motor/drum) in exchange for lower acquisition cost. Service economics favor repair through year 8-10 for Bosch compact laundry.</p>
    </div>
  </section>

  <!-- ── WARRANTY ── -->
  <section class="section">
    <div class="container narrow">
      <p class="eyebrow-sub">Warranty context</p>
      <h2>Bosch warranty and when to call us</h2>
      <p>Bosch residential warranty is <strong>1 year on all parts and labor</strong> on most product lines, shorter than Miele (2 years) or Sub-Zero (2 years + 12-year sealed system) but matched to the lower price point. During the warranty window, call Bosch at <strong>1-800-944-2904</strong> for authorized service dispatch at no parts cost.</p>
      <p>Some Bosch products have extended coverage on specific components: compressors on 800 Series and Benchmark refrigerators carry a 5-year limited warranty (years 2-5 part-free, you pay labor). Drums and motors on select dishwasher tiers have longer coverage. Before major component repair, we verify the actual warranty period for your specific model and process warranty claims when applicable.</p>
      <p>Post-warranty is where we operate. Most of our Bosch calls are 2-to-10-year-old units past the base coverage. Same factory training as Bosch authorized dispatch, faster response, lower labor rate. For in-warranty issues, call Bosch first; for anything outside warranty, call us.</p>
    </div>
  </section>

  <!-- ── SERVICE AREAS ── -->
  <section class="section section-alt">
    <div class="container">
      <p class="eyebrow-sub">Where we work</p>
      <h2>Bosch service across Greater Los Angeles</h2>
      <p>Bosch density is highest in mid-luxury and upper-luxury new construction: West Hollywood, Hollywood Hills, Westwood, Brentwood, Santa Monica, Mid-Wilshire, Culver City, Pasadena, and Glendale. Commercial-style kitchens in Bel Air and Beverly Hills typically specify Wolf + Sub-Zero + Miele, but even those often use Bosch dishwashers for their specific technology advantages.</p>
      <BrandBranchesGrid showHeader={false} />
    </div>
  </section>

  <!-- ── CREDENTIALS ── -->
  <section class="section">
    <div class="container narrow">
      <p class="eyebrow-sub">Credentials</p>
      <h2>Licensed, insured, EPA-certified</h2>
      <p>We hold an active CSLB C-20 HVAC license. Bosch refrigeration sealed-system service requires EPA 608 refrigerant handling certification; all our technicians are EPA 608 Universal certified (#1346255700410) plus BHGS #A49573. We carry general liability and workers' comp. BHGS-registered under <strong>#A49573</strong>. BBB A+ since 2022.</p>
    </div>
  </section>

  <!-- ── FAQ ── -->
  <section class="section section-alt">
    <div class="container narrow">
      <p class="eyebrow-sub">FAQ</p>
      <h2>Bosch service, common questions</h2>

      <details class="faq">
        <summary>What Bosch appliances do you service?</summary>
        <p>Dishwashers (100/300/500/800/Benchmark), wall ovens, cooktops, refrigerators, compact 24" washers and dryers. Not freestanding ranges (Bosch doesn't make for US market). Not standalone microwaves.</p>
      </details>

      <details class="faq">
        <summary>100 vs 300 vs 500 vs 800 vs Benchmark</summary>
        <p>Same 485-point engineering foundation, different feature tiers. 100 = entry. 300 = stainless tub, improved drying. 500 = PureDry, Home Connect. 800 = CrystalDry zeolite, 42-44 dB, PrecisionWash. Benchmark = 38 dB, ball-bearing racks, SideOpening ovens, FlexInduction cooktops.</p>
      </details>

      <details class="faq">
        <summary>Are you Bosch-authorized?</summary>
        <p>No, factory-trained but independent. Inside 1-year warranty call Bosch 1-800-944-2904. Post-warranty: faster response, lower labor rate, same training. 5-year compressor warranty on 800/Benchmark fridges may apply, we verify before major repairs.</p>
      </details>

      <details class="faq">
        <summary>How much does Bosch repair cost?</summary>
        <p>Diagnostic $89, waived with repair. Category-specific pricing on individual pages, dishwasher circulation pump $285-$385, washer shock set $385-$540, dryer heat-pump $685-$985, refrigerator compressor relay $95-$155.</p>
      </details>

      <details class="faq">
        <summary>Home Connect, does my model have it?</summary>
        <p>Most 2020+ 500/800/Benchmark units are Home Connect enabled. Look for logo inside door frame or model specs. We use Home Connect during service, firmware updates resolve 15% of error complaints without parts on 2021-2022 units.</p>
      </details>

      <details class="faq">
        <summary>Bosch range repair, do you do that?</summary>
        <p>Bosch doesn't sell freestanding ranges in US. If you have a "Bosch range" that's likely a cooktop + separate wall oven installation. We clarify on booking, covers both categories on same dispatch.</p>
      </details>

      <details class="faq">
        <summary>Built-in Benchmark refrigerators?</summary>
        <p>Yes. Less common in LA than Sub-Zero but show up in modernist kitchens. EPA 608 certified for sealed-system work. Common calls: compressor relay, evaporator fan, VitaFreshPro sensor, control board, gasket.</p>
      </details>
    </div>
  </section>

  <!-- ── BOTTOM CTA ── -->
  <section class="bottom-cta">
    <div class="container">
      <h2>Ready to schedule Bosch service?</h2>
      <p>Same day available. $89 diagnostic, waived with repair. Labor and parts quoted before we start.</p>
      <div class="hero-ctas">
        <a href={`tel:${MAIN_PHONE_TEL}`} class="btn-primary">☎ Call {MAIN_PHONE}</a>
        <a href="/contact/" class="btn-outline">Book Online</a>
      </div>
    </div>
  </section>

<style>
  :root {
    --red: #C8102E;
    --black: #0a0a0a;
    --gray: #f5f5f5;
    --border: #e2e2e2;
    --text: #1a1a1a;
    --muted: #6b6b6b;
    --white: #ffffff;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; color: var(--text); line-height: 1.6; }

  .hero { background: var(--black); color: #fff; padding: 80px 24px 72px; }
  .hero-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; max-width: 1100px; margin: 0 auto; align-items: center; }
  .hero-eyebrow { font-size: 13px; color: var(--red); text-transform: uppercase; letter-spacing: .12em; margin-bottom: 16px; font-weight: 600; }
  .hero h1 { font-size: clamp(28px, 4vw, 46px); font-weight: 700; color: #fff; margin-bottom: 20px; line-height: 1.15; font-family: 'Playfair Display', Georgia, serif; }
  .hero-sub { font-size: 17px; color: rgba(255,255,255,.72); margin-bottom: 28px; }
  .hero-ctas { display: flex; gap: 12px; margin-bottom: 28px; flex-wrap: wrap; }
  .btn-primary { display: inline-block; padding: 14px 28px; background: var(--red); color: #fff; text-decoration: none; border-radius: 6px; font-weight: 600; font-size: 16px; transition: background .2s; }
  .btn-primary:hover { background: #a50d25; }
  .btn-outline { display: inline-block; padding: 14px 28px; border: 1.5px solid rgba(255,255,255,.35); color: #fff; text-decoration: none; border-radius: 6px; font-weight: 600; font-size: 16px; transition: all .2s; }
  .btn-outline:hover { background: rgba(255,255,255,.08); border-color: #fff; }
  .hero-img-wrap { aspect-ratio: 4/3; background: #1a1a1a; border-radius: 4px; display: flex; align-items: center; justify-content: center; }
  .hero-img-placeholder { color: rgba(255,255,255,.35); font-size: 14px; text-align: center; }
  @media (max-width: 768px) { .hero-inner { grid-template-columns: 1fr; } .hero-img-wrap { display: none; } }

  .trust-bar { background: var(--red); color: #fff; padding: 16px 24px; }
  .trust-bar-inner { max-width: 1100px; margin: 0 auto; display: flex; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
  .trust-item { font-size: 13px; font-weight: 600; display: flex; align-items: center; gap: 8px; }
  .trust-icon { font-size: 16px; }

  .section { padding: 72px 24px; }
  .section-alt { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; }
  .container.narrow { max-width: 780px; }
  .eyebrow-sub { font-size: 13px; color: var(--red); text-transform: uppercase; letter-spacing: .12em; margin-bottom: 12px; font-weight: 600; }
  h2 { font-size: clamp(24px, 3vw, 34px); font-weight: 700; margin-bottom: 20px; line-height: 1.2; font-family: 'Playfair Display', Georgia, serif; }
  .section p { margin-bottom: 16px; color: var(--text); }

  .cat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 20px; margin-top: 32px; }
  .cat-card { display: block; padding: 24px; background: #fff; border: 1px solid var(--border); border-radius: 8px; text-decoration: none; color: inherit; transition: all .2s; }
  .cat-card:hover { border-color: var(--red); transform: translateY(-2px); box-shadow: 0 4px 16px rgba(0,0,0,.08); }
  .cat-card h3 { font-size: 17px; font-weight: 700; margin-bottom: 10px; color: var(--black); font-family: 'Playfair Display', Georgia, serif; }
  .cat-card p { font-size: 14px; color: var(--muted); margin-bottom: 14px; }
  .cat-cta { font-size: 13px; color: var(--red); font-weight: 600; }

  .faq { margin-bottom: 12px; border: 1px solid var(--border); border-radius: 6px; padding: 16px 20px; background: #fff; }
  .faq summary { font-weight: 600; cursor: pointer; font-size: 16px; color: var(--black); }
  .faq[open] summary { margin-bottom: 12px; }
  .faq p { font-size: 15px; color: var(--text); margin-bottom: 0; }

