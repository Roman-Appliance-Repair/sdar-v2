    ],
    "description": "Hestan stove repair across LA — Pro Series 30/36/48 all-gas + dual-fuel + induction, Hestan Cue smart integration, Bordeaux + Matte Black + Prince + Froth + Pacific Fog color program. Meyer Corporation Anaheim CA factory since 2014 (LA-local 1-3 day parts advantage). $89 residential diagnostic waived with repair.",
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, waived with repair" } }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "Hestan", "item": "https://samedayappliance.repair/brands/hestan/" },
      { "@type": "ListItem", "position": 4, "name": "Hestan Stove Repair", "item": canonical }
    ]
