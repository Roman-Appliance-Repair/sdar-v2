      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ], "description": "Smeg wall oven repair across LA — Victoria Series retro-styled, Classic Series clean modernist, Dolce Stil Novo premium tier. Italian Smeg Spa (Guastalla, founded 1948 by Vittorio Bertazzoni Jr.); separate company from Bertazzoni range brand. Smeg US Oakhurst NJ distribution. Built-in wall oven only (small appliances out of scope). $89 residential diagnostic waived with repair.", "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, waived with repair" } } },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a.replace(/<[^>]+>/g, '') } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [ { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" }, { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" }, { "@type": "ListItem", "position": 3, "name": "Smeg", "item": "https://samedayappliance.repair/brands/smeg/" }, { "@type": "ListItem", "position": 4, "name": "Smeg Wall Oven Repair", "item": canonical } ] }
];
