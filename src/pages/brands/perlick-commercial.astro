<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }

  .section { padding: 64px 24px; }
  .section-gray { background: var(--gray); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .container.narrow { max-width: 820px; margin: 0 auto; }

  .section-number { font-size: 12px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--red); margin: 0 0 12px; }
  h2 { font-size: clamp(22px, 3vw, 32px); font-weight: 700; line-height: 1.2; margin: 0 0 20px; color: var(--text); letter-spacing: -.01em; }
  h3 { font-size: 18px; font-weight: 700; margin: 24px 0 10px; color: var(--text); }
  p { font-size: 16px; line-height: 1.7; color: var(--text); margin: 0 0 14px; }
  strong { font-weight: 700; }
  em { font-style: italic; }
  a { color: var(--red); text-decoration: none; }
  a:hover { text-decoration: underline; }

  .bullet-list { list-style: none; padding: 0; margin: 16px 0; }
  .bullet-list li {
    position: relative;
    padding: 12px 0 12px 22px;
    font-size: 15.5px;
    line-height: 1.65;
    border-bottom: 1px solid var(--border);
  }
  .bullet-list li:last-child { border-bottom: none; }
  .bullet-list li::before {
    content: "▸";
    position: absolute;
    left: 0;
    color: var(--red);
    font-weight: 700;
