---
import Layout from '../../layouts/Layout.astro';
import BrandBranchesGrid from '../../components/BrandBranchesGrid.astro';
import { MAIN_PHONE, MAIN_PHONE_TEL } from '../../data/branches';

const title = "Bosch Range Hood Repair Los Angeles — Same Day";
const description = "$89 dx waived. Bosch range hood repair SoCal, 500 Series DUH/HCP, 800 Series wall/island/insert, HUI pull-out, Home Connect WiFi. BSH Irvine parts.";
const canonical = "https://samedayappliance.repair/brands/bosch-range-hood-repair/";

const faqs = [
  {
    q: "Bosch range hood lineup, which 500/800 Series model do I have?",
    a: "Bosch ships two active US residential hood series. <b>500 Series</b> is the premium-entry tier, DUH30252UC 30-inch undercabinet (117-300 CFM, halogen lights); DUH36652UC 36-inch undercabinet (200-500 CFM); HCP30652UC 30-inch wall-mount convertible (170-600 CFM, dishwasher-safe filters); HCP56652UC 36-inch wall-mount convertible (600 CFM, Home Connect WiFi). <b>800 Series</b> is the premium flagship, 30-inch undercabinet (140-600 CFM, 2-speed, dishwasher-safe filters); 30/36-inch wall-mount (180-600 CFM, 4-speed); 43-inch island (180-600 CFM, 4-speed); 30-inch insert for custom hoods (180-600 CFM). <b>HUI-series pull-out</b> (HUI50351UC), telescopic pull-out hood, concealed when retracted. Both series route through BSH Home Appliances via Irvine California parts chain."
  },
  {
    q: "BSH family, Bosch / Thermador / Gaggenau, how do parts share?",
    a: "All three brands are owned by BSH Home Appliances (Germany) and route through <b>BSH's Irvine California parts distribution</b>, 1-2 day LA-local delivery on common components, one of the fastest parts chains in LA luxury residential. For range hoods specifically, cross-fit happens at the mechanical level: motor assemblies, grease-filter hardware, and some LED drivers cross-reference between Bosch 800 Series and entry-Thermador hoods. Control boards + Home Connect modules are brand-specific but share the same BSH app platform (Home Connect covers Bosch + Thermador + Gaggenau + Bosch-family appliances together). When a Bosch hood-specific SKU is backordered, Thermador cross-references sometimes ship with the same chassis. See <a href='/brands/thermador-range-hood-repair/'>Thermador range hood</a> · <a href='/brands/gaggenau-range-hood-repair/'>Gaggenau range hood</a>."
  },
  {
    q: "HUI pull-out hood won't extend or retract, slide mechanism or motor?",
    a: "HUI50351UC is Bosch's signature pull-out hood, the entire hood body telescopes out over the cooktop when you pull the front handle, retracts flush when pushed back. Unlike motorized downdraft units (Dacor ERV), <b>Bosch HUI is manual pull-out with electric fan</b>, the telescoping slide is spring-loaded or gravity-assisted, not motor-driven, so \"won't extend\" is almost always a mechanical bind rather than a motor fault. Common causes: (1) grease buildup in the slide rails (cleaning resolves, $140-$220 no-part service); (2) bent slide rail from forced extension (realignment $180-$280); (3) spring mechanism fatigue at 10+ year mark ($160-$260 spring replacement). The fan motor and control electronics are separate from the slide, if those fail, we treat it as a standard wall-mount diagnostic."
  },
  {
    q: "Home Connect pairing lost, firmware or WiFi module?",
    a: "Bosch Home Connect (shared BSH platform covering Bosch + Thermador + Gaggenau) has predictable post-firmware-update pairing failures. Recovery: (1) power-cycle the hood at the breaker for 60 seconds; (2) in Home Connect app, remove the hood completely and re-add from scratch (don't try to reconnect an existing entry); (3) confirm router broadcasts 2.4 GHz, Home Connect does not pair on 5 GHz-only networks; (4) if pairing fails after those three steps, the WiFi module inside the hood ($180-$280) is the likely cause. BSH Irvine typically has the module on 1-2 day delivery."
  },
  {
    q: "800 Series insert (HMI) for custom hood install, service access?",
    a: "Bosch 800 Series 30-inch insert is designed for custom-hood installs where the blower + intake grille + controls are concealed behind a designer-built hood enclosure (tile, wood, metal, whatever the architect specified). <b>Service access depends on the custom enclosure design.</b> Most custom hoods provide removable access panels for the blower + filters + controls; some require cabinet-panel removal before service can begin. Tell us at booking that you have an insert install so we budget access time. Common service items: blower motor $280-$440; variable-speed control $240-$380; LED driver $180-$280; grease-filter latch $120-$200. The insert-vs-standalone distinction affects labor time, not parts cost, motor SKU is the same."
  },
  {
    q: "What does Bosch range hood repair cost in LA?",
    a: "Residential diagnostic $89 waived with repair. Typical Bosch bands: <b>500 Series</b> motor $240–$380; control board $280–$420; LED driver $160–$260; halogen transformer (older units) $180–$260; grease-filter latch $100–$180. <b>800 Series</b> motor $280–$440; control board (4-speed + Home Connect) $320–$480; 43-inch island extension kit $240–$360; dishwasher-safe filter assembly $80–$140. <b>HUI pull-out</b> slide-rail cleaning + realign $140–$220 (often no part); spring mechanism $160–$260. <b>Home Connect WiFi module</b> $180–$280. BSH Irvine 1-2 day LA-local parts chain; Thermador cross-references occasionally shorten backorder wait."
  }
];

const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair, Bosch Range Hood Service",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": canonical, "telephone": MAIN_PHONE_TEL, "priceRange": "$$$"
  },
  { "@context": "https://schema.org", "@type": "Service", "serviceType": "Bosch Range Hood Repair",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "description": "Bosch range hood repair across LA, 500 Series DUH undercabinet + HCP wall convertible, 800 Series 30/36\" wall + 43\" island + 30\" insert, HUI telescopic pull-out. Home Connect WiFi flagship. BSH Home Appliances Irvine California 1-2 day LA-local parts chain. $89 residential diagnostic waived with repair.",
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, waived with repair" } }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "Bosch", "item": "https://samedayappliance.repair/brands/bosch/" },
      { "@type": "ListItem", "position": 4, "name": "Bosch Range Hood Repair", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">{schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}</Fragment>
  <div class="call-banner"><div class="wrap"><span>Bosch range hood service?</span><a href={`tel:${MAIN_PHONE_TEL}`} class="phone-lg">{MAIN_PHONE}</a></div></div>

  <section class="hero"><div class="wrap">
    <div class="crumb"><a href="/">Home</a> › <a href="/brands/">Brands</a> › Bosch › Range Hood Repair</div>
    <h1>Bosch Range Hood Repair</h1>
    <p class="lede">Bosch's US residential range-hood lineup runs 500 Series premium-entry (DUH undercabinet + HCP wall-mount convertible with Home Connect WiFi on flagship) and 800 Series premium (30/36-inch wall, 43-inch island, 30-inch insert for custom hoods, dishwasher-safe filters, 4-speed variable control) plus the HUI-series telescopic pull-out that retracts flush when not in use. All route through BSH Home Appliances Irvine California parts distribution, 1-2 day LA-local delivery on common components, and Home Connect is the shared BSH app platform spanning Bosch + Thermador + Gaggenau residential. For LA, Bosch range hoods show up in premium kitchen remodels where Bosch dishwasher + range + refrigerator were the suite, and the hood was spec'd to match. Same-day dispatch, $89 residential diagnostic waived with the repair.</p>
    <div class="hero-cta"><a href={`tel:${MAIN_PHONE_TEL}`} class="btn btn-primary">Call {MAIN_PHONE}</a><a href="#book" class="btn btn-ghost">Request a Visit</a></div>
    <ul class="hero-facts">
      <li><b>500 Series DUH/HCP + 800 Series wall/island/insert + HUI pull-out</b>, full format coverage</li>
      <li><b>Home Connect WiFi</b>, shared BSH platform with Thermador + Gaggenau</li>
      <li><b>BSH Irvine CA 1-2 day LA-local parts</b>, one of LA's fastest luxury chains</li>
      <li><b>$89 residential diagnostic</b>, waived when you authorize the repair</li>
    </ul>
  </div></section>

  <BrandBranchesGrid />

  <section class="trust-bar"><div class="wrap"><span>BHGS #A49573 · Insured</span><span>Same-day in 5 SoCal counties</span><span>Residential diagnostic $89 · waived with repair</span></div></section>

  <section class="section"><div class="wrap">
    <h2>What Bosch range hood repair costs in LA</h2>
    <table class="price-table">
      <tr><th>Service</th><th>Typical Range</th><th>Notes</th></tr>
      <tr><td>Residential diagnostic</td><td>$89</td><td>Waived with repair</td></tr>
      <tr><td>500 Series motor (DUH / HCP)</td><td>$240 – $380</td><td>Premium-entry tier</td></tr>
      <tr><td>500 Series control board</td><td>$280 – $420</td><td>3-4 speed electronics</td></tr>
      <tr><td>800 Series motor</td><td>$280 – $440</td><td>Premium 4-speed</td></tr>
      <tr><td>800 Series control board (4-speed + Home Connect)</td><td>$320 – $480</td><td>WiFi-integrated</td></tr>
      <tr><td>LED driver</td><td>$160 – $280</td><td>Task lighting</td></tr>
      <tr><td>Grease-filter latch</td><td>$100 – $180</td><td>Interlock trigger</td></tr>
      <tr><td>HUI pull-out slide-rail service</td><td>$140 – $260</td><td>Clean + realign; often no part</td></tr>
      <tr><td>HUI spring mechanism</td><td>$160 – $260</td><td>10+ year fatigue</td></tr>
      <tr><td>Home Connect WiFi module</td><td>$180 – $280</td><td>Post-firmware pairing recovery</td></tr>
    </table>
    <p class="small">Related: <a href="/brands/bosch-dishwasher-repair/">Bosch brand hub</a> · <a href="/brands/bosch-dishwasher-repair/">Bosch dishwasher</a> · <a href="/brands/bosch-oven-repair/">Bosch oven</a> · <a href="/brands/bosch-microwave-repair/">Bosch microwave (legacy scope)</a> · <a href="/brands/thermador-range-hood-repair/">Thermador range hood (BSH sibling + cross-fit)</a> · <a href="/brands/gaggenau-range-hood-repair/">Gaggenau range hood (BSH ultra-luxury sibling)</a> · <a href="/services/range-hood-repair/">Range hood repair (service hub)</a> · <a href="/price-list/range-hood-repair-cost/">Range hood repair cost</a>.</p>
  </div></section>

  <section class="section alt"><div class="wrap narrow">
    <h2>BSH Home Appliances family, Bosch's place in the luxury hierarchy</h2>
    <p>Bosch is the premium tier in the BSH Home Appliances residential hierarchy, positioned below Thermador (American-style luxury) and Gaggenau (ultra-luxury modular architecture), above most mass-market brands. For range hoods specifically, Bosch 800 Series competes directly with Thermador HMCB and GE Profile, premium at $1,000-$2,500 hood pricing, 600+ CFM, dishwasher-safe filter hardware, Home Connect WiFi on flagship models. Bosch 500 Series addresses the premium-entry tier for mid-market renovations where Bosch dishwasher + range are the hero pieces but the hood budget needs to stay under $800.</p>
    <p>Service-side, the BSH Irvine California parts chain is a real advantage over mass-market brands and a modest advantage over competing European-import luxury brands (Miele, Asko) whose US parts networks are thinner. Home Connect pairing recovery is the same sequence across Bosch, Thermador, and Gaggenau residential units, one diagnostic protocol covers the whole BSH family. See <a href="/brands/thermador-range-hood-repair/">Thermador range hood</a> · <a href="/brands/gaggenau-range-hood-repair/">Gaggenau range hood</a> for sibling context.</p>
  </div></section>

  <section class="section"><div class="wrap narrow">
    <h2>Bosch range hood repair, frequently asked</h2>
    {faqs.map(f => (<details class="faq"><summary>{f.q}</summary><p set:html={f.a}></p></details>))}
  </div></section>

  <section id="book" class="cta-bottom"><div class="wrap">
    <h2>Bosch range hood service? Call the branch closest to your home.</h2>
    <p>Same-day appliance repair in Los Angeles, Orange County, Ventura County. Residential diagnostic $89, waived with repair.</p>
  </div></section>
  <a href={`tel:${MAIN_PHONE_TEL}`} class="float-call" aria-label="Call now">☎ Call {MAIN_PHONE}</a>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  body { color: var(--text); } .wrap { max-width: 1200px; margin: 0 auto; padding: 0 24px; } .wrap.narrow { max-width: 820px; }
  h1 { font-size: 2.4rem; line-height: 1.15; margin: 12px 0 20px; color: var(--black); }
  h2 { font-size: 1.8rem; margin: 0 0 16px; color: var(--black); }
  p { line-height: 1.65; margin: 0 0 14px; }
  .call-banner { background: var(--red); color: #fff; padding: 10px 0; }
  .call-banner .wrap { display:flex; gap: 14px; align-items: center; justify-content: center; flex-wrap: wrap; }
  .call-banner .phone-lg { color:#fff; font-weight: 800; text-decoration: underline; font-size: 1.05rem; }
  .hero { background: var(--black); color: #fff; padding: 42px 0 56px; } .hero h1 { color: #fff; }
  .hero .lede { font-size: 1.06rem; color: #d7d7d7; max-width: 680px; }
  .hero .crumb { color: #9a9a9a; font-size: 0.85rem; margin-bottom: 6px; } .hero .crumb a { color: #c9c9c9; text-decoration: none; }
  .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; margin: 18px 0 24px; }
  .btn { display: inline-block; padding: 12px 20px; border-radius: 4px; text-decoration: none; font-weight: 700; }
  .btn-primary { background: var(--red); color: #fff; } .btn-ghost { background: transparent; color: #fff; border: 1px solid #fff; }
  .hero-facts { list-style: none; padding: 0; margin: 0; color: #c9c9c9; font-size: 0.95rem; }
  .hero-facts li { padding: 6px 0; border-top: 1px solid #222; } .hero-facts li:first-child { border-top: 0; }
  .trust-bar { background: var(--red); color: #fff; padding: 14px 0; }
  .trust-bar .wrap { display: flex; gap: 28px; flex-wrap: wrap; justify-content: center; font-size: 0.95rem; font-weight: 600; }
  .section { padding: 56px 0; } .section.alt { background: var(--gray); }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 14px; background: #fff; }
  .price-table th, .price-table td { text-align: left; padding: 11px 12px; border-bottom: 1px solid var(--border); }
  .price-table th { background: var(--black); color: #fff; font-weight: 700; font-size: 0.95rem; }
  .small { color: var(--muted); font-size: 0.92rem; margin-top: 12px; }
  .faq { background: #fff; border: 1px solid var(--border); padding: 12px 16px; margin-bottom: 8px; border-radius: 4px; }
  .faq summary { font-weight: 700; cursor: pointer; padding: 4px 0; } .faq p { margin: 8px 0 0; }
  .cta-bottom { background: var(--black); color: #fff; padding: 48px 0; } .cta-bottom h2 { color: #fff; } .cta-bottom p { color: #c9c9c9; }
  .float-call { position: fixed; bottom: 18px; right: 18px; background: var(--red); color: #fff; padding: 14px 18px; border-radius: 40px; text-decoration: none; font-weight: 700; box-shadow: 0 6px 18px rgba(0,0,0,0.28); z-index: 50; font-size: 0.95rem; }
  @media (max-width: 820px) { h1 { font-size: 1.9rem; } .float-call { padding: 11px 14px; font-size: 0.88rem; } .trust-bar .wrap { gap: 14px; font-size: 0.85rem; } }
</style>
