---
import Layout from '../../layouts/Layout.astro';
import BrandBranchesGrid from '../../components/BrandBranchesGrid.astro';
import { MAIN_PHONE, MAIN_PHONE_TEL } from '../../data/branches';

const title = "GE Cafe Ice Maker Repair | Southern California | Matte Black + Brass Trim";
const description = "GE Cafe ice maker repair across Southern California, CDE06 undercounter + CYE22 French-door integrated, Matte Black / Platinum Glass, customizable brass / chrome hardware. $89 diagnostic. (424) 325-0520.";
const canonical = "https://samedayappliance.repair/brands/ge-cafe-ice-maker-repair/";

const faqs = [
  {
    q: "How does Cafe ice maker fit in the GE four-tier hierarchy?",
    a: "<b>GE Cafe</b> is the premium-prosumer tier ($2.5-8k), between mass-market <a href='/brands/ge-ice-maker-repair/'>GE</a> and ultra-luxury <a href='/brands/ge-monogram-ice-maker-repair/'>GE Monogram</a>. Cafe's signature is industrial-aesthetic design + customizable hardware trim (brushed brass / brushed copper / matte black interchangeable handles). Ice maker lineup: CDE06-series 15\" undercounter + CYE22 French-door integrated + shared Opal connection on some variants. See <a href='/brands/ge-profile-ice-maker-repair/'>GE Profile</a> for premium-refined sibling tier."
  },
  {
    q: "Cafe customizable hardware, does handle replacement need service?",
    a: "Customizable-hardware swap is designed for owner-DIY, handles ship with mounting hardware for household tool-kit installation. Most hardware refreshes happen without our involvement. Service calls on Cafe hardware are typically: (1) mounting hardware damaged during owner-swap attempt ($140–$220 correction + reinstall); (2) handle unseating from thermal-cycle stress (rare, usually tightening at diagnostic). Handle replacement parts $60–$240 depending on finish + model, owner-installable."
  },
  {
    q: "CDE06 undercounter ice maker diagnostic?",
    a: "CDE06-series 15\" undercounter uses conventional refrigeration architecture. Common: water-inlet valve $220–$340; condenser cleaning $140–$240 (undercounter ventilation restricted, dust accumulation common); compressor start relay $180–$280; ice-thickness probe $200–$320; evaporator plate service $280–$420; control board $440–$640. LA outdoor-kitchen installs see more-frequent condenser cleaning need."
  },
  {
    q: "Matte finish care on Cafe during service?",
    a: "Matte Black + Platinum Glass finishes require soft-cloth + mild-soap cleaning, abrasive cleaners damage the matte coat. During service we mask and cover Matte surfaces near interior work. Customer care tip: routine cleaning with microfiber + warm water preserves the matte-finish finish. Panel replacement 2-4 week lead through GE Appliances parts channel if finish damage requires replacement."
  },
  {
    q: "What does GE Cafe ice maker repair cost in LA?",
    a: "Residential diagnostic $89 waived with repair. Typical Cafe bands: water-inlet valve $220–$340; modular ice-maker assembly $240–$380; condenser cleaning $140–$240; compressor start relay $180–$280; ice-thickness probe $200–$320; control board $440–$640; SmartHQ WiFi module $260–$400; customizable hardware parts $60–$240 (owner-installable); Matte panel replacement quoted individually 2-4 week lead."
  },
  {
    q: "Cafe vs commercial ice machines?",
    a: "Cafe is residential-only. For restaurant / commercial 200+ lb/day ice production, see <a href='/commercial/ice-machine-repair/'>commercial ice machine repair</a>."
  }
];

const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair, GE Cafe Ice Maker Service",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": canonical, "telephone": MAIN_PHONE_TEL, "priceRange": "$$$"
  },
  { "@context": "https://schema.org", "@type": "Service", "serviceType": "GE Cafe Ice Maker Repair",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "description": "GE Cafe ice maker repair across LA, CDE06 undercounter + CYE22 French-door integrated, Matte Black / Platinum Glass finish, customizable hardware. GE Appliances (Haier 2016+) Louisville KY parts. $89 residential diagnostic waived with repair.",
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, waived with repair" } }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "GE Cafe", "item": "https://samedayappliance.repair/brands/ge-cafe/" },
      { "@type": "ListItem", "position": 4, "name": "GE Cafe Ice Maker Repair", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">{schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}</Fragment>
  <div class="call-banner"><div class="wrap"><span>GE Cafe ice maker service? Same-day across LA:</span><a href={`tel:${MAIN_PHONE_TEL}`} class="phone-lg">{MAIN_PHONE}</a></div></div>

  <section class="hero"><div class="wrap">
    <div class="crumb"><a href="/">Home</a> › <a href="/brands/">Brands</a> › GE Cafe › Ice Maker Repair</div>
    <h1>GE Cafe Ice Maker Repair</h1>
    <p class="lede">GE Cafe is the premium-prosumer tier in GE Appliances' four-tier hierarchy ($2.5-8k positioning), with industrial-aesthetic design + customizable hardware trim (brushed brass / brushed copper / matte black interchangeable handles) as the signature differentiator. Ice maker lineup: CDE06 15" undercounter + CYE22 French-door integrated + SmartHQ WiFi integration shared with Profile. Our LA Cafe service concentrates in Silver Lake + Los Feliz + Highland Park + Venice + Studio City + Pasadena design-forward kitchens. Same-day dispatch, $89 residential diagnostic waived with the repair.</p>
    <div class="hero-cta"><a href={`tel:${MAIN_PHONE_TEL}`} class="btn btn-primary">Call {MAIN_PHONE}</a><a href="#book" class="btn btn-ghost">Request a Visit</a></div>
    <ul class="hero-facts">
      <li><b>Premium-prosumer tier</b>, $2.5-8k between Profile + Monogram</li>
      <li><b>Matte Black + Platinum Glass</b>, requires soft-cloth cleaning</li>
      <li><b>Customizable hardware</b>, owner-installable brass / chrome / black</li>
      <li><b>$89 residential diagnostic</b>, waived when you authorize the repair</li>
    </ul>
  </div></section>

  <BrandBranchesGrid />

  <section class="trust-bar"><div class="wrap"><span>BHGS #A49573 · Insured</span><span>Same-day in 5 SoCal counties</span><span>Residential diagnostic $89 · waived with repair</span></div></section>

  <section class="section"><div class="wrap narrow">
    <h2>GE Cafe ice maker service in LA, industrial design + customizable hardware</h2>
    <p>Cafe's LA install base concentrates in design-forward households where industrial-aesthetic + hardware-swap flexibility are the purchase driver. CDE06 undercounter and CYE22 French-door ice makers both sit in kitchens where the Matte Black + Platinum Glass finish is a deliberate design choice. Service approach protects finish integrity during interior-component work. Customizable hardware swap is typically owner-DIY, we only handle hardware service when mounting needs correction or the thermal-cycle stress has unseated a handle.</p>
  </div></section>

  <section class="section alt"><div class="wrap">
    <h2>Cafe ice maker failures our techs see most often in LA</h2>
    <div class="fail-block"><h3>CDE06 undercounter water-inlet valve</h3><p>Valve $220–$340.</p></div>
    <div class="fail-block"><h3>CDE06 condenser cleaning</h3><p>Undercounter ventilation restricted. Clean $140–$240.</p></div>
    <div class="fail-block"><h3>CYE22 French-door modular assembly</h3><p>Integrated ice maker $240–$380.</p></div>
    <div class="fail-block"><h3>Matte finish exterior damage</h3><p>Panel replacement 2-4 week lead through GE Appliances.</p></div>
    <div class="fail-block"><h3>SmartHQ connectivity</h3><p>WiFi config first; module $260–$400 only if confirmed.</p></div>
    <div class="fail-block"><h3>Compressor start relay (CDE06)</h3><p>Relay $180–$280.</p></div>
  </div></section>

  <section class="section"><div class="wrap">
    <h2>GE Cafe ice maker product lines we service</h2>
    <div class="model-grid">
      <div class="model-card"><h3>CDE06 15" undercounter</h3><p>Dedicated undercounter ice maker. Conventional refrigeration. Matte / stainless finish.</p></div>
      <div class="model-card"><h3>CYE22 French-door integrated</h3><p>French-door refrigerator with integrated ice + water.</p></div>
      <div class="model-card"><h3>Customizable hardware trim</h3><p>Brass / chrome / matte black interchangeable. Owner-installable.</p></div>
      <div class="model-card"><h3>Matte finish program</h3><p>Matte Black + Platinum Glass signature. Soft-cloth care.</p></div>
      <div class="model-card"><h3>SmartHQ WiFi integration</h3><p>Unified GE connected ecosystem.</p></div>
      <div class="model-card"><h3>Louisville KY parts network</h3><p>1-day LA-local parts distribution.</p></div>
    </div>
  </div></section>

  <section class="section alt"><div class="wrap narrow">
    <h2>Residential Cafe vs commercial ice machines</h2>
    <p>Cafe is residential-only. See <a href="/commercial/ice-machine-repair/">commercial ice machine repair</a> for restaurant-scale.</p>
  </div></section>

  <section class="section"><div class="wrap">
    <h2>What GE Cafe ice maker repair costs in LA</h2>
    <table class="price-table">
      <tr><th>Service</th><th>Typical Range</th><th>Notes</th></tr>
      <tr><td>Residential diagnostic</td><td>$89</td><td>Waived with repair</td></tr>
      <tr><td>Water-inlet valve</td><td>$220 – $340</td><td>CDE06 undercounter</td></tr>
      <tr><td>Modular ice-maker assembly</td><td>$240 – $380</td><td>CYE22 French-door</td></tr>
      <tr><td>Condenser cleaning</td><td>$140 – $240</td><td>Undercounter ventilation</td></tr>
      <tr><td>Compressor start relay</td><td>$180 – $280</td><td>Start circuit</td></tr>
      <tr><td>Ice-thickness probe</td><td>$200 – $320</td><td>Cycle trigger</td></tr>
      <tr><td>Control board</td><td>$440 – $640</td><td>Main control</td></tr>
      <tr><td>SmartHQ WiFi module</td><td>$260 – $400</td><td>Smart connectivity</td></tr>
      <tr><td>Customizable hardware</td><td>$60 – $240</td><td>Owner-installable</td></tr>
      <tr><td>Matte panel replacement</td><td>Quoted individually</td><td>2-4 week lead</td></tr>
    </table>
    <p class="small">Related: <a href="/brands/ge-cafe/">GE Cafe brand hub</a> · <a href="/brands/ge-profile-ice-maker-repair/">GE Profile</a> · <a href="/brands/ge-monogram-ice-maker-repair/">GE Monogram</a> · <a href="/brands/ge-ice-maker-repair/">GE mass-market</a>.</p>
  </div></section>

  <section class="section alt"><div class="wrap">
    <h2>LA service areas</h2>
    <div class="area-grid">
      <div><h4>Silver Lake + Los Feliz</h4><p>Silver Lake · Los Feliz · Echo Park · Highland Park</p></div>
      <div><h4>Venice + Santa Monica</h4><p>Venice · Santa Monica · Mar Vista</p></div>
      <div><h4>Studio City + Atwater</h4><p>Studio City · Atwater Village · Glassell Park</p></div>
      <div><h4>Pasadena + South Pasadena</h4><p><a href="/pasadena/">Pasadena</a> · South Pasadena</p></div>
      <div><h4>Hermosa + coastal design</h4><p>Hermosa · Manhattan Beach</p></div>
      <div><h4>OC design-forward</h4><p>Costa Mesa · Newport Beach · <a href="/irvine/">Irvine</a></p></div>
    </div>
  </div></section>

  <section class="section"><div class="wrap narrow">
    <h2>Related GE Cafe and family pages</h2>
    <ul class="related-links">
      <li><a href="/brands/ge-cafe/">GE Cafe brand hub →</a></li>
      <li><a href="/brands/ge-profile-ice-maker-repair/">GE Profile ice maker →</a></li>
      <li><a href="/brands/ge-monogram-ice-maker-repair/">GE Monogram ice maker →</a></li>
      <li><a href="/brands/ge-ice-maker-repair/">GE ice maker (mass-market) →</a></li>
      <li><a href="/services/ice-maker-repair/">Ice maker repair (service hub) →</a></li>
      <li><a href="/price-list/ice-maker-repair-cost/">Ice maker repair cost guide →</a></li>
      <li><a href="/commercial/ice-machine-repair/">Commercial ice machine repair →</a></li>
    </ul>
  </div></section>

  <section class="section alt"><div class="wrap narrow">
    <h2>GE Cafe ice maker repair, frequently asked</h2>
    {faqs.map(f => (<details class="faq"><summary>{f.q}</summary><p set:html={f.a}></p></details>))}
  </div></section>

  <section id="book" class="cta-bottom"><div class="wrap">
    <h2>GE Cafe ice maker service? Call the branch closest to your home.</h2>
    <p>Same-day appliance repair in Los Angeles, Orange County, Ventura County. Residential diagnostic $89, waived with repair.</p>
  </div></section>
  <a href={`tel:${MAIN_PHONE_TEL}`} class="float-call" aria-label="Call now">☎ Call {MAIN_PHONE}</a>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  body { color: var(--text); } .wrap { max-width: 1200px; margin: 0 auto; padding: 0 24px; } .wrap.narrow { max-width: 820px; }
  h1 { font-size: 2.4rem; line-height: 1.15; margin: 12px 0 20px; color: var(--black); }
  h2 { font-size: 1.8rem; margin: 0 0 16px; color: var(--black); }
  h3 { font-size: 1.2rem; margin: 0 0 10px; color: var(--black); }
  h4 { font-size: 1.02rem; margin: 0 0 6px; color: var(--black); }
  p { line-height: 1.65; margin: 0 0 14px; }
  .call-banner { background: var(--red); color: #fff; padding: 10px 0; }
  .call-banner .wrap { display:flex; gap: 14px; align-items: center; justify-content: center; flex-wrap: wrap; }
  .call-banner .phone-lg { color:#fff; font-weight: 800; text-decoration: underline; font-size: 1.05rem; }
  .hero { background: var(--black); color: #fff; padding: 42px 0 56px; } .hero h1 { color: #fff; }
  .hero .lede { font-size: 1.06rem; color: #d7d7d7; max-width: 680px; }
  .hero .crumb { color: #9a9a9a; font-size: 0.85rem; margin-bottom: 6px; } .hero .crumb a { color: #c9c9c9; text-decoration: none; }
  .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; margin: 18px 0 24px; }
  .btn { display: inline-block; padding: 12px 20px; border-radius: 4px; text-decoration: none; font-weight: 700; }
  .btn-primary { background: var(--red); color: #fff; } .btn-ghost { background: transparent; color: #fff; border: 1px solid #fff; }
  .hero-facts { list-style: none; padding: 0; margin: 0; color: #c9c9c9; font-size: 0.95rem; }
  .hero-facts li { padding: 6px 0; border-top: 1px solid #222; } .hero-facts li:first-child { border-top: 0; }
  .trust-bar { background: var(--red); color: #fff; padding: 14px 0; }
  .trust-bar .wrap { display: flex; gap: 28px; flex-wrap: wrap; justify-content: center; font-size: 0.95rem; font-weight: 600; }
  .section { padding: 56px 0; } .section.alt { background: var(--gray); }
  .model-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 20px; margin-top: 24px; }
  .model-card { background: #fff; border: 1px solid var(--border); padding: 20px; border-radius: 6px; }
  .section.alt .model-card { background: #fff; }
  .fail-block { background: #fff; border-left: 3px solid var(--red); padding: 20px 22px; margin: 16px 0; }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 14px; background: #fff; }
  .price-table th, .price-table td { text-align: left; padding: 11px 12px; border-bottom: 1px solid var(--border); }
  .price-table th { background: var(--black); color: #fff; font-weight: 700; font-size: 0.95rem; }
  .small { color: var(--muted); font-size: 0.92rem; margin-top: 12px; }
  .area-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 18px; }
  .area-grid > div { background: #fff; border: 1px solid var(--border); padding: 16px; border-radius: 6px; }
  .related-links { list-style: none; padding: 0; } .related-links li { padding: 10px 0; border-bottom: 1px solid var(--border); }
  .related-links a { color: var(--red); font-weight: 600; text-decoration: none; } .related-links a:hover { text-decoration: underline; }
  .faq { background: #fff; border: 1px solid var(--border); padding: 12px 16px; margin-bottom: 8px; border-radius: 4px; }
  .faq summary { font-weight: 700; cursor: pointer; padding: 4px 0; } .faq p { margin: 8px 0 0; }
  .cta-bottom { background: var(--black); color: #fff; padding: 48px 0; } .cta-bottom h2 { color: #fff; } .cta-bottom p { color: #c9c9c9; }
  .float-call { position: fixed; bottom: 18px; right: 18px; background: var(--red); color: #fff; padding: 14px 18px; border-radius: 40px; text-decoration: none; font-weight: 700; box-shadow: 0 6px 18px rgba(0,0,0,0.28); z-index: 50; font-size: 0.95rem; }
  @media (max-width: 820px) { h1 { font-size: 1.9rem; } h2 { font-size: 1.45rem; } .float-call { padding: 11px 14px; font-size: 0.88rem; } .trust-bar .wrap { gap: 14px; font-size: 0.85rem; } }
</style>
