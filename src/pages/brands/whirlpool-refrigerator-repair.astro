        <li><a href="/price-list/refrigerator-repair-cost/">Refrigerator repair cost guide →</a></li>
      </ul>
    </div>
  </section>

  <section class="section alt">
    <div class="wrap narrow">
      <h2>Whirlpool refrigerator repair, frequently asked</h2>
      {faqs.map(f => (
