---
import Layout from '../../layouts/Layout.astro';
import BrandDetailPlaceholder from '../../components/BrandDetailPlaceholder.astro';

const title = "Whirlpool Refrigerator Repair Los Angeles | French Door";
const description = "Whirlpool fridge repair across LA — French Door, side-by-side, ice maker module, water-filter housing. Same-day, $89 diagnostic waived. (424) 325-0520.";
const canonical = "https://samedayappliance.repair/brands/whirlpool-refrigerator-repair/";
---

<Layout title={title} description={description} canonical={canonical}>
  <BrandDetailPlaceholder
    brandName="Whirlpool"
    brandSlug="whirlpool"
    category="Refrigerator"
    categorySlug="refrigerator-repair"
    hubUrl="/brands/whirlpool/"
  />
</Layout>
