---
import Layout from '../../layouts/Layout.astro';
import BrandBranchesGrid from '../../components/BrandBranchesGrid.astro';
import { MAIN_PHONE, MAIN_PHONE_TEL } from '../../data/branches';

const title = "GE Monogram Ice Maker Repair | Southern California | Statement Collection";
const description = "GE Monogram ice maker repair across Southern California — Statement Collection ZDIS15 + ZDIS18 column integrated, ZICS360 refrigerator-integrated. Haier 2016+ ultra-luxury. $89 diagnostic. (424) 325-0520.";
const canonical = "https://samedayappliance.repair/brands/ge-monogram-ice-maker-repair/";

const faqs = [
  {
    q: "What's GE Monogram Statement Collection ice maker?",
    a: "<b>Statement Collection</b> is Monogram's 2019-launched ultra-luxury sub-line ($5-25k positioning), replacing older 'Professional' nomenclature. Ice maker lineup: ZDIS15 15\" column integrated + ZDIS18 18\" wider column + ZICS360 integrated with Monogram column refrigerator. Statement Collection ice makers use premium components (heavier-gauge stainless, pro-style trim) + interior-design-trade distribution channel. Parts through GE Appliances Louisville KY distribution (1-day LA-local on common components)."
  },
  {
    q: "How does Monogram ice maker differ from Cafe / Profile / GE mass-market?",
    a: "Same 4-tier GE hierarchy applies: Monogram ultra-luxury ($5-25k) > Cafe premium-prosumer ($2.5-8k) > Profile premium-refined ($1.5-5k) > GE mass-market. Monogram Statement Collection ice makers use premium components distinct from lower tiers but share the same Louisville KY parts distribution. Install base: Bel Air + Beverly Hills + Pacific Palisades ultra-luxury custom kitchens accessed via interior-design trade channel. See <a href='/brands/ge-cafe-ice-maker-repair/'>Cafe</a> and <a href='/brands/ge-profile-ice-maker-repair/'>Profile</a> for sibling tiers."
  },
  {
    q: "Monogram column-integrated ice maker diagnostic?",
    a: "ZDIS15 / ZDIS18 column integrated ice makers use dedicated refrigeration architecture (own compressor + condenser in column format). Common: water-inlet valve $260–$400; condenser fan motor $280–$420; ice-maker modular assembly $300–$460; ice-thickness probe $220–$340; control board $480–$680. Column-integrated service requires access-side coordination because the ice maker column sits adjacent to Monogram refrigerator / freezer columns in the luxury-kitchen suite."
  },
  {
    q: "Monogram WiFi SmartHQ diagnostic?",
    a: "Monogram shares SmartHQ app with Profile + Cafe. WiFi faults resolve at: 2.4GHz configuration, account re-pair, firmware update, or WiFi module swap $280–$420 when hardware confirmed. Ice-maker operates independently of SmartHQ connectivity — smart layer is additive."
  },
  {
    q: "What does GE Monogram ice maker repair cost in LA?",
    a: "Residential diagnostic $89 waived with repair. Typical Monogram bands: water-inlet valve $260–$400; column-integrated modular assembly $300–$460; condenser fan motor $280–$420; compressor start relay $200–$320; ice-thickness probe $220–$340; evaporator plate service $320–$460; control board $480–$680; SmartHQ WiFi module $280–$420; panel / trim quoted individually. Monogram service runs 20-30% above mass-market GE on individual parts reflecting Statement Collection premium spec."
  },
  {
    q: "Monogram vs commercial ice machines?",
    a: "Monogram is residential-only. For restaurant / commercial 200+ lb/day, see <a href='/commercial/ice-machine-repair/'>commercial ice machine repair</a>."
  }
];

const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair — GE Monogram Ice Maker Service",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": canonical, "telephone": MAIN_PHONE_TEL, "priceRange": "$$$$"
  },
  { "@context": "https://schema.org", "@type": "Service", "serviceType": "GE Monogram Ice Maker Repair",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "description": "GE Monogram ice maker repair across Southern California — LA, Orange, Ventura, San Bernardino, Riverside. Statement Collection ZDIS15 / ZDIS18 column integrated, ZICS360 refrigerator-integrated. Haier 2016+ ultra-luxury, Louisville KY parts. $89 residential diagnostic waived with repair.",
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, waived with repair" } }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "GE Monogram", "item": "https://samedayappliance.repair/brands/ge-monogram/" },
      { "@type": "ListItem", "position": 4, "name": "GE Monogram Ice Maker Repair", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">{schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}</Fragment>
  <div class="call-banner"><div class="wrap"><span>GE Monogram ice maker service? Same-day across LA:</span><a href={`tel:${MAIN_PHONE_TEL}`} class="phone-lg">{MAIN_PHONE}</a></div></div>

  <section class="hero"><div class="wrap">
    <div class="crumb"><a href="/">Home</a> › <a href="/brands/">Brands</a> › GE Monogram › Ice Maker Repair</div>
    <h1>GE Monogram Ice Maker Repair</h1>
    <p class="lede">GE Monogram is GE Appliances' ultra-luxury tier under Haier 2016+ ownership — Statement Collection ice makers (ZDIS15 + ZDIS18 column integrated, ZICS360 refrigerator-integrated) anchor the $5-25k product range, sold through interior-design trade channel into Bel Air + Beverly Hills + Pacific Palisades ultra-luxury custom kitchens. Parts through GE Appliances Louisville KY distribution with 1-day LA-local on common service components. Same-day dispatch, $89 residential diagnostic waived with the repair.</p>
    <div class="hero-cta"><a href={`tel:${MAIN_PHONE_TEL}`} class="btn btn-primary">Call {MAIN_PHONE}</a><a href="#book" class="btn btn-ghost">Request a Visit</a></div>
    <ul class="hero-facts">
      <li><b>Statement Collection ultra-luxury</b> — $5-25k positioning</li>
      <li><b>Haier 2016+ ownership</b> — Louisville KY US operations retained</li>
      <li><b>Interior-design trade channel</b> — comprehensive Monogram-suite installs</li>
      <li><b>$89 residential diagnostic</b> — waived when you authorize the repair</li>
    </ul>
  </div></section>

  <BrandBranchesGrid />

  <section class="trust-bar"><div class="wrap"><span>CSLB #1138898 · Insured</span><span>Same-day in 5 SoCal counties</span><span>Residential diagnostic $89 · waived with repair</span></div></section>

  <section class="section"><div class="wrap narrow">
    <h2>GE Monogram ice maker service across Southern California — ultra-luxury column integration</h2>
    <p>Monogram installs across our service area — Westside LA luxury, Newport Coast and Pelican Hill OC luxury, Westlake Village and Hidden Hills Conejo Valley estates, and Rancho Cucamonga / Temecula wine-country IE estates — are typically comprehensive Monogram-suite kitchens (refrigerator column + freezer column + ice maker column + dishwasher + range + wall ovens specified as coordinated suite) rather than individual Monogram appliances. Service reflects this: when called for Monogram ice-maker service, we're often working alongside other Monogram components in the same kitchen. Parts through Louisville KY distribution; Statement Collection premium components run 20-30% above mass-market GE pricing.</p>
  </div></section>

  <section class="section alt"><div class="wrap">
    <h2>Monogram ice maker failures our techs see most often</h2>
    <div class="fail-block"><h3>Water-inlet valve (column integrated)</h3><p>Valve $260–$400.</p></div>
    <div class="fail-block"><h3>Column-integrated modular assembly</h3><p>Full module $300–$460.</p></div>
    <div class="fail-block"><h3>Condenser fan motor</h3><p>Motor $280–$420.</p></div>
    <div class="fail-block"><h3>Compressor start relay</h3><p>Relay $200–$320.</p></div>
    <div class="fail-block"><h3>Ice-thickness probe</h3><p>Probe $220–$340.</p></div>
    <div class="fail-block"><h3>SmartHQ connectivity</h3><p>WiFi config / module $280–$420.</p></div>
  </div></section>

  <section class="section"><div class="wrap">
    <h2>Monogram ice maker product lines we service</h2>
    <div class="model-grid">
      <div class="model-card"><h3>ZDIS15 15" column integrated</h3><p>Statement Collection 15" ice-maker column. Pairs with Monogram refrigerator + freezer columns.</p></div>
      <div class="model-card"><h3>ZDIS18 18" wider column</h3><p>Statement Collection 18" format. Higher production capacity.</p></div>
      <div class="model-card"><h3>ZICS360 French-door integrated</h3><p>Monogram French-door refrigerator with integrated ice maker.</p></div>
      <div class="model-card"><h3>Statement Collection 2019+</h3><p>Replaced older 'Professional' nomenclature.</p></div>
      <div class="model-card"><h3>Interior-design trade channel</h3><p>Comprehensive Monogram-suite typical vs mixed-brand kitchens.</p></div>
      <div class="model-card"><h3>SmartHQ app integration</h3><p>Shared with Profile + Cafe ecosystem.</p></div>
    </div>
  </div></section>

  <section class="section alt"><div class="wrap narrow">
    <h2>Residential Monogram vs commercial ice machines</h2>
    <p>Monogram is residential-only. Statement Collection residential vs commercial Manitowoc / Hoshizaki / Scotsman — see <a href="/commercial/ice-machine-repair/">commercial ice machine repair</a>.</p>
  </div></section>

  <section class="section"><div class="wrap">
    <h2>What Monogram ice maker repair costs in LA</h2>
    <table class="price-table">
      <tr><th>Service</th><th>Typical Range</th><th>Notes</th></tr>
      <tr><td>Residential diagnostic</td><td>$89</td><td>Waived with repair</td></tr>
      <tr><td>Water-inlet valve</td><td>$260 – $400</td><td>Column-integrated</td></tr>
      <tr><td>Modular assembly</td><td>$300 – $460</td><td>Full module</td></tr>
      <tr><td>Condenser fan motor</td><td>$280 – $420</td><td>Column airflow</td></tr>
      <tr><td>Compressor start relay</td><td>$200 – $320</td><td>Start circuit</td></tr>
      <tr><td>Ice-thickness probe</td><td>$220 – $340</td><td>Cycle trigger</td></tr>
      <tr><td>Evaporator plate service</td><td>$320 – $460</td><td>Cold-plate maintenance</td></tr>
      <tr><td>Control board</td><td>$480 – $680</td><td>Main control</td></tr>
      <tr><td>SmartHQ WiFi module</td><td>$280 – $420</td><td>Smart connectivity</td></tr>
    </table>
    <p class="small">Related: <a href="/brands/ge-monogram/">GE Monogram brand hub</a> · <a href="/brands/ge-cafe-ice-maker-repair/">Cafe</a> · <a href="/brands/ge-profile-ice-maker-repair/">Profile</a> · <a href="/brands/sub-zero-ice-maker-repair/">Sub-Zero (column competitor)</a>.</p>
  </div></section>

  <section class="section alt"><div class="wrap">
    <h2>Service areas</h2>
    <div class="area-grid">
      <div><h4>Bel Air + Beverly Hills</h4><p><a href="/beverly-hills/">Beverly Hills</a> · Bel Air · Holmby Hills</p></div>
      <div><h4>Pacific Palisades + Brentwood</h4><p>Pacific Palisades · Brentwood</p></div>
      <div><h4>Pasadena + San Marino</h4><p><a href="/pasadena/">Pasadena</a> · San Marino</p></div>
      <div><h4>OC ultra-luxury</h4><p>Newport Coast · Pelican Hill · Corona del Mar · Coto de Caza · Shady Canyon · <a href="/irvine/">Irvine</a></p></div>
      <div><h4>Coastal luxury</h4><p><a href="/malibu/">Malibu</a> · Manhattan Beach · Laguna Beach</p></div>
      <div><h4>Westside design</h4><p>Santa Monica · Venice</p></div>
      <div><h4>Conejo Valley estates</h4><p>Westlake Village · Hidden Hills · <a href="/thousand-oaks/">Thousand Oaks</a></p></div>
      <div><h4>Inland Empire estates</h4><p><a href="/rancho-cucamonga/">Rancho Cucamonga</a> · Alta Loma · Temecula wine-country</p></div>
    </div>
  </div></section>

  <section class="section"><div class="wrap narrow">
    <h2>Related GE Monogram and family pages</h2>
    <ul class="related-links">
      <li><a href="/brands/ge-monogram/">GE Monogram brand hub →</a></li>
      <li><a href="/brands/ge-cafe-ice-maker-repair/">GE Cafe ice maker →</a></li>
      <li><a href="/brands/ge-profile-ice-maker-repair/">GE Profile ice maker →</a></li>
      <li><a href="/brands/sub-zero-ice-maker-repair/">Sub-Zero ice maker (column alt) →</a></li>
      <li><a href="/services/ice-maker-repair/">Ice maker repair (service hub) →</a></li>
      <li><a href="/price-list/ice-maker-repair-cost/">Ice maker repair cost guide →</a></li>
      <li><a href="/commercial/ice-machine-repair/">Commercial ice machine repair →</a></li>
    </ul>
  </div></section>

  <section class="section alt"><div class="wrap narrow">
    <h2>Monogram ice maker repair — frequently asked</h2>
    {faqs.map(f => (<details class="faq"><summary>{f.q}</summary><p set:html={f.a}></p></details>))}
  </div></section>

  <section id="book" class="cta-bottom"><div class="wrap">
    <h2>Monogram ice maker service? Call the branch closest to your home.</h2>
    <p>Same-day appliance repair across Los Angeles, Orange, Ventura, San Bernardino, and Riverside counties. Residential diagnostic $89, waived with repair.</p>
  </div></section>
  <a href={`tel:${MAIN_PHONE_TEL}`} class="float-call" aria-label="Call now">☎ Call {MAIN_PHONE}</a>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  body { color: var(--text); } .wrap { max-width: 1200px; margin: 0 auto; padding: 0 24px; } .wrap.narrow { max-width: 820px; }
  h1 { font-size: 2.4rem; line-height: 1.15; margin: 12px 0 20px; color: var(--black); }
  h2 { font-size: 1.8rem; margin: 0 0 16px; color: var(--black); }
  h3 { font-size: 1.2rem; margin: 0 0 10px; color: var(--black); }
  h4 { font-size: 1.02rem; margin: 0 0 6px; color: var(--black); }
  p { line-height: 1.65; margin: 0 0 14px; }
  .call-banner { background: var(--red); color: #fff; padding: 10px 0; }
  .call-banner .wrap { display:flex; gap: 14px; align-items: center; justify-content: center; flex-wrap: wrap; }
  .call-banner .phone-lg { color:#fff; font-weight: 800; text-decoration: underline; font-size: 1.05rem; }
  .hero { background: var(--black); color: #fff; padding: 42px 0 56px; } .hero h1 { color: #fff; }
  .hero .lede { font-size: 1.06rem; color: #d7d7d7; max-width: 680px; }
  .hero .crumb { color: #9a9a9a; font-size: 0.85rem; margin-bottom: 6px; } .hero .crumb a { color: #c9c9c9; text-decoration: none; }
  .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; margin: 18px 0 24px; }
  .btn { display: inline-block; padding: 12px 20px; border-radius: 4px; text-decoration: none; font-weight: 700; }
  .btn-primary { background: var(--red); color: #fff; } .btn-ghost { background: transparent; color: #fff; border: 1px solid #fff; }
  .hero-facts { list-style: none; padding: 0; margin: 0; color: #c9c9c9; font-size: 0.95rem; }
  .hero-facts li { padding: 6px 0; border-top: 1px solid #222; } .hero-facts li:first-child { border-top: 0; }
  .trust-bar { background: var(--red); color: #fff; padding: 14px 0; }
  .trust-bar .wrap { display: flex; gap: 28px; flex-wrap: wrap; justify-content: center; font-size: 0.95rem; font-weight: 600; }
  .section { padding: 56px 0; } .section.alt { background: var(--gray); }
  .model-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 20px; margin-top: 24px; }
  .model-card { background: #fff; border: 1px solid var(--border); padding: 20px; border-radius: 6px; }
  .section.alt .model-card { background: #fff; }
  .fail-block { background: #fff; border-left: 3px solid var(--red); padding: 20px 22px; margin: 16px 0; }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 14px; background: #fff; }
  .price-table th, .price-table td { text-align: left; padding: 11px 12px; border-bottom: 1px solid var(--border); }
  .price-table th { background: var(--black); color: #fff; font-weight: 700; font-size: 0.95rem; }
  .small { color: var(--muted); font-size: 0.92rem; margin-top: 12px; }
  .area-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 18px; }
  .area-grid > div { background: #fff; border: 1px solid var(--border); padding: 16px; border-radius: 6px; }
  .related-links { list-style: none; padding: 0; } .related-links li { padding: 10px 0; border-bottom: 1px solid var(--border); }
  .related-links a { color: var(--red); font-weight: 600; text-decoration: none; } .related-links a:hover { text-decoration: underline; }
  .faq { background: #fff; border: 1px solid var(--border); padding: 12px 16px; margin-bottom: 8px; border-radius: 4px; }
  .faq summary { font-weight: 700; cursor: pointer; padding: 4px 0; } .faq p { margin: 8px 0 0; }
  .cta-bottom { background: var(--black); color: #fff; padding: 48px 0; } .cta-bottom h2 { color: #fff; } .cta-bottom p { color: #c9c9c9; }
  .float-call { position: fixed; bottom: 18px; right: 18px; background: var(--red); color: #fff; padding: 14px 18px; border-radius: 40px; text-decoration: none; font-weight: 700; box-shadow: 0 6px 18px rgba(0,0,0,0.28); z-index: 50; font-size: 0.95rem; }
  @media (max-width: 820px) { h1 { font-size: 1.9rem; } h2 { font-size: 1.45rem; } .float-call { padding: 11px 14px; font-size: 0.88rem; } .trust-bar .wrap { gap: 14px; font-size: 0.85rem; } }
</style>
