        <tr><td>Ice-maker module replacement</td><td>$420 – $620</td><td>Slow-ice final resolution</td></tr>
        <tr><td>Condenser fan motor replacement</td><td>$260 – $440</td><td>Standard Café specs on truck</td></tr>
