---
import Layout from '../../layouts/Layout.astro';
import BrandDetailPlaceholder from '../../components/BrandDetailPlaceholder.astro';

const title = "LG Refrigerator Repair Los Angeles | InstaView, Linear";
const description = "LG fridge repair across LA — InstaView Door-in-Door, Linear Compressor, French Door, ThinQ. Same-day, $89 diagnostic waived with repair. (424) 325-0520.";
const canonical = "https://samedayappliance.repair/brands/lg-refrigerator-repair/";
---

<Layout title={title} description={description} canonical={canonical}>
  <BrandDetailPlaceholder
    brandName="LG"
    brandSlug="lg"
    category="Refrigerator"
    categorySlug="refrigerator-repair"
    hubUrl="/brands/lg/"
  />
</Layout>
