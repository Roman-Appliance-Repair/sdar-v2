  </section>

  <section class="section alt">
    <div class="wrap narrow">
      <h2>LG refrigerator repair, frequently asked</h2>
      {faqs.map(f => (
        <details class="faq">
          <summary>{f.q}</summary>
          <p set:html={f.a}></p>
        </details>
      ))}
    </div>
  </section>

  <section id="book" class="cta-bottom">
