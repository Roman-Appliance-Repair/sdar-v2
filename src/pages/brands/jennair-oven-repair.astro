          <tr><td>Convection ring element (type-C cavity)</td><td>$285 – $425</td></tr>
          <tr><td>Convection fan motor</td><td>$285 – $425</td></tr>
          <tr><td>RTD temperature sensor</td><td>$145 – $215</td></tr>
          <tr><td>Thermal fuse (safety)</td><td>$95 – $155</td></tr>
          <tr><td>Appliance Manager board (OEM W10821712)</td><td>$485 – $680</td></tr>
          <tr><td>Control panel standard (OEM W11232121)</td><td>$585 – $820</td></tr>
          <tr><td>Control panel JMW combo (OEM W10855641)</td><td>$585 – $820</td></tr>
          <tr><td>User interface / touch panel</td><td>$425 – $620</td></tr>
          <tr><td>Door hinge pair (drop-down)</td><td>$320 – $460</td></tr>
          <tr><td>Door gasket</td><td>$195 – $285</td></tr>
          <tr><td>Inner door glass pane</td><td>$285 – $385</td></tr>
          <tr><td>Outer door glass (NOIR-specific)</td><td>$385 – $580</td></tr>
          <tr><td>Self-clean door latch motor</td><td>$225 – $325</td></tr>
          <tr><td>Meat probe receptacle</td><td>$95 – $155</td></tr>
          <tr><td>Oven light bulb + installation</td><td>$85 – $135</td></tr>
          <tr><td>LED module (NOIR)</td><td>$185 – $285</td></tr>
          <tr><td>Magnetron (JMW combo only)</td><td>$285 – $425</td></tr>
          <tr><td>Microwave door switch (JMW combo, each)</td><td>$95 – $145</td></tr>
          <tr><td>HV diode (JMW combo)</td><td>$65 – $95</td></tr>
          <tr><td>Temperature Offset calibration (standalone)</td><td>$95 flat</td></tr>
          <tr><td>Temperature calibration (with any other repair)</td><td>Free</td></tr>
          <tr><td>Home Connect firmware update</td><td>$85 flat</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- ── SERVICE AREAS ── -->
  <section class="section section-alt">
    <div class="container">
      <p class="eyebrow-sub">Where we go</p>
      <h2>Service areas for JennAir wall oven repair</h2>
      <BrandBranchesGrid showHeader={false} />
    </div>
  </section>

  <!-- ── RELATED ── -->
  <section class="section">
    <div class="container">
      <p class="eyebrow-sub">Related services</p>
      <h2>Related JennAir categories</h2>
      <div class="cat-grid">
        <a href="/brands/jennair/" class="cat-card">
          <h3>JennAir Appliance Repair</h3>
          <p>Hub page, all JennAir categories in LA.</p>
          <span class="cat-cta">View hub →</span>
        </a>
        <a href="/brands/jennair-range-repair/" class="cat-card">
          <h3>JennAir Range Repair</h3>
          <p>Dual-fuel, gas, induction ranges with integrated ovens. Different service category from wall ovens.</p>
          <span class="cat-cta">View range repair →</span>
        </a>
        <a href="/brands/bosch-oven-repair/" class="cat-card">
          <h3>Bosch Wall Oven Repair</h3>
          <p>Alternative luxury wall oven platform. HBL 30" and HBN 27" built-in. Different price tier and design language.</p>
          <span class="cat-cta">View Bosch oven →</span>
        </a>
        <a href="/brands/thermador-oven-repair/" class="cat-card">
          <h3>Thermador Wall Oven Repair</h3>
          <p>Alternative luxury wall oven. Professional tier comparison for buyers considering both brands.</p>
          <span class="cat-cta">View Thermador oven →</span>
        </a>
      </div>
