      <tr><td>Inlet valve</td><td>$260 – $400</td><td>Fill fault</td></tr>
      <tr><td>Door hinge adjustment</td><td>$220 – $360</td><td>Panel alignment</td></tr>
      <tr><td>Door hinge assembly</td><td>$360 – $520</td><td>Full replacement</td></tr>
      <tr><td>Door gasket (panel-ready)</td><td>$320 – $480</td><td>Specialty profile</td></tr>
      <tr><td>Heating element</td><td>$300 – $460</td><td>Hard-water scale</td></tr>
      <tr><td>Isolation mounts + insulation</td><td>$240 – $380</td><td>Noise-spec restoration</td></tr>
      <tr><td>Pump impeller service</td><td>$260 – $400</td><td>Subharmonic noise fix</td></tr>
      <tr><td>Interior LED lighting</td><td>$180 – $280</td><td>Module swap</td></tr>
