---
import Layout from '../../layouts/Layout.astro';
import BrandDetailPlaceholder from '../../components/BrandDetailPlaceholder.astro';

const title = "GE Refrigerator Repair Los Angeles | Haier-Owned Since 2016";
const description = "GE fridge repair across LA — French Door, side-by-side, bottom-freezer, Profile, Café, Monogram sub-brands. Same-day, $89 diagnostic waived. (424) 325-0520.";
const canonical = "https://samedayappliance.repair/brands/ge-refrigerator-repair/";
---

<Layout title={title} description={description} canonical={canonical}>
  <BrandDetailPlaceholder
    brandName="GE"
    brandSlug="ge"
    category="Refrigerator"
    categorySlug="refrigerator-repair"
    hubUrl="/brands/ge/"
  />
</Layout>
