          <tr><td>Humidity sensor (wine columns)</td><td>$195 – $265</td></tr>
          <tr><td>LED lighting assembly</td><td>$145 – $220</td></tr>
          <tr><td>Condenser coil cleaning (maintenance)</td><td>$145 flat</td></tr>
          <tr><td>Preventive maintenance visit</td><td>$145 flat</td></tr>
