      <tr><td>Ice maker module</td><td>$340 – $480</td><td>Viking OEM</td></tr>
      <tr><td>Evaporator fan motor</td><td>$320 – $480</td><td>Per section</td></tr>
      <tr><td>Defrost heater + thermostat</td><td>$320 – $460</td><td>Freezer defrost</td></tr>
      <tr><td>Door gasket</td><td>$280 – $420</td><td>Per section</td></tr>
      <tr><td>Compressor start relay + capacitor</td><td>$260 – $400</td><td>First-line diagnostic</td></tr>
