---
// src/pages/brands/frigidaire-dryer-repair.astro
// Niche combo, Frigidaire dryer repair (~0 GSC impressions; brand portfolio completion).
// Parent: /brands/frigidaire/. Voice consistency: Electrolux ownership (since 1986),
// Gallery + Professional tiers, EF1 drain-pump code (condenser dryers), Augusta GA laundry plant.
import Layout from '../../layouts/Layout.astro';
import ServiceHero from '../../components/ServiceHero.astro';
import { MAIN_PHONE } from '../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/brands/frigidaire-dryer-repair/";

const title = "Frigidaire Dryer Repair, Gallery · Professional · EF1 Diagnostics";
const description = `Frigidaire dryer repair across SoCal, Gallery, Professional, base FFRE/FFLE/FFRG. $89 dx waived. BHGS #A49573. Call.`;

const faqs = [
  {
    q: "What does the EF1 code mean on my Frigidaire dryer?",
    a: "EF1 is the drain-pump fault on Frigidaire condenser dryers (the ventless models that re-condense moisture into a drain rather than venting to the outside). The fault triggers when the pump can't move the condensate out within the cycle window. Diagnostic order: (1) clogged drain pump filter, usually accessible from the front kickplate; about 40% of EF1 calls resolve at this clean-out with no parts cost; (2) failed pump itself, replacement $245-$385; (3) blocked drain hose or external drain. Vented Frigidaire dryers don't show EF1 because they don't have a drain pump."
  },
  {
    q: "My Frigidaire dryer drum spins but the clothes aren't drying, what's wrong?",
    a: "Three likely causes on Frigidaire dryers (electric and gas). (1) Clogged dryer vent, the most common cause and a fire hazard. We inspect and clear the vent on every dryer service call as standard practice. (2) Failed heating element on electric models (FFRE / GLER series), element wears around year 8-12 on typical use. Replacement $285-$425. (3) Blown thermal fuse triggered by a vent restriction event, the fuse is doing its safety job, won't reset, has to be replaced and the underlying restriction cleared. Gas models add a fourth path: failed igniter or gas valve coil. We check vent restriction first because clearing it is the cheapest fix and addresses a fire hazard at the same time."
  },
  {
    q: "How much does Frigidaire dryer repair cost?",
    a: `Diagnostic is $89, applied toward the repair when you approve work. Common Frigidaire dryer repair ranges: thermal fuse + vent inspection $145-$245; drum belt + idler pulley $185-$285; thermistor or temperature sensor $145-$215; door switch $145-$245; heating element (electric) $285-$425; gas valve coil or igniter $245-$385; EF1 condenser drain pump $245-$385; drum bearing or roller $245-$385; main control board $345-$525. Frigidaire Gallery uplift typically 10-15% above base. Professional uplift 20-30%. We give a written estimate before any work begins.`
  }
];

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": canonical + "#service",
    "serviceType": "Frigidaire Dryer Repair",
    "name": "Frigidaire Dryer Repair, Same Day Appliance Repair",
    "url": canonical,
    "description": "Same-day Frigidaire dryer repair across Los Angeles, Orange, Ventura, San Bernardino, and Riverside counties. Gallery, Professional, and base tiers, FFRE / FFLE electric, FFRG / GLEG gas, condenser models with EF1 diagnostic. Heating elements, thermal fuses, drum belts, drain pumps, igniters, gas valves, control boards. Electrolux platform. $89 residential diagnostic, applied toward repair.",
    "provider": {
      "@type": "LocalBusiness",
      "name": "Same Day Appliance Repair",
      "url": "https://samedayappliance.repair/",
      "telephone": phone,
      "priceRange": "$$"
    },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "offers": {
      "@type": "Offer",
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "89.00",
        "priceCurrency": "USD",
        "description": "Residential diagnostic fee, applied toward repair"
      }
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map((f) => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "Frigidaire", "item": "https://samedayappliance.repair/brands/frigidaire/" },
      { "@type": "ListItem", "position": 4, "name": "Frigidaire Dryer Repair", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>

<Fragment slot="head-scripts">
  {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
</Fragment>

<ServiceHero
  eyebrow="LA · Orange · Ventura · San Bernardino · Riverside Counties"
  title="Frigidaire Dryer Repair, Across Southern California"
  subtitle="Gallery, Professional, base FFRE / FFLE / FFRG. EF1 condenser drain-pump diagnostics, heating element, thermal fuse, drum belt. Electrolux platform service. $89 diagnostic, applied toward repair. Same day across five SoCal counties."
  heroImageTitle="Frigidaire Dryer Repair"
  showBranches={true}
/>

<!-- 01 INTRO -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">01, About this service</p>
    <h2 class="section-title">Frigidaire dryers on the Electrolux platform.</h2>

    <p>Frigidaire has been part of Electrolux (the Swedish home-appliance group) since 1986, with US laundry manufacturing concentrated in Augusta, Georgia. The dryer catalog spans three tiers, base Frigidaire (FFRE / FFLE electric, FFRG / GLEG gas), Frigidaire Gallery (premium controls and finishes, Wi-Fi on newer models), and the narrowed Frigidaire Professional line still in service from the late-2010s. We service all three tiers across our 5-county Southern California territory.</p>

    <p>Frigidaire dryers run on direct Electrolux engineering with well-documented diagnostic codes, the EF-series codes specifically (EF0 over-sudsing detection, EF1 drain-pump fault on condenser dryers, EF2 sudsing variant) are some of the more direct diagnostic paths in the appliance industry. Vented dryers, which is most of the Frigidaire residential lineup, don't show EF1 because they don't have a drain pump. <a href="/brands/frigidaire-refrigerator-repair/">Brand hub</a> covers Frigidaire's full appliance lineup; this page is dryer-specific.</p>
  </div>
</section>

<!-- 02 COMMON FAILURES -->
<section class="section section-gray">
  <div class="container">
    <p class="section-number">02, Common failures</p>
    <h2 class="section-title">What we diagnose most often on Frigidaire dryers.</h2>

    <div class="problem-grid">
      <div class="problem-card">
        <h3>Heating element failure (electric, year 8-12)</h3>
        <p>FFRE and GLER electric Frigidaire dryers run a 240V heating element that wears out around year 8-12 on typical-use households. Symptom: drum spins, air moves, but no heat, clothes still wet at end of cycle. Replacement $285-$425. We always check the vent path before replacing the element because a restricted vent often causes the element to overheat and burn out prematurely.</p>
      </div>
      <div class="problem-card">
        <h3>Thermal fuse blown from vent restriction</h3>
        <p>The thermal fuse is a safety device that breaks the heating circuit when the dryer overheats. When it blows, the dryer runs but doesn't heat. Replacement is $145-$245 with vent inspection. The fuse won't reset, it has to be replaced. More importantly, the cause (almost always a clogged vent) has to be cleared at the same time, otherwise the new fuse will blow within weeks.</p>
      </div>
      <div class="problem-card">
        <h3>Drum belt + idler pulley (year 6-9)</h3>
        <p>Squealing or thumping during drum rotation, eventually failing to turn at all. We replace the belt and inspect the idler pulley as a paired service, replacing the belt without addressing a worn pulley shortens the new belt's life significantly. $185-$285 typical.</p>
      </div>
      <div class="problem-card">
        <h3>EF1 drain-pump fault (condenser models)</h3>
        <p>Specific to ventless condenser Frigidaire dryers. EF1 means condensate isn't draining within the cycle window. About 40% resolve at the drain-pump filter clean-out (accessible from the front kickplate) at no parts cost. The remaining cases are pump replacement ($245-$385) or blocked drain hose. Vented dryers don't show this code.</p>
      </div>
    </div>
  </div>
</section>

<!-- 03 MODELS -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">03, Frigidaire dryer models we service</p>
    <h2 class="section-title">Across base, Gallery, and Professional.</h2>

    <p><strong>Base electric (FFRE / FFLE / GLER series):</strong> FFRE4120, FFRE4015, GLER642A, FFLE3911, value-tier 240V electric vented dryers. Common service: heating element, thermal fuse, drum belt, idler pulley, door switch.</p>

    <p><strong>Base gas (FFRG / GLEG / FFRG4):</strong> FFRG4120, GLEG642A, FFRG4015, value-tier gas vented dryers with hot-surface igniter. Common service: igniter, gas valve coils, thermal fuse, drum belt.</p>

    <p><strong>Gallery (FAQE / FFTR-paired sets):</strong> Gallery dryers add steam cycles, Wi-Fi connectivity on newer models, and improved moisture-sensing drum sensors. Common service mirrors base series plus moisture-sensor calibration.</p>

    <p><strong>Condenser models (FAQE / GLEC variants):</strong> Ventless dryers re-condensing moisture to drain. Common service: drain pump (EF1 fault), drain pump filter, condenser-coil cleaning.</p>

    <p>Frigidaire Professional dryers from the late-2010s production runs we still service when parts are available; the Professional line has been narrowed but factory parts are still distributed through Electrolux authorized channels.</p>
  </div>
</section>

<!-- 04 PRICING -->
<section class="section section-gray">
  <div class="container">
    <p class="section-number">04, Pricing</p>
    <h2 class="section-title">Frigidaire dryer repair pricing.</h2>

    <p class="lead">Diagnostic is $89, applied toward the repair when you approve work. Written estimate before any parts go on. Frigidaire Gallery typically adds 10-15% to base; Professional adds 20-30%.</p>

    <div class="pricing-grid">
      <div class="price-card">
        <div class="price-label">Diagnostic</div>
        <div class="price-amount">$89</div>
        <div class="price-desc">Waived when you approve repair</div>
      </div>
      <div class="price-card">
        <div class="price-label">Standard band</div>
        <div class="price-amount">$145–$285</div>
        <div class="price-desc">Thermal fuse · drum belt · door switch · sensor</div>
      </div>
      <div class="price-card">
        <div class="price-label">Heating element / pump</div>
        <div class="price-amount">$245–$425</div>
        <div class="price-desc">Electric element · gas igniter · EF1 drain pump</div>
      </div>
      <div class="price-card">
        <div class="price-label">Major component</div>
        <div class="price-amount">$345–$525</div>
        <div class="price-desc">Main control board · drum bearing rebuild</div>
      </div>
    </div>

    <p class="price-note">Vent inspection and clearing is included on every dryer service visit at no extra charge. Most Frigidaire dryer repairs complete same-day with parts on the truck.</p>
  </div>
</section>

<!-- 05 FAQ -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">05, FAQ</p>
    <h2 class="section-title">Frigidaire dryer repair, common questions.</h2>

    <div class="faq-list">
      {faqs.map((f) => (
        <details class="faq-item">
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- 06 BOTTOM CTA -->
<section class="bottom-cta">
  <div class="container">
    <h2>Frigidaire dryer down? Same-day service across Southern California.</h2>
    <p>$89 diagnostic, applied toward the repair. Base, Gallery, Professional, Electrolux platform service across all five SoCal counties.</p>
    <div class="cta-row">
      <a href={phoneHref} class="btn-primary">☎ Call {phone}</a>
      <a href="/contact/" class="btn-secondary">Book Online</a>
    </div>
  </div>
</section>

</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .section { padding: 72px 24px; }
  .section-gray { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; }
  .container.narrow { max-width: 820px; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  h2.section-title { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; margin: 0 0 20px; line-height: 1.2; color: var(--text); }
  .lead { font-size: 1.05rem; line-height: 1.75; color: var(--text); margin-bottom: 20px; }
  .section p { margin: 0 0 18px; font-size: 1rem; line-height: 1.75; color: var(--text); }
  .section a { color: var(--red); font-weight: 600; text-decoration: none; }
  .section a:hover { text-decoration: underline; }

  .problem-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-top: 32px; }
  .problem-card { background: #fff; border: 1px solid var(--border); border-left: 4px solid var(--red); border-radius: 6px; padding: 26px 28px; }
  .problem-card h3 { font-size: 1.1rem; font-weight: 800; margin: 0 0 12px; color: var(--text); }
  .problem-card p { font-size: 0.95rem; color: var(--text); margin: 0; line-height: 1.7; }
  @media (max-width: 768px) { .problem-grid { grid-template-columns: 1fr; } }

  .pricing-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-top: 32px; }
  .price-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 26px 22px; text-align: center; }
  .price-card .price-label { font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--muted); margin-bottom: 10px; font-weight: 700; }
  .price-card .price-amount { font-size: 1.85rem; font-weight: 800; color: var(--text); line-height: 1; margin-bottom: 10px; }
  .price-card .price-desc { font-size: 0.85rem; color: var(--muted); line-height: 1.55; }
  .price-note { margin-top: 24px; font-size: 0.95rem; color: var(--text); line-height: 1.7; }

  .faq-list { margin-top: 32px; }
  .faq-item { background: #fff; border: 1px solid var(--border); border-radius: 6px; padding: 18px 22px; margin-bottom: 12px; }
  .faq-item summary { font-weight: 700; cursor: pointer; font-size: 1rem; color: var(--text); list-style: none; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::before { content: "+ "; color: var(--red); font-weight: 800; margin-right: 6px; }
  .faq-item[open] summary::before { content: "− "; }
  .faq-item p { font-size: 0.95rem; color: var(--text); line-height: 1.75; margin: 14px 0 0; }

  .bottom-cta { background: var(--black); color: #fff; padding: 72px 24px; text-align: center; }
  .bottom-cta h2 { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; margin: 0 0 16px; color: #fff; line-height: 1.25; }
  .bottom-cta p { color: #c9c9c9; margin: 0 0 30px; font-size: 1.02rem; line-height: 1.6; }
  .cta-row { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 16px 34px; border-radius: 5px; font-size: 1rem; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 16px 34px; border-radius: 5px; font-size: 1rem; font-weight: 600; text-decoration: none; border: 2px solid rgba(255,255,255,0.35); }
</style>
