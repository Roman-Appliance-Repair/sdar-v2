---
import Layout from '../../layouts/Layout.astro';

const title = "JennAir Range Repair Los Angeles | Stove, Oven, Dual-Fuel, Induction — Jenn-Air Service";
const description = "JennAir (Jenn-Air) range and stove repair in Los Angeles. Dual-fuel (JDRP, JDSP Steam Assist), gas pro (JGRP), induction slide-in (JIS) and pro induction (JPIFC, JPIGC), slide-in (JDS, JGS) ranges. F1/F1-1/F1-7/F2-E1/F3-1 error code decoder. Oven sensor 5760M301-60, spark module, convection fan service. Factory-trained. $89 diagnostic waived with repair. Call (424) 325-0520.";

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": "https://samedayappliance.repair/brands/jennair-range-repair/#business",
    "name": "Same Day Appliance Repair — JennAir Range Service",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": "https://samedayappliance.repair/brands/jennair-range-repair/",
    "telephone": "+1-424-325-0520",
    "priceRange": "$$$$",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "6230 Wilshire Blvd Ste A PMB 2267",
      "addressLocality": "Los Angeles",
      "addressRegion": "CA",
      "postalCode": "90048",
      "addressCountry": "US"
    },
    "geo": { "@type": "GeoCoordinates", "latitude": 34.0619, "longitude": -118.3692 },
    "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.6", "reviewCount": "37" }
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "JennAir Range Repair",
    "provider": { "@type": "LocalBusiness", "name": "Same Day Appliance Repair" },
    "areaServed": [
      { "@type": "City", "name": "Los Angeles" },
      { "@type": "City", "name": "Beverly Hills" },
      { "@type": "City", "name": "Sherman Oaks" },
      { "@type": "City", "name": "Brentwood" },
      { "@type": "City", "name": "Pasadena" }
    ],
    "offers": {
      "@type": "Offer",
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "89.00",
        "priceCurrency": "USD",
        "description": "Diagnostic fee, waived with repair"
      }
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "My JennAir range shows F1, F1-1, or F1-7 — what's the difference?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Each F1 variant points to different component. F1 alone = general ignition control fault; try unplugging range for 10 minutes (electronics discharge), then test. F1-1 = oven temperature sensor fault OR Electronic Range Control (ERC) failure; test oven sensor resistance (should read ~1080 ohms at room temperature, drifted units read 200+ ohms off) — OEM sensor part 5760M301-60 on JDS family, $165-$245 replacement. F1-7 = communication fault between touchpad and ERC, usually ribbon cable degradation from moisture or age (common on LA coastal JDS9860 units from 2004-2010); inspect ribbon cable for visible damage or corrosion at both connectors before ordering ERC — 60% of F1-7 resolve with cable reseat or replacement ($145-$215 ribbon). If both sensor and ERC test good, touchpad itself has failed ($385-$545 replacement). We diagnose which F1 variant first; the diagnostic path is completely different for each."
        }
      },
      {
        "@type": "Question",
        "name": "Burner won't ignite — what should I check first?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Listen for clicking when you turn the burner knob. Clicking = spark module firing, issue is elsewhere (burner port blockage, misaligned cap, or no gas). No clicking = spark module or igniter electrode failure. On JennAir ranges the spark module is located under the cooktop, replacement $285-$385. Individual electrode per burner $95-$145. Common LA issue on 10+ year old JDS slide-in units: grease accumulation on electrodes under burner pans — cleaning during service restores spark on 30% of 'no ignite' calls ($85 flat cleaning service). Manual light fallback: light burners with a long match while waiting for service. Same ignition architecture across JennAir gas models — JGRP pro, JGS slide-in, JDS dual-fuel."
        }
      },
      {
        "@type": "Question",
        "name": "What's the difference between JDRP, JGRP, JIS, and JPIFC/JPIGC ranges?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Five different JennAir range architectures in current and recent production. JDRP = dual-fuel pro (gas cooktop + electric convection oven), the most popular JennAir pro configuration in LA — combines gas cooking flexibility with electric oven precision. JDSP = newer dual-fuel pro with Steam Assist oven (launched 2024). JGRP = all-gas pro (gas cooktop + gas oven), simplest service profile with spark ignition + gas valves. JIS = induction slide-in (30\" consumer induction range, JIS1450ML/JIS1450D series). JPIFC / JPIGC = professional-style induction ranges (JennAir's first-ever pro induction, launched late 2024 at KBIS, 36\" and 48\" widths with Flex-Choice zones and chrome griddle). Service differences: JGRP failures are usually spark module or gas valve ($285-$560 each); JDRP adds electric oven heating elements ($245-$385 bake, $265-$385 broil); induction models (JIS/JPIFC/JPIGC) add inverter boards per zone ($485-$685 per zone). All share RTD temperature probe, convection fan motor, and door hinge architecture — same Whirlpool Corp engineering backbone."
        }
      },
      {
        "@type": "Question",
        "name": "My JennAir range is 15+ years old — worth repairing?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Depends on which component failed. JDS9860P slide-in ranges from 2004-2010 are the most common aged JennAir range we see in LA, now reaching 15-20 year old service territory. Honest framework: sensor replacement ($165-$245) or spark module ($285-$385) on a 15-year old unit makes sense — low cost, restores operation, unit likely serves another 5-7 years. ERC (Electronic Range Control) replacement ($485-$680) on the same unit is borderline — you're committing $700+ to a 15-year-old appliance. Full oven rebuild (multiple components) $1,200+ doesn't pencil out versus $3,000-5,000 new dual-fuel range pricing. We give honest assessment on site — we'd rather recommend replacement when the math doesn't work than sell you repairs that don't deliver value."
        }
      },
      {
        "@type": "Question",
        "name": "How much does JennAir range repair cost?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Diagnostic $89, waived with repair. Typical JennAir range repairs: oven temperature sensor (5760M301-60 on JDS) $165-$245, ERC / Electronic Range Control $485-$680, touchpad / ribbon cable $145-$215, touchpad assembly $385-$545, bake element $245-$385, broil element $265-$385, convection fan motor $285-$425, spark module $285-$385, spark igniter per burner $95-$145, gas valve assembly per burner $285-$425, gas regulator $145-$215, burner cap $45-$85, burner grate $85-$145 each, door hinge pair $320-$460, door gasket $195-$285, inner oven glass $285-$385, outer oven glass $385-$580, door handle $125-$225, induction inverter board (JIS / JPIFC / JPIGC, per zone) $485-$685, induction ceramic glass top $685-$985, downdraft blower motor $345-$485, downdraft damper actuator $245-$345, grease/carbon cleaning service $85 flat. Labor and parts quoted before work starts."
        }
      }
    ]
  }
];
---
<Layout title={title} description={description}>
  <Fragment slot="head-scripts">
    {schemaJsons.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </Fragment>

  <section class="hero">
    <div class="hero-inner">
      <div class="hero-content">
        <p class="hero-eyebrow">Los Angeles · Beverly Hills · Sherman Oaks · Brentwood · Pasadena</p>
        <h1>JennAir Range &amp; Stove Repair Los Angeles</h1>
        <p class="hero-sub">Factory-trained service on JennAir (Jenn-Air) ranges — dual-fuel pro (JDRP, JDSP Steam Assist), gas pro (JGRP), induction slide-in (JIS) and pro induction (JPIFC, JPIGC), slide-in (JDS, JGS), and downdraft slide-in configurations. Complete F-code diagnostic (F1, F1-1, F1-7, F2-E1, F3-1). Same-day service. Post-warranty specialists for 4-to-20-year-old JennAir ranges across LA.</p>
        <div class="hero-ctas">
          <a href="tel:+14243250520" class="btn-primary">☎ (424) 325-0520</a>
          <a href="/contact/" class="btn-outline">Book Online</a>
        </div>
        <div class="hero-rating">
          <span class="stars">★★★★★</span>
          <span>4.6 · 37 reviews · Google</span>
        </div>
      </div>
      <div class="hero-img-wrap">
        <div class="hero-img-placeholder">
          <p>JennAir Range Repair</p>
          <p>Los Angeles</p>
        </div>
      </div>
    </div>
  </section>

  <div class="trust-bar">
    <div class="trust-bar-inner">
      <div class="trust-item"><span class="trust-icon">🏅</span> CSLB Licensed #1138898</div>
      <div class="trust-item"><span class="trust-icon">🛡</span> Fully Insured</div>
      <div class="trust-item"><span class="trust-icon">⚡</span> Same Day Available</div>
      <div class="trust-item"><span class="trust-icon">🔩</span> OEM Parts on Truck</div>
      <div class="trust-item"><span class="trust-icon">💬</span> $89 Diagnostic — Waived With Repair</div>
    </div>
  </div>

  <!-- ── SERVICE CLARITY UP FRONT ── -->
  <section class="section">
    <div class="container narrow">
      <p class="eyebrow-sub">What we do</p>
      <h2>We repair every JennAir range configuration installed in LA.</h2>
      <p>Dual-fuel ranges (JDRP and newer JDSP with Steam Assist — gas cooktop + electric oven, most popular pro-style JennAir in LA luxury kitchens). All-gas pro ranges (JGRP). Induction slide-in (JIS) and professional-style induction (JPIFC, JPIGC — JennAir's first pro induction launched late 2024 at KBIS). Slide-in ranges with integrated downdraft ventilation (JDS9860 family, dominant in LA open-plan kitchens from 2004-2010). Freestanding gas ranges (JGS series). Electric ranges (JES, JER series). 30-inch, 36-inch, and 48-inch widths.</p>
      <p>Our technicians are <strong>factory-trained on JennAir across all four cooking architectures</strong> — gas ignition systems, electric heating elements, induction inverter boards, and downdraft ventilation assemblies. We carry the common failure parts on every truck: oven temperature sensors (5760M301-60 on JDS family), spark modules, igniter electrodes, ribbon cables, door gaskets, heating elements. Most calls complete in one visit.</p>
      <p>We're not JennAir-authorized (that network handles in-warranty service — call 1-800-536-6247 for units under the 1-year base warranty). We're post-warranty specialists: <strong>CSLB #1138898, BHGS #A49573, EPA 608 certified, BBB A+ since 2022</strong>. Our average JennAir range service call is a 4-to-20-year-old unit past base warranty — Bel Air, Beverly Hills, Sherman Oaks, Brentwood, Pasadena, Calabasas.</p>
    </div>
  </section>

  <!-- ── MODELS ── -->
  <section class="section section-alt">
    <div class="container">
      <p class="eyebrow-sub">Models we service</p>
      <h2>JennAir range model families</h2>

      <div class="model-grid">
        <div class="model-card">
          <h3>JDRP Dual-Fuel Pro (Flagship)</h3>
          <p class="model-list">JDRP436HL · JDRP536HL · JDRP548HL · JDRP636HL · JDRP748HL (RISE) · JDRP436HM · JDRP536HM · JDRP548HM (NOIR)</p>
          <p>Dual-fuel pro-style ranges — gas cooktop + electric convection oven. Most popular pro JennAir in LA luxury kitchens. 30", 36", 48" widths. Suffix convention: HL = RISE Collection (brushed stainless), HM = NOIR Collection (matte black with Obsidian Interior). 4 or 6 sealed-burners plus chrome-infused griddle and/or grill on 36"/48" configurations. Shared Whirlpool Corp electric oven architecture with KitchenAid dual-fuel equivalents for most service components.</p>
        </div>
        <div class="model-card">
          <h3>JDSP Dual-Fuel with Steam Assist (New)</h3>
          <p class="model-list">JDSP536HM · JDSP Steam Assist models</p>
          <p>Newer dual-fuel pro ranges with Steam Assist oven — combines dry convection heat with steam injection for professional cooking techniques (bread proofing, meat moisture retention). Launched 2024 in NOIR Collection. Service adds: steam generator descaling (LA hard water requires every 8-12 months, $185 flat), water inlet valve for steam reservoir, steam-specific temperature sensor. Steam generator descaling similar to Bosch Benchmark HSL combi-steam service approach.</p>
        </div>
        <div class="model-card">
          <h3>JGRP Gas Pro</h3>
          <p class="model-list">JGRP430HL · JGRP436HL · JGRP536HL · JGRP548HL · JGRP636HL · JGRP648HL · JGRP748HL (RISE) · JGRP436HM · JGRP548HM (NOIR)</p>
          <p>All-gas pro ranges — sealed-burner cooktop + gas oven. Simpler service profile than dual-fuel (no electric heating elements). 30", 36", 48" widths. HL = RISE, HM = NOIR. Common in homes with natural gas infrastructure already installed and preference for gas oven characteristics. Full ignition architecture shared with JDRP dual-fuel cooktop side. Double-oven variants (JGRP548HL) available on 48" widths.</p>
        </div>
        <div class="model-card">
          <h3>JIS Induction Slide-In (Consumer)</h3>
          <p class="model-list">JIS1450ML · JIS1450DS · JIS1450D</p>
          <p>30" slide-in induction ranges. Magnetic induction cooktop (4 zones with Bridge Function/Flex-Choice), True Convection electric oven (6.4 cu ft), Air Fry, Pan Detection, Assisted Cooking. Common LA choice in mid-luxury kitchens 2020+ when owner prefers induction over gas but doesn't need pro-style 36"/48" width. Each induction zone has independent inverter board ($485-$685 per zone failure).</p>
        </div>
        <div class="model-card">
          <h3>JPIFC / JPIGC Pro Induction (New 2024+)</h3>
          <p class="model-list">JPIFC730RL · JPIFC736RL · JPIGC748RL · JPIGC748RM (NOIR)</p>
          <p>JennAir's first-ever professional-style induction ranges — launched late 2024 at KBIS. JPIFC = pro induction freestanding, JPIGC = pro induction with chrome-infused griddle. 36" and 48" widths. Flex-Choice induction zones (two elements that combine into one large surface), Dual-Fan True Convection oven, Halo-Effect knobs, Sabbath Mode. Growing LA category post-2020 Title 24 toward electric-only kitchens. Both RL (RISE) and RM (NOIR) variants available.</p>
        </div>
        <div class="model-card">
          <h3>JDS Dual-Fuel Downdraft Slide-In (Legacy)</h3>
          <p class="model-list">JDS9860 · JDS9860P · JDS9860AAW · JDS8850 · JDS8860</p>
          <p>Dual-fuel slide-in ranges with integrated downdraft ventilation. Dominant LA installation 2002-2012 in open-plan kitchens where overhead hood was architecturally impossible. Many still in service — 15-20 year old units now routine service. OEM oven sensor part 5760M301-60. Downdraft-specific service: blower motor, damper actuator, telescoping vent mechanism.</p>
        </div>
        <div class="model-card">
          <h3>JGS / JES Slide-In (Standard)</h3>
          <p class="model-list">JGS8850 · JGS1450 · JGS9900 · JES8850 · JES9900</p>
          <p>Standard slide-in ranges without downdraft. JGS = gas, JES = electric. More common in mid-luxury JennAir kitchens. Simpler service than downdraft variants. Current generation has Home Connect / Wi-Fi on select models.</p>
        </div>
        <div class="model-card">
          <h3>Freestanding &amp; Legacy</h3>
          <p class="model-list">JGR2000 · JER2000 · PRG / PRD (pre-2010 legacy)</p>
          <p>Freestanding JennAir ranges (less common than slide-ins and pro-style in LA market). Legacy PRG (pro gas) and PRD (pro dual-fuel) models from pre-2010 era — still serviceable for common failures, some parts discontinued on 15+ year units. Honest repair-vs-replace assessment on pre-2010 units.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── F-CODE DECODER ── -->
  <section class="section">
    <div class="container narrow">
      <p class="eyebrow-sub">F-code decoder</p>
      <h2>JennAir range F-codes — what each one means</h2>
      <p>JennAir ranges display F-codes for specific fault conditions. Same code family across JDS, JGS, JES, and pro-style (JDRP, JGRP) models. Owners rarely know the difference between F1, F1-1, and F1-7 — but the diagnostic path is completely different for each.</p>
      <table class="price-table">
        <thead>
          <tr><th>Code</th><th>Meaning &amp; diagnostic</th></tr>
        </thead>
        <tbody>
          <tr><td><strong>F1</strong></td><td>General ignition control fault. Unplug 10 min for electronics discharge, retest. About 10% clear on reset. If persistent: proceed to sub-code diagnostic.</td></tr>
          <tr><td><strong>F1-1</strong></td><td>Oven temperature sensor OR Electronic Range Control (ERC) failure. Test sensor resistance ~1080 ohms at room temp. Sensor (part 5760M301-60 on JDS) $165-$245. ERC $485-$680.</td></tr>
          <tr><td><strong>F1-7</strong></td><td>Communication fault touchpad ↔ ERC. Ribbon cable degradation common on 2004-2010 LA coastal units (moisture). Reseat cable first (free). Ribbon replacement $145-$215. Touchpad $385-$545.</td></tr>
          <tr><td><strong>F2-E1</strong></td><td>Grate installation fault — grates installed backwards. When cool, rock grate corner-to-corner; if it wobbles, flip it. Free fix per JennAir product help.</td></tr>
          <tr><td><strong>F3 / F3-1</strong></td><td>Temperature sensor fault (specific variant of F1-1). Same sensor replacement procedure — $165-$245 part plus 45 min labor.</td></tr>
          <tr><td><strong>F5</strong></td><td>Self-clean door lock fault. Latch motor failed or alignment drift. Latch $225-$325. Alignment adjustment free if lock engages but reads open.</td></tr>
          <tr><td><strong>F7</strong></td><td>Function keystroke error — random touchpad signals detected. Usually ribbon cable or touchpad aging. Same diagnostic path as F1-7.</td></tr>
        </tbody>
      </table>
      <p><strong>Reset procedure:</strong> unplug at breaker for 10 minutes minimum (electronics capacitors discharge slowly), then restore. Clears transient codes. If code returns immediately, it's a real hardware fault requiring service.</p>
    </div>
  </section>

  <!-- ── COMMON PROBLEMS ── -->
  <section class="section section-alt">
    <div class="container">
      <p class="eyebrow-sub">Common failures</p>
      <h2>The eight things that break on a JennAir range</h2>

      <div class="problem">
        <h3>1. F1-1 / F3-1 — oven temperature sensor drift (#1 call)</h3>
        <p>Most common JennAir range failure across all model families. Oven temperature sensor (OEM 5760M301-60 on JDS family, equivalent parts on JGS/JES/JDRP) drifts out of calibration over 10-15 years. Symptoms: oven runs 25-75°F off setpoint, baked goods don't brown properly, self-clean cycle aborts, F1-1 or F3-1 displayed. Test: multimeter resistance across sensor terminals — should read ~1080 ohms at room temperature. Drifted sensors read 200+ ohms off spec. Replacement $165-$245, 45-min job. On pre-2012 JDS units, 20% of F1-1 codes resolve at the sensor connector (clean + reseat, free) before sensor replacement needed.</p>
      </div>

      <div class="problem">
        <h3>2. F1-7 — touchpad ribbon cable degradation</h3>
        <p>Common on JDS9860 family and older units in LA coastal areas (Santa Monica, Venice, Palisades, Malibu) — moisture accelerates ribbon cable oxidation at both connector ends. Symptoms: F1-7 displayed, random beeping, touchpad buttons gradually failing (some keys work, others don't). Before ordering ERC ($485-$680): inspect ribbon cable at touchpad and at ERC connector. Reseat — free if that's the fix. Ribbon cable replacement $145-$215. Only if ribbon and connectors test good is ERC replacement justified. About 60% of F1-7 complaints resolve with cable-level repair.</p>
      </div>

      <div class="problem">
        <h3>3. Burner won't ignite — spark module or electrode</h3>
        <p>Diagnostic by sound. Clicking when knob turns = spark module firing, issue is burner port blockage (grease, food debris — clean with soft brush, free to $85 flat service) or misaligned burner cap. No clicking = spark module or electrode failure. Spark module (under cooktop) $285-$385, affects all burners. Individual electrode per burner $95-$145. On 10+ year JDS units, grease accumulation on electrodes under burner pans causes current leak and weak spark — cleaning during service restores operation on 30% of "no ignite" calls.</p>
      </div>

      <div class="problem">
        <h3>4. Oven won't reach temperature — element or sensor</h3>
        <p>Dual-fuel (JDRP) and electric (JES) models only — gas ovens diagnose differently. If oven heats but slowly or to wrong temp, it's the sensor (see #1 above). If oven doesn't heat at all in bake mode but broil works: bake element failed ($245-$385, OEM family shared with KitchenAid dual-fuel). Broil doesn't work but bake does: broil element ($265-$385). Test by visual inspection — working elements glow uniformly; failed elements have burn spots, breaks, or don't glow.</p>
      </div>

      <div class="problem">
        <h3>5. Convection fan failure — uneven cooking</h3>
        <p>Dual-fuel, electric, and induction pro models have convection fan at rear of oven cavity. Fan bearings wear around year 10-14 on heavy-use units. Symptoms: one rack burns while another undercooks, back of cavity hotter than front, convection modes don't brown properly. Replacement $285-$425, 90-min job accessing through rear cavity panel. Inspect blade for impact damage simultaneously — bent blade from rack collision mimics motor failure, cheaper fix.</p>
      </div>

      <div class="problem">
        <h3>6. Door won't close flush or gasket leaking</h3>
        <p>Range oven doors weigh 35-60 lb on 30", 60-80 lb on 36"/48". Hinges wear over 10-15 years. Symptoms: door sags from frame, heat escaping around perimeter, self-clean latch can't engage. Hinge pair replacement $320-$460 (both recommended for balanced operation). Gasket often needs simultaneous replacement if compressed asymmetrically ($195-$285). On NOIR Collection ranges, door glass replacement is JennAir-specific (not cross-compatible with RISE) — $385-$580 per pane.</p>
      </div>

      <div class="problem">
        <h3>7. Downdraft ventilation failure (JDS family)</h3>
        <p>Only on JDS slide-in downdraft ranges. Blower motor is the most common downdraft failure at year 10-14 — $345-$485 replacement. Damper actuator (raises/lowers the telescoping vent) second most common — $245-$345. Vent telescope mechanism itself rarely fails but can jam from grease buildup (cleaning service $95 flat). Check downdraft operation during any JDS service visit — blower issues often develop slowly and get normalized by owner before they call for service.</p>
      </div>

      <div class="problem">
        <h3>8. Induction zone failure (JIS / JPIFC / JPIGC only)</h3>
        <p>JIS consumer induction slide-in and JPIFC/JPIGC pro induction models only. Each cooking zone has independent inverter board; failure is localized to one zone while others work. Before ordering $485-$685 inverter: cookware magnet test — if a magnet doesn't stick firmly to the pot's bottom, the pot is non-ferromagnetic (aluminum, copper) and will never heat on induction (free diagnostic, 30% of "zone doesn't work" calls resolve here). Also check child lock (key/padlock symbol on display — 3-5 second hold to deactivate). Only if cookware is compatible and lock isn't active is inverter board replacement justified.</p>
      </div>
    </div>
  </section>

  <!-- ── AGED UNIT HONESTY ── -->
  <section class="section">
    <div class="container narrow">
      <p class="eyebrow-sub">Aged units — honest framework</p>
      <h2>15-20 year old JDS ranges: repair or replace?</h2>
      <p>The JennAir JDS9860 family — dual-fuel downdraft slide-ins from 2004-2010 — is the most common aged range we see in LA. Many are now 15-20 years old and approaching decisions about further investment. Here's our honest framework, not a sales pitch.</p>
      <p><strong>Repair makes sense for:</strong> oven sensor failure ($165-$245), spark module ($285-$385), individual igniter or electrode ($95-$145), burner cap or grate ($45-$145), minor downdraft service. These are low-cost, high-value repairs that restore operation and extend useful life 5-7 more years. A $200 sensor on a 15-year-old range that otherwise works fine is a clear yes.</p>
      <p><strong>Repair is borderline for:</strong> ERC / control board replacement ($485-$680), ribbon cable + touchpad together ($385-$545), blower motor + damper actuator ($590-$830 combined). You're committing $600-800 to an aged appliance. Reasonable if the rest of the unit is sound and you love the layout; questionable if multiple systems are failing simultaneously.</p>
      <p><strong>Replacement usually makes more sense for:</strong> refrigerant-related oven sealing failures on dual-fuel units, structural heating element housing damage, compound failures where total repair cost exceeds $1,200 on a unit with pre-2010 manufacture date. New JennAir dual-fuel ranges $3,500-5,500 depending on configuration; JGRP/JDRP 36" flagship $7,500-11,000. Quick math: if cumulative repairs approach 25-30% of replacement cost on a 15+ year unit, replacement usually wins long-term.</p>
      <p>We'll give you the honest number on site — we'd rather you replace with confidence than spend on repairs that don't deliver value.</p>
    </div>
  </section>

  <!-- ── PRICING ── -->
  <section class="section section-alt">
    <div class="container narrow">
      <p class="eyebrow-sub">Pricing</p>
      <h2>What JennAir range repair usually costs</h2>
      <p>Diagnostic $89, waived with repair. Labor and parts quoted separately before work starts.</p>
      <table class="price-table">
        <thead>
          <tr><th>Repair</th><th>Typical range</th></tr>
        </thead>
        <tbody>
          <tr><td>Oven temperature sensor (5760M301-60 on JDS)</td><td>$165 – $245</td></tr>
          <tr><td>Electronic Range Control (ERC / main board)</td><td>$485 – $680</td></tr>
          <tr><td>Touchpad ribbon cable</td><td>$145 – $215</td></tr>
          <tr><td>Touchpad assembly</td><td>$385 – $545</td></tr>
          <tr><td>Bake element (dual-fuel / electric)</td><td>$245 – $385</td></tr>
          <tr><td>Broil element (dual-fuel / electric)</td><td>$265 – $385</td></tr>
          <tr><td>Convection fan motor</td><td>$285 – $425</td></tr>
          <tr><td>Spark module (all burners)</td><td>$285 – $385</td></tr>
          <tr><td>Spark igniter / electrode (per burner)</td><td>$95 – $145</td></tr>
