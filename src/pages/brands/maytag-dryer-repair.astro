---
// src/pages/brands/maytag-dryer-repair.astro
// Niche combo, Maytag dryer repair (~0 GSC impressions; brand portfolio completion).
// Parent: /brands/maytag/. Voice: Whirlpool ownership (2006), built-to-last reputation,
// Bravos / Maxima / Centennial line distinction, MED electric / MGD gas, F-code parity.
import Layout from '../../layouts/Layout.astro';
import ServiceHero from '../../components/ServiceHero.astro';
import { MAIN_PHONE } from '../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/brands/maytag-dryer-repair/";

const title = "Maytag Dryer Repair, MED · MGD · Bravos · Maxima | Same Day Appliance Repair";
const description = `Maytag dryer repair across Southern California, MED electric, MGD gas, Bravos, Maxima, Centennial. Whirlpool platform parts, F-code diagnostics, heating element, drum belt, thermal fuse. $89 diagnostic, applied toward repair. BHGS #A49573. Call ${phone}.`;

const faqs = [
  {
    q: "My Maytag dryer drum spins but the clothes won't dry, what's wrong?",
    a: "Three likely causes on Maytag dryers (electric and gas). (1) Clogged dryer vent, the most common cause and a fire hazard; we inspect and clear the vent on every dryer service call as standard practice. (2) Failed heating element on electric MED units, element wears around year 8-12 on typical use, replacement $285-$425. (3) Blown thermal fuse triggered by a vent restriction event, the fuse won't reset and has to be replaced, and the underlying restriction has to be cleared. Gas MGD models add a fourth path: failed igniter or gas valve coil. We check vent restriction first because it's the cheapest fix and addresses a fire hazard at the same time.",
  },
  {
    q: "What does an F22 or F70 code mean on my Maytag dryer?",
    a: "Maytag's F-codes share the Whirlpool diagnostic tree. F22, thermistor fault; the temperature sensor that monitors drum air temp has drifted out of spec. Replacement $145-$215. F23, thermistor fault similar to F22 but on a different sensor circuit. F31, moisture sensor fault on auto-dry models; the sensor that detects when clothes are dry isn't reading correctly, often from lint buildup on the sensor plate. F70 / F71, user interface or communication faults between control board and panel; reseat connectors first, replace second. About 30% of Maytag dryer F-codes resolve at the connector-reseat or sensor-cleaning step at no parts cost.",
  },
  {
    q: "How much does Maytag dryer repair cost?",
    a: `Diagnostic is $89, applied toward the repair when you approve work. Common Maytag dryer repair ranges: thermal fuse + vent inspection $145-$245; thermistor / temperature sensor $145-$215; door switch $145-$245; drum belt + idler pulley $185-$285; heating element (electric MED) $285-$425; gas valve coil or igniter (MGD) $245-$385; drum bearing (year 10+) $245-$385; main control board $345-$525. Bravos and Maxima premium-line dryers add 10-15% uplift; Centennial entry-line is at the lower end of the band. We give a written estimate before any work begins.`,
  },
];

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": canonical + "#service",
    "serviceType": "Maytag Dryer Repair",
    "name": "Maytag Dryer Repair, Same Day Appliance Repair",
    "url": canonical,
    "description": "Same-day Maytag dryer repair across Los Angeles, Orange, Ventura, San Bernardino, and Riverside counties. MED electric, MGD gas, Bravos, Maxima, Centennial. Whirlpool platform service. Heating elements, thermal fuses, drum belts, igniters, gas valves, F22 / F70 / F71 control faults. $89 residential diagnostic, applied toward repair.",
    "provider": {
      "@type": "LocalBusiness",
      "name": "Same Day Appliance Repair",
      "url": "https://samedayappliance.repair/",
      "telephone": phone,
      "priceRange": "$$",
    },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" },
    ],
    "offers": {
      "@type": "Offer",
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "89.00",
        "priceCurrency": "USD",
        "description": "Residential diagnostic fee, applied toward repair",
      },
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map((f) => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "Maytag", "item": "https://samedayappliance.repair/brands/maytag/" },
      { "@type": "ListItem", "position": 4, "name": "Maytag Dryer Repair", "item": canonical },
    ],
  },
];
---

<Layout title={title} description={description} canonical={canonical}>

<Fragment slot="head-scripts">
  {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
</Fragment>

<ServiceHero
  eyebrow="LA · Orange · Ventura · San Bernardino · Riverside Counties"
  title="Maytag Dryer Repair, Across Southern California"
  subtitle="MED electric, MGD gas, Bravos, Maxima, Centennial. Whirlpool platform parts, F-code diagnostics, heating element, drum belt, thermal fuse. $89 diagnostic, applied toward repair."
  heroImageTitle="Maytag Dryer Repair"
  showBranches={true}
/>

<!-- 01 INTRO -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">01, About this service</p>
    <h2 class="section-title">Maytag dryers on the Whirlpool platform.</h2>

    <p>Maytag has been part of Whirlpool Corporation since the 2006 acquisition, with US laundry manufacturing concentrated alongside the Whirlpool platform. The dryer catalog spans three lines: <strong>Bravos</strong> (the brand's premium top-load washer-paired dryers, MED / MGD-X series with steam cycles), <strong>Maxima</strong> (front-load matching dryers, electronic controls), and <strong>Centennial</strong> (entry-tier basic top-load-paired dryers). The "built to last" reputation that Maytag carried for decades was earned on the older Maytag-Newton platform; current production sits on Whirlpool engineering with shared parts, shared diagnostic tree, and parts cross-reference across the entire Whirlpool family.</p>

    <p>For service that's straightforward: Whirlpool F-codes apply directly, our trucks carry components that fit Maytag, Whirlpool, KitchenAid, and Amana with substantial overlap, and most Maytag dryer repairs run efficiently because we already know the platform. <a href="/brands/maytag/">Brand hub</a> covers Maytag's full appliance lineup; this page is dryer-specific.</p>
  </div>
</section>

<!-- 02 COMMON FAILURES -->
<section class="section section-gray">
  <div class="container">
    <p class="section-number">02, Common failures</p>
    <h2 class="section-title">What we diagnose most often on Maytag dryers.</h2>

    <div class="problem-grid">
      <div class="problem-card">
        <h3>Heating element failure (electric MED, year 8-12)</h3>
        <p>The single most-asked dryer question. MED electric Maytag dryers run a 240V heating element that wears out around year 8-12 on typical-use households. Drum spins, air moves, but no heat, clothes still wet at end of cycle. Replacement $285-$425. We always check the vent path before replacing the element because a restricted vent often causes the element to overheat and burn out prematurely.</p>
      </div>
      <div class="problem-card">
        <h3>Igniter or gas valve coil (gas MGD, year 6-9)</h3>
        <p>On gas MGD models, two failure modes produce "no heat": failed hot-surface igniter (most common, doesn't glow when you can see it through the inspection port) or failed gas valve coil (the coil energizes but the valve doesn't open). We diagnose by visual confirmation through the inspection port plus an electrical test of both circuits. Igniter replacement $245-$385. Gas valve coils less common, similar price range.</p>
      </div>
      <div class="problem-card">
        <h3>Drum belt + idler pulley (year 6-9)</h3>
        <p>Squealing or thumping during drum rotation, eventually failing to turn at all. We replace the belt and inspect the idler pulley as a paired service, replacing the belt without addressing a worn pulley shortens the new belt's life significantly. $185-$285 typical.</p>
      </div>
      <div class="problem-card">
        <h3>Thermal fuse blown from vent restriction</h3>
        <p>The thermal fuse is a safety device that breaks the heating circuit when the dryer overheats. Dryer runs but doesn't heat. The fuse won't reset; replacement $145-$245 with vent inspection. The cause (almost always a clogged vent) has to be cleared at the same time, otherwise the new fuse will blow within weeks. Vent restriction is a documented fire hazard and we treat it as a primary safety concern on every dryer service call.</p>
      </div>
    </div>
  </div>
</section>

<!-- 03 MODELS + F-CODES -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">03, Maytag dryer models and F-codes</p>
    <h2 class="section-title">MED / MGD series across Bravos, Maxima, Centennial.</h2>

    <p><strong>Bravos premium top-load-paired:</strong> MEDX655DW, MEDB766FW, MGDX655DW (gas), MGDB766FW (gas), Bravos premium dryers with steam cycles, advanced moisture sensing, electronic touch controls. Common service mirrors Whirlpool Cabrio platform.</p>

    <p><strong>Maxima front-load:</strong> MED7100DC, MED8200FC, MGD7100DC, MGD8200FC (gas), Maxima front-load matching dryers with steam, sanitize cycle, and Wi-Fi connectivity on newer models. Common service: heating element, drum bearing, control board.</p>

    <p><strong>Centennial entry-tier:</strong> MEDC215EW, MGDC215EW (gas), MEDX600, basic top-load-paired dryers with mechanical timer or basic electronic controls, lower BTU output, simpler service tree. Common service: heating element, thermal fuse, drum belt, door switch.</p>

    <p><strong>Whirlpool F-codes that apply to Maytag dryers:</strong></p>

    <ul class="bullet-list">
      <li><strong>F22:</strong> Thermistor fault, temperature sensor drift. Replacement $145-$215.</li>
      <li><strong>F23:</strong> Thermistor fault on a different sensor circuit, similar diagnosis.</li>
      <li><strong>F31:</strong> Moisture sensor fault on auto-dry models, often resolves with sensor-plate cleaning at no parts cost.</li>
      <li><strong>F70 / F71:</strong> User interface or communication faults, reseat panel connectors first, replace board second.</li>
    </ul>
  </div>
</section>

<!-- 04 PRICING -->
<section class="section section-gray">
  <div class="container">
    <p class="section-number">04, Pricing</p>
    <h2 class="section-title">Maytag dryer repair pricing.</h2>

    <p class="lead">Diagnostic is $89, applied toward the repair when you approve work. Bravos / Maxima premium tiers add 10-15% uplift; Centennial sits at the lower end of the band. Written estimate before any parts go on.</p>

    <div class="pricing-grid">
      <div class="price-card">
        <div class="price-label">Diagnostic</div>
        <div class="price-amount">$89</div>
        <div class="price-desc">Waived when you approve repair</div>
      </div>
      <div class="price-card">
        <div class="price-label">Standard band</div>
        <div class="price-amount">$145–$285</div>
        <div class="price-desc">Thermal fuse · drum belt · door switch · sensor</div>
      </div>
      <div class="price-card">
        <div class="price-label">Heating component</div>
        <div class="price-amount">$245–$425</div>
        <div class="price-desc">Electric element · gas igniter · valve coil</div>
      </div>
      <div class="price-card">
        <div class="price-label">Major component</div>
        <div class="price-amount">$345–$525</div>
        <div class="price-desc">Main control board · drum bearing rebuild</div>
      </div>
    </div>

    <p class="price-note">Vent inspection and clearing is included on every dryer service visit at no extra charge, restriction is the most common preventable cause of heating-element and thermal-fuse failure. Most Maytag dryer repairs complete same-day with parts on the truck thanks to Whirlpool-platform parts cross-reference.</p>
  </div>
</section>

<!-- 05 FAQ -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">05, FAQ</p>
    <h2 class="section-title">Maytag dryer repair, common questions.</h2>

    <div class="faq-list">
      {faqs.map((f) => (
        <details class="faq-item">
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- 06 BOTTOM CTA -->
<section class="bottom-cta">
  <div class="container">
    <h2>Maytag dryer down? Same-day service across Southern California.</h2>
    <p>$89 diagnostic, applied toward the repair. Bravos, Maxima, Centennial, Whirlpool platform service across all five SoCal counties.</p>
    <div class="cta-row">
      <a href={phoneHref} class="btn-primary">☎ Call {phone}</a>
      <a href="/contact/" class="btn-secondary">Book Online</a>
    </div>
  </div>
</section>

</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .section { padding: 72px 24px; }
  .section-gray { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; }
  .container.narrow { max-width: 820px; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  h2.section-title { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; margin: 0 0 20px; line-height: 1.2; color: var(--text); }
  .lead { font-size: 1.05rem; line-height: 1.75; color: var(--text); margin-bottom: 20px; }
  .section p { margin: 0 0 18px; font-size: 1rem; line-height: 1.75; color: var(--text); }
  .section a { color: var(--red); font-weight: 600; text-decoration: none; }
  .section a:hover { text-decoration: underline; }
  .bullet-list { margin: 20px 0; padding-left: 24px; }
  .bullet-list li { margin-bottom: 10px; font-size: 1rem; line-height: 1.7; color: var(--text); }

  .problem-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-top: 32px; }
  .problem-card { background: #fff; border: 1px solid var(--border); border-left: 4px solid var(--red); border-radius: 6px; padding: 26px 28px; }
  .problem-card h3 { font-size: 1.1rem; font-weight: 800; margin: 0 0 12px; color: var(--text); }
  .problem-card p { font-size: 0.95rem; color: var(--text); margin: 0; line-height: 1.7; }
  @media (max-width: 768px) { .problem-grid { grid-template-columns: 1fr; } }

  .pricing-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-top: 32px; }
  .price-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 26px 22px; text-align: center; }
  .price-card .price-label { font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--muted); margin-bottom: 10px; font-weight: 700; }
  .price-card .price-amount { font-size: 1.85rem; font-weight: 800; color: var(--text); line-height: 1; margin-bottom: 10px; }
  .price-card .price-desc { font-size: 0.85rem; color: var(--muted); line-height: 1.55; }
  .price-note { margin-top: 24px; font-size: 0.95rem; color: var(--text); line-height: 1.7; }

  .faq-list { margin-top: 32px; }
  .faq-item { background: #fff; border: 1px solid var(--border); border-radius: 6px; padding: 18px 22px; margin-bottom: 12px; }
  .faq-item summary { font-weight: 700; cursor: pointer; font-size: 1rem; color: var(--text); list-style: none; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::before { content: "+ "; color: var(--red); font-weight: 800; margin-right: 6px; }
  .faq-item[open] summary::before { content: "− "; }
  .faq-item p { font-size: 0.95rem; color: var(--text); line-height: 1.75; margin: 14px 0 0; }

  .bottom-cta { background: var(--black); color: #fff; padding: 72px 24px; text-align: center; }
  .bottom-cta h2 { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; margin: 0 0 16px; color: #fff; line-height: 1.25; }
  .bottom-cta p { color: #c9c9c9; margin: 0 0 30px; font-size: 1.02rem; line-height: 1.6; }
  .cta-row { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 16px 34px; border-radius: 5px; font-size: 1rem; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 16px 34px; border-radius: 5px; font-size: 1rem; font-weight: 600; text-decoration: none; border: 2px solid rgba(255,255,255,0.35); }
</style>
