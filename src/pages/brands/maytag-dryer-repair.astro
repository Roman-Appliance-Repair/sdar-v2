---
import Layout from '../../layouts/Layout.astro';
import BrandDetailPlaceholder from '../../components/BrandDetailPlaceholder.astro';

const title = "Maytag Dryer Repair | Southern California | Same Day Service";
const description = "Expert Maytag dryer repair across Southern California. Same-day appointments, OEM parts, licensed technicians. Call (424) 325-0520.";
---

