---
import Layout from '../../layouts/Layout.astro';
import BrandBranchesGrid from '../../components/BrandBranchesGrid.astro';
import { MAIN_PHONE, MAIN_PHONE_TEL } from '../../data/branches';

const title = "JennAir Appliance Repair | Southern California | Refrigerator, Range, Oven, Cooktop, Dishwasher, Jenn-Air Service";
const description = "JennAir appliance repair across SoCal. Refrigerators, ranges, wall ovens, cooktops, dishwashers. RISE + NOIR collections. BHGS #A49573. $89 dx waived.";

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": "https://samedayappliance.repair/brands/jennair/#business",
    "name": "Same Day Appliance Repair, JennAir Service",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": "https://samedayappliance.repair/brands/jennair/",
    "telephone": MAIN_PHONE_TEL,
    "priceRange": "$$$$",
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What JennAir appliances do you repair?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "All JennAir kitchen appliances: refrigerators (built-in columns, French-door, side-by-side, counter-depth), ranges (dual-fuel JDRP, gas pro JGRP, induction JIS/JPIFC/JPIGC, slide-in JDS/JGS, freestanding), wall ovens (JJW double and single, JMW microwave-combo, JBS speed), cooktops (gas, induction, electric, downdraft), dishwashers (JDB built-in, JDPSS professional, panel-ready), microwaves, and warming drawers. Both RISE Collection and NOIR Collection design tiers. We don't service laundry because JennAir doesn't currently make washers or dryers, they're a kitchen-appliance-only brand."
        }
      },
      {
        "@type": "Question",
        "name": "Are you factory-trained on JennAir?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Our technicians are factory-trained on JennAir across all product categories, including the Whirlpool Corporation diagnostic procedures (light-switch 3x test mode on refrigerators, 7-second stuck-button test on dishwashers, Service Mode on ovens). We're not JennAir-authorized, that network dispatches in-warranty service at no parts cost (call JennAir directly at 1-800-536-6247 during first year). We're post-warranty specialists: same factory training, lower labor rate, faster response than authorized dispatch. Most of our JennAir calls are 3-to-15-year-old units past the base 1-year warranty."
        }
      },
      {
        "@type": "Question",
        "name": "Why choose you over other JennAir repair shops in LA?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Five reasons. (1) Credentials we can prove: BHGS #A49573 (the appliance repair license, verifiable at bhgs.dca.ca.gov), active  license, EPA 608 Universal certified #1346255700410 for sealed-system refrigeration work, BBB A+ accredited since 2022. Most LA JennAir repair websites claim 'authorized' and 'certified' without showing license numbers. (2) Honest pricing: $89 diagnostic waived with repair, all parts and labor quoted before work starts, no surprise charges. (3) OEM parts on truck: common JennAir failure parts (Embraco VCC2 inverter 12002799, oven sensor 5760M301-60, Appliance Manager W10821712, control panels W11232121/W10855641) stocked on service trucks. (4) Whirlpool Corp cross-brand parts knowledge, JennAir components often shared with KitchenAid/Maytag, which gives us 1-2 day parts availability advantage. (5) We tell you when NOT to repair, 15+ year unit with compound failure often wins replacement rather than $1,200+ repair investment. Honest assessment on site."
        }
      },
      {
        "@type": "Question",
        "name": "Do you service all LA neighborhoods?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Five dispatch centers cover Greater LA: West Hollywood (323) 870-4790 serves Beverly Hills, Bel Air, Holmby Hills, Hancock Park, Mid-Wilshire. Los Angeles (424) 325-0520 serves Brentwood, Pacific Palisades, Malibu, Santa Monica, Century City, Westwood. Thousand Oaks (424) 208-0228 serves Sherman Oaks, Studio City, Encino, Tarzana, Calabasas. Pasadena (626) 376-4458 serves San Marino, La Cañada Flintridge, Arcadia, South Pasadena. Irvine (213) 401-9019 serves Orange County. Same-day service available. Strong JennAir density in Sherman Oaks specifically (91403 and 91423 zip codes)."
        }
      },
      {
        "@type": "Question",
        "name": "RISE vs NOIR Collections, does it matter for service?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Mostly no, same core engineering. RISE Collection (brushed stainless, commercial-style handles, suffix HL on model numbers) and NOIR Collection (matte black stainless with Obsidian Interior on ovens, suffix HM) share the same compressors, heating elements, motors, and control architectures. Service components are largely interchangeable. Where it matters: NOIR-specific trim, black-finish handles, and Obsidian Interior cavity glass aren't cross-compatible with RISE parts, if NOIR oven door glass breaks, it's an NOIR-specific replacement ($385-$580). Functional service (heating, control, convection, compressor) is identical between collections."
        }
      },
      {
        "@type": "Question",
        "name": "How much does JennAir repair cost in LA?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Diagnostic $89, waived with repair. Typical JennAir repairs: refrigerator compressor start relay $95-$155, inverter board (Embraco VCC2) $385-$485, evaporator fan motor $245-$345. Range oven sensor $165-$245, spark module $285-$385, convection fan $285-$425. Wall oven Appliance Manager board $485-$680, control panel $585-$820, heating element $245-$385. Dishwasher circulation pump $345-$485, drain pump $165-$245, control board $485-$680. Labor and parts always quoted before work starts. On aged units (15+ years) we provide honest repair-vs-replace assessment rather than selling unnecessary repairs."
        }
      }
    ]
  }
];
---
<Layout title={title} description={description}>
  <Fragment slot="head-scripts">
    {schemaJsons.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </Fragment>

  <section class="hero">
    <div class="hero-inner">
      <div class="hero-content">
        <p class="hero-eyebrow">LA · Orange · Ventura · San Bernardino · Riverside Counties</p>
        <h1>JennAir Appliance Repair</h1>
        <p class="hero-sub">Factory-trained service on JennAir (Jenn-Air) refrigerators, ranges, stoves, wall ovens, cooktops, and dishwashers. All models, all configurations, across RISE and NOIR collections. Same-day service available. $89 diagnostic waived with repair.</p>
        <div class="hero-ctas">
          <a href={`tel:${MAIN_PHONE_TEL}`} class="btn-primary">☎ {MAIN_PHONE}</a>
          <a href="/contact/" class="btn-outline">Book Online</a>
        </div>
      </div>
      <div class="hero-img-wrap">
        <div class="hero-img-placeholder">
          <p>JennAir Appliance Repair</p>
          <p>Across Southern California</p>
        </div>
      </div>
    </div>
  </section>

  <div class="trust-bar">
    <div class="trust-bar-inner">
      <div class="trust-item"><span class="trust-icon">🏅</span> BHGS #A49573</div>
      <div class="trust-item"><span class="trust-icon">❄</span> EPA 608 Certified</div>
      <div class="trust-item"><span class="trust-icon">⚡</span> Same Day Available</div>
      <div class="trust-item"><span class="trust-icon">🔩</span> OEM Parts on Truck</div>
      <div class="trust-item"><span class="trust-icon">💬</span> $89 Diagnostic, Waived With Repair</div>
    </div>
  </div>

  <!-- ── SERVICE CLARITY FIRST ── -->
  <section class="section">
    <div class="container narrow">
      <p class="eyebrow-sub">What we repair</p>
      <h2>We repair every JennAir kitchen appliance.</h2>
      <p><strong>Refrigerators</strong>, built-in columns (JS42, JS48, JF42), French-door, side-by-side, counter-depth. Compressor service (EPA 608 certified for sealed-system work), Embraco VCC2 inverter diagnostics, VitaFreshPlus humidity drawers, ice maker repair, temperature recalibration.</p>
      <p><strong>Ranges and stoves</strong>, dual-fuel pro (JDRP, JDSP Steam Assist), gas pro (JGRP), induction (JIS consumer, JPIFC/JPIGC pro), slide-in (JDS, JGS), downdraft configurations. Full F-code decoder (F1, F1-1, F1-7, F2-E1, F3-1), spark module and burner ignition, oven sensor calibration, convection fan replacement.</p>
      <p><strong>Wall ovens</strong>, JJW double and single, JMW microwave-combo, JBS speed ovens, NOIR Obsidian Interior variants. F2E1 control panel defect diagnostic (documented pattern on JJW2/JJW3/JMW/JMW3 serial D or F), F6E1 over-temp resolution, heating element replacement, door hinge service.</p>
      <p><strong>Cooktops</strong>, gas sealed-burner, induction, electric ceramic, downdraft integrated. JennAir's signature downdraft ventilation service (blower motor, damper actuator, vent telescope). Induction cookware magnet test free with diagnostic.</p>
      <p><strong>Dishwashers</strong>, JDB built-in and JDPSS professional, fully-integrated panel-ready. TriFecta wash system, OWI Optical Water Indicator sensor diagnostic, 7-second Whirlpool Corp stuck-button test procedure. Southern California hard-water descaling service (cadence varies by county).</p>
      <p>We don't service laundry because <a href="/brands/jennair-dryer-repair/">JennAir doesn't currently make washers or dryers</a>, they're a kitchen-appliance-only brand under Whirlpool Corporation. Need laundry service? See our <a href="/brands/miele-dryer-repair/">Miele</a> or <a href="/brands/bosch-dryer-repair/">Bosch</a> pages for compact luxury options that pair well with JennAir kitchens.</p>
    </div>
  </section>

  <!-- ── WHY CHOOSE US ── -->
  <section class="section section-alt">
    <div class="container narrow">
      <p class="eyebrow-sub">About our company</p>
      <h2>Why Southern California homeowners choose us for JennAir service.</h2>
      <p>Same Day Appliance Repair is a Los Angeles-headquartered appliance and HVAC service company with eight service territories across the 5-county SoCal market, LA, Orange, Ventura, San Bernardino, and Riverside counties. We've been servicing JennAir appliances since 2022, with a core focus on post-warranty service for luxury and premium kitchen appliances in Beverly Hills, Brentwood, Sherman Oaks, Pasadena, Santa Monica, and Calabasas on the LA side; Newport Coast, Newport Beach, and Tustin in OC; Westlake Village and Thousand Oaks in Ventura; and Rancho Cucamonga and Temecula wine-country in the IE.</p>
      <p><strong>Credentials we can prove.</strong> BHGS registration #A49573 (the appliance repair license, verifiable at bhgs.dca.ca.gov). Active  license. EPA 608 Universal certified #1346255700410 for sealed-system refrigeration work (required for JennAir column refrigerator compressor service). BBB A+ accredited since 2022. General liability and workers' comp insurance. Most JennAir repair websites in our service area claim "authorized" and "certified" without showing license numbers or proof, we publish ours because they're verifiable.</p>
      <p><strong>Factory-trained technicians.</strong> Our team trains on JennAir across all product categories, including the specific Whirlpool Corporation diagnostic procedures most general repair shops don't know: the light-switch 3x refrigerator test mode, the 7-second stuck-button dishwasher diagnostic, the Service Mode on wall ovens. This technical depth is why we close most diagnoses within the first visit rather than multiple trips ordering wrong parts.</p>
      <p><strong>Whirlpool Corp parts advantage.</strong> JennAir uses Whirlpool Corporation platform components (compressors, pumps, motors, control boards) often shared with KitchenAid and Maytag. Our parts network leverages this, common JennAir failure components arrive within 1-2 days, and on discontinued older JennAir SKUs we sometimes source functionally-equivalent KitchenAid parts when genuine JennAir is unavailable.</p>
      <p><strong>Honest assessment.</strong> We tell you when repair makes sense and when it doesn't. 15+ year old JennAir range with compound failure often pencils out better as replacement than $1,200+ repair investment on aged electronics. We'd rather lose the repair revenue and keep your trust than sell you work that doesn't deliver value.</p>
      <p><strong>OEM parts on truck.</strong> Common JennAir failure parts stocked on every service truck: Embraco VCC2 inverter board (12002799), oven temperature sensor (5760M301-60), Appliance Manager board (W10821712), control panels (W11232121 and W10855641), drain pumps, water inlet valves, heating elements, spark modules, door gaskets, thermistors, ice maker modules. Most calls complete in one visit.</p>
    </div>
  </section>

  <!-- ── CATEGORIES ── -->
  <section class="section">
    <div class="container">
      <p class="eyebrow-sub">Explore by category</p>
      <h2>JennAir categories we service</h2>
      <div class="cat-grid">
        <a href="/brands/jennair-refrigerator-repair/" class="cat-card">
          <h3>JennAir Refrigerator Repair</h3>
          <p>Built-in columns (JS42, JS48, JF42), French-door, side-by-side, counter-depth. Embraco VCC2 inverter board (OEM 12002799), diagnostic test mode, VitaFreshPlus drawers, EPA 608 sealed-system service.</p>
          <span class="cat-cta">View refrigerator repair →</span>
        </a>
        <a href="/brands/jennair-range-repair/" class="cat-card">
          <h3>JennAir Range &amp; Stove Repair</h3>
          <p>Dual-fuel (JDRP, JDSP Steam Assist), gas pro (JGRP), induction (JIS, JPIFC, JPIGC), slide-in (JDS, JGS). Complete F-code decoder, spark module, oven sensor 5760M301-60, 30"/36"/48" widths.</p>
          <span class="cat-cta">View range repair →</span>
        </a>
        <a href="/brands/jennair-oven-repair/" class="cat-card">
          <h3>JennAir Wall Oven Repair</h3>
          <p>JJW double/single ovens, JMW microwave-combo, JBS speed ovens. NOIR Obsidian Interior matte-black cavity. F2E1 control panel defect diagnostic, F6E1 over-temp, Appliance Manager W10821712.</p>
          <span class="cat-cta">View wall oven repair →</span>
        </a>
        <a href="/brands/jennair-dishwasher-repair/" class="cat-card">
          <h3>JennAir Dishwasher Repair</h3>
          <p>JDB built-in and JDPSS professional. TriFecta wash system, OWI Optical Water Indicator, panel-ready. 7-second stuck-button diagnostic. Southern California hard-water descaling service (cadence shorter in IE).</p>
          <span class="cat-cta">View dishwasher repair →</span>
        </a>
        <div class="cat-card cat-info">
          <h3>JennAir Cooktops &amp; Downdraft</h3>
          <p>Gas, induction, electric ceramic cooktops. JennAir's signature downdraft ventilation service, blower motor, damper actuator, vent telescope. Call directly or see range page for downdraft details.</p>
          <span class="cat-cta cat-cta-muted">Call for service →</span>
        </div>
        <a href="/brands/jennair-dryer-repair/" class="cat-card">
          <h3>JennAir Laundry, Brand Note</h3>
          <p>JennAir doesn't currently make washers or dryers (kitchen-only brand). Legacy 1982-2006 "Norgetag" units still serviced. See page for brand clarification and alternative recommendations.</p>
          <span class="cat-cta">View brand clarification →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ── SERVICE AREAS ── -->
  <section class="section section-alt">
    <div class="container">
      <p class="eyebrow-sub">Where we work</p>
      <h2>JennAir service across Southern California</h2>
      <p>JennAir density is highest in modern luxury and upper-mid renovation markets, Hollywood Hills, West Hollywood, Brentwood, Santa Monica, Mid-Wilshire, Westwood, Pasadena, Sherman Oaks, Encino, Studio City, Calabasas, and Malibu on the LA side; Newport Coast, Newport Beach, Pelican Hill, Coto de Caza, and Tustin in OC; Westlake Village, Thousand Oaks, and Hidden Hills in Ventura; and Rancho Cucamonga, Alta Loma, and Temecula wine-country in the IE. Strong market in Sherman Oaks specifically, the 91403 and 91423 zip codes have high density of 2010+ single-family renovations with JennAir kitchens, and growing markets in Newport Coast and Westlake Village contemporary modernist builds. Eight service territories cover all five counties with same-day service availability:</p>
      <BrandBranchesGrid showHeader={false} />
    </div>
  </section>

  <!-- ── BRAND CONTEXT ── -->
  <section class="section">
    <div class="container narrow">
      <p class="eyebrow-sub">About the brand</p>
      <h2>JennAir, Whirlpool Corporation's luxury kitchen brand.</h2>
      <p>JennAir (also spelled Jenn-Air) was founded in 1947 in Indianapolis, Indiana by Louis J. Jenn, originally making industrial fans. In 1961, Jenn integrated one of his fans into a cooktop, inventing the world's first self-ventilated downdraft range, the product that defined the brand. Maytag Corporation acquired JennAir in 1982, and Whirlpool Corporation acquired Maytag in 2006, bringing JennAir into the larger Whirlpool Corp luxury portfolio alongside KitchenAid, Maytag, Amana, and Whirlpool itself.</p>
      <p>Today JennAir positions as design-forward luxury with two design collections: <strong>RISE</strong> (brushed stainless, commercial-style handles, suffix HL on model numbers, evokes professional restaurant aesthetic similar to Viking or Wolf) and <strong>NOIR</strong> (matte black finishes, Obsidian Interior oven cavities, minimalist controls, suffix HM, design-forward contemporary aesthetic).</p>
      <p>For service, JennAir's Whirlpool Corporation parentage is a practical advantage, core components like compressors, motors, and control boards are frequently shared with KitchenAid and Maytag equivalents, which means excellent parts availability and competitive repair economics. JennAir-specific items (NOIR trim, Obsidian Interior glass, downdraft ventilation assemblies, branded faceplates) require genuine JennAir parts but are typically same-week availability.</p>
    </div>
  </section>

  <!-- ── WARRANTY ── -->
  <section class="section section-alt">
    <div class="container narrow">
      <p class="eyebrow-sub">Warranty context</p>
      <h2>In-warranty vs post-warranty, when to call us.</h2>
      <p>JennAir base warranty is <strong>1 year on parts and labor</strong> across most product lines. During the first year, call JennAir customer service at <strong>1-800-536-6247</strong> for authorized dispatch at no parts cost, this is the right move for units under original warranty.</p>
      <p>Post-warranty (year 2 and beyond) is where we operate. Most of our JennAir calls are 3-to-15-year-old units past the 1-year base coverage. Same factory training as JennAir authorized dispatch, faster response, lower labor rate. On aged units (12-15+ years), we provide honest repair-vs-replace assessment rather than defaulting to costly repairs on appliances nearing end-of-life.</p>
      <p>Some JennAir products carry extended component coverage, sealed-system refrigeration on premium column refrigerators typically has 5-year extended warranty on specific components. We verify actual warranty period for your specific model before any major repair quote, which sometimes identifies coverage still in effect that you weren't aware of.</p>
    </div>
  </section>

  <!-- ── FAQ ── -->
  <section class="section">
    <div class="container narrow">
      <p class="eyebrow-sub">FAQ</p>
      <h2>Common questions</h2>

      <details class="faq">
        <summary>What JennAir appliances do you repair?</summary>
        <p>Refrigerators, ranges, wall ovens, cooktops (including downdraft), dishwashers, microwaves, warming drawers. All models, all configurations, RISE and NOIR. We don't service JennAir laundry because JennAir doesn't currently make washers/dryers.</p>
      </details>

      <details class="faq">
        <summary>Are you factory-trained?</summary>
        <p>Yes on all categories. Not JennAir-authorized (in-warranty call 1-800-536-6247 directly). Post-warranty specialists with same factory training.</p>
      </details>

      <details class="faq">
        <summary>Why choose you over other LA repair shops?</summary>
        <p>Verifiable credentials (BHGS #A49573, active  license, EPA 608 Universal #1346255700410, BBB A+), honest pricing with no surprise charges, OEM parts on truck, Whirlpool Corp cross-brand parts advantage, honest repair-vs-replace assessments on aged units.</p>
      </details>

      <details class="faq">
        <summary>Do you service all LA neighborhoods?</summary>
        <p>Yes. Five dispatch centers: West Hollywood, LA, Thousand Oaks, Pasadena, Irvine. Same-day service for most of Greater LA. Strong JennAir density in Sherman Oaks (91403/91423).</p>
      </details>

      <details class="faq">
        <summary>RISE vs NOIR, service difference?</summary>
        <p>Mostly no. Same engineering. Only NOIR-specific trim and Obsidian Interior glass aren't cross-compatible with RISE. Functional service identical.</p>
      </details>

      <details class="faq">
        <summary>How much does JennAir repair cost?</summary>
        <p>Diagnostic $89, waived with repair. All parts and labor quoted before work starts. Common repairs range $165-$820 depending on component. See individual category pages for detailed pricing.</p>
      </details>
    </div>
  </section>

  <!-- ── BOTTOM CTA ── -->
  <section class="bottom-cta">
    <div class="container">
      <h2>Ready to schedule JennAir service?</h2>
      <p>Same day available. $89 diagnostic, waived with repair. Labor and parts quoted before we start.</p>
      <div class="hero-ctas">
        <a href={`tel:${MAIN_PHONE_TEL}`} class="btn-primary">☎ Call {MAIN_PHONE}</a>
        <a href="/contact/" class="btn-outline">Book Online</a>
      </div>
    </div>
  </section>

<style>
  :root {
    --red: #C8102E;
    --black: #0a0a0a;
    --gray: #f5f5f5;
    --border: #e2e2e2;
    --text: #1a1a1a;
    --muted: #6b6b6b;
    --white: #ffffff;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; color: var(--text); line-height: 1.6; }

  .hero { background: var(--black); color: #fff; padding: 80px 24px 72px; }
  .hero-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; max-width: 1100px; margin: 0 auto; align-items: center; }
  .hero-eyebrow { font-size: 13px; color: var(--red); text-transform: uppercase; letter-spacing: .12em; margin-bottom: 16px; font-weight: 600; }
  .hero h1 { font-size: clamp(28px, 4vw, 46px); font-weight: 700; color: #fff; margin-bottom: 20px; line-height: 1.15; font-family: 'Playfair Display', Georgia, serif; }
  .hero-sub { font-size: 17px; color: rgba(255,255,255,.72); margin-bottom: 28px; }
  .hero-ctas { display: flex; gap: 12px; margin-bottom: 28px; flex-wrap: wrap; }
  .btn-primary { display: inline-block; padding: 14px 28px; background: var(--red); color: #fff; text-decoration: none; border-radius: 6px; font-weight: 600; font-size: 16px; transition: background .2s; }
  .btn-primary:hover { background: #a50d25; }
  .btn-outline { display: inline-block; padding: 14px 28px; border: 1.5px solid rgba(255,255,255,.35); color: #fff; text-decoration: none; border-radius: 6px; font-weight: 600; font-size: 16px; transition: all .2s; }
  .btn-outline:hover { background: rgba(255,255,255,.08); border-color: #fff; }
  .hero-img-wrap { aspect-ratio: 4/3; background: #1a1a1a; border-radius: 4px; display: flex; align-items: center; justify-content: center; }
  .hero-img-placeholder { color: rgba(255,255,255,.35); font-size: 14px; text-align: center; }
  @media (max-width: 768px) { .hero-inner { grid-template-columns: 1fr; } .hero-img-wrap { display: none; } }

  .trust-bar { background: var(--red); color: #fff; padding: 16px 24px; }
  .trust-bar-inner { max-width: 1100px; margin: 0 auto; display: flex; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
  .trust-item { font-size: 13px; font-weight: 600; display: flex; align-items: center; gap: 8px; }
  .trust-icon { font-size: 16px; }

  .section { padding: 72px 24px; }
  .section-alt { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; }
  .container.narrow { max-width: 780px; }
  .eyebrow-sub { font-size: 13px; color: var(--red); text-transform: uppercase; letter-spacing: .12em; margin-bottom: 12px; font-weight: 600; }
  h2 { font-size: clamp(24px, 3vw, 34px); font-weight: 700; margin-bottom: 20px; line-height: 1.2; font-family: 'Playfair Display', Georgia, serif; }
  .section p { margin-bottom: 16px; color: var(--text); }
  .section p a { color: var(--red); text-decoration: underline; }

  .cat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 20px; margin-top: 32px; }
  .cat-card { display: block; padding: 24px; background: #fff; border: 1px solid var(--border); border-radius: 8px; text-decoration: none; color: inherit; transition: all .2s; }
  .cat-card:hover { border-color: var(--red); transform: translateY(-2px); box-shadow: 0 4px 16px rgba(0,0,0,.08); }
  .cat-card h3 { font-size: 17px; font-weight: 700; margin-bottom: 10px; color: var(--black); font-family: 'Playfair Display', Georgia, serif; }
  .cat-card p { font-size: 14px; color: var(--muted); margin-bottom: 14px; }
  .cat-cta { font-size: 13px; color: var(--red); font-weight: 600; }
  .cat-info { cursor: default; }
  .cat-info:hover { border-color: var(--border); transform: none; box-shadow: none; }
  .cat-cta-muted { color: var(--muted); }

  .faq { margin-bottom: 12px; border: 1px solid var(--border); border-radius: 6px; padding: 16px 20px; background: #fff; }
  .faq summary { font-weight: 600; cursor: pointer; font-size: 16px; color: var(--black); }
  .faq[open] summary { margin-bottom: 12px; }
