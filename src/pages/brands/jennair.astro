---
import Layout from '../../layouts/Layout.astro';

const title = "JennAir Appliance Repair Los Angeles | Jenn-Air, RISE Collection, NOIR Collection";
const description = "JennAir (Jenn-Air) appliance repair in Los Angeles. RISE Collection, NOIR Collection flagship. Column refrigerators, ranges, wall ovens, downdraft cooktops, dishwashers, dryers. Whirlpool luxury tier. Factory-trained on all platforms. Post-warranty specialists. $89 diagnostic waived with repair. Call (424) 325-0520.";

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": "https://samedayappliance.repair/brands/jennair/#business",
    "name": "Same Day Appliance Repair — JennAir Service",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": "https://samedayappliance.repair/brands/jennair/",
    "telephone": "+1-424-325-0520",
    "priceRange": "$$$$",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "6230 Wilshire Blvd Ste A PMB 2267",
      "addressLocality": "Los Angeles",
      "addressRegion": "CA",
      "postalCode": "90048",
      "addressCountry": "US"
    },
    "geo": { "@type": "GeoCoordinates", "latitude": 34.0619, "longitude": -118.3692 },
    "areaServed": [
      { "@type": "City", "name": "Los Angeles" },
      { "@type": "City", "name": "Beverly Hills" },
      { "@type": "City", "name": "Sherman Oaks" },
      { "@type": "City", "name": "Brentwood" },
      { "@type": "City", "name": "Santa Monica" },
      { "@type": "City", "name": "Pasadena" },
      { "@type": "City", "name": "Calabasas" }
    ],
    "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.6", "reviewCount": "37" }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What JennAir (Jenn-Air) appliances do you service?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "JennAir's full luxury product line: column refrigerators (panel-ready built-ins competing with Sub-Zero), standalone refrigerators, ranges (dual-fuel, gas, induction), wall ovens (single, double, speed ovens, steam), downdraft cooktops (JennAir signature feature), standard cooktops (induction, gas, electric), dishwashers (TriFecta, fully-integrated), compact 24\" dryers, and microwave ovens (built-in, drawer). Both RISE Collection and NOIR Collection design tiers. We service the full luxury line back to 2010-era units."
        }
      },
      {
        "@type": "Question",
        "name": "What's the difference between RISE and NOIR Collections?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Same core engineering, different design languages. RISE Collection is JennAir's professional-style aesthetic — brushed stainless steel, commercial-grade handles and controls, modular design cues that echo restaurant-kitchen heritage. Similar visual language to Viking or Wolf, targeted at buyers who want that commercial look. NOIR Collection is JennAir's flagship design tier — black stainless or obsidian finishes, matte-black glass, minimalist controls, design-forward aesthetic. Noir often includes the exclusive Obsidian Interior on ovens — matte-black glass oven cavity that disguises cooking splatters and visually emphasizes food. Service components are largely shared between collections — same compressors, same heating elements, same control architectures. The differences are in finish, trim, handle design, and sometimes control interface styling."
        }
      },
      {
        "@type": "Question",
        "name": "Is JennAir made by Whirlpool?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes — JennAir is Whirlpool Corporation's flagship luxury brand, sister to KitchenAid (upper-mid), Maytag (mid), Amana (entry), and Whirlpool (mass). All five brands are built in the same North American manufacturing facilities using shared core platforms, scaled and trimmed for different market tiers. For service: this means JennAir compressors, motors, control boards, and sensors are often shared parts with KitchenAid equivalents, even Whirlpool-tier parts. We carry cross-brand inventory and know which parts transfer between tiers. Some JennAir-specific items (the Obsidian Interior glass, NOIR panel trim, downdraft ventilation assemblies) don't share with other Whirlpool brands and require genuine JennAir parts."
        }
      },
      {
        "@type": "Question",
        "name": "Are you JennAir-authorized?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No — we're factory-trained but independent. JennAir has its own authorized service network for in-warranty dispatch. Inside the 1-year JennAir base warranty, call JennAir customer service at 1-800-536-6247 for authorized service dispatch at no parts cost. Post-warranty, we're the better call: faster response, lower labor rate, same technical training across all JennAir platforms. Most of our JennAir calls are 3-to-10-year-old units past the base coverage. For in-warranty issues, call JennAir first; for anything outside warranty, call us."
        }
      },
      {
        "@type": "Question",
        "name": "Do you service JennAir downdraft cooktops?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Downdraft ventilation is a JennAir signature — a powerful blower integrated into the cooktop that rises above the cooking surface to pull steam and smoke downward and out through ducting. Common in open-floorplan LA kitchens where a traditional overhead hood would be architecturally awkward. Service items specific to downdraft: blower motor (most common failure, $345-$485), damper actuator (raises and lowers the vent telescope), vent telescope mechanism, filter assembly, ducting connection integrity. Downdraft adds 45-60 minutes to typical cooktop service calls due to the additional ventilation system to diagnose. We're trained on both the downdraft ventilation and the cooktop it's integrated into."
        }
      },
      {
        "@type": "Question",
        "name": "JennAir in Sherman Oaks — do you service that area?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Sherman Oaks is a strong JennAir market — many 2010+ single-family homes and renovations in the 91403 and 91423 zip codes specified JennAir across the kitchen. We service Sherman Oaks, Studio City, Encino, Tarzana, and the rest of the 101 corridor from our Thousand Oaks dispatch (424) 208-0228 and Los Angeles dispatch (424) 325-0520. Same-day appointments available for most service needs."
        }
      }
    ]
  }
];
---
<Layout title={title} description={description}>
  <Fragment slot="head-scripts">
    {schemaJsons.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </Fragment>

  <section class="hero">
    <div class="hero-inner">
      <div class="hero-content">
        <p class="hero-eyebrow">Los Angeles · Beverly Hills · Sherman Oaks · Brentwood · Pasadena</p>
        <h1>JennAir Appliance Repair Los Angeles</h1>
        <p class="hero-sub">Factory-trained service on JennAir (Jenn-Air) — the full RISE Collection and NOIR Collection. Column refrigerators, dual-fuel and induction ranges, wall ovens with Obsidian Interior, downdraft cooktops, TriFecta dishwashers, and compact dryers. Whirlpool Corporation's luxury flagship. Post-warranty specialists for 3-to-10-year-old JennAir units across LA.</p>
        <div class="hero-ctas">
          <a href="tel:+14243250520" class="btn-primary">☎ (424) 325-0520</a>
          <a href="/contact/" class="btn-outline">Book Online</a>
        </div>
        <div class="hero-rating">
          <span class="stars">★★★★★</span>
          <span>4.6 · 37 reviews · Google</span>
        </div>
      </div>
      <div class="hero-img-wrap">
        <div class="hero-img-placeholder">
          <p>JennAir Appliance Repair</p>
          <p>Los Angeles</p>
        </div>
      </div>
    </div>
  </section>

  <div class="trust-bar">
    <div class="trust-bar-inner">
      <div class="trust-item"><span class="trust-icon">🏅</span> CSLB Licensed #1138898</div>
      <div class="trust-item"><span class="trust-icon">❄</span> EPA 608 Certified</div>
      <div class="trust-item"><span class="trust-icon">⚡</span> Same Day Available</div>
      <div class="trust-item"><span class="trust-icon">🔩</span> OEM Parts on Truck</div>
      <div class="trust-item"><span class="trust-icon">💬</span> $89 Diagnostic — Waived With Repair</div>
    </div>
  </div>

  <!-- ── ABOUT ── -->
  <section class="section">
    <div class="container">
      <p class="eyebrow-sub">About the brand</p>
      <h2>JennAir — Whirlpool's luxury flagship, design-forward across every category.</h2>
      <p>JennAir (also spelled Jenn-Air, pronounced "Jen Air") occupies a distinct position in the LA luxury appliance market. Not the old-money traditional luxury of Sub-Zero and Wolf, not the restaurant-heritage professional look of Viking. JennAir is <strong>design-forward luxury</strong> — engineered for owners who want premium performance with a contemporary aesthetic, particularly the NOIR Collection with its black-and-obsidian finishes that have become signature in modern LA architecture.</p>
      <p>Two design collections define the brand. <strong>RISE Collection</strong> uses brushed stainless and commercial-style detailing — appeals to buyers who want professional aesthetic at Whirlpool-corp price points rather than Viking/Wolf premium. <strong>NOIR Collection</strong> is the flagship — matte black finishes, blackened glass, minimalist controls, and the <strong>Obsidian Interior</strong> on wall ovens (matte-black glass oven cavity that visually emphasizes food against dark background, unique to JennAir in the US market). Common in contemporary Westside renovations, Hollywood Hills modernist builds, Sherman Oaks luxury single-family, and Calabasas custom homes.</p>
      <p>For service, JennAir's key advantage is its Whirlpool Corporation parentage — shared engineering platforms with KitchenAid, Maytag, Amana, and Whirlpool itself. Core components (compressors, motors, control boards) are often cross-compatible across tiers, which means excellent parts availability and competitive repair economics. JennAir-specific items (NOIR trim, Obsidian Interior glass, downdraft ventilation assemblies) require genuine JennAir parts — we carry both common cross-compatible parts and JennAir-specific items on every truck.</p>
    </div>
  </section>

  <!-- ── CATEGORIES ── -->
  <section class="section section-alt">
    <div class="container">
      <p class="eyebrow-sub">What we repair</p>
      <h2>JennAir categories we service</h2>
      <div class="cat-grid">
        <a href="/brands/jennair-refrigerator-repair/" class="cat-card">
          <h3>JennAir Refrigerator Repair</h3>
          <p>Column refrigerators (panel-ready built-in, competes with Sub-Zero), French-door, bottom-mount, counter-depth, side-by-side. JF prefix models, RISE and NOIR finishes. VitaFreshPlus, TwinCooling, compressor service, sealed-system diagnostics.</p>
          <span class="cat-cta">View refrigerator repair →</span>
        </a>
        <a href="/brands/jennair-range-repair/" class="cat-card">
          <h3>JennAir Range Repair</h3>
          <p>Dual-fuel, gas, and induction ranges. 30", 36", 48" widths. JGRP (gas pro), JDRP (dual-fuel pro), JIRP (induction pro), JES (electric). Obsidian Interior on NOIR ovens. Burner valves, spark ignition, convection fan.</p>
          <span class="cat-cta">View range repair →</span>
        </a>
        <a href="/brands/jennair-oven-repair/" class="cat-card">
          <h3>JennAir Wall Oven Repair</h3>
          <p>Single, double, speed ovens, steam ovens. JJW (wall oven), JMW (microwave-combo), JBS (speed). RISE and NOIR. Obsidian Interior matte-black cavity (NOIR). Heating elements, convection fan, RTD probe, door hinges.</p>
          <span class="cat-cta">View wall oven repair →</span>
        </a>
        <a href="/brands/jennair-dishwasher-repair/" class="cat-card">
          <h3>JennAir Dishwasher Repair</h3>
          <p>TriFecta wash system (pro-style cleaning), fully-integrated panel-ready dishwashers. JDB and JDPSS models. RISE handle styling, NOIR black stainless finishes. Circulation pump, drain pump, door latch, spray arm service.</p>
          <span class="cat-cta">View dishwasher repair →</span>
        </a>
        <a href="/brands/jennair-dryer-repair/" class="cat-card">
          <h3>JennAir Dryer &amp; Washer Repair</h3>
          <p>Compact 24" stacked laundry. JGD (gas dryer), JED (electric dryer), JTL (washer). Heat-pump and conventional venting options. Less common in LA than Miele or Bosch compact laundry but occasionally paired in JennAir kitchens.</p>
          <span class="cat-cta">View dryer repair →</span>
        </a>
        <div class="cat-card cat-info">
          <h3>JennAir Downdraft Cooktops</h3>
          <p>Covered on the range and cooktop pages — JennAir's signature downdraft ventilation rises above the cooking surface to pull steam and smoke downward through ducting. Blower motor, damper actuator, vent telescope, filter service. Common in open-plan LA kitchens.</p>
          <span class="cat-cta cat-cta-muted">See range / cooktop pages</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── COLLECTIONS GUIDE ── -->
  <section class="section">
    <div class="container narrow">
      <p class="eyebrow-sub">Collections guide</p>
      <h2>Understanding RISE vs NOIR Collections</h2>
      <p>JennAir organizes its current product lineup into two design collections. Both use the same core engineering — same compressors, heating elements, motors, and control architectures. The distinction is purely aesthetic, but that choice matters for how the appliance fits into a kitchen and for some NOIR-specific service items.</p>
      <p><strong>RISE Collection.</strong> JennAir's professional-style design language. Brushed stainless steel finishes, chrome-accented knobs and handles, commercial-grade ventilation grilles, modular visual language. Evokes restaurant-kitchen heritage similar to Viking or Wolf aesthetic but at Whirlpool Corporation's price tier. Most common in traditional-style luxury kitchens, transitional designs, and projects where the owner wants professional look without the Viking/Wolf price premium.</p>
      <p><strong>NOIR Collection.</strong> Flagship design tier. Matte black stainless, obsidian finishes, blackened glass, minimalist touch controls, understated branding. Includes the <strong>Obsidian Interior</strong> option on wall ovens — matte-black glass oven cavity that visually emphasizes food against the dark background. Signature LA kitchens with NOIR: Hollywood Hills modernist builds, contemporary Westside renovations, Sherman Oaks luxury single-family with clean-lined architecture, Calabasas custom homes with transitional-contemporary aesthetics.</p>
      <p>Service-relevant differences: NOIR appliances use JennAir-specific black-finish trim, handles, and glass panels that aren't interchangeable with RISE or with other Whirlpool Corp brands (KitchenAid, Maytag). If a NOIR oven door glass breaks, it's an NOIR-specific replacement ($385-$580) — not interchangeable with a RISE oven's glass even on identical underlying model. Core components (compressor, heating element, control board) are shared across the brand.</p>
    </div>
  </section>

  <!-- ── WHIRLPOOL FAMILY ── -->
  <section class="section section-alt">
    <div class="container narrow">
      <p class="eyebrow-sub">Brand family context</p>
      <h2>JennAir is Whirlpool Corporation's luxury brand.</h2>
      <p>Understanding the Whirlpool Corporation brand hierarchy helps explain JennAir's service economics and parts availability. The hierarchy from premium to mass:</p>
      <p><strong>JennAir</strong> (luxury flagship) — design-forward, NOIR and RISE collections, competing with Viking, Wolf, and Thermador in LA's luxury market.</p>
      <p><strong>KitchenAid</strong> (upper-mid premium) — the brand's "bakers' favorite" positioning. Shares many core components with JennAir — KitchenAid compressors, motors, and control boards are often identical to JennAir equivalents, trimmed differently.</p>
      <p><strong>Whirlpool</strong> (mid/mass) — the flagship volume brand. Some engineering platforms shared with JennAir/KitchenAid at simplified feature levels.</p>
      <p><strong>Maytag</strong> (durability-focused mid-tier) — traditionally aimed at longer-warranty value positioning, uses some shared platform components.</p>
      <p><strong>Amana</strong> (entry) — budget-tier volume brand. Less platform overlap with JennAir.</p>
      <p>For service: cross-brand parts compatibility is a real thing at Whirlpool Corp. Many JennAir compressor, control board, and motor components are literally the same part numbers used in KitchenAid equivalents. This means: (1) excellent parts availability — we can source most JennAir components in 1-2 days; (2) competitive repair economics because parts aren't "luxury exclusive" in the way genuine Sub-Zero or Wolf parts are; (3) on discontinued older JennAir models, we sometimes source functionally-equivalent KitchenAid parts when JennAir SKUs are unavailable.</p>
      <p>What doesn't cross-brand: NOIR-specific trim, Obsidian Interior glass, downdraft ventilation assemblies, branded faceplates. Those require genuine JennAir parts through standard distribution — typically same-week availability for common items.</p>
    </div>
  </section>

  <!-- ── SERVICE AREAS ── -->
  <section class="section">
    <div class="container">
      <p class="eyebrow-sub">Where we work</p>
      <h2>JennAir service across Greater Los Angeles</h2>
      <p>JennAir density is highest in modern luxury and upper-mid renovation markets: Hollywood Hills, West Hollywood, Brentwood, Santa Monica, Mid-Wilshire, Westwood, Pasadena, Sherman Oaks, Encino, Studio City, Calabasas, and Malibu. Strong market in Sherman Oaks specifically — the 91403 and 91423 zip codes have high density of 2010+ single-family renovations with JennAir kitchens.</p>
      <div class="branch-grid">
        <div class="branch-card">
          <h3>West Hollywood</h3>
          <p>(323) 870-4790</p>
          <p class="branch-area">Beverly Hills, Bel Air, Holmby Hills, Hancock Park, Mid-Wilshire</p>
        </div>
        <div class="branch-card">
          <h3>Los Angeles</h3>
          <p>(424) 325-0520</p>
          <p class="branch-area">Brentwood, Pacific Palisades, Malibu, Santa Monica, Century City, Westwood</p>
        </div>
        <div class="branch-card">
          <h3>Thousand Oaks</h3>
          <p>(424) 208-0228</p>
          <p class="branch-area">Sherman Oaks, Studio City, Encino, Tarzana, Calabasas, Westlake Village, Agoura Hills</p>
        </div>
        <div class="branch-card">
          <h3>Pasadena</h3>
          <p>(626) 376-4458</p>
          <p class="branch-area">San Marino, La Cañada Flintridge, Arcadia, South Pasadena, Altadena</p>
        </div>
        <div class="branch-card">
          <h3>Irvine</h3>
          <p>(213) 401-9019</p>
          <p class="branch-area">Newport Beach, Corona del Mar, Laguna, Newport Coast, Turtle Rock</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── WARRANTY ── -->
  <section class="section section-alt">
    <div class="container narrow">
      <p class="eyebrow-sub">Warranty context</p>
      <h2>JennAir warranty and when to call us</h2>
      <p>JennAir base warranty is <strong>1 year on parts and labor</strong> across most product lines. During the first year, call JennAir customer service at <strong>1-800-536-6247</strong> for authorized dispatch at no parts cost.</p>
      <p>Some JennAir products have extended coverage on specific components. Sealed-system refrigeration components on premium column refrigerators typically carry extended coverage — we verify actual warranty period for your specific model before any major repair. KitchenAid/JennAir compressor warranties are generally shorter than Sub-Zero's industry-leading 12-year sealed-system warranty; plan for year 8-12 compressor replacement budgeting on column refrigerators.</p>
      <p>Post-warranty is where we operate. Most of our JennAir calls are 3-to-10-year-old units past the 1-year base coverage. Same factory training as JennAir authorized dispatch, faster response, lower labor rate. For in-warranty issues, call JennAir first; for anything outside, call us.</p>
    </div>
  </section>

  <!-- ── CREDENTIALS ── -->
  <section class="section">
    <div class="container narrow">
      <p class="eyebrow-sub">Credentials</p>
      <h2>Licensed, insured, EPA-certified</h2>
      <p>HVAC 777 LLC (dba Same Day Appliance Repair) holds an active CSLB C-20 license — <strong>#1138898</strong>. JennAir column and built-in refrigerator sealed-system service requires EPA 608 refrigerant handling certification; all our technicians are 608 certified. We carry general liability and workers' comp. BHGS-registered under <strong>#A49573</strong>. BBB A+ since 2022.</p>
    </div>
  </section>

  <!-- ── FAQ ── -->
  <section class="section section-alt">
    <div class="container narrow">
      <p class="eyebrow-sub">FAQ</p>
      <h2>JennAir service — common questions</h2>

      <details class="faq">
        <summary>What JennAir appliances do you service?</summary>
        <p>Full line: column and standard refrigerators, ranges (dual-fuel/gas/induction), wall ovens, downdraft and standard cooktops, dishwashers, compact dryers, built-in microwaves. RISE and NOIR Collections.</p>
      </details>

      <details class="faq">
        <summary>RISE vs NOIR — what's the difference?</summary>
        <p>Same engineering, different design. RISE = brushed stainless, commercial-style, professional heritage. NOIR = matte black, obsidian finishes, minimalist, design-forward. NOIR adds Obsidian Interior on ovens. Service components largely shared except NOIR-specific trim.</p>
      </details>

      <details class="faq">
        <summary>Is JennAir Whirlpool?</summary>
        <p>Yes — Whirlpool Corporation's luxury flagship. Sister brands KitchenAid, Maytag, Amana, Whirlpool. Cross-brand parts compatibility for core components (compressors, motors, boards) — good for parts availability and repair economics.</p>
      </details>

      <details class="faq">
        <summary>Are you JennAir-authorized?</summary>
        <p>No — factory-trained but independent. In-warranty call JennAir 1-800-536-6247. Post-warranty: faster response, lower labor rate, same training.</p>
      </details>

      <details class="faq">
        <summary>Downdraft cooktops — do you service?</summary>
        <p>Yes. JennAir signature feature — blower motor, damper actuator, vent telescope, filter assembly. Adds 45-60 min to typical cooktop service. Covered on cooktop and range pages.</p>
      </details>

      <details class="faq">
        <summary>JennAir in Sherman Oaks / Valley?</summary>
        <p>Yes. Strong JennAir market in 91403/91423 zip codes. Covered from Thousand Oaks (424) 208-0228 and LA (424) 325-0520 dispatches. Same-day available.</p>
      </details>
    </div>
  </section>

  <!-- ── BOTTOM CTA ── -->
  <section class="bottom-cta">
    <div class="container">
      <h2>Ready to schedule JennAir service?</h2>
      <p>Same day available. $89 diagnostic, waived with repair. Labor and parts quoted before we start.</p>
      <div class="hero-ctas">
        <a href="tel:+14243250520" class="btn-primary">☎ Call (424) 325-0520</a>
        <a href="/contact/" class="btn-outline">Book Online</a>
      </div>
    </div>
  </section>

<style>
  :root {
    --red: #C8102E;
    --black: #0a0a0a;
    --gray: #f5f5f5;
    --border: #e2e2e2;
    --text: #1a1a1a;
    --muted: #6b6b6b;
    --white: #ffffff;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; color: var(--text); line-height: 1.6; }

  .hero { background: var(--black); color: #fff; padding: 80px 24px 72px; }
  .hero-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; max-width: 1100px; margin: 0 auto; align-items: center; }
  .hero-eyebrow { font-size: 13px; color: var(--red); text-transform: uppercase; letter-spacing: .12em; margin-bottom: 16px; font-weight: 600; }
  .hero h1 { font-size: clamp(28px, 4vw, 46px); font-weight: 700; color: #fff; margin-bottom: 20px; line-height: 1.15; font-family: 'Playfair Display', Georgia, serif; }
  .hero-sub { font-size: 17px; color: rgba(255,255,255,.72); margin-bottom: 28px; }
  .hero-ctas { display: flex; gap: 12px; margin-bottom: 28px; flex-wrap: wrap; }
  .btn-primary { display: inline-block; padding: 14px 28px; background: var(--red); color: #fff; text-decoration: none; border-radius: 6px; font-weight: 600; font-size: 16px; transition: background .2s; }
  .btn-primary:hover { background: #a50d25; }
  .btn-outline { display: inline-block; padding: 14px 28px; border: 1.5px solid rgba(255,255,255,.35); color: #fff; text-decoration: none; border-radius: 6px; font-weight: 600; font-size: 16px; transition: all .2s; }
  .btn-outline:hover { background: rgba(255,255,255,.08); border-color: #fff; }
  .hero-rating { display: flex; align-items: center; gap: 8px; font-size: 14px; color: rgba(255,255,255,.8); }
  .stars { color: #f59e0b; letter-spacing: 2px; }
  .hero-img-wrap { aspect-ratio: 4/3; background: #1a1a1a; border-radius: 4px; display: flex; align-items: center; justify-content: center; }
  .hero-img-placeholder { color: rgba(255,255,255,.35); font-size: 14px; text-align: center; }
  @media (max-width: 768px) { .hero-inner { grid-template-columns: 1fr; } .hero-img-wrap { display: none; } }

  .trust-bar { background: var(--red); color: #fff; padding: 16px 24px; }
  .trust-bar-inner { max-width: 1100px; margin: 0 auto; display: flex; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
  .trust-item { font-size: 13px; font-weight: 600; display: flex; align-items: center; gap: 8px; }
  .trust-icon { font-size: 16px; }

  .section { padding: 72px 24px; }
  .section-alt { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; }
  .container.narrow { max-width: 780px; }
  .eyebrow-sub { font-size: 13px; color: var(--red); text-transform: uppercase; letter-spacing: .12em; margin-bottom: 12px; font-weight: 600; }
  h2 { font-size: clamp(24px, 3vw, 34px); font-weight: 700; margin-bottom: 20px; line-height: 1.2; font-family: 'Playfair Display', Georgia, serif; }
  .section p { margin-bottom: 16px; color: var(--text); }

