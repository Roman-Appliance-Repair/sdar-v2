---
import Layout from '../../layouts/Layout.astro';
import BrandHubPlaceholder from '../../components/BrandHubPlaceholder.astro';

const title = "JennAir Appliance Repair Los Angeles | Same Day Service";
const description = "Expert JennAir appliance repair across LA, Orange, Ventura counties. All JennAir categories — refrigerator, range, oven, cooktop, dishwasher, microwave. Call (424) 325-0520.";

const categories = [
  { label: "Refrigerator", url: "/brands/jennair-refrigerator-repair/" },
  { label: "Range", url: "/brands/jennair-range-repair/" },
  { label: "Oven", url: "/brands/jennair-oven-repair/" },
  { label: "Cooktop", url: "/brands/jennair-cooktop-repair/" },
  { label: "Dishwasher", url: "/brands/jennair-dishwasher-repair/" },
  { label: "Microwave", url: "/brands/jennair-microwave-repair/" }
];
---

<Layout title={title} description={description}>
  <BrandHubPlaceholder brandName="JennAir" brandSlug="jennair" categories={categories} />
</Layout>
