---
// /brands/meiko-dishwasher-repair/
// Cluster 05 Commercial Dishwashers — Brand #6, P2 German premium, independent family 1927.
// 301 from legacy /meiko-dishwasher-repair/ (10 imp pos 11).
// MEIKO USA La Vergne TN direct (real US presence — distinguishing from Winterhalter).
import Layout from '../../layouts/Layout.astro';
import BrandBranchesGrid from '../../components/BrandBranchesGrid.astro';
import { MAIN_PHONE, MAIN_PHONE_TEL } from '../../data/branches';

const title = "Meiko Commercial Dishwasher Repair | Southern California | German";
const description = "Meiko M-iClean U/US/UM+/H, M-iQ flight-type, FV 40.2G glasswasher repair across Southern California. GiO RO + Blue Touch specialists. (424) 325-0520.";
const canonical = "https://samedayappliance.repair/brands/meiko-dishwasher-repair/";

const faqs = [
  {
    q: "Is Meiko family-owned or part of a conglomerate?",
    a: "Family-owned. Oskar Meier and August Koch founded Meiko in Offenburg, Germany in 1927 — the name combines their surnames (Meier + Koch). The company is still independent family-owned today, operating in 30+ countries with 23 subsidiaries and roughly 2,700 employees. Not part of ITW, not Ali Group, not Welbilt. Independence matters the same way it does for Winterhalter — the engineering continuity of a family-owned business versus the acquire-and-consolidate approach shapes long-term product decisions differently."
  },
  {
    q: "What's the difference between MEIKO USA direct and independent repair?",
    a: "MEIKO USA is the company's US subsidiary headquartered in La Vergne, Tennessee — 1-800-55-MEIKO or (615) 399-6600. It handles warranty work, authorized dealer installations, and direct-service accounts across the US. Unlike Winterhalter (which has no US subsidiary at all), MEIKO USA is a genuine US parts and service presence — parts flow through the La Vergne warehouse, and authorized technicians handle warranty claims. Our role as independent: out-of-warranty service, emergency after-hours calls, situations where MEIKO USA's authorized-provider dispatch window doesn't work for the operator's service timing. For warranty work on a newer unit, call MEIKO USA directly; for anything post-warranty or time-critical, we're the LA-local alternative."
  },
  {
    q: "Can you read MEIKO Connect app error codes?",
    a: "Yes. MEIKO Connect is Meiko's IoT diagnostic platform — the machine streams operational telemetry to a cloud platform that operators can access via app or web portal. When we come out on a service call, the Connect logs tell us a lot before we open the front panel: cycle counts, error-event history, temperature trends, chemistry-dosing events, any alert patterns over the last weeks. It shortens diagnostic time significantly. If your Meiko is Connect-enabled and you can share operator-portal access, we can review the logs remotely before dispatch and often narrow the likely failure before the tech arrives."
  },
  {
    q: "What's Blue Touch on my Meiko?",
    a: "Blue Touch is Meiko's color-coded maintenance training concept — any component marked with blue is designated as safe to touch, clean, or service by kitchen staff without technical training. Red-marked components are technician-only. The idea is to separate daily-maintenance tasks (filter cleaning, spray-arm inspection, gasket visual checks) that kitchen staff should do as part of closing-routine from deeper service that needs a trained technician. It's a good operational design; we point out the Blue Touch components during service calls so operators can integrate them into closing checklists. A well-maintained Meiko with staff doing Blue Touch maintenance daily lasts significantly longer than one where everything waits for service calls."
  },
  {
    q: "Do you service M-iQ flight-type at LAX airline kitchens?",
    a: "Yes. Meiko's M-iQ flight-type is the industry standard for high-throughput continuous-belt warewashing in airline flight kitchens and cruise-ship commissaries. Gate Gourmet at LAX operates M-iQ machines; so do several of the other major flight-catering operators serving LAX. AIDA cruise ships and other large cruise operators specify M-iQ for commissary operations — though the cruise side is not our LA service scope. At LAX and adjacent airline-catering operations, we service M-iQ on out-of-warranty and emergency-response accounts. Scheduled PM is contractual with MEIKO USA for most of the segment; our role is overflow and emergency coverage."
  },
  {
    q: "What does Meiko commercial dishwasher repair cost in LA?",
    a: "$120 flat commercial diagnostic, waived with repair. Typical Meiko service ranges: door gasket $180–$320, door switch $160–$260, fill valve $220–$380, rinse-arm bearing $200–$360, thermostat $200–$340, detergent dosing pump $220–$380, drain pump $300–$480, booster element $360–$580, GiO MODULE RO service $450–$800, wash pump seal kit $380–$620, ComfortAir heat-recovery module $400–$700, wash pump rebuild $500–$820, control board $750–$1,350, M-iQ flight service (scheduled or emergency) $800–$1,800. Most Meiko undercounter and door calls land $380–$800 parts-and-labor. Meiko typically runs comparable to Winterhalter pricing (both European premium) but with shorter parts lead time thanks to MEIKO USA's US parts warehouse — most parts 2–5 days versus 5–14 for Winterhalter."
  }
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": canonical + "#business",
      "name": "Same Day Appliance Repair",
      "image": "https://samedayappliance.repair/images/logo.png",
      "url": "https://samedayappliance.repair/",
      "telephone": MAIN_PHONE,
      "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ]
    },
    {
      "@type": "Service",
      "serviceType": "Meiko Commercial Dishwasher Repair",
      "provider": { "@id": canonical + "#business" },
      "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
      "description": "Meiko commercial dishwasher repair across Los Angeles — M-iClean U undercounter, M-iClean US compact, M-iClean UM+ larger undercounter, M-iClean H hood, M-iQ flight-type for airline and cruise, FV 40.2G glasswasher. GiO MODULE integrated RO, Blue Touch safe-component concept, ComfortAir heat recovery, MEIKO Connect IoT diagnostics. Independent German family-owned since 1927. MEIKO USA La Vergne TN parts supply."
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
        { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
        { "@type": "ListItem", "position": 3, "name": "Meiko Dishwasher Repair", "item": canonical }
      ]
    }
  ]
};
---

<Layout title={title} description={description} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <div class="call-banner">
    <div class="wrap">
      <span>Meiko dishwasher down? Same-day commercial service:</span>
      <a href={`tel:${MAIN_PHONE_TEL}`} class="phone-lg">{MAIN_PHONE}</a>
    </div>
  </div>

  <section class="hero"><div class="wrap">
          <div class="crumb"><a href="/">Home</a> › <a href="/brands/">Brands</a> › Meiko Dishwasher Repair</div>
          <h1>Meiko Commercial Dishwasher Repair</h1>
          <p class="lede">
            Meiko M-iClean U undercounter flagship, M-iClean US compact for wheat-beer glass clearance, M-iClean UM+
            high-throughput undercounter, M-iClean H hood machines, M-iQ flight-type for airline catering and hotel
            banquet prep, plus FV 40.2G glasswasher — our techs service the full Meiko Gastronom commercial line
            across LA, Orange County, Ventura, San Bernardino, and Riverside. Independent German engineering with
            real US parts infrastructure through MEIKO USA in La Vergne, Tennessee. $120 commercial diagnostic,
            waived with repair.
          </p>
          <div class="hero-cta">
            <a href={`tel:${MAIN_PHONE_TEL}`} class="btn btn-primary">Call {MAIN_PHONE}</a>
            <a href="#book" class="btn btn-ghost">Request a Visit</a>
          </div>
          <ul class="hero-facts">
            <li><b>Independent German family since 1927</b> — Oskar Meier + August Koch, Offenburg Germany, still family-run</li>
            <li><b>MEIKO USA parts advantage</b> — US warehouse La Vergne TN, 2–5 day parts vs 5–14 for Winterhalter</li>
            <li><b>LAX airline catering cluster</b> — M-iQ flight-type specialists at Gate Gourmet and peer operators</li>
            <li><b>MEIKO Connect IoT diagnostics</b> — we read cloud-logs before dispatch to narrow the failure</li>
          </ul>
        </div></section>

  <BrandBranchesGrid />

  <section class="trust-bar">
    <div class="wrap">
      <span>Licensed · Insured</span>
      <span>Same-day · 5 SoCal counties</span>
      <span>$120 commercial diagnostic · waived with repair</span>
    </div>
  </section>

  <section class="section">
    <div class="wrap narrow">
      <h2>Meiko — German family-owned since 1927, with a real US presence</h2>
      <p>
        Oskar Meier and August Koch founded Meiko in Offenburg, Germany in 1927 — the company name combines their
        surnames, Meier + Koch = Meiko. Nearly a century later, Meiko is still independent family-owned, operating
        in 30+ countries with 23 subsidiaries and about 2,700 employees worldwide. Not ITW, not Ali Group, not
        Welbilt. Among the German premium commercial dishwasher brands (Meiko, Winterhalter, Miele Professional),
        Meiko is the one that matters most for LA operators primarily because of MEIKO USA.
      </p>
      <p>
        MEIKO USA is the company's direct US subsidiary, headquartered in La Vergne, Tennessee. The phone number is
        1-800-55-MEIKO or (615) 399-6600. Unlike Winterhalter — which has zero direct US service presence — MEIKO
        USA operates a genuine US parts warehouse, an authorized technician network, and warranty service
        infrastructure. That translates to real operational advantages: typical parts lead time 2–5 days from La
        Vergne to LA versus 5–14 days for Winterhalter's European-only parts chain.
      </p>
      <p>
        Our independent-service role at Meiko complements rather than competes with MEIKO USA. For a newer Meiko
        under warranty, MEIKO USA's authorized-provider network handles warranty work directly. For post-warranty
        units, emergency after-hours calls, situations where MEIKO USA's dispatch window doesn't fit the operator's
        service timing, or straightforward out-of-warranty repairs where the La Vergne parts supply is what matters
        most — that's where we fit. Most of our LA Meiko calls are 3+ year old units outside warranty.
      </p>
    </div>
  </section>

  <section class="section alt">
    <div class="wrap">
      <h2>Meiko models we service</h2>
      <div class="model-grid">
        <div class="model-card">
          <h3>M-iClean U — undercounter flagship</h3>
          <p>Standard undercounter dishwasher for the mid-to-upper LA restaurant market. LED handle color indicators
            (blue = ready, green = washing, red = alert) are the distinctive operational feature. Service: door
            gasket, rinse-arm bearing, booster element, fill valve, wash pump rebuild.</p>
        </div>
        <div class="model-card">
          <h3>M-iClean US — compact undercounter</h3>
          <p>315mm clearance — engineered specifically for wheat-beer glasses, tall cocktail stemware, and specialty
            tall glassware. Common in LA craft-beer taprooms and craft-cocktail bars where wheat-beer and highball
            glassware won't clear standard-height undercounter machines.</p>
        </div>
        <div class="model-card">
          <h3>M-iClean UM+ — larger undercounter</h3>
          <p>Higher throughput — 37 racks per hour at 0.61 gallons per rack. The choice for LA mid-volume operations
            where a standard M-iClean U would run continuously but an M-iQ or full-size rack conveyor would be
            over-specified.</p>
        </div>
        <div class="model-card">
          <h3>M-iClean H — hood machine</h3>
          <p>Pass-through hood machine for mid-to-upper LA restaurant back-of-house. Standard rack-handling hood
            dishwasher with Meiko's engineering discipline. Service: hood cylinder, hood switch, rinse booster,
            wash pump rebuild.</p>
        </div>
        <div class="model-card">
          <h3>M-iQ — flight-type</h3>
          <p>Continuous-belt flight-type for high-throughput operations — airline catering (Gate Gourmet LAX),
            hotel banquet prep, cruise-ship commissaries, convention-center kitchens. Meiko's flagship institutional
            machine. Service complexity highest: belt, drive motor, multi-zone spray manifolds, pre-wash and final
            rinse modules.</p>
        </div>
        <div class="model-card">
          <h3>FV 40.2G — glasswasher</h3>
          <p>Dedicated glasswasher for bar environments. Smaller footprint, tuned specifically for glass clarity
            and polish. LA craft cocktail clusters in WeHo, DTLA Arts District, Santa Monica hotel bars. Service:
            dosing-pump chemistry, rinse-aid pickup, drain filter, spray-nozzle scale service.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="wrap narrow">
      <h2>GiO MODULE — integrated reverse osmosis, the Meiko way</h2>
      <p>
        GiO MODULE is Meiko's integrated reverse-osmosis water treatment — engineered into the dishwasher's water
        supply path rather than bolted on as an external RO system. The GiO MODULE produces mineral-free rinse
        water for spot-free glass, crystal, and high-gloss ware-washing. It's the direct competitor to Winterhalter's
        RoMatik XS in the engineering-feature-comparison discussion, and on LA's municipal-water mineral profile,
        both solve the same problem: visible spotting on glassware even with rinse-aid chemistry.
      </p>
      <p>
        Service on GiO MODULE focuses on membrane replacement (typically 18–24 months depending on water-supply
        mineral load), booster-pump seal service, pre-filter cartridge replacement (monthly to quarterly), and
        occasional controller-board service if the RO-monitoring electronics drift. We carry common GiO parts
        through MEIKO USA's La Vergne parts supply — 2-to-5-day typical lead time to LA on specialty RO components.
      </p>
    </div>
  </section>

  <section class="section alt">
    <div class="wrap narrow">
      <h2>Blue Touch — Meiko's maintenance-training concept</h2>
      <p>
        Blue Touch is a Meiko-specific design concept: every component on the machine is marked either blue
        (safe to touch, clean, or service by kitchen staff without technical training) or in a standard non-blue
        coloring (technician-only). The goal is to separate daily staff maintenance — filter cleaning, spray-arm
        inspection, gasket visual checks — from technician-required service. Kitchen staff who learn the Blue Touch
        components can run better daily-closing routines without fear of damaging something that requires technical
        training.
      </p>
      <p>
        We point out the Blue Touch components during every Meiko service call. Operators who integrate Blue Touch
        maintenance into closing checklists — typically a 5-minute add to the standard closing routine — see
        measurable improvement in dishwasher lifespan and reduction in emergency service calls. It's the best
        operator-education feature of any commercial dishwasher brand we service, and we encourage using it.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="wrap narrow">
      <h2>LAX airline catering — the M-iQ flight-type cluster</h2>
      <p>
        LAX hosts one of the largest airline catering operations in the western US. Gate Gourmet, LSG Sky Chefs,
        Flying Food Group, and other flight-catering operators prepare in-flight meals for carriers flying out of
        LAX — millions of meals per year flow through airline-catering kitchens adjacent to the airport. Meiko
        M-iQ flight-type dishwashers are the industry standard in this segment because the continuous-belt
        throughput required for airline catering exceeds what any door machine or rack conveyor can deliver.
      </p>
      <p>
        Our role at LAX airline catering is emergency and out-of-warranty coverage. Scheduled preventive maintenance
        on M-iQ machines is typically contractual with MEIKO USA for these accounts because the service discipline
        and parts stocking requirements are operationally integrated into the flight-catering business model. When
        an M-iQ belt jams during a peak production window and MEIKO USA's dispatch isn't available in the needed
        timeframe, we're the backup service.
      </p>
      <p>
        Beyond airline catering, M-iQ also shows up at hotel banquet prep for operations running 500+ cover banquet
        events (the LA Convention Center's peer hotel properties, some stadium-adjacent venue kitchens) and at
        institutional food service operations where the M-iQ throughput profile matches the operational scale.
      </p>
    </div>
  </section>

  <section class="section alt">
    <div class="wrap narrow">
      <h2>MEIKO Connect — IoT diagnostics that shorten service calls</h2>
      <p>
        MEIKO Connect is Meiko's cloud-based IoT platform. Newer Meiko commercial dishwashers stream operational
        telemetry — cycle counts, wash and rinse temperatures, chemistry-dosing events, error-code history, any
        alert patterns — to a cloud platform that operators access via app or web portal. The platform also sends
        proactive-maintenance alerts when cycle counts hit manufacturer-recommended thresholds for specific service
        items (descaling, pump inspection, booster-element check).
      </p>
      <p>
        For our service calls, MEIKO Connect is a diagnostic pre-check. When an operator opens Connect portal
        access for us before dispatch, we review the last weeks of operational logs and usually narrow the failure
        before the tech arrives. A Meiko showing repeated RINSE TEMP alarms in the log is telling us the booster
        element is degrading; a Meiko showing DOOR OPEN events 20 times in a day is telling us the door switch is
        failing. Diagnosis-before-dispatch shortens both the service call duration and the parts-run decision —
        often we already have the likely part on the truck before leaving the shop.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="wrap narrow">
      <h2>What Meiko commercial dishwasher repair costs in LA</h2>
      <p>$120 flat commercial diagnostic, waived with repair. Typical Meiko service ranges:</p>
      <table class="price-table">
        <thead><tr><th>Repair</th><th>Typical range (parts + labor)</th></tr></thead>
        <tbody>
          <tr><td>Door gasket replacement</td><td>$180–$320</td></tr>
          <tr><td>Door switch / microswitch</td><td>$160–$260</td></tr>
          <tr><td>Fill valve</td><td>$220–$380</td></tr>
          <tr><td>Thermostat replacement</td><td>$200–$340</td></tr>
          <tr><td>Rinse-arm bearing</td><td>$200–$360</td></tr>
          <tr><td>Detergent dosing pump</td><td>$220–$380</td></tr>
          <tr><td>Drain pump replacement</td><td>$300–$480</td></tr>
          <tr><td>Booster heating element</td><td>$360–$580</td></tr>
          <tr><td>Wash pump seal kit</td><td>$380–$620</td></tr>
          <tr><td>ComfortAir heat-recovery module</td><td>$400–$700</td></tr>
          <tr><td>GiO MODULE RO service</td><td>$450–$800</td></tr>
          <tr><td>Wash pump rebuild</td><td>$500–$820</td></tr>
          <tr><td>Control board replacement</td><td>$750–$1,350</td></tr>
          <tr><td>M-iQ flight service (scheduled or emergency)</td><td>$800–$1,800</td></tr>
        </tbody>
      </table>
      <p class="small">
        Most Meiko undercounter and door calls land $380–$800 parts-and-labor. Meiko typically runs comparable to
        Winterhalter pricing on specialty parts but with shorter lead times (2–5 days via MEIKO USA La Vergne vs
        5–14 days for Winterhalter's European supply). Full cross-brand context in our <a href="/price-list/commercial-dishwasher-repair-cost/">commercial
        dishwasher repair pricing guide</a>.
      </p>
    </div>
  </section>

  <section class="section alt">
    <div class="wrap narrow">
      <h2>Related Meiko and German-premium peer pages</h2>
      <ul class="related-links">
        <li><a href="/brands/winterhalter-dishwasher-repair/">Winterhalter commercial dishwasher repair Los Angeles</a> — German premium peer, no US direct service</li>
        <li><a href="/brands/miele-professional-dishwasher-repair/">Miele Professional commercial dishwasher repair Los Angeles</a> — German premium peer, dental/medical/lab focus</li>
        <li><a href="/brands/electrolux-professional-dishwasher-repair/">Electrolux Professional commercial dishwasher repair Los Angeles</a> — European premium peer, LA institutional cluster</li>
        <li><a href="/brands/hobart-dishwasher-repair/">Hobart commercial dishwasher repair Los Angeles</a> — ITW American premium-tier competitor</li>
        <li><a href="/commercial/dishwasher-repair/">All commercial dishwasher repair in Los Angeles →</a></li>
        <li><a href="/price-list/commercial-dishwasher-repair-cost/">Commercial dishwasher repair cost guide →</a></li>
      </ul>
    </div>
  </section>

  <section class="section">
    <div class="wrap narrow">
      <h2>Meiko dishwasher repair — frequently asked</h2>
      {faqs.map(f => (
        <details class="faq">
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
  </section>

  <section id="book" class="cta-bottom">
    <div class="wrap">
      <h2>Meiko dishwasher down? Call the branch nearest your kitchen.</h2>
      <p>Same-day in LA, Orange County, Ventura, San Bernardino, and Riverside. $120 commercial diagnostic, waived with repair.</p>
    </div>
  </section>

  <a href={`tel:${MAIN_PHONE_TEL}`} class="float-call" aria-label="Call now">☎ Call {MAIN_PHONE}</a>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  body { color: var(--text); }
  .wrap { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  .wrap.narrow { max-width: 820px; }
  h1 { font-size: 2.4rem; line-height: 1.15; margin: 12px 0 20px; color: var(--black); }
  h2 { font-size: 1.8rem; margin: 0 0 16px; color: var(--black); }
  h3 { font-size: 1.2rem; margin: 0 0 10px; color: var(--black); }
  p { line-height: 1.65; margin: 0 0 14px; }
  .call-banner { background: var(--red); color: #fff; padding: 10px 0; }
  .call-banner .wrap { display:flex; gap: 14px; align-items: center; justify-content: center; flex-wrap: wrap; }
  .call-banner .phone-lg { color:#fff; font-weight: 800; text-decoration: underline; font-size: 1.05rem; }
  .hero { background: var(--black); color: #fff; padding: 42px 0 56px; }
  .hero h1 { color: #fff; }
  .hero .lede { font-size: 1.06rem; color: #d7d7d7; max-width: 680px; }
  .hero .crumb { color: #9a9a9a; font-size: 0.85rem; margin-bottom: 6px; }
  .hero .crumb a { color: #c9c9c9; text-decoration: none; }
  .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; margin: 18px 0 24px; }
  .btn { display: inline-block; padding: 12px 20px; border-radius: 4px; text-decoration: none; font-weight: 700; }
  .btn-primary { background: var(--red); color: #fff; }
  .btn-ghost { background: transparent; color: #fff; border: 1px solid #fff; }
  .hero-facts { list-style: none; padding: 0; margin: 0; color: #c9c9c9; font-size: 0.95rem; }
  .hero-facts li { padding: 6px 0; border-top: 1px solid #222; }
  .hero-facts li:first-child { border-top: 0; }
  .trust-bar { background: var(--red); color: #fff; padding: 14px 0; }
  .trust-bar .wrap { display: flex; gap: 28px; flex-wrap: wrap; justify-content: center; font-size: 0.95rem; font-weight: 600; }
  .section { padding: 56px 0; }
  .section.alt { background: var(--gray); }
  .model-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 20px; margin-top: 24px; }
  .model-card { background: #fff; border: 1px solid var(--border); padding: 20px; border-radius: 6px; }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 14px; background: #fff; }
  .price-table th, .price-table td { text-align: left; padding: 11px 12px; border-bottom: 1px solid var(--border); }
  .price-table th { background: var(--black); color: #fff; font-weight: 700; font-size: 0.95rem; }
  .small { color: var(--muted); font-size: 0.92rem; margin-top: 12px; }
  .related-links { list-style: none; padding: 0; }
  .related-links li { padding: 10px 0; border-bottom: 1px solid var(--border); }
  .related-links a { color: var(--red); font-weight: 600; text-decoration: none; }
  .related-links a:hover { text-decoration: underline; }
  .faq { background: #fff; border: 1px solid var(--border); padding: 12px 16px; margin-bottom: 8px; border-radius: 4px; }
  .faq summary { font-weight: 700; cursor: pointer; padding: 4px 0; }
  .faq p { margin: 8px 0 0; }
  .cta-bottom { background: var(--black); color: #fff; padding: 48px 0; }
  .cta-bottom h2 { color: #fff; }
