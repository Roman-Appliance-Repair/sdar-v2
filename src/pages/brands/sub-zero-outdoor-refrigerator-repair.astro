---
import Layout from '../../layouts/Layout.astro';
import { MAIN_PHONE, MAIN_PHONE_TEL } from '../../data/branches';

const title = "Sub-Zero Outdoor Refrigerator Repair | Southern California | UC-24RO · IT-24CIIDRH";
const description = "Sub-Zero outdoor refrigerator repair Southern California, UC-series outdoor undercounter, IT-series integrated outdoor drawers. UL-rated outdoor refrigeration. $89 diagnostic. (424) 325-0520.";
const canonical = "https://samedayappliance.repair/brands/sub-zero-outdoor-refrigerator-repair/";

const faqs = [
  {
    "q": "How is the Sub-Zero UC-24RO different from a regular UC-24?",
    "a": "UC-24RO is UL-listed for outdoor use with weather-rated compressor seals, anti-corrosion coatings, and outdoor-rated electrical. The indoor UC-24 voids warranty in outdoor installations and typically fails by year 3."
  },
  {
    "q": "Coastal Malibu install, what should I expect for service intervals?",
    "a": "Salt air accelerates compressor seal and gasket aging. Annual condenser cleaning + every-3-year gasket inspection extends life from 7 years to 12+. Common service: $200–$400 annually."
  },
  {
    "q": "Can Sub-Zero outdoor refrigerator be repaired at 10+ years?",
    "a": "Yes, most failures are componentry (compressor relay, fan motor, control board) which we replace economically. Total replacement cost on a Sub-Zero outdoor unit is $7,000–$12,000; repair pencils out through year 15 in most cases."
  }
];

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": "https://samedayappliance.repair/brands/sub-zero-outdoor-refrigerator-repair/#business",
    "name": "Same Day Appliance Repair",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": "https://samedayappliance.repair/brands/sub-zero-outdoor-refrigerator-repair/",
    "telephone": MAIN_PHONE_TEL,
    "priceRange": "$$$",
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Sub-Zero Outdoor Refrigerator Repair",
    "provider": {
      "@id": "https://samedayappliance.repair/brands/sub-zero-outdoor-refrigerator-repair/#business"
    },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "description": "Sub-Zero outdoor refrigerator repair LA, UC-series outdoor undercounter, IT-series integrated outdoor drawers. UL-rated outdoor refrigeration. $89 diagnostic. (424) 325-0520.",
    "offers": {
      "@type": "Offer",
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "89.00",
        "priceCurrency": "USD",
        "description": "Residential diagnostic fee, waived with repair"
      }
    }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://samedayappliance.repair/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Brands",
      "item": "https://samedayappliance.repair/brands/"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "Sub-Zero",
      "item": "https://samedayappliance.repair/brands/sub-zero/"
    },
    {
      "@type": "ListItem",
      "position": 4,
      "name": "Outdoor Refrigerator Repair",
      "item": "https://samedayappliance.repair/brands/sub-zero-outdoor-refrigerator-repair/"
    }
  ] }
];
---
<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">
    {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
  </Fragment>

  <section class="ph-hero">
    <div class="ph-wrap">
      <p class="ph-eyebrow">Placeholder · Content Coming Soon</p>
      <h1>Sub-Zero Outdoor Refrigerator Repair</h1>
      <p class="ph-intro">Sub-Zero outdoor refrigeration covers the highest tier of LA outdoor kitchens, UC-24RO outdoor undercounter, IT-24CI integrated outdoor refrigerator drawers, and outdoor wine storage variants. UL-listed for outdoor installation with sealed stainless cabinetry and weather-rated compressors. Bel Air, Pacific Palisades, Malibu installs predominate. We service compressor circuits, evaporator fans, door seals (which fail faster on coastal installs), and control boards.</p>
      <div class="ph-ctas">
        <a href="tel:+14243250520" class="ph-btn">Call (424) 325-0520</a>
        <a href="/contact/" class="ph-btn ph-btn-ghost">Contact Us</a>
      </div>
    </div>
  </section>

  <section class="ph-faq">
    <div class="ph-wrap">
      <h2>Frequently Asked</h2>
      {faqs.map(f => (<details class="ph-detail"><summary>{f.q}</summary><p>{f.a}</p></details>))}
    </div>
  </section>
</Layout>

<style>
  .ph-wrap { max-width: 820px; margin: 0 auto; padding: 0 24px; }
  .ph-hero { background: #0a0a0a; color: #fff; padding: 64px 0; }
  .ph-eyebrow { color: #C8102E; font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; margin: 0 0 14px; }
  .ph-hero h1 { font-size: clamp(1.6rem, 3.2vw, 2.4rem); font-weight: 800; margin: 0 0 16px; line-height: 1.2; }
  .ph-intro { color: rgba(255,255,255,0.85); font-size: 1.05rem; margin: 0 0 28px; line-height: 1.65; }
  .ph-ctas { display: flex; gap: 12px; flex-wrap: wrap; }
  .ph-btn { display: inline-block; background: #C8102E; color: #fff; padding: 12px 24px; text-decoration: none; font-weight: 700; border-radius: 4px; font-size: 0.95rem; }
  .ph-btn-ghost { background: transparent; border: 1px solid rgba(255,255,255,0.4); }
  .ph-faq { padding: 56px 0; background: #f5f5f5; }
  .ph-faq h2 { font-size: 1.5rem; margin: 0 0 20px; color: #0a0a0a; }
  .ph-detail { background: #fff; border: 1px solid #e2e2e2; padding: 14px 18px; border-radius: 4px; margin-bottom: 8px; }
  .ph-detail summary { font-weight: 600; cursor: pointer; color: #0a0a0a; }
  .ph-detail p { margin: 10px 0 0; color: #444; line-height: 1.6; }
</style>
