          <tr><td>Preventive maintenance visit</td><td>$145 flat</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- ── SERVICE AREAS ── -->
  <section class="section section-alt">
    <div class="container">
      <p class="eyebrow-sub">Where we go</p>
      <h2>Service areas for Viking cooktop repair</h2>
      <BrandBranchesGrid showHeader={false} />
    </div>
  </section>

  <!-- ── RELATED ── -->
  <section class="section">
    <div class="container">
      <p class="eyebrow-sub">Related Viking services</p>
      <h2>Other Viking categories we service</h2>
      <div class="cat-grid">
        <a href="/brands/viking/" class="cat-card">
          <h3>Viking Appliance Repair</h3>
          <p>Hub page — all Viking categories across Southern California including refrigerator, range, grill, oven.</p>
          <span class="cat-cta">View hub →</span>
        </a>
        <a href="/brands/viking-range-repair/" class="cat-card">
