---
// Phase 2 Cluster 2 #1 — EuroCave wine cellar pillar.
// Brand: French luxury wine cellar systems, founded 1976. Premium tier
// Compact / Comfort / Pure / Royale / Inspiration / Origine families.
// Built-in and freestanding cabinets, hand-finished beechwood sliding
// shelves, premium glass doors. LA luxury cellar context (Bel Air,
// Beverly Hills, Malibu, Pacific Palisades).
// Residential pricing ($89 diagnostic). NEW schema pattern.

import Layout from '../../layouts/Layout.astro';
import ServiceHero from '../../components/ServiceHero.astro';
import { mergeCredentials } from '../../data/credentials-schema';

const phone = '(323) 870-4790';
const phoneRaw = phone.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/brands/eurocave/";

const title = "EuroCave Wine Cellar Repair LA — Same Day";
const description = "EuroCave wine cellar repair across LA, OC, Ventura. Compact, Comfort, Pure, Royale, Inspiration, Origine families. French luxury since 1976. EPA 608, $89 dx.";

const faqs = [
  {
    q: "Do you offer same-day EuroCave service in LA?",
    a: "Yes for diagnostic and most common repairs. EuroCave units are precise temperature-and-humidity systems holding bottles that often represent significant value, so we treat these calls as priority dispatch. Most calls received before 2 PM get a tech on-site the same business day. The honest caveat is parts: some EuroCave components are sourced from the manufacturer's European distribution network and may require ordering rather than coming off the truck. We confirm parts availability during the diagnostic and tell you the realistic timeline before you commit to the repair — never schedule labor that's blocked on a parts wait we didn't disclose."
  },
  {
    q: "Are EuroCave OEM parts always available, or are some hard to source?",
    a: "Common wear parts — door gaskets, fan motors, basic control components — are available either through US distribution or directly from EuroCave authorized parts channels with reasonable lead times (1-7 business days for most). Less common items — specific compressor variants, older generation control boards, model-specific evaporator components, premium beechwood shelving for the higher-end families — can run 2-4 weeks if they need to ship from the European manufacturing facility. We confirm availability before scheduling labor, and we never substitute aftermarket components on a unit at this tier — the build quality EuroCave invests in is exactly what we'd undermine with bargain parts."
  },
  {
    q: "Can you service custom-built cellar installations where the EuroCave is integrated into millwork?",
    a: "Yes, this is most of the EuroCave service work we do in LA. Custom cellar rooms with EuroCave units integrated into cabinetry, recessed installations, split-system architectural integrations — these are the standard configuration in Bel Air, Beverly Hills, Pacific Palisades, and Malibu cellar builds. We come prepared for tight access conditions, work with cellar designers and contractors when needed, and never force-pull a unit when extraction risks damage to the surrounding millwork. Our diagnostic time runs longer on integrated installs than on freestanding cabinets — we factor that into the realistic service window."
  },
  {
    q: "What's your diagnostic fee for EuroCave?",
    a: "$89 residential diagnostic, waived when you approve the repair. The diagnostic covers a full system assessment — refrigerant charge under EPA 608 protocol, control board diagnostic read, evaporator and condenser airflow check, compressor electrical test, humidity system inspection on units equipped with active humidification, door seal integrity check, and shelf and rail inspection on the higher-end families. We deliver a written quote with parts cost, labor estimate, and realistic timeline before any work or parts orders begin."
  },
  {
    q: "Is a 15+ year old EuroCave still worth repairing, or should I replace?",
    a: "Almost always worth repairing. EuroCave is engineered for service life that runs longer than most premium appliance categories — 15-20 years is typical with annual maintenance, and we regularly see 25+ year units still in the original cellar after parts service. The economics favor repair: a $400-$1,200 service call against a $5,000-$25,000 replacement cost makes the math obvious, and the cellar's wood paneling, shelf system, and architectural integration weren't designed to be removed and replaced every decade. We tell you honestly when a specific unit has reached the point where parts become impractical, but for most well-maintained EuroCave cabinets, that point is much later than owners assume."
  },
  {
    q: "Do you handle the humidification system on EuroCave's higher-end families?",
    a: "Yes. Higher-end EuroCave families (the more premium series in the Inspiration, Royale, and Origine ranges) include active humidification — water reservoirs, pumps, atomizing nozzles, and humidity sensors integrated with the temperature control. Service on these systems requires understanding the specific implementation in your model: water source, drain, filter cycle, and sensor calibration all matter. We carry the common humidifier service parts and source the family-specific items through EuroCave authorized distribution. Annual maintenance on humidified cellars is the highest-ROI service we recommend at this tier — clears scale before it damages atomizers, verifies sensor calibration, and prevents the cellar dryness issues that age corks prematurely."
  }
];

const localBusinessSchema = mergeCredentials({
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  '@id': canonical + '#business',
  name: 'Same Day Appliance Repair — EuroCave Wine Cellar Service',
  url: canonical,
  telephone: phone,
  email: 'support@samedayappliance.repair',
  priceRange: '$$$',
  openingHoursSpecification: [
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'], opens: '08:00', closes: '20:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: 'Sunday', opens: '00:00', closes: '00:00' }
  ],
  areaServed: [
    { '@type': 'AdministrativeArea', name: 'Los Angeles County' },
    { '@type': 'AdministrativeArea', name: 'Orange County' },
    { '@type': 'AdministrativeArea', name: 'Ventura County' },
    { '@type': 'AdministrativeArea', name: 'San Bernardino County' },
    { '@type': 'AdministrativeArea', name: 'Riverside County' }
  ]
});

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': canonical + '#service',
  serviceType: 'EuroCave Wine Cellar Repair',
  name: 'EuroCave Wine Cellar Repair, Same Day Appliance Repair',
  url: canonical,
  description: 'Same-day EuroCave wine cellar repair across Los Angeles, Orange, Ventura, San Bernardino, and Riverside counties. Compact, Comfort, Pure, Royale, Inspiration, and Origine series. Built-in and freestanding cabinets, custom integrated installations, premium glass doors, and beechwood sliding shelf systems. EPA 608 Universal certified (#1346255700410), BHGS #A49573, CSLB C-20 HVAC. $89 residential diagnostic, applied toward repair. EuroCave OEM parts; lead times confirmed before scheduling on items requiring European sourcing.',
  provider: { '@id': canonical + '#business' },
  areaServed: [
    { '@type': 'AdministrativeArea', name: 'Los Angeles County' },
    { '@type': 'AdministrativeArea', name: 'Orange County' },
    { '@type': 'AdministrativeArea', name: 'Ventura County' },
    { '@type': 'AdministrativeArea', name: 'San Bernardino County' },
    { '@type': 'AdministrativeArea', name: 'Riverside County' }
  ],
  brand: { '@type': 'Brand', name: 'EuroCave', sameAs: 'https://www.eurocave.com/' },
  offers: {
    '@type': 'Offer',
    priceSpecification: {
      '@type': 'PriceSpecification',
      price: '89.00',
      priceCurrency: 'USD',
      description: 'Residential diagnostic fee, applied toward repair'
    }
  }
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } }))
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://samedayappliance.repair/' },
    { '@type': 'ListItem', position: 2, name: 'Brands', item: 'https://samedayappliance.repair/brands/' },
    { '@type': 'ListItem', position: 3, name: 'EuroCave', item: canonical }
  ]
};

const schemaJsons = [localBusinessSchema, serviceSchema, faqSchema, breadcrumbSchema];
---

<Layout title={title} description={description} canonical={canonical}>

<Fragment slot="head-scripts">
  {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
</Fragment>

<ServiceHero
  eyebrow="Wine Cellar Cooling · French Luxury · Since 1976"
  title="EuroCave Wine Cellar Repair, Across Southern California"
  subtitle="Compact · Comfort · Pure · Royale · Inspiration · Origine series. French luxury wine cellar systems, premium build, hand-finished beechwood shelving. EPA 608 Universal certified, BHGS #A49573, CSLB C-20 HVAC. $89 residential diagnostic, waived with repair. Realistic parts-lead-time disclosure before scheduling labor."
  heroImageTitle="EuroCave Wine Cellar Repair"
  showBranches={true}
/>

<!-- 01 INTRO -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">01, About this service</p>
    <h2>The French luxury name in serious wine storage, in service across LA</h2>
    <p>
      EuroCave has been in the wine-cellar business since 1976 — a French manufacturer that essentially defined the premium-tier
      wine cabinet category and has held the high-end position through five decades of competition. The cabinets are engineered
      around the same principle as a real wine cave: precise temperature, controlled humidity, vibration isolation, dark
      environment, and shelving designed to keep bottles still and accessible without disturbing neighbors. The premium feel comes
      from real engineering — sealed compressor mounts that minimize vibration transmission, hand-finished beechwood sliding
      shelves on the higher-end families, glass doors with UV filtering, and active humidification on the cabinets where wine
      science actually demands it.
    </p>
    <p>
      LA's high-end home wine cellars run heavily on EuroCave. Bel Air estates, Beverly Hills cellar rooms, Pacific Palisades
      ocean-view homes, Malibu hillside compounds — when a homeowner specs an integrated cellar room into the architecture, the
      cooling system is often EuroCave. We service these regularly, both freestanding cabinets and built-in installations
      integrated into custom millwork. The pricing structure is clear: $89 residential diagnostic, waived with repair, EPA 608
      Universal certified for the refrigerant work, BHGS Registration #A49573 plus CSLB C-20 HVAC, and an honest conversation
      about parts lead time before we schedule labor.
    </p>
  </div>
</section>

<!-- 02 SERIES COVERAGE -->
<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">02, Series and product coverage</p>
    <h2>What we service across the EuroCave lineup</h2>

    <h3>Compact and Comfort families</h3>
    <p>
      The entry points into the EuroCave lineup — single-zone temperature control, modest capacity (typically 100-200 bottles
      depending on the specific model), and the foundation of the brand's reputation for quiet, vibration-isolated operation.
      Common in apartments, condos, and homes where the cellar is one cabinet rather than a custom-built room. Service items
      cluster around the cooling unit (compressor, fan motors, refrigerant work under EPA 608) and door seal integrity over
      time. Parts on these families are generally well-stocked through US authorized distribution.
    </p>

    <h3>Pure and Royale families</h3>
    <p>
      Premium positioning above Comfort with larger capacity, dual-zone temperature control on many configurations, and upgraded
      shelf and door systems. Royale runs higher capacity still, and the build is closer to specification cellar architecture —
      heavier-gauge construction, more sophisticated control systems, premium beechwood sliding shelves with the brand's signature
      hand-finishing on certain models. Service is more involved than Comfort: dual-zone control means two separate temperature
      circuits, the larger cabinet means more refrigerant volume in the system, and the premium shelving requires careful handling
      during access work.
    </p>

    <h3>Inspiration family</h3>
    <p>
      Inspiration is the brand's modern flagship line — contemporary architectural styling intended for kitchen integration and
      open-plan living spaces rather than dedicated cellar rooms. Capacity ranges substantially across the family. The build
      quality matches the higher-end EuroCave standard, but the service approach for Inspiration units installed in kitchen
      cabinetry adds the tight-access challenges of integrated installations. We come prepared for these conditions and work
      carefully with the surrounding millwork.
    </p>

    <h3>Origine family</h3>
    <p>
      EuroCave's purpose-built large-capacity cellar units, often configured for serious collectors with multi-hundred-bottle
      capacity and specific environmental controls (active humidification, vibration damping, multi-zone temperature). These are
      the units that anchor a serious cellar room rather than a kitchen-integrated cabinet. Service runs deeper because the
      systems are more sophisticated — humidification adds water-handling and atomizer service, multi-zone control adds
      independent refrigerant circuits, and the shelf systems often number in the dozens of beechwood rails per cabinet. We
      service these regularly across the LA luxury home market.
    </p>

    <h3>Built-in versus freestanding distinction</h3>
    <p>
      Most EuroCave families come in both freestanding and built-in configurations. The built-in versions are designed for
      integration into custom millwork and require front-venting condenser airflow rather than the standard rear-vent layout of a
      freestanding cabinet. Service approach differs: built-in units need the front grille kept clear of obstruction, and the
      condenser cleaning interval matters more because front-vented airflow accumulates dust faster than rear-vent in typical
      kitchen environments. We check these details on the diagnostic.
    </p>
  </div>
</section>

<!-- 03 COMMON FAILURES -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">03, Common failure patterns</p>
    <h2>What we see most often on EuroCave service calls</h2>
    <ul class="bullet-list">
      <li>
        <strong>Condenser fouling — the LA-specific stress.</strong> EuroCave compressors are commercial-grade and engineered for
        long service life, but they depend on clean condenser airflow to shed heat. LA's dry, dusty environment — combined with
        the warm summer stretches in the Hills neighborhoods — accumulates dust on a condenser faster than coastal European
        operating conditions. About 30-35% of "cellar warming" calls trace to a clogged condenser, no parts needed, just a deep
        clean and re-test.
      </li>
      <li>
        <strong>Door gasket compression set after 10-15 years.</strong> The gaskets on EuroCave cabinets are higher-quality than
        mid-tier wine cooler gaskets, but they still age. After a decade-plus of cycling, the gasket loses elasticity, the seal
        develops gaps along the bottom or hinge side, and warm humid air migrates into the cabinet. Symptom is icing on the
        evaporator from moisture infiltration, plus a cabinet working harder to hold setpoint. Replacement gaskets are available
        for current and most legacy models through EuroCave parts channels.
      </li>
      <li>
        <strong>Humidification system service on the higher-end families.</strong> Active humidification is the differentiator
        on the more premium ranges. The reservoir, pump, atomizing system, and humidity sensor all wear over time. Symptom can
        be cellar dryness (corks aging prematurely), water in unexpected places (atomizer or drain failure), or humidity sensor
        drift (cabinet over-humidifying). Annual maintenance on humidified cellars catches these before they become problems.
      </li>
      <li>
        <strong>Electronic control board fade after 12-15 years.</strong> EuroCave controls are reliable, but capacitors and
        relays don't last forever. Symptom is intermittent display issues, temperature setpoint drift the homeowner can't quite
        reproduce on demand, or cycling that's slightly off-pattern. These calls need careful diagnostic — we don't replace
        control boards on suspicion. We verify the failure with electrical testing and only swap when the diagnostic confirms
        the board, not the sensors or the wiring.
      </li>
      <li>
        <strong>Compressor end-of-life at 15-20 years.</strong> EuroCave compressors run longer than most wine cooler tiers,
        which is one of the reasons the brand justifies its position. We see end-of-life failures starting around year 15 on
        units in tougher LA environments (Hills with heat exposure, units in poorly-ventilated installations) and out to year
        20+ on units in milder operating conditions with annual maintenance. Compressor work is meaningful — refrigerant
        recovery, mechanical replacement, recharge under EPA 608 protocol — but cheaper than replacing a $5,000-$25,000 cabinet
        and easier than dismantling a custom cellar room around it.
      </li>
      <li>
        <strong>Shelf system wear on the higher-end families.</strong> The hand-finished beechwood sliding shelves on the
        premium ranges are beautiful, durable wood products — but the rails and slides do wear with use, especially in cellars
        accessed daily. We carry common rail and slide replacements and source the family-specific items through EuroCave parts.
        This isn't a failure that takes a cellar offline, but it's a service item we handle.
      </li>
    </ul>
  </div>
</section>

<!-- 04 LA CONTEXT -->
<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">04, Where we work most on EuroCave</p>
    <h2>The LA EuroCave footprint our techs know best</h2>
    <p>
      <strong>Bel Air and Beverly Hills cellar rooms.</strong> Custom-built cellar rooms with EuroCave Origine and Royale units
      integrated into the architecture are common in Bel Air estates and Beverly Hills properties. The cellar is often a
      dedicated room off the kitchen or wine-pairing area, with the EuroCave handling temperature, humidity, and vibration
      isolation for collections that can run into the thousands of bottles. Service here is careful work — we coordinate with
      the homeowner's property manager or cellar designer when needed and never force access where there's risk to the
      surrounding millwork.
    </p>
    <p>
      <strong>Pacific Palisades and Malibu coastal homes.</strong> Cellars in coastal homes face an additional environmental
      stressor — the salt-air influence on the condenser side of the system. We see slightly faster condenser fouling in coastal
      installations, plus occasional corrosion on outdoor-adjacent components. Annual maintenance is the right answer for
      coastal cellars; we recommend the cleaning interval more aggressively here.
    </p>
    <p>
      <strong>West Hollywood and Hollywood Hills high-rise condos.</strong> Inspiration-family EuroCave units integrated into
      kitchen cabinetry, common in the higher-end West Hollywood condo developments and the Hollywood Hills luxury apartments.
      Service approach adds the tight-access challenges of integrated installs — we come prepared for limited working space and
      carefully manage the cabinetry around the unit during diagnostic and repair.
    </p>
    <p>
      <strong>Newport Beach and Pacific Coast estates.</strong> Newer luxury home builds in Newport Beach and along the coast
      with dedicated cellar rooms or wine-pairing areas. Similar service profile to the Westside cellars — Origine and Royale
      anchoring serious collections, occasional Inspiration in kitchen integrations.
    </p>
  </div>
</section>

<!-- 05 RECENT REPAIRS -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">05, Recent repairs</p>
    <h2>What this month looked like on EuroCave</h2>
    <div class="repair-cards">
      <div class="repair-card">
        <p class="repair-quote">"Cellar room climbing past 60°F, my Origine unit's been running constantly for two days."</p>
        <p>
          Bel Air home cellar room with an Origine-family unit, install date per the homeowner approximately 2014. The unit
          itself was running fine on inspection — compressor healthy, refrigerant charge good — but the condenser was choked
          with dust and lint from a nearby HVAC return that had been pulling air across the cellar utility space. Deep-cleaned
          the condenser, verified airflow, ran the cabinet pull-down for 90 minutes while the homeowner reorganized the wine
          inventory. Cabinet at 55°F by mid-afternoon. Recommended quarterly condenser cleaning going forward and a small
          modification к the HVAC return airflow direction to keep dust away from the cellar utility space.
        </p>
      </div>
      <div class="repair-card">
        <p class="repair-quote">"Door not sealing, condensation on the glass, my labels are starting to peel."</p>
        <p>
          Beverly Hills home, Comfort-family freestanding cabinet, install year per the homeowner approximately 2013. Diagnostic
          confirmed door gasket compression set — the bottom seal had developed a measurable gap and the upper hinge corner
          showed noticeable compression. Replaced the gasket with an OEM EuroCave part (sourced through US authorized
          distribution, three business days), verified door alignment after replacement, and recommended a wipe-down of the
          interior glass to remove the condensate that had been accumulating during the seal failure period. Total service
          across two visits.
        </p>
      </div>
      <div class="repair-card">
        <p class="repair-quote">"Inspiration unit in the kitchen, display reads error code, cellar warming."</p>
        <p>
          Pacific Palisades home, Inspiration-family integrated kitchen unit, install year approximately 2018. The error code on
          the display pointed at sensor circuit, and electrical testing confirmed a humidity sensor failure (the unit's active
          humidification system was reading 0% and trying to compensate by running the atomizer continuously, which threw a
          fault). Sourced the sensor through EuroCave authorized parts, four business days. Replaced sensor, recalibrated the
          humidification system per the manufacturer service documentation, verified normal cycling for 24 hours before
          considering the call closed. Working closely with the surrounding kitchen cabinetry during access — careful pull and
          reinstall.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- 06 WHY US -->
<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">06, Why us, specifically</p>
    <h2>What makes us a fit for EuroCave service</h2>
    <ul class="bullet-list">
      <li><strong>EPA 608 Universal certification (#1346255700410).</strong> Required by federal law for the refrigerant work EuroCave systems require. We perform refrigerant recovery, charge verification, and recharge legally and document the work for service records.</li>
      <li><strong>BHGS Registration #A49573 and CSLB C-20 HVAC.</strong> California state coverage for appliance repair plus the HVAC scope that occasionally comes up on cellar-room installations tied into the home's broader environmental systems.</li>
      <li><strong>EuroCave OEM parts only.</strong> We do not substitute aftermarket compressors, control boards, or premium shelf-system components on a unit at this tier. Bargain parts undermine the engineering EuroCave invests in, and on an integrated cellar installation, the cost of a second visit to redo aftermarket work easily exceeds the price difference.</li>
      <li><strong>Honest parts lead-time disclosure.</strong> Some EuroCave components require ordering from European distribution. We confirm availability during the diagnostic and tell you the realistic timeline before scheduling labor — never schedule work blocked on a parts wait we didn't disclose.</li>
      <li><strong>Custom cellar installation experience.</strong> Most LA EuroCave service work involves units integrated into custom cellar rooms or kitchen millwork. We come prepared for tight access, work carefully with surrounding architecture, and coordinate with cellar designers and property managers when the installation requires it.</li>
      <li><strong>$89 residential diagnostic, waived with repair.</strong> Transparent flat fee, no surprise drive-time charges within our five-county service area.</li>
      <li><strong>BBB Accredited Business and $1M general liability insured.</strong> COI on request — sometimes required for high-value home insurance carriers' approved-vendor lists.</li>
    </ul>
  </div>
</section>

<!-- 07 FAQ -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">07, Frequently asked questions</p>
    <h2>The questions we get most on EuroCave calls</h2>
    <div class="faq-list">
      {faqs.map(f => (
        <details class="faq-item">
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- 08 CROSS-LINKS -->
<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">08, Other wine cellar cooling we cover</p>
    <h2>EuroCave service in context</h2>
    <p>
      EuroCave sits at the high end of the wine cellar cooling category. The links below cover other premium and mid-tier
      brands we service regularly across LA, plus the parent service hub for wine cooler repair across the full brand range.
    </p>
    <ul class="cross-links">
      <li><a href="/brands/le-cache/">Le Cache wine cabinets</a> — American luxury cabinet specialist</li>
      <li><a href="/brands/whisperkool/">WhisperKool wine cellar cooling</a> — split and self-contained systems</li>
      <li><a href="/brands/cellarpro/">CellarPro wine cellar cooling</a> — California specialist with 10-year service-eligibility cutoff</li>
      <li><a href="/brands/breezaire/">Breezaire wine cellar cooling</a> — through-wall and built-in cooling units</li>
      <li><a href="/services/wine-cooler-repair/">Wine cooler and cellar repair (all brands)</a></li>
    </ul>
  </div>
</section>

<!-- 09 BOTTOM CTA -->
<section class="bottom-cta">
  <div class="container narrow">
    <h2>Same-day EuroCave service across Southern California</h2>
    <p>$89 residential diagnostic, waived with repair. EPA 608 Universal certified, BHGS #A49573, CSLB C-20 HVAC, BBB Accredited.</p>
    <div class="cta-row">
      <a href={phoneHref} class="btn-red">Call {phone}</a>
      <a href="/contact/" class="btn-outline">Request service →</a>
    </div>
  </div>
</section>

</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }

  .section { padding: 64px 24px; }
  .section-gray { background: var(--gray); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .container.narrow { max-width: 820px; margin: 0 auto; }

  .section-number { font-size: 12px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--red); margin: 0 0 12px; }
  h2 { font-size: clamp(22px, 3vw, 32px); font-weight: 700; line-height: 1.2; margin: 0 0 20px; color: var(--text); letter-spacing: -.01em; }
  h3 { font-size: 18px; font-weight: 700; margin: 24px 0 10px; color: var(--text); }
  p { font-size: 16px; line-height: 1.7; color: var(--text); margin: 0 0 14px; }
  strong { font-weight: 700; }
  em { font-style: italic; }
  a { color: var(--red); text-decoration: none; }
  a:hover { text-decoration: underline; }

  .bullet-list { list-style: none; padding: 0; margin: 16px 0; }
  .bullet-list li {
    position: relative;
    padding: 12px 0 12px 22px;
    font-size: 15.5px;
    line-height: 1.65;
    border-bottom: 1px solid var(--border);
  }
  .bullet-list li:last-child { border-bottom: none; }
  .bullet-list li::before {
    content: "▸";
    position: absolute;
    left: 0;
    color: var(--red);
    font-weight: 700;
  }

  .repair-cards { display: grid; gap: 20px; margin-top: 20px; }
  .repair-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 22px 26px; }
  .repair-quote { font-style: italic; color: var(--red); font-weight: 600; margin: 0 0 12px; font-size: 15px; }
  .repair-card p:last-child { margin-bottom: 0; }

  .faq-list { margin-top: 20px; }
  .faq-item { border-bottom: 1px solid var(--border); padding: 16px 0; }
  .faq-item:last-child { border-bottom: none; }
  .faq-item summary {
    cursor: pointer;
    font-weight: 700;
    font-size: 16px;
    color: var(--text);
    padding: 4px 0;
  }
  .faq-item summary:hover { color: var(--red); }
  .faq-item p { margin: 12px 0 4px; font-size: 15.5px; color: var(--text); }

