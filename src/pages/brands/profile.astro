//
// Pillar URL was clear of redirect blocks (no matches in astro.config.mjs
// or public/_redirects). Direct write, no redirect cleanup needed.

import Layout from '../../layouts/Layout.astro';
import ServiceHero from '../../components/ServiceHero.astro';
