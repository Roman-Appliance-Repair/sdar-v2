const faqs = [
  { q: "Is this the same Imperial as the oven repair page?", a: "Yes — same company, different product scope. Imperial Commercial Cooking Equipment (the company) makes both commercial ovens and commercial ranges under the Imperial Range brand. Cluster 07 Commercial Ovens wrote <a href=\"/brands/imperial-oven-repair/\">Imperial oven repair</a> covering the ICV convection, ICB conveyor pizza, and related oven product lines. This cluster 08 Commercial Stove/Range page covers the Imperial Range product line — IR-G restaurant ranges, IHR heavy-duty, ICBR charbroilers, and related range/stove equipment. Cross-reference the two combos when your service needs cover both oven and range equipment at the same Imperial-equipped kitchen." },
  { q: "Who owns Imperial Commercial Cooking Equipment?", a: "Imperial Commercial Cooking Equipment is independent family-owned — headquartered and manufactured in Corona, California since 1957. The company remains independent of the major commercial foodservice consolidators (Ali Group, Middleby, ITW, Welbilt). \"Imperial Range\" is the brand name; \"Imperial Commercial Cooking Equipment\" is the company name. One entity, two names. NOT related to other companies using the Imperial name (Imperial HVAC, Imperial Industries, Imperial Hot Water, etc.)." },
  { q: "Corona CA local manufacturer — what's the LA parts advantage?", a: "Imperial's Corona California manufacturing location delivers a real logistical advantage on parts supply. Corona is roughly 60 miles from downtown LA and 40 miles from our Irvine service area — Imperial parts typically ship to LA in 1–3 business days direct from the Corona factory. That's meaningfully faster than competing value-tier brands' parts chains: 5–10 days for Chinese OEM value-tier (MainStreet via WebstaurantStore, Kratos via Restaurant Depot), and 2–5 days for premium brands shipping from out-of-state (Middleby Winston-Salem NC, Ali Group Winston-Salem NC, ITW Chicago). For LA operators on tight service timelines, Imperial's Corona proximity is a structural repair-turnaround advantage." },
  { q: "What's the California local-manufacturer trio (Imperial + American Range + Montague)?", a: "Three California-manufactured commercial cooking brands with LA-proximity parts advantages: Imperial Range (Corona CA, 60 miles from LA), American Range (Cypress CA, 30-40 miles from LA in Orange County), and Montague (Hayward CA, 360 miles but still California-based). All three ship parts from California factories rather than national out-of-state distribution networks, which translates to 1–3 day parts typical versus 2–5+ days for national-brand equivalents. For LA restaurant operators specifically — especially steakhouse, casual-dining, and specialty-cuisine operations — the California-trio blue-ocean is a real consideration alongside the brand-positioning factors. Plus independence from the major consolidators: Imperial and American Range are independent family-owned; Montague joined Ali Group July 2022 but manufactures in Hayward CA." },
  { q: "What does Imperial Range repair cost in LA?", a: "$120 flat commercial diagnostic, waived with repair. Typical Imperial Range service ranges: thermocouple $180–$320, burner orifice cleaning (per burner) $180–$280, burner ignitor $220–$380, gas valve $260–$440, oven-compartment thermostat $200–$340 (for range-oven combinations), door hinge service $200–$360, IHR heavy-duty burner refurbish $380–$640, ICBR charbroiler grate replacement $260–$440, control board $550–$950. Most Imperial Range calls land $280–$600 parts-and-labor — typically 15–25% below equivalent Vulcan or Garland range repair categories. Corona CA 1–3 day parts lead-time factors in. See our <a href=\"/price-list/commercial-stove-repair-cost/\">commercial stove repair cost guide</a>." }
];

const schema = { "@context": "https://schema.org", "@graph": [
  { "@type": "LocalBusiness", "@id": canonical + "#business", "name": "Same Day Appliance Repair", "image": "https://samedayappliance.repair/images/logo.png", "url": "https://samedayappliance.repair/", "telephone": "(424) 325-0520", "areaServed": [
