      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ], "description": "Imperial commercial range repair across Los Angeles — IR-G restaurant range, IHR heavy-duty, ICV convection, IFS fryers, ICBR charbroilers, IR-12-U-27-S under-counter, ISPA-M saladette. Imperial Commercial Cooking Equipment, Corona California since 1957. Independent family-owned. California local manufacturer — 1-3 day parts advantage for LA." },
  { "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a.replace(/<[^>]+>/g, '') } })) },
  { "@type": "BreadcrumbList", "itemListElement": [ { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" }, { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" }, { "@type": "ListItem", "position": 3, "name": "Imperial Range Repair", "item": canonical } ] }
] };
