---
import Layout from '../../layouts/Layout.astro';
import BrandBranchesGrid from '../../components/BrandBranchesGrid.astro';
import { MAIN_PHONE, MAIN_PHONE_TEL } from '../../data/branches';

const title = "GE Dishwasher Repair | Southern California | Haier-Owned Since 2016";
const description = "GE dishwasher repair across Southern California — GDT / GDF families, Dry Boost, Piranha disposer, SmartHQ Wi-Fi. GE Appliances Louisville KY, Haier-owned. $89 diagnostic. (424) 325-0520.";
const canonical = "https://samedayappliance.repair/brands/ge-dishwasher-repair/";

const faqs = [
  {
    q: "Is GE dishwasher parts supply good given the Haier 2016 acquisition?",
    a: "Yes — and the 2016 Haier acquisition actually improved US parts availability for GE dishwashers substantially. GE Appliances remains headquartered in Louisville, Kentucky and operates independently under Haier ownership; the Louisville distribution center consolidated US parts inventory after 2016, reducing typical lead times for common GE dishwasher service items. For LA service specifically: common parts (drain pump, inlet valve, door gasket, heating element, Piranha disposer assembly) are 2-4 day East Coast shipping typical, occasionally next-day on high-volume items. Control boards and specialty parts are 3-7 days."
  },
  {
    q: "What GE dishwasher models are most common in LA?",
    a: "By volume, GE GDT and GDF families dominate our LA GE dishwasher service. GDT mainstream models (GDT635, GDT645, GDT670, GDT695) are the 24-inch built-in workhorse across mass-market kitchens, rental properties, and apartment complex installs. Features include Dry Boost (heat-assist drying), Piranha hard food disposer, Bottle Jets (tall-items zone), SmartHQ Wi-Fi connectivity. GDF front-control families are similar feature sets with front-panel controls vs. GDT top-control. Mass-market GE dishwasher volume in LA concentrates in San Fernando Valley, South Bay, East LA, Pasadena, and inland-Valley rental-property portfolios."
  },
  {
    q: "What does the Piranha hard food disposer actually do?",
    a: "The Piranha is GE's in-dishwasher food-particle grinder — a small blade mechanism at the drain-sump level that grinds food particles into fine slurry so they flush through the drain hose rather than clogging the filter. Design benefit: less pre-rinsing needed. Service reality: the blade bearing wears at 7-10 years on daily-use households, and the mechanism occasionally jams when hard items (olive pits, small bones, dishwasher-tablet wrappers) get into the sump. Jam-clear often free at diagnostic; bearing replacement $180–$260; full Piranha assembly replacement $240–$340. Our techs always check Piranha function during drain-system service — a compromised Piranha contributes to downstream drain-pump strain and filter-clogging issues."
  },
  {
    q: "GE dishwasher not drying — how is Dry Boost different from other dry systems?",
    a: "Dry Boost is GE's heat-assist drying option (activated as a cycle option rather than standalone system). When enabled, Dry Boost runs the heating element during the dry phase to accelerate moisture evaporation. Failure modes: (1) Dry Boost not selected — user-side fix; (2) heating element failure — element works for wash heat but fails for dry-heat phase; element swap $260–$420; (3) control-board dry-cycle logic fault — $380–$580 board; (4) rinse aid empty — even with Dry Boost, rinse aid is critical for final sheeting-and-drying; $89 diagnostic resolves; (5) tub vent fault — moisture can't escape; $180–$280 vent mechanism service. Our techs verify rinse aid + Dry Boost selection before quoting any parts."
  },
  {
    q: "GE Appliances (Haier-owned) — does warranty service go through Haier or GE?",
    a: "Through GE Appliances, which operates independently from Louisville regardless of the Haier parent ownership. Warranty calls route to GE Appliances customer service (1-800-GE-CARES, ge.com/appliances); they dispatch to factory-authorized service partners across the US. For LA, several authorized service networks cover GE in-warranty work. Out-of-warranty service (most of our GE dishwasher calls) can route through any qualified service operator — we service GE dishwashers directly with GE-parts-channel sourcing and the $89 residential diagnostic. If you're uncertain of warranty status, we check serial-number-based warranty lookup at intake."
  },
  {
    q: "What does GE dishwasher repair cost in LA?",
    a: "Residential diagnostic is $89, waived when you authorize the repair. Common GE bands: drain filter clean $89 (often free at diagnostic); drain pump $220–$340; inlet valve $240–$380; door latch + switch $200–$320; door gasket $220–$360; heating element $260–$420; Piranha jam-clear $89 (often free), bearing $180–$260, full assembly $240–$340; Bottle Jets service $140–$240; SmartHQ Wi-Fi reconfig $89 diagnostic (module swap rare, $180–$280); control board $380–$580; membrane switch $240–$360; circulation pump $420–$620; vent flap mechanism $180–$280. GE parts through Louisville distribution 2-4 day typical common, 3-7 day specialty."
  }
];

const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair — GE Dishwasher Service",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": canonical, "telephone": MAIN_PHONE_TEL, "priceRange": "$$",
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ]
  },
  { "@context": "https://schema.org", "@type": "Service", "serviceType": "GE Dishwasher Repair",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "description": "GE dishwasher repair across Southern California — LA, Orange, Ventura, San Bernardino, Riverside. GDT / GDF mainstream families, Dry Boost heat-assist drying, Piranha hard food disposer, Bottle Jets, SmartHQ Wi-Fi. GE Appliances Louisville KY, Haier-owned since 2016. $89 residential diagnostic waived with repair.",
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, waived with repair" } }
  },
  { "@context": "https://schema.org", "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
  },
  { "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "GE", "item": "https://samedayappliance.repair/brands/ge/" },
      { "@type": "ListItem", "position": 4, "name": "GE Dishwasher Repair", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">
    {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
  </Fragment>

  <div class="call-banner"><div class="wrap"><span>GE dishwasher not cleaning? Same-day service across LA:</span><a href={`tel:${MAIN_PHONE_TEL}`} class="phone-lg">{MAIN_PHONE}</a></div></div>

  <section class="hero"><div class="wrap">
    <div class="crumb"><a href="/">Home</a> › <a href="/brands/">Brands</a> › GE › Dishwasher Repair</div>
    <h1>GE Dishwasher Repair</h1>
    <p class="lede">GE Appliances is the Louisville, Kentucky-based home-appliance manufacturer — one of the foundational US dishwasher brands since mid-20th century. Since June 2016, GE Appliances has been owned by Haier (Chinese home-appliance parent) under a $5.6 billion acquisition that preserved GE branding and Louisville operations. The 2016 consolidation actually improved US parts availability substantially. Our LA techs service the full mainstream GE dishwasher lineup: GDT top-control, GDF front-control, Dry Boost heat-assist drying, Piranha hard food disposer, Bottle Jets, SmartHQ Wi-Fi. Same-day dispatch, $89 residential diagnostic waived with the repair.</p>
    <div class="hero-cta"><a href={`tel:${MAIN_PHONE_TEL}`} class="btn btn-primary">Call {MAIN_PHONE}</a><a href="#book" class="btn btn-ghost">Request a Visit</a></div>
    <ul class="hero-facts">
      <li><b>GE Appliances Haier-owned since 2016</b> — Louisville KY ops, improved 2-4 day parts</li>
      <li><b>Piranha hard food disposer</b> — GE-signature grinder, distinctive service</li>
      <li><b>Dry Boost + Bottle Jets + SmartHQ</b> — current-gen feature stack</li>
      <li><b>$89 residential diagnostic</b> — waived when you authorize the repair</li>
    </ul>
  </div></section>

  <BrandBranchesGrid />

  <section class="trust-bar"><div class="wrap"><span>CSLB #1138898 · Insured</span><span>Same-day in 5 SoCal counties</span><span>Residential diagnostic $89 · waived with repair</span></div></section>

  <section class="section"><div class="wrap narrow">
    <h2>GE across Southern California — mainstream dishwasher workhorse, Louisville-supplied</h2>
    <p>GE Appliances has been one of the defining US residential dishwasher brands since the mid-20th century. The Louisville manufacturing and distribution operation has shipped millions of GE dishwashers into US kitchens, apartments, rental properties, and property-management portfolios. The 2016 Haier acquisition preserved the GE brand, Louisville HQ, and in practical service terms improved US parts availability through Haier's distribution investment.</p>
    <p>Our GE dishwasher service territory spans mass-market and mid-market geographies across all five counties: San Fernando Valley (Sherman Oaks, Van Nuys, Northridge, Woodland Hills, Reseda, Panorama City, Arleta), San Gabriel Valley (Pasadena, Alhambra, Monterey Park, Arcadia), South Bay (Torrance, Long Beach, Redondo Beach, Carson), East LA multifamily, and Westside mid-market (Culver City, Mar Vista, Palms) on the LA side; the central OC mainstream belt (Anaheim, Garden Grove, Santa Ana, Tustin, Fullerton); the Ventura mid-market (Oxnard, Ventura, Simi Valley, Camarillo); and the IE family-housing corridor (Ontario, Rancho Cucamonga, Riverside, Fontana, Murrieta). Property-management rental-portfolio accounts span the broader basin. The Haier-owned GE Appliances parts distribution from Louisville reaches Southern California in 2-4 days typical for common items.</p>
  </div></section>

  <section class="section alt"><div class="wrap">
    <h2>GE dishwasher failures our techs see most often</h2>
    <div class="fail-block"><h3>Piranha disposer jam / bearing wear</h3><p>Hard items (pits, bones, wrapper fragments) jam the Piranha blade. Jam-clear often free at diagnostic. Bearing replacement $180–$260 on 7-10 year units. Full Piranha assembly $240–$340.</p></div>
    <div class="fail-block"><h3>Drain pump + filter service</h3><p>Filter clean often free; drain pump $220–$340 when pump mechanical fault confirmed. Piranha function always checked alongside to ensure upstream debris flow is normal.</p></div>
    <div class="fail-block"><h3>Heating element on Dry Boost models</h3><p>Element swap $260–$420. Dry Boost performance depends on element function; failures often surface first as drying complaints before wash-temp complaints.</p></div>
    <div class="fail-block"><h3>Door latch + switch assembly</h3><p>5-7 year service item. Swap + alignment $200–$320. Often accompanies gasket compression loss ($220–$360 combined service when both due).</p></div>
    <div class="fail-block"><h3>Control board / membrane switch</h3><p>Board swap $380–$580; membrane switch $240–$360. Post-2016 generations are more reliable than earlier GE electronics.</p></div>
    <div class="fail-block"><h3>SmartHQ Wi-Fi reconfiguration</h3><p>Router-side fix typical ($89 diagnostic visit). Actual Wi-Fi module failure rare ($180–$280 swap).</p></div>
  </div></section>

  <section class="section"><div class="wrap">
    <h2>GE dishwasher product lines we service</h2>
    <div class="model-grid">
      <div class="model-card"><h3>GDT top-control (volume)</h3><p>GDT635, GDT645, GDT670, GDT695 families. Top-control with Dry Boost, Piranha, Bottle Jets. Mass-market across our service area.</p></div>
      <div class="model-card"><h3>GDF front-control</h3><p>Similar feature set to GDT with front-panel control interface.</p></div>
      <div class="model-card"><h3>Piranha hard food disposer</h3><p>GE-signature in-dishwasher grinder for food particles. Reduces pre-rinse requirement.</p></div>
      <div class="model-card"><h3>Dry Boost heat-assist</h3><p>Optional cycle enhancement for accelerated drying.</p></div>
      <div class="model-card"><h3>Bottle Jets + specialty zones</h3><p>Tall-items zone with high-pressure jets for bottles, tall cups.</p></div>
      <div class="model-card"><h3>SmartHQ Wi-Fi + fault app</h3><p>GE Appliances' connected-home platform. Fault-code app readout sometimes clearer than panel LED.</p></div>
    </div>
  </div></section>

  <section class="section alt"><div class="wrap narrow">
    <h2>GE tier navigation — which combo page fits your dishwasher</h2>
    <p><b>GE (mainstream)</b> — this page. GDT / GDF. Mass-market.</p>
    <p><b>GE Profile (feature-focused premium)</b> — PDT / PDP families. Separate combo page.</p>
    <p><b>GE Monogram (ultra-luxury)</b> — premium built-in. See <a href="/brands/ge-monogram-refrigerator-repair/">GE Monogram refrigerator repair</a> for tier context.</p>
    <p>Haier also markets Haier-branded compact appliances separately — see <a href="/brands/haier-refrigerator-repair/">Haier refrigerator repair</a>. Fisher &amp; Paykel + DCS are Haier-owned premium brands — see <a href="/brands/fisher-paykel-dishwasher-repair/">F&amp;P dishwasher repair</a>.</p>
  </div></section>

  <section class="section"><div class="wrap">
    <h2>What mainstream GE dishwasher repair typically costs</h2>
    <table class="price-table">
      <tr><th>Service</th><th>Typical Range</th><th>Notes</th></tr>
      <tr><td>Residential diagnostic</td><td>$89</td><td>Waived with repair</td></tr>
      <tr><td>Drain filter clean</td><td>$89</td><td>Often free at diagnostic</td></tr>
      <tr><td>Drain pump replacement</td><td>$220 – $340</td><td>Post-Piranha pump</td></tr>
      <tr><td>Inlet valve</td><td>$240 – $380</td><td>Supply fault</td></tr>
      <tr><td>Door latch + switch</td><td>$200 – $320</td><td>5-7 year wear</td></tr>
      <tr><td>Door gasket</td><td>$220 – $360</td><td>6-8 year service</td></tr>
      <tr><td>Heating element</td><td>$260 – $420</td><td>Dry Boost dependency</td></tr>
      <tr><td>Piranha jam-clear</td><td>$89</td><td>Often free at diagnostic</td></tr>
      <tr><td>Piranha bearing</td><td>$180 – $260</td><td>7-10 year wear</td></tr>
      <tr><td>Piranha full assembly</td><td>$240 – $340</td><td>When blade worn</td></tr>
      <tr><td>Bottle Jets service</td><td>$140 – $240</td><td>Tall-items zone</td></tr>
      <tr><td>Control board</td><td>$380 – $580</td><td>Post-2016 more reliable</td></tr>
      <tr><td>Membrane switch</td><td>$240 – $360</td><td>Panel fault</td></tr>
      <tr><td>SmartHQ Wi-Fi module</td><td>$180 – $280</td><td>Reconfig usually resolves</td></tr>
      <tr><td>Circulation pump</td><td>$420 – $620</td><td>8-plus-year service</td></tr>
    </table>
    <p class="small">Broader reference: <a href="/price-list/dishwasher-repair-cost/">dishwasher repair cost guide</a> · <a href="/price-list/dishwasher-door-spring-repair-cost/">door spring</a>. Related: <a href="/brands/ge-refrigerator-repair/">GE refrigerator repair</a> · <a href="/brands/fisher-paykel-dishwasher-repair/">F&amp;P dishwasher repair (Haier sibling)</a>.</p>
  </div></section>

  <section class="section alt"><div class="wrap">
    <h2>Service areas — where our GE calls come from</h2>
    <div class="area-grid">
      <div><h4>San Fernando Valley</h4><p>Sherman Oaks · Van Nuys · Northridge · Woodland Hills · <a href="/encino/">Encino</a> · Reseda</p></div>
      <div><h4>San Gabriel Valley</h4><p><a href="/pasadena/">Pasadena</a> · Alhambra · Monterey Park · Arcadia</p></div>
      <div><h4>South Bay + Long Beach</h4><p>Torrance · Long Beach · Redondo Beach · Carson</p></div>
      <div><h4>East LA + multifamily</h4><p>Boyle Heights · East Los Angeles · Lincoln Heights · Highland Park</p></div>
      <div><h4>Westside mid-market</h4><p>Culver City · Mar Vista · Palms · <a href="/santa-monica/">Santa Monica</a></p></div>
      <div><h4>Orange County mainstream</h4><p>Anaheim · <a href="/irvine/">Irvine</a> · Garden Grove · Santa Ana · Tustin</p></div>
      <div><h4>Ventura mid-market</h4><p><a href="/thousand-oaks/">Thousand Oaks</a> · Oxnard · Ventura · Simi Valley</p></div>
      <div><h4>Inland Empire family housing</h4><p>Ontario · <a href="/rancho-cucamonga/">Rancho Cucamonga</a> · Riverside · Fontana · Murrieta</p></div>
    </div>
  </div></section>

  <section class="section"><div class="wrap narrow">
    <h2>Related GE and Haier-family pages</h2>
    <ul class="related-links">
      <li><a href="/brands/ge-refrigerator-repair/">GE refrigerator repair →</a></li>
      <li><a href="/brands/fisher-paykel-dishwasher-repair/">F&amp;P dishwasher repair (Haier sibling) →</a></li>
      <li><a href="/brands/haier-refrigerator-repair/">Haier refrigerator repair →</a></li>
      <li><a href="/brands/whirlpool-dishwasher-repair/">Whirlpool dishwasher repair →</a></li>
      <li><a href="/services/dishwasher-repair/">Dishwasher repair (service hub) →</a></li>
      <li><a href="/price-list/dishwasher-repair-cost/">Dishwasher repair cost guide →</a></li>
    </ul>
  </div></section>

  <section class="section alt"><div class="wrap narrow">
    <h2>GE dishwasher repair — frequently asked</h2>
    {faqs.map(f => (<details class="faq"><summary>{f.q}</summary><p set:html={f.a}></p></details>))}
  </div></section>

  <section id="book" class="cta-bottom"><div class="wrap">
    <h2>GE dishwasher down? Call the branch closest to your home.</h2>
    <p>Same-day appliance repair across Los Angeles, Orange, Ventura, San Bernardino, and Riverside counties. Residential diagnostic $89, waived with repair.</p>
  </div></section>
  <a href={`tel:${MAIN_PHONE_TEL}`} class="float-call" aria-label="Call now">☎ Call {MAIN_PHONE}</a>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  body { color: var(--text); } .wrap { max-width: 1200px; margin: 0 auto; padding: 0 24px; } .wrap.narrow { max-width: 820px; }
  h1 { font-size: 2.4rem; line-height: 1.15; margin: 12px 0 20px; color: var(--black); }
  h2 { font-size: 1.8rem; margin: 0 0 16px; color: var(--black); }
  h3 { font-size: 1.2rem; margin: 0 0 10px; color: var(--black); }
  h4 { font-size: 1.02rem; margin: 0 0 6px; color: var(--black); }
  p { line-height: 1.65; margin: 0 0 14px; }
  .call-banner { background: var(--red); color: #fff; padding: 10px 0; }
  .call-banner .wrap { display:flex; gap: 14px; align-items: center; justify-content: center; flex-wrap: wrap; }
  .call-banner .phone-lg { color:#fff; font-weight: 800; text-decoration: underline; font-size: 1.05rem; }
  .hero { background: var(--black); color: #fff; padding: 42px 0 56px; } .hero h1 { color: #fff; }
  .hero .lede { font-size: 1.06rem; color: #d7d7d7; max-width: 680px; }
  .hero .crumb { color: #9a9a9a; font-size: 0.85rem; margin-bottom: 6px; } .hero .crumb a { color: #c9c9c9; text-decoration: none; }
  .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; margin: 18px 0 24px; }
  .btn { display: inline-block; padding: 12px 20px; border-radius: 4px; text-decoration: none; font-weight: 700; }
  .btn-primary { background: var(--red); color: #fff; } .btn-ghost { background: transparent; color: #fff; border: 1px solid #fff; }
  .hero-facts { list-style: none; padding: 0; margin: 0; color: #c9c9c9; font-size: 0.95rem; }
  .hero-facts li { padding: 6px 0; border-top: 1px solid #222; } .hero-facts li:first-child { border-top: 0; }
  .trust-bar { background: var(--red); color: #fff; padding: 14px 0; }
  .trust-bar .wrap { display: flex; gap: 28px; flex-wrap: wrap; justify-content: center; font-size: 0.95rem; font-weight: 600; }
  .section { padding: 56px 0; } .section.alt { background: var(--gray); }
  .model-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 20px; margin-top: 24px; }
  .model-card { background: #fff; border: 1px solid var(--border); padding: 20px; border-radius: 6px; }
  .section.alt .model-card { background: #fff; }
  .fail-block { background: #fff; border-left: 3px solid var(--red); padding: 20px 22px; margin: 16px 0; }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 14px; background: #fff; }
  .price-table th, .price-table td { text-align: left; padding: 11px 12px; border-bottom: 1px solid var(--border); }
  .price-table th { background: var(--black); color: #fff; font-weight: 700; font-size: 0.95rem; }
  .small { color: var(--muted); font-size: 0.92rem; margin-top: 12px; }
  .area-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 18px; }
  .area-grid > div { background: #fff; border: 1px solid var(--border); padding: 16px; border-radius: 6px; }
  .related-links { list-style: none; padding: 0; } .related-links li { padding: 10px 0; border-bottom: 1px solid var(--border); }
  .related-links a { color: var(--red); font-weight: 600; text-decoration: none; } .related-links a:hover { text-decoration: underline; }
  .faq { background: #fff; border: 1px solid var(--border); padding: 12px 16px; margin-bottom: 8px; border-radius: 4px; }
  .faq summary { font-weight: 700; cursor: pointer; padding: 4px 0; } .faq p { margin: 8px 0 0; }
  .cta-bottom { background: var(--black); color: #fff; padding: 48px 0; } .cta-bottom h2 { color: #fff; } .cta-bottom p { color: #c9c9c9; }
  .float-call { position: fixed; bottom: 18px; right: 18px; background: var(--red); color: #fff; padding: 14px 18px; border-radius: 40px; text-decoration: none; font-weight: 700; box-shadow: 0 6px 18px rgba(0,0,0,0.28); z-index: 50; font-size: 0.95rem; }
  @media (max-width: 820px) { h1 { font-size: 1.9rem; } h2 { font-size: 1.45rem; } .float-call { padding: 11px 14px; font-size: 0.88rem; } .trust-bar .wrap { gap: 14px; font-size: 0.85rem; } }
</style>
