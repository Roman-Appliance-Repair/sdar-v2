---
import Layout from '../../layouts/Layout.astro';
import BrandBranchesGrid from '../../components/BrandBranchesGrid.astro';
import { MAIN_PHONE, MAIN_PHONE_TEL } from '../../data/branches';

const title = "Wolf Microwave Repair | Southern California | ICBMO Built-In + Drawer";
const description = "$89 dx waived. Wolf microwave repair SoCal, ICBMO 24\" built-in convection + ICBMODR drawer (Sharp OEM). Sub-Zero Group Madison WI parts.";
const canonical = "https://samedayappliance.repair/brands/wolf-microwave-repair/";

const faqs = [
  {
    q: "Which Wolf microwave do I have, built-in or drawer?",
    a: "Wolf's US residential microwave catalog is small and deliberate: <b>ICBMO24TESTH 24-inch built-in convection microwave</b> (trim-kit integrated into cabinetry, the flagship, doubles as a small convection oven for reheating + small-roast duty), and the <b>ICBMODR / ICBMOTR drawer microwave</b> (under-counter pull-out drawer; Wolf uses the same Sharp OEM chassis that sits under Thermador MD24WSS and Miele EDT-series). Wolf does not sell over-the-range or countertop microwaves. If it's not built into cabinetry or pulled out from below the counter, it's not a Wolf microwave."
  },
  {
    q: "ICBMO24 built-in convection isn't reheating evenly, is it broken?",
    a: "The ICBMO24 is a convection-microwave combi, it has a <b>separate convection heating element + fan</b> in addition to the standard magnetron. When reheat is uneven, the common culprits are: (1) <b>convection element</b> (ohm check 15-25 ohms typical), failed element drops back to magnetron-only; still works, just less even; $160–$280 replacement. (2) <b>Convection fan motor</b>, bearing failure causes airflow dropoff; $220–$380 replacement. (3) <b>Turntable motor</b>, if the tray isn't rotating, cold spots are inevitable regardless of combi mode; $80–$140 part. We check all three before quoting, since combi-mode diagnostics are different from pure-magnetron."
  },
  {
    q: "ICBMODR drawer microwave uses the same chassis as Sharp / Thermador / Miele, why does it cost more?",
    a: "The <b>underlying Sharp drawer chassis</b> is shared across Wolf ICBMODR + Thermador MD24/30WSS + Miele EDT + Sharp SMD2470A, same magnetron, linear actuator, roller guide, door interlocks. What you pay extra for on a Wolf drawer is the <b>Sub-Zero Group front-fascia + premium touch-panel + integration with the Wolf suite + the Sub-Zero Group extended warranty and service network</b>. From a repair-cost standpoint, the shared chassis means our Sharp drawer parts inventory applies directly to Wolf drawer repairs, we usually have the motor and actuator on the truck, not on factory order. See <a href='/brands/sharp-microwave-repair/'>Sharp microwave</a> for the OEM chassis reference."
  },
  {
    q: "Wolf microwave door won't open / drawer won't extend, what's failing?",
    a: "Two different mechanisms depending on model. <b>ICBMO24 built-in (hinged door)</b>: door latch release mechanism fails most often at the 8-12 year mark, $140–$240 to replace. Sometimes a loose hinge lets the latch sit misaligned and simple adjustment ($89 diagnostic only, no part) resolves it. <b>ICBMODR drawer</b>: drawer won't extend = linear actuator motor failure (Sharp OEM), $240–$380 including install. Drawer extends but binds = roller guide rail contamination or bend, often clean + realign ($140–$220, no part). The interlock sensor is the common false-trigger on both mechanisms, we test it before assuming the motor or actuator."
  },
  {
    q: "Wolf microwave died completely, Sub-Zero Group service or third-party?",
    a: "Either works, but your economics differ. <b>Sub-Zero Group factory-authorized service</b> is the right call if you're inside the original warranty (typically 2 years on residential Wolf microwaves), or if you need a Sub-Zero Group service-record for a resale valuation. Our third-party residential service is the right call if you're <b>out of warranty and just want the thing working again</b>, we carry Sub-Zero Group parts via the same distribution network, our diagnostic is $89 waived with repair (vs factory-authorized rates that tend to start higher), and our turnaround is usually same-day vs multi-day factory scheduling. We coordinate with Sub-Zero Group if a factory-warranty issue surfaces mid-call."
  },
  {
    q: "What does Wolf microwave repair cost in LA?",
    a: "Residential diagnostic $89 waived with repair. Typical Wolf bands: <b>ICBMO24 built-in</b> magnetron $260–$420; convection element $160–$280; convection fan motor $220–$380; turntable motor $80–$140; door latch release $140–$240; main control board $360–$560. <b>ICBMODR drawer</b> linear actuator $240–$380; roller-guide cleaning + realign $140–$220; door interlock sensor $120–$200; touch-panel control $340–$520. Sub-Zero Group parts chain via Madison Wisconsin; shared chassis with Thermador / Miele drawers (parts cross-fit advantage)."
  }
];

const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair, Wolf Microwave Service",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": canonical, "telephone": MAIN_PHONE_TEL, "priceRange": "$$$$"
  },
  { "@context": "https://schema.org", "@type": "Service", "serviceType": "Wolf Microwave Repair",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "description": "Wolf microwave repair across Southern California, LA, Orange, Ventura, San Bernardino, Riverside. ICBMO24 built-in convection microwave + ICBMODR/ICBMOTR drawer (Sharp OEM chassis shared with Thermador MD24/30WSS + Miele EDT-series). Sub-Zero Group Madison WI factory parts since 1945; three-brand family Sub-Zero/Wolf/Cove. $89 residential diagnostic waived with repair.",
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, waived with repair" } }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "Wolf", "item": "https://samedayappliance.repair/brands/wolf/" },
      { "@type": "ListItem", "position": 4, "name": "Wolf Microwave Repair", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">{schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}</Fragment>
  <div class="call-banner"><div class="wrap"><span>Wolf microwave service?</span><a href={`tel:${MAIN_PHONE_TEL}`} class="phone-lg">{MAIN_PHONE}</a></div></div>

  <section class="hero"><div class="wrap">
    <div class="crumb"><a href="/">Home</a> › <a href="/brands/">Brands</a> › Wolf › Microwave Repair</div>
    <h1>Wolf Microwave Repair</h1>
    <p class="lede">Wolf (Sub-Zero Group, Madison Wisconsin since 1945) keeps its US microwave catalog deliberately small: the ICBMO24TESTH 24-inch built-in convection microwave (cabinetry-integrated; doubles as a small convection oven) and the ICBMODR / ICBMOTR drawer microwave (Sharp OEM chassis, same one that sits under Thermador MD24/30WSS and Miele EDT-series). No over-the-range, no countertop, Wolf's portfolio is built for cabinetry integration. For LA we see these in Bel Air, Beverly Hills, and Pacific Palisades custom kitchens where the matched Sub-Zero / Wolf / Cove suite is the centerpiece. Same-day dispatch, $89 residential diagnostic waived with the repair.</p>
    <div class="hero-cta"><a href={`tel:${MAIN_PHONE_TEL}`} class="btn btn-primary">Call {MAIN_PHONE}</a><a href="#book" class="btn btn-ghost">Request a Visit</a></div>
    <ul class="hero-facts">
      <li><b>ICBMO24 built-in convection + ICBMODR drawer</b>, two-model lineup</li>
      <li><b>Sub-Zero Group Madison WI since 1945</b>, Wolf / Sub-Zero / Cove siblings</li>
      <li><b>Sharp OEM drawer chassis</b>, cross-fits Thermador + Miele drawer parts</li>
      <li><b>$89 residential diagnostic</b>, waived when you authorize the repair</li>
    </ul>
  </div></section>

  <BrandBranchesGrid />

  <section class="trust-bar"><div class="wrap"><span>BHGS #A49573 · Insured</span><span>Same-day in 5 SoCal counties</span><span>Residential diagnostic $89 · waived with repair</span></div></section>

  <section class="section"><div class="wrap">
    <h2>What Wolf microwave repair typically costs</h2>
    <table class="price-table">
      <tr><th>Service</th><th>Typical Range</th><th>Notes</th></tr>
      <tr><td>Residential diagnostic</td><td>$89</td><td>Waived with repair</td></tr>
      <tr><td>ICBMO24 magnetron</td><td>$260 – $420</td><td>Built-in combi</td></tr>
      <tr><td>Convection element</td><td>$160 – $280</td><td>ICBMO24 combi</td></tr>
      <tr><td>Convection fan motor</td><td>$220 – $380</td><td>Airflow-critical</td></tr>
      <tr><td>ICBMODR linear actuator</td><td>$240 – $380</td><td>Drawer pull-out motor</td></tr>
      <tr><td>Roller guide clean + realign</td><td>$140 – $220</td><td>Often no part</td></tr>
      <tr><td>Door interlock sensor</td><td>$120 – $200</td><td>Common false-trigger</td></tr>
      <tr><td>Door latch release (ICBMO24)</td><td>$140 – $240</td><td>8-12 year service</td></tr>
      <tr><td>Touch-panel control</td><td>$340 – $520</td><td>Sub-Zero Group premium tier</td></tr>
      <tr><td>Main control board (ICBMO24)</td><td>$360 – $560</td><td>Combi-mode logic</td></tr>
    </table>
    <p class="small">Related: <a href="/brands/wolf/">Wolf brand hub</a> · <a href="/brands/wolf-stove-repair/">Wolf range / stove</a> · <a href="/brands/wolf-oven-repair/">Wolf oven</a> · <a href="/brands/wolf-range-hood-repair/">Wolf range hood</a> · <a href="/brands/sharp-microwave-repair/">Sharp (drawer OEM chassis)</a> · <a href="/brands/thermador-microwave-repair/">Thermador microwave (sibling drawer)</a> · <a href="/brands/miele-microwave-repair/">Miele microwave (sibling drawer)</a> · <a href="/services/microwave-repair/">Microwave repair (service hub)</a> · <a href="/price-list/microwave-repair-cost/">Microwave repair cost</a>.</p>
  </div></section>

  <section class="section alt"><div class="wrap narrow">
    <h2>Sub-Zero Group family parts chain</h2>
    <p>Wolf is part of the three-brand Sub-Zero Group under Sub-Zero Inc. (Madison Wisconsin, family-owned, founded 1945): <b>Sub-Zero</b> (refrigeration flagship), <b>Wolf</b> (cooking), and <b>Cove</b> (dishwashers, 2018+ acquisition). For LA service, Wolf microwaves route through the same Sub-Zero Group Madison Wisconsin parts chain that supports Wolf ranges, ovens, range hoods, and BBQ grills. Common parts have strong distributor stock on the West Coast; specialty or serial-matched Sub-Zero Group parts run 1-2 week factory order. The Sharp OEM drawer chassis is the one exception, our own Sharp drawer parts inventory covers most ICBMODR calls without routing through Sub-Zero Group channels.</p>
  </div></section>

  <section class="section"><div class="wrap narrow">
    <h2>Wolf microwave repair, frequently asked</h2>
    {faqs.map(f => (<details class="faq"><summary>{f.q}</summary><p set:html={f.a}></p></details>))}
  </div></section>

  <section id="book" class="cta-bottom"><div class="wrap">
    <h2>Wolf microwave service? Call the branch closest to your home.</h2>
    <p>Same-day appliance repair across Los Angeles, Orange, Ventura, San Bernardino, and Riverside counties. Residential diagnostic $89, waived with repair.</p>
  </div></section>
  <a href={`tel:${MAIN_PHONE_TEL}`} class="float-call" aria-label="Call now">☎ Call {MAIN_PHONE}</a>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  body { color: var(--text); } .wrap { max-width: 1200px; margin: 0 auto; padding: 0 24px; } .wrap.narrow { max-width: 820px; }
  h1 { font-size: 2.4rem; line-height: 1.15; margin: 12px 0 20px; color: var(--black); }
  h2 { font-size: 1.8rem; margin: 0 0 16px; color: var(--black); }
  p { line-height: 1.65; margin: 0 0 14px; }
  .call-banner { background: var(--red); color: #fff; padding: 10px 0; }
  .call-banner .wrap { display:flex; gap: 14px; align-items: center; justify-content: center; flex-wrap: wrap; }
  .call-banner .phone-lg { color:#fff; font-weight: 800; text-decoration: underline; font-size: 1.05rem; }
  .hero { background: var(--black); color: #fff; padding: 42px 0 56px; } .hero h1 { color: #fff; }
  .hero .lede { font-size: 1.06rem; color: #d7d7d7; max-width: 680px; }
  .hero .crumb { color: #9a9a9a; font-size: 0.85rem; margin-bottom: 6px; } .hero .crumb a { color: #c9c9c9; text-decoration: none; }
  .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; margin: 18px 0 24px; }
  .btn { display: inline-block; padding: 12px 20px; border-radius: 4px; text-decoration: none; font-weight: 700; }
  .btn-primary { background: var(--red); color: #fff; } .btn-ghost { background: transparent; color: #fff; border: 1px solid #fff; }
  .hero-facts { list-style: none; padding: 0; margin: 0; color: #c9c9c9; font-size: 0.95rem; }
  .hero-facts li { padding: 6px 0; border-top: 1px solid #222; } .hero-facts li:first-child { border-top: 0; }
  .trust-bar { background: var(--red); color: #fff; padding: 14px 0; }
  .trust-bar .wrap { display: flex; gap: 28px; flex-wrap: wrap; justify-content: center; font-size: 0.95rem; font-weight: 600; }
  .section { padding: 56px 0; } .section.alt { background: var(--gray); }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 14px; background: #fff; }
  .price-table th, .price-table td { text-align: left; padding: 11px 12px; border-bottom: 1px solid var(--border); }
  .price-table th { background: var(--black); color: #fff; font-weight: 700; font-size: 0.95rem; }
  .small { color: var(--muted); font-size: 0.92rem; margin-top: 12px; }
  .faq { background: #fff; border: 1px solid var(--border); padding: 12px 16px; margin-bottom: 8px; border-radius: 4px; }
  .faq summary { font-weight: 700; cursor: pointer; padding: 4px 0; } .faq p { margin: 8px 0 0; }
  .cta-bottom { background: var(--black); color: #fff; padding: 48px 0; } .cta-bottom h2 { color: #fff; } .cta-bottom p { color: #c9c9c9; }
  .float-call { position: fixed; bottom: 18px; right: 18px; background: var(--red); color: #fff; padding: 14px 18px; border-radius: 40px; text-decoration: none; font-weight: 700; box-shadow: 0 6px 18px rgba(0,0,0,0.28); z-index: 50; font-size: 0.95rem; }
  @media (max-width: 820px) { h1 { font-size: 1.9rem; } .float-call { padding: 11px 14px; font-size: 0.88rem; } .trust-bar .wrap { gap: 14px; font-size: 0.85rem; } }
</style>
