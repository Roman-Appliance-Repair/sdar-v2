const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": "https://samedayappliance.repair/brands/cove/#business",
    "name": "Same Day Appliance Repair — Cove Dishwasher Service",
