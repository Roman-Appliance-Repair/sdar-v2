---
import Layout from '../../layouts/Layout.astro';
import BrandDetailPlaceholder from '../../components/BrandDetailPlaceholder.astro';

const title = "LG Washer Repair | Southern California | Same Day Service";
const description = "Expert LG washer repair across Southern California. Same-day appointments, OEM parts, licensed technicians. Call (424) 325-0520.";
