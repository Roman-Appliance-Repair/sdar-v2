---
import Layout from '../../layouts/Layout.astro';
import BrandBranchesGrid from '../../components/BrandBranchesGrid.astro';
import { MAIN_PHONE, MAIN_PHONE_TEL } from '../../data/branches';

const title = "Sharp Appliance Repair | Southern California | Drawer Microwave Pioneer";
const description = "Sharp residential appliance repair across Southern California — drawer-microwave pioneer (SMD/SKS series), Supersteam convection, OEM for Wolf/Thermador/Miele drawers. $89 diagnostic. (424) 325-0520.";
const canonical = "https://samedayappliance.repair/brands/sharp/";

const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair — Sharp Service",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": canonical, "telephone": "+1-424-325-0520", "priceRange": "$$"
  },
  { "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "Sharp", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">{schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}</Fragment>
  <div class="call-banner"><div class="wrap"><span>Sharp service? Same-day across LA:</span><a href={`tel:${MAIN_PHONE_TEL}`} class="phone-lg">{MAIN_PHONE}</a></div></div>

  <section class="hero"><div class="wrap">
    <div class="crumb"><a href="/">Home</a> › <a href="/brands/">Brands</a> › Sharp</div>
    <h1>Sharp Appliance Repair</h1>
    <p class="lede">Sharp Corporation (Osaka, Japan, 1912; Foxconn-majority since 2016) is the inventor of the drawer microwave — the 1999 Sharp Insight Microwave Drawer remains the reference design that Wolf, Thermador, and Miele license for their own drawer-microwave lines. Sharp's current US residential appliance scope is built around the microwave category: SMD and SKS-series drawer models (24 inch + 30 inch), SuperSteam convection-steam countertop combis, Inverter-series NN countertop models, and over-the-range units. In LA we see Sharp drawer microwaves specified into Hollywood Hills, Bel Air, Pacific Palisades, and Manhattan Beach custom kitchens where under-counter ADA-accessible ventilation is the point. Same-day dispatch, $89 residential diagnostic waived with the repair.</p>
    <div class="hero-cta"><a href={`tel:${MAIN_PHONE_TEL}`} class="btn btn-primary">Call {MAIN_PHONE}</a><a href="#book" class="btn btn-ghost">Request a Visit</a></div>
    <ul class="hero-facts">
      <li><b>Sharp Corporation Osaka Japan since 1912</b> — Foxconn-majority 2016+</li>
      <li><b>Invented the drawer microwave 1999</b> — SMD / SKS-series</li>
      <li><b>OEM for Wolf + Thermador + Miele</b> drawer microwaves (licensed chassis)</li>
      <li><b>$89 residential diagnostic</b> — waived when you authorize the repair</li>
    </ul>
  </div></section>

  <BrandBranchesGrid />

  <section class="trust-bar"><div class="wrap"><span>CSLB #1138898 · Insured</span><span>Same-day in 5 SoCal counties</span><span>Residential diagnostic $89 · waived with repair</span></div></section>

  <section class="section"><div class="wrap narrow">
    <h2>Sharp services we cover</h2>
    <p>Our Sharp service scope is the residential microwave category — drawer, countertop (including SuperSteam convection), and over-the-range. The dedicated Sharp microwave combo page walks model lines, the licensing architecture that puts Sharp chassis under Wolf / Thermador / Miele drawer microwaves, and the common failure modes by series. Sharp also sells LED televisions and some small countertop appliances that fall outside appliance-repair scope — we don't service those categories.</p>
    <ul class="related-links">
      <li><a href="/brands/sharp-microwave-repair/">Sharp microwave repair →</a></li>
      <li><a href="/services/microwave-repair/">Microwave repair (service hub) →</a></li>
      <li><a href="/price-list/microwave-repair-cost/">Microwave repair cost guide →</a></li>
    </ul>
  </div></section>

  <section class="section alt"><div class="wrap narrow">
    <h2>Drawer-microwave licensing — a service-side advantage</h2>
    <p>Sharp invented the drawer microwave in 1999 and licenses the chassis to three luxury brands that sell the product under their own nameplates: Wolf (ICBMODR / ICBMOTR series), Thermador (MD24WSS / MD30WSS), and Miele (EDT-series). The underlying motor, magnetron, controller board, linear actuator, and roller guide are shared across all four brand versions; brand-specific firmware + trim + front-panel aesthetic is the only delta. For LA service this means our Sharp drawer parts inventory and drawer-mechanism repair experience applies directly across Wolf, Thermador, and Miele drawers without brand-dedicated parts isolation. See <a href="/brands/wolf-microwave-repair/">Wolf microwave</a> · <a href="/brands/thermador-microwave-repair/">Thermador microwave</a> · <a href="/brands/miele-microwave-repair/">Miele microwave</a> for per-brand drawer coverage.</p>
  </div></section>

  <section id="book" class="cta-bottom"><div class="wrap">
    <h2>Sharp service? Call the branch closest to your home.</h2>
    <p>Same-day appliance repair in Los Angeles, Orange County, Ventura County. Residential diagnostic $89, waived with repair.</p>
  </div></section>
  <a href={`tel:${MAIN_PHONE_TEL}`} class="float-call" aria-label="Call now">☎ Call {MAIN_PHONE}</a>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  body { color: var(--text); } .wrap { max-width: 1200px; margin: 0 auto; padding: 0 24px; } .wrap.narrow { max-width: 820px; }
  h1 { font-size: 2.4rem; line-height: 1.15; margin: 12px 0 20px; color: var(--black); }
  h2 { font-size: 1.8rem; margin: 0 0 16px; color: var(--black); }
  p { line-height: 1.65; margin: 0 0 14px; }
  .call-banner { background: var(--red); color: #fff; padding: 10px 0; }
  .call-banner .wrap { display:flex; gap: 14px; align-items: center; justify-content: center; flex-wrap: wrap; }
  .call-banner .phone-lg { color:#fff; font-weight: 800; text-decoration: underline; font-size: 1.05rem; }
  .hero { background: var(--black); color: #fff; padding: 42px 0 56px; } .hero h1 { color: #fff; }
  .hero .lede { font-size: 1.06rem; color: #d7d7d7; max-width: 680px; }
  .hero .crumb { color: #9a9a9a; font-size: 0.85rem; margin-bottom: 6px; } .hero .crumb a { color: #c9c9c9; text-decoration: none; }
  .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; margin: 18px 0 24px; }
  .btn { display: inline-block; padding: 12px 20px; border-radius: 4px; text-decoration: none; font-weight: 700; }
  .btn-primary { background: var(--red); color: #fff; } .btn-ghost { background: transparent; color: #fff; border: 1px solid #fff; }
  .hero-facts { list-style: none; padding: 0; margin: 0; color: #c9c9c9; font-size: 0.95rem; }
  .hero-facts li { padding: 6px 0; border-top: 1px solid #222; } .hero-facts li:first-child { border-top: 0; }
  .trust-bar { background: var(--red); color: #fff; padding: 14px 0; }
  .trust-bar .wrap { display: flex; gap: 28px; flex-wrap: wrap; justify-content: center; font-size: 0.95rem; font-weight: 600; }
  .section { padding: 56px 0; } .section.alt { background: var(--gray); }
  .related-links { list-style: none; padding: 0; margin: 16px 0 0; }
  .related-links li { padding: 6px 0; }
  .related-links a { color: var(--red); font-weight: 700; text-decoration: none; }
  .cta-bottom { background: var(--black); color: #fff; padding: 48px 0; } .cta-bottom h2 { color: #fff; } .cta-bottom p { color: #c9c9c9; }
  .float-call { position: fixed; bottom: 18px; right: 18px; background: var(--red); color: #fff; padding: 14px 18px; border-radius: 40px; text-decoration: none; font-weight: 700; box-shadow: 0 6px 18px rgba(0,0,0,0.28); z-index: 50; font-size: 0.95rem; }
  @media (max-width: 820px) { h1 { font-size: 1.9rem; } .float-call { padding: 11px 14px; font-size: 0.88rem; } .trust-bar .wrap { gap: 14px; font-size: 0.85rem; } }
</style>
