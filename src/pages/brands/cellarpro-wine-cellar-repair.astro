---
import Layout from '../../layouts/Layout.astro';
import { MAIN_PHONE, MAIN_PHONE_TEL } from '../../data/branches';

const title = "CellarPro Wine Cellar Repair | Southern California | 1800 · 4200 · 8200 VSi · QT + VSi Variants";
const description = "CellarPro wine cellar repair Southern California — 1800/3200/4200/6200/8200 series, QT + VSi variants, split + ducted + self-contained. $89 diagnostic. (424) 325-0520.";
const canonical = "https://samedayappliance.repair/brands/cellarpro-wine-cellar-repair/";

const faqs = [
  {
    "q": "My CellarPro VSi is throwing E1/E2/E3 codes — what now?",
    "a": "E-series codes on VSi panels point to specific sensor or fan-motor faults. We carry the diagnostic flowchart in-truck and can resolve most error-code calls in a single visit."
  },
  {
    "q": "Is CellarPro VSi worth the upgrade over QT?",
    "a": "For 24/7 cellar use, yes — modulating compressor draws less current, runs quieter, and lasts longer. The VSi premium pays back in 5–7 years on energy alone."
  },
  {
    "q": "How much does CellarPro repair cost?",
    "a": "Diagnostic $89. Evaporator fan $320–$460. VSi control board $580–$820. Refrigerant leak service $450–$850. Compressor replacement on 8200 series $1,400–$2,200."
  }
];

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": "https://samedayappliance.repair/brands/cellarpro-wine-cellar-repair/#business",
    "name": "Same Day Appliance Repair",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": "https://samedayappliance.repair/brands/cellarpro-wine-cellar-repair/",
    "telephone": MAIN_PHONE_TEL,
    "priceRange": "$$$",
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "CellarPro Wine Cellar Repair",
    "provider": {
      "@id": "https://samedayappliance.repair/brands/cellarpro-wine-cellar-repair/#business"
    },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "description": "CellarPro wine cellar repair LA — 1800/3200/4200/6200/8200 series, QT + VSi variants, split + ducted + self-contained. $89 diagnostic. (424) 325-0520.",
    "offers": {
      "@type": "Offer",
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "89.00",
        "priceCurrency": "USD",
        "description": "Residential diagnostic fee, waived with repair"
      }
    }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://samedayappliance.repair/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Brands",
      "item": "https://samedayappliance.repair/brands/"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "CellarPro",
      "item": "https://samedayappliance.repair/brands/cellarpro/"
    },
    {
      "@type": "ListItem",
      "position": 4,
      "name": "Wine Cellar Repair",
      "item": "https://samedayappliance.repair/brands/cellarpro-wine-cellar-repair/"
    }
  ] }
];
---
<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">
    {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
  </Fragment>

  <section class="ph-hero">
    <div class="ph-wrap">
      <p class="ph-eyebrow">Placeholder · Content Coming Soon</p>
      <h1>CellarPro Wine Cellar Repair</h1>
      <p class="ph-intro">CellarPro spans the LA cellar size range from 1800-series (small cellars, ~250 bottles) through 8200-series (large ducted installs, ~5000 bottles). Both QT (Quiet) and VSi (Variable Speed Inverter) variants in service. We replace evaporator fan motors (a common 7-10 year item), service VSi control boards, rebuild condensate pump assemblies, and handle refrigerant work across the full CellarPro lineup.</p>
      <div class="ph-ctas">
        <a href="tel:+14243250520" class="ph-btn">Call (424) 325-0520</a>
        <a href="/contact/" class="ph-btn ph-btn-ghost">Contact Us</a>
      </div>
    </div>
  </section>

  <section class="ph-faq">
    <div class="ph-wrap">
      <h2>Frequently Asked</h2>
      {faqs.map(f => (<details class="ph-detail"><summary>{f.q}</summary><p>{f.a}</p></details>))}
    </div>
  </section>
</Layout>

<style>
  .ph-wrap { max-width: 820px; margin: 0 auto; padding: 0 24px; }
  .ph-hero { background: #0a0a0a; color: #fff; padding: 64px 0; }
  .ph-eyebrow { color: #C8102E; font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; margin: 0 0 14px; }
  .ph-hero h1 { font-size: clamp(1.6rem, 3.2vw, 2.4rem); font-weight: 800; margin: 0 0 16px; line-height: 1.2; }
  .ph-intro { color: rgba(255,255,255,0.85); font-size: 1.05rem; margin: 0 0 28px; line-height: 1.65; }
  .ph-ctas { display: flex; gap: 12px; flex-wrap: wrap; }
  .ph-btn { display: inline-block; background: #C8102E; color: #fff; padding: 12px 24px; text-decoration: none; font-weight: 700; border-radius: 4px; font-size: 0.95rem; }
  .ph-btn-ghost { background: transparent; border: 1px solid rgba(255,255,255,0.4); }
  .ph-faq { padding: 56px 0; background: #f5f5f5; }
  .ph-faq h2 { font-size: 1.5rem; margin: 0 0 20px; color: #0a0a0a; }
  .ph-detail { background: #fff; border: 1px solid #e2e2e2; padding: 14px 18px; border-radius: 4px; margin-bottom: 8px; }
  .ph-detail summary { font-weight: 600; cursor: pointer; color: #0a0a0a; }
  .ph-detail p { margin: 10px 0 0; color: #444; line-height: 1.6; }
</style>
