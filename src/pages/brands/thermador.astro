---
import Layout from '../../layouts/Layout.astro';
import BrandBranchesGrid from '../../components/BrandBranchesGrid.astro';
import { MAIN_PHONE, MAIN_PHONE_TEL } from '../../data/branches';

const title = "Thermador Appliance Repair | Southern California | Factory-Trained Technicians | Same Day";
const description = "Thermador repair across SoCal, ranges, wall ovens, cooktops, Freedom Collection refrigeration, Sapphire dishwashers. $89 dx waived.";

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": "https://samedayappliance.repair/brands/thermador/#business",
    "name": "Same Day Appliance Repair, Thermador Service",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": "https://samedayappliance.repair/brands/thermador/",
    "telephone": MAIN_PHONE_TEL,
    "priceRange": "$$$",
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "08:00", "closes": "20:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "00:00", "closes": "00:00" }
      ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Are you Thermador Factory-Certified?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "We're an independent repair service, not a Thermador Factory-Certified contractor. Our technicians are factory-trained on Thermador platforms, Star Burner ignition, Freedom Induction touch systems, Freedom Collection compressor control, and Sapphire wash pump assemblies. If your Thermador is still under warranty, call Thermador at 1-800-735-4328 first. For post-warranty service, we're usually faster and cost less."
        }
      },
      {
        "@type": "Question",
        "name": "Do you stock Thermador parts?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Common wear parts for Thermador ranges, cooktops, and dishwashers are on our trucks, ignition modules, spark electrodes, door gaskets, wash pumps. Freedom Collection refrigeration parts (compressors, control boards, evaporator fans) are ordered same-day from BSH distribution. Most jobs finish in one visit. If a rare part is backordered, we tell you the timeline upfront."
        }
      },
      {
        "@type": "Question",
        "name": "Can you service built-in Thermador refrigerators without damaging cabinetry?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Most Freedom Collection service, compressor replacement, control board, evaporator fan, defrost system, door seal, doesn't require pulling the column out of the millwork. We diagnose through the toe-kick and access panels. When a column does need to come out for a compressor swap, we document the installation and reseat it to the factory alignment spec."
        }
      },
      {
        "@type": "Question",
        "name": "How much does Thermador repair cost?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The diagnostic is $89 and it's waived when you book the repair. Typical job ranges: cooktop ignition module $275–$425, range oven control board $450–$700, Freedom Collection compressor $950–$1,650, Sapphire dishwasher wash pump $385–$525, Masterpiece wall oven door gasket $245–$380. We quote labor and parts before we start."
        }
      },
      {
        "@type": "Question",
        "name": "Does Thermador still make BBQ grills or wall heaters?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. Thermador discontinued outdoor grills and wall heaters in the 1990s. For BBQ grill repair we'd point you to our main page at /services/bbq-grill-repair-los-angeles/. For wall heater service we cover that at /services/wall-heater-repair-los-angeles/. Thermador never made laundry, so for washer/dryer we'd need a different brand."
        }
      }
    ]
  }
];
---
<Layout title={title} description={description}>
  <Fragment slot="head-scripts">
    {schemaJsons.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </Fragment>

  <section class="hero">
    <div class="hero-inner">
      <div class="hero-content">
        <p class="hero-eyebrow">LA · Orange · Ventura · San Bernardino · Riverside Counties</p>
        <h1>Thermador Repair</h1>
        <p class="hero-sub">Factory-trained service for Thermador Pro Grand ranges, Masterpiece and Professional wall ovens, Star Burner cooktops, Freedom Collection refrigeration, and Sapphire dishwashers. Most repairs done the same day. Parts stocked for the common jobs.</p>
        <div class="hero-ctas">
          <a href={`tel:${MAIN_PHONE_TEL}`} class="btn-primary">☎ {MAIN_PHONE}</a>
          <a href="/contact/" class="btn-outline">Book Online</a>
        </div>
      </div>
      <div class="hero-img-wrap">
        <div class="hero-img-placeholder">
          <p>Thermador Repair</p>
          <p>Across Southern California</p>
        </div>
      </div>
    </div>
  </section>

  <div class="trust-bar">
    <div class="trust-bar-inner">
      <div class="trust-item"><span class="trust-icon">🏅</span> BHGS #A49573</div>
      <div class="trust-item"><span class="trust-icon">🛡</span> Fully Insured</div>
      <div class="trust-item"><span class="trust-icon">⚡</span> Same Day Available</div>
      <div class="trust-item"><span class="trust-icon">🔩</span> OEM Parts on Truck</div>
      <div class="trust-item"><span class="trust-icon">💬</span> $89 Diagnostic, Waived With Repair</div>
    </div>
  </div>

  <!-- ── WHY THERMADOR ── -->
  <section class="section">
    <div class="container">
      <p class="eyebrow-sub">About the brand</p>
      <h2>Thermador is a BSH-engineered kitchen system. We treat it that way.</h2>
      <p>Thermador was founded in Los Angeles in 1916 and is now part of BSH Home Appliances, the same German parent company behind Bosch and Gaggenau. What this means in the field is that Thermador service lives on three platforms: Star Burner gas combustion, Freedom Collection modular built-in refrigeration, and the BSH wash-motor architecture shared across Sapphire, Emerald, and Topaz dishwashers. Master those three and you can repair any residential Thermador product built since about 2005.</p>
      <p>Most Thermador owners across our Southern California service area live in Bel Air, Beverly Hills, Holmby Hills, Brentwood, Malibu, and Pacific Palisades on LA's Westside; Newport Beach, Newport Coast, and Irvine in OC; Thousand Oaks, Westlake Village, and the Conejo Valley in Ventura; and the Temecula and Rancho Cucamonga estate corridors in the IE. These are long-ownership kitchens, 15 to 20 years in the same house is normal. That changes what gets called in. We see very few "appliance is completely dead" calls. We see a lot of "the left burner is slow to light," "the oven thermostat reads 15 degrees low," "the Freedom column iced over after a panel swap." These are drift failures, not catastrophic ones, and they need a technician who knows the platform, not someone swapping parts to see what sticks.</p>
      <p>One more thing worth saying clearly: if your Thermador is still inside the 2-year major-parts warranty, call Thermador customer service at 1-800-735-4328 first. They'll dispatch a Factory-Certified contractor at no parts cost to you. We're the right call after the warranty is out, faster response, lower labor rates, same technical grade.</p>
    </div>
  </section>

  <!-- ── CATEGORIES ── -->
  <section class="section section-alt">
    <div class="container">
      <p class="eyebrow-sub">What we repair</p>
      <h2>Thermador categories we service</h2>
      <div class="cat-grid">
        <a href="/brands/thermador-range-repair/" class="cat-card">
          <h3>Thermador Range Repair</h3>
          <p>Pro Grand 36" and 48" dual-fuel and all-gas. Star Burner ignition, oven convection, ExtraLow simmer. Consolidated stove and slide-in range service.</p>
          <span class="cat-cta">View range repair →</span>
        </a>
        <a href="/brands/thermador-oven-repair/" class="cat-card">
          <h3>Thermador Oven Repair</h3>
          <p>Masterpiece and Professional wall ovens, combi-steam, speed ovens, double and triple configurations. Door gaskets, control boards, convection fan motors.</p>
          <span class="cat-cta">View oven repair →</span>
        </a>
        <a href="/brands/thermador-cooktop-repair/" class="cat-card">
          <h3>Thermador Cooktop Repair</h3>
          <p>Star Burner gas, Freedom Induction full-surface, Masterpiece electric glass. Ignition modules, pan detection, touch control glass replacement.</p>
          <span class="cat-cta">View cooktop repair →</span>
        </a>
        <a href="/brands/thermador-refrigerator-repair/" class="cat-card">
          <h3>Thermador Refrigerator Repair</h3>
          <p>Freedom Collection columns T18, T24, T30, T36, T42, T48. Compressors, control boards, ice makers, wine columns. Non-invasive built-in service.</p>
          <span class="cat-cta">View refrigerator repair →</span>
        </a>
        <a href="/brands/thermador-dishwasher-repair/" class="cat-card">
          <h3>Thermador Dishwasher Repair</h3>
          <p>Sapphire (premium), Emerald (mid), Topaz (entry). Star Speed wash, Chef's Tool panel-ready, 38dBA quiet cycles. Wash pumps, control boards, door latches.</p>
          <span class="cat-cta">View dishwasher repair →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ── WHAT WE DON'T DO ── -->
  <section class="section">
    <div class="container narrow">
      <p class="eyebrow-sub">Scope honesty</p>
      <h2>What Thermador doesn't make, and where to go instead</h2>
      <p>A few product lines come up in searches because Thermador made them years ago. We want to be upfront about what we can and can't service on the brand's current platform.</p>
      <ul class="scope-list">
        <li><strong>BBQ and outdoor grills</strong>, Thermador discontinued outdoor cooking in the 1990s. For grill repair see our <a href="/services/bbq-grill-repair/">BBQ grill repair page</a>. We service Viking, Wolf, Hestan, Lynx, Weber, DCS, Fire Magic, and other outdoor brands.</li>
        <li><strong>Wall heaters</strong>, also a 1990s discontinuation. For wall heater and forced-air residential heating see our <a href="/services/">wall heater repair page</a>.</li>
        <li><strong>Washers and dryers</strong>, Thermador never produced residential laundry. If you have a matched Thermador kitchen and are looking for a laundry brand to service, we work on Miele, Bosch, LG, Samsung, Whirlpool, Speed Queen, and Asko.</li>
        <li><strong>Standalone microwaves</strong>, Thermador's microwave function lives inside the MC30WS combi-steam speed oven or the MED30WS speed oven. Both fall under our <a href="/brands/thermador-oven-repair/">oven repair page</a>.</li>
      </ul>
    </div>
  </section>

  <!-- ── BUILT-IN PHILOSOPHY ── -->
  <section class="section section-alt">
    <div class="container narrow">
      <p class="eyebrow-sub">Built-in service</p>
      <h2>Freedom Collection and the cabinetry problem</h2>
      <p>Thermador's Freedom Collection refrigeration system is different from a freestanding appliance. A T36IR all-refrigerator column costs $9,800 before install. A paired T24IW wine column with panel, handle, and trim runs another $6,400. Adjacent are custom walnut or rift white oak millwork panels that were specified, fabricated, and installed by the general contractor during the original build. You can't just pull the column out of the wall like a GE fridge.</p>
      <p>Our service approach: diagnose through the toe-kick and rear access panel wherever possible. Compressor service, evaporator fan replacement, control board swap, defrost thermostat, condenser fan, and ice maker harness work all happen without pulling the column. When a column does need to come out, a leaking refrigerant circuit, a seized compressor, we photograph the millwork before disassembly, label every shim and panel clip, and reseat the column to the factory 1/8" flush spec.</p>
      <p>If your kitchen was done by a named Southern California designer or builder, Beverly Hills, Newport Beach, Westlake Village, or IE-based, we've probably worked alongside their trim carpenter before. We don't damage cabinetry.</p>
    </div>
  </section>

  <!-- ── SERVICE AREAS ── -->
  <section class="section">
    <div class="container">
      <p class="eyebrow-sub">Where we work</p>
      <h2>Thermador service across Southern California</h2>
      <p>Eight service territories cover all five counties, Los Angeles, Orange, Ventura, San Bernardino, and Riverside. Thermador owners are concentrated in the Westside and foothill districts of LA, Newport Coast and Pelican Hill in OC, the Conejo Valley estate corridor in Ventura, and Temecula wine-country in the IE, those neighborhoods get same-day routing when you call before 1 PM.</p>
      <BrandBranchesGrid showHeader={false} />
    </div>
  </section>

  <!-- ── CREDENTIALS ── -->
  <section class="section section-alt">
    <div class="container narrow">
      <p class="eyebrow-sub">Credentials</p>
      <h2>Licensed, insured, background-checked</h2>
      <p>We hold an active  license, covering HVAC scope work. We carry general liability and workers' comp. Every technician on our routes is background-checked, BHGS-registered under <strong>#A49573</strong>, and EPA 608 Universal certified (#1346255700410) plus BHGS #A49573 for refrigerant handling. BBB A+ since 2022.</p>
      <p>See the <a href="/credentials/">full credentials page</a> for license verification links.</p>
    </div>
  </section>

  <!-- ── FAQ ── -->
  <section class="section">
    <div class="container narrow">
      <p class="eyebrow-sub">FAQ</p>
      <h2>Thermador service questions</h2>

      <details class="faq">
        <summary>Are you Thermador Factory-Certified?</summary>
        <p>No, we're independent. Our technicians are factory-trained on the Thermador platforms (Star Burner, Freedom Collection, Freedom Induction, Sapphire), but we're not on the Thermador Factory-Certified contractor list. Practical difference: if your Thermador is still under the 2-year major-parts warranty, call Thermador at 1-800-735-4328, they'll send a Certified contractor at no cost. After the warranty window, we're a better fit: faster response, lower labor rate, same technical depth.</p>
      </details>

      <details class="faq">
        <summary>How fast can you be here?</summary>
        <p>Same-day when you call before 1 PM on a weekday and you're inside one of our branch coverage areas. Weekend appointments available with priority dispatch. For a Freedom Collection refrigerator losing cold, we push routing to today regardless of hour, spoiled food in a $12,000 column is not something to schedule for Tuesday.</p>
      </details>

      <details class="faq">
        <summary>Do you carry Thermador parts?</summary>
        <p>Common wear parts are on our trucks: ignition modules, spark electrodes, door gaskets, convection fan motors, Sapphire wash pumps, latch assemblies, Freedom Induction touch control modules. Less common parts (compressors, main control boards, Freedom Collection evaporators) come next-day from BSH parts distribution. We quote lead time before we start. Straightforward pricing.</p>
      </details>

      <details class="faq">
        <summary>What does Thermador repair typically cost?</summary>
        <p>Diagnostic is $89, waived when you book the repair. Typical repair ranges:</p>
        <ul>
          <li>Cooktop ignition module replacement, $275 to $425</li>
          <li>Range oven thermostat or temperature sensor, $215 to $340</li>
          <li>Range control board, $450 to $700</li>
          <li>Freedom Collection compressor replacement, $950 to $1,650</li>
          <li>Freedom Collection control board, $580 to $920</li>
          <li>Sapphire dishwasher wash pump, $385 to $525</li>
          <li>Wall oven door gasket, $245 to $380</li>
          <li>Freedom Induction touch control glass, $780 to $1,150</li>
        </ul>
        <p>Labor and parts are quoted separately and approved before any work starts.</p>
      </details>

      <details class="faq">
        <summary>Can you repair a Freedom Collection column without pulling it?</summary>
        <p>Yes, for most service. Compressor, control board, evaporator fan, defrost thermostat, condenser fan, ice maker harness, and door gasket work all happen through the toe-kick and access panels. Pulling the column is only required for sealed-system refrigerant work or a seized compressor. When that's necessary we document the millwork before disassembly and reseat to factory flush spec.</p>
      </details>

      <details class="faq">
        <summary>What about Thermador BBQ grills, wall heaters, or laundry?</summary>
        <p>Thermador doesn't make those. Outdoor grills and wall heaters were discontinued in the 1990s, for grill repair see <a href="/services/bbq-grill-repair/">/services/bbq-grill-repair-los-angeles/</a>, for wall heaters see <a href="/services/">/services/wall-heater-repair-los-angeles/</a>. Thermador never made washers or dryers. If you're trying to match a Thermador kitchen with a laundry brand we also service, Miele and Bosch are the closest premium matches.</p>
      </details>
    </div>
  </section>
  <!-- ── ALL CATEGORY LINKS (Wave 40b — pillar-to-category cross-links) ── -->
  <section class="section section-light">
    <div class="container narrow">
      <p class="eyebrow-sub">Every Thermador category we cover</p>
      <h2>All Thermador repair services in one place</h2>
      <ul class="cat-list">
        <li><a href="/brands/thermador-built-in-refrigerator-repair/">Thermador Built In Refrigerator Repair</a></li>
        <li><a href="/brands/thermador-cooktop-repair/">Thermador Cooktop Repair</a></li>
        <li><a href="/brands/thermador-dishwasher-repair/">Thermador Dishwasher Repair</a></li>
        <li><a href="/brands/thermador-ice-maker-repair/">Thermador Ice Maker Repair</a></li>
        <li><a href="/brands/thermador-microwave-repair/">Thermador Microwave Repair</a></li>
        <li><a href="/brands/thermador-oven-repair/">Thermador Oven Repair</a></li>
        <li><a href="/brands/thermador-range-hood-repair/">Thermador Range Hood Repair</a></li>
        <li><a href="/brands/thermador-range-repair/">Thermador Range Repair</a></li>
        <li><a href="/brands/thermador-refrigerator-repair/">Thermador Refrigerator Repair</a></li>
        <li><a href="/brands/thermador-stove-repair/">Thermador Stove Repair</a></li>
        <li><a href="/brands/thermador-wine-cooler-repair/">Thermador Wine Cooler Repair</a></li>
      </ul>
    </div>
  </section>



  <!-- ── BOTTOM CTA ── -->
  <section class="bottom-cta">
    <div class="container">
      <h2>Ready to schedule Thermador service?</h2>
      <p>Same day available. $89 diagnostic, waived with repair. Labor and parts quoted before we start.</p>
      <div class="hero-ctas">
        <a href={`tel:${MAIN_PHONE_TEL}`} class="btn-primary">☎ Call {MAIN_PHONE}</a>
        <a href="/contact/" class="btn-outline">Book Online</a>
      </div>
    </div>
  </section>

<style>
  :root {
    --red: #C8102E;
    --black: #0a0a0a;
    --gray: #f5f5f5;
    --border: #e2e2e2;
    --text: #1a1a1a;
    --muted: #6b6b6b;
    --white: #ffffff;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; color: var(--text); line-height: 1.6; }

  .hero { background: var(--black); color: #fff; padding: 80px 24px 72px; }
  .hero-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; max-width: 1100px; margin: 0 auto; align-items: center; }
  .hero-eyebrow { font-size: 13px; color: var(--red); text-transform: uppercase; letter-spacing: .12em; margin-bottom: 16px; font-weight: 600; }
  .hero h1 { font-size: clamp(28px, 4vw, 46px); font-weight: 700; color: #fff; margin-bottom: 20px; line-height: 1.15; font-family: 'Playfair Display', Georgia, serif; }
  .hero-sub { font-size: 17px; color: rgba(255,255,255,.72); margin-bottom: 28px; }
  .hero-ctas { display: flex; gap: 12px; margin-bottom: 28px; flex-wrap: wrap; }
  .btn-primary { display: inline-block; padding: 14px 28px; background: var(--red); color: #fff; text-decoration: none; border-radius: 6px; font-weight: 600; font-size: 16px; transition: background .2s; }
  .btn-primary:hover { background: #a50d25; }
  .btn-outline { display: inline-block; padding: 14px 28px; border: 1.5px solid rgba(255,255,255,.35); color: #fff; text-decoration: none; border-radius: 6px; font-weight: 600; font-size: 16px; transition: all .2s; }
  .btn-outline:hover { background: rgba(255,255,255,.08); border-color: #fff; }
  .hero-img-wrap { aspect-ratio: 4/3; background: #1a1a1a; border-radius: 4px; display: flex; align-items: center; justify-content: center; }
  .hero-img-placeholder { color: rgba(255,255,255,.35); font-size: 14px; text-align: center; }
  @media (max-width: 768px) { .hero-inner { grid-template-columns: 1fr; } .hero-img-wrap { display: none; } }

  .trust-bar { background: var(--red); color: #fff; padding: 16px 24px; }
  .trust-bar-inner { max-width: 1100px; margin: 0 auto; display: flex; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
  .trust-item { font-size: 13px; font-weight: 600; display: flex; align-items: center; gap: 8px; }
  .trust-icon { font-size: 16px; }

  .section { padding: 72px 24px; }
  .section-alt { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; }
  .container.narrow { max-width: 780px; }
  .eyebrow-sub { font-size: 13px; color: var(--red); text-transform: uppercase; letter-spacing: .12em; margin-bottom: 12px; font-weight: 600; }
  h2 { font-size: clamp(24px, 3vw, 34px); font-weight: 700; margin-bottom: 20px; line-height: 1.2; font-family: 'Playfair Display', Georgia, serif; }
  .section p { margin-bottom: 16px; color: var(--text); }

  .cat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 20px; margin-top: 32px; }
  .cat-card { display: block; padding: 28px; background: #fff; border: 1px solid var(--border); border-radius: 8px; text-decoration: none; color: inherit; transition: all .2s; }
  .cat-card:hover { border-color: var(--red); transform: translateY(-2px); box-shadow: 0 4px 16px rgba(0,0,0,.08); }
  .cat-card h3 { font-size: 18px; font-weight: 700; margin-bottom: 10px; color: var(--black); font-family: 'Playfair Display', Georgia, serif; }
  .cat-card p { font-size: 14px; color: var(--muted); margin-bottom: 16px; }
  .cat-cta { font-size: 13px; color: var(--red); font-weight: 600; }

  .scope-list { margin: 20px 0; padding-left: 20px; }
  .scope-list li { margin-bottom: 12px; color: var(--text); }
  .scope-list a { color: var(--red); text-decoration: underline; }

  .faq { margin-bottom: 12px; border: 1px solid var(--border); border-radius: 6px; padding: 16px 20px; background: #fff; }
  .faq summary { font-weight: 600; cursor: pointer; font-size: 16px; color: var(--black); }
  .faq[open] summary { margin-bottom: 12px; }
  .faq p { font-size: 15px; color: var(--text); margin-bottom: 8px; }
  .faq ul { margin: 12px 0 8px 20px; }
  .faq li { font-size: 14px; color: var(--text); margin-bottom: 4px; }
  .faq a { color: var(--red); }

  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { color: #fff; }
  .bottom-cta p { color: rgba(255,255,255,.72); margin-bottom: 24px; }
  .bottom-cta .hero-ctas { justify-content: center; }
</style>
</Layout>
