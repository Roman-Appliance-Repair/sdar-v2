          <tr><td>User interface / touchpad</td><td>$425 – $620</td></tr>
          <tr><td>Oven light bulb &amp; socket</td><td>$85 – $125</td></tr>
          <tr><td>Meat probe receptacle</td><td>$95 – $145</td></tr>
          <tr><td>TruGlide Full Extension Rack (single)</td><td>$165 – $245</td></tr>
          <tr><td>Steam generator descaling (MVSOC)</td><td>$185 flat</td></tr>
          <tr><td>Steam generator element (MVSOC)</td><td>$345 – $485</td></tr>
          <tr><td>Steam oven water inlet valve (MVSOC)</td><td>$245 – $345</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- ── SERVICE AREAS ── -->
  <section class="section section-alt">
    <div class="container">
      <p class="eyebrow-sub">Where we go</p>
      <h2>Service areas for Viking wall oven repair</h2>
      <BrandBranchesGrid showHeader={false} />
    </div>
  </section>

  <!-- ── RELATED ── -->
  <section class="section">
    <div class="container">
      <p class="eyebrow-sub">Related Viking services</p>
      <h2>Other Viking categories we service</h2>
      <div class="cat-grid">
        <a href="/brands/viking/" class="cat-card">
          <h3>Viking Appliance Repair</h3>
          <p>Hub page — all Viking categories in LA including refrigerator, range, grill, cooktop.</p>
          <span class="cat-cta">View hub →</span>
