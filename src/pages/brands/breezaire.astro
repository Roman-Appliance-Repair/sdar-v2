---
import Layout from '../../layouts/Layout.astro';
import { MAIN_PHONE, MAIN_PHONE_TEL } from '../../data/branches';

const title = "Breezaire Wine Cellar Cooling Repair | Southern California | WKCE · WKL Self-Contained";
const description = "Breezaire wine cellar cooling repair SoCal, WKCE + WKL self-contained through-wall units. Compact cellar specialist. $89 dx.";
const canonical = "https://samedayappliance.repair/brands/breezaire/";

const faqs = [
  {
    "q": "What size cellar does a Breezaire fit?",
    "a": "WKCE-series fits cellars up to ~1000 cu ft; WKL-series up to ~2000 cu ft. Above that, a CellarPro 8200 or WhisperKOOL ducted is the right call."
  },
  {
    "q": "My Breezaire is icing up, normal?",
    "a": "No. Coil icing usually means a failed evaporator fan, low refrigerant charge, or thermostat short-cycling. We diagnose; most repairs run $250–$450."
  },
  {
    "q": "How long does a Breezaire last?",
    "a": "Self-contained units in moderate cellars: 8–12 years. The condensate drain is the most-overlooked failure point, annual cleaning prevents 70% of mid-life failures."
  }
];

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": "https://samedayappliance.repair/brands/breezaire/#business",
    "name": "Same Day Appliance Repair",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": "https://samedayappliance.repair/brands/breezaire/",
    "telephone": MAIN_PHONE_TEL,
    "priceRange": "$$$",
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Breezaire Wine Cellar Cooling Repair",
    "provider": {
      "@id": "https://samedayappliance.repair/brands/breezaire/#business"
    },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "description": "Breezaire wine cellar cooling repair LA, WKCE + WKL self-contained through-wall units. Compact cellar specialist. $89 diagnostic. (424) 325-0520.",
    "offers": {
      "@type": "Offer",
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "89.00",
        "priceCurrency": "USD",
        "description": "Residential diagnostic fee, waived with repair"
      }
    }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://samedayappliance.repair/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Brands",
      "item": "https://samedayappliance.repair/brands/"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "Breezaire",
      "item": "https://samedayappliance.repair/brands/breezaire/"
    }
  ] }
];
---
<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">
    {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
  </Fragment>

  <section class="ph-hero">
    <div class="ph-wrap">
      <p class="ph-eyebrow">Placeholder · Content Coming Soon</p>
      <h1>Breezaire Wine Cellar Cooling Repair</h1>
      <p class="ph-intro">Breezaire (Vinotemp brand) is the small-cellar specialist, WKCE through-wall self-contained units for cellars under 1500 cubic feet, and WKL larger self-contained for converted basements and closets. We service evaporator fans, condensate drains, control thermostats, and refrigerant circuits across the full Breezaire lineup. Often paired with budget cellar builds where WhisperKOOL/CellarPro pricing isn’t justified.</p>
      <p class="credential-line" style="color: rgba(255,255,255,0.85); font-size: 0.95rem; margin: 14px 0 0; line-height: 1.6; padding-top: 14px; border-top: 1px solid rgba(255,255,255,0.15);">Licensed in California (BHGS #A49573) and EPA 608 Universal certified (#1346255700410) for sealed-system refrigeration work.</p>
      <div class="ph-ctas">
        <a href="tel:+14243250520" class="ph-btn">Call (424) 325-0520</a>
        <a href="/contact/" class="ph-btn ph-btn-ghost">Contact Us</a>
      </div>
    </div>
  </section>

  <section class="ph-faq">
    <div class="ph-wrap">
      <h2>Frequently Asked</h2>
      {faqs.map(f => (<details class="ph-detail"><summary>{f.q}</summary><p>{f.a}</p></details>))}
    </div>
  </section>
</Layout>

<style>
  .ph-wrap { max-width: 820px; margin: 0 auto; padding: 0 24px; }
  .ph-hero { background: #0a0a0a; color: #fff; padding: 64px 0; }
  .ph-eyebrow { color: #C8102E; font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; margin: 0 0 14px; }
  .ph-hero h1 { font-size: clamp(1.6rem, 3.2vw, 2.4rem); font-weight: 800; margin: 0 0 16px; line-height: 1.2; }
  .ph-intro { color: rgba(255,255,255,0.85); font-size: 1.05rem; margin: 0 0 28px; line-height: 1.65; }
  .ph-ctas { display: flex; gap: 12px; flex-wrap: wrap; }
  .ph-btn { display: inline-block; background: #C8102E; color: #fff; padding: 12px 24px; text-decoration: none; font-weight: 700; border-radius: 4px; font-size: 0.95rem; }
  .ph-btn-ghost { background: transparent; border: 1px solid rgba(255,255,255,0.4); }
  .ph-faq { padding: 56px 0; background: #f5f5f5; }
  .ph-faq h2 { font-size: 1.5rem; margin: 0 0 20px; color: #0a0a0a; }
  .ph-detail { background: #fff; border: 1px solid #e2e2e2; padding: 14px 18px; border-radius: 4px; margin-bottom: 8px; }
  .ph-detail summary { font-weight: 600; cursor: pointer; color: #0a0a0a; }
  .ph-detail p { margin: 10px 0 0; color: #444; line-height: 1.6; }
</style>
