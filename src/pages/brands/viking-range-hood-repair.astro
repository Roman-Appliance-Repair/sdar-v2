---
import Layout from '../../layouts/Layout.astro';
import BrandBranchesGrid from '../../components/BrandBranchesGrid.astro';
import { MAIN_PHONE, MAIN_PHONE_TEL } from '../../data/branches';

const title = "Viking Range Hood Repair | Southern California | VWH Pro Wall + Island";
const description = "Viking range hood repair across Southern California — VWH wall 30-66 inch Pro 7-Series, VIWH island, VBCV insert, VHCV custom liner. Middleby Greenwood MS parts. $89 diagnostic. (424) 325-0520.";
const canonical = "https://samedayappliance.repair/brands/viking-range-hood-repair/";

const faqs = [
  {
    q: "What Viking range hood models are most common in LA?",
    a: "<b>VWH (Viking Wall Hood) Professional 7-Series</b> 30-66 inch dominates LA Viking range hood installs — matched to Viking Professional 7-Series rangetop in Bel Air + Beverly Hills + Pacific Palisades + Malibu luxury kitchens. <b>VIWH (Viking Island Wall Hood)</b> covers 36-54 inch open-plan kitchen-island configurations. <b>VBCV insert + VHCV custom liner</b> handle custom-cabinet integration. 600-1500 CFM tier range; halogen + LED task lighting; 4-speed variable control. Tuscany Collection hoods match Viking Tuscany-package range + commercial-aesthetic kitchens."
  },
  {
    q: "Is Viking the same company as Wolf?",
    a: "No — separate corporate entities. <b>Viking</b> is Middleby Corporation (Greenwood, Mississippi since 1987, Middleby since 2002). <b>Wolf</b> is Sub-Zero Group Inc. (independent, Madison WI). Different factories, different parts chains, different engineering platforms. Viking range hood matches to Viking range (VGR prefix); Wolf range hood matches to Wolf Pro Grand Masterpiece. See <a href='/brands/wolf-range-hood-repair/'>Wolf range hood repair</a> for the competing Sub-Zero Group luxury. Also: Viking Residential ≠ Viking Commercial (separate Middleby commercial foodservice division) — residential VWH is this page's scope."
  },
  {
    q: "Viking range hood motor not running or variable-speed issue — diagnostic?",
    a: "Standard luxury pro-hood diagnostic: (1) variable-speed motor at 8-12 year mark; motor swap $320–$480; (2) control-board capacitor bank $460–$660; (3) halogen transformer $180–$280 / LED driver $180–$280; (4) baffle-filter latch $120–$200; (5) downdraft motor-lift (legacy Viking DD variants) $380–$560 — **Viking DD downdraft was discontinued; parts sourcing 2-4 week legacy-sourcing typical**; (6) external-blower remote wiring $220–$340. Middleby Greenwood MS parts channel 3-5 day typical on common VWH service items."
  },
  {
    q: "Viking vs Wolf vs Thermador — luxury pro-hood comparison in LA?",
    a: "<b>Viking (this page)</b> — Middleby Greenwood MS, VWH wall + VIWH island + Tuscany commercial-aesthetic, ProFlow heritage integration. <b>Wolf</b> — Sub-Zero Group Madison WI, Pro Wall + coordinated Sub-Zero/Wolf/Cove suite. See <a href='/brands/wolf-range-hood-repair/'>Wolf range hood repair</a>. <b>Thermador</b> — BSH Irvine CA 1-2 day parts, HMWB Masterpiece wall + Home Connect WiFi integration. See <a href='/brands/thermador-range-hood-repair/'>Thermador range hood repair</a>. Choice drivers: Viking for Middleby heritage + Tuscany outdoor-kitchen crossover; Wolf for Sub-Zero Group matched-suite; Thermador for BSH + Irvine parts proximity."
  },
  {
    q: "Viking hood vs commercial exhaust hood scope?",
    a: "Viking Residential VWH = residential 600-1500 CFM scope only. Viking Commercial (Middleby commercial foodservice division) is separate product line — not same parts chain, not same service. For commercial restaurant / foodservice kitchen exhaust hood (2000+ CFM Captive-Aire / Halton / Greenheck / Gaylord scope), see <a href='/commercial/exhaust-hood-repair/'>commercial exhaust hood repair</a>. This page covers residential VWH only."
  },
  {
    q: "What does Viking range hood repair cost in LA?",
    a: "Residential diagnostic $89 waived with repair. Typical Viking VWH bands: variable-speed motor $320–$480; control-board $460–$660; halogen transformer / LED driver $180–$280; baffle-filter latch $120–$200; baffle-filter replacement $60–$120 per filter routine; downdraft motor-lift (DD legacy) $380–$560; external-blower remote wiring $220–$340; cooktop-insert specific control $340–$480; light fixture $180–$280. Middleby Greenwood MS parts 3-5 day typical lead."
  }
];

const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair — Viking Range Hood Service",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": canonical, "telephone": MAIN_PHONE_TEL, "priceRange": "$$$$"
  },
  { "@context": "https://schema.org", "@type": "Service", "serviceType": "Viking Range Hood Repair",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "description": "Viking range hood repair across LA — VWH Professional 7-Series wall 30-66 inch, VIWH island, VBCV insert, VHCV custom liner. Middleby Greenwood MS 1987+. $89 residential diagnostic waived with repair.",
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, waived with repair" } }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "Viking", "item": "https://samedayappliance.repair/brands/viking/" },
      { "@type": "ListItem", "position": 4, "name": "Viking Range Hood Repair", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">{schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}</Fragment>
  <div class="call-banner"><div class="wrap"><span>Viking range hood service? Same-day across LA:</span><a href={`tel:${MAIN_PHONE_TEL}`} class="phone-lg">{MAIN_PHONE}</a></div></div>

  <section class="hero"><div class="wrap">
    <div class="crumb"><a href="/">Home</a> › <a href="/brands/">Brands</a> › Viking › Range Hood Repair</div>
    <h1>Viking Range Hood Repair</h1>
    <p class="lede">Viking range hoods (Middleby Corporation, Greenwood Mississippi) anchor the Middleby-family luxury pro-kitchen ventilation in LA custom kitchens. VWH Professional 7-Series wall hood 30-66 inch matched to Viking 7-Series rangetop + VIWH Island wall + VBCV insert + VHCV custom liner cover the Viking luxury-hood lineup. Tuscany Collection adds commercial-aesthetic crossover for Viking outdoor-kitchen luxury. Middleby Greenwood MS parts chain 3-5 day typical. Same-day dispatch, $89 residential diagnostic waived with the repair.</p>
    <div class="hero-cta"><a href={`tel:${MAIN_PHONE_TEL}`} class="btn btn-primary">Call {MAIN_PHONE}</a><a href="#book" class="btn btn-ghost">Request a Visit</a></div>
    <ul class="hero-facts">
      <li><b>Middleby Greenwood MS since 1987</b> — residential division</li>
      <li><b>VWH Professional 7-Series 30-66 inch</b> — luxury pro-hood signature</li>
      <li><b>Tuscany Collection</b> — commercial-aesthetic crossover</li>
      <li><b>$89 residential diagnostic</b> — waived when you authorize the repair</li>
    </ul>
  </div></section>

  <BrandBranchesGrid />

  <section class="trust-bar"><div class="wrap"><span>CSLB #1138898 · Insured</span><span>Same-day in 5 SoCal counties</span><span>Residential diagnostic $89 · waived with repair</span></div></section>

  <section class="section alt"><div class="wrap">
    <h2>Viking range hood failures our techs see most often in LA</h2>
    <div class="fail-block"><h3>Variable-speed motor</h3><p>8-12 year mark. Motor swap $320–$480.</p></div>
    <div class="fail-block"><h3>Control-board capacitor bank</h3><p>Multi-speed unresponsive. Board swap $460–$660.</p></div>
    <div class="fail-block"><h3>Halogen transformer / LED driver</h3><p>$180–$280 depending on era.</p></div>
    <div class="fail-block"><h3>Baffle-filter latch + interlock</h3><p>$120–$200.</p></div>
    <div class="fail-block"><h3>Downdraft motor-lift (DD legacy)</h3><p>$380–$560. DD variants discontinued; 2-4 week legacy-sourcing typical.</p></div>
    <div class="fail-block"><h3>External-blower remote wiring</h3><p>Roof-mount blower installs. $220–$340.</p></div>
  </div></section>

  <section class="section"><div class="wrap">
    <h2>Viking range hood product lines we service</h2>
    <div class="model-grid">
      <div class="model-card"><h3>VWH Professional 7-Series wall</h3><p>30-66 inch wall hood matched to Viking 7-Series rangetop.</p></div>
      <div class="model-card"><h3>VIWH Island</h3><p>36-54 inch island mount for open-plan kitchens.</p></div>
      <div class="model-card"><h3>VBCV insert + VHCV custom liner</h3><p>Custom-cabinet integration + built-in canopy.</p></div>
      <div class="model-card"><h3>Tuscany Collection</h3><p>Commercial-aesthetic crossover; Viking outdoor-kitchen luxury.</p></div>
      <div class="model-card"><h3>Viking DD downdraft (legacy)</h3><p>Discontinued; parts 2-4 week legacy-sourcing.</p></div>
      <div class="model-card"><h3>Internal + external blower</h3><p>Both architectures service-supported. 600-1500 CFM range.</p></div>
    </div>
  </div></section>

  <section class="section alt"><div class="wrap narrow">
    <h2>Residential Viking vs Viking commercial / commercial exhaust</h2>
    <p>Viking Residential VWH is this page's scope (600-1500 CFM luxury pro residential). Viking Commercial is a separate Middleby commercial foodservice division — separate parts chain. For commercial restaurant exhaust hood at 2000+ CFM with grease-duct + health-department-coded makeup air (Captive-Aire, Halton, Greenheck, Gaylord scope), see <a href="/commercial/exhaust-hood-repair/">commercial exhaust hood repair</a>.</p>
  </div></section>

  <section class="section"><div class="wrap">
    <h2>What Viking range hood repair costs in LA</h2>
    <table class="price-table">
      <tr><th>Service</th><th>Typical Range</th><th>Notes</th></tr>
      <tr><td>Residential diagnostic</td><td>$89</td><td>Waived with repair</td></tr>
      <tr><td>Variable-speed motor</td><td>$320 – $480</td><td>8-12 year service</td></tr>
      <tr><td>Control board</td><td>$460 – $660</td><td>Capacitor bank</td></tr>
      <tr><td>Halogen transformer</td><td>$180 – $280</td><td>Legacy VWH</td></tr>
      <tr><td>LED driver</td><td>$180 – $280</td><td>Current VWH</td></tr>
      <tr><td>Baffle-filter latch</td><td>$120 – $200</td><td>Interlock trigger</td></tr>
      <tr><td>Baffle-filter replacement</td><td>$60 – $120</td><td>Per filter routine</td></tr>
      <tr><td>Downdraft motor-lift (DD legacy)</td><td>$380 – $560</td><td>2-4 week legacy lead</td></tr>
      <tr><td>External-blower wiring</td><td>$220 – $340</td><td>Roof-mount installs</td></tr>
      <tr><td>Cooktop-insert control</td><td>$340 – $480</td><td>Insert-specific</td></tr>
    </table>
    <p class="small">Related: <a href="/brands/viking/">Viking brand hub</a> · <a href="/brands/viking-stove-repair/">Viking stove repair</a> · <a href="/brands/viking-refrigerator-repair/">Viking refrigerator repair</a> · <a href="/services/range-hood-repair/">Range hood repair (service hub)</a> · <a href="/price-list/range-hood-repair-cost/">Range hood repair cost guide</a>.</p>
  </div></section>

  <section class="section alt"><div class="wrap">
    <h2>LA service areas — Viking range hood calls</h2>
    <div class="area-grid">
      <div><h4>Bel Air + Beverly Hills</h4><p><a href="/beverly-hills/">Beverly Hills</a> · Bel Air · Holmby Hills</p></div>
      <div><h4>Pacific Palisades + Brentwood</h4><p>Pacific Palisades · Brentwood</p></div>
      <div><h4>Malibu + coastal luxury</h4><p><a href="/malibu/">Malibu</a> · Palos Verdes</p></div>
      <div><h4>Hollywood Hills</h4><p>Hollywood Hills · Laurel Canyon</p></div>
      <div><h4>Pasadena + San Marino</h4><p><a href="/pasadena/">Pasadena</a> · San Marino</p></div>
      <div><h4>OC ultra-luxury</h4><p>Newport Coast · <a href="/irvine/">Irvine</a></p></div>
    </div>
  </div></section>

  <section class="section"><div class="wrap narrow">
    <h2>Related Viking and luxury pages</h2>
    <ul class="related-links">
      <li><a href="/brands/viking/">Viking brand hub →</a></li>
      <li><a href="/brands/viking-stove-repair/">Viking stove repair →</a></li>
      <li><a href="/brands/wolf-range-hood-repair/">Wolf range hood (Sub-Zero Group alt) →</a></li>
      <li><a href="/brands/thermador-range-hood-repair/">Thermador range hood (BSH alt) →</a></li>
      <li><a href="/services/range-hood-repair/">Range hood repair (service hub) →</a></li>
      <li><a href="/price-list/range-hood-repair-cost/">Range hood repair cost guide →</a></li>
      <li><a href="/commercial/exhaust-hood-repair/">Commercial exhaust hood repair →</a></li>
    </ul>
  </div></section>

  <section class="section alt"><div class="wrap narrow">
    <h2>Viking range hood repair — frequently asked</h2>
    {faqs.map(f => (<details class="faq"><summary>{f.q}</summary><p set:html={f.a}></p></details>))}
  </div></section>

  <section id="book" class="cta-bottom"><div class="wrap">
    <h2>Viking range hood service? Call the branch closest to your home.</h2>
    <p>Same-day appliance repair in Los Angeles, Orange County, Ventura County. Residential diagnostic $89, waived with repair.</p>
  </div></section>
  <a href={`tel:${MAIN_PHONE_TEL}`} class="float-call" aria-label="Call now">☎ Call {MAIN_PHONE}</a>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  body { color: var(--text); } .wrap { max-width: 1200px; margin: 0 auto; padding: 0 24px; } .wrap.narrow { max-width: 820px; }
  h1 { font-size: 2.4rem; line-height: 1.15; margin: 12px 0 20px; color: var(--black); }
  h2 { font-size: 1.8rem; margin: 0 0 16px; color: var(--black); }
  h3 { font-size: 1.2rem; margin: 0 0 10px; color: var(--black); }
  h4 { font-size: 1.02rem; margin: 0 0 6px; color: var(--black); }
  p { line-height: 1.65; margin: 0 0 14px; }
  .call-banner { background: var(--red); color: #fff; padding: 10px 0; }
  .call-banner .wrap { display:flex; gap: 14px; align-items: center; justify-content: center; flex-wrap: wrap; }
  .call-banner .phone-lg { color:#fff; font-weight: 800; text-decoration: underline; font-size: 1.05rem; }
  .hero { background: var(--black); color: #fff; padding: 42px 0 56px; } .hero h1 { color: #fff; }
  .hero .lede { font-size: 1.06rem; color: #d7d7d7; max-width: 680px; }
  .hero .crumb { color: #9a9a9a; font-size: 0.85rem; margin-bottom: 6px; } .hero .crumb a { color: #c9c9c9; text-decoration: none; }
  .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; margin: 18px 0 24px; }
  .btn { display: inline-block; padding: 12px 20px; border-radius: 4px; text-decoration: none; font-weight: 700; }
  .btn-primary { background: var(--red); color: #fff; } .btn-ghost { background: transparent; color: #fff; border: 1px solid #fff; }
  .hero-facts { list-style: none; padding: 0; margin: 0; color: #c9c9c9; font-size: 0.95rem; }
  .hero-facts li { padding: 6px 0; border-top: 1px solid #222; } .hero-facts li:first-child { border-top: 0; }
  .trust-bar { background: var(--red); color: #fff; padding: 14px 0; }
  .trust-bar .wrap { display: flex; gap: 28px; flex-wrap: wrap; justify-content: center; font-size: 0.95rem; font-weight: 600; }
  .section { padding: 56px 0; } .section.alt { background: var(--gray); }
  .model-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 20px; margin-top: 24px; }
  .model-card { background: #fff; border: 1px solid var(--border); padding: 20px; border-radius: 6px; }
  .section.alt .model-card { background: #fff; }
  .fail-block { background: #fff; border-left: 3px solid var(--red); padding: 20px 22px; margin: 16px 0; }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 14px; background: #fff; }
  .price-table th, .price-table td { text-align: left; padding: 11px 12px; border-bottom: 1px solid var(--border); }
  .price-table th { background: var(--black); color: #fff; font-weight: 700; font-size: 0.95rem; }
  .small { color: var(--muted); font-size: 0.92rem; margin-top: 12px; }
  .area-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 18px; }
  .area-grid > div { background: #fff; border: 1px solid var(--border); padding: 16px; border-radius: 6px; }
  .related-links { list-style: none; padding: 0; } .related-links li { padding: 10px 0; border-bottom: 1px solid var(--border); }
  .related-links a { color: var(--red); font-weight: 600; text-decoration: none; } .related-links a:hover { text-decoration: underline; }
  .faq { background: #fff; border: 1px solid var(--border); padding: 12px 16px; margin-bottom: 8px; border-radius: 4px; }
  .faq summary { font-weight: 700; cursor: pointer; padding: 4px 0; } .faq p { margin: 8px 0 0; }
  .cta-bottom { background: var(--black); color: #fff; padding: 48px 0; } .cta-bottom h2 { color: #fff; } .cta-bottom p { color: #c9c9c9; }
  .float-call { position: fixed; bottom: 18px; right: 18px; background: var(--red); color: #fff; padding: 14px 18px; border-radius: 40px; text-decoration: none; font-weight: 700; box-shadow: 0 6px 18px rgba(0,0,0,0.28); z-index: 50; font-size: 0.95rem; }
  @media (max-width: 820px) { h1 { font-size: 1.9rem; } h2 { font-size: 1.45rem; } .float-call { padding: 11px 14px; font-size: 0.88rem; } .trust-bar .wrap { gap: 14px; font-size: 0.85rem; } }
</style>
