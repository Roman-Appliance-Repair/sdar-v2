        },
        {
          "@type": "Question",
          "name": "Do you service the steam oven on Pro Grand dual-fuel 48-inch ranges?",
          "acceptedAnswer": { "@type": "Answer", "text": "We do. The 1.4 cu ft steam oven on the PRD48JDSGU and related Pro Grand models uses a separate steam generator and water line that runs behind the range — different fault pattern than the main convection cavity. We diagnose both cavities in one visit." }
        },
        {
          "@type": "Question",
          "name": "Is it worth repairing a 12-year-old Thermador Pro Grand or should I replace?",
          "acceptedAnswer": { "@type": "Answer", "text": "Usually worth repairing. A new Pro Grand 48-inch dual-fuel is $14,000 to $18,000 installed. If our quote comes in under $1,500 and the cabinet frame, gas manifold, and oven cavity are sound, you're buying another 8 to 10 years. We'll tell you straight if it's the other way." }
        }
      ]
