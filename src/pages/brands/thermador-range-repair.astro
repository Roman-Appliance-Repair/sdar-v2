    },
    {
      "@type": "Service",
      "serviceType": "Thermador Range Repair",
      "provider": { "@id": canonical + "#business" },
      "areaServed": "Los Angeles County, CA",
      "offers": {
        "@type": "Offer",
        "priceSpecification": {
          "@type": "PriceSpecification",
          "priceCurrency": "USD",
          "minPrice": "300",
          "maxPrice": "950"
        }
      }
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Why won't my Thermador Star Burner ignite?",
          "acceptedAnswer": { "@type": "Answer", "text": "On Thermador Pro Grand and Pro Harmony ranges, the five-point Star Burner uses a dual-electrode ignition system. When it clicks but won't light, nine times out of ten the spark electrode has shifted out of tolerance with the star-tip geometry, or boil-over has flooded the igniter well. Both are fixable in one visit. Our techs carry OEM spark modules and Star Burner igniters for models back to 2010." }
        },
        {
          "@type": "Question",
          "name": "What does an F3 or F34 error code mean on my Thermador oven?",
          "acceptedAnswer": { "@type": "Answer", "text": "F3/F34 on Thermador Pro Grand and Professional Series ranges points to the oven temperature sensor (RTD) — either failed, loose at the rear connector, or showing resistance outside spec. It's one of the cleaner diagnoses we run because the sensor is a bolt-in replacement from the rear with the range pulled 6 inches out." }
        },
        {
          "@type": "Question",
          "name": "My ExtraLow simmer cycles off on its own — is that normal?",
          "acceptedAnswer": { "@type": "Answer", "text": "No. ExtraLow uses a secondary low-BTU valve that holds flame as low as 100°F. When the valve develops sticking or calibration drift — usually year 7 or 8 — it cuts flame mid-simmer on long-cook dishes. Valve replacement is a cooktop-off job but routine for our Thermador techs." }
        },
        {
          "@type": "Question",
          "name": "How much does Thermador range repair cost in Los Angeles?",
          "acceptedAnswer": { "@type": "Answer", "text": "Most Thermador range repairs run $300 to $700 for Pro Harmony all-gas models and $400 to $950 for Pro Grand dual-fuel. Star Burner igniters, ExtraLow valves, and RTD sensors sit at the lower end; convection fan motors, control boards, and steam oven modules sit at the upper. Our $89 diagnostic is waived the moment you approve the repair." }
        },
        {
          "@type": "Question",
          "name": "Can you convert my Thermador range between natural gas and LP?",
