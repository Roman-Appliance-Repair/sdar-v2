      "telephone": "+1-424-325-0520",
      "priceRange": "$300-$950",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "6230 Wilshire Blvd Ste A PMB 2267",
        "addressLocality": "Los Angeles",
        "addressRegion": "CA",
        "postalCode": "90048",
        "addressCountry": "US"
      },
      "areaServed": ["Los Angeles", "Beverly Hills", "Bel Air", "Malibu", "Pacific Palisades", "Brentwood", "West Hollywood", "Hollywood Hills", "Sherman Oaks", "Pasadena", "Thousand Oaks", "Calabasas", "Hidden Hills"],
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.6",
        "reviewCount": "37"
