        <div class="cred"><span class="cred-icon">⚡</span><div><strong>EPA-Certified</strong><span>Sealed-system work</span></div></div>
        <div class="cred"><span class="cred-icon">⌚</span><div><strong>Same-Day Service</strong><span>Calls before 2 PM</span></div></div>
      </div>
