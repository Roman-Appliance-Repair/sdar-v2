---
import Layout from '../../layouts/Layout.astro';
import BrandHubPlaceholder from '../../components/BrandHubPlaceholder.astro';

const title = "Maytag Appliance Repair Los Angeles | Same Day Service";
const description = "Expert Maytag appliance repair across LA, Orange, Ventura counties. All Maytag categories — washer, dryer, refrigerator, range, dishwasher, microwave. Call (424) 325-0520.";

const categories = [
  { label: "Washer", url: "/brands/maytag-washer-repair/" },
  { label: "Dryer", url: "/brands/maytag-dryer-repair/" },
  { label: "Refrigerator", url: "/brands/maytag-refrigerator-repair/" },
  { label: "Range", url: "/brands/maytag-range-repair/" },
  { label: "Dishwasher", url: "/brands/maytag-dishwasher-repair/" },
  { label: "Microwave", url: "/brands/maytag-microwave-repair/" }
];
---

<Layout title={title} description={description}>
  <BrandHubPlaceholder brandName="Maytag" brandSlug="maytag" categories={categories} />
</Layout>
