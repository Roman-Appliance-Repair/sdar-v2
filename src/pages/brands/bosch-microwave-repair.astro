---
import Layout from '../../layouts/Layout.astro';
import BrandBranchesGrid from '../../components/BrandBranchesGrid.astro';
import { MAIN_PHONE, MAIN_PHONE_TEL } from '../../data/branches';

const title = "Bosch Microwave Repair | Southern California | Legacy HMB + Thermador Route";
const description = "$89 dx waived. Bosch microwave repair SoCal, legacy HMB-series European import + BSH Irvine parts. Modern BSH microwave = Thermador. Honest scope.";
const canonical = "https://samedayappliance.repair/brands/bosch-microwave-repair/";

const faqs = [
  {
    q: "Does Bosch make microwaves for the US market?",
    a: "Honest answer: <b>Bosch's current US residential lineup does not headline microwaves</b>, BSH Home Appliances (Bosch's parent; also owns Thermador and Gaggenau) concentrates the luxury US microwave portfolio under the <b>Thermador</b> nameplate (MC30WS built-in, MD24/30WSS drawer) and the ultra-luxury <b>Gaggenau</b> nameplate (BM 450/451). Some Bosch-branded microwaves exist in the US as European-import models (HMB-series built-in, occasional countertop units), but the availability is limited and the matched-suite install answer in a Bosch-branded kitchen is typically a Thermador microwave through the shared BSH Irvine parts chain. See <a href='/brands/thermador-microwave-repair/'>Thermador microwave repair</a>."
  },
  {
    q: "What Bosch microwaves do you actually service?",
    a: "We service any Bosch-branded residential microwave that's installed in an LA household: <b>HMB-series built-in microwaves</b> (European-import 24-inch built-ins imported into the US market at various times; limited distribution); <b>HMV-series over-the-range</b> (rare in US Bosch lineup but some units exist); <b>legacy Bosch speed-oven combis</b> that occasionally surface in premium builds from the mid-2010s. All Bosch residential microwave service routes through the <b>BSH Irvine California parts chain</b>, the same parts depot that serves Thermador and Gaggenau, so Bosch-specific parts have the same 1-2 day LA-local delivery advantage the BSH family enjoys."
  },
  {
    q: "Bosch and Thermador and Gaggenau, what's the actual relationship?",
    a: "All three brands are owned by <b>BSH Home Appliances</b> (Bosch-Siemens Home Appliances, a German multinational). In the US residential market, BSH positions them as tier-differentiated: <b>Bosch</b> (premium German-engineered dishwashers + ranges + refrigerators, the mainstream BSH play), <b>Thermador</b> (American-style luxury + Masterpiece series, the US-luxury-cooking anchor), and <b>Gaggenau</b> (ultra-luxury modular architecture for architect-specified high-end builds). Microwaves concentrate in Thermador and Gaggenau; Bosch's US microwave presence is thin. All three share the BSH Irvine California parts distribution and the Home Connect app platform."
  },
  {
    q: "My Bosch microwave died, repair or replace given the thin parts line?",
    a: "Depends on the unit age and what failed. For a <b>recent Bosch HMB or HMV unit</b> (within 5 years), simple failures (door switch, turntable motor, light) route through BSH Irvine at standard parts cost, repair usually wins. For <b>older units or specialty European-import models</b>, the parts chain thins out and we sometimes recommend considering a Thermador replacement for matched-suite integration if you're in a Bosch kitchen, particularly if you're already planning to renovate or upgrade elsewhere in the suite. We run the honest repair-vs-replace analysis during diagnostic with real numbers rather than leading with the expensive option."
  },
  {
    q: "Home Connect pairing with Bosch vs Thermador, is the app the same?",
    a: "Yes. <b>Home Connect is BSH's unified app platform</b> covering Bosch, Thermador, and Gaggenau residential appliances, same app, same pairing flow, same firmware-recovery sequence. If your Bosch microwave loses pairing after a firmware update, the recovery steps are identical to what we'd do on a Thermador: (1) power-cycle at the breaker 60 seconds; (2) remove and re-add the device in Home Connect app from scratch; (3) confirm 2.4 GHz WiFi (Home Connect doesn't pair on 5 GHz-only); (4) if pairing fails, the internal WiFi module ($180–$280) is the next check. The shared BSH app platform is one of the reasons mixed Bosch-Thermador kitchens are relatively common in LA, one app handles both."
  },
  {
    q: "What does Bosch microwave repair cost in LA?",
    a: "Residential diagnostic $89 waived with repair. Typical Bosch bands: magnetron $240–$380; main control board $320–$520; HV capacitor $120–$180; HV diode $60–$100; door switch / interlock $100–$200; turntable motor $80–$140; Home Connect WiFi module $180–$280; <b>legacy HMV OTR vent fan</b> $140–$240. BSH Irvine 1-2 day LA-local parts on common items; specialty European-import parts may require 3-5 day factory-direct order. Honest repair-vs-replace analysis on older units."
  }
];

const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair, Bosch Microwave Service",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": canonical, "telephone": MAIN_PHONE_TEL, "priceRange": "$$$"
  },
  { "@context": "https://schema.org", "@type": "Service", "serviceType": "Bosch Microwave Repair",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "description": "Bosch microwave repair across LA, legacy HMB built-in, HMV over-the-range, European-import units. BSH Home Appliances Irvine CA 1-2 day LA-local parts (shared with Thermador + Gaggenau). Modern BSH microwave headline in US is Thermador. Home Connect WiFi diagnostic. $89 residential diagnostic waived with repair.",
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, waived with repair" } }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "Bosch", "item": "https://samedayappliance.repair/brands/bosch/" },
      { "@type": "ListItem", "position": 4, "name": "Bosch Microwave Repair", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">{schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}</Fragment>
  <div class="call-banner"><div class="wrap"><span>Bosch microwave service?</span><a href={`tel:${MAIN_PHONE_TEL}`} class="phone-lg">{MAIN_PHONE}</a></div></div>

  <section class="hero"><div class="wrap">
    <div class="crumb"><a href="/">Home</a> › <a href="/brands/">Brands</a> › Bosch › Microwave Repair</div>
    <h1>Bosch Microwave Repair</h1>
    <p class="lede">Bosch's US residential microwave footprint is thin by design, BSH Home Appliances (Bosch's parent) concentrates the luxury US microwave portfolio under Thermador (MC30WS built-in, MD24/30WSS drawer) and Gaggenau (BM 450/451 ultra-luxury). Some Bosch-branded units are in the field as European-import HMB-series built-ins or legacy HMV over-the-range, and we service those, BSH Irvine California parts chain gives Bosch microwave service the same 1-2 day LA-local parts advantage that Thermador and Gaggenau enjoy. If you're in a Bosch-branded kitchen and need a <b>new</b> microwave, the matched-suite modern answer is typically a Thermador through the shared BSH parts chain. Same-day dispatch, $89 residential diagnostic waived with the repair.</p>
    <div class="hero-cta"><a href={`tel:${MAIN_PHONE_TEL}`} class="btn btn-primary">Call {MAIN_PHONE}</a><a href="#book" class="btn btn-ghost">Request a Visit</a></div>
    <ul class="hero-facts">
      <li><b>Legacy HMB built-in + HMV OTR serviced</b>, European-import units in US kitchens</li>
      <li><b>BSH Irvine CA 1-2 day LA-local parts</b>, shared with Thermador + Gaggenau</li>
      <li><b>Home Connect WiFi app</b>, unified BSH platform across Bosch / Thermador / Gaggenau</li>
      <li><b>$89 residential diagnostic</b>, waived when you authorize the repair</li>
    </ul>
  </div></section>

  <BrandBranchesGrid />

  <section class="trust-bar"><div class="wrap"><span>BHGS #A49573 · Insured</span><span>Same-day in 5 SoCal counties</span><span>Residential diagnostic $89 · waived with repair</span></div></section>

  <section class="section"><div class="wrap">
    <h2>What Bosch microwave repair costs in LA</h2>
    <table class="price-table">
      <tr><th>Service</th><th>Typical Range</th><th>Notes</th></tr>
      <tr><td>Residential diagnostic</td><td>$89</td><td>Waived with repair</td></tr>
      <tr><td>Magnetron</td><td>$240 – $380</td><td>HMB / HMV</td></tr>
      <tr><td>Main control board</td><td>$320 – $520</td><td>BSH-specific SKU</td></tr>
      <tr><td>HV capacitor</td><td>$120 – $180</td><td>First check on no-heat</td></tr>
      <tr><td>HV diode</td><td>$60 – $100</td><td>Cheap fix before magnetron</td></tr>
      <tr><td>Door switch / interlock</td><td>$100 – $200</td><td>Safety-critical</td></tr>
      <tr><td>Turntable motor</td><td>$80 – $140</td><td>Cross-fits BSH family</td></tr>
      <tr><td>HMV OTR vent fan motor</td><td>$140 – $240</td><td>Over-the-range specific</td></tr>
      <tr><td>Home Connect WiFi module</td><td>$180 – $280</td><td>Pairing / firmware recovery</td></tr>
    </table>
    <p class="small">Related: <a href="/brands/bosch/">Bosch brand hub</a> · <a href="/brands/bosch-dishwasher-repair/">Bosch dishwasher</a> · <a href="/brands/bosch-refrigerator-repair/">Bosch refrigerator</a> · <a href="/brands/bosch-oven-repair/">Bosch oven</a> · <a href="/brands/thermador-microwave-repair/">Thermador microwave (BSH luxury microwave)</a> · <a href="/brands/gaggenau-range-hood-repair/">Gaggenau (BSH ultra-luxury)</a> · <a href="/services/microwave-repair/">Microwave repair (service hub)</a> · <a href="/price-list/microwave-repair-cost/">Microwave repair cost</a>.</p>
  </div></section>

  <section class="section alt"><div class="wrap narrow">
    <h2>BSH family microwave strategy, where Bosch fits</h2>
    <p>BSH Home Appliances positions its three US residential brands by tier: <b>Bosch</b> is the premium German-engineered mainstream play (dishwashers are the US headline, followed by ranges and refrigerators); <b>Thermador</b> is the American-style luxury anchor with the full microwave lineup (MC30WS built-in + MD24/30WSS drawer + MCES combi); <b>Gaggenau</b> is the ultra-luxury modular architecture for architect-specified builds (BM 450/451 microwaves).</p>
    <p>Microwaves concentrate in the Thermador and Gaggenau tiers; Bosch's US microwave footprint is limited to European-import and legacy units. All three brands share the BSH Irvine California parts distribution and the Home Connect app platform, so mixed BSH kitchens (Bosch dishwasher + Thermador microwave + Gaggenau cooktop) work through a unified service network. We service any Bosch microwave that's in the field, honestly framed against the reality that Bosch isn't where BSH concentrates its US microwave portfolio.</p>
  </div></section>

  <section class="section"><div class="wrap narrow">
    <h2>Bosch microwave repair, frequently asked</h2>
    {faqs.map(f => (<details class="faq"><summary>{f.q}</summary><p set:html={f.a}></p></details>))}
  </div></section>

  <section id="book" class="cta-bottom"><div class="wrap">
    <h2>Bosch microwave service? Call the branch closest to your home.</h2>
    <p>Same-day appliance repair in Los Angeles, Orange County, Ventura County. Residential diagnostic $89, waived with repair.</p>
  </div></section>
  <a href={`tel:${MAIN_PHONE_TEL}`} class="float-call" aria-label="Call now">☎ Call {MAIN_PHONE}</a>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  body { color: var(--text); } .wrap { max-width: 1200px; margin: 0 auto; padding: 0 24px; } .wrap.narrow { max-width: 820px; }
  h1 { font-size: 2.4rem; line-height: 1.15; margin: 12px 0 20px; color: var(--black); }
  h2 { font-size: 1.8rem; margin: 0 0 16px; color: var(--black); }
  p { line-height: 1.65; margin: 0 0 14px; }
  .call-banner { background: var(--red); color: #fff; padding: 10px 0; }
  .call-banner .wrap { display:flex; gap: 14px; align-items: center; justify-content: center; flex-wrap: wrap; }
  .call-banner .phone-lg { color:#fff; font-weight: 800; text-decoration: underline; font-size: 1.05rem; }
  .hero { background: var(--black); color: #fff; padding: 42px 0 56px; } .hero h1 { color: #fff; }
  .hero .lede { font-size: 1.06rem; color: #d7d7d7; max-width: 680px; }
  .hero .crumb { color: #9a9a9a; font-size: 0.85rem; margin-bottom: 6px; } .hero .crumb a { color: #c9c9c9; text-decoration: none; }
  .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; margin: 18px 0 24px; }
  .btn { display: inline-block; padding: 12px 20px; border-radius: 4px; text-decoration: none; font-weight: 700; }
  .btn-primary { background: var(--red); color: #fff; } .btn-ghost { background: transparent; color: #fff; border: 1px solid #fff; }
  .hero-facts { list-style: none; padding: 0; margin: 0; color: #c9c9c9; font-size: 0.95rem; }
  .hero-facts li { padding: 6px 0; border-top: 1px solid #222; } .hero-facts li:first-child { border-top: 0; }
  .trust-bar { background: var(--red); color: #fff; padding: 14px 0; }
  .trust-bar .wrap { display: flex; gap: 28px; flex-wrap: wrap; justify-content: center; font-size: 0.95rem; font-weight: 600; }
  .section { padding: 56px 0; } .section.alt { background: var(--gray); }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 14px; background: #fff; }
  .price-table th, .price-table td { text-align: left; padding: 11px 12px; border-bottom: 1px solid var(--border); }
  .price-table th { background: var(--black); color: #fff; font-weight: 700; font-size: 0.95rem; }
  .small { color: var(--muted); font-size: 0.92rem; margin-top: 12px; }
  .faq { background: #fff; border: 1px solid var(--border); padding: 12px 16px; margin-bottom: 8px; border-radius: 4px; }
  .faq summary { font-weight: 700; cursor: pointer; padding: 4px 0; } .faq p { margin: 8px 0 0; }
  .cta-bottom { background: var(--black); color: #fff; padding: 48px 0; } .cta-bottom h2 { color: #fff; } .cta-bottom p { color: #c9c9c9; }
  .float-call { position: fixed; bottom: 18px; right: 18px; background: var(--red); color: #fff; padding: 14px 18px; border-radius: 40px; text-decoration: none; font-weight: 700; box-shadow: 0 6px 18px rgba(0,0,0,0.28); z-index: 50; font-size: 0.95rem; }
  @media (max-width: 820px) { h1 { font-size: 1.9rem; } .float-call { padding: 11px 14px; font-size: 0.88rem; } .trust-bar .wrap { gap: 14px; font-size: 0.85rem; } }
</style>
