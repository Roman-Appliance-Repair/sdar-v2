---
import Layout from '../../layouts/Layout.astro';
import BrandDetailPlaceholder from '../../components/BrandDetailPlaceholder.astro';

const title = "KitchenAid Oven Repair Los Angeles | Same Day Service";
const description = "Expert KitchenAid oven repair in Los Angeles. Same-day appointments, OEM parts, licensed technicians. Call (424) 325-0520.";
