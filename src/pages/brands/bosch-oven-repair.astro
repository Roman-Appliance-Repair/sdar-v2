---
import Layout from '../../layouts/Layout.astro';

const title = "Bosch Wall Oven Repair Los Angeles | Benchmark, 800 Series, Speed Oven";
const description = "Bosch wall oven repair across LA. Factory-Trained specialists for Benchmark, 800 Series, 500 Series. Single, double, combi-steam, Speed Oven. Convection fan, control board, self-clean lock, door hinges. $89 diagnostic waived with repair. Call (424) 325-0520.";

const branches = [
  { name: "West Hollywood",  phone: "(323) 870-4790", tel: "+13238704790", areas: "WeHo · Beverly Hills · Hollywood · Mid-City" },
  { name: "Los Angeles",     phone: "(424) 325-0520", tel: "+14243250520", areas: "Mid-Wilshire · Brentwood · Santa Monica · Culver City" },
  { name: "Thousand Oaks",   phone: "(424) 208-0228", tel: "+14242080228", areas: "Ventura County · Calabasas · Agoura · Westlake · Malibu" },
  { name: "Pasadena",        phone: "(626) 376-4458", tel: "+16263764458", areas: "Pasadena · San Marino · Arcadia · Glendale · SGV" },
  { name: "Irvine",          phone: "(213) 401-9019", tel: "+12134019019", areas: "Orange County · Newport Beach · Irvine · Anaheim" },
];
const mainPhone = branches[1];

const namedTechs = [
  { name: "Mikhail V.", role: "Bosch/Thermador Specialist · 12 yrs", photo: "/images/techs/placeholder-1.jpg", areas: "Westside · West Hollywood · Beverly Hills" },
  { name: "Artur S.",   role: "Built-in Installation & Repair · 9 yrs", photo: "/images/techs/placeholder-2.jpg", areas: "Pasadena · San Marino · Arcadia" },
  { name: "David K.",   role: "European Appliance Specialist · 14 yrs", photo: "/images/techs/placeholder-3.jpg", areas: "Malibu · Pacific Palisades · Calabasas" },
];

const faqs = [
  {
    q: "How much does Bosch wall oven repair cost in Los Angeles?",
    a: "Most Bosch wall oven repairs in LA land between $240 and $620 all-in, parts and labor combined. Bake or broil element replacement averages $280. Convection fan motor replacement runs $340–$460. Control board replacement lands $380–$520. Door hinge assembly is $280–$380. Temperature sensor (thermistor) replacement averages $220. Benchmark-specific parts (Speed Oven magnetron, steam module) typically add 20–30% over standard 800 Series pricing. Our $89 diagnostic is waived when you approve the repair — no $179 call-out fee, no 6-minute metered labor."
  },
  {
    q: "Why does my Bosch wall oven not heat evenly or read the wrong temperature?",
    a: "Three common causes. First — temperature sensor (thermistor) drift. The sensor telling the control board oven temperature has gone out of calibration by 15–30°F, so the oven runs hotter or colder than set. Common year 5–7. Second — convection fan motor wearing out, air no longer circulating properly, so some racks run hot while others run cool. Third — door gasket compressed or torn, heat leaking past the seal. We check all three in sequence before replacing anything. A 20-minute sensor test often saves a $400 element replacement that wouldn't have fixed the problem."
  },
  {
    q: "My Bosch oven door won't close properly — is that a big deal?",
    a: "It's usually a hinge failure, and yes it matters. Bosch uses GentleClose soft-close gas struts on 800 Series and Benchmark ovens. After 5–7 years the struts lose pressure and the door drops hard or won't stay at partial-open positions. Ignored, a dropping door eventually damages the hinge bracket welded to the oven frame — a $280 hinge-assembly repair becomes a $600+ frame-repair situation. If the door also isn't sealing (you feel heat escaping from the top edge), the gasket likely needs replacement too. Neither is a DIY repair — the oven needs partial disassembly."
  },
  {
    q: "What's the difference between Benchmark and 800 Series wall ovens?",
    a: "Benchmark is Bosch's top tier — 800 Series Plus. Key differences: Benchmark has HomeConnect Wi-Fi, pyrolytic self-clean (heats to 900°F for ash cleaning vs. 800 Series EcoClean Plus steam), true European convection ring element wrapped around the fan, and Speed Oven / Steam Convection combi options in the lineup. Repair-wise, Benchmark uses more sophisticated control boards, more sensors, and Benchmark-specific parts that often require a 24-hour order from the authorized distributor. 800 Series repairs are faster; Benchmark repairs are more involved but the platform lasts longer."
  },
  {
    q: "Do you service built-in Bosch wall ovens without damaging cabinetry?",
    a: "Yes — this is routine in Bel Air, Holmby Hills, and Pacific Palisades custom kitchens. Our non-invasive protocol: protective floor covering, photographed installation before any screw is removed, controlled extraction on protective sliders with two technicians for double-oven stacks (200+ lb units), reinstall to exact original panel fit. Double-oven stack extraction takes 45–60 minutes longer than a single-unit call for the cabinetry work. Price is the same — we don't charge extra for doing the job properly. On wall oven / speed oven combi-stacks, we verify both units re-seat level and flush before reattaching trim pieces."
  },
  {
    q: "Does Bosch make ranges too? I was told I have a Bosch range.",
    a: "Yes — Bosch makes slide-in and freestanding ranges for the US market in gas, dual-fuel, and induction. Ranges and wall ovens are separate products, though, with different parts and service procedures. If your unit is a standalone oven-plus-cooktop sitting on the floor, it's a range — see our Bosch range repair page. If your unit is a built-in oven that drops into a cabinet niche, it's a wall oven — you're on the right page. A 'Bosch range' could also refer to a Bosch wall oven paired with a separate Bosch cooktop set into the countertop above (two distinct appliances that visually read as a range). Call us with the model number off the data plate and we'll confirm which product you have."
  },
  {
    q: "Are you Bosch Factory-Trained for wall ovens?",
    a: "Our technicians complete manufacturer training on Bosch wall oven platforms each year — Benchmark, 800 Series, 500 Series. We're licensed (CA), insured ($2M liability), BBB A+ rated, and EPA-certified. We're an independent repair company, not Bosch Factory Service subcontractors, which is why our pricing is different: no $179 call-out fee, no 6-minute metered labor, flat price quoted before work starts. Same manufacturer-approved parts either way."
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
};

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Same Day Appliance Repair",
  "image": "https://samedayappliance.repair/logo.png",
  "telephone": "(424) 325-0520",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "6230 Wilshire Blvd Ste A PMB 2267",
    "addressLocality": "Los Angeles",
    "addressRegion": "CA",
    "postalCode": "90048",
    "addressCountry": "US"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.6",
    "reviewCount": "37"
  }
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Bosch Wall Oven Repair",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Same Day Appliance Repair",
    "telephone": "(424) 325-0520"
  },
  "areaServed": { "@type": "City", "name": "Los Angeles" }
};
---

<Layout title={title} description={description}>
  <Fragment slot="head-scripts">
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  </Fragment>

  <!-- 0. CALL BANNER -->
  <div class="call-banner">
    <div class="container call-banner-inner">
      <span class="cb-label">Bosch Wall Oven Down? —</span>
      <a href={`tel:${mainPhone.tel}`} class="cb-phone">Call {mainPhone.phone}</a>
      <span class="cb-sep">·</span>
      <a href={`sms:${mainPhone.tel}`} class="cb-sms">Text us a photo</a>
    </div>
  </div>

  <!-- 1. HERO -->
  <section class="bosch-hero">
    <div class="container hero-grid">
      <div class="hero-text">
        <div class="hero-eyebrow">Factory-Trained · Post-Warranty Bosch Specialists</div>
        <h1>Bosch Wall Oven Repair in Los Angeles</h1>
        <p class="hero-sub">
          Convection fan failures. Door hinge collapses. Control board surge
          damage. Benchmark Speed Oven combi-service. Our Factory-Trained
          technicians work on Bosch wall ovens every day across LA — Benchmark,
          800 Series, 500 Series. Single, double, combi-steam, Speed Oven.
          Manufacturer-approved parts. Same-day appointments.
        </p>

        <div class="branch-select">
          <label for="branchPicker" class="bs-label">Your area:</label>
          <select id="branchPicker" class="bs-dropdown" onchange="
            const b = this.options[this.selectedIndex];
            const phoneEl = document.getElementById('heroPhoneBtn');
            phoneEl.href = 'tel:' + b.dataset.tel;
            phoneEl.textContent = 'Call ' + b.dataset.phone;
          ">
            {branches.map((b, i) => (
              <option value={b.name} data-tel={b.tel} data-phone={b.phone} selected={i === 1}>
                {b.name} — {b.areas}
              </option>
            ))}
          </select>
        </div>

        <div class="hero-ctas">
          <a id="heroPhoneBtn" href={`tel:${mainPhone.tel}`} class="btn btn-red">Call {mainPhone.phone}</a>
          <a href="/schedule/" class="btn btn-hero-outline">Schedule Online</a>
          <a href={`sms:${mainPhone.tel}?body=Bosch wall oven photo — `} class="btn btn-hero-outline btn-sms">📷 Text Photo</a>
        </div>

        <div class="hero-badge">
          <span class="badge-amount">$89</span>
          <span class="badge-text">Diagnostic — <strong>waived</strong> when you approve the repair. No $179 call-out fee.</span>
        </div>
      </div>
      <div class="hero-image">
        <div class="image-frame">
          <div class="image-ring"></div>
          <img src="/images/bosch-oven-repair.jpg" alt="Bosch 800 Series wall oven repair Los Angeles" loading="eager" />
        </div>
      </div>
    </div>
  </section>

  <!-- 2. CREDS BAR -->
  <section class="creds-bar">
    <div class="container">
      <div class="creds-grid">
        <div class="cred"><span class="cred-icon">★</span><div><strong>BBB A+ Rated</strong><span>Accredited business</span></div></div>
        <div class="cred"><span class="cred-icon">✓</span><div><strong>Factory-Trained</strong><span>Benchmark · 800 · 500</span></div></div>
        <div class="cred"><span class="cred-icon">⚖</span><div><strong>Licensed &amp; Insured</strong><span>CA Lic. · $2M liability</span></div></div>
        <div class="cred"><span class="cred-icon">⚡</span><div><strong>EPA-Certified</strong><span>Refrigerant-safe</span></div></div>
        <div class="cred"><span class="cred-icon">⌚</span><div><strong>Same-Day Service</strong><span>Calls before 2 PM</span></div></div>
      </div>
    </div>
  </section>

  <!-- 3. POST-WARRANTY POSITIONING -->
  <section class="positioning">
    <div class="container container-narrow">
      <div class="pos-eyebrow">Who We Serve — Wall Ovens Only</div>
      <h2>LA's Post-Warranty Bosch Wall Oven Specialists</h2>
      <p>
        One clarification upfront: this page is about Bosch <strong>wall
        ovens</strong> — the built-in units that drop into a cabinet niche.
        Bosch also makes slide-in and freestanding <strong>ranges</strong>
        in the US market (gas, dual-fuel, induction), but those are a
        separate product with different parts and different service
        procedures. If you have a Bosch range (the standalone oven-plus-
        cooktop unit that sits on the floor), you'll want our Bosch range
        repair page instead. If you have a Bosch wall oven — single,
        double, or Benchmark Speed Oven combi — you're on the right page.
      </p>
      <p>
        Bosch's factory warranty covers wall ovens for one year on parts and
        labor. After that, owners face the familiar choice — call Bosch Factory
        Service at $179 per visit plus $25 every 6 minutes of metered labor,
        or find an independent shop that actually knows the Benchmark, 800,
        and 500 Series platforms.
      </p>
      <p>
        Most of our Bosch wall oven calls are units aged 2–15 years. The bake
        and broil elements, convection fan motor, thermistor, and door hinges
        all fail in predictable windows. Control boards fail from LA brownout
        surges in any year. Almost all of these are serviceable without
        pulling the oven out of the cabinet — but when extraction is needed,
        our built-in protocol keeps the cabinetry intact.
      </p>
    </div>
  </section>

  <!-- 4. INTRO -->
  <section class="intro">
    <div class="container container-narrow">
      <p class="lead">
        Bosch wall ovens have a specific failure curve in Los Angeles — thermistor
        drift around year 5 throws baking off-recipe, and door hinge
        collapses around year 6–8 as the GentleClose gas struts lose pressure.
      </p>
      <p>
        These are the two most common wall oven calls we run. Thermistor drift
        is the subtler one — nothing breaks visibly, the oven still heats,
        cycles look normal. But your recipes aren't coming out right. A
        15–30°F calibration error on a 350°F bake is the difference between
        perfect cookies and flat cookies. A quick sensor test catches it in
        20 minutes and replacement is a $220 repair.
      </p>
      <p>
        Door hinge issues are harder to ignore. Bosch's soft-close gas struts
        lose pressure over 5–7 years of normal use. First the door drops
        slightly on open. Then it won't stay at 45° open for loading. Then
        it slams shut on its own. Each stage puts more strain on the hinge
        bracket welded to the oven frame. Catching it at stage one is a
        $280–$380 hinge-assembly swap. Waiting until stage three sometimes
        means frame repair work on top.
      </p>
    </div>
  </section>

  <!-- 5. NAMED TECHNICIANS -->
  <section class="techs">
    <div class="container">
      <div class="section-heading">
        <span class="section-num">01</span>
        <h2>Meet the Technicians Who Service Your Bosch</h2>
      </div>
      <p class="section-lead">
        You'll know the name and face of the tech before they arrive. Our Bosch
        wall oven specialists are Factory-Trained on Benchmark and 800 Series
        platforms, background-checked, and assigned by neighborhood.
      </p>
      <div class="techs-grid">
        {namedTechs.map(t => (
          <div class="tech-card">
            <div class="tech-photo">
              <img src={t.photo} alt={`${t.name} — ${t.role}`} loading="lazy" />
            </div>
            <div class="tech-info">
              <h3>{t.name}</h3>
              <div class="tech-role">{t.role}</div>
              <div class="tech-areas">Primary areas: {t.areas}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 6. TRY THIS FIRST -->
  <section class="diy-check">
    <div class="container container-narrow">
      <div class="section-heading">
        <span class="section-num">02</span>
        <h2>Before You Call — Four Quick Checks</h2>
      </div>
      <p class="section-lead">
        A few Bosch wall oven calls we dispatch turn out to be simple resets.
        Worth 60 seconds before scheduling.
      </p>
      <ol class="diy-list">
        <li>
          <strong>Check the circuit breaker.</strong> Bosch wall ovens run on
          a dedicated 240V circuit. After a power event, one leg of the
          breaker can trip without the other — oven lights work but heating
          elements don't. Reset the breaker fully (off all the way, back on).
        </li>
        <li>
          <strong>Cancel any active Self-Clean cycle.</strong> If the oven
          entered Self-Clean accidentally and the door locked, it won't
          unlock until cycle completes or temperature drops below 400°F.
          Press Cancel. Wait 45–60 minutes for cool-down. Don't force the door.
        </li>
        <li>
          <strong>Verify the oven is in the right mode.</strong> Bosch
          Benchmark and 800 Series have 10+ modes (Bake, Convection Bake,
          True Convection, Broil, Proof, Pizza, Warming). Accidental mode
          selection explains maybe 5% of "oven doesn't work right" calls.
        </li>
        <li>
          <strong>Check the temperature probe jack.</strong> On models with a
          meat-probe jack, a loose or half-inserted probe connector can throw
          temperature errors. Unplug fully, push back in firmly, try again.
        </li>
      </ol>
      <p class="diy-foot">
        Still broken? That's what we're here for. <a href={`tel:${mainPhone.tel}`}>{mainPhone.phone}</a>
        or <a href={`sms:${mainPhone.tel}?body=Bosch wall oven photo — `}>text us a photo</a>.
      </p>
    </div>
  </section>

  <!-- 7. COMMON PROBLEMS -->
  <section class="problems">
    <div class="container">
      <div class="section-heading">
        <span class="section-num">03</span>
        <h2>Bosch Wall Oven Problems We Fix Every Week</h2>
      </div>
      <div class="problems-grid">
        <div class="problem-card">
          <h3>Bake or Broil Element Burned Out</h3>
          <p><strong>What it means:</strong> oven doesn't heat, or heats only
          from top (broil ok, bake dead) or only from bottom (bake ok, broil
          dead). Usually visible burn-out spot on the element ring. Common
          year 6–9.</p>
          <p><strong>How we fix it:</strong> verify with ohm-meter test
          (infinite resistance = open element). Replace with manufacturer-
          approved element. 30–45 minute job. We carry 800 Series bake and
          broil elements in stock.</p>
        </div>
        <div class="problem-card">
          <h3>Convection Fan Not Working or Noisy</h3>
          <p><strong>What it means:</strong> convection modes bake unevenly,
          or fan runs with a grinding/rattling noise. Fan motor bearing
          worn. Year 8–10 pattern. Bosch uses a rear-mounted fan on the
          True Convection ring element.</p>
          <p><strong>How we fix it:</strong> full convection fan and motor
          assembly replacement with manufacturer-approved part. Access is
          through the rear of the oven cavity — oven stays in cabinet,
          45–60 minute job.</p>
        </div>
        <div class="problem-card">
          <h3>Temperature Drift (Thermistor)</h3>
          <p><strong>What it means:</strong> oven heats but runs hotter or
          cooler than set — recipes come out wrong, baking inconsistent. No
          error code, just drift. Year 5–7 common.</p>
          <p><strong>How we fix it:</strong> test thermistor resistance
          against manufacturer spec at known temperatures. Replace if out
          of spec by more than 10%. Often a $220 fix that restores proper
          baking performance.</p>
        </div>
        <div class="problem-card">
          <h3>Door Won't Close / Drops Hard (Hinge Failure)</h3>
          <p><strong>What it means:</strong> door drops when opened, won't
          stay at partial-open positions, or slams shut on its own. Bosch
          GentleClose gas struts lose pressure year 5–7. Ignored, damages
          hinge bracket welded to oven frame.</p>
          <p><strong>How we fix it:</strong> full hinge-and-strut assembly
          replacement. Inspect hinge bracket for stress cracks — replace if
          compromised. 45–60 minute job with manufacturer-approved
          hardware.</p>
        </div>
        <div class="problem-card">
          <h3>Self-Clean Door Stuck Locked</h3>
          <p><strong>What it means:</strong> Self-Clean cycle finished (or
          was cancelled), but the door lock solenoid didn't release. Door
          won't open. Common on 800 Series Plus and Benchmark.</p>
          <p><strong>How we fix it:</strong> verify cavity temperature has
          dropped below threshold (below 400°F). If lock solenoid failed,
          replace. If control board didn't send unlock signal, diagnose
          board. Never force the door — damages latch and frame.</p>
        </div>
        <div class="problem-card">
          <h3>Control Panel Dead / Display Dark</h3>
          <p><strong>What it means:</strong> no lights, touch controls dead,
          oven won't respond. Usually control board damage from LA power
          surges, occasionally user interface failure, rarely power supply.</p>
          <p><strong>How we fix it:</strong> verify 240V power at terminal,
          isolate main control board from user interface — they fail
          separately. Replace the failing board with manufacturer-approved
          part. 800 Series and Benchmark boards in stock for common models.</p>
        </div>
        <div class="problem-card">
          <h3>Door Seal Leaking Heat</h3>
          <p><strong>What it means:</strong> gasket around door compressed,
          torn, or falling out. Heat escapes from top edge of door during
          baking. Uneven baking, longer preheat times, higher energy bills.</p>
          <p><strong>How we fix it:</strong> full door gasket replacement
          with manufacturer-approved seal. Aftermarket gaskets fail within
          18 months and don't seal properly — we install OEM only. 30-minute
          job.</p>
        </div>
        <div class="problem-card">
          <h3>Benchmark Speed Oven / Microwave-Combi Issues</h3>
          <p><strong>What it means:</strong> on Benchmark Speed Oven combi-
          models, microwave function fails while convection oven works, or
          vice versa. Magnetron failure is the common cause on microwave
          side. Benchmark-specific parts.</p>
          <p><strong>How we fix it:</strong> diagnose which function failed,
          test magnetron and high-voltage diode if microwave side. Source
          Benchmark-specific parts through authorized distributor — typically
          24-hour order for magnetrons and combi-specific control boards.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 8. BUILT-IN WALL OVEN EXTRACTION PROTOCOL -->
  <section class="builtin">
    <div class="container container-narrow">
      <div class="section-heading">
        <span class="section-num">04</span>
        <h2>Built-In Wall Oven Extraction — Non-Invasive Service</h2>
      </div>
      <p>
        Every Bosch wall oven is built-in. Single units in 24"/27"/30"
        cabinetry niches. Double-oven stacks at 30" wide by 50" tall — these
        weigh 180–260 lb installed. In Bel Air, Holmby Hills, and Pacific
        Palisades custom kitchens, they're integrated flush with surrounding
        cabinetry, sometimes with custom trim panels. One scratch to adjacent
        wood during extraction is a $3,000–$8,000 cabinet-maker callback.
      </p>
      <p>
        Most wall oven repairs don't require extraction — bake elements,
        broil elements, thermistor, door hinges, and door gaskets are all
        front-accessible. Control boards and convection fan motors sometimes
        need partial extraction. Full extraction is reserved for frame work,
        which is rare.
      </p>
      <div class="builtin-list">
        <div class="bl-item">
          <div class="bl-num">1</div>
          <div>
            <strong>Diagnose what can be done in place.</strong> 70%+ of
            wall oven repairs happen with the unit in the cabinet. We scope
            the job before disassembly to avoid unnecessary extraction.
          </div>
        </div>
        <div class="bl-item">
          <div class="bl-num">2</div>
          <div>
            <strong>Protective covering before anything else.</strong>
            Moving blankets on countertops below the oven, cardboard on
            adjacent cabinet faces, carpet runner from oven to staging area.
          </div>
        </div>
        <div class="bl-item">
          <div class="bl-num">3</div>
          <div>
            <strong>Two-tech extraction for double-oven stacks.</strong>
            180–260 lb units require two technicians. Oven walked out on
            protective sliders from the cabinet, never dragged or dropped.
            Anti-tip straps maintained throughout.
          </div>
        </div>
        <div class="bl-item">
          <div class="bl-num">4</div>
          <div>
            <strong>Reinstall flush to original trim.</strong> Panel gaps
            verified against pre-service photos. Level adjusters reset.
            Trim pieces checked for square before final screws. On double
            stacks, both units aligned together before attaching trim.
          </div>
        </div>
      </div>
      <p class="builtin-note">
        Built-in extraction adds 45–60 minutes to a service call for double-
        oven stacks. Price is the same — we don't charge extra for doing the
        job properly.
      </p>
    </div>
  </section>

  <!-- 9. MODELS -->
  <section class="models">
    <div class="container">
      <div class="section-heading">
        <span class="section-num">05</span>
        <h2>Bosch Wall Oven Models We Service</h2>
      </div>
      <p class="section-lead">
        Our technicians are trained across the full US-market Bosch wall oven
        lineup — Benchmark, 800 Series, 500 Series. If your model isn't
        listed, call us.
      </p>
      <div class="models-grid">
        <div class="models-col">
          <h3>Benchmark Series</h3>
          <p class="series-desc">Top tier. HomeConnect Wi-Fi, pyrolytic self-clean, Speed Oven combi, Steam Convection.</p>
          <ul>
            <li>HBLP651LUC</li><li>HBLP751LUC</li>
            <li>HBLP451LUC</li><li>HSLP751UC</li>
            <li>HMCP0252UC (Speed)</li>
          </ul>
        </div>
        <div class="models-col">
          <h3>800 Series Single</h3>
          <p class="series-desc">30" single wall oven. EcoClean Plus, convection, 4.6 cu ft. Workhorse.</p>
          <ul>
            <li>HBL8453UC</li><li>HBL8451UC</li>
            <li>HBL8752UC</li><li>HBL8455UC</li>
          </ul>
        </div>
        <div class="models-col">
          <h3>800 Series Double</h3>
          <p class="series-desc">30" double wall oven stack. Upper+lower independent control, convection both.</p>
          <ul>
            <li>HBL8651UC</li><li>HBL8652UC</li>
            <li>HBL8752UC (combi)</li>
          </ul>
        </div>
        <div class="models-col">
          <h3>500 Series &amp; Legacy</h3>
          <p class="series-desc">Mid-tier single/double. 27" and 30" sizes. 3-rack configuration.</p>
          <ul>
            <li>HBL5351UC</li><li>HBL5451UC</li>
