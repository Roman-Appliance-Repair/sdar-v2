  <section class="section alt"><div class="wrap">
    <h2>Service areas, where our Café calls come from</h2>
    <div class="area-grid">
      <div><h4>Design-conscious eastside</h4><p>Silver Lake · Los Feliz · Highland Park · Mount Washington · Echo Park</p></div>
      <div><h4>Westside premium remodels</h4><p>Brentwood · Pacific Palisades · <a href="/santa-monica/">Santa Monica</a> · Mar Vista</p></div>
      <div><h4>Hollywood Hills custom</h4><p>Hollywood Hills · Laurel Canyon · Outpost Estates</p></div>
      <div><h4>Valley premium</h4><p><a href="/encino/">Encino</a> · Calabasas · Sherman Oaks · Studio City</p></div>
      <div><h4>Pasadena + San Marino</h4><p><a href="/pasadena/">Pasadena</a> · San Marino · South Pasadena</p></div>
