const canonical = "https://samedayappliance.repair/brands/sub-zero-wine-cooler-repair/";

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": "https://samedayappliance.repair/brands/sub-zero-wine-cooler-repair/#business",
    "name": "Same Day Appliance Repair, Sub-Zero Wine Cooler Service",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": "https://samedayappliance.repair/brands/sub-zero-wine-cooler-repair/",
    "telephone": MAIN_PHONE_TEL,
    "priceRange": "$$$$"
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Sub-Zero Wine Cooler Repair",
    "provider": { "@type": "LocalBusiness", "name": "Same Day Appliance Repair" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "offers": {
      "@type": "Offer",
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "89.00",
        "priceCurrency": "USD",
        "description": "Diagnostic fee, waived with repair"
      }
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "My Sub-Zero IW-24 shows error code 40140 or 40240, what does it mean?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Both codes indicate temperature sensor (thermistor) faults in dual-zone IW-24 wine columns. 40140 is typically the upper zone sensor, 40240 the lower zone. The thermistor probes monitor each compartment's temperature and feed signals to the control board, when a probe reads open circuit, shorted, or inconsistent values for more than 10 seconds, the error posts. Diagnostic: inspect probe wiring for loose connections (clean-up, no parts), test probe resistance with a meter, replace the faulty thermistor if resistance is out of spec. Thermistor replacement runs $175–$245, about 45-minute job. We don't jump to control board replacement for these codes, 85% resolve at the sensor level."
        }
      },
      {
        "@type": "Question",
        "name": "Why is humidity critical in a Sub-Zero wine cooler?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Wine needs ~50% relative humidity to keep corks moist, dry corks shrink, compromise their seal, and allow oxygen ingress that oxidizes the wine. Sub-Zero wine columns maintain humidity through a combination of the sealed-system cooling profile (which limits moisture removal compared to regular refrigeration) and a humidity sensor in some models (IW-30 and newer) that modulates the compressor duty cycle. When humidity falls below 40% or rises above 70%, it's usually a door gasket leak, a stuck damper, or (rarely) the humidity sensor itself. For a serious collection, humidity excursions for more than 24 hours are a real problem, we treat wine cooler calls with the same urgency as a warm refrigerator."
        }
      },
      {
        "@type": "Question",
        "name": "My dual-zone IW-24 only cools one side",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Characteristic of the IW-24 three-way valve architecture. Unlike BI built-ins that use dual compressors, the IW-24 runs a single compressor with a three-way valve that directs refrigerant flow between the upper and lower zones alternately. Each zone gets 15–25 minutes of active cooling, then the valve switches. When one zone stays warm while the other cools fine, the valve is stuck, won't switch direction, or one of the zone evaporators is blocked. Diagnostic requires watching a full valve cycle (about 40 minutes) with pressure monitoring. Three-way valve replacement $445–$620, specialized part that most shops don't stock. We carry for IW-24 and IW-30 calls."
        }
      },
      {
        "@type": "Question",
        "name": "How much does Sub-Zero wine cooler repair cost?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Diagnostic is $89, waived with repair. Typical Sub-Zero wine cooler repairs: temperature sensor (thermistor) $175–$245, evaporator fan motor $385–$540, condenser fan motor $320–$425, door gasket $345–$485 (wine cooler gaskets have specialized humidity seal), UV-glass door assembly $985–$1,480 (specialized glass with UV coating), three-way valve (IW-24/IW-30) $445–$620, humidity sensor $215–$295, compressor start relay $95–$155, main control board $680–$980, LED interior lighting $165–$240. Sealed-system refrigerant work runs $1,850–$2,600 depending on which zone and unit."
        }
      },
      {
        "@type": "Question",
        "name": "Can you replace the glass door on my Sub-Zero wine column?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Sub-Zero wine column glass doors use UV-filtered tempered glass with a specific amber tint that blocks wavelengths harmful to wine. Part costs $985–$1,480 depending on column size and hinge side. Replacement is 90-minute job, the unit stays in the cabinet. Most common causes of glass replacement: impact damage (something fell against the glass or a cabinet door hit it), seal failure around the triple-pane gas fill that causes condensation between panes, or hinge-related glass stress fractures. We also handle door handle replacement (less common) and the stainless trim kit that frames the glass on some models."
        }
      },
      {
        "@type": "Question",
        "name": "My wine cooler makes a clicking sound every few minutes",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Compressor attempting to start and failing, the clicking you hear is the start relay firing and the compressor drawing current briefly before the overload protector cuts power. Three possible causes: failed start relay (most common, $95–$155 part), failed compressor motor windings (expensive, compressor replacement $1,850–$2,600), or a refrigerant issue preventing the compressor from pumping against pressure. Diagnostic with a meter and amp clamp identifies which in one visit. Start relay failure alone is a same-visit $200–$250 total repair. Compressor issues are bigger but still economic against a $3,000–$6,000 unit replacement."
        }
      }
    ]
  }
];
