---
import Layout from '../../layouts/Layout.astro';
import BrandBranchesGrid from '../../components/BrandBranchesGrid.astro';
import { MAIN_PHONE, MAIN_PHONE_TEL } from '../../data/branches';

const title = "Manitowoc Ice Machine Repair | Southern California | Same Day";
const description = "Manitowoc Indigo NXT, IYT, IDT, IRT cubers and flake ice machine repair across Southern California, OC, Valley. Ali Group parts network. Call (424) 325-0520.";
const canonical = "https://samedayappliance.repair/brands/manitowoc/";

const faqs = [
  {
    q: "Who owns Manitowoc Ice Machines now?",
    a: "Manitowoc Ice is part of Ali Group. Welbilt, which owned Manitowoc Ice alongside brands like Lincoln, Garland, Merrychef, Convotherm, Frymaster, Pitco, and Kolpak, was acquired by Ali Group in July 2022 for $3.5 billion. So Manitowoc Ice is now one of many Ali Group brands, meaning parts distribution, service networks, and engineering have been integrated into the broader Ali Group North America infrastructure."
  },
  {
    q: "Is Manitowoc Ice the same company as Manitowoc the crane manufacturer?",
    a: "No, and this confuses a lot of operators. Manitowoc Ice is a commercial ice machine brand made in Manitowoc, Wisconsin since 1964. The Manitowoc Company (NYSE: MTW) is a separate crane and shipbuilding manufacturer. Same city of origin, completely different companies. When you search for Manitowoc parts or service, make sure you're looking at the ice machine side."
  },
  {
    q: "What Manitowoc models do you service?",
    a: "Full lineup: Indigo NXT series (flagship touchscreen models with 36 service error codes), IYT-series (indoor air-cooled cubers IYT0300 through IYT1900), IDT-series (dice cubers), IRT/IRF (nugget and flake ice), Neo undercounter series, and R-series remote condenser configurations. Most common LA sizes: IYT0620, IYT0900, IDT0750, IYT1200, IRT0620, IB0890 bins. Our techs carry common service parts for the Indigo NXT and IYT models on the truck."
  },
  {
    q: "What does Manitowoc error code E01 mean?",
    a: "E01 on a Manitowoc Indigo NXT ice machine means Long Freeze Cycle, the unit spent more time than spec on the freeze portion of the cycle. Root causes in LA: dirty condenser coil (air-quality loading in urban areas), scale on the evaporator plate from hard water, stuck water curtain, low refrigerant charge, or a failing compressor. Our diagnostic sequence starts with a condenser cleaning and evaporator inspection before moving to sealed-system work."
  },
  {
    q: "Can I reset my Manitowoc Indigo NXT myself?",
    a: "Yes. Power cycle reset: turn the machine off, open the front panel and let any ice on the evaporator melt completely, unplug from power, wait 30 seconds to clear control board memory, plug back in and press ON. A blue light confirms reset. If the error returns immediately or blue light doesn't appear, the underlying fault hasn't been addressed, that's a service call. On Indigo NXT touchscreen models, factory reset is Menu-driven; we recommend against factory reset unless directed by a technician, because it wipes service intervals and calibration data."
  },
  {
    q: "What's the Ali Group package advantage for LA operators?",
    a: "Ali Group owns a large cluster of commercial foodservice brands that often show up together in LA kitchens: Manitowoc Ice + Scotsman + Ice-O-Matic + Kold-Draft (ice machines), Beverage-Air + Victory + Delfield (refrigeration), Kolpak + Master-Bilt + Nor-Lake (walk-ins), Champion + CMA (dishwashers), Garland + Lincoln + Pitco + Frymaster + Convotherm (cooking). One service partner can cover the whole stack because parts, service network, and technical support are shared across the family. That's the Ali Group advantage for LA hotels, chains, and multi-unit operators."
  },
  {
    q: "How does Manitowoc compare to Hoshizaki and Scotsman?",
    a: "All three are first-tier US commercial ice brands. Manitowoc has the largest installed base in the US and the deepest parts distribution, if something breaks, you're almost guaranteed the part is nearby. Hoshizaki has a California parts warehouse and CleanCycle12 self-cleaning that makes maintenance intervals longer. Scotsman is an Ali Group sister brand to Manitowoc (both under Ali), known for compact modular designs. For LA chain operators running Ali-family equipment, Manitowoc + Scotsman is a natural pairing. For sushi and Japanese concepts, Hoshizaki F-series flake is the default spec."
  },
  {
    q: "What's Manitowoc repair pricing in LA?",
    a: "Commercial diagnostic $120 flat, waived with repair. Typical bands: water valve $220–$340, water curtain $160–$260, ice thickness probe $200–$320, fan motor $300–$550, condenser cleaning + refrigerant top-off $350–$600, HPCO switch $240–$380, control board (Indigo NXT) $700–$1,400, compressor replacement $900–$1,600 installed. Most common calls land $300–$800 parts-and-labor."
  }
];

const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "LocalBusiness",
      "@id": canonical + "#business",
      "name": "Same Day Appliance Repair",
      "image": "https://samedayappliance.repair/images/logo.png",
      "url": "https://samedayappliance.repair/",
      "telephone": MAIN_PHONE,
      "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ]
    },
    {
      "@type": "Service",
      "serviceType": "Manitowoc Ice Machine Service",
      "provider": { "@id": canonical + "#business" },
      "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
      "description": "Manitowoc commercial ice machine repair, maintenance, and diagnostics, Indigo NXT, IYT, IDT, IRT, IRF model lines. Ali Group parts network support. Same-day dispatch across Southern California."
    },
    {
      "@type": "Brand",
      "name": "Manitowoc Ice",
      "description": "Manitowoc Ice Machines, US commercial ice machine manufacturer, Manitowoc Wisconsin since 1964. Market leader in commercial ice production by US share. Formerly part of Welbilt; now part of Ali Group following the 2022 acquisition of Welbilt. Separate company from The Manitowoc Company (cranes and shipbuilding).",
      "foundingDate": "1964",
      "foundingLocation": "Manitowoc, Wisconsin, USA"
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(f => ({
        "@type": "Question",
        "name": f.q,
        "acceptedAnswer": { "@type": "Answer", "text": f.a }
      }))
    }
  ]
};
---

<Layout title={title} description={description} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <div class="call-banner">
    <div class="wrap">
      <span>Manitowoc ice machine down? Same-day commercial service:</span>
      <a href={`tel:${MAIN_PHONE_TEL}`} class="phone-lg">{MAIN_PHONE}</a>
    </div>
  </div>

  <!-- HERO -->
  <section class="hero"><div class="wrap">
          <div class="crumb"><a href="/">Home</a> › <a href="/brands/">Brands</a> › Manitowoc</div>
          <h1>Manitowoc Ice Machine Service & Repair</h1>
          <p class="lede">
            Manitowoc Ice is the #1 US commercial ice machine manufacturer, Manitowoc, Wisconsin-built since 1964,
            now part of Ali Group following the 2022 Welbilt acquisition. Our techs service the full Manitowoc lineup
            across LA County, Orange County, Ventura, San Bernardino, and Riverside: Indigo NXT touchscreen models,
            IYT / IDT cubers, IRT / IRF flake and nugget ice machines, Neo undercounter units, and R-series remote
            condenser installs. Same-day commercial ice machine repair, $120 diagnostic waived with the repair.
          </p>
          <div class="hero-cta">
            <a href={`tel:${MAIN_PHONE_TEL}`} class="btn btn-primary">Call {MAIN_PHONE}</a>
            <a href="#services" class="btn btn-ghost">See What We Service</a>
          </div>
          <ul class="hero-facts">
            <li><b>Ali Group parts network</b>, deepest commercial ice distribution in the US</li>
            <li><b>Factory-trained</b> on Indigo NXT, IYT/IDT error code system (36 codes)</li>
            <li><b>Ali family package</b>: Manitowoc + Scotsman + Ice-O-Matic + Beverage-Air one service call</li>
            <li><b>$120 commercial diagnostic</b>, waived with repair authorization</li>
          </ul>
        </div></section>

  <BrandBranchesGrid />

  <section class="trust-bar">
    <div class="wrap">
      <span>Licensed BHGS #A49573 · Insured</span>
      <span>Same-day · 5 SoCal counties</span>
      <span>$120 commercial diagnostic · waived with repair</span>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="section">
    <div class="wrap narrow">
      <h2>Who Manitowoc Ice actually is (and why the corporate story matters)</h2>
      <p>
        Manitowoc Ice was founded in 1964 in Manitowoc, Wisconsin, and over six decades became the #1 US commercial
        ice machine manufacturer by installed base. For most of that history Manitowoc Ice was part of Welbilt, a
        publicly traded holding group (NYSE: WBT) that also owned Lincoln, Garland, Merrychef, Convotherm, Frymaster,
        Pitco, Kolpak, and a handful of other commercial foodservice brands.
      </p>
      <p>
        <b>In July 2022, Ali Group acquired Welbilt for roughly $3.5 billion.</b> Welbilt was de-listed, and every
        former Welbilt brand, Manitowoc Ice included, became part of Ali Group North America. For LA operators
        this is a practical update, not just corporate trivia: parts distribution, technical support, service network,
        and engineering are now integrated with the rest of Ali Group (Scotsman, Ice-O-Matic, Kold-Draft, Beverage-Air,
        Victory, Delfield, Champion, CMA, Garland, Lincoln, Pitco, Frymaster, Convotherm, and more). One service partner
        can cover the entire Ali Group family without bouncing between corporate parts channels.
      </p>
      <p>
        <b>Important fact check:</b> Manitowoc Ice is not the same company as The Manitowoc Company (NYSE: MTW),
        which manufactures cranes and heavy equipment. Same city of origin, completely different corporate lineage.
        Writers and operators mix them up all the time. When you search for Manitowoc parts or service, make sure
        you're on the ice-machine side.
      </p>
      <p>
        At Same Day Appliance Repair Los Angeles, Manitowoc sits next to Hoshizaki and Scotsman at the top of our
        commercial ice machine brand stack. If your kitchen runs high-volume cube ice production, hotels, chain
        restaurants, sports venues, convention catering, there's a real chance it's Manitowoc. Our techs read the
        Indigo NXT error-code system, carry common parts on the truck, and pull through Ali Group parts channels for
        faster turnaround than cross-country factory shipping.
      </p>
    </div>
  </section>

  <!-- WHAT WE SERVICE -->
  <section id="services" class="section alt">
    <div class="wrap">
      <h2>Manitowoc ice machine models we service in LA</h2>
      <p class="intro">The full Manitowoc commercial ice machine lineup, what our techs see in LA kitchens:</p>
      <div class="model-grid">
        <div class="model-card">
          <h3>Indigo NXT Series</h3>
          <p>Flagship touchscreen ice machines with 36-code diagnostic system, energy-saver programming, and event logging.
          Common LA sizes: IYT0300, IYT0500, IYT0620, IYT0900, IYT1200, IYT1400, IYT1600, IYT1900. Indigo NXT is what
          you'll find in most post-2017 restaurant builds and chain remodels. Our techs read the E-code system on the
          touchscreen before opening the unit.</p>
        </div>
        <div class="model-card">
          <h3>IYT / IDT Cubers</h3>
          <p>IYT-series air-cooled cube ice machines and IDT-series dice cubers, modular head configurations that sit on
          top of standard ice bins. IYT0620 and IYT0900 are the LA workhorses, high-volume cube ice for cocktail bars,
          hotel beverage stations, and chain restaurants.</p>
        </div>
        <div class="model-card">
          <h3>IRT / IRF Flake & Nugget</h3>
          <p>IRT-series nugget ice (soft chewable ice, popular in healthcare and sonic-style bars) and IRF-series flake
          ice (for seafood display, produce misting, and specialty cocktail applications). Different refrigeration
          architecture than cube machines, diagnostic approach is distinct.</p>
        </div>
        <div class="model-card">
          <h3>Neo Undercounter</h3>
          <p>Compact undercounter ice machines for back-bar, cafe, and boutique hotel service stations. Smaller footprint,
          same Indigo NXT control platform on newer Neo models.</p>
        </div>
        <div class="model-card">
          <h3>R-series Remote Condenser</h3>
          <p>R-series installations split the condenser from the ice head, condenser on the roof or in a utility closet,
          head in the bar or kitchen. Quieter operation inside the kitchen, more complex service (two locations to
          check). Common in LA luxury hotels and Michelin-level restaurants.</p>
        </div>
        <div class="model-card">
          <h3>IB / IM Ice Bins</h3>
          <p>IB0890, IB1094, IB1894 ice storage bins, the container under the ice head. Usually low-maintenance, but
          gasket seals and door sensors are the usual repair points. Bin-full sensor issues show up as error codes on
          the head unit.</p>
        </div>
        <div class="model-card">
          <h3>Water Filtration & Pre-filters</h3>
          <p>Manitowoc AR, AR2, and K00339 / K00374 water filter systems. LA hard water makes pre-filter replacement
          the single most impactful maintenance action. Change cartridges every 6 months in moderate volume, quarterly
          in high-volume or 24-hour operations.</p>
        </div>
        <div class="model-card">
          <h3>Ali Group Cross-Brand Service</h3>
          <p>If your Manitowoc sits next to Scotsman ice, Ice-O-Matic, Beverage-Air refrigeration, Champion or CMA
          dishwashers, Kolpak walk-ins, or Garland / Pitco / Frymaster cooking, all Ali Group sister brands, we
          service them on the same ticket.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ERROR CODES OVERVIEW -->
  <section class="section">
    <div class="wrap">
      <h2>Manitowoc Indigo NXT error codes, the short list</h2>
      <p class="intro">
        Indigo NXT ice machines log 36 distinct service codes on the touchscreen display, each pointing to a specific
        fault. The codes we see most often in LA:
      </p>
      <div class="code-grid">
        <div class="code-card">
          <h3>E01, Long Freeze Cycle</h3>
          <p>Freeze portion of the cycle ran longer than spec. Usual LA suspects: dirty condenser coil from urban air
          loading, scale on the evaporator from hard water, stuck water curtain, low refrigerant charge, or weakening
          compressor.</p>
        </div>
        <div class="code-card">
          <h3>E02, Long Harvest Cycle</h3>
          <p>Harvest (ice release) cycle ran too long. Suspects: harvest valve not opening, ice thickness probe misread,
          water curtain stuck, compressor short of capacity.</p>
        </div>
        <div class="code-card">
          <h3>E03, Input Power Loss</h3>
          <p>Power interruption logged. Often triggered by LA brownouts or a scheduled utility event. Clears on its own
          once stable power returns, but repeated E03 events may signal a wiring issue at the disconnect.</p>
        </div>
        <div class="code-card">
          <h3>E04, High Condenser Temperature</h3>
          <p>Condenser temperature above safe range. Almost always dirty condenser in LA service environments. Clean
          the coil, check fan motor, verify refrigerant charge.</p>
        </div>
        <div class="code-card">
          <h3>E05, HPCO Switch Tripped</h3>
          <p>High-pressure cutout switch opened three times in a 4-hour period. Head pressure running too high ,
          condenser fouling, fan motor failure, or restricted airflow around the unit.</p>
        </div>
        <div class="code-card">
          <h3>E07, Starving TXV / Low Charge</h3>
          <p>Thermostatic expansion valve starving the evaporator, or refrigerant charge low. Measured by 10 consecutive
          instances where inlet-outlet temperature difference exceeds 12°F. Sealed-system repair, requires recovery
          and recharge.</p>
        </div>
        <div class="code-card">
          <h3>E20, Water System Fault</h3>
          <p>Water supply or water-path problem. Low incoming pressure, closed supply valve, or failed water inlet
          solenoid. Start with the filter system and supply pressure.</p>
        </div>
        <div class="code-card">
          <h3>E21–E27, Sensor / Probe Faults</h3>
          <p>Temperature sensor or bin level probe range. Each sub-code maps to a specific sensor, ice thickness probe,
          evaporator inlet, evaporator outlet, bin full sensor. We carry common Manitowoc probes on the truck.</p>
        </div>
        <div class="code-card">
          <h3>E31, Safe Mode</h3>
          <p>Ice thickness probe (ITP) sensor failed, machine runs in a timed Safe Mode until the probe is replaced.
          Production continues but thickness isn't actively measured. Schedule service promptly.</p>
        </div>
        <div class="code-card">
          <h3>E32, RS485 Comm Fault</h3>
          <p>RS485 communication between control board and gateway (or external accessory) failed. Usually a cable or
          terminator issue.</p>
        </div>
        <div class="code-card">
          <h3>E33 / E34, Touchscreen / Display</h3>
          <p>Front-panel touchscreen or display hardware fault on Indigo NXT. If unresponsive, often a connector or
          ribbon cable, rarely the display itself.</p>
        </div>
        <div class="code-card">
          <h3>E36 / E37, Board Faults</h3>
          <p>Check Sum Error (E36) or Watch Dog Event (E37), control board firmware or memory issue. Power-cycle reset
          clears some; persistent codes mean board replacement.</p>
        </div>
      </div>
      <p class="small">
        Full 36-code reference is in the Manitowoc Indigo NXT service manual. Our techs carry the diagnostic flowchart
        on the truck, reading the code on your display before we arrive saves diagnostic time.
      </p>
    </div>
  </section>

  <!-- WHY OPERATORS CALL US -->
  <section class="section alt">
    <div class="wrap">
      <h2>Why LA operators call us for Manitowoc service</h2>
      <div class="why-grid">
        <div>
          <h4>Ali Group parts network</h4>
          <p>Manitowoc parts pull through the integrated Ali Group distribution since the 2022 acquisition. Common Indigo
          NXT and IYT parts arrive in 1–2 days vs. cross-country factory shipping.</p>
        </div>
        <div>
          <h4>36-code diagnostic flowchart</h4>
          <p>Our techs know the Indigo NXT error code system end to end. Read the code off your touchscreen when you
          call, and we can often narrow the fault before arrival.</p>
        </div>
        <div>
          <h4>Ali family cross-brand service</h4>
          <p>If your kitchen runs Manitowoc + Scotsman + Beverage-Air + Champion or any combination of Ali brands, one
          visit covers all of them. Shared parts channels, one invoice.</p>
        </div>
        <div>
          <h4>LA hard-water expertise</h4>
          <p>Manitowoc evaporator plates scale up fast in LA's 13–15 gpg water. We know the descaling intervals, the
          pre-filter spec that actually works, and the model-specific scaling patterns.</p>
        </div>
        <div>
          <h4>Remote condenser R-series work</h4>
          <p>R-series installs split the condenser from the head unit. Service requires roof access and two-location
          diagnostics, not every repair shop handles these. We do.</p>
        </div>
        <div>
          <h4>Honest repair-vs-replace guidance</h4>
          <p>Manitowoc ice machines run reliably for 10–15 years with proper maintenance. If your unit is 8 years old
          and the cabinet is sound, we repair. We don't upsell replacement when the economics say fix it.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- COMMON PROBLEMS -->
  <section class="section">
    <div class="wrap narrow">
      <h2>Common Manitowoc ice machine problems LA kitchens call us for</h2>
      <p>
        Pattern recognition from weekly Manitowoc ice machine repair calls across LA. If any of these sound familiar,
        same-day commercial ice machine repair will usually resolve it:
      </p>
      <ul class="check-list">
        <li><b>Ice machine making less ice than before</b>, scale on the evaporator, dirty condenser, or pre-filter
          saturated. Cleaning + filter change usually restores 80–100% of capacity.</li>
        <li><b>Indigo NXT displaying E01 long freeze cycle</b>, condenser fouling is the #1 LA cause. Coil cleaning
          first, then refrigerant check.</li>
        <li><b>E04 high condenser temp</b>, almost always dirty condenser coil. LA kitchens need quarterly condenser
          cleaning in most cases.</li>
        <li><b>E05 HPCO repeated trips</b>, head pressure too high. Condenser clean, fan motor check, unit clearance
          verification.</li>
        <li><b>Ice bin full but machine keeps running</b>, bin level sensor (E21–E27 range) or proximity switch stuck.</li>
        <li><b>Water leaking from the unit</b>, water inlet valve seal failure, condensate drain clog, or on older
          units a pinhole in the evaporator plate.</li>
        <li><b>Indigo NXT touchscreen unresponsive</b>, usually ribbon cable or connector, rarely the screen itself.</li>
        <li><b>IRT nugget machine not producing</b>, auger drive assembly, gearbox, or water regulator.</li>
        <li><b>Ice has off-flavor</b>, biofilm in the water path. Full descale + sanitize resolves.</li>
        <li><b>Compressor short-cycling</b>, overload, low charge, or dirty condenser forcing high-pressure trips.</li>
      </ul>
      <p>
        For the Manitowoc ice machine repair drill-down with full error-code diagnostic flow and model-specific
        troubleshooting, see our <a href="/brands/manitowoc-ice-machine-repair/">Manitowoc ice machine repair page</a>.
        For broader commercial ice machine context across brands, see our
        <a href="/commercial/ice-machine-repair/">commercial ice machine repair page</a> and
        <a href="/price-list/commercial-ice-machine-repair-cost/">commercial ice machine repair cost guide</a>.
      </p>
    </div>
  </section>

  <!-- ALI GROUP PACKAGE -->
  <section class="section alt">
    <div class="wrap narrow">
      <h2>The Ali Group family in LA foodservice</h2>
      <p>
        The 2022 Ali Group acquisition of Welbilt consolidated an enormous cluster of commercial foodservice brands
        under one corporate roof. For LA operators running multi-brand kitchens, this is a real logistical advantage ,
        our techs can source parts and service for any of these brands through the same channels:
      </p>
      <ul class="check-list">
        <li><b>Ice machines:</b> Manitowoc Ice, Scotsman, Ice-O-Matic, Kold-Draft</li>
        <li><b>Commercial refrigeration:</b> Beverage-Air, Victory Refrigeration, Delfield</li>
        <li><b>Walk-in coolers and freezers:</b> Kolpak, Master-Bilt, Nor-Lake</li>
        <li><b>Commercial dishwashers:</b> Champion, CMA, ADS, Moyer Diebel</li>
        <li><b>Commercial ovens and ranges:</b> Garland, Lincoln, Convotherm, Merrychef</li>
        <li><b>Commercial fryers:</b> Pitco, Frymaster</li>
      </ul>
      <p>
        A mid-size LA restaurant or hotel running Manitowoc Ice + Scotsman ice dispenser + Beverage-Air prep tables +
        Champion dishwashers + Garland ranges + Pitco fryers is running entirely on Ali Group equipment. One service
        contract, one parts invoice, one point of contact. That's the Ali package advantage we deliver for LA multi-unit
        operators.
      </p>
    </div>
  </section>

  <!-- Pricing -->
  <section class="section">
    <div class="wrap">
      <h2>Manitowoc ice machine repair pricing in LA</h2>
      <p class="intro">
        Manitowoc parts are highly standardized across the Indigo NXT and IYT lines, so our price bands are predictable:
      </p>
      <table class="price-table">
        <tr><th>Service</th><th>Typical Range</th><th>Notes</th></tr>
        <tr><td>Commercial diagnostic</td><td>$120</td><td>Flat, waived if repair authorized same visit</td></tr>
        <tr><td>Descaling + sanitize service</td><td>$220 – $380</td><td>Scheduled maintenance standard</td></tr>
        <tr><td>Water inlet valve / solenoid</td><td>$220 – $340</td><td>Common stocked part</td></tr>
        <tr><td>Water curtain assembly</td><td>$160 – $260</td><td>Quick swap</td></tr>
        <tr><td>Ice thickness probe (ITP)</td><td>$200 – $320</td><td>Resolves E31 Safe Mode</td></tr>
        <tr><td>Temperature sensor (evap inlet/outlet)</td><td>$180 – $280</td><td>Resolves E21–E27 range</td></tr>
        <tr><td>Condenser fan motor</td><td>$300 – $550</td><td>Prevents E04 / E05</td></tr>
        <tr><td>Condenser cleaning + refrigerant top-off</td><td>$350 – $600</td><td>LA quarterly standard</td></tr>
        <tr><td>HPCO switch replacement</td><td>$240 – $380</td><td>Safety component, OEM only</td></tr>
        <tr><td>TXV replacement</td><td>$450 – $720</td><td>Brazing + recharge, resolves E07</td></tr>
        <tr><td>Auger motor (IRT / IRF nugget-flake)</td><td>$450 – $800</td><td>Size-dependent</td></tr>
        <tr><td>Control board (Indigo NXT)</td><td>$700 – $1,400</td><td>Factory firmware-matched</td></tr>
        <tr><td>Compressor replacement</td><td>$900 – $1,600</td><td>Includes refrigerant recharge</td></tr>
        <tr><td>Labor rate</td><td>$150 / hr</td><td>1-hour minimum after diagnostic</td></tr>
      </table>
      <p class="small">
        For comparison pricing across all commercial ice machine brands see our
        <a href="/price-list/commercial-ice-machine-repair-cost/">commercial ice machine repair cost guide</a>. On a
        Manitowoc under 10 years old with a sound cabinet and clean evaporator, repair almost always beats replacement
       , we'll quote honestly before any work starts.
      </p>
    </div>
  </section>

  <!-- LA service areas -->
  <section class="section alt">
    <div class="wrap">
      <h2>Where we run Manitowoc calls</h2>
      <div class="area-grid">
