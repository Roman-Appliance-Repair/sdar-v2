---
import Layout from '../../layouts/Layout.astro';
import BrandBranchesGrid from '../../components/BrandBranchesGrid.astro';
import { MAIN_PHONE, MAIN_PHONE_TEL } from '../../data/branches';

const title = "GE Profile Ice Maker Repair Los Angeles — Same Day";
const description = "GE Profile ice maker repair across SoCal, Opal 2.0 countertop nugget + PIH built-in undercounter + PDU French-door. SmartHQ app, Haier 2016+. $89 dx.";
const canonical = "https://samedayappliance.repair/brands/ge-profile-ice-maker-repair/";

const faqs = [
  {
    q: "What's Opal 2.0 and how does it differ from the original Opal?",
    a: "<b>Opal 2.0</b> (launched 2021) is the second-generation GE Profile Opal countertop nugget ice maker, a refresh of the original 2017 Opal (which launched via Indiegogo raising $2.7M). 2.0 adds improved auger, larger bin, side tank option, and SmartHQ WiFi/app integration. Both versions produce Sonic-style chewy nugget ice, ~24 lb/day max, retail $500-650. Service distinct from refrigerator-integrated ice makers, Opal is countertop portable with auger / compression chamber / water tank components."
  },
  {
    q: "Opal auger motor failure, most common Profile Opal fault?",
    a: "Yes. The auger mechanism is the primary mechanical-wear point on Opal 2.0, after 2-4 years of daily use, auger bearings wear and motor draws higher current, eventually failing. Auger motor swap $260–$380. Sometimes resolved with compression-chamber cleaning + auger lubrication if caught early, $140–$240."
  },
  {
    q: "PIH built-in Profile ice maker diagnostic?",
    a: "Profile PIH-series built-in undercounter ice makers use conventional refrigeration architecture (compressor + condenser + evaporator + water valve) distinct from Opal countertop. Common faults: water-inlet valve $220–$340; condenser coil cleaning $140–$240 (LA outdoor-kitchen installs accumulate dust); compressor start relay $180–$280; ice-thickness probe $200–$320; control board $440–$640."
  },
  {
    q: "SmartHQ app not connecting to Opal / Profile?",
    a: "GE SmartHQ is the unified app across Profile + Cafe + Monogram WiFi-connected appliances. When Opal or PIH won't connect: (1) 2.4GHz WiFi required (5GHz-only routers block); (2) account re-pair via app; (3) firmware update via app; (4) WiFi module hardware $260–$400 only when hardware confirmed."
  },
  {
    q: "What does GE Profile ice maker repair cost in LA?",
    a: "Residential diagnostic $89 waived with repair. Typical Profile bands: Opal auger motor $260–$380; Opal water-tank sensor $180–$280; Opal compression-chamber clean $140–$240; PIH water-inlet valve $220–$340; PIH ice-thickness probe $200–$320; PIH compressor start relay $180–$280; condenser cleaning $140–$240; control board $440–$640; SmartHQ WiFi module $260–$400. Louisville KY parts same-day / 1-day LA-local."
  },
  {
    q: "Profile vs commercial ice machines?",
    a: "Profile is residential-only. Opal 2.0 produces ~24 lb/day nugget max. For restaurant / commercial nugget ice at 200+ lb/day, see Hoshizaki F-series via <a href='/commercial/ice-machines/'>commercial ice machine repair</a>."
  },

    {
      q: "Where can I find the official GE manual or warranty information?",
      a: `Our technicians work independently of GE's factory service network - we're often faster and available same-day in Southern California.`
    },
  ];

const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair, GE Profile Ice Maker Service",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": canonical, "telephone": MAIN_PHONE_TEL, "priceRange": "$$$"
  },
  { "@context": "https://schema.org", "@type": "Service", "serviceType": "GE Profile Ice Maker Repair",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "description": "GE Profile ice maker repair across LA, Opal 2.0 countertop nugget + PIH-series built-in undercounter + PDU French-door. GE Appliances (Haier 2016+) Louisville KY parts. $89 residential diagnostic waived with repair.",
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, waived with repair" } }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "GE Profile", "item": "https://samedayappliance.repair/brands/ge-profile/" },
      { "@type": "ListItem", "position": 4, "name": "GE Profile Ice Maker Repair", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">{schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}</Fragment>
  <div class="call-banner"><div class="wrap"><span>GE Profile ice maker service? Same-day across LA:</span><a href={`tel:${MAIN_PHONE_TEL}`} class="phone-lg">{MAIN_PHONE}</a></div></div>

  <section class="hero"><div class="wrap">
    <div class="crumb"><a href="/">Home</a> › <a href="/brands/">Brands</a> › GE Profile › Ice Maker Repair</div>
    <h1>GE Profile Ice Maker Repair</h1>
    <p class="lede">GE Profile is GE Appliances' premium-refined mid-tier, and Opal 2.0 is the brand's consumer-flagship nugget ice maker, the 2021-refresh of the original 2017 Indiegogo Opal countertop nugget unit (~24 lb/day, Sonic-style chewy ice). Profile also covers PIH-series built-in 24" undercounter ice makers and PDU French-door integrated ice makers. SmartHQ app integration ties Opal + PIH into the GE Appliances connected ecosystem. Louisville KY parts distribution supports 1-day LA-local parts. Same-day dispatch, $89 residential diagnostic waived with the repair.</p>
    <div class="hero-cta"><a href={`tel:${MAIN_PHONE_TEL}`} class="btn btn-primary">Call {MAIN_PHONE}</a><a href="#book" class="btn btn-ghost">Request a Visit</a></div>
    <ul class="hero-facts">
      <li><b>Opal 2.0 countertop nugget</b>, 2021 refresh of 2017 original Indiegogo Opal</li>
      <li><b>PIH built-in 24" undercounter</b>, conventional refrigeration architecture</li>
      <li><b>SmartHQ app integration</b>, unified GE connected ecosystem</li>
      <li><b>$89 residential diagnostic</b>, waived when you authorize the repair</li>
    </ul>
  </div></section>

  <BrandBranchesGrid />

  <section class="trust-bar"><div class="wrap"><span>BHGS #A49573 · Insured</span><span>Same-day in 5 SoCal counties</span><span>Residential diagnostic $89 · waived with repair</span></div></section>

  <section class="section"><div class="wrap narrow">
    <h2>GE Profile ice maker service in LA</h2>
    <p>Profile's LA install base breaks into two distinct product categories: countertop Opal 2.0 units (portable, bench-serviceable) and PIH-series built-in undercounter + PDU French-door integrated (on-site service). Opal 2.0 has become the signature GE Profile ice maker through WiFi-connected convenience + high-quality nugget ice production at consumer scale. Our techs handle both, Opal service on the truck-bench; built-in service through standard undercounter refrigeration diagnostic.</p>
  </div></section>

  <section class="section alt"><div class="wrap">
    <h2>Profile ice maker failures our techs see most often in LA</h2>
    <div class="fail-block"><h3>Opal auger motor (highest-frequency)</h3><p>Auger bearing wear 2-4 years. Motor swap $260–$380.</p></div>
    <div class="fail-block"><h3>Opal water-tank + compression chamber</h3><p>Tank sensor $180–$280; chamber clean $140–$240.</p></div>
    <div class="fail-block"><h3>PIH water-inlet valve</h3><p>Valve $220–$340 on built-in undercounter.</p></div>
    <div class="fail-block"><h3>PIH condenser coil cleaning</h3><p>LA outdoor-kitchen installs accumulate dust. Clean $140–$240.</p></div>
    <div class="fail-block"><h3>PIH compressor start relay</h3><p>Relay $180–$280.</p></div>
    <div class="fail-block"><h3>SmartHQ connectivity</h3><p>WiFi config first; module hardware $260–$400 only if confirmed.</p></div>
  </div></section>

  <section class="section"><div class="wrap">
    <h2>GE Profile ice maker product lines we service</h2>
    <div class="model-grid">
      <div class="model-card"><h3>Opal 2.0 countertop nugget</h3><p>2021 refresh. ~24 lb/day Sonic-style chewy ice. SmartHQ app. Bench-serviceable.</p></div>
      <div class="model-card"><h3>Opal (original 2017)</h3><p>Indiegogo-launched original. Auger mechanism. Parts channel supports legacy units.</p></div>
      <div class="model-card"><h3>PIH-series built-in undercounter</h3><p>24" undercounter integrated ice maker. Conventional refrigeration.</p></div>
      <div class="model-card"><h3>PDU French-door integrated</h3><p>French-door refrigerator integrated ice maker. Modular-assembly service.</p></div>
      <div class="model-card"><h3>SmartHQ connected ecosystem</h3><p>Unified GE app across Profile + Cafe + Monogram.</p></div>
      <div class="model-card"><h3>Louisville KY parts network</h3><p>1-day LA-local parts distribution.</p></div>
    </div>
  </div></section>

  <section class="section alt"><div class="wrap narrow">
    <h2>Residential Profile vs commercial ice machines</h2>
    <p>Profile is residential-only. Opal 2.0 nugget ice at ~24 lb/day vs commercial Hoshizaki F-series at 330+ lb/day nugget. See <a href="/commercial/ice-machines/">commercial ice machine repair</a> for restaurant-scale.</p>
  </div></section>

  <section class="section"><div class="wrap">
    <h2>What GE Profile ice maker repair costs in LA</h2>
    <table class="price-table">
      <tr><th>Service</th><th>Typical Range</th><th>Notes</th></tr>
      <tr><td>Residential diagnostic</td><td>$89</td><td>Waived with repair</td></tr>
      <tr><td>Opal auger motor</td><td>$260 – $380</td><td>Nugget-specific</td></tr>
      <tr><td>Opal water-tank sensor</td><td>$180 – $280</td><td>Tank level</td></tr>
      <tr><td>Opal compression-chamber clean</td><td>$140 – $240</td><td>Preventive service</td></tr>
      <tr><td>PIH water-inlet valve</td><td>$220 – $340</td><td>Built-in undercounter</td></tr>
      <tr><td>PIH ice-thickness probe</td><td>$200 – $320</td><td>Cycle trigger</td></tr>
      <tr><td>PIH compressor start relay</td><td>$180 – $280</td><td>Start circuit</td></tr>
      <tr><td>Condenser cleaning (PIH)</td><td>$140 – $240</td><td>Airflow restoration</td></tr>
      <tr><td>Control board</td><td>$440 – $640</td><td>Main control</td></tr>
      <tr><td>SmartHQ WiFi module</td><td>$260 – $400</td><td>Connectivity hardware</td></tr>
    </table>
    <p class="small">Related: <a href="/brands/ge-profile/">GE Profile brand hub</a> · <a href="/brands/ge-ice-maker-repair/">GE ice maker (mass-market tier)</a> · <a href="/brands/ge-cafe-ice-maker-repair/">GE Cafe</a> · <a href="/brands/ge-monogram-ice-maker-repair/">GE Monogram</a>.</p>
  </div></section>

  <section class="section alt"><div class="wrap">
    <h2>LA service areas</h2>
    <div class="area-grid">
      <div><h4>Silver Lake + Echo Park</h4><p>Silver Lake · Echo Park · Highland Park</p></div>
      <div><h4>Studio City + Valley</h4><p>Studio City · Sherman Oaks · Encino</p></div>
      <div><h4>Manhattan Beach</h4><p>Manhattan Beach · Hermosa · Redondo</p></div>
      <div><h4>Pasadena + San Marino</h4><p><a href="/pasadena/">Pasadena</a> · San Marino · La Cañada</p></div>
      <div><h4>West Hollywood</h4><p><a href="/west-hollywood/">West Hollywood</a> · Hancock Park</p></div>
      <div><h4>OC</h4><p>Newport Beach · <a href="/irvine/">Irvine</a></p></div>
    </div>
  </div></section>

  <section class="section"><div class="wrap narrow">
    <h2>Related GE Profile and family pages</h2>
    <ul class="related-links">
      <li><a href="/brands/ge-profile/">GE Profile brand hub →</a></li>
      <li><a href="/brands/ge-ice-maker-repair/">GE ice maker (mass-market) →</a></li>
      <li><a href="/brands/ge-cafe-ice-maker-repair/">GE Cafe ice maker →</a></li>
      <li><a href="/brands/ge-monogram-ice-maker-repair/">GE Monogram ice maker →</a></li>
      <li><a href="/services/ice-maker-repair/">Ice maker repair (service hub) →</a></li>
      <li><a href="/price-list/ice-maker-repair-cost/">Ice maker repair cost guide →</a></li>
      <li><a href="/commercial/ice-machines/">Commercial ice machine repair →</a></li>
    </ul>
  </div></section>

  <section class="section alt"><div class="wrap narrow">
    <h2>GE Profile ice maker repair, frequently asked</h2>
    {faqs.map(f => (<details class="faq"><summary>{f.q}</summary><p set:html={f.a}></p></details>))}
  </div></section>

  <section id="book" class="cta-bottom"><div class="wrap">
    <h2>GE Profile ice maker service? Call the branch closest to your home.</h2>
    <p>Same-day appliance repair in Los Angeles, Orange County, Ventura County. Residential diagnostic $89, waived with repair.</p>
  </div></section>
  <a href={`tel:${MAIN_PHONE_TEL}`} class="float-call" aria-label="Call now">☎ Call {MAIN_PHONE}</a>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  body { color: var(--text); } .wrap { max-width: 1200px; margin: 0 auto; padding: 0 24px; } .wrap.narrow { max-width: 820px; }
  h1 { font-size: 2.4rem; line-height: 1.15; margin: 12px 0 20px; color: var(--black); }
  h2 { font-size: 1.8rem; margin: 0 0 16px; color: var(--black); }
  h3 { font-size: 1.2rem; margin: 0 0 10px; color: var(--black); }
  h4 { font-size: 1.02rem; margin: 0 0 6px; color: var(--black); }
  p { line-height: 1.65; margin: 0 0 14px; }
  .call-banner { background: var(--red); color: #fff; padding: 10px 0; }
  .call-banner .wrap { display:flex; gap: 14px; align-items: center; justify-content: center; flex-wrap: wrap; }
  .call-banner .phone-lg { color:#fff; font-weight: 800; text-decoration: underline; font-size: 1.05rem; }
  .hero { background: var(--black); color: #fff; padding: 42px 0 56px; } .hero h1 { color: #fff; }
  .hero .lede { font-size: 1.06rem; color: #d7d7d7; max-width: 680px; }
  .hero .crumb { color: #9a9a9a; font-size: 0.85rem; margin-bottom: 6px; } .hero .crumb a { color: #c9c9c9; text-decoration: none; }
  .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; margin: 18px 0 24px; }
  .btn { display: inline-block; padding: 12px 20px; border-radius: 4px; text-decoration: none; font-weight: 700; }
  .btn-primary { background: var(--red); color: #fff; } .btn-ghost { background: transparent; color: #fff; border: 1px solid #fff; }
  .hero-facts { list-style: none; padding: 0; margin: 0; color: #c9c9c9; font-size: 0.95rem; }
  .hero-facts li { padding: 6px 0; border-top: 1px solid #222; } .hero-facts li:first-child { border-top: 0; }
  .trust-bar { background: var(--red); color: #fff; padding: 14px 0; }
  .trust-bar .wrap { display: flex; gap: 28px; flex-wrap: wrap; justify-content: center; font-size: 0.95rem; font-weight: 600; }
  .section { padding: 56px 0; } .section.alt { background: var(--gray); }
  .model-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 20px; margin-top: 24px; }
  .model-card { background: #fff; border: 1px solid var(--border); padding: 20px; border-radius: 6px; }
  .section.alt .model-card { background: #fff; }
  .fail-block { background: #fff; border-left: 3px solid var(--red); padding: 20px 22px; margin: 16px 0; }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 14px; background: #fff; }
  .price-table th, .price-table td { text-align: left; padding: 11px 12px; border-bottom: 1px solid var(--border); }
  .price-table th { background: var(--black); color: #fff; font-weight: 700; font-size: 0.95rem; }
  .small { color: var(--muted); font-size: 0.92rem; margin-top: 12px; }
  .area-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 18px; }
  .area-grid > div { background: #fff; border: 1px solid var(--border); padding: 16px; border-radius: 6px; }
  .related-links { list-style: none; padding: 0; } .related-links li { padding: 10px 0; border-bottom: 1px solid var(--border); }
  .related-links a { color: var(--red); font-weight: 600; text-decoration: none; } .related-links a:hover { text-decoration: underline; }
  .faq { background: #fff; border: 1px solid var(--border); padding: 12px 16px; margin-bottom: 8px; border-radius: 4px; }
  .faq summary { font-weight: 700; cursor: pointer; padding: 4px 0; } .faq p { margin: 8px 0 0; }
  .cta-bottom { background: var(--black); color: #fff; padding: 48px 0; } .cta-bottom h2 { color: #fff; } .cta-bottom p { color: #c9c9c9; }
  .float-call { position: fixed; bottom: 18px; right: 18px; background: var(--red); color: #fff; padding: 14px 18px; border-radius: 40px; text-decoration: none; font-weight: 700; box-shadow: 0 6px 18px rgba(0,0,0,0.28); z-index: 50; font-size: 0.95rem; }
  @media (max-width: 820px) { h1 { font-size: 1.9rem; } h2 { font-size: 1.45rem; } .float-call { padding: 11px 14px; font-size: 0.88rem; } .trust-bar .wrap { gap: 14px; font-size: 0.85rem; } }
</style>
