---
import Layout from '../../layouts/Layout.astro';

const title = "Bosch Dryer Repair Los Angeles | Heat-Pump Ventless, Compact 24\"";
const description = "Bosch dryer repair across LA. Factory-Trained specialists for 800 Series heat-pump ventless, 500 condenser, 300 vented, Axxis compact. Heat-pump compressor, condenser coils, thermistor. $89 diagnostic waived with repair. Call (424) 325-0520.";

const branches = [
  { name: "West Hollywood",  phone: "(323) 870-4790", tel: "+13238704790", areas: "WeHo · Beverly Hills · Hollywood · Mid-City" },
  { name: "Los Angeles",     phone: "(424) 325-0520", tel: "+14243250520", areas: "Mid-Wilshire · Brentwood · Santa Monica · Culver City" },
  { name: "Thousand Oaks",   phone: "(424) 208-0228", tel: "+14242080228", areas: "Ventura County · Calabasas · Agoura · Westlake · Malibu" },
  { name: "Pasadena",        phone: "(626) 376-4458", tel: "+16263764458", areas: "Pasadena · San Marino · Arcadia · Glendale · SGV" },
  { name: "Irvine",          phone: "(213) 401-9019", tel: "+12134019019", areas: "Orange County · Newport Beach · Irvine · Anaheim" },
];
const mainPhone = branches[1];

const namedTechs = [
  { name: "Mikhail V.", role: "Bosch/Thermador Specialist · 12 yrs", photo: "/images/techs/placeholder-1.jpg", areas: "Westside · West Hollywood · Beverly Hills" },
  { name: "Artur S.",   role: "Built-in Installation & Repair · 9 yrs", photo: "/images/techs/placeholder-2.jpg", areas: "Pasadena · San Marino · Arcadia" },
  { name: "David K.",   role: "European Appliance Specialist · 14 yrs", photo: "/images/techs/placeholder-3.jpg", areas: "Malibu · Pacific Palisades · Calabasas" },
];

const faqs = [
  {
    q: "How much does Bosch dryer repair cost in Los Angeles?",
    a: "Most Bosch dryer repairs in LA land between $220 and $650 all-in, parts and labor combined. Heat-pump compressor replacement on 800 Series ventless units is the most expensive at $580–$900 — it involves EPA-certified sealed-system work. Thermistor or moisture sensor replacement averages $240. Drum belt replacement lands $260–$340. Condenser coil deep-clean is $180–$240. Control board replacement comes in at $320–$420. Our $89 diagnostic is waived when you approve the repair — no $179 call-out fee, no 6-minute metered labor."
  },
  {
    q: "How does a Bosch heat-pump dryer work and why does it matter for repair?",
    a: "Heat-pump dryers — Bosch 800 Series ventless models — don't vent hot moist air outside. They use a closed-loop heat-pump system (like a mini air conditioner in reverse) to extract moisture and condense it into a tank or drain line. This is why they run on standard 120V and need no vent hole in the wall — the entire reason they exist in LA condos. The tradeoff: the heat-pump system is more complex than a standard vented dryer, and when the compressor fails around year 8–10, the repair involves EPA-certified sealed-system work. Our technicians carry EPA 608 Type I certification for this."
  },
  {
    q: "My Bosch dryer takes forever to dry clothes — what's wrong?",
    a: "Long cycle times are the most common Bosch dryer complaint in LA, and they point to three root causes. First: clogged condenser coils (on ventless and heat-pump models) — LA dust and lint coat the coils over months, heat-pump efficiency drops, cycles stretch from 90 minutes to 3+ hours. Second: failed moisture sensor — the dryer can't tell clothes are dry, keeps running. Third: on vented 300 Series, a clogged vent line from dryer to wall. Diagnosing the actual cause saves money — we don't swap $400 parts before checking a $0 clogged coil."
  },
  {
    q: "Do you service stacked Bosch washer-dryer units?",
    a: "Yes, constantly. In LA condos and lofts, stacked Axxis and 300/500/800 Series pairs are the rule. We bring a two-tech stack-unstack protocol: safely lowering the dryer off the washer, servicing either unit, restacking with proper factory kit hardware. No dings in the closet wall, no scratched side panels. Stacked service takes 30–45 minutes longer than a freestanding unit — price is the same, we don't charge extra."
  },
  {
    q: "Is it worth repairing an 8-year-old heat-pump dryer?",
    a: "Depends on the failure. A heat-pump compressor ($600–$900) on an 8-year-old unit is a closer call — we'll run the honest repair-vs-replace math with you before starting. Bosch 800 Series heat-pump dryers replace new at $1,400–$2,000, so a compressor is roughly 40–60% of replacement cost. But a thermistor ($240), drum belt ($300), control board ($380), or condenser cleaning ($220) on the same unit is almost always worth repairing — the drum and cabinet have 5+ years left. We don't push repairs that don't pencil out."
  },
  {
    q: "Why does my Bosch dryer smell like burning?",
    a: "Burning smell is serious — stop using the dryer and call us. Most common cause: lint buildup on the heating element (on vented 300 Series) or on condenser fins (on heat-pump models), where it smolders against hot metal. Second: a slipping drum belt creating friction burn. Third, less common: a failing drive motor overheating its windings. A burning smell escalates to fire risk fast on any dryer — we prioritize these as same-day emergency calls across all five branches. Don't run another cycle."
  },
  {
    q: "Are you EPA-certified for heat-pump sealed-system work?",
    a: "Yes. Any repair involving refrigerant — heat-pump compressor replacement, sealed-system leak repair, recharge — is performed under EPA 608 Type I certification. Federal law requires this for any work that opens a sealed system containing refrigerant, including heat-pump dryers. Non-certified shops will quote cheaper on these repairs, but refrigerant recovery alone is a $4,000–$10,000 fine per incident without certification. Plus a non-certified repair voids the sealed-system warranty on the unit."
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
};

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Same Day Appliance Repair",
  "image": "https://samedayappliance.repair/logo.png",
  "telephone": "(424) 325-0520",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "6230 Wilshire Blvd Ste A PMB 2267",
    "addressLocality": "Los Angeles",
    "addressRegion": "CA",
    "postalCode": "90048",
    "addressCountry": "US"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.6",
    "reviewCount": "37"
  }
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Bosch Dryer Repair",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Same Day Appliance Repair",
    "telephone": "(424) 325-0520"
  },
  "areaServed": { "@type": "City", "name": "Los Angeles" }
};
---

<Layout title={title} description={description}>
  <Fragment slot="head-scripts">
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  </Fragment>

  <!-- 0. CALL BANNER -->
  <div class="call-banner">
    <div class="container call-banner-inner">
      <span class="cb-label">Bosch Dryer Not Working? —</span>
      <a href={`tel:${mainPhone.tel}`} class="cb-phone">Call {mainPhone.phone}</a>
      <span class="cb-sep">·</span>
      <a href={`sms:${mainPhone.tel}`} class="cb-sms">Text us a photo</a>
    </div>
  </div>

  <!-- 1. HERO -->
  <section class="bosch-hero">
    <div class="container hero-grid">
      <div class="hero-text">
        <div class="hero-eyebrow">Factory-Trained · EPA-Certified · Heat-Pump Specialists</div>
        <h1>Bosch Dryer Repair in Los Angeles</h1>
        <p class="hero-sub">
          Heat-pump compressor failures. Condenser coil clogs. Thermistor and
          moisture sensor drift. Our Factory-Trained technicians carry EPA 608
          Type I certification for heat-pump sealed-system work — 800 Series
          heat-pump, 500 condenser, 300 vented, Axxis legacy. Manufacturer-
          approved parts. Same-day appointments.
        </p>

        <div class="branch-select">
          <label for="branchPicker" class="bs-label">Your area:</label>
          <select id="branchPicker" class="bs-dropdown" onchange="
            const b = this.options[this.selectedIndex];
            const phoneEl = document.getElementById('heroPhoneBtn');
            phoneEl.href = 'tel:' + b.dataset.tel;
            phoneEl.textContent = 'Call ' + b.dataset.phone;
          ">
            {branches.map((b, i) => (
              <option value={b.name} data-tel={b.tel} data-phone={b.phone} selected={i === 1}>
                {b.name} — {b.areas}
              </option>
            ))}
          </select>
        </div>

        <div class="hero-ctas">
          <a id="heroPhoneBtn" href={`tel:${mainPhone.tel}`} class="btn btn-red">Call {mainPhone.phone}</a>
          <a href="/schedule/" class="btn btn-hero-outline">Schedule Online</a>
          <a href={`sms:${mainPhone.tel}?body=Bosch dryer photo — `} class="btn btn-hero-outline btn-sms">📷 Text Photo</a>
        </div>

        <div class="hero-badge">
          <span class="badge-amount">$89</span>
          <span class="badge-text">Diagnostic — <strong>waived</strong> when you approve the repair. EPA 608 for heat-pump work.</span>
        </div>
      </div>
      <div class="hero-image">
        <div class="image-frame">
          <div class="image-ring"></div>
          <img src="/images/bosch-dryer-repair.jpg" alt="Bosch 800 Series heat-pump dryer repair Los Angeles" loading="eager" />
        </div>
      </div>
    </div>
  </section>

  <!-- 2. CREDS BAR -->
  <section class="creds-bar">
    <div class="container">
      <div class="creds-grid">
        <div class="cred"><span class="cred-icon">★</span><div><strong>BBB A+ Rated</strong><span>Accredited business</span></div></div>
        <div class="cred"><span class="cred-icon">✓</span><div><strong>Factory-Trained</strong><span>800 · 500 · 300 · Axxis</span></div></div>
        <div class="cred"><span class="cred-icon">⚖</span><div><strong>Licensed &amp; Insured</strong><span>CA Lic. · $2M liability</span></div></div>
        <div class="cred"><span class="cred-icon">⚡</span><div><strong>EPA 608 Certified</strong><span>Heat-pump sealed-system</span></div></div>
        <div class="cred"><span class="cred-icon">⌚</span><div><strong>Same-Day Service</strong><span>Burning-smell priority</span></div></div>
      </div>
    </div>
  </section>

  <!-- 3. POST-WARRANTY POSITIONING -->
  <section class="positioning">
    <div class="container container-narrow">
      <div class="pos-eyebrow">Who We Serve</div>
      <h2>LA's Post-Warranty Bosch Dryer Specialists</h2>
      <p>
        Bosch's factory warranty covers one year on parts and labor, with
        extended sealed-system coverage on heat-pump compressor models. After
        year one, owners face a choice — call Bosch Factory Service at $179 per
        visit plus $25 every 6 minutes of metered labor, or find an independent
        shop that actually knows the heat-pump platform.
      </p>
      <p>
        Most of our Bosch dryer calls are units aged 2–12 years. Condenser coil
        buildup, thermistor drift, drum belt wear, and moisture sensor failure
        follow predictable timelines. The big one on heat-pump models — the
        compressor — typically shows up around years 8–10 as long cycle times
        and elevated drum temperatures before catastrophic failure. Catch it
        early, refrigerant and labor stay contained.
      </p>
      <p>
        Heat-pump sealed-system work is EPA-regulated federally. Our
        technicians carry EPA 608 Type I certification. Non-certified handymen
        will quote cheaper on a compressor job, but refrigerant recovery alone
        is a $4,000–$10,000 fine per incident, and the repair voids sealed-
        system warranty coverage on qualifying models.
      </p>
    </div>
  </section>

  <!-- 4. INTRO -->
  <section class="intro">
    <div class="container container-narrow">
      <p class="lead">
        Bosch dryers have a specific failure curve in Los Angeles — condenser
        coils clog fast from LA dust, thermistors drift around year 5, and
        heat-pump compressors start losing efficiency around year 8 on 800
        Series ventless units.
      </p>
      <p>
        The LA angle is dust. Our air carries more particulates than most
        cities, and heat-pump dryers pull room air across the condenser to
        drive heat exchange. That air is dusty. Over 12–18 months, the condenser
        fins coat with lint and dust, heat transfer efficiency drops, and a
        60-minute cycle stretches to 2+ hours. Most owners assume the unit is
        "going bad" — it's usually just a condenser that needs deep cleaning.
      </p>
      <p>
        The second common category is sensors. The thermistor tells the control
        board drum temperature; the moisture sensor tells it when clothes are
        dry. When either drifts out of spec, cycles run too long, too short,
        or shut down with vague errors. We meter both on every long-cycle call
        before replacing anything more expensive.
      </p>
    </div>
  </section>

  <!-- 5. NAMED TECHNICIANS -->
  <section class="techs">
    <div class="container">
      <div class="section-heading">
        <span class="section-num">01</span>
        <h2>Meet the Technicians Who Service Your Bosch</h2>
      </div>
      <p class="section-lead">
        You'll know the name and face of the tech before they arrive. Our Bosch
        dryer specialists are Factory-Trained, EPA-certified for sealed-system
        work, background-checked, and assigned by neighborhood.
      </p>
      <div class="techs-grid">
        {namedTechs.map(t => (
          <div class="tech-card">
            <div class="tech-photo">
              <img src={t.photo} alt={`${t.name} — ${t.role}`} loading="lazy" />
            </div>
            <div class="tech-info">
              <h3>{t.name}</h3>
              <div class="tech-role">{t.role}</div>
              <div class="tech-areas">Primary areas: {t.areas}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 6. TRY THIS FIRST -->
  <section class="diy-check">
    <div class="container container-narrow">
      <div class="section-heading">
        <span class="section-num">02</span>
        <h2>Before You Call — Four Quick Checks</h2>
      </div>
      <p class="section-lead">
        A few Bosch dryer calls we dispatch turn out to be simple fixes.
        Worth 60 seconds before scheduling.
      </p>
      <ol class="diy-list">
        <li>
          <strong>Clean the lint filter every single load.</strong> Bosch
          fluff filters have two layers on 500/800 Series — pull the mesh
          filter up, then lift the secondary fine screen beneath. A clogged
          secondary screen is responsible for maybe 30% of "dryer won't dry"
          complaints we get. Runs 30 seconds.
        </li>
        <li>
          <strong>Empty the condenser water tank (ventless models).</strong>
          On 500 and 800 Series ventless, water collects in a tank near the
          top of the unit. If it's full, the dryer stops with a "water tank
          full" indicator. Pull tank, empty, replace. Or connect the drain
          hose to a standpipe if you're tired of emptying manually.
        </li>
        <li>
          <strong>Check vent line (300 Series vented only).</strong> Pull the
          dryer out, disconnect the 4-inch vent, inspect from dryer to wall.
          A kinked or clogged vent throws long-cycle errors fast and is a fire
          risk. Clean with a vent brush or have a pro do it.
        </li>
        <li>
          <strong>Pull the dryer and vacuum the condenser (heat-pump &amp;
          condenser models).</strong> On ventless units, the condenser
          accessed from the bottom front or through a panel. LA dust and lint
          coat the fins — annual vacuuming restores cycle times. If you can
          see white dust on the fins, it's past due.
        </li>
      </ol>
      <p class="diy-foot">
        Still broken? That's what we're here for. <a href={`tel:${mainPhone.tel}`}>{mainPhone.phone}</a>
        or <a href={`sms:${mainPhone.tel}?body=Bosch dryer photo — `}>text us a photo</a>.
      </p>
    </div>
  </section>

  <!-- 7. COMMON PROBLEMS -->
  <section class="problems">
    <div class="container">
      <div class="section-heading">
        <span class="section-num">03</span>
        <h2>Bosch Dryer Problems We Fix Every Week</h2>
      </div>
      <div class="problems-grid">
        <div class="problem-card">
          <h3>Long Cycle Times / Clothes Still Damp</h3>
          <p><strong>What it means:</strong> cycle stretches from 60 minutes to
          2+ hours, clothes come out warm-damp instead of dry. Usually clogged
          condenser coils (ventless), clogged vent (300 Series), failed
          moisture sensor, or thermistor drift.</p>
          <p><strong>How we fix it:</strong> inspect condenser, meter sensors,
          test vent flow. Deep-clean the condenser first — saves hundreds if
          that's the root cause. Replace sensors only after ruling out airflow.</p>
        </div>
        <div class="problem-card">
          <h3>Heat-Pump Compressor Failure</h3>
          <p><strong>What it means:</strong> on 800 Series ventless, compressor
          can't maintain refrigerant pressure. Drum temperature elevated, cycle
          times very long, eventually no heat at all. Year 8–10 pattern.</p>
          <p><strong>How we fix it:</strong> verify with pressure gauges and
          amp-clamp, replace heat-pump compressor under EPA-certified sealed-
          system protocol. Refrigerant recovery, new compressor, vacuum,
          recharge to spec. Full-day job.</p>
        </div>
        <div class="problem-card">
          <h3>No Heat / Cold Air Only</h3>
          <p><strong>What it means:</strong> drum tumbles but no heat is
          generated. On 300 Series vented — usually thermal fuse tripped or
          heating element open. On heat-pump — compressor issue or refrigerant
          leak.</p>
          <p><strong>How we fix it:</strong> vented units — replace thermal
          fuse and investigate what caused it (usually blocked vent). Heat-pump
          — diagnose sealed-system, replace whatever failed, address root
          cause before recharge.</p>
        </div>
        <div class="problem-card">
          <h3>Drum Not Turning</h3>
          <p><strong>What it means:</strong> motor hums but drum stays still,
          or motor runs quietly but drum doesn't spin. Broken drum belt, seized
          drum roller, failed drive motor, or snapped motor pulley.</p>
          <p><strong>How we fix it:</strong> inspect belt first (most common —
          60-70% of no-turn calls). Replace rollers if flat-spotted. Meter
          motor windings. Keep cost down by fixing what actually failed.</p>
        </div>
        <div class="problem-card">
          <h3>Burning Smell or Smoke</h3>
          <p><strong>What it means:</strong> lint on heating element, belt
          slipping and burning, or motor windings overheating. Fire risk
          escalates fast — stop using the unit.</p>
          <p><strong>How we fix it:</strong> same-day emergency priority.
          Diagnose source (element, belt, motor, or condenser on heat-pump),
          clean or replace. Thorough lint trap, vent, and condenser cleaning
          before returning unit to service.</p>
        </div>
        <div class="problem-card">
          <h3>Error Codes E06 / E10 / E17 (Heat-Pump)</h3>
          <p><strong>What it means:</strong> heat-pump specific codes. E06 =
          compressor overload. E10 = evaporator temperature sensor fault.
          E17 = low refrigerant or heat-exchange efficiency problem.</p>
          <p><strong>How we fix it:</strong> diagnostic under manufacturer
          protocol — check refrigerant pressure (requires EPA cert), meter
          sensors, inspect heat-exchanger. E06 and E17 usually point to
          compressor or refrigerant; E10 is sensor.</p>
        </div>
        <div class="problem-card">
          <h3>Won't Start / Dead Panel</h3>
          <p><strong>What it means:</strong> no lights, unresponsive touch
          controls. Main control board, user interface panel, or power supply
          failure. LA brownouts and surges trigger most of these.</p>
          <p><strong>How we fix it:</strong> verify line voltage at outlet,
          isolate main board from UI, meter power supply. Replace failed
          component — boards in stock for 500/800 Series.</p>
        </div>
        <div class="problem-card">
          <h3>Water Tank Alarm / Won't Drain Condensate</h3>
          <p><strong>What it means:</strong> on ventless units, condensate
          water has nowhere to go. Either the collection tank is full and
          needs emptying (owner fix), or the condensate pump failed, or the
          drain hose is kinked.</p>
          <p><strong>How we fix it:</strong> verify tank status first, test
          condensate pump if drain-hose option installed, clear or replace
          drain hose. Pump replacement with manufacturer-approved part if
          motor failed.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 8. STACKED / COMPACT PROTOCOL -->
  <section class="builtin">
    <div class="container container-narrow">
      <div class="section-heading">
        <span class="section-num">04</span>
        <h2>Stacked Units &amp; Tight Laundry Closets — Our Service Protocol</h2>
      </div>
      <p>
        Most LA condos and lofts have Bosch dryers stacked over matching
        washers in closets with 2–4 inches of clearance per side. Heat-pump
        dryers weigh 130–160 lb — more than standard vented dryers because of
        the compressor and heat-exchanger assembly. Done wrong, a stacked-unit
        service call ends with a gouged closet wall, scratched side panel, or
        worse.
      </p>
      <div class="builtin-list">
        <div class="bl-item">
          <div class="bl-num">1</div>
          <div>
            <strong>Protective covering first.</strong> Moving blankets on
            the floor, cardboard against walls under 3 inches clearance.
            Carpet runner from closet to staging area.
          </div>
        </div>
        <div class="bl-item">
          <div class="bl-num">2</div>
          <div>
            <strong>Two-tech lift for heat-pump stacked pairs.</strong>
            The extra weight of the heat-pump makes single-tech lifts unsafe.
            Two techs per side, dryer walked off the washer to protective
            staging.
          </div>
        </div>
        <div class="bl-item">
          <div class="bl-num">3</div>
          <div>
            <strong>Service access from front when possible.</strong> Bosch
            24" dryers designed for front access — lint filter, moisture
            sensor, drum belt, most electrical reachable without pulling.
            We pull only when the repair requires it.
          </div>
        </div>
        <div class="bl-item">
          <div class="bl-num">4</div>
          <div>
            <strong>Restack with factory kit hardware.</strong> Bosch uses
            specific stacking kits (WTZ11400, WTZ11310). Mismatched or
            missing hardware means the dryer can walk during operation. We
            verify kit and reinstall to factory spec.
          </div>
        </div>
      </div>
      <p class="builtin-note">
        Stacked heat-pump service takes 30–45 minutes longer than a
        freestanding call. Price is the same.
      </p>
    </div>
  </section>

  <!-- 9. MODELS -->
  <section class="models">
    <div class="container">
      <div class="section-heading">
        <span class="section-num">05</span>
        <h2>Bosch Dryer Models We Service</h2>
      </div>
      <p class="section-lead">
        Our technicians are trained across the full US-market Bosch dryer
        lineup. Heat-pump, condenser, and vented formats — all 24" compact.
        If your model isn't listed, call us.
      </p>
      <div class="models-grid">
        <div class="models-col">
          <h3>800 Series Heat-Pump</h3>
          <p class="series-desc">Ventless, 120V. LA condo flagship. Compressor year 8–10 attention point.</p>
          <ul>
            <li>WTG86401UC</li><li>WTG86403UC</li>
            <li>WQG245AVUC</li><li>WTG865H3UC</li>
          </ul>
        </div>
        <div class="models-col">
          <h3>500 Series Condenser</h3>
          <p class="series-desc">Ventless, 120V. No heat-pump — uses room air to condense moisture.</p>
          <ul>
            <li>WTG86401UC</li><li>WTG86402UC</li>
            <li>WTB86201UC</li>
          </ul>
        </div>
        <div class="models-col">
          <h3>300 Series Vented</h3>
          <p class="series-desc">Standard vented 240V electric. For homes with existing vent line.</p>
          <ul>
            <li>WTA3500UC</li><li>WTV76100UC</li>
            <li>WTZ1180UC</li>
          </ul>
        </div>
        <div class="models-col">
          <h3>Axxis Compact</h3>
          <p class="series-desc">Legacy 24" compact line, still in service across LA condos. Vented 240V.</p>
          <ul>
            <li>WTV76101UC</li><li>WTV76121UC</li>
            <li>WTA3510UC</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- 10. FACTORY SERVICE COMPARISON -->
  <section class="comparison">
    <div class="container container-narrow">
      <div class="section-heading">
        <span class="section-num">06</span>
        <h2>How Our Pricing Compares to Bosch Factory Service</h2>
      </div>
      <p class="section-lead">
        Bosch Factory Service is one option after warranty expires. Here's
        how our LA pricing stacks up, based on Bosch's publicly posted rates.
      </p>
      <div class="compare-table">
        <div class="compare-row compare-header">
          <span>Cost Item</span>
          <span>Bosch Factory Service</span>
          <span>Same Day Appliance Repair</span>
        </div>
