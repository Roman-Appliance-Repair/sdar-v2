---
import Layout from '../../layouts/Layout.astro';

const title = "KitchenAid Dishwasher Repair LA | FreeFlex, ProWash";
const description = "KitchenAid dishwasher repair in LA — KDTE / KDTM / KDPE families, FreeFlex Third Rack, ProWash, panel-ready built-in. Whirlpool premium. $89 diagnostic. (424) 325-0520.";
const canonical = "https://samedayappliance.repair/brands/kitchenaid-dishwasher-repair/";

const faqs = [
  {
    q: "Is KitchenAid dishwasher really different from Whirlpool under the hood?",
    a: "They share Whirlpool Corporation platform engineering, but the finished-good specification is genuinely stepped-up on KitchenAid. Both brands use the EveryDrop filter system, similar Whirlpool-family pump and motor architecture, and cross-compatible parts on many service items. Where KitchenAid differentiates: stainless-steel tub and interior standard across the lineup (not just upper trim), FreeFlex Third Rack with articulating tines for fine items (stemware, utensils, espresso cups), ProWash adaptive cycle that adjusts wash intensity per load sensor readings, quieter 39-44 dB noise profiles typical, premium trim hardware. For service, Whirlpool-family parts inventory covers most common KitchenAid service items (drain pump, inlet valve, heating element, capacitors, common sensors); KitchenAid-specific items (FreeFlex rack hardware, panel-ready trim parts, premium control interface) source separately but through the same Whirlpool parts channel. Repair pricing runs slightly above mainstream Whirlpool, below Bosch 800 Series."
  },
  {
    q: "What KitchenAid dishwasher models are most common in LA?",
    a: "KDTE, KDTM, and KDPE families dominate our LA KitchenAid dishwasher service — 24-inch built-in configurations with FreeFlex Third Rack, ProWash, stainless interior, panel-ready option on higher trim. KDTE series runs mid-premium trim (~$1,000-$1,400 retail), KDTM runs premium trim (~$1,300-$1,700), KDPE runs upper-premium trim with panel-ready integration (~$1,600-$2,200). All three share Whirlpool chassis backbone with KitchenAid finish and feature upgrades. LA installs concentrate in premium-kitchen geographies: Westside remodels (Brentwood, Pacific Palisades, Mar Vista), Hollywood Hills, Encino + Calabasas Valley premium, Pasadena + San Marino, Beverly Hills secondary kitchens. Common alongside KitchenAid refrigeration in coordinated Whirlpool-family premium kitchen suites."
  },
  {
    q: "Our KitchenAid FreeFlex Third Rack won't stay in position — what's wrong?",
    a: "FreeFlex Third Rack relies on articulating hardware (rail, roller, tine-adjust mechanism) that wears at 5-8 years on daily-use households. Failure modes: (1) rail roller wear — rack doesn't slide smoothly; $160–$240 rail + roller service; (2) tine-adjust mechanism broken — tines don't fold up/down properly; $140–$240 mechanism swap; (3) rack-height-adjust hardware fault — Third Rack drops or binds when adjusted; $180–$280 height-adjust service; (4) rack hanger attachment point broken (plastic fatigue over years) — $120–$200 part. Third Rack service is tuition-level inexpensive vs. full rack replacement — we typically service the specific worn hardware rather than swap the full rack."
  },
  {
    q: "KitchenAid dishwasher won't start or showing fault — what's the diagnostic?",
    a: "Most common KitchenAid won't-start diagnostic order: (1) door latch + switch — latch not fully engaged signals won't-start to control board; $200–$320 service; (2) control-panel lockout — Cycle Cancel, Control Lock, or Sabbath Mode engaged; user-side fix, $89 diagnostic if that's it; (3) power supply — circuit breaker tripped, GFCI outlet reset; often free diagnostic; (4) control board fault — $380–$580 swap when isolated; (5) main circulation pump lockup — motor seized prevents start sequence; $420–$620 pump replacement. ProWash-equipped models occasionally show sensor-reading faults that mimic start-fail — sensor calibration or replacement $180–$280. Our techs work through this sequence to avoid defaulting to control-board replacement as the first quote."
  },
  {
    q: "What does KitchenAid dishwasher repair cost in LA?",
    a: "Residential diagnostic is $89, waived when you authorize the repair. Common KitchenAid bands: drain filter clean $89 (often free at diagnostic); drain pump $240–$360; inlet valve $240–$380; door latch + switch $200–$320; door gasket $240–$400 (panel-ready profiles run upper end); heating element $280–$440; FreeFlex rail + roller $160–$240; FreeFlex tine-adjust $140–$240; FreeFlex rack hanger $120–$200; ProWash sensor $180–$280; control board $380–$580; membrane switch + panel $260–$440; main circulation pump $420–$620; panel-ready trim hardware (custom panel units) quoted individually. Whirlpool-family parts network delivers 2-5 day typical on common items, 5-10 day specialty."
  }
];

const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair — KitchenAid Dishwasher Service",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": canonical, "telephone": "+1-424-325-0520", "priceRange": "$$$",
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ]
  },
  { "@context": "https://schema.org", "@type": "Service", "serviceType": "KitchenAid Dishwasher Repair",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "description": "KitchenAid dishwasher repair across LA — KDTE / KDTM / KDPE families, FreeFlex Third Rack, ProWash adaptive cycle, stainless tub, panel-ready built-in. Whirlpool premium sub-brand, platform-shared parts with Whirlpool family. $89 residential diagnostic waived with repair.",
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, waived with repair" } }
  },
  { "@context": "https://schema.org", "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
  },
  { "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "KitchenAid", "item": "https://samedayappliance.repair/brands/kitchenaid/" },
      { "@type": "ListItem", "position": 4, "name": "KitchenAid Dishwasher Repair", "item": canonical }
    ]
  }
];
