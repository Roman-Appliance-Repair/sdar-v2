---
import Layout from '../../layouts/Layout.astro';

const title = "LG Range Repair LA | ProBake Convection, F-Codes, ThinQ";
const description = "$89 diagnostic waived. LG range repair LA — ProBake Convection, EasyClean, InstaView, SmartThinQ F-code diagnostic. LRE/LRG/LDG series + Studio. (424) 325-0520.";
const canonical = "https://samedayappliance.repair/brands/lg-range-repair/";

const faqs = [
  {
    q: "LG range F-codes — F1 / F3 / F9 / F10 / F11 — what do they mean?",
    a: "These are the most common LG range error codes and we see them across LRE / LRG / LDG series weekly. <b>F1</b> — over-temperature safety trigger; often a stuck relay on the main control board, sometimes a failed temperature sensor. <b>F3</b> — oven temperature sensor (RTD) open or shorted; sensor $80–$140 replacement. <b>F9</b> — oven not heating in the programmed time; element or igniter (gas) or bake element (electric) failure. <b>F10</b> — runaway temperature; safety cutout — replace thermal fuse + investigate root cause. <b>F11</b> — keypad / membrane-switch stuck; touch panel fault. We read the full error history during diagnostic, not just the current code, because rolling F-codes often point at a common wiring fault rather than multiple parts."
  },
  {
    q: "What LG range models are most common in LA?",
    a: "<b>LRE / LREL series (electric smoothtop)</b> — 30 inch slide-in and freestanding; ProBake Convection third-element setup. <b>LRG series (gas)</b> — cast-iron continuous grates, ProBake Convection, EasyClean optional. <b>LDG / LDGL series (dual-fuel)</b> — gas surface + electric oven; common in Westside remodels. <b>LSE / LSEL series (slide-in with InstaView door)</b> — premium LG Studio tier; knock-to-view bonded glass door. <b>LSDL / LSDS slide-in dual-fuel Studio</b> — flagship premium. All major LG US residential ranges route through LG's Huntsville Alabama parts chain (LG started US manufacturing at Huntsville in 2019 for appliances). Part availability is generally strong."
  },
  {
    q: "ProBake Convection isn't browning evenly — is it broken?",
    a: "Maybe, but usually not. ProBake puts the convection heating element at the <b>back wall</b> instead of the top of the oven, and the rear fan pulls air through it. That's different from top-mounted convection and needs a different cooking approach: preheat longer (LG's sensor hits target faster than actual cavity equilibrium suggests), use the lower racks more than you would with top-convection, and avoid crowding — ProBake depends on airflow. If you've followed all that and it's still uneven, check: (1) the rear fan's spinning freely (usually is), (2) the convection element is actually heating (ohm check at 15-30 ohms typical), (3) the fan motor bearings aren't noisy (bearing failure = airflow dropoff). $160–$280 convection element / $220–$380 fan motor if either has failed."
  },
  {
    q: "SmartThinQ won't pair or keeps losing connection — what to check?",
    a: "Standard LG SmartThinQ recovery on ranges (same pattern as LG microwaves + refrigerators): (1) make sure your router is broadcasting <b>2.4 GHz</b> — LG appliances don't connect on 5 GHz-only networks. If your router auto-bridges bands, set a 2.4 GHz-only SSID for pairing. (2) In the ThinQ app, remove the range completely (not just disconnect) and re-add from scratch — the app's internal device list corrupts after router changes or firmware updates. (3) Power-cycle the range at the breaker for 60 seconds between retries. (4) If pairing still fails, the WiFi module inside the range ($180–$280) is the likely cause. We run the sequence during diagnostic before recommending the module swap."
  },
  {
    q: "EasyClean vs self-clean — what's actually different and can I still use self-clean?",
    a: "LG offers <b>two cleaning modes</b> on most electric ranges: EasyClean is a 10-minute low-temperature steam-assist clean (water in the bottom of the cavity, 200°F), intended for light cleanup. Full pyrolytic self-clean at 850°F is still available on most models — the mode just isn't the default. For light weekly cleanup, EasyClean is the cheaper mode on parts wear (no pyrolytic stress on door seals + lock mechanism). For hard baked-on residue, pyrolytic is still the right tool. If your self-clean isn't initiating, the <b>door-lock motor</b> ($140–$240) is the most common failure, followed by the <b>high-temperature thermistor</b> ($100–$180). We diagnose which before quoting."
  },
  {
    q: "What does LG range repair cost in LA?",
    a: "Residential diagnostic $89 waived with repair. Typical LG range bands: bake element (electric) $140–$240; gas surface igniter $120–$220; oven temperature sensor RTD $80–$140; main control board (LRE/LRG) $280–$440; LG Studio control board $340–$520; ProBake convection element $160–$280 / fan motor $220–$380; InstaView bonded door assembly (LSE Studio) $440–$680; SmartThinQ WiFi module $180–$280; door-lock motor $140–$240; thermal fuse $40–$80. Dual-fuel LDG repairs often combine gas-side + electric-side diagnostics — plan on two-stage quote."
  }
];

const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair — LG Range Service",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": canonical, "telephone": "+1-424-325-0520", "priceRange": "$$"
  },
  { "@context": "https://schema.org", "@type": "Service", "serviceType": "LG Range Repair",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "description": "LG range repair across LA — LRE/LREL electric, LRG gas, LDG/LDGL dual-fuel, LSE/LSDL Studio with InstaView. ProBake rear-fan Convection, EasyClean + pyrolytic self-clean, SmartThinQ WiFi, F-code diagnostic. LG Huntsville AL US manufacturing 2019+. $89 residential diagnostic waived with repair.",
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, waived with repair" } }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "LG", "item": "https://samedayappliance.repair/brands/lg/" },
      { "@type": "ListItem", "position": 4, "name": "LG Range Repair", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">{schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}</Fragment>
  <div class="call-banner"><div class="wrap"><span>LG range service?</span><a href="tel:+14243250520" class="phone-lg">(424) 325-0520</a></div></div>

  <section class="hero"><div class="wrap"><div class="hero-grid"><div class="hero-text">
    <div class="crumb"><a href="/">Home</a> › <a href="/brands/">Brands</a> › LG › Range Repair</div>
    <h1>LG Range Repair in Los Angeles</h1>
    <p class="lede">LG Electronics (Seoul, South Korea; US manufacturing at Huntsville Alabama 2019+) ships ranges across three residential tiers — mass-market LG + LG Studio premium + Signature Kitchen Suite ultra-luxury. The LRE/LRG/LDG series covers electric, gas, and dual-fuel with ProBake rear-fan Convection, EasyClean steam-assist cleanup, and SmartThinQ WiFi diagnostics. LG Studio adds the InstaView knock-to-view bonded door. F-codes (F1/F3/F9/F10/F11) are well-documented and we read full code history during diagnostic rather than reacting to the latest single code — rolling F-codes usually indicate a shared wiring fault rather than multiple parts. Same-day dispatch, $89 residential diagnostic waived with the repair.</p>
    <div class="hero-cta"><a href="tel:+14243250520" class="btn btn-primary">Call (424) 325-0520</a><a href="#book" class="btn btn-ghost">Request a Visit</a></div>
    <ul class="hero-facts">
      <li><b>LRE / LRG / LDG + LSE/LSDL Studio</b> — electric, gas, dual-fuel, slide-in InstaView</li>
      <li><b>ProBake Convection (rear-fan)</b> — distinct from top-convection; different cooking approach</li>
      <li><b>LG Huntsville AL US manufacturing 2019+</b> — parts availability advantage</li>
      <li><b>$89 residential diagnostic</b> — waived when you authorize the repair</li>
    </ul>
  </div><aside class="hero-aside"><div class="aside-card"><h3>Talk to a local branch</h3>
    <a href="tel:+13238704790" class="branch"><b>West Hollywood</b><span>(323) 870-4790</span></a>
    <a href="tel:+14243250520" class="branch"><b>Los Angeles</b><span>(424) 325-0520</span></a>
    <a href="tel:+14242080228" class="branch"><b>Thousand Oaks</b><span>(424) 208-0228</span></a>
    <a href="tel:+16263764458" class="branch"><b>Pasadena</b><span>(626) 376-4458</span></a>
    <a href="tel:+12134019019" class="branch"><b>Irvine</b><span>(213) 401-9019</span></a>
  </div></aside></div></div></section>

  <section class="trust-bar"><div class="wrap"><span>★ 4.6 / 37 Google reviews</span><span>CSLB #1138898 · Insured</span><span>Same-day in 5 SoCal counties</span><span>Residential diagnostic $89 · waived with repair</span></div></section>

  <section class="section"><div class="wrap">
    <h2>What LG range repair costs in LA</h2>
    <table class="price-table">
      <tr><th>Service</th><th>Typical Range</th><th>Notes</th></tr>
      <tr><td>Residential diagnostic</td><td>$89</td><td>Waived with repair</td></tr>
      <tr><td>Bake element (electric)</td><td>$140 – $240</td><td>LRE / LREL smoothtop</td></tr>
      <tr><td>Gas surface igniter</td><td>$120 – $220</td><td>LRG / LDG</td></tr>
      <tr><td>Oven temperature sensor (RTD)</td><td>$80 – $140</td><td>F3 code resolution</td></tr>
      <tr><td>Main control board</td><td>$280 – $440</td><td>LRE / LRG</td></tr>
      <tr><td>Studio control board</td><td>$340 – $520</td><td>LSE / LSDL premium tier</td></tr>
      <tr><td>ProBake convection element / fan motor</td><td>$160 – $380</td><td>Rear-fan architecture</td></tr>
      <tr><td>InstaView door assembly</td><td>$440 – $680</td><td>LSE Studio bonded-glass</td></tr>
      <tr><td>SmartThinQ WiFi module</td><td>$180 – $280</td><td>Pairing / firmware recovery</td></tr>
      <tr><td>Door-lock motor (self-clean)</td><td>$140 – $240</td><td>Most common self-clean failure</td></tr>
    </table>
    <p class="small">Related: <a href="/brands/lg/">LG brand hub</a> · <a href="/brands/lg-microwave-repair/">LG microwave</a> · <a href="/brands/lg-refrigerator-repair/">LG refrigerator</a> · <a href="/brands/signature-kitchen-suite-range-hood-repair/">SKS (LG ultra-luxury)</a> · <a href="/brands/samsung-range-repair/">Samsung range (Korean peer)</a> · <a href="/services/stove-repair/">Range / stove repair (service hub)</a> · <a href="/price-list/range-repair-cost/">Range repair cost</a>.</p>
  </div></section>

  <section class="section alt"><div class="wrap narrow">
    <h2>LG tier disambig — LG vs LG Studio vs Signature Kitchen Suite</h2>
    <p>Three tiers, three parts catalogs, three pricing bands. Knowing which tier you own matters for first-dispatch parts accuracy.</p>
    <ul style="list-style:none; padding:0; margin:14px 0;">
      <li style="padding:6px 0;"><b>LG (mass-market)</b> — LRE/LREL electric, LRG gas, LDG dual-fuel. Most common. ProBake + ThinQ; no InstaView on base.</li>
      <li style="padding:6px 0;"><b>LG Studio (premium)</b> — LSE/LSEL/LSDL slide-in + dual-fuel. InstaView knock-to-view bonded door; ThinQ WiFi. Studio control boards are a separate parts SKU from mass-market LG — not cross-fit.</li>
      <li style="padding:6px 0;"><b>Signature Kitchen Suite (ultra-luxury)</b> — separate LG luxury brand, dedicated dealer channel, 36/48 inch dual-fuel sous-vide flagship. See <a href="/brands/signature-kitchen-suite-range-hood-repair/">SKS context</a>.</li>
    </ul>
  </div></section>

  <section class="section"><div class="wrap narrow">
    <h2>LG range repair — frequently asked</h2>
    {faqs.map(f => (<details class="faq"><summary>{f.q}</summary><p set:html={f.a}></p></details>))}
  </div></section>

  <section id="book" class="cta-bottom"><div class="wrap">
    <h2>LG range service? Call the branch closest to your home.</h2>
    <p>Same-day appliance repair in Los Angeles, Orange County, Ventura County. Residential diagnostic $89, waived with repair.</p>
    <div class="branches">
      <a href="tel:+13238704790"><b>West Hollywood</b><span>(323) 870-4790</span></a>
      <a href="tel:+14243250520"><b>Los Angeles</b><span>(424) 325-0520</span></a>
      <a href="tel:+14242080228"><b>Thousand Oaks</b><span>(424) 208-0228</span></a>
      <a href="tel:+16263764458"><b>Pasadena</b><span>(626) 376-4458</span></a>
      <a href="tel:+12134019019"><b>Irvine</b><span>(213) 401-9019</span></a>
    </div>
  </div></section>
  <a href="tel:+14243250520" class="float-call" aria-label="Call now">☎ Call (424) 325-0520</a>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  body { color: var(--text); } .wrap { max-width: 1200px; margin: 0 auto; padding: 0 24px; } .wrap.narrow { max-width: 820px; }
  h1 { font-size: 2.4rem; line-height: 1.15; margin: 12px 0 20px; color: var(--black); }
  h2 { font-size: 1.8rem; margin: 0 0 16px; color: var(--black); }
  p { line-height: 1.65; margin: 0 0 14px; }
  .call-banner { background: var(--red); color: #fff; padding: 10px 0; }
  .call-banner .wrap { display:flex; gap: 14px; align-items: center; justify-content: center; flex-wrap: wrap; }
  .call-banner .phone-lg { color:#fff; font-weight: 800; text-decoration: underline; font-size: 1.05rem; }
  .hero { background: var(--black); color: #fff; padding: 42px 0 56px; } .hero h1 { color: #fff; }
  .hero .lede { font-size: 1.06rem; color: #d7d7d7; max-width: 680px; }
  .hero .crumb { color: #9a9a9a; font-size: 0.85rem; margin-bottom: 6px; } .hero .crumb a { color: #c9c9c9; text-decoration: none; }
  .hero-grid { display: grid; grid-template-columns: 1.6fr 1fr; gap: 40px; align-items: start; }
  .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; margin: 18px 0 24px; }
  .btn { display: inline-block; padding: 12px 20px; border-radius: 4px; text-decoration: none; font-weight: 700; }
  .btn-primary { background: var(--red); color: #fff; } .btn-ghost { background: transparent; color: #fff; border: 1px solid #fff; }
  .hero-facts { list-style: none; padding: 0; margin: 0; color: #c9c9c9; font-size: 0.95rem; }
  .hero-facts li { padding: 6px 0; border-top: 1px solid #222; } .hero-facts li:first-child { border-top: 0; }
  .hero-aside .aside-card { background: #111; border: 1px solid #222; padding: 20px; border-radius: 6px; } .hero-aside h3 { color: #fff; }
  .branch { display:flex; justify-content: space-between; padding: 10px 0; border-top: 1px solid #222; color: #fff; text-decoration: none; }
  .branch:first-of-type { border-top: 0; } .branch b { color: #fff; } .branch span { color: #ff5a6e; font-weight: 700; }
  .trust-bar { background: var(--red); color: #fff; padding: 14px 0; }
  .trust-bar .wrap { display: flex; gap: 28px; flex-wrap: wrap; justify-content: center; font-size: 0.95rem; font-weight: 600; }
  .section { padding: 56px 0; } .section.alt { background: var(--gray); }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 14px; background: #fff; }
  .price-table th, .price-table td { text-align: left; padding: 11px 12px; border-bottom: 1px solid var(--border); }
  .price-table th { background: var(--black); color: #fff; font-weight: 700; font-size: 0.95rem; }
  .small { color: var(--muted); font-size: 0.92rem; margin-top: 12px; }
  .faq { background: #fff; border: 1px solid var(--border); padding: 12px 16px; margin-bottom: 8px; border-radius: 4px; }
  .faq summary { font-weight: 700; cursor: pointer; padding: 4px 0; } .faq p { margin: 8px 0 0; }
  .cta-bottom { background: var(--black); color: #fff; padding: 48px 0; } .cta-bottom h2 { color: #fff; } .cta-bottom p { color: #c9c9c9; }
  .cta-bottom .branches { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 14px; margin-top: 22px; }
  .cta-bottom .branches a { display: flex; justify-content: space-between; background: #1a1a1a; border: 1px solid #333; padding: 14px 18px; color: #fff; text-decoration: none; border-radius: 4px; }
  .cta-bottom .branches a span { color: var(--red); font-weight: 800; }
  .float-call { position: fixed; bottom: 18px; right: 18px; background: var(--red); color: #fff; padding: 14px 18px; border-radius: 40px; text-decoration: none; font-weight: 700; box-shadow: 0 6px 18px rgba(0,0,0,0.28); z-index: 50; font-size: 0.95rem; }
  @media (max-width: 820px) { .hero-grid { grid-template-columns: 1fr; } h1 { font-size: 1.9rem; } .float-call { padding: 11px 14px; font-size: 0.88rem; } .trust-bar .wrap { gap: 14px; font-size: 0.85rem; } }
</style>
