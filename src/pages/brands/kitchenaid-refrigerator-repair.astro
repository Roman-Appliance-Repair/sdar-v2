---
import Layout from '../../layouts/Layout.astro';
import BrandDetailPlaceholder from '../../components/BrandDetailPlaceholder.astro';

const title = "KitchenAid Refrigerator Repair Los Angeles | Built-In";
const description = "KitchenAid fridge repair across LA — built-in French Door, panel-ready column, counter-depth. Whirlpool premium tier. Same-day, $89 diagnostic. (424) 325-0520.";
const canonical = "https://samedayappliance.repair/brands/kitchenaid-refrigerator-repair/";
---

<Layout title={title} description={description} canonical={canonical}>
  <BrandDetailPlaceholder
    brandName="KitchenAid"
    brandSlug="kitchenaid"
    category="Refrigerator"
    categorySlug="refrigerator-repair"
    hubUrl="/brands/kitchenaid/"
  />
</Layout>
