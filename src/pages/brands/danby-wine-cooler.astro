---
// Phase 2 Cluster 4 #4 — Danby wine cooler pillar.
// Brand: Danby Appliances, Canadian, founded 1947 в Streetsville Ontario.
// Marshall family-owned, 75+ years heritage. Tier split: Silhouette
// Professional (commercial-grade $800-1500), Silhouette consumer
// (premium $500-1000), Designer/Standard entry tier ($200-500).
// Critical angle: Silhouette Professional commercial deployments
// в LA restaurants/hospitality.
// Residential pricing ($89). NEW schema pattern via mergeCredentials().

import Layout from '../../layouts/Layout.astro';
import ServiceHero from '../../components/ServiceHero.astro';
import { mergeCredentials } from '../../data/credentials-schema';

const phone = '(323) 870-4790';
const phoneRaw = phone.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/brands/danby-wine-cooler/";

const title = "Danby Wine Cooler Repair Los Angeles — Same Day";
const description = "Danby wine cooler repair across LA. Silhouette Professional commercial-grade, Silhouette consumer, Designer entry-tier. Marshall family Canadian heritage 1947.";

const faqs = [
  { q: "Which Danby tier is mine, и does that change the repair-vs-replace math?", a: "Yes, significantly. Three tiers: Silhouette Professional (commercial-grade, $800-1500 retail when new) — repair almost always makes sense, even на 8-10 year-old units. Silhouette consumer (premium residential, $500-1000) — repair viable when quote comes in под $300; past that, replacement math gets close. Designer / Standard Danby (entry-tier mass-market, $200-500) — replacement usually wins, even на repairs under $200, because remaining service life expectancy is short. We identify your tier during the diagnostic by model number и serial-plate verification, then frame the math honestly before you commit к anything. The fairest service is к tell you upfront which tier you have и what makes economic sense." },
  { q: "Same-day Danby service in LA?", a: "Yes for diagnostic and most common repairs. Most calls received before 2 PM get a tech on-site the same business day. Common service items — door gaskets, evaporator and condenser fan motors, control board components, и thermostat replacements — typically ride on the truck for Silhouette Professional и Silhouette consumer configurations. Less common items may add 1-5 business days for parts ordering through Danby distribution." },
  { q: "Is Danby still family-owned, или has it been acquired?", a: "Danby is a Canadian company founded в 1947 в Streetsville Ontario by the Marshall family, и has been continuously operated by the Marshall family для 75+ years. Family-owned and independent operation. We confirm current ownership status against the manufacturer's own corporate page when ownership questions matter for warranty или parts-source decisions; if you need a current verification before you make a purchase decision, the Danby corporate site is the authoritative reference. Operating context for service — Canadian-based parts distribution generally means reasonable lead times для US shipments, similar к other North American specialty appliance brands." },
  { q: "Can you handle restaurant and hospitality service contracts on Silhouette Professional?", a: "Yes. Silhouette Professional units anchor wine storage в LA restaurants, hotel bars, и hospitality venues across the five-county service area. Multi-unit accounts get a named account manager и net-30 invoicing after the first visit. Quarterly preventative maintenance contracts cover door gasket inspection, condenser cleaning, refrigerant-charge verification under EPA 608, и documentation для health-department compliance. We coordinate scheduling with operational hours к minimize service disruption — work between meal services or during slow afternoon blocks." },
  { q: "Do you carry Danby OEM parts on the truck?", a: "Common service parts ride on every wine cooler truck: door gaskets in standard configurations, evaporator and condenser fan motors, common control board components, drain heaters, и thermostat replacements для Silhouette Professional и Silhouette consumer models. Designer/Standard entry-tier parts: typically not stocked because we don't recommend repair on those units anyway (replacement math wins most of the time). Silhouette Professional specific parts (commercial-grade lock components, alarm features, digital control modules) come через Danby distribution, typically 1-7 business days. We confirm availability before scheduling labor." },
  { q: "How long should a Danby Silhouette Professional last?", a: "Silhouette Professional commercial-grade — 10-15 years с routine maintenance, sometimes longer in mild operating environments. The build quality difference vs consumer Danby is meaningful: heavier compressor mounts, better gaskets, и more robust electrical components. Restaurants и hospitality operators that maintain quarterly service contracts routinely run Silhouette Professional past 12 years. Silhouette consumer typically 7-10 years, Designer/Standard entry-tier 5-8 years. The single biggest variable is condenser cleanliness и door-cycle frequency. Annual maintenance is the highest-ROI service line item на commercial-grade Silhouette Professional installations." }
];

const localBusinessSchema = mergeCredentials({
  '@context': 'https://schema.org', '@type': 'HomeAndConstructionBusiness', '@id': canonical + '#business',
  name: 'Same Day Appliance Repair — Danby Wine Cooler Service',
  url: canonical, telephone: phone, email: 'support@samedayappliance.repair', priceRange: '$$',
  openingHoursSpecification: [
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'], opens: '08:00', closes: '20:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: 'Sunday', opens: '00:00', closes: '00:00' }
  ],
  areaServed: [
    { '@type': 'AdministrativeArea', name: 'Los Angeles County' }, { '@type': 'AdministrativeArea', name: 'Orange County' },
    { '@type': 'AdministrativeArea', name: 'Ventura County' }, { '@type': 'AdministrativeArea', name: 'San Bernardino County' },
    { '@type': 'AdministrativeArea', name: 'Riverside County' }
  ]
});

const serviceSchema = {
  '@context': 'https://schema.org', '@type': 'Service', '@id': canonical + '#service',
  serviceType: 'Danby Wine Cooler Repair',
  name: 'Danby Wine Cooler Repair, Same Day Appliance Repair',
  url: canonical,
  description: 'Same-day Danby wine cooler repair across LA, Orange, Ventura, San Bernardino, and Riverside counties. Silhouette Professional commercial-grade, Silhouette consumer premium, Designer/Standard entry-tier. Marshall family Canadian company since 1947. Honest tier-identification и repair-vs-replace math during diagnostic. EPA 608 Universal certified (#1346255700410), BHGS #A49573, CSLB C-20 HVAC. $89 residential diagnostic, applied toward repair.',
  provider: { '@id': canonical + '#business' },
  areaServed: [
    { '@type': 'AdministrativeArea', name: 'Los Angeles County' }, { '@type': 'AdministrativeArea', name: 'Orange County' },
    { '@type': 'AdministrativeArea', name: 'Ventura County' }, { '@type': 'AdministrativeArea', name: 'San Bernardino County' },
    { '@type': 'AdministrativeArea', name: 'Riverside County' }
  ],
  brand: { '@type': 'Brand', name: 'Danby', sameAs: 'https://www.danby.com/' },
  offers: { '@type': 'Offer', priceSpecification: { '@type': 'PriceSpecification', price: '89.00', priceCurrency: 'USD', description: 'Residential diagnostic fee, applied toward repair' } }
};

const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
const breadcrumbSchema = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
  { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://samedayappliance.repair/' },
  { '@type': 'ListItem', position: 2, name: 'Brands', item: 'https://samedayappliance.repair/brands/' },
  { '@type': 'ListItem', position: 3, name: 'Danby', item: canonical }
]};
const schemaJsons = [localBusinessSchema, serviceSchema, faqSchema, breadcrumbSchema];
---

<Layout title={title} description={description} canonical={canonical}>
<Fragment slot="head-scripts">
  {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
</Fragment>

<ServiceHero
  eyebrow="Wine Cooler · Marshall Family Canadian · Since 1947"
  title="Danby Wine Cooler Repair, Across Southern California"
  subtitle="Silhouette Professional commercial-grade · Silhouette consumer premium · Designer entry-tier. Marshall family Canadian company с 75+ years heritage. Honest tier-identification и repair-vs-replace math during diagnostic. EPA 608 Universal certified, BHGS #A49573. $89 residential diagnostic, waived with repair."
  heroImageTitle="Danby Wine Cooler Repair"
  showBranches={true}
/>

<section class="section">
  <div class="container narrow">
    <p class="section-number">01, About this service</p>
    <h2>The Marshall family Canadian heritage в the wine cooler category</h2>
    <p>
      Danby Appliances was founded в 1947 в Streetsville, Ontario by the Marshall family и has been continuously operated
      by the same family для 75+ years. The brand carries a quiet but meaningful position в the wine cooler category — not
      luxury-tier (EuroCave / Sub-Zero territory), not commodity disposable (Amazon entry-tier), но a multi-tier offering
      that includes genuine commercial-grade equipment в the Silhouette Professional line. The commercial-grade angle
      matters because it's where Danby competes seriously: LA restaurants, hotel bars, и hospitality venues run Silhouette
      Professional units for wine storage и back-of-bar refrigeration, и those operators chose the brand specifically для
      the build quality / price positioning balance.
    </p>
    <p>
      Pricing structure is straightforward: $89 residential diagnostic, waived when you approve the repair. EPA 608 Universal
      certified для refrigerant work, BHGS Registration #A49573, CSLB C-20 HVAC. The first thing we do during the diagnostic
      is identify which tier и which series your specific Danby is — Silhouette Professional commercial-grade, Silhouette
      consumer premium, or Designer/Standard entry-tier — because the repair-vs-replace math diverges meaningfully across
      these tiers и the right answer depends on accurate tier identification.
    </p>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">02, Series and product coverage</p>
    <h2>What we service across the Danby lineup</h2>

    <h3>Silhouette Professional — commercial-grade</h3>
    <p>
      Danby's commercial-grade line — UL certification for restaurant и hospitality use, heavier-gauge construction than
      consumer Silhouette, lock и alarm features standard на most configurations, и electronic temperature control с digital
      display. Capacity varies by configuration. Used heavily в LA restaurants (Hollywood / WeHo / Beverly Hills / Santa
      Monica), hotel bars и hospitality F&B operations, и occasionally serious residential collectors who chose
      commercial-grade reliability without going к full luxury-tier pricing. The build quality difference vs consumer
      Silhouette is real — better compressor mounts, more robust electrical components, longer service-life expectations.
      Repair value math typically favors repair across most failure modes на units under 12 years old.
    </p>

    <h3>Silhouette — consumer premium</h3>
    <p>
      Danby's premium consumer line — solid build для residential wine cooler use, somewhat less robust than Silhouette
      Professional но meaningfully better than entry-tier offerings. Service items cluster around standard wine cooler
      patterns: condenser cleanliness, gasket integrity, fan motor wear, control board electronics. Repair viable when quote
      comes in под $300 на units 6-10 years old; past that, replacement math gets close.
    </p>

    <h3>Designer / Standard Danby — entry-tier</h3>
    <p>
      Mass-market consumer offerings — distributed через big-box retail и occasionally warehouse clubs. Build quality matches
      the price point ($200-500 retail). Service approach honest: we identify the tier и frame the math accurately during
      the diagnostic. For entry-tier units, replacement usually wins the math decision because remaining service life
      expectancy is short и the unit's residual value low. We don't push repairs on disposable equipment.
    </p>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">03, Common failure patterns</p>
    <h2>What we look at first on a Danby call</h2>
    <ul class="bullet-list">
      <li><strong>Tier identification — first step, every time.</strong> Silhouette Professional / Silhouette consumer / Designer entry-tier? The diagnostic identifies this by model number и serial-plate verification before anything else, because the service approach и repair-vs-replace math differ meaningfully across tiers.</li>
      <li><strong>Condenser fouling — LA dust environment.</strong> Restaurants, busy kitchens, и hospitality bar contexts fou condenser coils faster than the manufacturer's specification anticipates. About 30-35% of "not cooling" Danby calls trace к a clogged condenser, no parts needed, just a deep clean and re-test. Quarterly cleaning prevents this entirely on commercial deployments.</li>
      <li><strong>Door gasket compression set — 4-6 years на heavily-cycled commercial units.</strong> Silhouette Professional doors в restaurant deployments cycle hundreds of times per service shift. Gaskets compress permanently и lose seal. Symptom is icing on the evaporator from moisture infiltration plus a cabinet struggling к hold setpoint. Replacement gaskets stocked для common Silhouette Professional configurations.</li>
      <li><strong>Evaporator fan motor wear.</strong> Year 8-12 cluster shows fan bearing wear or motor failure. Symptom is uneven cabinet cooling, warm spots в the upper or rear bottle positions. Replacement motors через Danby parts distribution.</li>
      <li><strong>Control board fade на digital display models.</strong> Newer Silhouette Professional и Silhouette consumer units с digital temperature display и electronic controls show capacitor aging after 8-12 years of duty. Symptom is intermittent display issues, temperature setpoint drift, или controls not responding. We diagnose carefully — control board replacement is meaningful labor и parts cost, и we don't swap on suspicion.</li>
      <li><strong>Lock and alarm components on Silhouette Professional commercial models.</strong> Restaurant и hospitality units often have keyed lock и temperature alarm features. Lock cylinders wear over years of daily use; alarm contacts can develop intermittent connection issues. Replacement parts available through Danby для common configurations.</li>
      <li><strong>Compressor end-of-life on heavy-cycled commercial units.</strong> Year 12-15 cluster on Silhouette Professional в restaurant duty. We frame the math honestly: compressor swap on a commercial-grade Silhouette Professional runs $500-900 typical с EPA 608 refrigerant work, against $1000-1800 replacement для an equivalent new unit. Math usually favors repair on units under 13 years; closer call past that.</li>
    </ul>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">04, Where we work most on Danby</p>
    <h2>The LA Danby footprint our techs know best</h2>
    <p><strong>LA restaurants с serious bar programs — Silhouette Professional commercial deployments.</strong> Hollywood, West Hollywood, Beverly Hills, Santa Monica, и Pasadena restaurants с wine programs или back-of-bar refrigeration. Service approach respects operational hours — work between meal services or during slow afternoon blocks.</p>
    <p><strong>Boutique hotels и hospitality F&B operations.</strong> Beverly Hills, West Hollywood, Santa Monica boutique properties с serious F&B programs use Silhouette Professional в bar back configurations и room service prep. Service approach matches restaurant work — careful around staff, COI on file, scheduling around guest service hours.</p>
    <p><strong>Serious residential wine collectors who chose commercial-grade.</strong> Bel Air, Beverly Hills, и Newport Beach homeowners who chose Silhouette Professional specifically для commercial-grade reliability without going к premium-luxury pricing. Service approach standard residential — но we recognize the customer chose this brand для build-quality reasons.</p>
    <p><strong>Consumer Silhouette across general LA market.</strong> Standard residential wine cooler installations в kitchens, dining rooms, и home libraries. Service approach standard wine cooler diagnostic с tier-appropriate repair-vs-replace framing.</p>
    <p><strong>Entry-tier Designer/Standard Danby across the market.</strong> Apartment kitchens, smaller condo installations, secondary residences. Honest framing на repair-vs-replace math; we don't waste customer money pushing repairs on disposable units.</p>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">05, Recent repairs</p>
    <h2>What this month looked like on Danby</h2>
    <div class="repair-cards">
      <div class="repair-card">
        <p class="repair-quote">"Silhouette Professional in our wine bar climbed past 60°F overnight, и Friday service starts in 4 hours."</p>
        <p>Hollywood Boulevard restaurant с Silhouette Professional commercial-grade unit, install year per the operator approximately 2016. Diagnostic ran condenser first — heavily fouled с airborne grease from the kitchen pass adjacent. Deep-cleaned coil, verified refrigerant charge under EPA 608, ran cabinet pull-down for 90 minutes during the slow afternoon block. Cabinet at 55°F by 5 PM, ready for Friday evening service. Recommended quarterly cleaning contract going forward — operator signed up. The Silhouette Professional was specifically chosen for the bar program because the price-к-build-quality ratio works at this tier; service restored that value proposition.</p>
      </div>
      <div class="repair-card">
        <p class="repair-quote">"Silhouette consumer wine cooler at home stopped cooling, и the cabinet has been getting warmer for weeks."</p>
        <p>Pasadena home, Silhouette consumer premium wine cooler, install year per the homeowner approximately 2017. Diagnostic isolated к evaporator fan motor failure — bearings noisy on test, airflow measurably reduced, cabinet warmth concentrated в upper bottle positions consistent с air-circulation problem (not refrigerant issue). Sourced replacement motor через Danby parts (4 business days), returned for install on second visit, verified normal cabinet cooling. Total service across two visits, $325 quote with parts и labor — under the $400 threshold where repair math still wins clearly on this tier.</p>
      </div>
      <div class="repair-card">
        <p class="repair-quote">"My Designer Danby stopped cooling, what should I do?"</p>
        <p>West Hollywood condo, Designer entry-tier Danby wine cooler, install year per the resident approximately 2019. Diagnostic confirmed compressor failure after only 5 years — within the typical service-life range for entry-tier units но frustrating для the homeowner. Honest math conversation: compressor replacement quote came in at $380 с EPA 608 refrigerant work, against $250-400 для a replacement unit of similar capacity at retail. Recommended replacement, не repair. The homeowner appreciated the honest framing — many shops would have pushed the $380 repair и left the customer с a repaired unit that's already 5 years into a 5-8 year service life. We don't operate that way; tier identification и honest math are part of the service.</p>
      </div>
    </div>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">06, Why us, specifically</p>
    <h2>What makes us a fit for Danby service</h2>
    <ul class="bullet-list">
      <li><strong>Honest tier identification и repair-vs-replace math.</strong> Silhouette Professional commercial-grade vs Silhouette consumer vs Designer entry-tier — completely different service equations. We identify your unit и frame the math before you commit к anything. We don't push $400 repairs on $300 units.</li>
      <li><strong>Restaurant и hospitality service contracts.</strong> Silhouette Professional commercial deployments get quarterly preventative maintenance, named account management, и net-30 invoicing after first visit.</li>
      <li><strong>EPA 608 Universal certification (#1346255700410).</strong> Required для refrigerant work на Danby's compressor-based wine coolers across all tiers. We perform the work legally и document для service records.</li>
      <li><strong>BHGS Registration #A49573 plus CSLB C-20 HVAC.</strong> California state coverage.</li>
      <li><strong>Danby OEM parts only on Silhouette Professional и Silhouette consumer.</strong> No aftermarket substitutions on the tiers where build-quality investment matters.</li>
      <li><strong>$89 residential diagnostic, waived с repair.</strong> Tier identification first, then math-honest recommendation.</li>
      <li><strong>BBB Accredited Business and $1M general liability insured.</strong> COI on request — sometimes required for hotel и hospitality vendor onboarding.</li>
    </ul>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">07, Frequently asked questions</p>
    <h2>The questions we get most on Danby calls</h2>
    <div class="faq-list">
      {faqs.map(f => (<details class="faq-item"><summary>{f.q}</summary><p>{f.a}</p></details>))}
    </div>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">08, Other wine cooler brands we cover</p>
    <h2>Danby service в context</h2>
    <ul class="cross-links">
      <li><a href="/brands/summit-wine-cooler/">Summit wine cooler</a> — commercial-grade Felix Storch alternative</li>
      <li><a href="/brands/vinotemp/">Vinotemp wine cooler + cellar</a> — California specialty company</li>
      <li><a href="/brands/wine-enthusiast-wine-cooler/">Wine Enthusiast wine cooler</a> — dual-tier brand</li>
      <li><a href="/brands/eurocave/">EuroCave wine cellars</a> — French luxury</li>
      <li><a href="/brands/le-cache/">Le Cache wine cabinets</a> — American hardwood</li>
      <li><a href="/brands/whisperkool/">WhisperKool wine cellar cooling</a></li>
      <li><a href="/brands/cellarpro/">CellarPro wine cellar cooling</a></li>
      <li><a href="/services/wine-cooler-repair/">Wine cooler repair (all brands)</a></li>
    </ul>
  </div>
</section>

<section class="bottom-cta">
  <div class="container narrow">
    <h2>Same-day Danby service across Southern California</h2>
    <p>$89 residential diagnostic, waived with repair. EPA 608 Universal certified, BHGS #A49573, CSLB C-20 HVAC, BBB Accredited.</p>
    <div class="cta-row">
      <a href={phoneHref} class="btn-red">Call {phone}</a>
      <a href="/contact/" class="btn-outline">Request service →</a>
    </div>
  </div>
</section>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .section { padding: 64px 24px; }
  .section-gray { background: var(--gray); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .container.narrow { max-width: 820px; margin: 0 auto; }
  .section-number { font-size: 12px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--red); margin: 0 0 12px; }
  h2 { font-size: clamp(22px, 3vw, 32px); font-weight: 700; line-height: 1.2; margin: 0 0 20px; color: var(--text); letter-spacing: -.01em; }
  h3 { font-size: 18px; font-weight: 700; margin: 24px 0 10px; color: var(--text); }
  p { font-size: 16px; line-height: 1.7; color: var(--text); margin: 0 0 14px; }
  strong { font-weight: 700; }
  a { color: var(--red); text-decoration: none; }
  a:hover { text-decoration: underline; }
  .bullet-list { list-style: none; padding: 0; margin: 16px 0; }
  .bullet-list li { position: relative; padding: 12px 0 12px 22px; font-size: 15.5px; line-height: 1.65; border-bottom: 1px solid var(--border); }
  .bullet-list li:last-child { border-bottom: none; }
  .bullet-list li::before { content: "▸"; position: absolute; left: 0; color: var(--red); font-weight: 700; }
  .repair-cards { display: grid; gap: 20px; margin-top: 20px; }
  .repair-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 22px 26px; }
  .repair-quote { font-style: italic; color: var(--red); font-weight: 600; margin: 0 0 12px; font-size: 15px; }
  .repair-card p:last-child { margin-bottom: 0; }
  .faq-list { margin-top: 20px; }
  .faq-item { border-bottom: 1px solid var(--border); padding: 16px 0; }
  .faq-item:last-child { border-bottom: none; }
  .faq-item summary { cursor: pointer; font-weight: 700; font-size: 16px; color: var(--text); padding: 4px 0; }
  .faq-item summary:hover { color: var(--red); }
  .faq-item p { margin: 12px 0 4px; font-size: 15.5px; color: var(--text); }
  .cross-links { list-style: none; padding: 0; margin: 16px 0 0; }
  .cross-links li { padding: 10px 0; border-bottom: 1px solid var(--border); font-size: 15px; }
  .cross-links li:last-child { border-bottom: none; }
  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { color: #fff; }
  .bottom-cta p { color: rgba(255,255,255,.85); max-width: 640px; margin: 0 auto 24px; }
  .bottom-cta a { color: #fff; }
  .cta-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-red { background: var(--red); color: #fff; padding: 14px 28px; border-radius: 6px; font-weight: 600; text-decoration: none; }
  .btn-outline { border: 1.5px solid rgba(255,255,255,.3); color: #fff; padding: 14px 28px; border-radius: 6px; font-weight: 600; text-decoration: none; }
</style>
