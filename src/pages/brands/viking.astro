---
import Layout from '../../layouts/Layout.astro';
import BrandHubPlaceholder from '../../components/BrandHubPlaceholder.astro';

const title = "Viking Appliance Repair Los Angeles | Same Day Service";
const description = "Expert Viking appliance repair across LA, Orange, Ventura counties. All Viking categories — refrigerator, range, bbq grill, oven, cooktop. Call (424) 325-0520.";

const categories = [
  { label: "Refrigerator", url: "/brands/viking-refrigerator-repair/" },
  { label: "Range", url: "/brands/viking-range-repair/" },
  { label: "BBQ Grill", url: "/brands/viking-bbq-grill-repair/" },
  { label: "Oven", url: "/brands/viking-oven-repair/" },
  { label: "Cooktop", url: "/brands/viking-cooktop-repair/" }
];
---

<Layout title={title} description={description}>
  <BrandHubPlaceholder brandName="Viking" brandSlug="viking" categories={categories} />
</Layout>
