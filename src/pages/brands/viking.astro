---
import Layout from '../../layouts/Layout.astro';
import BrandBranchesGrid from '../../components/BrandBranchesGrid.astro';
import { MAIN_PHONE, MAIN_PHONE_TEL } from '../../data/branches';

const title = "Viking Appliance Repair | Southern California | Refrigerator, Range, Grill, Oven, Cooktop";
const description = "Viking appliance repair across Southern California. Professional 7 Series ranges, Tuxedo Collection, 5 Series, Outdoor Series grills (VGBQ/VGIQ), built-in refrigeration, wall ovens, cooktops. Factory-trained. Post-warranty specialists. $89 diagnostic waived with repair. Call (424) 325-0520.";

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": "https://samedayappliance.repair/brands/viking/#business",
    "name": "Same Day Appliance Repair, Viking Service",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": "https://samedayappliance.repair/brands/viking/",
    "telephone": MAIN_PHONE_TEL,
    "priceRange": "$$$$",
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What Viking appliances do you service?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Viking's full residential product line: professional-style ranges (Professional 7 Series, 5 Series, Tuxedo Collection), built-in refrigeration (30\"/36\"/42\"/48\" columns and side-by-side), Outdoor Series gas grills and islands (VGBQ T-Series, VGIQ I-Series), wall ovens (single, double, combi-steam), cooktops (gas sealed-burner, induction, electric), undercounter refrigeration, wine coolers, and range hoods. We don't service Viking dishwashers (Viking VDWU524/525 is an OEM Asko rebadge, for dishwasher service see our Miele or Bosch pages, which are what most Viking kitchen specs actually use). Viking does not make washers, dryers, or microwaves for US market."
        }
      },
      {
        "@type": "Question",
        "name": "Are you Viking-authorized?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No, we're factory-trained but independent. Viking has their own Viking Certified Service network of authorized contractors. Inside the Viking 3-year residential warranty, call Viking customer service at 1-888-845-4641 for authorized service dispatch at no parts cost. Post-warranty, we're the better call: faster response, lower labor rate, same training on Professional 7, Tuxedo, 5 Series, Outdoor Series, and legacy platforms. Most of our Viking calls are 4-to-15-year-old units outside the warranty window."
        }
      },
      {
        "@type": "Question",
        "name": "My Viking is the 'fridge side' of my kitchen, do you handle that?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, Viking refrigeration is actually our most common Viking call in LA. The Viking 7 Series built-in refrigerator (BI-series columns, side-by-side, over-and-under) is specified in many LA luxury kitchens as the alternative to Sub-Zero when the homeowner wants Viking aesthetic consistency with their Viking range. Common issues we service: compressor start relay, evaporator fan, condenser cleaning, defrost system, ice maker module, door gasket. Viking 7 Series fridges are factory-trained service territory for us. See our dedicated Viking refrigerator page for full details."
        }
      },
      {
        "@type": "Question",
        "name": "Can you service my Viking outdoor grill?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Viking Outdoor Series grills (VGBQ T-Series, VGIQ I-Series, 30\"/36\"/41\"/53\" widths) are a significant part of our Viking service work, common in Malibu, Bel Air, Calabasas, and Pacific Palisades outdoor kitchens. Typical repairs: U-burner replacement, igniter module (2-output and 4-output Quikliter modules), spark electrodes, heat distribution plates, cooking grates, rotisserie motors, gas regulators, infrared sear burners, flame throwers. We carry common Outdoor Series parts and source model-specific components from Viking distribution. See our dedicated Viking BBQ and grill page for full details."
        }
      },
      {
        "@type": "Question",
        "name": "How much does Viking repair cost?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Diagnostic is $89, waived with repair. Typical Viking repairs vary by category. Refrigerator: compressor start relay $95-$155, evaporator fan $320-$460, door gasket $285-$420, control board $580-$820. Range (Professional 7): spark module $285-$425, surface igniter $185-$275, oven igniter (gas) $245-$340, bake element (dual-fuel) $225-$325, control board $640-$920. Outdoor Grill: U-burner $125-$185, spark electrode $65-$95, Quikliter ignition module $95-$145, rotisserie motor $185-$265, infrared sear burner $285-$425. Oven (wall): heating element $265-$385, convection fan $285-$420. Cooktop: surface igniter $185-$275, spark module $285-$425, induction inverter $620-$885. Labor and parts quoted before work starts."
        }
      },
      {
        "@type": "Question",
        "name": "How long should a Viking last?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Viking is built to commercial-grade standards, 20+ years of service life is common on ranges and refrigerators in LA kitchens where original installs from 2000-2010 are still running. Outdoor grills live a shorter life because of weather exposure: coastal Malibu and Pacific Palisades grills see 8-12 years before serious corrosion; inland Calabasas and Hidden Hills grills typically last 12-15 years. Component-level repairs are always cheaper than replacement, a $500 evaporator fan or a $300 burner set pencils out against a $12,000 built-in fridge or a $6,000 grill. We give honest repair-versus-replace assessments on every call."
        }
      }
    ]
  }
];
---
<Layout title={title} description={description}>
  <Fragment slot="head-scripts">
    {schemaJsons.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </Fragment>

  <section class="hero">
    <div class="hero-inner">
      <div class="hero-content">
        <p class="hero-eyebrow">LA · Orange · Ventura · San Bernardino · Riverside Counties</p>
        <h1>Viking Appliance Repair</h1>
        <p class="hero-sub">Factory-trained service for the full Viking residential line: Professional 7 Series ranges, Tuxedo Collection, 5 Series, Outdoor Series grills, built-in refrigeration, wall ovens, and cooktops. Commercial-heritage engineering, premium kitchens across Southern California, Bel Air, Beverly Hills, Malibu, Pacific Palisades, Calabasas, and Hidden Hills on LA's Westside; Newport Coast, Coto de Caza, and Newport Beach in OC; Westlake Village and Thousand Oaks in Ventura; and Rancho Cucamonga and Temecula wine-country in the IE.</p>
        <div class="hero-ctas">
          <a href={`tel:${MAIN_PHONE_TEL}`} class="btn-primary">☎ {MAIN_PHONE}</a>
          <a href="/contact/" class="btn-outline">Book Online</a>
        </div>
      </div>
      <div class="hero-img-wrap">
        <div class="hero-img-placeholder">
          <p>Viking Appliance Repair</p>
          <p>Across Southern California</p>
        </div>
      </div>
    </div>
  </section>

  <div class="trust-bar">
    <div class="trust-bar-inner">
      <div class="trust-item"><span class="trust-icon">🏅</span> BHGS Licensed #A49573</div>
      <div class="trust-item"><span class="trust-icon">🛡</span> Fully Insured</div>
      <div class="trust-item"><span class="trust-icon">⚡</span> Same Day Available</div>
      <div class="trust-item"><span class="trust-icon">🔩</span> OEM Parts on Truck</div>
      <div class="trust-item"><span class="trust-icon">💬</span> $89 Diagnostic, Waived With Repair</div>
    </div>
  </div>

  <!-- ── ABOUT ── -->
  <section class="section">
    <div class="container">
      <p class="eyebrow-sub">About the brand</p>
      <h2>Viking invented the residential pro range, and kept building.</h2>
      <p>Viking Range was founded in 1987 on a specific engineering bet: professional restaurant-grade cooking performance, certified and warranted for residential installation. The first Viking ranges brought 15,000+ BTU sealed burners, full-size convection ovens, and commercial-style cast-iron grates into American home kitchens. Over nearly four decades since, the line has grown into a full premium kitchen suite, Professional 7 Series ranges that still carry the commercial heritage, the Tuxedo Collection with matte-black aesthetic for contemporary kitchens, Outdoor Series grills that dominate outdoor kitchens from Malibu to Calabasas, and built-in refrigeration that competes directly with Sub-Zero in LA's premium market.</p>
      <p>The Viking engineering philosophy shows in service. Components are built heavier than competitors at the same price point, gas valve assemblies are commercial-grade, oven cavity walls are thicker steel, refrigerator compressors are over-specified for residential duty cycles. That means Vikings last longer (20+ year service lives are common on 2000s-era ranges and fridges we still service in LA), but it also means service requires technicians who understand commercial-grade components and don't try to swap in residential-grade parts as a "cheaper alternative." Genuine Viking parts from authorized distribution; commercial-grade diagnostics; no shortcuts.</p>
      <p>Most of our Viking calls come from kitchens where Viking was specified during 2000-2020 construction or major remodels, Bel Air, Beverly Hills, Brentwood, Pacific Palisades, Malibu, Calabasas, Hidden Hills, and the Pasadena foothills on LA's Westside; Newport Coast, Coto de Caza, Newport Beach, and Shady Canyon in OC; Westlake Village, Thousand Oaks, and the Conejo Valley in Ventura; and Rancho Cucamonga, Temecula wine-country, and Murrieta hillsides in the IE. These are post-warranty units (Viking residential warranty is 3 years) where independent factory-trained service at a lower labor rate is the right fit. We're the right call for 5-to-20-year-old Viking ranges, fridges, grills, and ovens.</p>
    </div>
  </section>

  <!-- ── CATEGORIES ── -->
  <section class="section section-alt">
    <div class="container">
      <p class="eyebrow-sub">What we repair</p>
      <h2>Viking categories we service</h2>
      <div class="cat-grid">
        <a href="/brands/viking-refrigerator-repair/" class="cat-card">
          <h3>Viking Refrigerator Repair</h3>
          <p>7 Series built-in refrigeration, 5 Series, side-by-side, over-and-under, column configurations 30"/36"/42"/48". Wine coolers, undercounter refrigeration. Compressor, evaporator, control, and door service.</p>
          <span class="cat-cta">View refrigerator repair →</span>
        </a>
        <a href="/brands/viking-range-repair/" class="cat-card">
          <h3>Viking Range Repair</h3>
          <p>Professional 7 Series ranges, Tuxedo Collection, 5 Series. 30", 36", 48", 60" widths. All-gas, dual-fuel, induction. Sealed-burner ignition, oven convection, self-clean, door hinges, control boards.</p>
          <span class="cat-cta">View range repair →</span>
        </a>
        <a href="/brands/viking-bbq-grill-repair/" class="cat-card">
          <h3>Viking BBQ &amp; Grill Repair</h3>
          <p>Outdoor Series VGBQ T-Series and VGIQ I-Series grills. 30"/36"/41"/53" widths. U-burner replacement, igniter modules, rotisserie, infrared sear burners, flame throwers, regulators.</p>
          <span class="cat-cta">View BBQ/grill repair →</span>
        </a>
        <a href="/brands/viking-oven-repair/" class="cat-card">
          <h3>Viking Oven Repair</h3>
          <p>Wall ovens, single, double, combi-steam. 27", 30", 36" widths. Heating elements, convection fans, door hinges, self-clean latch motors, control boards, steam-generator service.</p>
          <span class="cat-cta">View oven repair →</span>
        </a>
        <a href="/brands/viking-cooktop-repair/" class="cat-card">
          <h3>Viking Cooktop Repair</h3>
          <p>Gas sealed-burner cooktops, induction cooktops, electric cooktops. 30"/36" widths. Spark ignition, burner valves, induction inverter boards, sensor grids, ceramic glass service.</p>
          <span class="cat-cta">View cooktop repair →</span>
        </a>
        <div class="cat-card static">
          <h3>Viking Range Hoods &amp; Ventilation</h3>
          <p>Professional range hoods (Professional, Designer, Tuxedo). Blower motors, lighting, filter service, duct diagnostics. Section coverage on hub; call for specific model service.</p>
          <span class="cat-cta">Call {MAIN_PHONE}</span>
        </div>
        <div class="cat-card static">
          <h3>Viking Outdoor Refrigerators</h3>
          <p>VBUR outdoor undercounter, VRUO outdoor refrigerator drawers, outdoor beverage centers. Paired with Viking Outdoor Series grills in full-Viking outdoor kitchens. Coming soon, call for current service.</p>
          <span class="cat-cta">Call {MAIN_PHONE}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── SOCAL MARKET CONTEXT ── -->
  <section class="section">
    <div class="container narrow">
      <p class="eyebrow-sub">Viking in Southern California</p>
      <h2>Why Viking in Southern California is a fridge-first brand, not just a range brand</h2>
      <p>Viking's reputation is built on the Professional 7 range, commercial-style burners, cast-iron grates, the signature red control knob. But in our Southern California service area specifically, the pattern we see from service calls is different: Viking refrigeration is the most common Viking service call, not the range. Why? Two reasons.</p>
      <p>First, many Southern California kitchens specified Viking refrigeration as the alternative to Sub-Zero when the homeowner wanted aesthetic consistency across a fully Viking-branded kitchen, Viking range plus Viking fridge plus Viking hood. That pattern shows up across the Westside LA luxury corridor, Newport Beach and Newport Coast, the Conejo Valley estate market, and the Temecula and Rancho Cucamonga estate corridor. The 7 Series built-in fridge is engineered to match the range visually (same stainless finish, same commercial design language) and is a legitimate refrigeration choice, not a compromise. Second, the fridge gets used 24/7 every day for 20 years, the range gets heavy use but has more idle hours than a fridge does. Fridges accumulate service-needed component wear faster.</p>
      <p>The Southern California Viking market has another distinctive feature: <strong>outdoor kitchens</strong>. Viking Outdoor Series is one of the most specified outdoor grill brands in Malibu, Bel Air, Calabasas, and the Pasadena foothills on the LA side; in Newport Coast, Coto de Caza, and Shady Canyon in OC; in Hidden Hills and Westlake Village in Ventura; and across the Temecula wine-country and Rancho Cucamonga estate corridor in the IE. VGBQ 30", 36", 41", and 53" built-in grills, often paired with Viking refrigerator drawers, outdoor side burners, and Viking ventilation, represent a significant service stream that most general appliance shops don't handle at factory-trained depth. Our outdoor grill service is a real specialty, not an afterthought.</p>
    </div>
  </section>

  <!-- ── WARRANTY ── -->
  <section class="section section-alt">
    <div class="container narrow">
      <p class="eyebrow-sub">Warranty context</p>
      <h2>Viking residential warranty, and when to call us</h2>
      <p>Viking residential warranty is <strong>3 years on all parts and labor</strong> for most product lines, generous by industry standards (Sub-Zero and Miele are 2 years on base parts). During the warranty window, call Viking customer service at <strong>1-888-845-4641</strong> for Viking Certified Service dispatch at no parts cost.</p>
      <p>Post-warranty work is where we operate. Most of our Viking calls are units 4-to-20-year-old where the warranty has closed. Same factory training, faster response, lower labor rate than a post-warranty Viking Certified dispatch. For integrated Viking kitchens, Viking range + fridge + grill + hood, we service all categories on a single visit. One dispatch, one invoice, one technician trained on the full Viking platform.</p>
    </div>
  </section>

  <!-- ── SERVICE AREAS ── -->
  <section class="section">
    <div class="container">
      <p class="eyebrow-sub">Where we work</p>
      <h2>Viking service across Southern California</h2>
      <p>Eight service territories cover all five counties, Los Angeles, Orange, Ventura, San Bernardino, and Riverside. Viking density is highest in Bel Air, Beverly Hills, Holmby Hills, Brentwood, Malibu, Pacific Palisades, Calabasas, Hidden Hills, and the Pasadena foothills on LA's Westside; Newport Coast, Newport Beach, and Coto de Caza in OC; Westlake Village and Thousand Oaks in Ventura; and the Rancho Cucamonga and Temecula wine-country estate corridors in the IE. Outdoor grill service extends to the outdoor-kitchen districts, Malibu beachfront, Calabasas hillside estates, Hidden Hills gated properties, Newport Coast oceanside builds, Coto de Caza estate properties, and Temecula wine-country, where Viking Outdoor Series is the dominant spec.</p>
      <BrandBranchesGrid showHeader={false} />
    </div>
  </section>

  <!-- ── CREDENTIALS ── -->
  <section class="section section-alt">
    <div class="container narrow">
      <p class="eyebrow-sub">Credentials</p>
      <h2>Licensed, insured, EPA-certified</h2>
      <p>We hold an active CSLB C-20 HVAC license, covering HVAC scope work. Viking refrigeration and outdoor grill sealed-system service requires EPA 608 refrigerant handling certification; all our technicians are EPA 608 Universal certified (#1346255700410) plus BHGS #A49573. We carry general liability and workers' comp. BHGS-registered under <strong>#A49573</strong>. BBB A+ since 2022.</p>
      <p>See the <a href="/credentials/">full credentials page</a> for license verification links.</p>
    </div>
  </section>

  <!-- ── FAQ ── -->
  <section class="section">
    <div class="container narrow">
      <p class="eyebrow-sub">FAQ</p>
      <h2>Viking service, common questions</h2>

      <details class="faq">
        <summary>What Viking appliances do you service?</summary>
        <p>Ranges (Professional 7, Tuxedo, 5 Series), built-in refrigeration (7 Series, columns, side-by-side, undercounter, wine), Outdoor Series grills (VGBQ, VGIQ), wall ovens (single, double, combi-steam), cooktops (gas, induction, electric), range hoods. Not dishwashers (Viking DW = Asko rebadge), no washers/dryers/microwaves (Viking doesn't make those for US).</p>
      </details>

      <details class="faq">
        <summary>Are you Viking-authorized?</summary>
        <p>No, factory-trained but independent. Inside 3-year Viking warranty, call 1-888-845-4641 for authorized service at no parts cost. Post-warranty: faster response, lower labor rate, same training.</p>
      </details>

      <details class="faq">
        <summary>Is Viking a fridge brand or a range brand?</summary>
        <p>Both, in LA, we actually see more fridge calls than range calls. Viking 7 Series built-in refrigeration is specified as an alternative to Sub-Zero in Viking-consistent kitchens. Fridges run 24/7 and accumulate wear faster than ranges. Our Viking refrigerator page has details.</p>
      </details>

      <details class="faq">
        <summary>Can you fix my outdoor grill?</summary>
        <p>Yes, Viking Outdoor Series (VGBQ/VGIQ) is a specialty. Burners, igniters, rotisserie, infrared sear, regulators. Common in Malibu, Bel Air, Calabasas outdoor kitchens. Dedicated page for BBQ/grill service.</p>
      </details>

      <details class="faq">
        <summary>How long does a Viking last?</summary>
        <p>Indoor appliances 20+ years (we service 2000-era Vikings still running). Outdoor grills 8-15 years depending on weather exposure (coastal Malibu shorter, inland Hidden Hills longer). Component repairs cheaper than replacement through most of the life cycle.</p>
      </details>

      <details class="faq">
        <summary>How much does Viking repair cost?</summary>
        <p>Diagnostic $89, waived with repair. Category-specific pricing on individual pages: refrigerator compressor relay $95-$155, range spark module $285-$425, grill U-burner $125-$185, oven heating element $265-$385, induction inverter $620-$885.</p>
      </details>

      <details class="faq">
        <summary>Do you handle integrated Viking kitchens?</summary>
        <p>Yes, range + fridge + grill + hood on a single dispatch. One visit, one invoice, one technician trained on the full Viking platform. Preferred for homeowners with all-Viking kitchen specs.</p>
      </details>
    </div>
  </section>

  <!-- ── BOTTOM CTA ── -->
  <section class="bottom-cta">
    <div class="container">
      <h2>Ready to schedule Viking service?</h2>
      <p>Same day available. $89 diagnostic, waived with repair. Labor and parts quoted before we start.</p>
      <div class="hero-ctas">
        <a href={`tel:${MAIN_PHONE_TEL}`} class="btn-primary">☎ Call {MAIN_PHONE}</a>
        <a href="/contact/" class="btn-outline">Book Online</a>
      </div>
    </div>
  </section>

<style>
  :root {
    --red: #C8102E;
    --black: #0a0a0a;
    --gray: #f5f5f5;
    --border: #e2e2e2;
    --text: #1a1a1a;
    --muted: #6b6b6b;
    --white: #ffffff;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; color: var(--text); line-height: 1.6; }

  .hero { background: var(--black); color: #fff; padding: 80px 24px 72px; }
  .hero-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; max-width: 1100px; margin: 0 auto; align-items: center; }
  .hero-eyebrow { font-size: 13px; color: var(--red); text-transform: uppercase; letter-spacing: .12em; margin-bottom: 16px; font-weight: 600; }
  .hero h1 { font-size: clamp(28px, 4vw, 46px); font-weight: 700; color: #fff; margin-bottom: 20px; line-height: 1.15; font-family: 'Playfair Display', Georgia, serif; }
  .hero-sub { font-size: 17px; color: rgba(255,255,255,.72); margin-bottom: 28px; }
  .hero-ctas { display: flex; gap: 12px; margin-bottom: 28px; flex-wrap: wrap; }
  .btn-primary { display: inline-block; padding: 14px 28px; background: var(--red); color: #fff; text-decoration: none; border-radius: 6px; font-weight: 600; font-size: 16px; transition: background .2s; }
  .btn-primary:hover { background: #a50d25; }
  .btn-outline { display: inline-block; padding: 14px 28px; border: 1.5px solid rgba(255,255,255,.35); color: #fff; text-decoration: none; border-radius: 6px; font-weight: 600; font-size: 16px; transition: all .2s; }
  .btn-outline:hover { background: rgba(255,255,255,.08); border-color: #fff; }
  .hero-img-wrap { aspect-ratio: 4/3; background: #1a1a1a; border-radius: 4px; display: flex; align-items: center; justify-content: center; }
  .hero-img-placeholder { color: rgba(255,255,255,.35); font-size: 14px; text-align: center; }
  @media (max-width: 768px) { .hero-inner { grid-template-columns: 1fr; } .hero-img-wrap { display: none; } }

  .trust-bar { background: var(--red); color: #fff; padding: 16px 24px; }
  .trust-bar-inner { max-width: 1100px; margin: 0 auto; display: flex; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
  .trust-item { font-size: 13px; font-weight: 600; display: flex; align-items: center; gap: 8px; }
  .trust-icon { font-size: 16px; }

  .section { padding: 72px 24px; }
  .section-alt { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; }
  .container.narrow { max-width: 780px; }
  .eyebrow-sub { font-size: 13px; color: var(--red); text-transform: uppercase; letter-spacing: .12em; margin-bottom: 12px; font-weight: 600; }
  h2 { font-size: clamp(24px, 3vw, 34px); font-weight: 700; margin-bottom: 20px; line-height: 1.2; font-family: 'Playfair Display', Georgia, serif; }
  .section p { margin-bottom: 16px; color: var(--text); }

  .cat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 20px; margin-top: 32px; }
  .cat-card { display: block; padding: 24px; background: #fff; border: 1px solid var(--border); border-radius: 8px; text-decoration: none; color: inherit; transition: all .2s; }
  .cat-card:hover { border-color: var(--red); transform: translateY(-2px); box-shadow: 0 4px 16px rgba(0,0,0,.08); }
  .cat-card.static { cursor: default; }
  .cat-card.static:hover { transform: none; box-shadow: none; border-color: var(--border); }
  .cat-card h3 { font-size: 17px; font-weight: 700; margin-bottom: 10px; color: var(--black); font-family: 'Playfair Display', Georgia, serif; }
  .cat-card p { font-size: 14px; color: var(--muted); margin-bottom: 14px; }
  .cat-cta { font-size: 13px; color: var(--red); font-weight: 600; }

  .faq { margin-bottom: 12px; border: 1px solid var(--border); border-radius: 6px; padding: 16px 20px; background: #fff; }
  .faq summary { font-weight: 600; cursor: pointer; font-size: 16px; color: var(--black); }
  .faq[open] summary { margin-bottom: 12px; }
  .faq p { font-size: 15px; color: var(--text); margin-bottom: 0; }

  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { color: #fff; }
  .bottom-cta p { color: rgba(255,255,255,.72); margin-bottom: 24px; }
  .bottom-cta .hero-ctas { justify-content: center; }
</style>
</Layout>
