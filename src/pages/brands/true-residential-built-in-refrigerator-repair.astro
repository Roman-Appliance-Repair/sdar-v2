      <tr><td>Evaporator fan motor (commercial-spec)</td><td>$340 – $480</td><td>Per section</td></tr>
      <tr><td>Defrost heater + thermostat</td><td>$340 – $460</td><td>Freezer defrost cycle</td></tr>
      <tr><td>Door gasket</td><td>$300 – $440</td><td>Per section</td></tr>
