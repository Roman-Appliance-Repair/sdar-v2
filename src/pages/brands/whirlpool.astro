---
import Layout from '../../layouts/Layout.astro';
import BrandHubPlaceholder from '../../components/BrandHubPlaceholder.astro';

const title = "Whirlpool Appliance Repair Los Angeles | Same Day Service";
const description = "Expert Whirlpool appliance repair across LA, Orange, Ventura counties. All Whirlpool categories — refrigerator, washer, dryer, dishwasher, range, cooktop, microwave. Call (424) 325-0520.";

const categories = [
  { label: "Refrigerator", url: "/brands/whirlpool-refrigerator-repair/" },
  { label: "Washer", url: "/brands/whirlpool-washer-repair/" },
  { label: "Dryer", url: "/brands/whirlpool-dryer-repair/" },
  { label: "Dishwasher", url: "/brands/whirlpool-dishwasher-repair/" },
  { label: "Range", url: "/brands/whirlpool-range-repair/" },
  { label: "Cooktop", url: "/brands/whirlpool-cooktop-repair/" },
  { label: "Microwave", url: "/brands/whirlpool-microwave-repair/" }
];
---

<Layout title={title} description={description}>
  <BrandHubPlaceholder brandName="Whirlpool" brandSlug="whirlpool" categories={categories} />
</Layout>
