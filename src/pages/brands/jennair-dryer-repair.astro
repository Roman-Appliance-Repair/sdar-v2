---
import Layout from '../../layouts/Layout.astro';
import BrandBranchesGrid from '../../components/BrandBranchesGrid.astro';
import { MAIN_PHONE, MAIN_PHONE_TEL } from '../../data/branches';

const title = "JennAir Dryer & Washer Repair | Southern California | Legacy Service & Brand Clarification";
const description = "Looking for JennAir (Jenn-Air) dryer or washer repair across Southern California? JennAir is a kitchen-appliance-only brand, they don't make current laundry. Legacy units from 1990s-2000s era serviced. Most 'JennAir laundry' searches need Maytag, Whirlpool, or KitchenAid service. Honest guidance, factory-trained technicians across all Whirlpool Corp brands. Call (424) 325-0520.";

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": "https://samedayappliance.repair/brands/jennair-dryer-repair/#business",
    "name": "Same Day Appliance Repair, JennAir Laundry Legacy Service",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": "https://samedayappliance.repair/brands/jennair-dryer-repair/",
    "telephone": MAIN_PHONE_TEL,
    "priceRange": "$$$"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Does JennAir make dryers and washers?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Not currently. JennAir is a kitchen-appliance-only brand in its current Whirlpool Corporation lineup, refrigerators, ranges, wall ovens, cooktops, dishwashers, microwaves, warming drawers, ventilation hoods. No washers or dryers in the current JennAir product line. This has been the case since Whirlpool acquired Maytag (JennAir's parent) in 2006 and consolidated laundry under the Maytag, Whirlpool, and Amana brands. If you have a JennAir appliance badge on a washer or dryer, it's almost certainly a legacy unit from the 1982-2006 Maytag ownership era, when Maytag briefly expanded the JennAir brand to include laundry (internally these were often rebadged Maytag or Norge platforms, sometimes called 'Norgetags' in the industry)."
        }
      },
      {
        "@type": "Question",
        "name": "I have a JennAir washer or dryer, can you still service it?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. If you have a legacy JennAir-branded washer or dryer (typically 1990s-early-2000s manufacture), we service it, but the underlying machine is a Maytag, Whirlpool, or Norge platform with a JennAir badge, so we approach it with our Maytag and Whirlpool service expertise. Part numbers, diagnostic procedures, and failure patterns match the underlying platform rather than the JennAir branding. Common findings: washer transmissions, dryer heating elements, moisture sensors, drive belts, and control boards are all serviceable. Parts availability varies by age, units from the 1990s may have reduced parts availability; 2000-2006 era units generally still have good parts access through Whirlpool Corporation's distribution network. We give honest assessment on site, if the unit is 25+ years old and failure is major (motor, transmission), replacement discussion rather than repair investment is often the right call."
        }
      },
      {
        "@type": "Question",
        "name": "Why do Google searches show 'JennAir dryer repair' results?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Three reasons. First, legacy JennAir laundry units from 1982-2006 era still exist in some homes, and owners correctly search the brand name on their badge. Second, some owners confuse JennAir with Maytag (sister brands under Whirlpool Corp) and search 'JennAir dryer' when they actually own Maytag. Third, appliance service directories and parts retailers still list 'JennAir dryer' categories because legacy units exist in the installed base. For current laundry purchases within the Whirlpool Corporation family, the correct brands are Maytag, Whirlpool, KitchenAid, or Amana, not JennAir."
        }
      },
      {
        "@type": "Question",
        "name": "What brand should I buy for laundry that pairs with JennAir kitchen?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "If you have a JennAir kitchen and want matching premium laundry, the most aesthetically and platform-compatible choices within Whirlpool Corporation are Maytag (durability-focused, commercial-grade mid-tier) or KitchenAid (upper-mid premium, design-matched to JennAir's RISE Collection aesthetic). For true luxury laundry paired with a JennAir kitchen, owners often step outside Whirlpool Corp to Miele (W1 washer / T1 dryer, 20+ year service life positioning) or Bosch (800 Series compact 24\", common in LA condos and smaller kitchens). We service all four platforms, Maytag, KitchenAid, Miele, and Bosch, with factory-trained technicians."
        }
      },
      {
        "@type": "Question",
        "name": "How much does legacy JennAir washer or dryer repair cost?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Diagnostic is $89, waived with repair. Legacy JennAir laundry service costs follow the underlying Maytag/Whirlpool platform pricing. Typical repairs on legacy units: dryer heating element $165-$265, drive belt $115-$175, drum rollers (set of 4) $125-$185, idler pulley $95-$145, motor $265-$365, control board $345-$485 (availability-dependent on age), thermal fuse $85-$145, moisture sensor $125-$185, thermostat $95-$145. Washer: drive belt $115-$175, transmission/gearcase $485-$785 (major repair on older units, often replacement discussion territory), water inlet valve $185-$265, drain pump $165-$245, door latch $85-$135, control board $345-$485. On 25+ year old units, we give honest repair-vs-replace assessment, sometimes a $500 repair doesn't pencil out on a unit near end-of-life. Labor and parts quoted before work starts."
        }
      }
    ]
  }
];
---
<Layout title={title} description={description}>
  <Fragment slot="head-scripts">
    {schemaJsons.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </Fragment>

  <section class="hero">
    <div class="hero-inner">
      <div class="hero-content">
        <p class="hero-eyebrow">LA · Orange · Ventura · San Bernardino · Riverside Counties</p>
        <h1>JennAir Dryer &amp; Washer Repair, Legacy Service &amp; Brand Clarification</h1>
        <p class="hero-sub">Important note: JennAir (Jenn-Air) doesn't currently make washers or dryers. They're a kitchen-appliance-only brand. If you have a JennAir-badged laundry unit from the 1982-2006 era, we service it as a Maytag/Whirlpool platform repair. If you're shopping for new laundry, you need Maytag, KitchenAid, Miele, or Bosch. Read below for details, or call and we'll help you figure out what you have.</p>
        <div class="hero-ctas">
          <a href={`tel:${MAIN_PHONE_TEL}`} class="btn-primary">☎ {MAIN_PHONE}</a>
          <a href="/contact/" class="btn-outline">Book Online</a>
        </div>
      </div>
      <div class="hero-img-wrap">
        <div class="hero-img-placeholder">
          <p>JennAir Laundry Legacy Service</p>
          <p>Across Southern California</p>
        </div>
      </div>
    </div>
  </section>

  <div class="trust-bar">
    <div class="trust-bar-inner">
      <div class="trust-item"><span class="trust-icon">🏅</span> BHGS Licensed #A49573</div>
      <div class="trust-item"><span class="trust-icon">🛡</span> Fully Insured</div>
      <div class="trust-item"><span class="trust-icon">⚡</span> Same Day Available</div>
      <div class="trust-item"><span class="trust-icon">🔩</span> OEM Parts on Truck</div>
      <div class="trust-item"><span class="trust-icon">💬</span> $89 Diagnostic, Waived With Repair</div>
    </div>
  </div>

  <!-- ── HONEST ANSWER FIRST ── -->
  <section class="section">
    <div class="container narrow">
      <p class="eyebrow-sub">Quick answer</p>
      <h2>JennAir doesn't make washers or dryers.</h2>
      <p>JennAir's current product lineup, under Whirlpool Corporation ownership since 2006, is kitchen appliances only: refrigerators, ranges, wall ovens, cooktops, dishwashers, microwaves, warming drawers, and ventilation hoods. <strong>No washers or dryers.</strong> If you searched "JennAir dryer repair" or "JennAir washer repair" and landed here, one of three things is probably true:</p>
      <p><strong>(1) You have a legacy JennAir laundry unit</strong> from the 1982-2006 Maytag ownership era. Briefly during that period, Maytag rebadged Maytag and Norge laundry platforms with JennAir branding to expand the brand into matching kitchen-and-laundry suites. Industry historians sometimes call these "Norgetags." The underlying machines were Maytag or Norge platforms with JennAir badges. We service these as Maytag/Norge platform repairs, same diagnostic, same parts, same expertise.</p>
      <p><strong>(2) You may be confusing JennAir with Maytag.</strong> Both are Whirlpool Corporation brands and sometimes get mixed up. If you have a Maytag laundry unit, see our <a href="/brands/maytag-washer-repair/">Maytag washer</a> and <a href="/brands/maytag-dryer-repair/">Maytag dryer</a> repair pages. (Or just call, we'll figure out what you have.)</p>
      <p><strong>(3) You're shopping for new laundry to pair with a JennAir kitchen.</strong> See our recommendations below, short version: Maytag, KitchenAid, Miele, or Bosch are the right brand choices depending on budget and kitchen aesthetic.</p>
    </div>
  </section>

  <!-- ── BRAND HISTORY ── -->
  <section class="section section-alt">
    <div class="container narrow">
      <p class="eyebrow-sub">How JennAir briefly had laundry</p>
      <h2>The 1982-2006 Maytag era, when JennAir laundry existed.</h2>
      <p>JennAir was founded in Indianapolis, Indiana in 1947 by Louis J. Jenn, originally making industrial fans. In 1961, Jenn integrated one of his fans into a cooktop, inventing the world's first self-ventilated downdraft range, the product that defined the brand. JennAir expanded into convection ovens, refrigerators, and dishwashers over the next two decades.</p>
      <p><strong>Maytag acquired JennAir in 1982</strong>, and during the following years expanded the brand line to include matching laundry units. These were rebadged Maytag and Norge (a Maytag-owned budget laundry brand) platforms with JennAir styling applied. They existed primarily to complete JennAir kitchen packages with matching laundry rather than as engineering-led laundry products. Industry service techs sometimes called these "Norgetags" (Norge + Maytag, with JennAir badging). The laundry line was never the focus of the brand, it was always kitchen-driven.</p>
      <p><strong>Whirlpool acquired Maytag in 2006</strong>, bringing JennAir into the much larger Whirlpool Corporation portfolio alongside KitchenAid, Whirlpool, Maytag, Amana, and other brands. Whirlpool consolidated laundry under the Maytag, Whirlpool, and Amana brands and repositioned JennAir as a pure luxury kitchen brand, dropping laundry entirely. At the 2018 Architectural Digest Design Show, Whirlpool formally announced that the hyphen was being removed from "Jenn-Air" to become "JennAir", signaling the brand refresh and re-emphasizing the luxury kitchen positioning.</p>
      <p>Result: any JennAir-badged washer or dryer you own today is at least 18-40 years old, and the underlying platform is a Maytag or Norge design. Parts and service follow the platform, not the JennAir branding.</p>
    </div>
  </section>

  <!-- ── LEGACY SERVICE ── -->
  <section class="section">
    <div class="container narrow">
      <p class="eyebrow-sub">If you have a legacy JennAir laundry unit</p>
      <h2>We still service legacy JennAir laundry units.</h2>
      <p>Our Maytag and Whirlpool service training applies directly to JennAir-badged laundry from the 1982-2006 era. Same diagnostic procedures, same parts catalog (through Whirlpool Corporation's distribution network), same failure patterns. What we service:</p>
      <p><strong>Legacy JennAir dryers (electric and gas).</strong> Common issues: moisture sensor coating (fabric softener residue on metal strips inside drum, free fix, wipe with rubbing alcohol on cotton swab), heating element failure (partial first, then complete, $165-$265 replacement), drive belt ($115-$175), drum rollers ($125-$185 set), thermal fuse ($85-$145, usually caused by restricted venting), thermostat ($95-$145), control board ($345-$485 if still available for unit's age).</p>
      <p><strong>Legacy JennAir washers.</strong> Common issues: drive belt ($115-$175), water inlet valve ($185-$265), drain pump ($165-$245), door/lid switch ($85-$135), control board ($345-$485), and on older top-loaders, transmission/gearcase issues which on 20+ year old units often warrant replacement discussion rather than repair investment ($485-$785 transmission repair on an aged unit isn't usually economical).</p>
      <p><strong>Age framework.</strong> Units from the 1990s may have reduced parts availability on some electronic components, we source through Whirlpool Corp network, and specific part availability varies by model. Units from 2000-2006 era generally still have good parts access. Any laundry unit 25+ years old that develops major component failure (motor, transmission, control board) is usually a replacement discussion rather than a repair investment, we give honest assessment on site.</p>
    </div>
  </section>

  <!-- ── WHAT TO BUY ── -->
  <section class="section section-alt">
    <div class="container narrow">
      <p class="eyebrow-sub">What to buy if you need new laundry</p>
      <h2>Laundry brands that pair with a JennAir kitchen.</h2>
      <p>For JennAir kitchen owners shopping for new laundry, four brand paths based on budget and aesthetic:</p>
      <p><strong>Maytag</strong> (mid-tier, durability focused). Same Whirlpool Corporation parent as JennAir, commercial-grade engineering tradition, excellent repair economics. Most common LA choice for owners wanting matching Whirlpool Corp platform without premium pricing. See our <a href="/brands/maytag-washer-repair/">Maytag washer repair</a> and <a href="/brands/maytag-dryer-repair/">Maytag dryer repair</a> pages.</p>
      <p><strong>KitchenAid</strong> (upper-mid premium). Design-matched to JennAir's RISE Collection aesthetic, similar brushed stainless handle styling, matching control architectures. Natural visual pair for RISE kitchen owners. Whirlpool Corporation platform shared with JennAir kitchen appliances.</p>
      <p><strong>Miele</strong> (true luxury, 20+ year service life). The direct laundry equivalent to Sub-Zero / Wolf kitchen tier, premium German engineering, compact 24" W1 washer and T1 heat-pump dryer platform, designed for decades-long service. Common in LA luxury homes that pair Miele laundry with JennAir or Sub-Zero kitchens. See our <a href="/brands/miele-dryer-repair/">Miele dryer repair</a> page.</p>
      <p><strong>Bosch</strong> (compact premium). 800 Series compact 24" laundry, condenser and heat-pump dryer variants, popular in LA condos and kitchens with integrated laundry closets. European engineering, mid-luxury tier between Maytag and Miele. See our <a href="/brands/bosch-dryer-repair/">Bosch dryer repair</a> page.</p>
      <p>For owners with NOIR Collection JennAir kitchens specifically, Miele's current black stainless finishes tend to be the best aesthetic match. For RISE Collection, KitchenAid or Maytag commercial-style are closer matches.</p>
    </div>
  </section>

  <!-- ── PRICING ── -->
  <section class="section">
    <div class="container narrow">
      <p class="eyebrow-sub">Pricing for legacy JennAir laundry service</p>
      <h2>Typical costs</h2>
      <p>Diagnostic $89, waived with repair. Legacy JennAir laundry follows the underlying Maytag or Norge platform pricing, not premium luxury pricing. Labor and parts quoted before work starts.</p>
      <table class="price-table">
        <thead>
          <tr><th>Repair</th><th>Typical range</th></tr>
        </thead>
        <tbody>
          <tr><td>Dryer heating element</td><td>$165 – $265</td></tr>
          <tr><td>Dryer moisture sensor cleaning (with service)</td><td>Free</td></tr>
          <tr><td>Dryer moisture sensor replacement</td><td>$125 – $185</td></tr>
          <tr><td>Dryer drive belt</td><td>$115 – $175</td></tr>
          <tr><td>Dryer drum rollers (set of 4)</td><td>$125 – $185</td></tr>
          <tr><td>Dryer idler pulley</td><td>$95 – $145</td></tr>
          <tr><td>Dryer motor</td><td>$265 – $365</td></tr>
          <tr><td>Dryer thermal fuse</td><td>$85 – $145</td></tr>
          <tr><td>Dryer thermostat (cycling or high-limit)</td><td>$95 – $145</td></tr>
          <tr><td>Dryer control board (availability-dependent on age)</td><td>$345 – $485</td></tr>
          <tr><td>Washer drive belt</td><td>$115 – $175</td></tr>
          <tr><td>Washer water inlet valve</td><td>$185 – $265</td></tr>
          <tr><td>Washer drain pump</td><td>$165 – $245</td></tr>
          <tr><td>Washer door / lid switch</td><td>$85 – $135</td></tr>
          <tr><td>Washer control board</td><td>$345 – $485</td></tr>
          <tr><td>Washer transmission / gearcase (20+ yr units)</td><td>$485 – $785*</td></tr>
          <tr><td>LA dryer vent cleaning service</td><td>$145 – $195</td></tr>
        </tbody>
      </table>
      <p class="footnote">*On 20+ year old units, transmission/gearcase failure usually warrants replacement discussion rather than repair, we provide honest assessment.</p>
    </div>
  </section>

  <!-- ── SERVICE AREAS ── -->
  <section class="section section-alt">
    <div class="container">
      <p class="eyebrow-sub">Where we go</p>
      <h2>Service areas</h2>
      <BrandBranchesGrid showHeader={false} />
    </div>
  </section>

  <!-- ── RELATED ── -->
  <section class="section">
    <div class="container">
      <p class="eyebrow-sub">Related services</p>
      <h2>Related laundry and JennAir kitchen services</h2>
      <div class="cat-grid">
        <a href="/brands/jennair/" class="cat-card">
          <h3>JennAir Appliance Repair (Kitchen)</h3>
          <p>JennAir's current product line, refrigerators, ranges, ovens, cooktops, dishwashers. This is where JennAir actively operates today.</p>
          <span class="cat-cta">View JennAir hub →</span>
        </a>
        <a href="/brands/miele-dryer-repair/" class="cat-card">
          <h3>Miele Dryer Repair</h3>
          <p>True luxury compact laundry, W1 washer and T1 heat-pump dryer. 20+ year service life. Common LA pairing with JennAir kitchens.</p>
          <span class="cat-cta">View Miele dryer →</span>
        </a>
        <a href="/brands/bosch-dryer-repair/" class="cat-card">
          <h3>Bosch Dryer Repair</h3>
          <p>Compact 24" laundry, condenser and heat-pump. 800 Series common in LA condo kitchens.</p>
          <span class="cat-cta">View Bosch dryer →</span>
        </a>
        <a href="/brands/jennair-refrigerator-repair/" class="cat-card">
          <h3>JennAir Refrigerator Repair</h3>
          <p>Columns, French-door, side-by-side. Embraco VCC2 inverter, diagnostic test mode procedure.</p>
          <span class="cat-cta">View refrigerator →</span>
        </a>
      </div>
    </div>
  </section>

  <!-- ── FAQ ── -->
  <section class="section section-alt">
    <div class="container narrow">
      <p class="eyebrow-sub">FAQ</p>
      <h2>Common questions</h2>

      <details class="faq">
        <summary>Does JennAir make dryers and washers?</summary>
        <p>No, not currently. Kitchen-appliance-only brand since Whirlpool acquired Maytag in 2006. Current lineup: refrigeration, cooking, dishwashers, hoods, warming drawers. No laundry.</p>
      </details>

      <details class="faq">
        <summary>I have a JennAir washer/dryer, can you fix it?</summary>
        <p>Yes, legacy units from 1982-2006 era Maytag ownership. Underlying platform is Maytag or Norge. Same parts, same diagnostic as Maytag laundry. Age assessment honest: 25+ year units with major failure usually = replacement discussion.</p>
      </details>

      <details class="faq">
        <summary>What brand pairs with JennAir kitchen for laundry?</summary>
        <p>Maytag (same Whirlpool Corp), KitchenAid (RISE-matching), Miele (luxury W1/T1), or Bosch (compact 24"). All four serviced by us with factory-trained technicians.</p>
      </details>

      <details class="faq">
        <summary>Why does Google show 'JennAir dryer' results?</summary>
        <p>Three reasons: legacy units still in homes, owners confusing JennAir with Maytag (sister Whirlpool brands), parts retailers listing legacy categories. For current laundry: Maytag, Whirlpool, or KitchenAid.</p>
      </details>

      <details class="faq">
        <summary>How much does legacy JennAir laundry repair cost?</summary>
        <p>Follows Maytag platform pricing, not luxury. Common: dryer heating element $165-$265, drive belt $115-$175, thermal fuse $85-$145. Full pricing above. Diagnostic $89, waived with repair.</p>
      </details>
    </div>
  </section>

  <!-- ── BOTTOM CTA ── -->
  <section class="bottom-cta">
    <div class="container">
      <h2>Have a JennAir laundry unit? Call us to diagnose.</h2>
      <p>Same day available. $89 diagnostic, waived with repair. We'll tell you honestly whether repair makes sense or whether replacement is the better call.</p>
      <div class="hero-ctas">
        <a href={`tel:${MAIN_PHONE_TEL}`} class="btn-primary">☎ Call {MAIN_PHONE}</a>
        <a href="/contact/" class="btn-outline">Book Online</a>
      </div>
    </div>
  </section>

<style>
  :root {
    --red: #C8102E;
    --black: #0a0a0a;
    --gray: #f5f5f5;
    --border: #e2e2e2;
    --text: #1a1a1a;
    --muted: #6b6b6b;
    --white: #ffffff;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; color: var(--text); line-height: 1.6; }

  .hero { background: var(--black); color: #fff; padding: 80px 24px 72px; }
  .hero-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; max-width: 1100px; margin: 0 auto; align-items: center; }
  .hero-eyebrow { font-size: 13px; color: var(--red); text-transform: uppercase; letter-spacing: .12em; margin-bottom: 16px; font-weight: 600; }
  .hero h1 { font-size: clamp(26px, 3.5vw, 40px); font-weight: 700; color: #fff; margin-bottom: 20px; line-height: 1.15; font-family: 'Playfair Display', Georgia, serif; }
  .hero-sub { font-size: 17px; color: rgba(255,255,255,.72); margin-bottom: 28px; }
  .hero-ctas { display: flex; gap: 12px; margin-bottom: 28px; flex-wrap: wrap; }
  .btn-primary { display: inline-block; padding: 14px 28px; background: var(--red); color: #fff; text-decoration: none; border-radius: 6px; font-weight: 600; font-size: 16px; transition: background .2s; }
  .btn-primary:hover { background: #a50d25; }
  .btn-outline { display: inline-block; padding: 14px 28px; border: 1.5px solid rgba(255,255,255,.35); color: #fff; text-decoration: none; border-radius: 6px; font-weight: 600; font-size: 16px; transition: all .2s; }
  .btn-outline:hover { background: rgba(255,255,255,.08); border-color: #fff; }
  .hero-img-wrap { aspect-ratio: 4/3; background: #1a1a1a; border-radius: 4px; display: flex; align-items: center; justify-content: center; }
  .hero-img-placeholder { color: rgba(255,255,255,.35); font-size: 14px; text-align: center; }
  @media (max-width: 768px) { .hero-inner { grid-template-columns: 1fr; } .hero-img-wrap { display: none; } }

  .trust-bar { background: var(--red); color: #fff; padding: 16px 24px; }
  .trust-bar-inner { max-width: 1100px; margin: 0 auto; display: flex; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
  .trust-item { font-size: 13px; font-weight: 600; display: flex; align-items: center; gap: 8px; }
  .trust-icon { font-size: 16px; }

  .section { padding: 72px 24px; }
  .section-alt { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; }
  .container.narrow { max-width: 780px; }
  .eyebrow-sub { font-size: 13px; color: var(--red); text-transform: uppercase; letter-spacing: .12em; margin-bottom: 12px; font-weight: 600; }
  h2 { font-size: clamp(24px, 3vw, 34px); font-weight: 700; margin-bottom: 20px; line-height: 1.2; font-family: 'Playfair Display', Georgia, serif; }
  .section p { margin-bottom: 16px; color: var(--text); }
  .section p a { color: var(--red); text-decoration: underline; }
  .footnote { font-size: 13px; color: var(--muted); font-style: italic; margin-top: 12px; }

  .price-table { width: 100%; border-collapse: collapse; margin: 24px 0 12px; background: #fff; border: 1px solid var(--border); border-radius: 6px; overflow: hidden; }
  .price-table th { background: var(--black); color: #fff; padding: 14px 18px; text-align: left; font-size: 14px; text-transform: uppercase; letter-spacing: 0.08em; }
  .price-table td { padding: 12px 18px; border-top: 1px solid var(--border); font-size: 15px; }
  .price-table td:last-child { color: var(--red); font-weight: 600; white-space: nowrap; }

  .cat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px; margin-top: 28px; }
  .cat-card { display: block; padding: 24px; background: #fff; border: 1px solid var(--border); border-radius: 8px; text-decoration: none; color: inherit; transition: all .2s; }
  .cat-card:hover { border-color: var(--red); transform: translateY(-2px); box-shadow: 0 4px 16px rgba(0,0,0,.08); }
  .cat-card h3 { font-size: 17px; font-weight: 700; margin-bottom: 10px; color: var(--black); font-family: 'Playfair Display', Georgia, serif; }
  .cat-card p { font-size: 13px; color: var(--muted); margin-bottom: 14px; }
  .cat-cta { font-size: 12px; color: var(--red); font-weight: 600; }

  .faq { margin-bottom: 12px; border: 1px solid var(--border); border-radius: 6px; padding: 16px 20px; background: #fff; }
  .faq summary { font-weight: 600; cursor: pointer; font-size: 16px; color: var(--black); }
  .faq[open] summary { margin-bottom: 12px; }
  .faq p { font-size: 15px; color: var(--text); margin-bottom: 0; }

  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
