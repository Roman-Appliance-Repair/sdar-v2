---
// Phase 2 Cluster 3 #1 — Twin Eagles outdoor BBQ grill pillar.
// Brand: American premium outdoor cooking. Built-in + freestanding gas grills.
// Series families generalized: Eagle One Series (entry premium), C Series,
// flagship Twin Eagles. LA luxury backyard market focus.
// Residential pricing ($89). NEW schema pattern via mergeCredentials().

import Layout from '../../layouts/Layout.astro';
import ServiceHero from '../../components/ServiceHero.astro';
import { mergeCredentials } from '../../data/credentials-schema';

const phone = '(323) 870-4790';
const phoneRaw = phone.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/brands/twin-eagles-grill-repair/";

const title = "Twin Eagles Grill Repair Los Angeles — Same Day";
const description = "Twin Eagles outdoor grill repair across LA. Eagle One, C Series, flagship Twin Eagles. Built-in and freestanding luxury grills. EPA 608, $89 dx waived with repair.";

const faqs = [
  {
    q: "Same-day Twin Eagles service in LA?",
    a: "Yes for diagnostic and most common repairs. Most calls received before 2 PM get a tech on-site the same business day. Common service items — igniter modules, gas valves, infrared burners, regulator components — typically ride on the truck. Less common items (specific control board variants, premium burner replacements) may add 1-5 business days for parts ordering. We confirm availability during the diagnostic and tell you the realistic timeline before scheduling labor."
  },
  {
    q: "Do you carry Twin Eagles OEM parts on the truck?",
    a: "Common service parts ride on every residential outdoor truck: igniter modules, gas valves, regulator components, burner shields, cooking grates and heat plates in standard sizes, and electrical components for the smart-grill features on newer Twin Eagles configurations. Premium-tier specific parts — flagship-series infrared burner assemblies, brand-specific control boards — typically come through Twin Eagles authorized distribution, 2-7 business days. We do not substitute aftermarket burners or electrical components on a unit at this tier. Twin Eagles invests in the build quality that justifies its position; bargain parts undermine that and shorten service life."
  },
  {
    q: "What's your diagnostic fee for Twin Eagles?",
    a: "$89 residential diagnostic, waived when you approve the repair. The diagnostic covers ignition system test (igniter modules, hot-surface elements, electronic control if equipped), gas system pressure and leak test, burner inspection (gas burners and infrared elements where present), control valve operation, electrical components on smart-grill configurations, exterior stainless and weatherproofing inspection. We deliver a written quote with parts cost, labor estimate, and realistic timeline before any work begins."
  },
  {
    q: "How does coastal LA exposure affect Twin Eagles grills?",
    a: "Coastal installations — Malibu, Manhattan Beach, Pacific Coast properties — face accelerated corrosion on the grill's stainless steel components and electrical modules. Even premium 304 or 316 stainless used in Twin Eagles construction will show salt-air influence over years of exposure. Common patterns: surface oxidation on the cooking grates and grill body that requires more aggressive cleaning, igniter module degradation from salt air infiltration into the electrical compartment, gas valve cycling fatigue from the corrosive environment. We adjust the maintenance interval more aggressively for coastal installs — quarterly inspection rather than annual — and recommend specific cleaning protocols and corrosion-protection products that extend service life meaningfully."
  },
  {
    q: "Is a 12+ year old Twin Eagles still worth repairing?",
    a: "Almost always worth repairing. Twin Eagles construction at this tier is engineered for service life that runs 15-20+ years with maintenance — heavier-gauge stainless than mass-market grills, better burner materials, more durable electronics on the smart-grill features. The economics favor repair: a $300-$1,200 service call against a $5,000-$15,000+ replacement makes the math straightforward, and the grill's integration into a custom outdoor kitchen wasn't designed to be removed and replaced casually. We tell you honestly when a specific unit has reached the point where parts become impractical or the cumulative repair cost exceeds replacement value, but for most well-maintained Twin Eagles, that point is much later than owners assume."
  },
  {
    q: "Can you service Twin Eagles built into custom outdoor kitchens?",
    a: "Yes, this is most of the Twin Eagles service work we do across LA. Built-in grills integrated into stone, stucco, or stainless outdoor kitchen islands — common configuration в Bel Air, Beverly Hills, Pacific Palisades, Hidden Hills luxury backyard installations. Service approach respects the surrounding installation: we access from the front when possible, never force-pull a unit when extraction risks damaging the surrounding masonry or finish, and coordinate с the homeowner's outdoor designer or contractor when major components need replacement. Diagnostic time runs longer on integrated installs than freestanding cabinets — we factor that into the realistic service window."
  }
];

const localBusinessSchema = mergeCredentials({
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  '@id': canonical + '#business',
  name: 'Same Day Appliance Repair — Twin Eagles Grill Service',
  url: canonical,
  telephone: phone,
  email: 'support@samedayappliance.repair',
  priceRange: '$$$',
  openingHoursSpecification: [
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'], opens: '08:00', closes: '20:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: 'Sunday', opens: '00:00', closes: '00:00' }
  ],
  areaServed: [
    { '@type': 'AdministrativeArea', name: 'Los Angeles County' },
    { '@type': 'AdministrativeArea', name: 'Orange County' },
    { '@type': 'AdministrativeArea', name: 'Ventura County' },
    { '@type': 'AdministrativeArea', name: 'San Bernardino County' },
    { '@type': 'AdministrativeArea', name: 'Riverside County' }
  ]
});

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  '@id': canonical + '#service',
  serviceType: 'Twin Eagles Grill Repair',
  name: 'Twin Eagles Grill Repair, Same Day Appliance Repair',
  url: canonical,
  description: 'Same-day Twin Eagles outdoor grill repair across Los Angeles, Orange, Ventura, San Bernardino, and Riverside counties. Eagle One Series, C Series, flagship Twin Eagles built-in and freestanding gas grills. Igniter modules, gas valves, infrared burners, regulators, smart-grill electronics. EPA 608 Universal certified (#1346255700410), BHGS #A49573, CSLB C-20 HVAC. $89 residential diagnostic, applied toward repair. Twin Eagles OEM parts only.',
  provider: { '@id': canonical + '#business' },
  areaServed: [
    { '@type': 'AdministrativeArea', name: 'Los Angeles County' },
    { '@type': 'AdministrativeArea', name: 'Orange County' },
    { '@type': 'AdministrativeArea', name: 'Ventura County' },
    { '@type': 'AdministrativeArea', name: 'San Bernardino County' },
    { '@type': 'AdministrativeArea', name: 'Riverside County' }
  ],
  brand: { '@type': 'Brand', name: 'Twin Eagles', sameAs: 'https://www.twineaglesgrills.com/' },
  offers: {
    '@type': 'Offer',
    priceSpecification: { '@type': 'PriceSpecification', price: '89.00', priceCurrency: 'USD', description: 'Residential diagnostic fee, applied toward repair' }
  }
};

const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };

const breadcrumbSchema = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
  { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://samedayappliance.repair/' },
  { '@type': 'ListItem', position: 2, name: 'Brands', item: 'https://samedayappliance.repair/brands/' },
  { '@type': 'ListItem', position: 3, name: 'Twin Eagles', item: canonical }
]};

const schemaJsons = [localBusinessSchema, serviceSchema, faqSchema, breadcrumbSchema];
---

<Layout title={title} description={description} canonical={canonical}>

<Fragment slot="head-scripts">
  {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
</Fragment>

<ServiceHero
  eyebrow="Outdoor Grill · American Luxury · Built-In and Freestanding"
  title="Twin Eagles Grill Repair, Across Southern California"
  subtitle="Eagle One Series · C Series · flagship Twin Eagles. Heavy-gauge stainless construction, infrared burners, smart-grill electronics on newer configurations. EPA 608 Universal certified, BHGS #A49573. $89 residential diagnostic, waived with repair."
  heroImageTitle="Twin Eagles Grill Repair"
  showBranches={true}
/>

<section class="section">
  <div class="container narrow">
    <p class="section-number">01, About this service</p>
    <h2>The American luxury name in serious outdoor cooking</h2>
    <p>
      Twin Eagles is one of the few American brands at the top of the outdoor grill market. Premium-tier construction —
      heavier-gauge 304 stainless than mass-market grills, infrared burners on the higher-end configurations, smart-grill
      electronics on the newer flagship lineup — and the kind of build that justifies position в a custom outdoor kitchen
      rather than an off-the-rack purchase. The brand anchors serious LA backyard installations from Bel Air to Hidden Hills,
      Pacific Palisades to Newport Beach, and we service these regularly when the grill needs more than what the homeowner
      can do with a wire brush and a $20 igniter from the hardware store.
    </p>
    <p>
      Pricing structure is straightforward: $89 residential diagnostic, waived when you approve the repair. EPA 608 Universal
      certified для refrigerant work on grills equipped with side burners or refrigerated drawers integrated into the grill
      island. BHGS Registration #A49573 plus CSLB C-20 HVAC for the gas-line and adjacent mechanical work. Twin Eagles OEM
      parts only — we do not substitute aftermarket burners or electrical components on a unit at this tier.
    </p>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">02, Series and product coverage</p>
    <h2>What we service across the Twin Eagles lineup</h2>

    <h3>Eagle One Series (entry premium)</h3>
    <p>
      Twin Eagles' entry into the premium tier — solid build quality with proper stainless construction, gas burner systems,
      and standard outdoor grill features. Common in luxury backyards where the homeowner wanted Twin Eagles build quality
      без the flagship pricing. Service items cluster around the gas system (igniters, valves, regulators), burner replacement
      after years of use, and exterior stainless maintenance. Parts generally well-stocked through Twin Eagles authorized distribution.
    </p>

    <h3>C Series (mid-premium)</h3>
    <p>
      C Series adds upgraded construction and feature set above Eagle One — more burner options, heavier-duty grates, often
      infrared burner integration в the burner array. Service approach is similar к Eagle One с additional attention to the
      infrared elements (different failure mode and replacement procedure than conventional gas burners) и any expanded
      electrical components.
    </p>

    <h3>Flagship Twin Eagles configurations</h3>
    <p>
      The brand's top tier — heaviest construction, premium burner technology including dedicated infrared zones, smart-grill
      electronic control systems, integrated rotisserie systems, and various accessory configurations (side burners,
      refrigerated drawers, warming drawers integrated into the grill island). Service runs more involved on these
      configurations: more components to diagnose, electronic control systems require specific diagnostic procedures, and
      premium burner technology has its own service approach.
    </p>

    <h3>Built-in versus freestanding configurations</h3>
    <p>
      Most Twin Eagles models come в both built-in (designed для integration into outdoor kitchen islands) and freestanding
      (cart-mounted) configurations. Service approach differs: built-in units require careful access from the front of the
      installation (we never force-pull a built-in grill when surrounding masonry or stainless cladding could be damaged),
      while freestanding carts allow easier access to all sides for diagnostic and repair. We adjust technique accordingly.
    </p>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">03, Common failure patterns</p>
    <h2>What we look at first on a Twin Eagles call</h2>
    <ul class="bullet-list">
      <li><strong>Igniter module failure.</strong> Outdoor electrical components в LA's environment — UV exposure, moisture infiltration during winter rains, dust accumulation from the dry season — wear faster than indoor electrical components. Igniter modules typically reach end-of-life at year 7-10 в average operating conditions, sooner на coastal installs. Symptom is a burner that won't light from the electronic ignition (manual lighting still works). Replacement is straightforward с the OEM module.</li>
      <li><strong>Gas valve cycling fatigue.</strong> The brass gas valves в Twin Eagles burner controls cycle thousands of times over the life of the grill. After year 8-12 of heavy use, valves can develop sticking issues или incomplete closure. Symptom is a burner that won't fully turn off, или uneven flame across burner zones. Replacement valves available through Twin Eagles distribution.</li>
      <li><strong>Burner port accumulation.</strong> Cooking debris, grease, и occasional ash (LA's wildfire season contributes this when active) can clog burner ports over time. Symptom is uneven flame distribution или specific zones not firing. Service is mechanical cleaning rather than parts replacement в most cases — we clear the ports, verify gas flow, and run the burner under load to confirm restoration. Some heavy buildup cases require burner replacement.</li>
      <li><strong>Infrared burner end-of-life.</strong> Infrared burners on the higher-end Twin Eagles configurations have different failure modes than conventional gas burners. The infrared element's ceramic and metal surface can degrade с years of high-heat cycling. Symptom is reduced infrared output (slower searing, uneven heat across the burner face). Replacement requires the OEM infrared element.</li>
      <li><strong>Electronic control board fade on smart-grill configurations.</strong> Newer Twin Eagles flagship configurations with smart-grill electronics use control boards that can fade after 8-12 years of outdoor exposure. Symptom is intermittent display issues, controls not responding, или temperature setpoint drift. We diagnose carefully — control board replacement is meaningful labor and parts cost, and we don't swap on suspicion.</li>
      <li><strong>Stainless corrosion on coastal installs.</strong> Coastal homes (Malibu, Manhattan Beach, Pacific Coast) face salt-air corrosion на even premium stainless components. We see oxidation on cooking grates, fastener corrosion, и accelerated electrical module degradation. Service approach for coastal installs runs more aggressive maintenance interval (quarterly rather than annual) и specific cleaning/protection protocols.</li>
    </ul>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">04, Where we work most on Twin Eagles</p>
    <h2>The LA Twin Eagles footprint our techs know best</h2>
    <p>
      <strong>Bel Air, Beverly Hills, Pacific Palisades luxury backyards.</strong> Custom outdoor kitchens с Twin Eagles
      built-in grills integrated into stone or stainless islands. The grill is one component в an outdoor kitchen build that
      may also include refrigerated drawers, side burners, warming drawers, и outdoor sink configurations. We service the
      grill specifically; для refrigerated components we coordinate с the right service approach for that brand (often Sub-Zero
      or U-Line outdoor refrigeration в these installations).
    </p>
    <p>
      <strong>Hidden Hills, Calabasas, и newer luxury developments.</strong> Newer-build Twin Eagles installations с
      smart-grill electronic configurations. Service approach adds the electronic diagnostic component — we test electrical
      components carefully и don't replace control boards on suspicion.
    </p>
    <p>
      <strong>Malibu и Pacific Coast estates.</strong> Coastal exposure changes the maintenance picture meaningfully. We
      recommend more aggressive cleaning protocols, quarterly maintenance intervals, и specific corrosion-protection products
      that extend service life в the salt-air environment.
    </p>
    <p>
      <strong>Newport Beach и South Bay homes.</strong> Mix of coastal exposure и higher-end luxury market. Twin Eagles
      installations across both standard residential backyards и serious custom outdoor kitchen builds.
    </p>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">05, Recent repairs</p>
    <h2>What this month looked like on Twin Eagles</h2>
    <div class="repair-cards">
      <div class="repair-card">
        <p class="repair-quote">"Two of the four burners won't light, and Memorial Day weekend is in three days."</p>
        <p>
          Bel Air home, C Series built-in grill, install year per the homeowner approximately 2017. Diagnostic identified
          igniter module failure on the affected burner pair — typical year 7-9 cluster failure для outdoor electrical в LA's
          dry-season UV exposure. Igniter modules (OEM Twin Eagles parts) ride on the truck для common configurations; replaced
          both modules, verified ignition on all four burners, ran a full-load cook test before completing the call. Total
          service time 90 minutes, homeowner ready для the holiday weekend.
        </p>
      </div>
      <div class="repair-card">
        <p class="repair-quote">"My infrared burner stopped searing properly, restaurant-grade results aren't coming back."</p>
        <p>
          Pacific Palisades home, flagship Twin Eagles built-in с infrared burner zone, install year per the homeowner
          approximately 2014. Diagnostic confirmed infrared element degradation — measurable reduction в IR output на load test,
          ceramic surface showing visible aging. Sourced replacement element through Twin Eagles authorized distribution
          (4 business days). Returned for install on the second visit, replaced element, calibrated burner output, ran cook
          test. The homeowner specifically wanted to confirm sear results before considering the call closed; we ran a steak
          test on actual food and the homeowner confirmed restoration.
        </p>
      </div>
      <div class="repair-card">
        <p class="repair-quote">"My grill controls aren't responding, the smart-grill display is intermittent."</p>
        <p>
          Hidden Hills home, newer flagship Twin Eagles с smart-grill electronics, install year per the homeowner approximately
          2020. Diagnostic ran control board last после verifying ignition system, gas valves, и electrical connections were
          all healthy. Confirmed control board fade — intermittent communication between display и burner controllers. Sourced
          replacement board through Twin Eagles distribution (5 business days). The homeowner asked для realistic options
          including continuing to use the grill manually until the part arrived; we walked through manual operation, verified
          safe operation в that mode, и returned for the install when the part arrived. Total elapsed time about a week, with
          a usable grill the entire time.
        </p>
      </div>
    </div>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">06, Why us, specifically</p>
    <h2>What makes us a fit for Twin Eagles service</h2>
    <ul class="bullet-list">
      <li><strong>EPA 608 Universal certification (#1346255700410).</strong> Required for refrigerant work on grills с integrated refrigerated drawers и side burners that involve refrigeration scope. We perform the work legally и document for service records.</li>
      <li><strong>BHGS Registration #A49573 plus CSLB C-20 HVAC.</strong> California state coverage для appliance repair, gas-line scope, и adjacent HVAC work that comes up on outdoor kitchen installations.</li>
      <li><strong>Twin Eagles OEM parts only.</strong> No aftermarket burner substitutions, no aftermarket electrical components, no bargain replacements that undermine the engineering Twin Eagles invests в. Sourced through Twin Eagles authorized distribution.</li>
      <li><strong>$89 residential diagnostic, waived с repair.</strong> Transparent flat fee, no surprise drive-time charges within our five-county service area.</li>
      <li><strong>Custom installation experience.</strong> Most LA Twin Eagles work involves built-in grills integrated into custom outdoor kitchen masonry. We come prepared для tight access, work carefully с surrounding architecture, и coordinate с outdoor kitchen designers when needed.</li>
      <li><strong>Coastal and inland service approach differentiation.</strong> Coastal installations get more aggressive maintenance recommendations и specific corrosion-protection protocols; inland luxury installs get standard service approach. We adjust accordingly.</li>
      <li><strong>BBB Accredited Business and $1M general liability insured.</strong> COI on request — sometimes required for high-value home insurance carriers' approved-vendor lists.</li>
    </ul>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">07, Frequently asked questions</p>
    <h2>The questions we get most on Twin Eagles calls</h2>
    <div class="faq-list">
      {faqs.map(f => (
        <details class="faq-item">
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">08, Other outdoor grill brands we cover</p>
    <h2>Twin Eagles service in context</h2>
    <p>
      Twin Eagles sits at the high end of the American outdoor grill market. The links below cover other premium и
      mainstream brands we service regularly across LA, plus the parent service hub for outdoor cooking repair.
    </p>
    <ul class="cross-links">
      <li><a href="/brands/wolf-outdoor-grill-repair/">Wolf Outdoor grill repair</a> — Sub-Zero Group company, premium tier</li>
      <li><a href="/brands/lynx-grill-repair/">Lynx grill repair</a> — Middleby Outdoor, professional built-in</li>
      <li><a href="/brands/fire-magic-grill-repair/">Fire Magic grill repair</a> — Echelon, Aurora, Choice families</li>
      <li><a href="/brands/hestan-outdoor-grill-repair/">Hestan Outdoor grill repair</a> — premium professional fabrication</li>
      <li><a href="/brands/kalamazoo-grill-repair/">Kalamazoo grill repair</a> — Hybrid Fire signature, hand-built</li>
      <li><a href="/brands/alfresco-grill-repair/">Alfresco grill repair</a> — ALX2 / ALXE families</li>
      <li><a href="/brands/dcs-grill-repair/">DCS grill repair</a> — Fisher & Paykel sister brand</li>
      <li><a href="/brands/viking-bbq-grill-repair/">Viking BBQ grill repair</a></li>
      <li><a href="/brands/coyote-grill-repair/">Coyote grill repair</a></li>
      <li><a href="/outdoor/grill-repair/">Outdoor grill repair (all brands)</a></li>
    </ul>
  </div>
</section>

<section class="bottom-cta">
  <div class="container narrow">
    <h2>Same-day Twin Eagles service across Southern California</h2>
    <p>$89 residential diagnostic, waived with repair. EPA 608 Universal certified, BHGS #A49573, CSLB C-20 HVAC, BBB Accredited.</p>
    <div class="cta-row">
      <a href={phoneHref} class="btn-red">Call {phone}</a>
      <a href="/contact/" class="btn-outline">Request service →</a>
    </div>
  </div>
</section>

</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .section { padding: 64px 24px; }
  .section-gray { background: var(--gray); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .container.narrow { max-width: 820px; margin: 0 auto; }
  .section-number { font-size: 12px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--red); margin: 0 0 12px; }
  h2 { font-size: clamp(22px, 3vw, 32px); font-weight: 700; line-height: 1.2; margin: 0 0 20px; color: var(--text); letter-spacing: -.01em; }
  h3 { font-size: 18px; font-weight: 700; margin: 24px 0 10px; color: var(--text); }
  p { font-size: 16px; line-height: 1.7; color: var(--text); margin: 0 0 14px; }
  strong { font-weight: 700; }
  a { color: var(--red); text-decoration: none; }
  a:hover { text-decoration: underline; }
  .bullet-list { list-style: none; padding: 0; margin: 16px 0; }
  .bullet-list li { position: relative; padding: 12px 0 12px 22px; font-size: 15.5px; line-height: 1.65; border-bottom: 1px solid var(--border); }
  .bullet-list li:last-child { border-bottom: none; }
  .bullet-list li::before { content: "▸"; position: absolute; left: 0; color: var(--red); font-weight: 700; }
  .repair-cards { display: grid; gap: 20px; margin-top: 20px; }
  .repair-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 22px 26px; }
  .repair-quote { font-style: italic; color: var(--red); font-weight: 600; margin: 0 0 12px; font-size: 15px; }
  .repair-card p:last-child { margin-bottom: 0; }
  .faq-list { margin-top: 20px; }
  .faq-item { border-bottom: 1px solid var(--border); padding: 16px 0; }
  .faq-item:last-child { border-bottom: none; }
  .faq-item summary { cursor: pointer; font-weight: 700; font-size: 16px; color: var(--text); padding: 4px 0; }
  .faq-item summary:hover { color: var(--red); }
  .faq-item p { margin: 12px 0 4px; font-size: 15.5px; color: var(--text); }
  .cross-links { list-style: none; padding: 0; margin: 16px 0 0; }
  .cross-links li { padding: 10px 0; border-bottom: 1px solid var(--border); font-size: 15px; }
  .cross-links li:last-child { border-bottom: none; }
  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { color: #fff; }
  .bottom-cta p { color: rgba(255,255,255,.85); max-width: 640px; margin: 0 auto 24px; }
  .bottom-cta a { color: #fff; }
  .cta-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-red { background: var(--red); color: #fff; padding: 14px 28px; border-radius: 6px; font-weight: 600; text-decoration: none; }
  .btn-outline { border: 1.5px solid rgba(255,255,255,.3); color: #fff; padding: 14px 28px; border-radius: 6px; font-weight: 600; text-decoration: none; }
</style>
