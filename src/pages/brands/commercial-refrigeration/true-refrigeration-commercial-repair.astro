      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "True Refrigeration", "item": "https://samedayappliance.repair/brands/true/" },
