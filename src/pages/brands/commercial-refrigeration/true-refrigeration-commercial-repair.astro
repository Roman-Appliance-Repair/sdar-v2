const title = "True Refrigeration Commercial Repair Los Angeles";
const description = "Same-day True commercial refrigeration repair across LA. T-series reach-ins, TUC, TSSU, GDM, THAC back bar with R-290. Call (424) 325-0520.";
const canonical = "https://samedayappliance.repair/brands/commercial-refrigeration/true-refrigeration-commercial-repair/";

const productLines = [
  {
    series: "T Series — Reach-In Refrigerators & Freezers",
    models: "T-23, T-35, T-49, T-72 (refrigerators) · T-23F, T-35F, T-49F, T-72F (freezers)",
    description: "True's flagship one, two, and three-section reach-in refrigerators and freezers — the most widely deployed commercial refrigerator in American food service. Built in Springfield, Missouri, with foamed-in-place polyurethane insulation and a cam-lift hinge system that self-closes doors on a 1/8-inch clearance. In LA's high-volume restaurant environment, T-series units often run 18–22 hours a day. The failure patterns we see most in SoCal's kitchen environments: evaporator coil icing from defrost system failure, fan blade grease accumulation from the cooking environment, door gasket wear from constant traffic, and temperature controller drift on older Ranco units.",
    failures: [
      "Evaporator coil icing — defrost heater or thermostat failure causes ice buildup blocking airflow",
      "Fan blade grease — restaurant grease-laden air coats evaporator fans, reducing airflow and cooling",
      "Door gasket wear — cam-lift hinges see 200+ open/close cycles daily in busy kitchens",
      "Ranco/Dixell controller drift — temperature controller loses calibration, unit runs too warm or too cold",
    ]
  },
  {
    series: "GDM Series — Glass Door Merchandisers",
    models: "GDM-12, GDM-23, GDM-49, GDM-72 · GDM-12F, GDM-23F, GDM-49F",
    description: "True's glass door reach-in merchandisers are standard in convenience stores, grocery store cold aisles, hotel grab-and-go sections, and front-of-house bar displays throughout SoCal. The GDM series runs a different refrigeration circuit than the T-series — typically with a remote condensing unit or a self-contained top-mount system. Glass door fogging is the most common aesthetic complaint, but the structural failure mode is the door heater wire that runs through the door frame to prevent condensation on the glass. When that wire fails, the door fogs constantly and the unit works harder to compensate.",
    failures: [
      "Door heater wire failure — glass fogs, accelerates condensation and increases energy draw",
      "Door gasket seal failure — warm air infiltration in high-traffic retail environments",
      "Condensing unit failure (remote models) — roof-mounted or exterior condensers in SoCal heat",
      "Lighting failure — LED or fluorescent arrays in display models visible to customers",
    ]
  },
  {
    series: "TUC / TUCR — Undercounter Refrigerators",
    models: "TUC-27, TUC-36, TUC-48, TUC-60, TUC-72 · TUCR (refrigerator-freezer combo)",
    description: "True undercounter refrigerators are under every bar and prep station in SoCal. The TUC series runs a bottom-mount condensing unit — compact and designed for tight bar installations. The problem in bar environments: the condenser sits at floor level in an environment that's hot, humid, and thick with spilled beer, cleaning chemicals, and debris. Condenser coil cleaning in bar undercounters is a monthly task, not an annual one. We service more True undercounters in LA bars than any other single product category.",
    failures: [
      "Condenser coil loading — floor-level condenser in bar environment packs with debris monthly",
      "Fan motor failure — hot, humid bar environment accelerates motor wear",
      "Temperature controller sensor failure — probe in refrigerated compartment drifts or fails",
      "Door spring fatigue — undercounter doors open and close hundreds of times per service",
    ]
  },
  {
    series: "TSSU / TWT — Sandwich Prep & Worktop",
    models: "TSSU-27, TSSU-36, TSSU-48, TSSU-60, TSSU-72 · TWT-27, TWT-36, TWT-48",
    description: "True sandwich prep tables and worktops are the backbone of every QSR and casual dining kitchen in SoCal. The TSSU holds 33–41°F in the pan rail and 33–38°F in the cabinet below. In a busy kitchen, the pan rail lid is open for extended periods — the refrigeration system works harder to compensate for the constant heat load. The most common failure mode in SoCal's summer heat: the prep table can't maintain temperature with the rail open because the condenser coils are dirty. A prep table failure during lunch service means warm protein in a food-safety zone.",
    failures: [
      "Condenser coil loading — under-counter condenser in hot kitchen environment requires 3-month cleaning",
      "Temperature failure with lid open — dirty coils + summer heat = pan rail can't hold 41°F",
      "Cutting board crack — HDPE board above pan rail wears and develops bacterial-harbouring cracks",
      "Pan rail gasket failure — cold air escapes from pan section, temperatures rise",
    ]
  },
  {
    series: "TD Series — Display Merchandisers & Specialty",
    models: "TD-23 · THAC back bar · True Residential (T-30R, T-36R, T-48R)",
    description: "True's back bar coolers (THAC series) are standard in LA cocktail bars — stainless interior, glass doors, designed for bottle display and beverage service at 28–38°F. The THAC runs R-290 propane refrigerant in current production models — a hydrocarbon refrigerant with very low GWP. R-290 systems require EPA 608 technicians who are specifically trained for hydrocarbon refrigerants. Most general appliance companies will not service R-290 equipment — this is a technical barrier that separates commercial refrigeration specialists.",
    failures: [
      "R-290 refrigerant handling — only EPA 608 certified techs with hydrocarbon training can service",
      "Back bar glass door fogging — door heater failure in high-humidity bar environments",
      "Compressor overload — R-290 compressors are high-efficiency and sensitive to voltage fluctuation",
      "Temperature stratification — bottle display units show warm spots at door edges or top shelf",
    ]
  },
];

const faqItems = [
  {
    q: "Do you service all True Refrigeration commercial models?",
    a: `Yes — the full True commercial line: T-series reach-in refrigerators and freezers (T-23 through T-72), GDM glass door merchandisers, TUC and TUCR undercounters, TSSU sandwich prep tables, TWT worktops, THAC back bar coolers, and True Residential units. We also service the TD display line. Call ${phone} for availability.`
  },
  {
    q: "How fast can you respond to a True Refrigeration failure?",
    a: `Same-day response for commercial refrigeration emergencies throughout Los Angeles and Orange County. Call ${phone} immediately if you have a True unit failing during service hours — we dispatch from the nearest location with True parts stocked. A $2,000–$5,000 perishable loss risk justifies treating every commercial refrigeration failure as urgent.`
  },
  {
    q: "My True T-49 is running warm but the compressor sounds fine — what's wrong?",
    a: "In a restaurant kitchen environment, the most common cause of a True reach-in that runs warm despite a running compressor is evaporator coil icing (defrost system failure) or grease-coated evaporator fan blades reducing airflow. Both are maintenance-related issues, not compressor failures. Check the evaporator fan — if you don't hear it running, either the fan motor has failed or the coil is iced over. We diagnose this on-site before recommending any part replacement."
  },
  {
    q: "Can you service True units with R-290 propane refrigerant?",
    a: "Yes. True has transitioned newer THAC back bar and some commercial models to R-290 propane refrigerant. R-290 requires EPA 608 certified technicians with specific hydrocarbon refrigerant training — most residential appliance companies cannot legally service these units. We carry the appropriate equipment and certification for R-290 service. Never let an uncertified technician attempt R-290 work — propane refrigerant improperly handled is a fire and safety hazard."
  },
  {
    q: "How often should True undercounter bar coolers be cleaned?",
    a: "Monthly condenser cleaning minimum for bar undercounters. The TUC condenser sits at floor level in a bar environment — it's exposed to spilled liquids, cleaning chemicals, humidity, and debris from constant floor activity. Monthly cleaning is not excessive; it's the maintenance interval True recommends for high-soil environments. Annual cleaning is appropriate only for light-duty office or healthcare applications. We include condenser cleaning in all True undercounter service calls regardless of the presenting complaint."
  },
  {
    q: "What is your diagnostic fee for True commercial equipment?",
    a: `$120 commercial diagnostic, applied directly to the repair cost when you proceed. No hidden trip charge. We quote on-site after diagnosis — what we quote is what appears on the invoice.`
  },
];

const schemaJsons = [
