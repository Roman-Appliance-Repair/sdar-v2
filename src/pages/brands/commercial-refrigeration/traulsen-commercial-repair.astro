const title = "Traulsen Commercial Refrigeration Repair | Southern California";
const description = "Same-day Traulsen repair across Southern California. G-series reach-ins, RHT/RLT half-door, blast chillers. INTELA-TRAUL specialists. ITW family. (424) 325-0520.";
