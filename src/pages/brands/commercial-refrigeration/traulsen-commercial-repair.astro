---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">
    {schemaJsons.map((s) => (
      <script type="application/ld+json" set:html={JSON.stringify(s)} />
    ))}
  </Fragment>

  <section class="brand-hero">
    <div class="container hero-inner">
      <div class="hero-text">
        <p class="eyebrow">Commercial Refrigeration — Los Angeles &amp; SoCal</p>
        <h1><span class="brand-name">Traulsen</span> Commercial Refrigeration Repair in Los Angeles</h1>
        <p class="hero-sub">Expert service for Traulsen G-series reach-ins, RHT half-door units, blast chillers, and undercounters throughout Los Angeles, Orange County, and Southern California. INTELA-TRAUL control specialists.</p>
        <div class="hero-ctas">
          <a href={`tel:${phoneRaw}`} class="btn btn-primary btn-lg">{phone}</a>
          <a href={`tel:${phoneRaw}`} class="btn btn-outline btn-lg">Request Service</a>
        </div>
        <div class="hero-trust">
          <span>EPA 608 Certified</span>
          <span>INTELA-TRAUL Specialists</span>
          <span>$120 Commercial Diagnostic</span>
        </div>
      </div>
