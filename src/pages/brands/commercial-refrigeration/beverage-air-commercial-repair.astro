---
// src/pages/brands/commercial/beverage-air-repair.astro
import BaseLayout from '../../../layouts/BaseLayout.astro';

const phone = "(323) 870-4790";
const phoneRaw = "3238704790";

const title = `Beverage-Air Repair Los Angeles & SoCal — Commercial Refrigeration Service | ${phone}`;
const description = `Expert Beverage-Air commercial repair in Los Angeles, Orange County & SoCal. SP reach-ins, HR back bar coolers, UCR undercounters, DR display cases. Bar, restaurant & deli specialists. Call ${phone}.`;

const productLines = [
  {
    series: "SP / SPE Series — Reach-In Refrigerators & Freezers",
    models: "SP23HC, SP35HC, SP49HC, SP72HC · SPE23HC, SPE35HC · BEF23HC, BEF35HC (freezers)",
    description: "Beverage-Air's SP series is the workhorse reach-in refrigerator for mid-market restaurants, cafes, and food service operations throughout SoCal. More affordable than True or Traulsen, the SP series trades some engineering refinement for cost accessibility — and that trade-off shows in the failure pattern. SP units run a simpler analog thermostat control rather than a microprocessor system, which makes them straightforward to diagnose but also means they lack temperature logging or alarm functions. The condenser coil is accessible through the bottom front grille — critical in restaurant environments where monthly cleaning is necessary. We service more SP series units in LA's mid-market restaurant corridor (the neighborhood spots, taqueries, breakfast diners, and lunch counters) than any other Beverage-Air product line.",
    failures: [
      "Thermostat calibration drift — analog thermostat overcools or undercools; recalibration or replacement",
      "Condenser coil loading — bottom-front condenser in restaurant kitchen packs with grease and debris",
      "Evaporator fan motor failure — motor in cold compartment fails from moisture exposure",
      "Door gasket magnetic seal failure — magnetic gaskets on SP series wear faster than mechanical-latch types",
    ]
  },
  {
    series: "HR Series — Back Bar Coolers",
    models: "HR34-1-B, HR48-1-B, HR60-1-B, HR72-1-B, HR96-1-B · DD50HC (direct draw)",
    description: "Beverage-Air HR back bar coolers are under every bar in LA — from the dive bars in Silver Lake to the sports bars in the Valley to the hotel bars in Downtown. The HR series is designed specifically for front-of-house bar environments: stainless exterior, glass doors, LED lighting for bottle display, and a refrigeration circuit tuned for 36–38°F bottle service. In a high-traffic bar environment, the HR sees 200–400 door-open cycles per service. The door heater wire that prevents condensation on the glass fails in high-humidity bar environments — when it does, the glass fogs and the unit works harder. The condenser at the bottom of the HR gets exposed to spilled beer, cleaning products, and bar mat debris. Monthly cleaning is not optional.",
    failures: [
      "Door heater wire failure — glass fogs constantly, unit increases energy consumption",
      "Condenser coil contamination — beer, cleaning chemicals, and debris at floor-level condenser",
      "Thermostat over-cooling — bar units sometimes drift cold, freezing bottle necks near evaporator",
      "LED lighting failure — visible to customers, affects bar presentation",
    ]
  },
  {
    series: "UCR / UCF Series — Undercounter Refrigerators",
    models: "UCR20HC, UCR27HC, UCR34HC, UCR48HC · UCF20HC, UCF27HC (freezers)",
    description: "Beverage-Air undercounter refrigerators are the most space-efficient commercial cold storage solution in SoCal bars and prep stations. The UCR series runs the same basic refrigeration circuit as the HR back bar but in a 24-inch depth footprint for undercounter installation. The condenser is at the bottom rear — in a bar environment with limited clearance and constant floor-level exposure, condenser maintenance is the single most important preventive step. We see UCR failures cluster in two patterns: Friday afternoon before a busy weekend (condenser hasn't been cleaned in months, SoCal summer heat, unit can't keep up), and Monday morning after a holiday weekend of heavy use.",
    failures: [
      "Condenser coil overload — floor-level condenser in bar environment requires monthly cleaning",
      "Temperature creep in summer heat — dirty coils + 95°F SoCal day = UCR struggling at 45°F",
      "Fan motor failure — enclosed undercounter space concentrates heat around motor",
      "Door seal wear — undercounter door seals compress under the physical load of bar use",
    ]
  },
  {
    series: "DR / MMF Series — Display Cases & Merchandisers",
    models: "DR34HC, DR49HC, DR72HC · MMF23HC, MMF49HC · CF23HC (counter)",
    description: "Beverage-Air glass-door display refrigerators are standard in convenience stores, delis, and grab-and-go food service throughout SoCal. The DR series runs anti-sweat door frame heaters that prevent condensation on the glass — when these heaters fail, the glass fogs and door frames sweat, reducing product visibility and accelerating seal degradation. In SoCal's climate, display cases in convenience stores along the 405 corridor or in East LA delis run harder than equivalent units in cooler markets. The bottom-mounted condensing system needs quarterly cleaning in high-traffic, warm environments.",
    failures: [
      "Anti-sweat heater failure — door frames sweat, glass fogs, product visibility drops",
      "Mullion heater failure — center mullion between glass doors sweats excessively",
      "Compressor overload in summer — display case in warm store environment near window or door",
      "Lighting array failure — LED or T8 fluorescent arrays in display cases are customer-visible",
    ]
  },
  {
    series: "MT / CF Series — Prep & Counter Units",
    models: "MT49HC, MT72HC · CF23HC, CF49HC · LV-Series liquor vault",
    description: "Beverage-Air's MT prep tables and CF counter refrigerators serve LA's sandwich shops, pizza prep stations, and counter-service operations. The MT series holds 33–41°F in the pan rail and 33–38°F in the cabinet. In a busy prep station, the rail lid is open for extended periods — exactly the same thermal challenge as True TSSU units, but at a lower price point with less insulation reserve. Summer heat plus open rail plus dirty condenser is the standard failure scenario for BA prep tables in SoCal. The Beverage-Air LV liquor vault — designed for below-counter spirit storage — is a specialty unit found in higher-volume LA bars where spirit inventory is large enough to require dedicated cold storage.",
    failures: [
      "Pan rail temperature failure — dirty condenser + summer heat + open lid = warm proteins",
      "Cutting board crack — HDPE surface develops bacterial-harbouring cracks from heavy use",
      "Thermostat sensor failure — rail temperature sensor drifts from evaporator icing",
      "LV liquor vault — compressor overload from high ambient temperature in enclosed bar cabinet",
    ]
  },
];

const barServiceBlock = {
  title: "Bar Equipment Failures — The SoCal Friday Night Problem",
  body: `The Los Angeles bar industry has a specific appliance service dynamic that doesn't exist in most other commercial sectors: the failure moment that matters most is always the worst possible time. A Beverage-Air back bar cooler that starts struggling on a Thursday afternoon will fail completely on Friday night. A UCR undercounter that's been running warm for a week will stop cooling entirely on the Saturday of a holiday weekend.

The math is simple. A mid-volume LA bar — not a nightclub, just a neighborhood bar or sports bar — does 40–60% of its weekly revenue on Friday and Saturday nights. A back bar failure on Friday at 7pm means warm beer, warm cocktail mixers, and a bartender calling for backup coolers and ice from the restaurant supply down the block. We treat bar refrigeration calls exactly as urgently as restaurant service calls — because in bar economics, Friday night is service.

We stock HR series and UCR series parts on our commercial trucks specifically for the SoCal bar market. Door heater wire assemblies, thermostat assemblies, condenser fan motors, and door gaskets for the most common HR and UCR models are available on the truck. Most bar equipment failures resolve same-day.`,
};

const faqItems = [
  {
    q: "Do you service all Beverage-Air commercial models?",
    a: `Yes — the full Beverage-Air commercial line: SP and SPE series reach-in refrigerators and freezers, HR back bar coolers, UCR and UCF undercounters, DR and MMF glass door display cases, MT prep tables, CF counter units, and the LV liquor vault series. Call ${phone} for same-day availability.`
  },
  {
    q: "My Beverage-Air back bar is fogging on the glass doors — what's wrong?",
    a: "Almost always a door heater wire failure. Beverage-Air HR series doors have a resistive heating element embedded in the door frame that prevents condensation on the glass. When this wire fails, the glass fogs immediately in humid bar environments. The fix is replacement of the door heater wire assembly — a parts-and-labor job that typically takes 60–90 minutes per door. Don't let a fogged bar display run — the increased condensation accelerates door gasket degradation and the unit works harder to compensate."
  },
  {
    q: "How often should Beverage-Air bar undercounters be cleaned?",
    a: "Monthly condenser cleaning minimum for bar undercounters in SoCal. The UCR condenser sits at floor level in a bar environment with constant exposure to spilled liquids, cleaning chemicals, and humidity. Monthly cleaning is not excessive — it's the interval necessary to prevent summer heat failures. Bars that get quarterly cleaning instead of monthly will have at least one UCR failure per summer. We include condenser cleaning on every BA bar equipment call regardless of the presenting complaint."
  },
  {
    q: "Is Beverage-Air equipment worth repairing versus replacing?",
    a: "Yes, with a realistic assessment. Beverage-Air occupies the affordable commercial tier — new SP49HC two-door reach-in runs $2,000–$3,000, new HR72-1-B back bar $1,800–$2,500. Repair economics are favorable through the first 8–10 years of service: a thermostat replacement ($150–$200), fan motor replacement ($180–$300), or door gasket set ($100–$180) on a sound machine makes sense. When the compressor fails on a 12-year-old BA unit, the repair-versus-replace calculation becomes closer — we give you honest numbers after diagnosis."
  },
  {
    q: "What is your diagnostic fee for Beverage-Air commercial equipment?",
    a: `$120 commercial diagnostic, applied directly to the repair cost when you proceed. No hidden trip charge throughout SoCal.`
  },
  {
    q: "Can you respond same-day to a bar equipment failure?",
    a: `Yes. Bar equipment failures — especially on Thursday, Friday, or Saturday — are treated as emergency calls. Call ${phone} immediately. We dispatch from the nearest location with BA parts stocked and aim for same-day resolution. We understand that a bar cooler failure before weekend service is a revenue emergency, not just an inconvenience.`
  },
];

const schema = {
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  "name": "Same Day Appliance Repair — Beverage-Air Commercial Service",
  "telephone": phone,
  "email": "info@samedayappliance.repair",
  "areaServed": ["Los Angeles", "Orange County", "Ventura County", "San Bernardino County", "Riverside County"],
  "priceRange": "$$",
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.7",
    "reviewCount": "22",
    "bestRating": "5"
  }
};
---

<BaseLayout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <section class="brand-hero">
    <div class="container hero-inner">
      <div class="hero-text">
        <p class="eyebrow">Commercial Refrigeration — Los Angeles &amp; SoCal</p>
        <h1><span class="brand-name">Beverage-Air</span><br>Commercial Repair</h1>
        <p class="hero-sub">Expert service for Beverage-Air SP reach-ins, HR back bar coolers, UCR undercounters, DR display cases, and MT prep tables throughout Los Angeles, Orange County, and Southern California.</p>
        <div class="hero-ctas">
          <a href={`tel:${phoneRaw}`} class="btn btn-primary btn-lg">{phone}</a>
          <a href="/book" class="btn btn-outline btn-lg">Request Service</a>
        </div>
        <div class="hero-trust">
          <span>⭐ 4.7 · 22 Commercial Reviews</span>
          <span>EPA 608 Certified</span>
          <span>Bar &amp; Restaurant Specialists</span>
          <span>$120 Commercial Diagnostic</span>
        </div>
      </div>
      <div class="hero-badge">
        <div class="badge-inner">
          <div class="badge-brand">BEVERAGE-AIR</div>
          <div class="badge-line">Bar · Restaurant · Deli · C-Store</div>
          <div class="badge-specs">
            <span>SP Reach-Ins</span>
            <span>HR Back Bar</span>
            <span>UCR Undercounter</span>
            <span>DR Display</span>
            <span>MT Prep Tables</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="trust-bar">
    <div class="container trust-bar-inner">
      <div class="trust-item"><span class="ti-icon">🍺</span><span>Bar Equipment Specialists</span></div>
      <div class="trust-item"><span class="ti-icon">⚡</span><span>Same-Day Emergency Response</span></div>
      <div class="trust-item"><span class="ti-icon">🔬</span><span>EPA 608 Certified</span></div>
      <div class="trust-item"><span class="ti-icon">🏪</span><span>Restaurant, Deli &amp; C-Store</span></div>
      <div class="trust-item"><span class="ti-icon">📋</span><span>PM Contracts Available</span></div>
    </div>
  </div>

  <section class="intro-section container">
    <div class="intro-content">
      <h2>Beverage-Air Repair in Southern California — The Bar and Restaurant Standard</h2>

      <p>Beverage-Air occupies a different tier than Hoshizaki, True, or Traulsen — and that's by design. Where Traulsen serves the institutional and fine-dining market and True dominates the mid-to-upper restaurant segment, Beverage-Air fills the high-volume, cost-accessible end of the commercial refrigeration market. The brand is in every neighborhood bar in LA, every convenience store cooler along the 405 corridor, every deli on the Eastside, every taproom in the Arts District. When you need reliable commercial refrigeration at an accessible price point with parts that are widely available and a repair network that covers the full SoCal market — that's Beverage-Air's position.</p>

      <p>The failure patterns in Beverage-Air equipment reflect the environments these units run in. HR back bar coolers at floor level in a bar setting see spilled beer, cleaning chemicals, and humidity that destroy condenser coils if they aren't cleaned monthly. SP reach-ins in neighborhood restaurants run analog thermostats that drift over time. Display cases in convenience stores need anti-sweat heater wire maintenance that most operators don't know exists. We service Beverage-Air throughout SoCal and stock parts specifically for the most common BA failure modes in bar and restaurant environments.</p>

      <p>$120 commercial diagnostic applied to the repair. Same-day response on bar and restaurant emergency calls. EPA 608 certified. Call {phone}.</p>
    </div>

    <aside class="sticky-cta-box">
      <p class="scb-brand">Beverage-Air</p>
      <p class="scb-phone">{phone}</p>
      <a href={`tel:${phoneRaw}`} class="btn btn-primary btn-block">Emergency Call</a>
      <a href="/book" class="btn btn-outline btn-block">Schedule Service</a>
      <ul class="scb-list">
        <li>✓ $120 Commercial Diagnostic → Applied</li>
        <li>✓ BA Parts Stocked on Trucks</li>
        <li>✓ EPA 608 Certified</li>
        <li>✓ Same-Day Bar Equipment Response</li>
        <li>✓ PM Contracts Available</li>
        <li>✓ LA, OC, Ventura, IE Coverage</li>
      </ul>
      <p class="scb-note">Bar cooler down before the weekend? Call immediately — we stock HR and UCR parts on every commercial truck.</p>
    </aside>
  </section>

  <section class="product-lines container">
    <h2>Beverage-Air Equipment We Service</h2>
    <div class="lines-grid">
      {productLines.map((line, i) => (
        <div class="line-card">
          <div class="line-number">{String(i + 1).padStart(2, '0')}</div>
          <div class="line-body">
            <h3>{line.series}</h3>
            <p class="line-models"><strong>Models:</strong> {line.models}</p>
            <p class="line-desc">{line.description}</p>
            <div class="failure-list">
              <p class="failure-label">Common SoCal failure modes:</p>
              <ul>
                {line.failures.map(f => <li>{f}</li>)}
              </ul>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- BAR SERVICE BLOCK -->
  <section class="bar-section">
    <div class="container bar-inner">
      <h2>{barServiceBlock.title}</h2>
      <div class="bar-content">
        {barServiceBlock.body.split('\n\n').map(para => <p>{para}</p>)}
      </div>
    </div>
  </section>

  <!-- RECENT REPAIRS -->
  <section class="repairs-section container">
    <h2>Recent Beverage-Air Service Calls</h2>
    <div class="repairs-grid">
      <div class="repair-card">
        <h3>"HR72 back bar — fogging glass, Silver Lake dive bar"</h3>
        <p class="repair-loc">📍 Silver Lake, Los Angeles</p>
        <p>HR72-1-B back bar, both glass doors fogging from the minute the bar opened. Door heater wire failure on both doors — classic pattern, both usually go within a few months of each other. Replaced door heater wire assemblies on both doors with OEM Beverage-Air parts. While there, pulled the condenser from the bottom grille — thick layer of beer residue and debris, hadn't been cleaned in 8+ months. Cleaned condenser, tested cooling at full capacity. Bar had good temperature throughout service that evening.</p>
        <p class="repair-note"><em>HR glass door fogging: door heater wire failure. Always check both doors — the second one isn't far behind the first.</em></p>
      </div>
      <div class="repair-card">
        <h3>"SP49HC reach-in — running at 48°F, taco restaurant East LA"</h3>
        <p class="repair-loc">📍 East Los Angeles</p>
        <p>Neighborhood taqueria, SP49HC showing 48°F — above the 41°F food safety threshold. Analog thermostat had drifted warm over 18 months of service, a common pattern on SP series. Replaced the thermostat assembly, reset to 38°F, confirmed stable temperature within 30 minutes. Also found the condenser coil moderately loaded through the bottom grille — cleaned while there. Restaurant had been running with the unit warm for "a few weeks" and hadn't realized the food safety implication. Clean documentation left for their health inspection file.</p>
        <p class="repair-note"><em>SP analog thermostats drift over time. Annual calibration check should be part of any PM program.</em></p>
      </div>
      <div class="repair-card">
        <h3>"DR49HC display case — fogging glass, anti-sweat failure, convenience store"</h3>
        <p class="repair-loc">📍 South Los Angeles convenience store</p>
        <p>Beverage-Air DR49 display case, glass doors fogging constantly — customer couldn't see beverages. Anti-sweat heater wire had failed in the right door frame. Also found the mullion heater between the two doors failing — both are part of the same heater circuit, and the mullion failure was causing condensation that dripped onto the floor in front of the case. Replaced both the door frame anti-sweat heater assembly and the mullion heater with OEM BA parts. Glass clear, no condensation within 2 hours.</p>
        <p class="repair-note"><em>DR series: anti-sweat and mullion heaters often fail together — check both when one presents.</em></p>
      </div>
      <div class="repair-card">
        <h3>"UCR34HC undercounter — not cooling, Friday 4pm, Valley sports bar"</h3>
        <p class="repair-loc">📍 San Fernando Valley sports bar</p>
        <p>Called at 4pm Friday — sports bar opening at 5pm, undercounter bar cooler stopped cooling. Condenser coil completely blocked — the unit sits in a floor-level bar cabinet with no cleaning access through the back for 6 months. Pulled the unit, cleaned the condenser, confirmed normal cooling operation by 4:45pm. Bar opened on time. Owner had never been told the condenser needed cleaning. Set them on a monthly cleaning reminder. Bar now on a quarterly PM contract — three UCR units across the bar stations.</p>
        <p class="repair-note"><em>UCR failure on Friday afternoon: 90% chance it's a dirty condenser. Bar owners are almost never told about condenser cleaning.</em></p>
      </div>
    </div>
  </section>

  <section class="faq-section container">
    <h2>Beverage-Air Commercial Service — FAQ</h2>
    <div class="faq-list">
      {faqItems.map(item => (
        <details class="faq-item">
          <summary class="faq-q">{item.q}</summary>
          <p class="faq-a">{item.a}</p>
        </details>
      ))}
    </div>
  </section>

  <section class="bottom-cta">
    <div class="container">
      <h2>Beverage-Air Equipment Down? We Respond Today.</h2>
      <p>Same-day emergency service for Beverage-Air SP, HR, UCR, DR, and MT equipment throughout Los Angeles, Orange County, and Southern California. Bar and restaurant specialists. EPA 608 certified.</p>
      <div class="cta-buttons">
        <a href={`tel:${phoneRaw}`} class="btn btn-primary btn-lg">{phone}</a>
        <a href="/book" class="btn btn-outline btn-lg">Schedule Service</a>
      </div>
      <p class="cta-sub">Also servicing: Hoshizaki · True Refrigeration · Traulsen · Perlick · Delfield</p>
    </div>
  </section>

</BaseLayout>

<style>
.brand-hero{background:var(--color-bg);padding:5rem 0 4rem;border-bottom:1px solid var(--color-border)}
.hero-inner{display:grid;grid-template-columns:1fr auto;gap:4rem;align-items:center}
.eyebrow{font-size:.75rem;letter-spacing:.12em;text-transform:uppercase;color:var(--color-accent);margin-bottom:.75rem}
h1{font-size:clamp(2rem,4vw,3rem);font-weight:800;line-height:1.1;margin-bottom:1rem}
.brand-name{color:var(--color-accent)}
.hero-sub{font-size:1.05rem;color:var(--color-text-muted);margin-bottom:2rem;max-width:52ch}
.hero-ctas{display:flex;gap:1rem;flex-wrap:wrap;margin-bottom:1.5rem}
.hero-trust{display:flex;gap:1.5rem;flex-wrap:wrap;font-size:.8rem;color:var(--color-text-muted)}
.hero-badge{background:var(--color-surface);border:1px solid var(--color-border);border-radius:1rem;padding:2rem;min-width:200px;text-align:center}
.badge-brand{font-size:.95rem;font-weight:900;letter-spacing:.05em;color:var(--color-accent);margin-bottom:.25rem}
.badge-line{font-size:.7rem;color:var(--color-text-muted);margin-bottom:1rem}
.badge-specs{display:flex;flex-direction:column;gap:.4rem}
.badge-specs span{background:var(--color-bg);border:1px solid var(--color-border);border-radius:.25rem;padding:.25rem .5rem;font-size:.75rem}
.trust-bar{background:var(--color-accent);padding:1rem 0}
.trust-bar-inner{display:flex;gap:2rem;justify-content:center;flex-wrap:wrap}
.trust-item{display:flex;align-items:center;gap:.5rem;color:#fff;font-size:.875rem;font-weight:600}
.intro-section{display:grid;grid-template-columns:1fr 300px;gap:4rem;padding-top:4rem;padding-bottom:4rem}
.intro-content h2{font-size:1.6rem;margin-bottom:1.25rem}
.intro-content p{margin-bottom:1.25rem;line-height:1.75;color:var(--color-text-body)}
.sticky-cta-box{background:var(--color-surface);border:1px solid var(--color-border);border-radius:.75rem;padding:1.75rem;position:sticky;top:5rem;height:fit-content}
.scb-brand{font-size:.75rem;text-transform:uppercase;letter-spacing:.1em;color:var(--color-accent);margin-bottom:.25rem}
.scb-phone{font-size:1.4rem;font-weight:800;margin-bottom:1.25rem}
.btn-block{display:block;width:100%;text-align:center;margin-bottom:.75rem}
.scb-list{list-style:none;padding:0;margin:1.25rem 0;font-size:.8rem}
.scb-list li{padding:.3rem 0;border-bottom:1px solid var(--color-border);color:var(--color-text-body)}
.scb-note{font-size:.75rem;color:var(--color-text-muted);margin-top:1rem;font-style:italic}
.product-lines{padding:4rem 0}
.product-lines h2{font-size:1.6rem;margin-bottom:2rem}
.lines-grid{display:flex;flex-direction:column;gap:2rem}
.line-card{display:grid;grid-template-columns:60px 1fr;gap:1.5rem;background:var(--color-surface);border:1px solid var(--color-border);border-radius:.75rem;padding:2rem}
.line-number{font-size:2.5rem;font-weight:900;color:var(--color-accent);opacity:.25;line-height:1}
.line-body h3{font-size:1.1rem;margin-bottom:.4rem}
.line-models{font-size:.8rem;color:var(--color-text-muted);margin-bottom:.75rem}
.line-desc{font-size:.9rem;line-height:1.7;color:var(--color-text-body);margin-bottom:1rem}
.failure-label{font-size:.8rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em;color:var(--color-accent);margin-bottom:.5rem}
.failure-list ul{list-style:none;padding:0;display:grid;grid-template-columns:1fr 1fr;gap:.5rem}
.failure-list li{font-size:.85rem;color:var(--color-text-body);padding-left:1rem;position:relative;line-height:1.5}
.failure-list li::before{content:"→";position:absolute;left:0;color:var(--color-accent)}
.bar-section{background:var(--color-surface);border-top:1px solid var(--color-border);padding:4rem 0}
.bar-inner h2{font-size:1.6rem;margin-bottom:2rem}
.bar-content{max-width:75ch}
.bar-content p{font-size:.95rem;line-height:1.8;color:var(--color-text-body);margin-bottom:1.25rem}
.repairs-section{padding:4rem 0}
.repairs-section h2{font-size:1.6rem;margin-bottom:2rem}
.repairs-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.5rem}
.repair-card{background:var(--color-surface);border:1px solid var(--color-border);border-radius:.75rem;padding:1.75rem}
.repair-card h3{font-size:.95rem;font-weight:700;margin-bottom:.5rem}
.repair-loc{font-size:.8rem;color:var(--color-accent);margin-bottom:.75rem}
.repair-card p{font-size:.875rem;line-height:1.7;color:var(--color-text-body);margin-bottom:.75rem}
.repair-note{font-size:.825rem;color:var(--color-text-muted);border-top:1px solid var(--color-border);padding-top:.75rem}
.faq-section{padding:4rem 0}
.faq-section h2{font-size:1.6rem;margin-bottom:2rem}
.faq-list{display:flex;flex-direction:column;gap:.75rem}
.faq-item{border:1px solid var(--color-border);border-radius:.5rem;background:var(--color-surface)}
.faq-q{padding:1.25rem 1.5rem;font-weight:600;cursor:pointer;list-style:none}
.faq-a{padding:0 1.5rem 1.25rem;font-size:.9rem;line-height:1.7;color:var(--color-text-body)}
.bottom-cta{background:var(--color-accent);padding:4rem 0;text-align:center}
.bottom-cta h2{font-size:1.75rem;margin-bottom:.75rem;color:#fff}
