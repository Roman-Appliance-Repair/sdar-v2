---
import Layout from '../../layouts/Layout.astro';

const title = "Frigidaire Ice Maker Repair LA | Gallery + Professional";
const description = "Frigidaire ice maker repair in LA — FRFS French-door, FGHB Gallery, PRMC Professional, FFSS side-by-side. Electrolux 1986+ parts chain, PureSource filter. $89 diagnostic. (424) 325-0520.";
const canonical = "https://samedayappliance.repair/brands/frigidaire-ice-maker-repair/";

const faqs = [
  {
    q: "What's the Frigidaire tier hierarchy and how does it affect service?",
    a: "Frigidaire operates three tiers: <b>Frigidaire standard</b> (FFSS / FRFS value-tier mass-market), <b>Frigidaire Gallery</b> (FGHB premium sub-tier with feature upgrades), and <b>Frigidaire Professional</b> (PRMC top-tier premium with pro-style aesthetic). All three tiers share the same Electrolux North America parts distribution (Charlotte NC HQ + Anderson SC factory). Ice-maker architecture is similar across tiers with feature-set differentiation rather than fundamentally different mechanisms. Our service covers all three through the same protocol."
  },
  {
    q: "Is Frigidaire the same company as Electrolux?",
    a: "Frigidaire is the North American value + mid-market brand under <b>Electrolux AB</b> (Swedish parent since 1986 acquisition; originally Frigidaire Corp 1918 Detroit, then GM subsidiary, then White Consolidated, then Electrolux). Residential Frigidaire and Electrolux-branded residential share engineering and parts chain. Important disambig: <b>Electrolux Professional</b> is a SEPARATE commercial brand (EPRO 2020 Nasdaq spin-off) — not related to Frigidaire residential or Electrolux residential. For restaurant / commercial ice production see <a href='/commercial/ice-machine-repair/'>commercial ice machine repair</a>."
  },
  {
    q: "Frigidaire ice maker not making ice — diagnostic order?",
    a: "Standard diagnostic: (1) water-inlet valve — Frigidaire valves at 5-8 year mark; valve swap $180–$280; (2) ice-maker modular assembly $220–$360; (3) PureSource water filter (PureSource 1 / 2 / 3 / Plus / Ultra depending on model); filter $50–$80 routine; (4) thermistor / ice-bin sensor $160–$240; (5) ejector motor $140–$220; (6) refrigerant-leak-caused evap-frost impact on ice-maker cycle — requires sealed-system diagnostic $340–$500 when cooling side compromised; (7) evaporator fan motor $220–$340. LA-area Frigidaire parts ship 1-2 day through Electrolux distribution."
  },
  {
    q: "PureSource water filter — how does it differ from other brands?",
    a: "PureSource is Frigidaire's (+ Electrolux residential's) water filter brand. Multiple generations: PureSource 1 (older models), PureSource 2, PureSource 3, PureSource Plus (Professional tier), PureSource Ultra. Each generation fits specific Frigidaire year-ranges — compatibility isn't interchangeable across generations. Replacement cost $50-$80 by model. Schedule every 6 months. LA hard water sometimes requires 4-month replacement on high-use households. Neglected filter affects ice quality (cloudy / off-taste) + ice-fill pressure (undersized cubes)."
  },
  {
    q: "What does Frigidaire ice maker repair cost in LA?",
    a: "Residential diagnostic $89 waived with repair. Typical Frigidaire bands: water-inlet valve $180–$280; modular ice-maker assembly $220–$360; ejector motor $140–$220; thermistor $160–$240; PureSource filter $50–$80; evaporator fan motor $220–$340; control board $380–$560; door-seal gasket $160–$240; sealed-system diagnostic (refrigerant-leak) $340–$500. Professional tier parts run 10-15% higher than standard tier on certain specialty components. Electrolux distribution supports 1-2 day LA-local parts."
  },
  {
    q: "Frigidaire vs commercial ice machines?",
    a: "Frigidaire is residential-only. Electrolux Professional (EPRO commercial brand) is separate — NOT Frigidaire residential. For restaurant / bar / commercial 200+ lb/day production, see <a href='/commercial/ice-machine-repair/'>commercial ice machine repair</a> covering Manitowoc / Hoshizaki / Scotsman / Follett."
  }
];

const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair — Frigidaire Ice Maker Service",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": canonical, "telephone": "+1-424-325-0520", "priceRange": "$$",
    "address": { "@type": "PostalAddress", "streetAddress": "6230 Wilshire Blvd Ste A PMB 2267", "addressLocality": "Los Angeles", "addressRegion": "CA", "postalCode": "90048", "addressCountry": "US" },
    "geo": { "@type": "GeoCoordinates", "latitude": 34.0619, "longitude": -118.3692 },
    "aggregateRating": { "@type": "AggregateRating", "ratingValue": "4.6", "reviewCount": "37" }
  },
  { "@context": "https://schema.org", "@type": "Service", "serviceType": "Frigidaire Ice Maker Repair",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [{"@type":"AdministrativeArea","name":"Los Angeles County"},{"@type":"AdministrativeArea","name":"Orange County"},{"@type":"AdministrativeArea","name":"Ventura County"}],
    "description": "Frigidaire ice maker repair across LA — FRFS / FFSS standard, FGHB Gallery, PRMC Professional tier. Electrolux 1986+ parts chain, PureSource filter. $89 residential diagnostic waived with repair.",
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, waived with repair" } }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "Frigidaire", "item": "https://samedayappliance.repair/brands/frigidaire/" },
      { "@type": "ListItem", "position": 4, "name": "Frigidaire Ice Maker Repair", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>
