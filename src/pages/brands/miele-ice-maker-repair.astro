---
import Layout from '../../layouts/Layout.astro';
import BrandBranchesGrid from '../../components/BrandBranchesGrid.astro';
import { MAIN_PHONE, MAIN_PHONE_TEL } from '../../data/branches';

const title = "Miele Ice Maker Repair Los Angeles — Same Day";
const description = "Miele ice maker repair across SoCal, MasterCool F1411Vi / F2811Vi column + KF2902Vi French-door integrated. Miele AG Gütersloh 1899 family. $89 dx.";
const canonical = "https://samedayappliance.repair/brands/miele-ice-maker-repair/";

const faqs = [
  {
    q: "Miele residential vs Miele Professional, which is this?",
    a: "This page covers <b>Miele MasterCool residential</b> (F1411Vi 24\" column + F2811Vi 36\" column + KF2902Vi French-door integrated). <b>Miele Professional</b> is a separate commercial division (PG-series commercial refrigeration + dishwashers + washers/dryers; 2025 Alabama plant), not the MasterCool residential line. If you have a Miele Professional commercial PG-series ice or refrigeration unit, see <a href='/commercial/ice-machines/'>commercial ice machine repair</a> or contact our commercial team. This page covers residential only."
  },
  {
    q: "Is Miele still family-owned after 125+ years?",
    a: "Yes, Miele AG (Gütersloh, Germany; founded 1899) remains family-owned by the Miele + Zinkann families into the 5th/6th generation (Reinhard + Markus Miele-Zinkann current leadership). Miele hasn't been sold to a conglomerate like BSH (Thermador/Gaggenau) or Middleby (Viking). That ownership continuity matters for service, product + parts decisions made by the family, generational parts support on MasterCool platform. US parts through Miele Princeton NJ distribution + 2025 Alabama plant; typical 3-5 day parts to LA authorized service."
  },
  {
    q: "Miele MasterCool ice maker no-ice diagnostic?",
    a: "F1411Vi / F2811Vi column + KF2902Vi French-door integrated diagnostic: (1) water-inlet valve $240–$360; (2) harvest cycle thermistor $240–$360; (3) ice-bin sensor $200–$320; (4) evaporator plate service $300–$440; (5) control board $480–$680; (6) F-code readout from display panel narrows fault. Miele parts 3-5 day typical through Princeton NJ distribution. Miele MasterCool service requires factory-authorized technician certification, verify with our dispatch."
  },
  {
    q: "MasterCool integration, service different from standalone?",
    a: "MasterCool F/KF ice maker integrates tightly with F/K column refrigerator as coordinated single-appliance system. Service often requires access to adjacent refrigerator column wiring + common control board logic. Coordinated service visits typical rather than single-component diagnostic. Our techs trained on full MasterCool suite."
  },
  {
    q: "What does Miele ice maker repair cost in LA?",
    a: "Residential diagnostic $89 waived with repair. Typical Miele bands: water-inlet valve $240–$360; harvest thermistor $240–$360; ice-bin sensor $200–$320; evaporator plate service $300–$440; compressor start relay $220–$340; control board $480–$680; door-seal gasket $200–$300; MasterCool panel service quoted individually. Miele service runs 20-30% above mass-market on individual parts reflecting factory-trained + specialty German engineering."
  }
];

const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair, Miele Ice Maker Service",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": canonical, "telephone": MAIN_PHONE_TEL, "priceRange": "$$$$"
  },
  { "@context": "https://schema.org", "@type": "Service", "serviceType": "Miele Ice Maker Repair",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "description": "Miele ice maker repair across Southern California, LA, Orange, Ventura, San Bernardino, Riverside. MasterCool F1411Vi / F2811Vi column + KF2902Vi French-door integrated. Miele AG Gütersloh Germany 1899 family-owned (Miele/Zinkann 5th+ generation). $89 residential diagnostic waived with repair.",
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, waived with repair" } }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "Miele", "item": "https://samedayappliance.repair/brands/miele/" },
      { "@type": "ListItem", "position": 4, "name": "Miele Ice Maker Repair", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">{schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}</Fragment>
  <div class="call-banner"><div class="wrap"><span>Miele ice maker service? Same-day across all 5 SoCal counties:</span><a href={`tel:${MAIN_PHONE_TEL}`} class="phone-lg">{MAIN_PHONE}</a></div></div>

  <section class="hero"><div class="wrap">
    <div class="crumb"><a href="/">Home</a> › <a href="/brands/">Brands</a> › Miele › Ice Maker Repair</div>
    <h1>Miele Ice Maker Repair</h1>
    <p class="lede">Miele MasterCool residential ice makers (F1411Vi 24" column + F2811Vi 36" column + KF2902Vi French-door integrated) represent Miele's luxury integrated refrigeration line, manufactured by Miele AG in Gütersloh, Germany (family-owned since 1899 into the 5th/6th Miele-Zinkann family generation). Parts through Miele Princeton NJ + 2025 Alabama plant distribution, 3-5 day typical to LA authorized service. Miele MasterCool service requires factory-authorized technician certification. Same-day dispatch, $89 residential diagnostic waived with the repair.</p>
    <div class="hero-cta"><a href={`tel:${MAIN_PHONE_TEL}`} class="btn btn-primary">Call {MAIN_PHONE}</a><a href="#book" class="btn btn-ghost">Request a Visit</a></div>
    <ul class="hero-facts">
      <li><b>Miele AG Gütersloh 1899 family</b>, 5th+ generation ownership</li>
      <li><b>MasterCool F1411Vi + F2811Vi + KF2902Vi</b>, column + French-door integrated</li>
      <li><b>Miele Professional separate</b>, commercial PG-series NOT this page</li>
      <li><b>$89 residential diagnostic</b>, waived when you authorize the repair</li>
    </ul>
  </div></section>

  <BrandBranchesGrid />

  <section class="trust-bar"><div class="wrap"><span>BHGS #A49573 · Insured</span><span>Same-day in 5 SoCal counties</span><span>Residential diagnostic $89 · waived with repair</span></div></section>

  <section class="section"><div class="wrap narrow">
    <h2>Miele ice maker service in LA, MasterCool luxury integration</h2>
    <p>Miele MasterCool installs in LA concentrate in luxury Bel Air + Beverly Hills + Pacific Palisades + Malibu custom kitchens where MasterCool coordinates F/K column refrigerator + ice maker + wine column as integrated appliance suite. Service requires factory-authorized technician certification; our techs carry Miele MasterCool training. Parts through Princeton NJ + Alabama plant typically 3-5 day to LA authorized service.</p>
  </div></section>

  <section class="section alt"><div class="wrap">
    <h2>Miele ice maker failures our techs see most often</h2>
    <div class="fail-block"><h3>Water-inlet valve</h3><p>Valve $240–$360.</p></div>
    <div class="fail-block"><h3>Harvest cycle thermistor</h3><p>Thermistor $240–$360.</p></div>
    <div class="fail-block"><h3>Ice-bin sensor</h3><p>Sensor $200–$320.</p></div>
    <div class="fail-block"><h3>Evaporator plate service</h3><p>Plate service $300–$440.</p></div>
    <div class="fail-block"><h3>F-code display fault</h3><p>Display-panel F-code readout narrows diagnostic path.</p></div>
    <div class="fail-block"><h3>Control board</h3><p>Board $480–$680.</p></div>
  </div></section>

  <section class="section"><div class="wrap">
    <h2>Miele ice maker product lines we service</h2>
    <div class="model-grid">
      <div class="model-card"><h3>F1411Vi 24" column integrated</h3><p>MasterCool 24" ice column. Pairs with F/K column refrigerator.</p></div>
      <div class="model-card"><h3>F2811Vi 36" column integrated</h3><p>MasterCool 36" wider format.</p></div>
      <div class="model-card"><h3>KF2902Vi French-door integrated</h3><p>French-door refrigerator with integrated ice + water.</p></div>
      <div class="model-card"><h3>Miele Pro disambig block</h3><p>Residential MasterCool ≠ commercial Miele Professional PG-series.</p></div>
      <div class="model-card"><h3>Princeton NJ parts distribution</h3><p>3-5 day typical LA lead + 2025 Alabama plant.</p></div>
      <div class="model-card"><h3>Factory-trained tech required</h3><p>Miele certification for MasterCool service.</p></div>
    </div>
  </div></section>

  <section class="section alt"><div class="wrap narrow">
    <h2>Miele residential vs Miele Professional commercial</h2>
    <p>Residential Miele MasterCool (F/KF series this page) ≠ commercial Miele Professional (PG-series), separate division with Alabama 2025 plant serving both. For commercial refrigeration + ice see <a href="/commercial/ice-machines/">commercial ice machine repair</a>. For Miele Professional commercial dishwashers / laundry see commercial categories.</p>
  </div></section>

  <section class="section"><div class="wrap">
    <h2>What Miele ice maker repair typically costs</h2>
    <table class="price-table">
      <tr><th>Service</th><th>Typical Range</th><th>Notes</th></tr>
      <tr><td>Residential diagnostic</td><td>$89</td><td>Waived with repair</td></tr>
      <tr><td>Water-inlet valve</td><td>$240 – $360</td><td>MasterCool F/KF</td></tr>
      <tr><td>Harvest thermistor</td><td>$240 – $360</td><td>Cycle trigger</td></tr>
      <tr><td>Ice-bin sensor</td><td>$200 – $320</td><td>Bin-full detection</td></tr>
      <tr><td>Evaporator plate service</td><td>$300 – $440</td><td>Cold-plate maintenance</td></tr>
      <tr><td>Compressor start relay</td><td>$220 – $340</td><td>Start circuit</td></tr>
      <tr><td>Control board</td><td>$480 – $680</td><td>Main control</td></tr>
      <tr><td>Door-seal gasket</td><td>$200 – $300</td><td>Cavity integrity</td></tr>
    </table>
    <p class="small">Related: <a href="/brands/miele-refrigerator-repair/">Miele brand hub</a> · <a href="/brands/miele-refrigerator-repair/">Miele refrigerator repair</a> · <a href="/brands/sub-zero-ice-maker-repair/">Sub-Zero ice maker (luxury alt)</a>.</p>
  </div></section>

  <section class="section alt"><div class="wrap">
    <h2>LA service areas</h2>
    <div class="area-grid">
      <div><h4>Bel Air + Beverly Hills</h4><p><a href="/beverly-hills/">Beverly Hills</a> · Bel Air</p></div>
      <div><h4>Pacific Palisades + Brentwood</h4><p>Pacific Palisades · Brentwood</p></div>
      <div><h4>Malibu</h4><p><a href="/malibu/">Malibu</a> · Palos Verdes</p></div>
      <div><h4>Pasadena + San Marino</h4><p><a href="/pasadena/">Pasadena</a> · San Marino</p></div>
      <div><h4>Hollywood Hills</h4><p>Hollywood Hills · Laurel Canyon</p></div>
      <div><h4>OC ultra-luxury</h4><p>Newport Coast · <a href="/irvine/">Irvine</a></p></div>
    </div>
  </div></section>

  <section class="section"><div class="wrap narrow">
    <h2>Related Miele and luxury-tier pages</h2>
    <ul class="related-links">
      <li><a href="/brands/miele-refrigerator-repair/">Miele brand hub →</a></li>
      <li><a href="/brands/miele-refrigerator-repair/">Miele refrigerator repair →</a></li>
      <li><a href="/brands/miele-dishwasher-repair/">Miele dishwasher repair →</a></li>
      <li><a href="/brands/sub-zero-ice-maker-repair/">Sub-Zero ice maker →</a></li>
      <li><a href="/brands/thermador-ice-maker-repair/">Thermador ice maker →</a></li>
      <li><a href="/services/ice-maker-repair/">Ice maker repair (service hub) →</a></li>
      <li><a href="/price-list/ice-maker-repair-cost/">Ice maker repair cost guide →</a></li>
      <li><a href="/commercial/ice-machines/">Commercial ice machine repair →</a></li>
    </ul>
  </div></section>

  <section class="section alt"><div class="wrap narrow">
    <h2>Miele ice maker repair, frequently asked</h2>
    {faqs.map(f => (<details class="faq"><summary>{f.q}</summary><p set:html={f.a}></p></details>))}
  </div></section>

  <section id="book" class="cta-bottom"><div class="wrap">
    <h2>Miele ice maker service? Call the branch closest to your home.</h2>
    <p>Same-day appliance repair across Los Angeles, Orange, Ventura, San Bernardino, and Riverside counties. Residential diagnostic $89, waived with repair.</p>
  </div></section>
  <a href={`tel:${MAIN_PHONE_TEL}`} class="float-call" aria-label="Call now">☎ Call {MAIN_PHONE}</a>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  body { color: var(--text); } .wrap { max-width: 1200px; margin: 0 auto; padding: 0 24px; } .wrap.narrow { max-width: 820px; }
  h1 { font-size: 2.4rem; line-height: 1.15; margin: 12px 0 20px; color: var(--black); }
  h2 { font-size: 1.8rem; margin: 0 0 16px; color: var(--black); }
  h3 { font-size: 1.2rem; margin: 0 0 10px; color: var(--black); }
  h4 { font-size: 1.02rem; margin: 0 0 6px; color: var(--black); }
  p { line-height: 1.65; margin: 0 0 14px; }
  .call-banner { background: var(--red); color: #fff; padding: 10px 0; }
  .call-banner .wrap { display:flex; gap: 14px; align-items: center; justify-content: center; flex-wrap: wrap; }
  .call-banner .phone-lg { color:#fff; font-weight: 800; text-decoration: underline; font-size: 1.05rem; }
  .hero { background: var(--black); color: #fff; padding: 42px 0 56px; } .hero h1 { color: #fff; }
  .hero .lede { font-size: 1.06rem; color: #d7d7d7; max-width: 680px; }
  .hero .crumb { color: #9a9a9a; font-size: 0.85rem; margin-bottom: 6px; } .hero .crumb a { color: #c9c9c9; text-decoration: none; }
  .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; margin: 18px 0 24px; }
  .btn { display: inline-block; padding: 12px 20px; border-radius: 4px; text-decoration: none; font-weight: 700; }
  .btn-primary { background: var(--red); color: #fff; } .btn-ghost { background: transparent; color: #fff; border: 1px solid #fff; }
  .hero-facts { list-style: none; padding: 0; margin: 0; color: #c9c9c9; font-size: 0.95rem; }
  .hero-facts li { padding: 6px 0; border-top: 1px solid #222; } .hero-facts li:first-child { border-top: 0; }
  .trust-bar { background: var(--red); color: #fff; padding: 14px 0; }
  .trust-bar .wrap { display: flex; gap: 28px; flex-wrap: wrap; justify-content: center; font-size: 0.95rem; font-weight: 600; }
  .section { padding: 56px 0; } .section.alt { background: var(--gray); }
  .model-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 20px; margin-top: 24px; }
  .model-card { background: #fff; border: 1px solid var(--border); padding: 20px; border-radius: 6px; }
  .section.alt .model-card { background: #fff; }
  .fail-block { background: #fff; border-left: 3px solid var(--red); padding: 20px 22px; margin: 16px 0; }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 14px; background: #fff; }
  .price-table th, .price-table td { text-align: left; padding: 11px 12px; border-bottom: 1px solid var(--border); }
  .price-table th { background: var(--black); color: #fff; font-weight: 700; font-size: 0.95rem; }
  .small { color: var(--muted); font-size: 0.92rem; margin-top: 12px; }
  .area-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 18px; }
  .area-grid > div { background: #fff; border: 1px solid var(--border); padding: 16px; border-radius: 6px; }
  .related-links { list-style: none; padding: 0; } .related-links li { padding: 10px 0; border-bottom: 1px solid var(--border); }
  .related-links a { color: var(--red); font-weight: 600; text-decoration: none; } .related-links a:hover { text-decoration: underline; }
  .faq { background: #fff; border: 1px solid var(--border); padding: 12px 16px; margin-bottom: 8px; border-radius: 4px; }
  .faq summary { font-weight: 700; cursor: pointer; padding: 4px 0; } .faq p { margin: 8px 0 0; }
  .cta-bottom { background: var(--black); color: #fff; padding: 48px 0; } .cta-bottom h2 { color: #fff; } .cta-bottom p { color: #c9c9c9; }
  .float-call { position: fixed; bottom: 18px; right: 18px; background: var(--red); color: #fff; padding: 14px 18px; border-radius: 40px; text-decoration: none; font-weight: 700; box-shadow: 0 6px 18px rgba(0,0,0,0.28); z-index: 50; font-size: 0.95rem; }
  @media (max-width: 820px) { h1 { font-size: 1.9rem; } h2 { font-size: 1.45rem; } .float-call { padding: 11px 14px; font-size: 0.88rem; } .trust-bar .wrap { gap: 14px; font-size: 0.85rem; } }
</style>
