---
// src/pages/brands/whirlpool-cooktop-repair.astro
// Niche combo, Whirlpool cooktop repair (~0 GSC impressions; brand portfolio completion).
// Parent: /brands/whirlpool/. Voice: American/Michigan-owned (parent of KitchenAid/Maytag/Amana/JennAir),
// Tulsa OK cooking plant, mainstream positioning, F-code parity across Whirlpool family.
import Layout from '../../layouts/Layout.astro';
import ServiceHero from '../../components/ServiceHero.astro';
import { MAIN_PHONE } from '../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/brands/whirlpool-cooktop-repair/";

const title = "Whirlpool Cooktop Repair, Gas · Electric · Induction";
const description = `Whirlpool cooktop repair across SoCal, gas (WCG / W3CG), electric glass-top (WCE / W3CE), induction (WCI). F-code diagnostics, $89 dx. Call.`;

const faqs = [
  {
    q: "My Whirlpool gas cooktop won't ignite on one burner, what's wrong?",
    a: "Most common cause on WCG / W3CG gas cooktops is a corroded or wet spark electrode under the affected burner. Spilled food and liquid can short the spark path; the electrode keeps clicking but no spark jumps to light the burner. Diagnostic order: (1) clean and dry the electrode, about 35% of single-burner ignition calls resolve here at no parts cost; (2) confirm gas supply at the unit (check that other burners light); (3) failed ignition switch under the knob ($145-$245); (4) clogged orifice in the burner cap; (5) gas valve failure (least common, $280-$440). When all four burners click but none ignite, the diagnostic shifts to the spark module rather than individual igniters."
  },
  {
    q: "Why does my Whirlpool induction cooktop show an F-code or zone shutdown?",
    a: "Whirlpool induction cooktops (WCI series) share the F-code diagnostic tree with the broader Whirlpool family. F2 is a pan-detection error that often points to a coil sensor rather than a wrong-cookware issue (we test sensors directly before recommending board replacement; about a third of F2 calls resolve at the sensor swap). F11 is a communication fault between touch control and power board. F70 / F71 are user interface or communication faults, reseat panel connectors first, replace board second. About 30% of Whirlpool cooktop F-codes resolve at the homeowner-troubleshooting layer (full power cycle, connector reseat) at no parts cost."
  },
  {
    q: "How much does Whirlpool cooktop repair cost?",
    a: `Diagnostic is $89, applied toward the repair when you approve work. Common Whirlpool cooktop repair ranges: spark electrode or ignition switch (gas) $145-$285; gas valve assembly $280-$440; bake / surface element on WCE electric coil $145-$245; radiant element on glass-top $185-$285; induction zone module on WCI $345-$525; main control board $345-$525; touch control glass + assembly $480-$780; full glass-ceramic surface replacement $620-$980. Whirlpool cooktops sit at mainstream pricing, middle of the platform band shared with KitchenAid (premium), JennAir (premium), Maytag (mid), and Amana (value-tier). We give a written estimate before any work begins.`
  }
];

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": canonical + "#service",
    "serviceType": "Whirlpool Cooktop Repair",
    "name": "Whirlpool Cooktop Repair, Same Day Appliance Repair",
    "url": canonical,
    "description": "Same-day Whirlpool cooktop repair across Los Angeles, Orange, Ventura, San Bernardino, and Riverside counties. Gas (WCG / W3CG series), electric glass-top (WCE / W3CE), electric coil, induction (WCI series). American-made Michigan-headquartered platform shared with KitchenAid, Maytag, Amana, and JennAir. F-code diagnostics, spark electrodes, gas valves, induction modules, control boards, glass-ceramic surfaces. $89 residential diagnostic, applied toward repair.",
    "provider": {
      "@type": "LocalBusiness",
      "name": "Same Day Appliance Repair",
      "url": "https://samedayappliance.repair/",
      "telephone": phone,
      "priceRange": "$$"
    },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "offers": {
      "@type": "Offer",
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "89.00",
        "priceCurrency": "USD",
        "description": "Residential diagnostic fee, applied toward repair"
      }
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map((f) => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "Whirlpool", "item": "https://samedayappliance.repair/brands/whirlpool/" },
      { "@type": "ListItem", "position": 4, "name": "Whirlpool Cooktop Repair", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>

<Fragment slot="head-scripts">
  {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
</Fragment>

<ServiceHero
  eyebrow="LA · Orange · Ventura · San Bernardino · Riverside Counties"
  title="Whirlpool Cooktop Repair, Across Southern California"
  subtitle="Gas (WCG / W3CG), electric glass-top (WCE), induction (WCI). American-made Michigan-headquartered platform, parent of KitchenAid, Maytag, Amana, JennAir. F-code diagnostics. $89 diagnostic, applied toward repair. BHGS #A49573."
  heroImageTitle="Whirlpool Cooktop Repair"
  showBranches={true}
/>

<!-- 01 INTRO -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">01, About this service</p>
    <h2 class="section-title">Whirlpool cooktops on the American-made Michigan platform.</h2>

    <p>Whirlpool Corporation is headquartered in Benton Harbor, Michigan, with US cooking-appliance manufacturing concentrated in Tulsa, Oklahoma. The cooktop catalog spans three families: gas (WCG and W3CG series with sealed-burner construction and electronic ignition), electric glass-top radiant (WCE and W3CE series), and induction (WCI series). Whirlpool cooktops are positioned at the mainstream tier, middle of the engineering platform shared with the rest of the Whirlpool Corp family (KitchenAid premium, JennAir luxury, Maytag mid, Amana value).</p>

    <p>Because four other US brands run on the same platform, Whirlpool cooktop service is some of the most parts-efficient repair work we do. Our trucks carry components that fit Whirlpool, KitchenAid, Maytag, Amana, and JennAir cooktops with substantial cross-reference, F-codes apply across all five brands with the same diagnostic tree, and most Whirlpool cooktop repairs complete same-day with parts already on the truck. <a href="/brands/whirlpool/">Brand hub</a> covers Whirlpool refrigerators, washers, dryers, ovens, and dishwashers; this page is cooktop-specific.</p>
  </div>
</section>

<!-- 02 COMMON FAILURES -->
<section class="section section-gray">
  <div class="container">
    <p class="section-number">02, Common failures</p>
    <h2 class="section-title">What we diagnose most often on Whirlpool cooktops.</h2>

    <div class="problem-grid">
      <div class="problem-card">
        <h3>Gas burner won't ignite (WCG / W3CG)</h3>
        <p>Spark clicks but no flame. Most common cause is corroded or wet spark electrode at the burner base, spilled liquid shorting the spark path. About 35% of single-burner ignition calls resolve at the cleaning step with no parts cost. Remaining failures: clogged orifice in the burner cap, failed ignition switch ($145-$245), or rarely, gas valve failure ($280-$440). Multiple-burner failure shifts diagnostic toward the spark module.</p>
      </div>
      <div class="problem-card">
        <h3>WCE radiant element failure (electric glass-top)</h3>
        <p>One of the radiant heating coils under the glass-ceramic surface fails, visible as the zone running cooler than set, or not heating at all. Heating element under the glass is replaceable at $185-$285. We always test the surface temperature limiters at the same time because element failure is sometimes secondary to a limiter that's been cycling out repeatedly.</p>
      </div>
      <div class="problem-card">
        <h3>WCI induction zone module failure</h3>
        <p>One zone of the induction surface stops heating while others still function. Module-level architecture means failure is contained, repair is one zone module replacement at $345-$525, substantially less than a complete control system swap. F2 (pan-detection) and F11 (communication) codes often accompany. About a third of F2 calls trace to a coil sensor rather than the module itself; we test sensors directly before quoting.</p>
      </div>
      <div class="problem-card">
        <h3>Touch control glass unresponsive</h3>
        <p>WCI induction and electronic-ignition WCG gas cooktops use touch-glass controls sensitive to liquid intrusion at the front edge. Boil-over running across the front edge can short the touch traces, leaving controls unresponsive in one zone or globally. Replacement is the glass-and-touch-assembly part. We confirm failure mode with a power-cycle reset before quoting because apparent touch failures sometimes resolve at reset.</p>
      </div>
    </div>
  </div>
</section>

<!-- 03 MODELS + F-CODES -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">03, Whirlpool cooktop models and F-codes</p>
    <h2 class="section-title">WCG gas, WCE electric glass-top, WCI induction.</h2>

    <p><strong>Gas (WCG / W3CG series):</strong> WCG75US0HS, WCG97US0HS, W3CG3014XS, W3CG5430XB, 30" and 36" gas cooktops with sealed-burner construction, electronic ignition, mechanical knob controls or basic-electronic controls on premium variants. Common service: spark electrodes, ignition switches, surface igniters, gas valves, burner cap and head assemblies.</p>

    <p><strong>Electric glass-top (WCE / W3CE series):</strong> WCE55US0HB, WCE97US0HS, W3CE3014LS, W3CE3024LS, 30" and 36" radiant glass-top cooktops with electronic touch controls. Common service: radiant elements under the glass, surface temperature limiters, control board, touch glass.</p>

    <p><strong>Induction (WCI series):</strong> WCI55US0HS, WCI55US6JS, WCI55US4JS, 30" induction cooktops with full-touch controls and four induction zones. Common service: induction modules, touch control assemblies, coil temperature sensors.</p>

    <p><strong>Whirlpool F-codes that apply to cooktops:</strong></p>

    <ul class="bullet-list">
      <li><strong>F2:</strong> Pan-detection error on induction; often resolves at sensor swap rather than module replacement.</li>
      <li><strong>F11:</strong> Communication fault between touch control and power board.</li>
      <li><strong>F70 / F71:</strong> User interface or communication faults, reseat connectors first, replace board second.</li>
    </ul>
  </div>
</section>

<!-- 04 PRICING -->
<section class="section section-gray">
  <div class="container">
    <p class="section-number">04, Pricing</p>
    <h2 class="section-title">Whirlpool cooktop repair pricing.</h2>

    <p class="lead">Diagnostic is $89, applied toward the repair when you approve work. Whirlpool cooktops sit at mainstream pricing, middle of the platform band shared with KitchenAid (premium), JennAir (premium), Maytag (mid), and Amana (value-tier). Written estimate before any parts go on.</p>

    <div class="pricing-grid">
      <div class="price-card">
        <div class="price-label">Diagnostic</div>
        <div class="price-amount">$89</div>
        <div class="price-desc">Waived when you approve repair</div>
      </div>
      <div class="price-card">
        <div class="price-label">Standard band</div>
        <div class="price-amount">$145–$285</div>
        <div class="price-desc">Spark electrode · ignition switch · element</div>
      </div>
      <div class="price-card">
        <div class="price-label">Induction module</div>
        <div class="price-amount">$345–$525</div>
        <div class="price-desc">WCI single-module replacement · main board</div>
      </div>
      <div class="price-card">
        <div class="price-label">Touch glass / surface</div>
        <div class="price-amount">$480–$980</div>
        <div class="price-desc">Touch assembly · full glass-ceramic surface</div>
      </div>
    </div>

    <p class="price-note">Gas valve replacement $280-$440. Cross-platform parts compatibility across the Whirlpool family means most repairs complete same-day with parts already on the truck. Same-day completion is typical even for models on the older WCG / WCE platform.</p>
  </div>
</section>

<!-- 05 FAQ -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">05, FAQ</p>
    <h2 class="section-title">Whirlpool cooktop repair, common questions.</h2>

    <div class="faq-list">
      {faqs.map((f) => (
        <details class="faq-item">
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- 06 BOTTOM CTA -->
<section class="bottom-cta">
  <div class="container">
    <h2>Whirlpool cooktop down? Same-day service across Southern California.</h2>
    <p>$89 diagnostic, applied toward the repair. Gas, electric, induction, Michigan-headquartered platform service across all five SoCal counties.</p>
    <div class="cta-row">
      <a href={phoneHref} class="btn-primary">☎ Call {phone}</a>
      <a href="/contact/" class="btn-secondary">Book Online</a>
    </div>
  </div>
</section>

</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .section { padding: 72px 24px; }
  .section-gray { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; }
  .container.narrow { max-width: 820px; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  h2.section-title { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; margin: 0 0 20px; line-height: 1.2; color: var(--text); }
  .lead { font-size: 1.05rem; line-height: 1.75; color: var(--text); margin-bottom: 20px; }
  .section p { margin: 0 0 18px; font-size: 1rem; line-height: 1.75; color: var(--text); }
  .section a { color: var(--red); font-weight: 600; text-decoration: none; }
  .section a:hover { text-decoration: underline; }
  .bullet-list { margin: 20px 0; padding-left: 24px; }
  .bullet-list li { margin-bottom: 10px; font-size: 1rem; line-height: 1.7; color: var(--text); }

  .problem-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-top: 32px; }
  .problem-card { background: #fff; border: 1px solid var(--border); border-left: 4px solid var(--red); border-radius: 6px; padding: 26px 28px; }
  .problem-card h3 { font-size: 1.1rem; font-weight: 800; margin: 0 0 12px; color: var(--text); }
  .problem-card p { font-size: 0.95rem; color: var(--text); margin: 0; line-height: 1.7; }
  @media (max-width: 768px) { .problem-grid { grid-template-columns: 1fr; } }

  .pricing-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-top: 32px; }
  .price-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 26px 22px; text-align: center; }
  .price-card .price-label { font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--muted); margin-bottom: 10px; font-weight: 700; }
  .price-card .price-amount { font-size: 1.85rem; font-weight: 800; color: var(--text); line-height: 1; margin-bottom: 10px; }
  .price-card .price-desc { font-size: 0.85rem; color: var(--muted); line-height: 1.55; }
  .price-note { margin-top: 24px; font-size: 0.95rem; color: var(--text); line-height: 1.7; }

  .faq-list { margin-top: 32px; }
  .faq-item { background: #fff; border: 1px solid var(--border); border-radius: 6px; padding: 18px 22px; margin-bottom: 12px; }
  .faq-item summary { font-weight: 700; cursor: pointer; font-size: 1rem; color: var(--text); list-style: none; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::before { content: "+ "; color: var(--red); font-weight: 800; margin-right: 6px; }
  .faq-item[open] summary::before { content: "− "; }
  .faq-item p { font-size: 0.95rem; color: var(--text); line-height: 1.75; margin: 14px 0 0; }

  .bottom-cta { background: var(--black); color: #fff; padding: 72px 24px; text-align: center; }
  .bottom-cta h2 { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; margin: 0 0 16px; color: #fff; line-height: 1.25; }
  .bottom-cta p { color: #c9c9c9; margin: 0 0 30px; font-size: 1.02rem; line-height: 1.6; }
  .cta-row { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 16px 34px; border-radius: 5px; font-size: 1rem; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 16px 34px; border-radius: 5px; font-size: 1rem; font-weight: 600; text-decoration: none; border: 2px solid rgba(255,255,255,0.35); }
</style>
