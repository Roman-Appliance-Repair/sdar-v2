    ],
    "description": "U.S. Cooler walk-in cooler and freezer repair across Los Angeles, panel seals, door hardware, condensing units, evaporator defrost, refrigerant retrofits. Independent-brand specialists, same-day service.",
    "offers": {
      "@type": "Offer",
