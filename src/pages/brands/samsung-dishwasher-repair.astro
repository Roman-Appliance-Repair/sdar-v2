---
import Layout from '../../layouts/Layout.astro';
import BrandDetailPlaceholder from '../../components/BrandDetailPlaceholder.astro';

const title = "Samsung Dishwasher Repair Los Angeles | Same Day Service";
const description = "Expert Samsung dishwasher repair in Los Angeles. Same-day appointments, OEM parts, licensed technicians. Call (424) 325-0520.";
---

<Layout title={title} description={description}>
  <BrandDetailPlaceholder
    brandName="Samsung"
    brandSlug="samsung"
    category="Dishwasher"
    categorySlug="dishwasher-repair"
    hubUrl="/brands/samsung/"
  />
</Layout>
