const canonical = "https://samedayappliance.repair/brands/jennair-dishwasher-repair/";

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": "https://samedayappliance.repair/brands/jennair-dishwasher-repair/#business",
    "name": "Same Day Appliance Repair — JennAir Dishwasher Service",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": "https://samedayappliance.repair/brands/jennair-dishwasher-repair/",
    "telephone": MAIN_PHONE_TEL,
    "priceRange": "$$$$"
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "JennAir Dishwasher Repair",
    "provider": { "@type": "LocalBusiness", "name": "Same Day Appliance Repair" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "offers": {
      "@type": "Offer",
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "89.00",
        "priceCurrency": "USD",
        "description": "Diagnostic fee, waived with repair"
      }
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "My JennAir dishwasher fills with water, then drains and shuts off — why?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Two most common causes on JDB family (seen often on JDB8200 and JDB2150 specifically). Cause #1: door latch sensor failure — control doesn't register door as fully closed even though mechanical latch engaged, so cycle aborts as safety precaution. Latch assembly $185-$265 replacement. Test: close door firmly, watch for 'locked' indicator; if it flickers or doesn't light, sensor side has failed. Cause #2: water inlet valve malfunction — valve opens but doesn't close properly, control detects pressure abnormality and aborts cycle protectively. Inlet valve $185-$265. Before ordering: check OWI (Optical Water Indicator) sensor — calibration failure or backflow through drain check valve can cause similar symptoms (dirty water from drain line flowing back into tub triggers abort). Check valve replacement $125-$175. Our diagnostic identifies which of the three before ordering parts."
        }
      },
      {
        "@type": "Question",
        "name": "Buttons on my JennAir dishwasher aren't responding",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Stuck-button diagnostic has a specific Whirlpool Corp procedure that works on JennAir and KitchenAid dishwashers. Step 1: unplug dishwasher or trip breaker. Step 2: disconnect user interface wire harness from the door assembly. Step 3: reassemble door with harness DISCONNECTED, but don't close the door. Step 4: restore power and wait at least 7 seconds for electronic control board to fully initialize. Step 5: close the door. If control board no longer detects stuck buttons, the drain pump will briefly run. If drain pump runs: user interface control has failed ($385-$545 replacement). If drain pump doesn't run: electronic control board still thinks buttons are stuck with UI disconnected — electronic control board itself has failed ($485-$680). This one-test diagnostic saves ordering $545 UI control when the $680 board is actually failed (or vice versa)."
        }
      },
      {
        "@type": "Question",
        "name": "Is JennAir dishwasher same as KitchenAid or Whirlpool?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Shared core engineering across Whirlpool Corporation luxury tier. JennAir dishwashers use Whirlpool Corp motors, pumps, and control architectures often shared with KitchenAid and Maytag equivalents — JennAir JDB circulation pumps, drain pumps, and water inlet valves are frequently identical part numbers to KitchenAid KDTE/KDTM models from the same generation. For service: cross-brand parts compatibility is excellent — we source most JennAir dishwasher components in 1-2 days because they're common parts across the Whirlpool Corp luxury portfolio. What's JennAir-specific: NOIR black stainless handles and trim, RISE commercial handle designs, Obsidian interior accents, and some control board firmware. Functional service components work across brands at Whirlpool Corp."
        }
      },
      {
        "@type": "Question",
        "name": "Dishwasher won't drain — what should I check first?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Five-step diagnostic. Step 1 (free): remove bottom rack, inspect sump and filter area for food debris or glass pieces blocking drain pump inlet — 40% of 'won't drain' calls resolve with cleaning. Step 2: check drain hose for kinks behind or under dishwasher — free if that's the fix. Step 3: drain pump impeller inspection — listen for hum with no water movement, indicates pump motor OK but impeller blocked by hardened mineral deposits (common on LA hard water, 200-350 ppm) or debris; clean impeller or replace pump ($165-$245). Step 4: drain hose check valve — if stuck closed, water can't drain despite pump working ($125-$175 replacement). Step 5: control board drain relay — rare but if pump doesn't run at all in diagnostic mode, board replacement $485-$680. We start with free inspection before any parts recommendation."
        }
      },
      {
        "@type": "Question",
        "name": "How much does JennAir dishwasher repair cost?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Diagnostic $89, waived with repair. Typical JennAir dishwasher repairs: circulation pump assembly $345-$485, drain pump $165-$245, water inlet valve $185-$265, door latch assembly $185-$265, spray arm (upper or lower) $85-$145, check valve (drain hose) $125-$175, thermistor (water temp sensor) $95-$145, OWI sensor (Optical Water Indicator) $145-$215, user interface control $385-$545, electronic control board $485-$680, heating element $185-$265, thermal fuse $85-$145, door seal $145-$215, tub gasket $125-$185, dispenser assembly $185-$265, rack adjuster $95-$145, rack wheel kit $65-$95, water filter (EDR4RXD1) $45-$85, NOIR handle/trim $165-$285 (JennAir-specific), hard-water descaling service (LA-specific) $95 flat, filter cleaning (included with any service) free. Labor and parts quoted before work starts."
        }
      }
    ]
  }
];
