---
import Layout from '../../layouts/Layout.astro';
import BrandBranchesGrid from '../../components/BrandBranchesGrid.astro';
import { MAIN_PHONE, MAIN_PHONE_TEL } from '../../data/branches';

const title = "GE Ice Maker Repair | Southern California | Opal Nugget + Built-In";
const description = "GE ice maker repair across Southern California — French-door + side-by-side integrated + Opal countertop nugget ice. Haier 2016+, Louisville KY parts. $89 diagnostic. (424) 325-0520.";
const canonical = "https://samedayappliance.repair/brands/ge-ice-maker-repair/";

const faqs = [
  {
    q: "How does GE-branded ice maker differ from GE Profile / Cafe / Monogram?",
    a: "GE Appliances operates a four-tier hierarchy under Haier ownership (since 2016): GE mass-market < GE Profile premium-refined < GE Cafe premium-prosumer < GE Monogram ultra-luxury. GE-branded (this page) covers standard mass-market French-door (GNE29), side-by-side (GSS22), 4-door Flex (GFE28), and GE-branded Opal countertop nugget (lower-tier alternative to Profile Opal 2.0). All four tiers share the same Louisville KY parts distribution network but have distinct engineering specs and model ranges. See <a href='/brands/ge-profile-ice-maker-repair/'>GE Profile</a>, <a href='/brands/ge-cafe-ice-maker-repair/'>GE Cafe</a>, and <a href='/brands/ge-monogram-ice-maker-repair/'>GE Monogram</a> for the premium tiers."
  },
  {
    q: "What's GE Opal nugget ice, and how is service different?",
    a: "Opal is GE's countertop nugget ice maker — produces the chewy 'Sonic-style' ice by extruding soft-frozen flakes through a compression/auger mechanism. Two product tiers: GE-branded Opal (lower-tier, ~$400-500) and GE Profile Opal 2.0 (flagship, ~$500-650). Service is fundamentally different from refrigerator-integrated ice makers — Opal is countertop portable, bench-serviceable, and has auger / compression-chamber / water-tank / thermistor components distinct from modular refrigerator ice makers. Common Opal failures: auger motor $240–$360; water-tank sensor $180–$280; compression chamber build-up (cleaning service $140–$240); WiFi connect / SmartHQ app connectivity. Our techs handle Opal bench service; refrigerator-integrated GE ice makers get on-site service."
  },
  {
    q: "GE French-door ice maker not making ice — diagnostic order?",
    a: "Standard GE residential diagnostic: (1) water-inlet valve — GE valves typically fail at 5-8 year mark; valve swap $200–$320; (2) modular ice-maker assembly $240–$380; (3) water filter clog — GE uses XWF / RPWFE / MWF filters depending on model; filter $50–$80 routine replacement; (4) thermistor $180–$280; (5) ejector motor inside module $160–$240; (6) freezer-cavity temp — verify 0°F or colder; (7) dual-evap cold-zone sensor on GE Profile-shared platforms $240–$360. Louisville KY parts channel supports same-day / 1-day LA-local on most service items. Our techs carry common GE ice-maker modules + valves + filters on the truck."
  },
  {
    q: "Is GE still made in USA under Haier?",
    a: "Yes — GE Appliances continues operating from <b>Appliance Park, Louisville, Kentucky</b> (GE's historic manufacturing complex since 1953) under Haier Group ownership (acquired 2016 for $5.6B). Haier has invested in US manufacturing under GE Appliances rather than moving production offshore — much of the GE-branded, Profile, Cafe, and Monogram lineup continues to be made in the US, with some imported components. For service, that translates to a stable US parts distribution network: Louisville-anchored with regional distribution centers, same-day or 1-day LA-local parts on common components. Haier ownership hasn't changed GE service economics meaningfully."
  },
  {
    q: "My older GE ice maker is 12+ years old — worth fixing?",
    a: "Depends on what's failing. Standard ice-maker module swap $240–$380 on a 12-year GE refrigerator in otherwise sound condition is usually the right call — parts are readily available, service is fast, and the refrigerator itself is often engineered for 15-20 year service life. If the unit has multiple concurrent faults (ice maker + cooling issues + control-board concerns), we'll be straight about whether rebuild math still favors continued service. GE Appliances continues parts support on pre-Haier and post-Haier production through Louisville distribution."
  },
  {
    q: "GE ice maker vs commercial ice machines?",
    a: "GE is residential-only in ice — no GE commercial ice machine line. GE residential ice makers (French-door, side-by-side, 4-door Flex, countertop Opal) produce 3-24 lb/day max. For restaurant / bar / hospitality production at 200+ lb/day scale, see <a href='/commercial/ice-machine-repair/'>commercial ice machine repair</a> covering Manitowoc / Hoshizaki / Scotsman / Follett. This page covers GE residential only."
  },
  {
    q: "What does GE ice maker repair cost in LA?",
    a: "Residential diagnostic $89 waived with repair. Typical GE bands: water-inlet valve $200–$320; modular ice-maker assembly $240–$380; ejector motor $160–$240; thermistor $180–$280; water filter (XWF / RPWFE / MWF) $50–$80; dual-evap cold-zone sensor $240–$360; evaporator fan motor $240–$360; control board $400–$580; door-seal gasket $160–$240. Opal countertop: auger motor $240–$360; water-tank sensor $180–$280; compression-chamber cleaning $140–$240; SmartHQ WiFi module $260–$400. Louisville KY parts ship same-day / 1-day LA-local through GE Appliances distribution."
  }
];

const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair — GE Ice Maker Service",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": canonical, "telephone": MAIN_PHONE_TEL, "priceRange": "$$"
  },
  { "@context": "https://schema.org", "@type": "Service", "serviceType": "GE Ice Maker Repair",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "description": "GE ice maker repair across LA — French-door GNE29, side-by-side GSS22, 4-door Flex GFE28, countertop Opal nugget ice maker. GE Appliances (Haier 2016+) Louisville KY parts. $89 residential diagnostic waived with repair.",
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, waived with repair" } }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "GE", "item": "https://samedayappliance.repair/brands/ge/" },
      { "@type": "ListItem", "position": 4, "name": "GE Ice Maker Repair", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">{schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}</Fragment>
  <div class="call-banner"><div class="wrap"><span>GE ice maker service? Same-day across LA:</span><a href={`tel:${MAIN_PHONE_TEL}`} class="phone-lg">{MAIN_PHONE}</a></div></div>

  <section class="hero"><div class="wrap">
    <div class="crumb"><a href="/">Home</a> › <a href="/brands/">Brands</a> › GE › Ice Maker Repair</div>
    <h1>GE Ice Maker Repair</h1>
    <p class="lede">GE Appliances (Haier-owned since 2016, operating from Appliance Park in Louisville, Kentucky) anchors the mass-market tier of the four-tier GE hierarchy (GE → Profile → Café → Monogram). Our LA GE ice maker service covers standard French-door (GNE29), side-by-side (GSS22), 4-door Flex (GFE28), and GE-branded Opal countertop nugget ice. Louisville KY parts distribution supports same-day or 1-day LA-local parts on common components. Same-day dispatch, $89 residential diagnostic waived with the repair.</p>
    <div class="hero-cta"><a href={`tel:${MAIN_PHONE_TEL}`} class="btn btn-primary">Call {MAIN_PHONE}</a><a href="#book" class="btn btn-ghost">Request a Visit</a></div>
    <ul class="hero-facts">
      <li><b>Four-tier GE hierarchy</b> — GE → Profile → Café → Monogram</li>
      <li><b>Haier 2016+ ownership</b> — Louisville KY US operations retained</li>
      <li><b>Opal countertop nugget ice</b> — bench-serviceable portable</li>
      <li><b>$89 residential diagnostic</b> — waived when you authorize the repair</li>
    </ul>
  </div></section>

  <BrandBranchesGrid />

  <section class="trust-bar"><div class="wrap"><span>BHGS #A49573 · Insured</span><span>Same-day in 5 SoCal counties</span><span>Residential diagnostic $89 · waived with repair</span></div></section>

  <section class="section"><div class="wrap narrow">
    <h2>GE ice maker service in LA — mass-market scale + Opal countertop specialty</h2>
    <p>GE's LA residential ice-maker install base is substantial, with concentration in broad mid-tier family kitchens across the San Fernando Valley, San Gabriel Valley, South Bay, and OC. GE refrigerator-integrated ice makers follow standard modular-assembly service patterns; GE-branded Opal countertop nugget ice is a distinct product category that's grown substantially since 2019 Haier-era launch — bench-serviceable portable with auger + compression-chamber specific components. Louisville KY parts through GE Appliances distribution ship same-day / 1-day LA-local on most items.</p>
    <p>Our techs handle both the on-site refrigerator-integrated GE ice maker service and bench-service Opal countertop units. Diagnostic approach differs: refrigerator-integrated service runs the standard water-inlet valve + modular assembly + thermistor sequence; Opal service runs auger-motor + water-tank-sensor + compression-chamber cleaning sequence. Opal units with SmartHQ WiFi connectivity add a firmware-vs-hardware diagnostic layer.</p>
  </div></section>

  <section class="section alt"><div class="wrap">
    <h2>GE ice maker failures our techs see most often in LA</h2>
    <div class="fail-block"><h3>Refrigerator water-inlet valve</h3><p>GE valves at 5-8 year mark. Valve swap $200–$320.</p></div>
    <div class="fail-block"><h3>Modular ice-maker assembly</h3><p>Full module swap $240–$380 on integrated French-door / side-by-side / 4-door Flex.</p></div>
    <div class="fail-block"><h3>Opal auger motor failure</h3><p>Countertop nugget-specific. Auger swap $240–$360.</p></div>
    <div class="fail-block"><h3>Opal water-tank sensor + compression chamber</h3><p>Sensor $180–$280; chamber cleaning $140–$240.</p></div>
    <div class="fail-block"><h3>Water filter clog (XWF / RPWFE / MWF)</h3><p>Filter $50–$80. 6-month schedule.</p></div>
    <div class="fail-block"><h3>Dual-evap cold-zone sensor</h3><p>On GE Profile-shared platforms. Sensor $240–$360.</p></div>
  </div></section>

  <section class="section"><div class="wrap">
    <h2>GE ice maker product lines we service</h2>
    <div class="model-grid">
      <div class="model-card"><h3>GNE29 French-door</h3><p>Standard mass-market French-door with through-door ice.</p></div>
      <div class="model-card"><h3>GSS22 side-by-side</h3><p>Side-by-side through-door ice + water dispenser.</p></div>
      <div class="model-card"><h3>GFE28 4-door Flex</h3><p>4-door configuration with Flex zone. Ice in main freezer or flex.</p></div>
      <div class="model-card"><h3>GE Opal countertop nugget ice</h3><p>Bench-serviceable portable. Auger + compression mechanism.</p></div>
      <div class="model-card"><h3>GE Opal + SmartHQ WiFi</h3><p>App-coordinated ice production. Firmware-vs-hardware diagnostic.</p></div>
      <div class="model-card"><h3>Louisville KY parts network</h3><p>Same-day / 1-day LA-local parts distribution.</p></div>
    </div>
  </div></section>

  <section class="section alt"><div class="wrap narrow">
    <h2>Residential GE ice maker vs commercial ice machines</h2>
    <p>GE is residential-only. Refrigerator-integrated produces 3-8 lb/day; countertop Opal produces ~24 lb/day max. For restaurant / bar / commercial 200+ lb/day production, see <a href="/commercial/ice-machine-repair/">commercial ice machine repair</a>.</p>
  </div></section>

  <section class="section"><div class="wrap">
    <h2>What GE ice maker repair costs in LA</h2>
    <table class="price-table">
      <tr><th>Service</th><th>Typical Range</th><th>Notes</th></tr>
      <tr><td>Residential diagnostic</td><td>$89</td><td>Waived with repair</td></tr>
      <tr><td>Water-inlet valve</td><td>$200 – $320</td><td>5-8 year service</td></tr>
      <tr><td>Modular ice-maker assembly</td><td>$240 – $380</td><td>Full module swap</td></tr>
      <tr><td>Ejector motor</td><td>$160 – $240</td><td>Inside module</td></tr>
      <tr><td>Thermistor / ice-bin sensor</td><td>$180 – $280</td><td>Harvest + bin-full</td></tr>
      <tr><td>Water filter (XWF / RPWFE / MWF)</td><td>$50 – $80</td><td>6-month routine</td></tr>
      <tr><td>Dual-evap cold-zone sensor</td><td>$240 – $360</td><td>Profile-shared platform</td></tr>
      <tr><td>Evaporator fan motor</td><td>$240 – $360</td><td>Freezer airflow</td></tr>
      <tr><td>Control board</td><td>$400 – $580</td><td>Main control</td></tr>
      <tr><td>Opal auger motor</td><td>$240 – $360</td><td>Countertop-specific</td></tr>
      <tr><td>Opal water-tank sensor</td><td>$180 – $280</td><td>Tank level detection</td></tr>
      <tr><td>Opal compression-chamber cleaning</td><td>$140 – $240</td><td>Nugget-ice build-up</td></tr>
      <tr><td>SmartHQ WiFi module</td><td>$260 – $400</td><td>Smart connectivity</td></tr>
    </table>
    <p class="small">Related: <a href="/brands/ge/">GE brand hub</a> · <a href="/brands/ge-profile-ice-maker-repair/">GE Profile (Opal 2.0)</a> · <a href="/brands/ge-cafe-ice-maker-repair/">GE Cafe</a> · <a href="/brands/ge-monogram-ice-maker-repair/">GE Monogram</a> · <a href="/services/ice-maker-repair/">Ice maker repair (service hub)</a> · <a href="/price-list/ice-maker-repair-cost/">Ice maker repair cost guide</a>.</p>
  </div></section>

  <section class="section alt"><div class="wrap">
    <h2>LA service areas — where our GE ice maker calls come from</h2>
    <div class="area-grid">
      <div><h4>San Fernando Valley</h4><p>Studio City · Sherman Oaks · Encino · Van Nuys</p></div>
      <div><h4>Eastside + Mid-Wilshire</h4><p>Silver Lake · Los Feliz · Highland Park</p></div>
      <div><h4>South Bay</h4><p>Manhattan Beach · Hermosa · Redondo · Torrance</p></div>
      <div><h4>Pasadena + San Gabriel</h4><p><a href="/pasadena/">Pasadena</a> · San Marino · Arcadia</p></div>
      <div><h4>Long Beach + Whittier</h4><p>Long Beach · Whittier · La Habra</p></div>
      <div><h4>OC + Ventura</h4><p><a href="/irvine/">Irvine</a> · Anaheim · Thousand Oaks · Ventura</p></div>
    </div>
  </div></section>

  <section class="section"><div class="wrap narrow">
    <h2>Related GE and ice-maker pages</h2>
    <ul class="related-links">
      <li><a href="/brands/ge/">GE brand hub →</a></li>
      <li><a href="/brands/ge-profile-ice-maker-repair/">GE Profile ice maker (Opal 2.0) →</a></li>
      <li><a href="/brands/ge-cafe-ice-maker-repair/">GE Cafe ice maker →</a></li>
      <li><a href="/brands/ge-monogram-ice-maker-repair/">GE Monogram ice maker →</a></li>
      <li><a href="/brands/whirlpool-ice-maker-repair/">Whirlpool ice maker repair →</a></li>
      <li><a href="/services/ice-maker-repair/">Ice maker repair (service hub) →</a></li>
      <li><a href="/price-list/ice-maker-repair-cost/">Ice maker repair cost guide →</a></li>
      <li><a href="/commercial/ice-machine-repair/">Commercial ice machine repair →</a></li>
    </ul>
  </div></section>

  <section class="section alt"><div class="wrap narrow">
    <h2>GE ice maker repair — frequently asked</h2>
    {faqs.map(f => (<details class="faq"><summary>{f.q}</summary><p set:html={f.a}></p></details>))}
  </div></section>

  <section id="book" class="cta-bottom"><div class="wrap">
    <h2>GE ice maker service? Call the branch closest to your home.</h2>
    <p>Same-day appliance repair in Los Angeles, Orange County, Ventura County. Residential diagnostic $89, waived with repair.</p>
  </div></section>
  <a href={`tel:${MAIN_PHONE_TEL}`} class="float-call" aria-label="Call now">☎ Call {MAIN_PHONE}</a>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  body { color: var(--text); } .wrap { max-width: 1200px; margin: 0 auto; padding: 0 24px; } .wrap.narrow { max-width: 820px; }
  h1 { font-size: 2.4rem; line-height: 1.15; margin: 12px 0 20px; color: var(--black); }
  h2 { font-size: 1.8rem; margin: 0 0 16px; color: var(--black); }
  h3 { font-size: 1.2rem; margin: 0 0 10px; color: var(--black); }
  h4 { font-size: 1.02rem; margin: 0 0 6px; color: var(--black); }
  p { line-height: 1.65; margin: 0 0 14px; }
  .call-banner { background: var(--red); color: #fff; padding: 10px 0; }
  .call-banner .wrap { display:flex; gap: 14px; align-items: center; justify-content: center; flex-wrap: wrap; }
  .call-banner .phone-lg { color:#fff; font-weight: 800; text-decoration: underline; font-size: 1.05rem; }
  .hero { background: var(--black); color: #fff; padding: 42px 0 56px; } .hero h1 { color: #fff; }
  .hero .lede { font-size: 1.06rem; color: #d7d7d7; max-width: 680px; }
  .hero .crumb { color: #9a9a9a; font-size: 0.85rem; margin-bottom: 6px; } .hero .crumb a { color: #c9c9c9; text-decoration: none; }
  .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; margin: 18px 0 24px; }
  .btn { display: inline-block; padding: 12px 20px; border-radius: 4px; text-decoration: none; font-weight: 700; }
  .btn-primary { background: var(--red); color: #fff; } .btn-ghost { background: transparent; color: #fff; border: 1px solid #fff; }
  .hero-facts { list-style: none; padding: 0; margin: 0; color: #c9c9c9; font-size: 0.95rem; }
  .hero-facts li { padding: 6px 0; border-top: 1px solid #222; } .hero-facts li:first-child { border-top: 0; }
  .trust-bar { background: var(--red); color: #fff; padding: 14px 0; }
  .trust-bar .wrap { display: flex; gap: 28px; flex-wrap: wrap; justify-content: center; font-size: 0.95rem; font-weight: 600; }
  .section { padding: 56px 0; } .section.alt { background: var(--gray); }
  .model-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 20px; margin-top: 24px; }
  .model-card { background: #fff; border: 1px solid var(--border); padding: 20px; border-radius: 6px; }
  .section.alt .model-card { background: #fff; }
  .fail-block { background: #fff; border-left: 3px solid var(--red); padding: 20px 22px; margin: 16px 0; }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 14px; background: #fff; }
  .price-table th, .price-table td { text-align: left; padding: 11px 12px; border-bottom: 1px solid var(--border); }
  .price-table th { background: var(--black); color: #fff; font-weight: 700; font-size: 0.95rem; }
  .small { color: var(--muted); font-size: 0.92rem; margin-top: 12px; }
  .area-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 18px; }
  .area-grid > div { background: #fff; border: 1px solid var(--border); padding: 16px; border-radius: 6px; }
  .related-links { list-style: none; padding: 0; } .related-links li { padding: 10px 0; border-bottom: 1px solid var(--border); }
  .related-links a { color: var(--red); font-weight: 600; text-decoration: none; } .related-links a:hover { text-decoration: underline; }
  .faq { background: #fff; border: 1px solid var(--border); padding: 12px 16px; margin-bottom: 8px; border-radius: 4px; }
  .faq summary { font-weight: 700; cursor: pointer; padding: 4px 0; } .faq p { margin: 8px 0 0; }
  .cta-bottom { background: var(--black); color: #fff; padding: 48px 0; } .cta-bottom h2 { color: #fff; } .cta-bottom p { color: #c9c9c9; }
  .float-call { position: fixed; bottom: 18px; right: 18px; background: var(--red); color: #fff; padding: 14px 18px; border-radius: 40px; text-decoration: none; font-weight: 700; box-shadow: 0 6px 18px rgba(0,0,0,0.28); z-index: 50; font-size: 0.95rem; }
  @media (max-width: 820px) { h1 { font-size: 1.9rem; } h2 { font-size: 1.45rem; } .float-call { padding: 11px 14px; font-size: 0.88rem; } .trust-bar .wrap { gap: 14px; font-size: 0.85rem; } }
</style>
