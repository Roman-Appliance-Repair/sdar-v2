---
import Layout from '../../layouts/Layout.astro';
import BrandBranchesGrid from '../../components/BrandBranchesGrid.astro';
import { MAIN_PHONE, MAIN_PHONE_TEL } from '../../data/branches';

const title = "Thermador Microwave Repair Los Angeles — Same Day";
const description = "$89 dx waived. Thermador microwave repair SoCal, MC30WS built-in, MD24/30WSS drawer (Sharp OEM), MCES combi. BSH Irvine 1-2 day LA-local parts.";
const canonical = "https://samedayappliance.repair/brands/thermador-microwave-repair/";

const faqs = [
  {
    q: "Thermador, what's in the US microwave lineup today?",
    a: "Thermador's current US residential microwave catalog is three distinct products. <b>MC30WS / MC30WP 30-inch built-in microwave</b>, the workhorse cabinetry-integrated unit, most common call. <b>MD24WSS 24-inch drawer + MD30WSS 30-inch drawer</b>, Sharp OEM chassis (same one sold as Wolf ICBMODR and Miele EDT-series). <b>MCES 30-inch combi-microwave-oven</b> (Masterpiece series), microwave + convection oven + steam hybrid. BSH also sells the Gaggenau BM 450/451 under the ultra-luxury Gaggenau badge using the same BSH Home Appliances parts chain. No over-the-range or countertop Thermador microwaves, all cabinetry-integrated."
  },
  {
    q: "BSH Irvine LA-local parts, how fast is that actually?",
    a: "<b>Thermador is BSH Home Appliances; BSH runs US parts distribution out of Irvine, California</b>. For LA service this means <b>1-2 day parts delivery</b> on most common items (magnetron, fan motor, door switch, control board, oven sensor), the fastest luxury-tier parts chain in LA alongside Gaggenau (same BSH Irvine), Hestan (Anaheim), and Fisher & Paykel (Huntington Beach). Specialty or custom-configured parts run 3-5 days; Masterpiece-series MCES combi electronics occasionally go factory-direct at 1-2 week lead, but those are the exception. Door switches, magnetrons, and drawer mechanisms we typically have on the truck."
  },
  {
    q: "MC30WS built-in won't heat, magnetron or control board?",
    a: "Classic BSH diagnostic sequence on an MC30WS that won't heat: (1) check high-voltage capacitor, a short-circuited cap will prevent magnetron drive; $120–$180 replacement. (2) HV diode, open diode = no magnetron voltage, cheap fix at $60–$100. (3) Magnetron itself, resistance check + visible arcing; $260–$400. (4) Main control board if all above test fine, indicates inverter or triac-drive issue; $380–$560 at the Masterpiece/MC30WS SKU. We run the sequence in this order specifically because the cheap fixes resolve ~40% of \"won't heat\" calls before we need to quote a magnetron. Skipping straight to magnetron replacement without testing HV network upstream is how customers get overcharged."
  },
  {
    q: "Thermador drawer microwave and Wolf / Miele drawers, same chassis, so same parts?",
    a: "Yes. The <b>Sharp OEM drawer chassis</b> under Thermador MD24/30WSS is the same chassis that sits under Wolf ICBMODR and Miele EDT-series, identical magnetron, linear actuator, roller guide, door interlocks. Brand-specific differences: front fascia, premium touch-panel, firmware, and the BSH-Irvine-fast parts chain. Practical repair impact: our Sharp drawer inventory covers Thermador, Wolf, and Miele drawer calls interchangeably for the chassis-side parts, we don't wait for Thermador-specific SKUs unless it's a front-panel aesthetic issue. See <a href='/brands/sharp-microwave-repair/'>Sharp</a> for the OEM reference."
  },
  {
    q: "Home Connect pairing lost, firmware or WiFi module?",
    a: "Thermador's Home Connect app (BSH's shared platform, also covers Bosch and Gaggenau) shows similar failure patterns to LG SmartThinQ and Samsung SmartThings post-firmware-update. Recovery: (1) power-cycle the microwave at the breaker for 60 seconds; (2) in the Home Connect app, remove the device completely and re-pair from scratch (don't try to reconnect an existing entry); (3) confirm router is <b>2.4 GHz</b>, Home Connect does not pair on 5 GHz-only networks; (4) if pairing fails after those three steps, the <b>WiFi module inside the microwave</b> ($180–$280 part) is the next check. BSH Irvine usually has the module on one-day delivery."
  },
  {
    q: "What does Thermador microwave repair cost in LA?",
    a: "Residential diagnostic $89 waived with repair. Typical Thermador bands: HV capacitor $120–$180; HV diode $60–$100; magnetron $260–$400; main control board $380–$560; <b>MCES combi</b> convection element $180–$300 + fan motor $240–$400 + steam-generator heating $280–$440; <b>MD24/30WSS drawer</b> linear actuator $240–$380, roller-guide clean + realign $140–$220, door interlock $120–$200, touch-panel control $380–$560; Home Connect WiFi module $180–$280. BSH Irvine 1-2 day parts on most common items."
  }
];

const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair, Thermador Microwave Service",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": canonical, "telephone": MAIN_PHONE_TEL, "priceRange": "$$$$"
  },
  { "@context": "https://schema.org", "@type": "Service", "serviceType": "Thermador Microwave Repair",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "description": "Thermador microwave repair across LA, MC30WS/MC30WP 30\" built-in, MD24WSS/MD30WSS drawer (Sharp OEM), MCES combi-microwave-oven Masterpiece series. BSH Home Appliances Irvine CA 1-2 day LA-local parts. Home Connect WiFi diagnostic. $89 residential diagnostic waived with repair.",
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, waived with repair" } }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "Thermador", "item": "https://samedayappliance.repair/brands/thermador/" },
      { "@type": "ListItem", "position": 4, "name": "Thermador Microwave Repair", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">{schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}</Fragment>
  <div class="call-banner"><div class="wrap"><span>Thermador microwave service?</span><a href={`tel:${MAIN_PHONE_TEL}`} class="phone-lg">{MAIN_PHONE}</a></div></div>

  <section class="hero"><div class="wrap">
    <div class="crumb"><a href="/">Home</a> › <a href="/brands/">Brands</a> › Thermador › Microwave Repair</div>
    <h1>Thermador Microwave Repair</h1>
    <p class="lede">Thermador (BSH Home Appliances, US parts out of Irvine California) keeps its microwave lineup cabinetry-integrated, MC30WS/MC30WP 30-inch built-in, MD24/30WSS drawer (Sharp OEM chassis shared with Wolf ICBMODR and Miele EDT-series), and MCES Masterpiece-series combi-microwave-oven with integrated convection + steam. BSH Irvine gives Thermador one of the fastest luxury-tier parts chains in LA, 1-2 day delivery on most common items. Home Connect WiFi app (BSH shared platform covering Bosch and Gaggenau too) adds diagnostic depth on newer units. Same-day dispatch, $89 residential diagnostic waived with the repair.</p>
    <div class="hero-cta"><a href={`tel:${MAIN_PHONE_TEL}`} class="btn btn-primary">Call {MAIN_PHONE}</a><a href="#book" class="btn btn-ghost">Request a Visit</a></div>
    <ul class="hero-facts">
      <li><b>MC30WS built-in + MD24/30WSS drawer + MCES combi</b>, full cabinetry lineup</li>
      <li><b>BSH Irvine CA 1-2 day LA-local parts</b>, fastest luxury-tier chain in LA</li>
      <li><b>Sharp OEM drawer chassis</b>, cross-fits Wolf + Miele drawer parts</li>
      <li><b>$89 residential diagnostic</b>, waived when you authorize the repair</li>
    </ul>
  </div></section>

  <BrandBranchesGrid />

  <section class="trust-bar"><div class="wrap"><span>BHGS #A49573 · Insured</span><span>Same-day in 5 SoCal counties</span><span>Residential diagnostic $89 · waived with repair</span></div></section>

  <section class="section"><div class="wrap">
    <h2>What Thermador microwave repair costs in LA</h2>
    <table class="price-table">
      <tr><th>Service</th><th>Typical Range</th><th>Notes</th></tr>
      <tr><td>Residential diagnostic</td><td>$89</td><td>Waived with repair</td></tr>
      <tr><td>HV capacitor</td><td>$120 – $180</td><td>First check on no-heat</td></tr>
      <tr><td>HV diode</td><td>$60 – $100</td><td>Cheap fix before magnetron</td></tr>
      <tr><td>Magnetron</td><td>$260 – $400</td><td>MC30WS / MCES</td></tr>
      <tr><td>Main control board</td><td>$380 – $560</td><td>MC30WS / Masterpiece SKU</td></tr>
      <tr><td>MCES combi convection element + fan</td><td>$180 – $400</td><td>Masterpiece combi mode</td></tr>
      <tr><td>MD24/30WSS linear actuator</td><td>$240 – $380</td><td>Drawer pull-out motor</td></tr>
      <tr><td>Roller guide clean + realign</td><td>$140 – $220</td><td>Drawer binding, often no part</td></tr>
      <tr><td>Door interlock sensor</td><td>$120 – $200</td><td>Drawer + hinged door common</td></tr>
      <tr><td>Home Connect WiFi module</td><td>$180 – $280</td><td>Pairing / firmware recovery</td></tr>
    </table>
    <p class="small">Related: <a href="/brands/thermador-refrigerator-repair/">Thermador brand hub</a> · <a href="/brands/thermador-oven-repair/">Thermador oven</a> · <a href="/brands/thermador-range-hood-repair/">Thermador range hood</a> · <a href="/brands/sharp-microwave-repair/">Sharp (drawer OEM chassis)</a> · <a href="/brands/wolf-microwave-repair/">Wolf microwave (sibling drawer)</a> · <a href="/brands/miele-microwave-repair/">Miele microwave (sibling drawer)</a> · <a href="/services/microwave-repair/">Microwave repair (service hub)</a> · <a href="/price-list/microwave-repair-cost/">Microwave repair cost</a>.</p>
  </div></section>

  <section class="section alt"><div class="wrap narrow">
    <h2>BSH Home Appliances family, Thermador / Bosch / Gaggenau</h2>
    <p>Thermador is part of BSH Home Appliances (Bosch-Siemens Home Appliances), a German multinational that sells three residential brands in the US: <b>Thermador</b> (American-style luxury + Masterpiece series), <b>Bosch</b> (German-engineered premium), and <b>Gaggenau</b> (ultra-luxury modular architecture). All three route through BSH's Irvine California parts distribution, which is why Thermador-Gaggenau-Bosch shares a Home Connect WiFi app platform and a shared service network. Thermador, Gaggenau, and occasionally Bosch microwaves cross-reference at the BSH part-number level on certain mechanical components, useful for parts availability when Thermador-specific SKUs run short.</p>
  </div></section>

  <section class="section"><div class="wrap narrow">
    <h2>Thermador microwave repair, frequently asked</h2>
    {faqs.map(f => (<details class="faq"><summary>{f.q}</summary><p set:html={f.a}></p></details>))}
  </div></section>

  <section id="book" class="cta-bottom"><div class="wrap">
    <h2>Thermador microwave service? Call the branch closest to your home.</h2>
    <p>Same-day appliance repair in Los Angeles, Orange County, Ventura County. Residential diagnostic $89, waived with repair.</p>
  </div></section>
  <a href={`tel:${MAIN_PHONE_TEL}`} class="float-call" aria-label="Call now">☎ Call {MAIN_PHONE}</a>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  body { color: var(--text); } .wrap { max-width: 1200px; margin: 0 auto; padding: 0 24px; } .wrap.narrow { max-width: 820px; }
  h1 { font-size: 2.4rem; line-height: 1.15; margin: 12px 0 20px; color: var(--black); }
  h2 { font-size: 1.8rem; margin: 0 0 16px; color: var(--black); }
  p { line-height: 1.65; margin: 0 0 14px; }
  .call-banner { background: var(--red); color: #fff; padding: 10px 0; }
  .call-banner .wrap { display:flex; gap: 14px; align-items: center; justify-content: center; flex-wrap: wrap; }
  .call-banner .phone-lg { color:#fff; font-weight: 800; text-decoration: underline; font-size: 1.05rem; }
  .hero { background: var(--black); color: #fff; padding: 42px 0 56px; } .hero h1 { color: #fff; }
  .hero .lede { font-size: 1.06rem; color: #d7d7d7; max-width: 680px; }
  .hero .crumb { color: #9a9a9a; font-size: 0.85rem; margin-bottom: 6px; } .hero .crumb a { color: #c9c9c9; text-decoration: none; }
  .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; margin: 18px 0 24px; }
  .btn { display: inline-block; padding: 12px 20px; border-radius: 4px; text-decoration: none; font-weight: 700; }
  .btn-primary { background: var(--red); color: #fff; } .btn-ghost { background: transparent; color: #fff; border: 1px solid #fff; }
  .hero-facts { list-style: none; padding: 0; margin: 0; color: #c9c9c9; font-size: 0.95rem; }
  .hero-facts li { padding: 6px 0; border-top: 1px solid #222; } .hero-facts li:first-child { border-top: 0; }
  .trust-bar { background: var(--red); color: #fff; padding: 14px 0; }
  .trust-bar .wrap { display: flex; gap: 28px; flex-wrap: wrap; justify-content: center; font-size: 0.95rem; font-weight: 600; }
  .section { padding: 56px 0; } .section.alt { background: var(--gray); }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 14px; background: #fff; }
  .price-table th, .price-table td { text-align: left; padding: 11px 12px; border-bottom: 1px solid var(--border); }
  .price-table th { background: var(--black); color: #fff; font-weight: 700; font-size: 0.95rem; }
  .small { color: var(--muted); font-size: 0.92rem; margin-top: 12px; }
  .faq { background: #fff; border: 1px solid var(--border); padding: 12px 16px; margin-bottom: 8px; border-radius: 4px; }
  .faq summary { font-weight: 700; cursor: pointer; padding: 4px 0; } .faq p { margin: 8px 0 0; }
  .cta-bottom { background: var(--black); color: #fff; padding: 48px 0; } .cta-bottom h2 { color: #fff; } .cta-bottom p { color: #c9c9c9; }
  .float-call { position: fixed; bottom: 18px; right: 18px; background: var(--red); color: #fff; padding: 14px 18px; border-radius: 40px; text-decoration: none; font-weight: 700; box-shadow: 0 6px 18px rgba(0,0,0,0.28); z-index: 50; font-size: 0.95rem; }
  @media (max-width: 820px) { h1 { font-size: 1.9rem; } .float-call { padding: 11px 14px; font-size: 0.88rem; } .trust-bar .wrap { gap: 14px; font-size: 0.85rem; } }
</style>
