---
// src/pages/brands/amana.astro
// Tier 3 brand hub, Amana (~36 GSC imp/3mo across 7 queries; "amana glass top stove repair
// cost" 27 imp pos 10.9 already top-10).
// Built from SERP research 2026-04-30. Tone reference: maytag.astro (sister-brand voice
// consistency under Whirlpool Corp). Voice discipline: Amana value-tier positioning,
// Whirlpool-platform parts cross-reference, refrigeration heritage (Iowa plant still active).
// Minimal 6-section hub for final stub completion. NO fabricated client names.

import Layout from '../../layouts/Layout.astro';
import ServiceHero from '../../components/ServiceHero.astro';
import { MAIN_PHONE } from '../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/brands/amana-refrigerator-repair/";

const title = "Amana Appliance Repair Los Angeles — Same Day";
const description = "Amana appliance repair across LA, Orange, Ventura, San Bernardino & Riverside counties. Whirlpool-platform parts, OEM service, $89 dx. BHGS #A49573, EPA 608.";

const faqs = [
  {
    q: "Who owns Amana?",
    a: "Amana is owned by Whirlpool Corporation. The brand has had a winding ownership history, founded in 1934 as Amana Refrigeration in Amana, Iowa; acquired by Raytheon in 1965; sold to Goodman (HVAC) in 1997; sold to Maytag in 2001; and finally to Whirlpool when Whirlpool acquired Maytag in 2006. From a service standpoint, Amana shares Whirlpool's manufacturing infrastructure and parts platform, which means Amana / Whirlpool / Maytag washers, dryers, and refrigerators are mechanically very similar across most model generations. Same parts on our trucks, same diagnostic procedures. The original Amana Iowa plant still produces refrigerators for the Whirlpool family."
  },
  {
    q: "How much does Amana appliance repair cost in LA?",
    a: "Diagnostic is $89, applied toward the repair when work is approved. Amana pricing matches Whirlpool / Maytag because of the shared platform: refrigerator door gasket $180-$280; refrigerator water inlet valve $185-$285; refrigerator ice maker assembly $245-$385; refrigerator main control board $345-$525; washer lid switch / drain pump $145-$385; washer drive belt $185-$285; dryer thermal fuse + vent inspection $145-$245; dryer heating element $285-$425; range surface igniter $145-$215; oven bake element $185-$285; oven temperature sensor $145-$215. Amana sits at the value tier of the Whirlpool family, which usually means parts are at the lower end of the band rather than the higher end."
  },
  {
    q: "Are Amana appliances reliable?",
    a: "Honest answer. Amana is positioned as the value-tier brand within the Whirlpool family, built to a price point, with the lifetime profile that implies. Amana refrigerators are reliable mid-tier units (the Iowa plant has historically made well-engineered refrigeration). Amana laundry is more entry-tier, adequate, not standout, and similar to base-spec Whirlpool. Amana ranges are competitive value-tier units. Across the lineup, Amana appliances should run reliably to year 10-12 with normal maintenance. Repair-vs-replace at year 12+ tilts toward replacement on most Amana categories given the value-tier positioning; under year 8, repair is usually the right call."
  }
];

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": canonical + "#service",
    "serviceType": "Amana Appliance Repair",
    "name": "Amana Appliance Repair, Same Day Appliance Repair",
    "url": canonical,
    "description": "Same-day Amana appliance repair across Los Angeles, Orange, Ventura, San Bernardino, and Riverside counties. Refrigerators, freezers, washers, dryers, ranges, microwaves. Factory-trained on shared Whirlpool platform, Amana, Whirlpool, and Maytag share engineering and parts across most model generations. $89 residential diagnostic, applied toward repair.",
    "provider": {
      "@type": "LocalBusiness",
      "name": "Same Day Appliance Repair",
      "url": "https://samedayappliance.repair/",
      "telephone": phone,
      "priceRange": "$$",
      "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "08:00", "closes": "20:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "00:00", "closes": "00:00" }
      ]
    },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "brand": {
      "@type": "Brand",
      "name": "Amana",
      "sameAs": "https://www.amana.com/"
    },
    "offers": {
      "@type": "Offer",
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "89.00",
        "priceCurrency": "USD",
        "description": "Residential diagnostic fee, applied toward repair"
      }
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "Amana", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>

<Fragment slot="head-scripts">
  {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
</Fragment>

<ServiceHero
  eyebrow="LA · Orange · Ventura · San Bernardino · Riverside Counties"
  title="Amana Appliance Repair, Across Southern California"
  subtitle="Refrigerator · Freezer · Washer · Dryer · Range · Microwave · Glass-top Stove. Whirlpool-platform parts on every truck. Factory-trained, OEM parts. $89 diagnostic, same day across five SoCal counties."
  heroImageTitle="Amana Appliance Repair"
  showBranches={true}
/>

<!-- 01 INTRO -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">01, About this service</p>
    <h2 class="section-title">Amana, Iowa-rooted refrigeration heritage, now Whirlpool's value tier.</h2>

    <p>Amana has one of the longer histories in American appliances, founded in 1934 in Amana, Iowa, originally focused on commercial refrigeration before expanding into the residential market. The brand passed through several owners (Raytheon, Goodman, Maytag) before landing under Whirlpool Corporation in 2006. Today Amana is positioned as the value-tier brand within the Whirlpool family, built to competitive price points with the same engineering platform that underpins Whirlpool and Maytag products. The original Amana Iowa plant still produces refrigerators for the Whirlpool family.</p>

    <p>For service, this is straightforward: Amana, Whirlpool, and Maytag washers, dryers, and refrigerators are mechanically very similar across most model generations, cosmetic trim and badging differences, with shared internal components. Our trucks carry parts that fit all three brands, our techs use the same diagnostic procedures, and most Amana service calls run efficiently because we already know the platform. Every service call gets a $89 residential diagnostic (applied toward the repair when work is approved), OEM parts where we can, and an honest written quote before any work begins.</p>
  </div>
</section>

<!-- 02 REFRIGERATION -->
<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">02, Amana refrigerators &amp; freezers</p>
    <h2 class="section-title">Where Amana's heritage strength still shows.</h2>

    <p class="lead">Refrigeration is Amana's strongest category, the brand's Iowa manufacturing roots produced reliable refrigerators for decades, and the current lineup continues that tradition under Whirlpool's parts platform. Amana refrigerators are conventional value-tier units with mostly mechanical wear items rather than high-tech failure modes.</p>

    <p>Most-common Amana refrigerator and freezer service items by year:</p>

    <ul class="bullet-list">
      <li><strong>Year 4-7, Ice maker assembly:</strong> Modular ice makers shared with Whirlpool platform. Replacement $245-$385.</li>
      <li><strong>Year 5-9, Water inlet valve:</strong> Solenoid wear; partial fills, slow water dispensing. Replacement $185-$285.</li>
      <li><strong>Year 6-10, Evaporator fan motor + condenser fan motor:</strong> Whirring sound from the freezer compartment, intermittent cooling. Replacement $245-$385.</li>
      <li><strong>Year 7-11, Defrost system:</strong> Defrost heater, thermostat, or sensor failure causing frost buildup. $185-$345 replacement depending on item.</li>
      <li><strong>Year 8-12, Door gasket:</strong> Especially in coastal homes (Malibu, Newport Beach). Replacement $180-$280.</li>
      <li><strong>Year 8-12, Main control board:</strong> Especially after grid power surges. Replacement $345-$525.</li>
    </ul>

    <p>Amana stand-alone freezers (chest and upright variants) follow the same service tree as Whirlpool freezer counterparts, door gasket, defrost system, thermostat. Garage-installed Amana freezers in the Inland Empire see harder service life from summer ambient stress (temperatures in unconditioned garages routinely exceed 100°F in July-August), with August-September service spikes typical.</p>
  </div>
</section>

<!-- 03 OTHER APPLIANCES -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">03, Amana laundry, ranges, microwaves</p>
    <h2 class="section-title">Value-tier laundry and cooking on the Whirlpool platform.</h2>

    <p class="lead">Outside refrigeration, Amana's lineup is narrower than its Whirlpool and Maytag siblings, but the parts platform is shared.</p>

    <p><strong>Amana laundry</strong> consists of NTW / NED top-load washers and dryers, entry-tier units mechanically similar to Whirlpool Centennial. Service tree: lid switch (year 3-6), drain pump (year 6-9), drive coupler / motor coupling, water inlet valve, drum belt + idler pulley on dryers (year 6-9), heating element (electric, year 8-12). Standard Whirlpool F-codes apply: F01 (CCU), F02 (long drain), F26 (lid switch).</p>

    <p><strong>Amana ranges</strong> (gas AGR / electric AER) are competitive value-tier freestanding ranges. Common service: surface igniter (gas, year 4-7), bake/broil element (electric, year 8-12), oven temperature sensor, control board. Glass-top electric models add radiant element service. F-codes follow Whirlpool diagnostic tree.</p>

    <p><strong>Amana microwaves</strong> (AMV over-the-range, ACM countertop), basic OTR and countertop units. Common service: door switch (3-switch system; one fails, microwave won't start), magnetron, turntable motor. Less prominent in Amana's current lineup than refrigeration and laundry.</p>
  </div>
</section>

<!-- 04 PRICING -->
<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">04, Pricing</p>
    <h2 class="section-title">What Amana appliance repair costs in Southern California.</h2>

    <p class="lead">Diagnostic is $89, applied toward the repair. Amana pricing typically lands at the lower end of the Whirlpool-platform band given the value-tier positioning. Labor and parts quoted in writing before any work begins.</p>

    <div class="pricing-grid">
      <div class="price-card">
        <div class="price-label">Diagnostic</div>
        <div class="price-amount">$89</div>
        <div class="price-desc">Waived when you approve repair</div>
      </div>
      <div class="price-card">
        <div class="price-label">Standard band</div>
        <div class="price-amount">$145–$385</div>
        <div class="price-desc">Lid switch · igniter · valve · drain pump · ice maker · sensor</div>
      </div>
      <div class="price-card">
        <div class="price-label">Major component</div>
        <div class="price-amount">$285–$525</div>
        <div class="price-desc">Control board · CCU · heating element · evaporator fan</div>
      </div>
      <div class="price-card">
        <div class="price-label">Sealed-system</div>
        <div class="price-amount">$585–$880</div>
        <div class="price-desc">Refrigerant work · compressor (out-of-warranty)</div>
      </div>
    </div>

    <p class="price-note">Note: Amana sits at the value tier of the Whirlpool family. On year-10+ Amana units, repair quotes that approach 50% of replacement cost typically tilt toward replacement, we tell you the math out loud before authorization. Cross-platform parts compatibility means Amana repairs are usually completed same-day with parts already on the truck.</p>
  </div>
</section>

<!-- 05 FAQ -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">05, FAQ</p>
    <h2 class="section-title">Amana appliance repair, common questions.</h2>

    <div class="faq-list">
      {faqs.map(f => (
        <details class="faq-item">
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- 06 BOTTOM CTA -->

  <!-- ── ALL CATEGORY LINKS (Wave 40b — pillar-to-category cross-links) ── -->
  <section class="section section-light">
    <div class="container narrow">
      <p class="eyebrow-sub">Every Amana category we cover</p>
      <h2>All Amana repair services in one place</h2>
      <ul class="cat-list">
        <li><a href="/brands/amana-dishwasher-repair/">Amana Dishwasher Repair</a></li>
        <li><a href="/brands/amana-laundry-repair/">Amana Laundry Repair</a></li>
        <li><a href="/brands/amana-range-repair/">Amana Range Repair</a></li>
        <li><a href="/brands/amana-refrigerator-repair/">Amana Refrigerator Repair</a></li>
        <li><a href="/brands/amana-wall-oven-repair/">Amana Wall Oven Repair</a></li>
      </ul>
    </div>
  </section>

<section class="bottom-cta">
  <div class="container">
    <h2>Amana appliance down? Same-day service across Southern California.</h2>
    <p>$89 diagnostic, applied toward the repair. Refrigerator · Freezer · Washer · Dryer · Range · Microwave. Whirlpool-platform parts on every truck, same-day fix on most repairs.</p>
    <div class="cta-row">
      <a href={phoneHref} class="btn-primary">☎ Call {phone}</a>
      <a href="/contact/" class="btn-secondary">Book Online</a>
    </div>
  </div>
</section>

</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .section { padding: 72px 24px; }
  .section-gray { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; }
  .container.narrow { max-width: 820px; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  h2.section-title { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; margin: 0 0 20px; line-height: 1.2; color: var(--text); }
  .lead { font-size: 1.05rem; line-height: 1.75; color: var(--text); margin-bottom: 20px; }
  .section p { margin: 0 0 18px; font-size: 1rem; line-height: 1.75; color: var(--text); }
  .section a { color: var(--red); font-weight: 600; text-decoration: none; }
  .section a:hover { text-decoration: underline; }

  .bullet-list { padding-left: 22px; margin: 16px 0; }
  .bullet-list li { font-size: 1rem; line-height: 1.75; color: var(--text); margin-bottom: 10px; }
  .bullet-list strong { color: var(--text); font-weight: 700; }

  .pricing-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-top: 32px; }
  .price-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 26px 22px; text-align: center; }
  .price-card .price-label { font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--muted); margin-bottom: 10px; font-weight: 700; }
  .price-card .price-amount { font-size: 1.7rem; font-weight: 800; color: var(--text); line-height: 1; margin-bottom: 10px; }
  .price-card .price-desc { font-size: 0.85rem; color: var(--muted); line-height: 1.55; }
  .price-note { margin-top: 24px; font-size: 0.95rem; color: var(--text); line-height: 1.7; }

  .faq-list { margin-top: 32px; }
  .faq-item { background: #fff; border: 1px solid var(--border); border-radius: 6px; padding: 18px 22px; margin-bottom: 12px; }
  .faq-item summary { font-weight: 700; cursor: pointer; font-size: 1rem; color: var(--text); list-style: none; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::before { content: "+ "; color: var(--red); font-weight: 800; margin-right: 6px; }
  .faq-item[open] summary::before { content: "− "; }
  .faq-item p { font-size: 0.95rem; color: var(--text); line-height: 1.75; margin: 14px 0 0; }

  .bottom-cta { background: var(--black); color: #fff; padding: 72px 24px; text-align: center; }
  .bottom-cta h2 { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; margin: 0 0 16px; color: #fff; line-height: 1.25; }
  .bottom-cta p { color: #c9c9c9; margin: 0 0 30px; font-size: 1.02rem; line-height: 1.6; }
  .cta-row { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 16px 34px; border-radius: 5px; font-size: 1rem; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 16px 34px; border-radius: 5px; font-size: 1rem; font-weight: 600; text-decoration: none; border: 2px solid rgba(255,255,255,0.35); }
</style>
