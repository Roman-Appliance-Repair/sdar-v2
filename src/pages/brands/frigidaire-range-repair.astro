---
// src/pages/brands/frigidaire-range-repair.astro
// Niche combo — Frigidaire range repair (~0 GSC impressions; brand portfolio completion).
// Parent: /brands/frigidaire/. Voice: Electrolux ownership, FFEF/FGEF base series, Gallery
// induction (GCRI), Memphis TN cooking plant, Professional pro-style ranges.
import Layout from '../../layouts/Layout.astro';
import ServiceHero from '../../components/ServiceHero.astro';
import { MAIN_PHONE } from '../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/brands/frigidaire-range-repair/";

const title = "Frigidaire Range Repair — Gas · Electric · Gallery Induction | Same Day Appliance Repair";
const description = `Frigidaire range repair across Southern California — gas (FGEF / FGGF), electric (FFEF / FFEC), Gallery induction (GCRI), Professional pro-style. Surface igniters, bake/broil elements, oven temp sensors, control boards. $89 diagnostic, applied toward repair. Call ${phone}.`;

const faqs = [
  {
    q: "My Frigidaire gas range burner clicks but won't light — what's wrong?",
    a: "Most common cause is a corroded or wet spark electrode at the burner base. Spilled food and liquid can short the spark path; the electrode keeps clicking but no spark jumps to the burner. Diagnostic order: (1) clean and dry the electrode — about 35% of 'clicks but no light' calls resolve here at no parts cost; (2) confirm gas supply at the unit (check that other burners light); (3) failed ignition switch under the knob — replacement $145-$245; (4) clogged orifice or blocked burner cap; (5) gas valve failure (least common, most expensive). We work the cheap items first. If multiple burners are failing simultaneously, the diagnostic shifts toward the spark module rather than individual igniters.",
  },
  {
    q: "My Frigidaire electric oven heats unevenly — what's the fix?",
    a: "Three things usually cause uneven oven heat on Frigidaire electric models (FFEF / FFEC series). (1) Failed bake or broil element — visible damage (cracks, blistering, or a broken loop) shows on inspection. Bake element $185-$285; broil element similar. (2) Oven temperature sensor drift — the resistance value changes over time and the control board reads incorrect temperature. Replacement $145-$215, takes 20 minutes. (3) Convection fan motor failure on convection-equipped models, leaving the oven heating but not circulating. We always test oven calibration after element or sensor replacement to confirm temperature is reading correctly across the bake range.",
  },
  {
    q: "How much does Frigidaire range repair cost?",
    a: `Diagnostic is $89, applied toward the repair when you approve work. Common Frigidaire range repair ranges: surface igniter (gas) $145-$215; ignition switch / spark module $145-$285; gas valve $280-$440; bake / broil element (electric) $185-$285; oven temperature sensor $145-$215; convection fan motor $245-$385; surface coil element (electric coil-top) $145-$245; radiant element (glass-top electric) $185-$285; Gallery induction zone coil $345-$525; main control board $345-$525. Frigidaire Gallery uplift typically 10-15% above base; Professional uplift 20-30%. We give a written estimate before any work begins.`,
  },
];

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": canonical + "#service",
    "serviceType": "Frigidaire Range Repair",
    "name": "Frigidaire Range Repair — Same Day Appliance Repair",
    "url": canonical,
    "description": "Same-day Frigidaire range repair across Los Angeles, Orange, Ventura, San Bernardino, and Riverside counties. Gas (FGEF / FGGF), electric coil-top, electric glass-top (FFEF / FFEC), Gallery induction (GCRI), Professional pro-style ranges. Surface igniters, ignition switches, gas valves, bake / broil elements, oven temperature sensors, control boards. Electrolux platform. $89 residential diagnostic, applied toward repair.",
    "provider": {
      "@type": "LocalBusiness",
      "name": "Same Day Appliance Repair",
      "url": "https://samedayappliance.repair/",
      "telephone": phone,
      "priceRange": "$$",
    },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" },
    ],
    "offers": {
      "@type": "Offer",
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "89.00",
        "priceCurrency": "USD",
        "description": "Residential diagnostic fee, applied toward repair",
      },
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map((f) => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "Frigidaire", "item": "https://samedayappliance.repair/brands/frigidaire/" },
      { "@type": "ListItem", "position": 4, "name": "Frigidaire Range Repair", "item": canonical },
    ],
  },
];
---

<Layout title={title} description={description} canonical={canonical}>

<Fragment slot="head-scripts">
  {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
</Fragment>

<ServiceHero
  eyebrow="LA · Orange · Ventura · San Bernardino · Riverside Counties"
  title="Frigidaire Range Repair — Across Southern California"
  subtitle="Gas (FGEF / FGGF), electric (FFEF / FFEC), Gallery induction (GCRI), Professional pro-style. Surface igniters, oven elements, temperature sensors, induction zone coils. Electrolux platform. $89 diagnostic, applied toward repair."
  heroImageTitle="Frigidaire Range Repair"
  showBranches={true}
/>

<!-- 01 INTRO -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">01 — About this service</p>
    <h2 class="section-title">Frigidaire ranges across gas, electric, and induction.</h2>

    <p>Frigidaire has been part of Electrolux since 1986, with US cooking-appliance manufacturing concentrated in Memphis, Tennessee. The range catalog spans four lines — gas freestanding (FGEF / FGGF series), electric coil-top and glass-top (FFEF / FFEC series), Gallery induction (GCRI series with full-surface induction zones), and the narrowed Frigidaire Professional pro-style ranges from late-2010s production. We service all four across our 5-county Southern California territory.</p>

    <p>Frigidaire ranges are competitive value-tier units in their respective categories. The Gallery induction line specifically (GCRI series) deserves note — it's a credible alternative to higher-priced induction brands, and the failure modes are documented: zone-coil sensor drift, touch control intrusion, individual zone module failure. Professional ranges from the discontinued line are still serviceable through Electrolux authorized parts. <a href="/brands/frigidaire/">Brand hub</a> covers Frigidaire's full appliance lineup; this page is range-specific.</p>
  </div>
</section>

<!-- 02 COMMON FAILURES -->
<section class="section section-gray">
  <div class="container">
    <p class="section-number">02 — Common failures</p>
    <h2 class="section-title">What we diagnose most often on Frigidaire ranges.</h2>

    <div class="problem-grid">
      <div class="problem-card">
        <h3>Gas burner won't ignite (FGEF / FGGF)</h3>
        <p>Spark clicks but no flame. Most common cause: corroded or wet spark electrode at the burner base from spilled food. About 35% resolve at the cleaning step with no parts cost. Remaining failures trace to ignition switch ($145-$245), clogged orifice, gas valve, or spark module on units showing multiple-burner failure simultaneously.</p>
      </div>
      <div class="problem-card">
        <h3>Bake or broil element failure (electric)</h3>
        <p>Element shows visible damage on inspection — cracks, blistering, or a broken section of the loop. Cooking time runs longer than usual, eventually heat fails entirely. Bake element $185-$285. We always run the oven through a calibration test after replacement to confirm temperature reads correctly.</p>
      </div>
      <div class="problem-card">
        <h3>Oven temperature sensor drift</h3>
        <p>Oven runs hotter or colder than the set temperature without the homeowner noticing for weeks. The resistance of the temperature sensor drifts as it ages, and the control board reads the wrong temperature. Replacement is a quick 20-minute job at $145-$215. Common wear pattern at year 6-9.</p>
      </div>
      <div class="problem-card">
        <h3>Gallery induction zone module failure (GCRI)</h3>
        <p>One zone of the induction surface stops heating while the others still work. The cooktop's modular architecture means the failure is module-level rather than full-surface — replacement is contained to one zone. $345-$525 typical. We confirm whether the issue is module-level or full control board before quoting.</p>
      </div>
    </div>
  </div>
</section>

<!-- 03 MODELS -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">03 — Frigidaire range models we service</p>
    <h2 class="section-title">FGEF / FFEF / GCRI / Professional.</h2>

    <p><strong>Gas (FGEF / FGGF series):</strong> FGEF3035, FGGF3036, FGGF3059, FGGH3047 — value-tier and Gallery 30" gas freestanding ranges, sealed-burner design. Common service: spark electrodes, ignition switches, surface igniters, gas valves, oven temperature sensors.</p>

    <p><strong>Electric coil-top (FFEF series):</strong> FFEF3052, FFEF3054, FFEC3025 — coil-top and basic glass-top electric ranges. Common service: surface coil elements, radiant elements (glass-top), bake / broil elements, oven sensor.</p>

    <p><strong>Gallery induction (GCRI series):</strong> GCRI305CAF, GCRI3038, GCRI306DAF — Gallery induction freestanding ranges with full-surface induction zones, electronic touch controls. Common service: zone module replacement, touch control glass, coil temperature sensors.</p>

    <p><strong>Frigidaire Professional pro-style:</strong> PCFE / FPGF series and similar — discontinued or narrowed Professional pro-style ranges with stainless-steel construction, premium burner hardware. Still serviceable through Electrolux authorized distribution; we identify model and serial year before scheduling.</p>
  </div>
</section>

<!-- 04 PRICING -->
<section class="section section-gray">
  <div class="container">
    <p class="section-number">04 — Pricing</p>
    <h2 class="section-title">Frigidaire range repair pricing.</h2>

    <p class="lead">Diagnostic is $89, applied toward the repair when you approve work. Frigidaire Gallery uplift typically 10-15% above base; Professional uplift 20-30%. Written estimate before any parts go on.</p>

    <div class="pricing-grid">
      <div class="price-card">
        <div class="price-label">Diagnostic</div>
        <div class="price-amount">$89</div>
        <div class="price-desc">Waived when you approve repair</div>
      </div>
      <div class="price-card">
        <div class="price-label">Standard band</div>
        <div class="price-amount">$145–$285</div>
        <div class="price-desc">Surface igniter · ignition switch · sensor</div>
      </div>
      <div class="price-card">
        <div class="price-label">Bake / broil element</div>
        <div class="price-amount">$185–$385</div>
        <div class="price-desc">Electric element · convection fan motor</div>
      </div>
      <div class="price-card">
        <div class="price-label">Major component</div>
        <div class="price-amount">$345–$525</div>
        <div class="price-desc">Induction zone module · main control board</div>
      </div>
    </div>

    <p class="price-note">Gas valve replacement $280-$440. Glass-top surface replacement (electric or induction) on year-10+ units typically tilts toward replacement rather than repair given the uplift on premium-glass parts.</p>
  </div>
</section>

<!-- 05 FAQ -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">05 — FAQ</p>
    <h2 class="section-title">Frigidaire range repair — common questions.</h2>

    <div class="faq-list">
      {faqs.map((f) => (
        <details class="faq-item">
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- 06 BOTTOM CTA -->
<section class="bottom-cta">
  <div class="container">
    <h2>Frigidaire range down? Same-day service across Southern California.</h2>
    <p>$89 diagnostic, applied toward the repair. Gas, electric, Gallery induction, Professional — Electrolux platform service across all five SoCal counties.</p>
    <div class="cta-row">
      <a href={phoneHref} class="btn-primary">☎ Call {phone}</a>
      <a href="/contact/" class="btn-secondary">Book Online</a>
    </div>
  </div>
</section>

</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .section { padding: 72px 24px; }
  .section-gray { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; }
  .container.narrow { max-width: 820px; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  h2.section-title { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; margin: 0 0 20px; line-height: 1.2; color: var(--text); }
  .lead { font-size: 1.05rem; line-height: 1.75; color: var(--text); margin-bottom: 20px; }
  .section p { margin: 0 0 18px; font-size: 1rem; line-height: 1.75; color: var(--text); }
  .section a { color: var(--red); font-weight: 600; text-decoration: none; }
  .section a:hover { text-decoration: underline; }

  .problem-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-top: 32px; }
  .problem-card { background: #fff; border: 1px solid var(--border); border-left: 4px solid var(--red); border-radius: 6px; padding: 26px 28px; }
  .problem-card h3 { font-size: 1.1rem; font-weight: 800; margin: 0 0 12px; color: var(--text); }
  .problem-card p { font-size: 0.95rem; color: var(--text); margin: 0; line-height: 1.7; }
  @media (max-width: 768px) { .problem-grid { grid-template-columns: 1fr; } }

  .pricing-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-top: 32px; }
  .price-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 26px 22px; text-align: center; }
  .price-card .price-label { font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--muted); margin-bottom: 10px; font-weight: 700; }
  .price-card .price-amount { font-size: 1.85rem; font-weight: 800; color: var(--text); line-height: 1; margin-bottom: 10px; }
  .price-card .price-desc { font-size: 0.85rem; color: var(--muted); line-height: 1.55; }
  .price-note { margin-top: 24px; font-size: 0.95rem; color: var(--text); line-height: 1.7; }

  .faq-list { margin-top: 32px; }
  .faq-item { background: #fff; border: 1px solid var(--border); border-radius: 6px; padding: 18px 22px; margin-bottom: 12px; }
  .faq-item summary { font-weight: 700; cursor: pointer; font-size: 1rem; color: var(--text); list-style: none; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::before { content: "+ "; color: var(--red); font-weight: 800; margin-right: 6px; }
  .faq-item[open] summary::before { content: "− "; }
  .faq-item p { font-size: 0.95rem; color: var(--text); line-height: 1.75; margin: 14px 0 0; }

  .bottom-cta { background: var(--black); color: #fff; padding: 72px 24px; text-align: center; }
  .bottom-cta h2 { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; margin: 0 0 16px; color: #fff; line-height: 1.25; }
  .bottom-cta p { color: #c9c9c9; margin: 0 0 30px; font-size: 1.02rem; line-height: 1.6; }
  .cta-row { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 16px 34px; border-radius: 5px; font-size: 1rem; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 16px 34px; border-radius: 5px; font-size: 1rem; font-weight: 600; text-decoration: none; border: 2px solid rgba(255,255,255,0.35); }
</style>
