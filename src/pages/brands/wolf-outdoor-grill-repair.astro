---
import Layout from '../../layouts/Layout.astro';
import BrandBranchesGrid from '../../components/BrandBranchesGrid.astro';
import { MAIN_PHONE, MAIN_PHONE_TEL } from '../../data/branches';

const title = "Wolf Outdoor Grill Repair | Southern California | OG36, Sub-Zero Group Family";
const description = "$89 diagnostic waived. Wolf outdoor grill repair Southern California — OG series built-in 30/36/42/54\", Sub-Zero Group family, Madison WI parts. (424) 325-0520.";
const canonical = "https://samedayappliance.repair/brands/wolf-outdoor-grill-repair/";

const faqs = [
  {
    q: "Wolf outdoor grill — which OG series model do I have?",
    a: "Wolf's outdoor grill lineup is the <b>OG-series built-in</b>: OG30, OG36, OG42, and OG54 (widths in inches). All are propane or natural gas built-in grills designed for outdoor kitchens — no portable or freestanding Wolf models. Standard features include 22,000 BTU stainless main burners with a ceramic-tile infrared sear zone, rotisserie with bi-directional spit motor, integrated halogen grill lights, and smoker box on larger sizes. Wolf outdoor grills ship under the Sub-Zero Group (the three-brand family: Sub-Zero + Wolf + Cove), so parts and service route through the same Madison Wisconsin parts chain that supports Wolf kitchen ranges + Sub-Zero refrigeration."
  },
  {
    q: "Sub-Zero Group family service — what does that mean for my Wolf grill?",
    a: "Wolf is part of Sub-Zero Inc.'s three-brand Sub-Zero Group (family-owned, Madison Wisconsin, founded 1945): <b>Sub-Zero</b> (refrigeration flagship), <b>Wolf</b> (cooking including outdoor grills), <b>Cove</b> (dishwashers, 2018+). For LA outdoor-grill service, parts route through the same Sub-Zero Group Madison Wisconsin chain that supports Wolf ranges, ovens, and range hoods — strong distributor stock on the West Coast, typical 2-4 day turnaround on common parts, 1-2 week factory-order on specialty or serial-matched items. If you have a matched Sub-Zero Group outdoor kitchen (Wolf grill + Sub-Zero outdoor refrigerator drawer), the same technician can service both on one visit."
  },
  {
    q: "OG36 burner won't ignite — sparker, battery, or gas valve?",
    a: "Wolf OG-series grills use an electronic spark ignition with a 9V battery driving the spark module. Diagnostic sequence: (1) <b>9V battery</b> — replace every 12-18 months regardless; $89 diag only, battery included in call. (2) <b>Spark module</b> — control board that pulses the igniter; $180-$280 replacement. (3) <b>Electrode corrosion</b> — LA coastal air + outdoor install accumulates corrosion on the spark electrode tips; clean + reposition $100-$160 (often no part). (4) <b>Gas valve</b> — if spark is healthy but no flame, the burner gas valve may have debris or spring fatigue; $220-$360 valve replacement. (5) <b>Orifice clogged</b> — rare but happens on natural-gas installs with dirty line; orifice cleaning $120-$180."
  },
  {
    q: "Rotisserie motor stopped — which motor is this?",
    a: "Wolf OG-series ships with a <b>Sub-Zero-Group-spec rotisserie motor</b> sized for the grill's heavy stainless spit — not a generic universal rotisserie motor. Bi-directional motors on newer units (spit rotates either clockwise or counter-clockwise depending on cooking setup). Typical failure at 8-12 year mark — thermal-cycling bearing wear. OEM rotisserie motor $280-$420 through Madison WI parts chain. We don't recommend generic aftermarket motors because they're not sized for the OG-series spit weight and typically fail within 1-2 years. For a grill investment at this tier, OEM is the right call."
  },
  {
    q: "Smoker box not producing smoke — pellets, burner, or ventilation?",
    a: "Wolf OG42 and OG54 include a dedicated smoker box — a separate sealed chamber with a low-BTU smoker-specific burner and wood-chip tray. Common issues: (1) <b>Wood-chip tray not sealing</b> — the box lid can warp with thermal cycling; the tray then loses its seal and smoke escapes before flavoring the food; $120-$180 tray replacement. (2) <b>Smoker burner fouled</b> — low-BTU burners clog faster than main burners; cleaning service $140-$220 often resolves. (3) <b>Ventilation louver</b> stuck open or closed — the box has a manual vent for smoke flow; check/lubricate ($89 diag). (4) <b>Using wrong wood type</b> — not a repair issue but we'll mention it during diagnostic; fine chips + pellets work better than chunks for the Wolf smoker box design."
  },
  {
    q: "What does Wolf outdoor grill repair cost in LA?",
    a: "Residential diagnostic $89 waived with repair. Typical Wolf OG-series bands: main burner $260–$400; igniter battery + electrode service $89 diag only; spark module $180–$280; gas valve $220–$360; burner orifice cleaning $120–$180; ceramic sear tile $180–$280; rotisserie motor (OEM) $280–$420; halogen grill light $80–$140; control panel knob $60–$140; thermostat/thermocouple $120–$200; smoker box tray $120–$180; grill-grate set $280–$420; integrated handle $120–$200. Sub-Zero Group Madison WI parts chain with West Coast distributor stock keeps common-parts turnaround fast."
  }
];

const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair — Wolf Outdoor Grill Service",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": canonical, "telephone": MAIN_PHONE_TEL, "priceRange": "$$$$"
  },
  { "@context": "https://schema.org", "@type": "Service", "serviceType": "Wolf Outdoor Grill Repair",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "description": "Wolf outdoor grill repair across LA — OG-series built-in (OG30/OG36/OG42/OG54), infrared sear zone, rotisserie, smoker box. Sub-Zero Group Madison Wisconsin parts chain (Sub-Zero + Wolf + Cove three-brand family). $89 residential diagnostic waived with repair.",
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, waived with repair" } }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "Wolf", "item": "https://samedayappliance.repair/brands/wolf/" },
      { "@type": "ListItem", "position": 4, "name": "Wolf Outdoor Grill Repair", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">{schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}</Fragment>
  <div class="call-banner"><div class="wrap"><span>Wolf outdoor grill service?</span><a href={`tel:${MAIN_PHONE_TEL}`} class="phone-lg">{MAIN_PHONE}</a></div></div>

  <section class="hero"><div class="wrap">
    <div class="crumb"><a href="/">Home</a> › <a href="/brands/">Brands</a> › Wolf › Outdoor Grill Repair</div>
    <h1>Wolf Outdoor Grill Repair</h1>
    <p class="lede">Wolf's outdoor grill lineup is the OG-series built-in (OG30, OG36, OG42, OG54 — widths in inches) with 22,000 BTU stainless main burners, ceramic-tile infrared sear zone, bi-directional rotisserie motor, integrated halogen grill lights, and smoker box on OG42/OG54. All ship under Sub-Zero Inc.'s Sub-Zero Group family (the three-brand Sub-Zero + Wolf + Cove lineup, family-owned Madison Wisconsin since 1945), so parts + service route through the same Madison WI parts chain that supports Wolf ranges, ovens, and range hoods. For LA outdoor kitchens where the builder spec'd a matched Sub-Zero Group suite, we can service Wolf grill + Sub-Zero outdoor refrigeration drawer on one visit. Same-day dispatch, $89 residential diagnostic waived with the repair.</p>
    <div class="hero-cta"><a href={`tel:${MAIN_PHONE_TEL}`} class="btn btn-primary">Call {MAIN_PHONE}</a><a href="#book" class="btn btn-ghost">Request a Visit</a></div>
    <ul class="hero-facts">
      <li><b>OG30 / OG36 / OG42 / OG54 built-in</b> — 22k BTU stainless main burners</li>
      <li><b>Sub-Zero Group family</b> — Sub-Zero + Wolf + Cove Madison WI parts chain</li>
      <li><b>Infrared sear + bi-directional rotisserie + halogen lights + smoker box (OG42/54)</b></li>
      <li><b>$89 residential diagnostic</b> — waived when you authorize the repair</li>
    </ul>
  </div></section>

  <BrandBranchesGrid />

  <section class="trust-bar"><div class="wrap"><span>BHGS #A49573 · Insured</span><span>Same-day in 5 SoCal counties</span><span>Residential diagnostic $89 · waived with repair</span></div></section>

  <section class="section"><div class="wrap">
    <h2>What Wolf outdoor grill repair costs in LA</h2>
    <table class="price-table">
      <tr><th>Service</th><th>Typical Range</th><th>Notes</th></tr>
      <tr><td>Residential diagnostic</td><td>$89</td><td>Waived with repair</td></tr>
      <tr><td>Main burner (22k BTU)</td><td>$260 – $400</td><td>Stainless steel</td></tr>
      <tr><td>Spark module</td><td>$180 – $280</td><td>Ignition control board</td></tr>
      <tr><td>Gas valve (burner-specific)</td><td>$220 – $360</td><td>Spring-fatigue diagnostic</td></tr>
      <tr><td>Ceramic sear tile</td><td>$180 – $280</td><td>Thermal shock failure</td></tr>
      <tr><td>Rotisserie motor (OEM bi-directional)</td><td>$280 – $420</td><td>Sub-Zero Group spec</td></tr>
      <tr><td>Smoker box tray (OG42/OG54)</td><td>$120 – $180</td><td>Seal-warp fix</td></tr>
      <tr><td>Halogen grill light</td><td>$80 – $140</td><td>Integrated lighting</td></tr>
      <tr><td>Thermocouple</td><td>$120 – $200</td><td>Flame-sensing safety</td></tr>
      <tr><td>Grill-grate set</td><td>$280 – $420</td><td>Stainless; 10+ year service</td></tr>
    </table>
    <p class="small">Related: <a href="/brands/wolf/">Wolf brand hub</a> · <a href="/brands/wolf-range-repair/">Wolf range</a> · <a href="/brands/wolf-range-hood-repair/">Wolf range hood</a> · <a href="/brands/wolf-oven-repair/">Wolf oven</a> · <a href="/brands/sub-zero-refrigerator-repair/">Sub-Zero refrigerator (Sub-Zero Group family)</a> · <a href="/brands/twin-eagles-grill-repair/">Twin Eagles (luxury built-in peer)</a> · <a href="/services/bbq-grill-repair/">BBQ grill repair (service hub)</a>.</p>
  </div></section>

  <section class="section alt"><div class="wrap narrow">
    <h2>Sub-Zero Group matched-suite outdoor kitchen — one service relationship</h2>
    <p>Wolf outdoor grills ship as part of the three-brand Sub-Zero Group family alongside Sub-Zero refrigeration (indoor + outdoor) and Cove dishwashers (indoor only). Customers who spec the matched Sub-Zero Group outdoor kitchen — Wolf OG-series grill + Sub-Zero outdoor refrigerator drawer + indoor Sub-Zero + indoor Wolf range + indoor Cove dishwasher — get a single parts chain (Madison Wisconsin distribution network), consistent service warranty terms across all three brands, and shared tech protocols that let one of our technicians cover multiple appliances on a single call. That's the Sub-Zero Group value proposition at service time — no brand-to-brand escalation chains, no parts-catalog surprises. If your outdoor kitchen also includes Sub-Zero refrigeration, tell us at booking and we'll budget the combined service call accordingly.</p>
  </div></section>

  <section class="section"><div class="wrap narrow">
    <h2>Wolf outdoor grill repair — frequently asked</h2>
    {faqs.map(f => (<details class="faq"><summary>{f.q}</summary><p set:html={f.a}></p></details>))}
  </div></section>

  <section id="book" class="cta-bottom"><div class="wrap">
    <h2>Wolf outdoor grill service? Call the branch closest to your home.</h2>
    <p>Same-day appliance repair in Los Angeles, Orange County, Ventura County. Residential diagnostic $89, waived with repair.</p>
  </div></section>
  <a href={`tel:${MAIN_PHONE_TEL}`} class="float-call" aria-label="Call now">☎ Call {MAIN_PHONE}</a>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  body { color: var(--text); } .wrap { max-width: 1200px; margin: 0 auto; padding: 0 24px; } .wrap.narrow { max-width: 820px; }
  h1 { font-size: 2.4rem; line-height: 1.15; margin: 12px 0 20px; color: var(--black); }
  h2 { font-size: 1.8rem; margin: 0 0 16px; color: var(--black); }
  p { line-height: 1.65; margin: 0 0 14px; }
  .call-banner { background: var(--red); color: #fff; padding: 10px 0; }
  .call-banner .wrap { display:flex; gap: 14px; align-items: center; justify-content: center; flex-wrap: wrap; }
  .call-banner .phone-lg { color:#fff; font-weight: 800; text-decoration: underline; font-size: 1.05rem; }
  .hero { background: var(--black); color: #fff; padding: 42px 0 56px; } .hero h1 { color: #fff; }
  .hero .lede { font-size: 1.06rem; color: #d7d7d7; max-width: 680px; }
  .hero .crumb { color: #9a9a9a; font-size: 0.85rem; margin-bottom: 6px; } .hero .crumb a { color: #c9c9c9; text-decoration: none; }
  .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; margin: 18px 0 24px; }
  .btn { display: inline-block; padding: 12px 20px; border-radius: 4px; text-decoration: none; font-weight: 700; }
  .btn-primary { background: var(--red); color: #fff; } .btn-ghost { background: transparent; color: #fff; border: 1px solid #fff; }
  .hero-facts { list-style: none; padding: 0; margin: 0; color: #c9c9c9; font-size: 0.95rem; }
  .hero-facts li { padding: 6px 0; border-top: 1px solid #222; } .hero-facts li:first-child { border-top: 0; }
  .trust-bar { background: var(--red); color: #fff; padding: 14px 0; }
  .trust-bar .wrap { display: flex; gap: 28px; flex-wrap: wrap; justify-content: center; font-size: 0.95rem; font-weight: 600; }
  .section { padding: 56px 0; } .section.alt { background: var(--gray); }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 14px; background: #fff; }
  .price-table th, .price-table td { text-align: left; padding: 11px 12px; border-bottom: 1px solid var(--border); }
  .price-table th { background: var(--black); color: #fff; font-weight: 700; font-size: 0.95rem; }
  .small { color: var(--muted); font-size: 0.92rem; margin-top: 12px; }
  .faq { background: #fff; border: 1px solid var(--border); padding: 12px 16px; margin-bottom: 8px; border-radius: 4px; }
  .faq summary { font-weight: 700; cursor: pointer; padding: 4px 0; } .faq p { margin: 8px 0 0; }
  .cta-bottom { background: var(--black); color: #fff; padding: 48px 0; } .cta-bottom h2 { color: #fff; } .cta-bottom p { color: #c9c9c9; }
  .float-call { position: fixed; bottom: 18px; right: 18px; background: var(--red); color: #fff; padding: 14px 18px; border-radius: 40px; text-decoration: none; font-weight: 700; box-shadow: 0 6px 18px rgba(0,0,0,0.28); z-index: 50; font-size: 0.95rem; }
  @media (max-width: 820px) { h1 { font-size: 1.9rem; } .float-call { padding: 11px 14px; font-size: 0.88rem; } .trust-bar .wrap { gap: 14px; font-size: 0.85rem; } }
</style>
