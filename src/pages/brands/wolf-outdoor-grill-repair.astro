---
// Phase 2 Cluster 3 #2 — Wolf Outdoor BBQ grill pillar.
// Brand: Sub-Zero Group (Madison WI) — same parent as indoor Wolf cooking.
// Outdoor Series built-in gas grills + side burners. Premium tier.
// **Important: distinct from /brands/wolf/ (indoor cooking pillar).**
// Cross-link к Wolf indoor explicit.
// Residential ($89). NEW schema pattern.

import Layout from '../../layouts/Layout.astro';
import ServiceHero from '../../components/ServiceHero.astro';
import { mergeCredentials } from '../../data/credentials-schema';

const phone = '(323) 870-4790';
const phoneRaw = phone.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/brands/wolf-outdoor-grill-repair/";

const title = "Wolf Outdoor Grill Repair Los Angeles — Same Day";
const description = "Wolf Outdoor grill repair across LA. Sub-Zero Group outdoor cooking, built-in gas grills + side burners. Premium luxury tier. EPA 608, $89 dx waived with repair.";

const faqs = [
  { q: "Same-day Wolf Outdoor service in LA?", a: "Yes for diagnostic and most common repairs. Most calls received before 2 PM get a tech on-site the same business day. Common service items — igniter modules, gas valves, regulator components, burner assemblies — typically ride on the truck. Less common items may add 1-5 business days for parts ordering through Sub-Zero Group authorized distribution. We confirm availability during the diagnostic and tell you the realistic timeline before scheduling labor." },
  { q: "Is Wolf Outdoor different from Wolf indoor cooking?", a: "Yes — they're related but separate product categories from the same parent company (Sub-Zero Group, Madison Wisconsin). Wolf indoor cooking covers ranges, ovens, cooktops, and warming drawers; we cover that practice on our /brands/wolf/ pillar with a different scope and parts inventory. Wolf Outdoor covers built-in gas grills, side burners, and outdoor-rated accessories — different operating environment (UV, weather, gas-grill-specific failure modes) and different parts catalog. Our diagnostic identifies which Wolf product family you have and routes the service correctly. Both share Sub-Zero Group authorized parts distribution, so our sourcing infrastructure is the same." },
  { q: "Do you carry Wolf Outdoor OEM parts on the truck?", a: "Common service parts ride on every residential outdoor truck: igniter modules, gas valves, regulator components, common burner assemblies, electrical components for newer Wolf Outdoor configurations. Premium-tier specific parts (specific control board variants, brand-specific burner shields, premium grate replacements) come through Sub-Zero Group authorized distribution, 2-7 business days. We do not substitute aftermarket components on Wolf Outdoor — the brand's positioning at the premium tier reflects engineering investment that bargain parts undermine." },
  { q: "What's your diagnostic fee for Wolf Outdoor?", a: "$89 residential diagnostic, waived when you approve the repair. The diagnostic covers ignition system test, gas system pressure and leak test, burner inspection, control valve operation, electrical components, exterior stainless integrity, and weatherproofing assessment. Written quote with parts cost, labor estimate, and realistic timeline before any work begins." },
  { q: "How does coastal exposure affect Wolf Outdoor grills?", a: "Coastal installations face accelerated stainless steel oxidation, electrical module degradation from salt-air infiltration, and gas valve cycling fatigue from the corrosive environment. Wolf Outdoor uses higher-grade stainless than mass-market grills, so the brand handles coastal exposure better than entry-tier options — but no stainless is impervious. We adjust maintenance interval more aggressively for coastal installs (quarterly rather than annual) and recommend specific corrosion-protection protocols. Most LA Wolf Outdoor coastal installs run 12-15 years с proper maintenance, sometimes longer." },
  { q: "Can you service Wolf Outdoor built into custom outdoor kitchens?", a: "Yes, this is most of the Wolf Outdoor service work we do across LA. Built-in grills integrated into stone, stucco, or stainless outdoor kitchen islands — common configuration в Bel Air, Beverly Hills, Pacific Palisades, и Hidden Hills luxury installations. Service approach respects the surrounding masonry: front access where possible, careful component extraction, и coordination с the homeowner's outdoor designer when major work is needed. Wolf Outdoor installations frequently combine с Sub-Zero outdoor refrigeration в the same kitchen island — when both need service, we coordinate single dispatches when possible." }
];

const localBusinessSchema = mergeCredentials({
  '@context': 'https://schema.org', '@type': 'HomeAndConstructionBusiness', '@id': canonical + '#business',
  name: 'Same Day Appliance Repair — Wolf Outdoor Grill Service',
  url: canonical, telephone: phone, email: 'support@samedayappliance.repair', priceRange: '$$$',
  openingHoursSpecification: [
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'], opens: '08:00', closes: '20:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: 'Sunday', opens: '00:00', closes: '00:00' }
  ],
  areaServed: [
    { '@type': 'AdministrativeArea', name: 'Los Angeles County' }, { '@type': 'AdministrativeArea', name: 'Orange County' },
    { '@type': 'AdministrativeArea', name: 'Ventura County' }, { '@type': 'AdministrativeArea', name: 'San Bernardino County' },
    { '@type': 'AdministrativeArea', name: 'Riverside County' }
  ]
});

const serviceSchema = {
  '@context': 'https://schema.org', '@type': 'Service', '@id': canonical + '#service',
  serviceType: 'Wolf Outdoor Grill Repair',
  name: 'Wolf Outdoor Grill Repair, Same Day Appliance Repair',
  url: canonical,
  description: 'Same-day Wolf Outdoor grill repair across Los Angeles, Orange, Ventura, San Bernardino, and Riverside counties. Sub-Zero Group outdoor cooking — built-in gas grills, side burners, accessories. Premium luxury tier. Igniter modules, gas valves, burner assemblies, control electronics. EPA 608 Universal certified (#1346255700410), BHGS #A49573, CSLB C-20 HVAC. $89 residential diagnostic, applied toward repair. Sub-Zero Group OEM parts only.',
  provider: { '@id': canonical + '#business' },
  areaServed: [
    { '@type': 'AdministrativeArea', name: 'Los Angeles County' }, { '@type': 'AdministrativeArea', name: 'Orange County' },
    { '@type': 'AdministrativeArea', name: 'Ventura County' }, { '@type': 'AdministrativeArea', name: 'San Bernardino County' },
    { '@type': 'AdministrativeArea', name: 'Riverside County' }
  ],
  brand: { '@type': 'Brand', name: 'Wolf Outdoor', sameAs: 'https://www.subzero-wolf.com/wolf/outdoor-grills' },
  offers: { '@type': 'Offer', priceSpecification: { '@type': 'PriceSpecification', price: '89.00', priceCurrency: 'USD', description: 'Residential diagnostic fee, applied toward repair' } }
};

const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
const breadcrumbSchema = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
  { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://samedayappliance.repair/' },
  { '@type': 'ListItem', position: 2, name: 'Brands', item: 'https://samedayappliance.repair/brands/' },
  { '@type': 'ListItem', position: 3, name: 'Wolf Outdoor', item: canonical }
]};
const schemaJsons = [localBusinessSchema, serviceSchema, faqSchema, breadcrumbSchema];
---

<Layout title={title} description={description} canonical={canonical}>
<Fragment slot="head-scripts">
  {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
</Fragment>

<ServiceHero
  eyebrow="Outdoor Grill · Sub-Zero Group · Premium Luxury Tier"
  title="Wolf Outdoor Grill Repair, Across Southern California"
  subtitle="Built-in gas grills, side burners, and outdoor-rated accessories from Sub-Zero Group's outdoor cooking lineup. Same parent company as Wolf indoor cooking, separate product family с distinct service approach. EPA 608 Universal certified, BHGS #A49573. $89 residential diagnostic, waived with repair."
  heroImageTitle="Wolf Outdoor Grill Repair"
  showBranches={true}
/>

<section class="section">
  <div class="container narrow">
    <p class="section-number">01, About this service</p>
    <h2>Sub-Zero Group's outdoor cooking, in service across LA</h2>
    <p>
      Wolf Outdoor is part of the Sub-Zero Group lineup из Madison, Wisconsin — same parent company как Wolf indoor cooking
      и Sub-Zero refrigeration. The outdoor product family targets the same premium-tier customer who specs Wolf indoor
      ranges and Sub-Zero refrigerators inside the house — a coordinated luxury kitchen и outdoor-cooking package built
      around one parent company's engineering и parts ecosystem. The grills themselves are built-in gas units intended
      for integration into custom outdoor kitchens, с side burner и accessory configurations that anchor a complete
      outdoor cooking setup rather than a freestanding cart.
    </p>
    <p>
      <strong>Important distinction:</strong> Wolf Outdoor и Wolf indoor cooking are separate product categories. Our
      <a href="/brands/wolf/">/brands/wolf/ pillar</a> covers Wolf indoor — ranges, ovens, cooktops, warming drawers — с its own
      service scope, parts inventory, и failure-mode patterns. This page covers the outdoor product family specifically:
      different operating environment (UV, weather, gas-grill-specific failures), different parts catalog, different diagnostic
      approach. Both share Sub-Zero Group authorized parts distribution, so our sourcing infrastructure is the same. We
      service both, и often the same homeowner who needs Wolf Outdoor service also has Wolf indoor cooking equipment in the
      house — we coordinate.
    </p>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">02, Series and product coverage</p>
    <h2>What we service across the Wolf Outdoor lineup</h2>

    <h3>Outdoor Series built-in gas grills</h3>
    <p>
      The core Wolf Outdoor offering — built-in gas grills designed для integration into custom outdoor kitchen islands.
      Various burner configurations (typically 3-burner up through larger 6+ burner spreads), infrared burner zones on certain
      configurations, и rotisserie systems integrated с the burner array. Premium stainless construction, electronic ignition
      systems, и heavy-duty grate materials. Service items cluster around the gas system (igniters, valves, regulators),
      burner replacement after years of use, и electronic component aging.
    </p>

    <h3>Side burners and outdoor-rated accessories</h3>
    <p>
      Wolf Outdoor side burners pair с the main grill в outdoor kitchen configurations — typically gas burners для outdoor
      cookware (sauces, sides, frying that the homeowner doesn't want to do indoors). Service approach is similar к the
      grill side: gas valves, igniters, regulator components. Other Wolf Outdoor accessories (warming drawers, storage
      configurations) we service as needed; refrigerated drawers integrated с the outdoor kitchen are typically Sub-Zero
      product, which we cover separately.
    </p>

    <h3>Built-in vs freestanding</h3>
    <p>
      Wolf Outdoor's positioning is primarily built-in — the brand emphasizes integration into custom outdoor kitchen
      installations rather than freestanding cart configurations. Most LA Wolf Outdoor service work involves built-in units
      integrated into stone, stucco, or stainless cladding на an outdoor kitchen island. Service approach respects the
      surrounding installation: front access where possible, careful component extraction, and coordination с the homeowner's
      outdoor kitchen designer when major work requires removing the grill chassis from the surrounding masonry.
    </p>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">03, Common failure patterns</p>
    <h2>What we look at first on a Wolf Outdoor call</h2>
    <ul class="bullet-list">
      <li><strong>Igniter module failure.</strong> Outdoor electrical components в LA's environment wear faster than indoor — UV exposure on the dry season, moisture infiltration during winter rains. Igniter modules typically reach end-of-life at year 7-10 в average operating conditions, sooner на coastal installs. Symptom is electronic ignition failing while manual lighting still works. OEM module replacement straightforward.</li>
      <li><strong>Gas valve cycling fatigue.</strong> Brass valves cycle thousands of times over the life of the grill. Year 8-12 cluster shows sticking issues или incomplete closure on heavily-used burners. Symptom is burner that won't fully turn off или uneven flame. Replacement valves through Sub-Zero Group distribution.</li>
      <li><strong>Burner port accumulation.</strong> Cooking debris, grease, и occasional ash (LA wildfire season) clog ports over time. Symptom is uneven flame distribution. Service is mechanical cleaning в most cases; heavy buildup requires burner replacement.</li>
      <li><strong>Regulator aging.</strong> Outdoor regulators handle pressure transitions and weather exposure. Year 10-15 cluster shows pressure drift или regulator failure. Symptom is overall reduced burner output across multiple burners simultaneously. OEM replacement restores correct gas pressure delivery.</li>
      <li><strong>Stainless corrosion на coastal installs.</strong> Wolf Outdoor uses higher-grade stainless than mass-market grills, but coastal salt air still oxidizes external surfaces over years. We see surface oxidation on cooking grates, fastener corrosion, и accelerated electrical module degradation в coastal environments. Quarterly maintenance recommended for coastal installs.</li>
      <li><strong>Control electronics fade.</strong> Newer Wolf Outdoor configurations с electronic burner control or smart-grill features use control boards that age с years of outdoor exposure. Symptom is intermittent display issues или controls not responding. Diagnostic confirms before swapping; we don't replace control boards on suspicion.</li>
    </ul>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">04, Where we work most on Wolf Outdoor</p>
    <h2>The LA Wolf Outdoor footprint our techs know best</h2>
    <p><strong>Coordinated Sub-Zero Group installations.</strong> Many Wolf Outdoor units sit на outdoor kitchens that also include Sub-Zero outdoor refrigeration — refrigerated drawers, bar centers, ice makers integrated с the cooking island. The customer who specs Wolf Outdoor often specs Sub-Zero outdoor refrigeration в the same project. We service the full Sub-Zero Group equipment lineup, so when the homeowner has multiple components needing service, we coordinate single dispatches.</p>
    <p><strong>Bel Air, Beverly Hills, Pacific Palisades luxury backyards.</strong> Custom outdoor kitchens с Wolf Outdoor built-in grills integrated into stone or stainless islands. The premium positioning matches the surrounding install quality.</p>
    <p><strong>Hidden Hills, Calabasas newer luxury developments.</strong> Wolf Outdoor installations с newer electronic features. Service approach adds the electronic diagnostic component.</p>
    <p><strong>Malibu и Pacific Coast estates.</strong> Coastal exposure changes the maintenance picture; we recommend more aggressive cleaning protocols и quarterly service intervals.</p>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">05, Recent repairs</p>
    <h2>What this month looked like on Wolf Outdoor</h2>
    <div class="repair-cards">
      <div class="repair-card">
        <p class="repair-quote">"Three of six burners stopped lighting electronically, manual ignition still works, dinner party Saturday."</p>
        <p>Pacific Palisades home, Wolf Outdoor built-in grill, install year per the homeowner approximately 2016. Diagnostic confirmed igniter module failure on the affected burner cluster — typical year 8-10 cluster failure для outdoor electrical в LA's UV exposure. OEM modules ride on the truck для common configurations; replaced affected modules, verified ignition on all burners, ran load test before completing the call. Total service 2 hours, homeowner ready for the dinner party.</p>
      </div>
      <div class="repair-card">
        <p class="repair-quote">"Burner output dropped across the entire grill, can't reach proper sear temps anymore."</p>
        <p>Bel Air home, Wolf Outdoor с side burner configuration, install year per the homeowner approximately 2013. Diagnostic isolated к regulator aging — pressure delivery dropped below spec across the burner array, which explained the uniform output reduction across all burners (not a single-burner failure pattern). Sourced replacement regulator through Sub-Zero Group distribution (3 business days), installed on second visit, verified pressure delivery и full burner output. Restored proper sear performance.</p>
      </div>
      <div class="repair-card">
        <p class="repair-quote">"Coastal exposure showing on stainless, electronic ignition intermittent during early morning humidity."</p>
        <p>Malibu home, Wolf Outdoor near the PCH, install year approximately 2018. Diagnostic showed combined coastal patterns: visible corrosion on external stainless components, igniter module электрical degradation from salt-air infiltration. Replaced affected igniter modules, performed deep clean of stainless surfaces, applied corrosion-protection coating, и worked with homeowner on adjusted maintenance schedule (quarterly rather than annual). Functional restoration plus longer-term protection plan.</p>
      </div>
    </div>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">06, Why us, specifically</p>
    <h2>What makes us a fit for Wolf Outdoor service</h2>
    <ul class="bullet-list">
      <li><strong>Sub-Zero Group authorized parts sourcing.</strong> Same distribution we use для Sub-Zero refrigeration и Wolf indoor cooking — consistent supply chain across the parent company's product lines.</li>
      <li><strong>EPA 608 Universal certification (#1346255700410).</strong> Required для refrigeration scope work on outdoor kitchens с integrated Sub-Zero refrigerated drawers.</li>
      <li><strong>BHGS Registration #A49573 plus CSLB C-20 HVAC.</strong> California state coverage for appliance repair, gas-line scope, и adjacent HVAC work.</li>
      <li><strong>Wolf Outdoor OEM parts only.</strong> No aftermarket substitutions on the brand's premium-tier engineering investment.</li>
      <li><strong>$89 residential diagnostic, waived с repair.</strong> Transparent flat fee.</li>
      <li><strong>Coordinated service for full Sub-Zero Group installations.</strong> Outdoor kitchens с both Wolf Outdoor cooking и Sub-Zero refrigeration get single-dispatch coordination when both need service.</li>
      <li><strong>Custom installation experience.</strong> Most LA Wolf Outdoor work involves built-in grills integrated into custom outdoor kitchen masonry — careful access, surrounding architecture protection, designer coordination when needed.</li>
      <li><strong>BBB Accredited Business and $1M general liability insured.</strong></li>
    </ul>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">07, Frequently asked questions</p>
    <h2>The questions we get most on Wolf Outdoor calls</h2>
    <div class="faq-list">
      {faqs.map(f => (<details class="faq-item"><summary>{f.q}</summary><p>{f.a}</p></details>))}
    </div>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">08, Other outdoor cooking and Wolf services we cover</p>
    <h2>Wolf Outdoor service in context</h2>
    <ul class="cross-links">
      <li><a href="/brands/wolf/">Wolf indoor cooking</a> — ranges, ovens, cooktops, warming drawers (sister product line)</li>
      <li><a href="/brands/twin-eagles-grill-repair/">Twin Eagles grill repair</a> — American luxury alternative</li>
      <li><a href="/brands/lynx-grill-repair/">Lynx grill repair</a></li>
      <li><a href="/brands/fire-magic-grill-repair/">Fire Magic grill repair</a></li>
      <li><a href="/brands/hestan-outdoor-grill-repair/">Hestan Outdoor grill repair</a></li>
      <li><a href="/brands/dcs-grill-repair/">DCS grill repair</a></li>
      <li><a href="/brands/viking-bbq-grill-repair/">Viking BBQ grill repair</a></li>
      <li><a href="/outdoor/grill-repair/">Outdoor grill repair (all brands)</a></li>
    </ul>
  </div>
</section>

<section class="bottom-cta">
  <div class="container narrow">
    <h2>Same-day Wolf Outdoor service across Southern California</h2>
    <p>$89 residential diagnostic, waived with repair. EPA 608 Universal certified, BHGS #A49573, CSLB C-20 HVAC, BBB Accredited.</p>
    <div class="cta-row">
      <a href={phoneHref} class="btn-red">Call {phone}</a>
      <a href="/contact/" class="btn-outline">Request service →</a>
    </div>
  </div>
</section>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .section { padding: 64px 24px; }
  .section-gray { background: var(--gray); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .container.narrow { max-width: 820px; margin: 0 auto; }
  .section-number { font-size: 12px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--red); margin: 0 0 12px; }
  h2 { font-size: clamp(22px, 3vw, 32px); font-weight: 700; line-height: 1.2; margin: 0 0 20px; color: var(--text); letter-spacing: -.01em; }
  h3 { font-size: 18px; font-weight: 700; margin: 24px 0 10px; color: var(--text); }
  p { font-size: 16px; line-height: 1.7; color: var(--text); margin: 0 0 14px; }
  strong { font-weight: 700; }
  a { color: var(--red); text-decoration: none; }
  a:hover { text-decoration: underline; }
  .bullet-list { list-style: none; padding: 0; margin: 16px 0; }
  .bullet-list li { position: relative; padding: 12px 0 12px 22px; font-size: 15.5px; line-height: 1.65; border-bottom: 1px solid var(--border); }
  .bullet-list li:last-child { border-bottom: none; }
  .bullet-list li::before { content: "▸"; position: absolute; left: 0; color: var(--red); font-weight: 700; }
  .repair-cards { display: grid; gap: 20px; margin-top: 20px; }
  .repair-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 22px 26px; }
  .repair-quote { font-style: italic; color: var(--red); font-weight: 600; margin: 0 0 12px; font-size: 15px; }
  .repair-card p:last-child { margin-bottom: 0; }
  .faq-list { margin-top: 20px; }
  .faq-item { border-bottom: 1px solid var(--border); padding: 16px 0; }
  .faq-item:last-child { border-bottom: none; }
  .faq-item summary { cursor: pointer; font-weight: 700; font-size: 16px; color: var(--text); padding: 4px 0; }
  .faq-item summary:hover { color: var(--red); }
  .faq-item p { margin: 12px 0 4px; font-size: 15.5px; color: var(--text); }
  .cross-links { list-style: none; padding: 0; margin: 16px 0 0; }
  .cross-links li { padding: 10px 0; border-bottom: 1px solid var(--border); font-size: 15px; }
  .cross-links li:last-child { border-bottom: none; }
  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { color: #fff; }
  .bottom-cta p { color: rgba(255,255,255,.85); max-width: 640px; margin: 0 auto 24px; }
  .bottom-cta a { color: #fff; }
  .cta-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-red { background: var(--red); color: #fff; padding: 14px 28px; border-radius: 6px; font-weight: 600; text-decoration: none; }
  .btn-outline { border: 1.5px solid rgba(255,255,255,.3); color: #fff; padding: 14px 28px; border-radius: 6px; font-weight: 600; text-decoration: none; }
</style>
