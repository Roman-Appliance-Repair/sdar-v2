---
// src/pages/brands/lg-freezer-repair.astro
// Niche combo, LG freezer repair (~0 GSC impressions; brand portfolio completion).
// Parent: /brands/lg/. Voice: LG Electronics Korean manufacturer, Linear Compressor + 10-year
// Rosen warranty extension, CF / CHE / Er rF compressor codes, Smart ThinQ connectivity,
// standalone upright (LRTLS) + chest (LROFC) freezer focus.
import Layout from '../../layouts/Layout.astro';
import ServiceHero from '../../components/ServiceHero.astro';
import { MAIN_PHONE } from '../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/brands/lg-freezer-repair/";

const title = "LG Freezer Repair Los Angeles — Same Day";
const description = `LG freezer repair across SoCal. Upright LRTLS, chest LROFC, garage-rated. Linear Compressor + 10-year warranty. BHGS #A49573. $89 dx waived.`;

const faqs = [
  {
    q: "Does the 10-year LG Linear Compressor warranty apply to LG freezers?",
    a: "It depends on the specific model. The Rosen v. LG settlement extended the Linear Compressor warranty to 10 years on millions of refrigerators built with that compressor; some LG stand-alone freezer models also use Linear Compressor architecture and may fall under the same extension. We verify warranty status during diagnostic, model number, serial, manufacture date, and the specific fault code determine whether your freezer's compressor failure is a covered claim through LG or an out-of-pocket repair. We don't profit from work that's already covered; if it's a warranty claim we'll tell you to call LG first."
  },
  {
    q: "My LG freezer is in the garage and stops staying frozen every July, what's going on?",
    a: "This is a common Inland Empire and San Fernando Valley call. Most consumer-grade LG freezers (and freezers in general) are spec'd for ambient temperatures up to about 95-100°F. An unconditioned LA garage in July-August routinely runs 105-115°F, which is outside the operating envelope. The compressor can run continuously trying to maintain setpoint, the condenser coil can't reject heat fast enough, and interior temps drift above 0°F. We see the same units recover when ambient drops in October. The structural fix is a garage-rated LG freezer (some LRTLS upright models carry a garage-ready spec, check the spec sheet for ambient operating range), not a service repair on a unit working at the limit of its envelope. We'll tell you that honestly at diagnostic."
  },
  {
    q: "How much does LG freezer repair cost?",
    a: `Diagnostic is $89, applied toward the repair when you approve work. Common LG freezer repair ranges (out of warranty): door gasket $180-$280; thermostat or temperature sensor $185-$285; evaporator fan motor $245-$385; condenser fan motor $245-$385; defrost system (heater + thermostat + sensor) $185-$345; main control board $345-$525; door alarm or temperature alarm $145-$215; sealed-system / refrigerant work $585-$880 on units outside compressor warranty. If the unit is under the 10-year Linear Compressor warranty and the failure points to the compressor itself, the part and labor for that specific repair are usually covered through LG, we verify before quoting.`
  }
];

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": canonical + "#service",
    "serviceType": "LG Freezer Repair",
    "name": "LG Freezer Repair, Same Day Appliance Repair",
    "url": canonical,
    "description": "Same-day LG freezer repair across Los Angeles, Orange, Ventura, San Bernardino, and Riverside counties. Upright (LRTLS series), chest (LROFC series), garage-rated LG stand-alone freezers. Linear Compressor warranty verification, defrost systems, door gaskets, evaporator and condenser fan motors, Smart ThinQ connectivity diagnostics. $89 residential diagnostic, applied toward repair.",
    "provider": {
      "@type": "LocalBusiness",
      "name": "Same Day Appliance Repair",
      "url": "https://samedayappliance.repair/",
      "telephone": phone,
      "priceRange": "$$"
    },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "offers": {
      "@type": "Offer",
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "89.00",
        "priceCurrency": "USD",
        "description": "Residential diagnostic fee, applied toward repair"
      }
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map((f) => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "LG", "item": "https://samedayappliance.repair/brands/lg/" },
      { "@type": "ListItem", "position": 4, "name": "LG Freezer Repair", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>

<Fragment slot="head-scripts">
  {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
</Fragment>

<ServiceHero
  eyebrow="LA · Orange · Ventura · San Bernardino · Riverside Counties"
  title="LG Freezer Repair, Across Southern California"
  subtitle="Upright LRTLS, chest LROFC. Linear Compressor + 10-year Rosen warranty verification, defrost system, door gasket, fan motors, Smart ThinQ. $89 diagnostic, applied toward repair."
  heroImageTitle="LG Freezer Repair"
  showBranches={true}
/>

<!-- 01 INTRO -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">01, About this service</p>
    <h2 class="section-title">LG stand-alone freezers and the Linear Compressor warranty.</h2>

    <p>LG Electronics is most visible in the US refrigeration market for its French Door and side-by-side full refrigerators, but the brand also produces stand-alone upright freezers (LRTLS series) and chest freezers (LROFC series). These are smaller-volume segments than LG's mainline refrigeration, but the underlying engineering, Inverter Linear Compressor on certain models, Smart ThinQ connectivity on newer SKUs, LG control architecture, is shared with the larger refrigeration platform.</p>

    <p>The most consequential thing to know about LG freezer service is the <strong>10-year Linear Compressor warranty extension</strong> from the Rosen v. LG class action settlement. Millions of LG refrigerators and some freezers built with the Linear Compressor are covered for parts and labor on that specific component for 10 years from purchase. Before any out-of-pocket compressor repair on an LG freezer, we verify model, serial, and manufacture date to determine warranty status. We don't profit from work that's already covered. <a href="/brands/lg-refrigerator-repair/">Brand hub</a> covers LG's full appliance lineup including refrigeration, washers, dryers, ovens, and dishwashers; this page is freezer-specific.</p>
  </div>
</section>

<!-- 02 COMMON FAILURES -->
<section class="section section-gray">
  <div class="container">
    <p class="section-number">02, Common failures</p>
    <h2 class="section-title">What we diagnose most often on LG freezers.</h2>

    <div class="problem-grid">
      <div class="problem-card">
        <h3>Linear Compressor failure (warranty check first)</h3>
        <p>Click-buzz-click failure pattern, often paired with CF, CHE, or Er rF codes on networked LG units. On units under 10 years from manufacture date, this is typically a Rosen-settlement covered repair through LG, part and labor covered. We verify warranty status from the model and serial tag before quoting any out-of-pocket compressor work. Compressor replacements on units outside warranty run $585-$880 in the sealed-system band.</p>
      </div>
      <div class="problem-card">
        <h3>Garage ambient temperature stress (July-August)</h3>
        <p>Most consumer-grade LG freezers are spec'd for ambient up to 95-100°F. Unconditioned LA garages routinely hit 105-115°F in summer afternoons. The compressor runs continuously, condenser can't keep up, interior temps drift above 0°F. We see units recover when ambient drops in October. Structural fix is a garage-rated LG model, some LRTLS uprights carry the spec, not a repair on a unit working at the limit of its envelope.</p>
      </div>
      <div class="problem-card">
        <h3>Defrost system failure (auto-defrost models)</h3>
        <p>Frost-free LG freezers run a scheduled defrost cycle to clear evaporator coil ice. When the defrost heater, thermostat, or sensor fails, ice accumulates until airflow is blocked. Symptoms: heavy frost on the rear interior wall, items at the back not staying frozen while front items are fine. $185-$345 replacement depending on which component failed.</p>
      </div>
      <div class="problem-card">
        <h3>Door seal compression loss</h3>
        <p>Year 7-12 service item. Gasket compresses, dries, and stops sealing. Symptom: condensation around the door frame, freezer running more than it should, energy bill creeping up. Replacement $180-$280. Coastal installations (Newport Beach, Manhattan Beach, Malibu, Pacific Palisades) see gasket wear faster from salt-air exposure than inland units.</p>
      </div>
    </div>
  </div>
</section>

<!-- 03 MODELS -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">03, LG freezer models we service</p>
    <h2 class="section-title">Upright LRTLS, chest LROFC, garage-rated variants.</h2>

    <p><strong>Upright (LRTLS series):</strong> LRTLS2403S, LRTLS2403W, stand-alone upright frost-free freezers in the 13-17 cu ft range, electronic temperature control, optional Smart ThinQ on newer models. Common service: defrost system, door gasket, evaporator fan, thermostat, control board.</p>

    <p><strong>Chest (LROFC series):</strong> LROFC1715V, manual-defrost chest freezer in 17 cu ft. Mechanically simple, long service life. Common service: door gasket, thermostat, light, drain plug.</p>

    <p><strong>Smart ThinQ-enabled units:</strong> Newer LG freezers with Wi-Fi connectivity expose temperature alerts and door-open warnings to the LG ThinQ mobile app. Connectivity faults are a documented service category, typically resolved at the router level (Wi-Fi password change, signal strength) rather than the freezer itself, but we diagnose during the service visit.</p>

    <p><strong>Garage-rated variants:</strong> Some LRTLS upright LG freezers carry a "garage ready" spec on the data plate, wider ambient operating range. We confirm spec from the model and serial tag before recommending repair-vs-replace on a marginal-ambient install. If your current unit isn't garage-rated and the garage ambient is the root cause of the issue, replacement to a garage-rated model usually pays for itself in compressor longevity within 3-4 summers.</p>
  </div>
</section>

<!-- 04 PRICING -->
<section class="section section-gray">
  <div class="container">
    <p class="section-number">04, Pricing</p>
    <h2 class="section-title">LG freezer repair pricing.</h2>

    <p class="lead">Diagnostic is $89, applied toward the repair when you approve work. Linear Compressor failures on units under 10 years from manufacture are typically covered by LG warranty, we verify before quoting any out-of-pocket sealed-system work.</p>

    <div class="pricing-grid">
      <div class="price-card">
        <div class="price-label">Diagnostic</div>
        <div class="price-amount">$89</div>
        <div class="price-desc">Waived when you approve repair</div>
      </div>
      <div class="price-card">
        <div class="price-label">Standard band</div>
        <div class="price-amount">$145–$285</div>
        <div class="price-desc">Thermostat · door gasket · alarm · light</div>
      </div>
      <div class="price-card">
        <div class="price-label">Defrost / fan motors</div>
        <div class="price-amount">$245–$385</div>
        <div class="price-desc">Defrost heater · evaporator or condenser fan</div>
      </div>
      <div class="price-card">
        <div class="price-label">Sealed-system</div>
        <div class="price-amount">$585–$880</div>
        <div class="price-desc">Refrigerant work · compressor (out of warranty)</div>
      </div>
    </div>

    <p class="price-note">Main control board replacement $345-$525. Smart ThinQ connectivity diagnostics typically resolve at the network layer (Wi-Fi password / signal) at no parts cost. We verify Linear Compressor warranty status before any quote that would involve compressor work.</p>
  </div>
</section>

<!-- 05 FAQ -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">05, FAQ</p>
    <h2 class="section-title">LG freezer repair, common questions.</h2>

    <div class="faq-list">
      {faqs.map((f) => (
        <details class="faq-item">
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- 06 BOTTOM CTA -->
<section class="bottom-cta">
  <div class="container">
    <h2>LG freezer down? Same-day service across Southern California.</h2>
    <p>$89 diagnostic, applied toward the repair. Upright, chest, garage-rated, Linear Compressor warranty verification on every quote.</p>
    <div class="cta-row">
      <a href={phoneHref} class="btn-primary">☎ Call {phone}</a>
      <a href="/contact/" class="btn-secondary">Book Online</a>
    </div>
  </div>
</section>

</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .section { padding: 72px 24px; }
  .section-gray { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; }
  .container.narrow { max-width: 820px; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  h2.section-title { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; margin: 0 0 20px; line-height: 1.2; color: var(--text); }
  .lead { font-size: 1.05rem; line-height: 1.75; color: var(--text); margin-bottom: 20px; }
  .section p { margin: 0 0 18px; font-size: 1rem; line-height: 1.75; color: var(--text); }
  .section a { color: var(--red); font-weight: 600; text-decoration: none; }
  .section a:hover { text-decoration: underline; }

  .problem-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-top: 32px; }
  .problem-card { background: #fff; border: 1px solid var(--border); border-left: 4px solid var(--red); border-radius: 6px; padding: 26px 28px; }
  .problem-card h3 { font-size: 1.1rem; font-weight: 800; margin: 0 0 12px; color: var(--text); }
  .problem-card p { font-size: 0.95rem; color: var(--text); margin: 0; line-height: 1.7; }
  @media (max-width: 768px) { .problem-grid { grid-template-columns: 1fr; } }

  .pricing-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-top: 32px; }
  .price-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 26px 22px; text-align: center; }
  .price-card .price-label { font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--muted); margin-bottom: 10px; font-weight: 700; }
  .price-card .price-amount { font-size: 1.85rem; font-weight: 800; color: var(--text); line-height: 1; margin-bottom: 10px; }
  .price-card .price-desc { font-size: 0.85rem; color: var(--muted); line-height: 1.55; }
  .price-note { margin-top: 24px; font-size: 0.95rem; color: var(--text); line-height: 1.7; }

  .faq-list { margin-top: 32px; }
  .faq-item { background: #fff; border: 1px solid var(--border); border-radius: 6px; padding: 18px 22px; margin-bottom: 12px; }
  .faq-item summary { font-weight: 700; cursor: pointer; font-size: 1rem; color: var(--text); list-style: none; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::before { content: "+ "; color: var(--red); font-weight: 800; margin-right: 6px; }
  .faq-item[open] summary::before { content: "− "; }
  .faq-item p { font-size: 0.95rem; color: var(--text); line-height: 1.75; margin: 14px 0 0; }

  .bottom-cta { background: var(--black); color: #fff; padding: 72px 24px; text-align: center; }
  .bottom-cta h2 { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; margin: 0 0 16px; color: #fff; line-height: 1.25; }
  .bottom-cta p { color: #c9c9c9; margin: 0 0 30px; font-size: 1.02rem; line-height: 1.6; }
  .cta-row { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 16px 34px; border-radius: 5px; font-size: 1rem; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 16px 34px; border-radius: 5px; font-size: 1rem; font-weight: 600; text-decoration: none; border: 2px solid rgba(255,255,255,0.35); }
</style>
