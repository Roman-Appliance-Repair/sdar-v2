---
import Layout from '../../layouts/Layout.astro';
import BrandDetailPlaceholder from '../../components/BrandDetailPlaceholder.astro';

const title = "Frigidaire Dishwasher Repair Los Angeles | Same Day Service";
const description = "Expert Frigidaire dishwasher repair in Los Angeles. Same-day appointments, OEM parts, licensed technicians. Call (424) 325-0520.";
---

<Layout title={title} description={description}>
  <BrandDetailPlaceholder
    brandName="Frigidaire"
    brandSlug="frigidaire"
    category="Dishwasher"
    categorySlug="dishwasher-repair"
    hubUrl="/brands/frigidaire/"
  />
</Layout>
