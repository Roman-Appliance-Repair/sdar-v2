---
import Layout from '../../layouts/Layout.astro';
import BrandBranchesGrid from '../../components/BrandBranchesGrid.astro';
import { MAIN_PHONE, MAIN_PHONE_TEL } from '../../data/branches';

const title = "AGA Range Hood Repair | Southern California | British Enamel Heritage";
const description = "AGA range hood repair across Southern California — Classic + matched-AGA-cooker hoods. Shropshire England + Middleby US parts. $89 diagnostic. (424) 325-0520.";
const canonical = "https://samedayappliance.repair/brands/aga-range-hood-repair/";

const faqs = [
  {
    q: "AGA hood — who makes it and where are parts?",
    a: "AGA Rangemaster Group (<b>Telford Shropshire, England</b>; Middleby Corporation 2015+ parent) manufactures AGA cookers and AGA hoods under the same British family of brands that includes Rangemaster, Falcon, and La Cornue. The hood product line is coordinated to the AGA cooker aesthetic — cast iron, enamel-finish color coordination (Pewter, Dark Blue, Claret, British Racing Green, Cream, Black, and several bespoke colors). US service parts route through <b>Middleby Greenwood MS</b> 1-2 week on common components; specialty enamel + color-match items route back to Shropshire at 2-4 week typical lead."
  },
  {
    q: "What AGA range hood configurations show up in LA?",
    a: "<b>AGA Classic hood</b> matched to the AGA 3-oven / 4-oven / 5-oven cast-iron cooker (flagship heritage product) + <b>AGA City24 / City36 hood</b> matched to the smaller City60 + Elise ranges for smaller LA kitchens. Typically 600-900 CFM; halogen or LED task lighting. The hood carries AGA's enamel finish language matching the cooker body color — Pewter, Dark Blue, Claret, Cream, etc. Less common than the cooker itself; the cooker + hood + enamel-matched kitchen is the signature AGA aesthetic."
  },
  {
    q: "AGA hood service diagnostic — what do we actually fix?",
    a: "Standard AGA hood diagnostic: (1) variable-speed motor at 10-12 year mark; motor swap $340–$500; (2) control-switch assembly $360–$520 (AGA uses simpler switchgear than app-connected brands — mechanical + rotary control more common); (3) halogen transformer or LED driver $200–$320; (4) grease-filter latch $160–$240; (5) enamel-matched panel damage replacement 2-4 week Shropshire factory match lead + $400–$700+ depending on color + size. Mechanical simplicity is a service advantage for AGA — fewer electronic failure modes than app-connected peers."
  },
  {
    q: "What does AGA range hood repair cost in LA?",
    a: "Residential diagnostic $89 waived with repair. Typical AGA bands: motor $340–$500; control-switch $360–$520; halogen/LED $200–$320; grease-filter latch $160–$240; enamel-matched panel quoted individually 2-4 week lead. Premium luxury-tier service economics; AGA sits alongside La Cornue + Viking + Wolf on service pricing; British heritage + mechanical simplicity often makes repair economically sound well past the 15-year mark."
  },
  {
    q: "AGA vs La Cornue vs other European heritage brands?",
    a: "AGA (British cast-iron heritage since 1929 Dr. Gustaf Dalén — Swedish Nobel-laureate inventor) and <a href='/brands/la-cornue-range-hood-repair/'>La Cornue</a> (French handbuilt heritage since 1908) are the two top European heritage cooker brands with matched-hood programs. <a href='/brands/gaggenau-range-hood-repair/'>Gaggenau</a> is the German BSH ultra-luxury peer. For Italian pro-style matched-range-and-hood, see <a href='/brands/bertazzoni-range-hood-repair/'>Bertazzoni</a>, <a href='/brands/ilve-range-hood-repair/'>ILVE</a>, <a href='/brands/fulgor-milano-range-hood-repair/'>Fulgor Milano</a>."
  }
];

const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair — AGA Range Hood Service",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": canonical, "telephone": MAIN_PHONE_TEL, "priceRange": "$$$$"
  },
  { "@context": "https://schema.org", "@type": "Service", "serviceType": "AGA Range Hood Repair",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "description": "AGA range hood repair across LA — Classic + City enamel-matched hoods. Telford Shropshire England factory since 1929 Dr. Gustaf Dalén heritage. Middleby Greenwood MS US parts. $89 residential diagnostic waived with repair.",
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, waived with repair" } }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "AGA", "item": "https://samedayappliance.repair/brands/aga/" },
      { "@type": "ListItem", "position": 4, "name": "AGA Range Hood Repair", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">{schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}</Fragment>
  <div class="call-banner"><div class="wrap"><span>AGA range hood service?</span><a href={`tel:${MAIN_PHONE_TEL}`} class="phone-lg">{MAIN_PHONE}</a></div></div>

  <section class="hero"><div class="wrap">
    <div class="crumb"><a href="/">Home</a> › <a href="/brands/">Brands</a> › AGA › Range Hood Repair</div>
    <h1>AGA Range Hood Repair</h1>
    <p class="lede">AGA has built cookers at the Telford Shropshire factory since 1929 — a century of British cast-iron heritage that started with Swedish Nobel-laureate Dr. Gustaf Dalén. The hood product line (Classic, City24, City36) is color-matched to the AGA cooker in Pewter, Dark Blue, Claret, British Racing Green, Cream, Black, and bespoke options. Middleby Corporation (2015+ parent) distributes US service parts through Greenwood MS; specialty enamel ships from Shropshire. For LA — Brentwood, Pacific Palisades, Beverly Hills kitchens where the AGA cooker is the centerpiece. Same-day dispatch, $89 residential diagnostic waived with the repair.</p>
    <div class="hero-cta"><a href={`tel:${MAIN_PHONE_TEL}`} class="btn btn-primary">Call {MAIN_PHONE}</a><a href="#book" class="btn btn-ghost">Request a Visit</a></div>
    <ul class="hero-facts">
      <li><b>Telford Shropshire England since 1929</b> — British cast-iron heritage</li>
      <li><b>Classic + City24/36 enamel-matched hoods</b> — coordinated to AGA cooker color</li>
      <li><b>Middleby Greenwood MS US parts</b> — 1-2 week common; 2-4 week enamel specialty</li>
      <li><b>$89 residential diagnostic</b> — waived when you authorize the repair</li>
    </ul>
  </div></section>

  <BrandBranchesGrid />

  <section class="trust-bar"><div class="wrap"><span>CSLB #1138898 · Insured</span><span>Same-day in 5 SoCal counties</span><span>Residential diagnostic $89 · waived with repair</span></div></section>

  <section class="section"><div class="wrap">
    <h2>What AGA range hood repair costs in LA</h2>
    <table class="price-table">
      <tr><th>Service</th><th>Typical Range</th><th>Notes</th></tr>
      <tr><td>Residential diagnostic</td><td>$89</td><td>Waived with repair</td></tr>
      <tr><td>Variable-speed motor</td><td>$340 – $500</td><td>10-12 year service</td></tr>
      <tr><td>Control-switch assembly</td><td>$360 – $520</td><td>Mechanical + rotary signature</td></tr>
      <tr><td>Halogen transformer / LED driver</td><td>$200 – $320</td><td>Task lighting</td></tr>
      <tr><td>Grease-filter latch</td><td>$160 – $240</td><td>Interlock trigger</td></tr>
      <tr><td>Enamel-matched panel</td><td>Quoted</td><td>2-4 week Shropshire</td></tr>
    </table>
    <p class="small">Related: <a href="/brands/aga/">AGA brand hub</a> · <a href="/brands/aga-stove-repair/">AGA cooker / stove</a> · <a href="/brands/la-cornue-range-hood-repair/">La Cornue range hood (French peer)</a> · <a href="/services/range-hood-repair/">Range hood repair (service hub)</a> · <a href="/commercial/exhaust-hood-repair/">Commercial exhaust hood repair</a>. For commercial kitchen exhaust hood repair (restaurant/foodservice Captive-Aire, Halton scope), see the <a href="/commercial/exhaust-hood-repair/">commercial page</a> — different scope, different equipment.</p>
  </div></section>

  <section class="section alt"><div class="wrap narrow">
    <h2>AGA range hood repair — frequently asked</h2>
    {faqs.map(f => (<details class="faq"><summary>{f.q}</summary><p set:html={f.a}></p></details>))}
  </div></section>

  <section id="book" class="cta-bottom"><div class="wrap">
    <h2>AGA range hood service? Call the branch closest to your home.</h2>
    <p>Same-day appliance repair across Los Angeles, Orange, Ventura, San Bernardino, and Riverside counties. Residential diagnostic $89, waived with repair.</p>
  </div></section>
  <a href={`tel:${MAIN_PHONE_TEL}`} class="float-call" aria-label="Call now">☎ Call {MAIN_PHONE}</a>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  body { color: var(--text); } .wrap { max-width: 1200px; margin: 0 auto; padding: 0 24px; } .wrap.narrow { max-width: 820px; }
  h1 { font-size: 2.4rem; line-height: 1.15; margin: 12px 0 20px; color: var(--black); }
  h2 { font-size: 1.8rem; margin: 0 0 16px; color: var(--black); }
  p { line-height: 1.65; margin: 0 0 14px; }
  .call-banner { background: var(--red); color: #fff; padding: 10px 0; }
  .call-banner .wrap { display:flex; gap: 14px; align-items: center; justify-content: center; flex-wrap: wrap; }
  .call-banner .phone-lg { color:#fff; font-weight: 800; text-decoration: underline; font-size: 1.05rem; }
  .hero { background: var(--black); color: #fff; padding: 42px 0 56px; } .hero h1 { color: #fff; }
  .hero .lede { font-size: 1.06rem; color: #d7d7d7; max-width: 680px; }
  .hero .crumb { color: #9a9a9a; font-size: 0.85rem; margin-bottom: 6px; } .hero .crumb a { color: #c9c9c9; text-decoration: none; }
  .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; margin: 18px 0 24px; }
  .btn { display: inline-block; padding: 12px 20px; border-radius: 4px; text-decoration: none; font-weight: 700; }
  .btn-primary { background: var(--red); color: #fff; } .btn-ghost { background: transparent; color: #fff; border: 1px solid #fff; }
  .hero-facts { list-style: none; padding: 0; margin: 0; color: #c9c9c9; font-size: 0.95rem; }
  .hero-facts li { padding: 6px 0; border-top: 1px solid #222; } .hero-facts li:first-child { border-top: 0; }
  .trust-bar { background: var(--red); color: #fff; padding: 14px 0; }
  .trust-bar .wrap { display: flex; gap: 28px; flex-wrap: wrap; justify-content: center; font-size: 0.95rem; font-weight: 600; }
  .section { padding: 56px 0; } .section.alt { background: var(--gray); }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 14px; background: #fff; }
  .price-table th, .price-table td { text-align: left; padding: 11px 12px; border-bottom: 1px solid var(--border); }
  .price-table th { background: var(--black); color: #fff; font-weight: 700; font-size: 0.95rem; }
  .small { color: var(--muted); font-size: 0.92rem; margin-top: 12px; }
  .faq { background: #fff; border: 1px solid var(--border); padding: 12px 16px; margin-bottom: 8px; border-radius: 4px; }
  .faq summary { font-weight: 700; cursor: pointer; padding: 4px 0; } .faq p { margin: 8px 0 0; }
  .cta-bottom { background: var(--black); color: #fff; padding: 48px 0; } .cta-bottom h2 { color: #fff; } .cta-bottom p { color: #c9c9c9; }
  .float-call { position: fixed; bottom: 18px; right: 18px; background: var(--red); color: #fff; padding: 14px 18px; border-radius: 40px; text-decoration: none; font-weight: 700; box-shadow: 0 6px 18px rgba(0,0,0,0.28); z-index: 50; font-size: 0.95rem; }
  @media (max-width: 820px) { h1 { font-size: 1.9rem; } .float-call { padding: 11px 14px; font-size: 0.88rem; } .trust-bar .wrap { gap: 14px; font-size: 0.85rem; } }
</style>
