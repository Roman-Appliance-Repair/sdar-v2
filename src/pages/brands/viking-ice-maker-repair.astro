---
import Layout from '../../layouts/Layout.astro';
import BrandBranchesGrid from '../../components/BrandBranchesGrid.astro';
import { MAIN_PHONE, MAIN_PHONE_TEL } from '../../data/branches';

const title = "Viking Ice Maker Repair | Southern California | VUIM + 7-Series Integrated";
const description = "Viking ice maker repair across Southern California — VUIM5240 undercounter + 7-Series VIFH/VUIM column integrated. Middleby Greenwood MS 2002+. Tuscany bar-station. $89 diagnostic. (424) 325-0520.";
const canonical = "https://samedayappliance.repair/brands/viking-ice-maker-repair/";

const faqs = [
  {
    q: "Which Viking ice makers are most common in LA?",
    a: "<b>VUIM5240 + VUIM5220</b> 5-Series undercounter (15\" + 24\" formats) anchor the Viking standalone ice maker lineup — common in Tuscany Collection bar-station and outdoor-kitchen builds. <b>7-Series VIFH + VUIM column integrated</b> ice makers pair with 648/630 Viking column refrigerators in luxury-kitchen suite configurations. Viking Professional 5-Series + Tuscany Collection variants cover specialty formats. All route through Middleby Greenwood MS parts distribution (4-6 day typical lead). LA installs concentrate in Bel Air + Beverly Hills + Pacific Palisades + Malibu + Montecito luxury outdoor-kitchen + bar-station contexts."
  },
  {
    q: "Viking ice maker no-ice diagnostic?",
    a: "Standalone VUIM diagnostic: (1) water-inlet valve $240–$360; (2) condenser coil cleaning (undercounter + outdoor installs especially) $160–$260; (3) evaporator plate cleaning / harvest valve $280–$420; (4) compressor start relay $200–$320; (5) ice-thickness probe $240–$360; (6) control board $480–$680. Column-integrated 7-Series VIFH/VUIM uses refrigerator-sibling parts chain. Middleby parts 4-6 day typical; our techs carry common Viking service parts on the truck for single-visit resolution where possible."
  },
  {
    q: "Outdoor-kitchen Viking ice maker service — different approach?",
    a: "Yes. LA outdoor-kitchen Viking installs (Tuscany bar-package VUIM5240 + WR48GSLP commercial-style refrigerator combos common in Malibu / Pacific Palisades / Bel Air estates) see condenser coil dust accumulation + ambient-heat stress from outdoor exposure. Service cycle: condenser cleaning every 12-18 months vs 24-36 months for indoor installs; insulation + gasket inspection more frequent; UV-exposure panel finish check. Outdoor-kitchen service uses same parts chain but higher preventive-maintenance frequency."
  },
  {
    q: "Is Viking residential ice maker same as commercial?",
    a: "No — Viking Residential ice makers and Viking Commercial are different product divisions under Middleby Corporation. Residential Tuscany + 5-Series + 7-Series ice makers use residential-grade refrigeration at residential scale (up to 80 lb/day VUIM). Viking Commercial is a separate Middleby commercial division serving restaurant / hospitality at production scale (200+ lb/day). For commercial ice machines see <a href='/commercial/ice-machine-repair/'>commercial ice machine repair</a> (Manitowoc / Hoshizaki / Scotsman / Follett). This page covers Viking residential only."
  },
  {
    q: "What does Viking ice maker repair cost in LA?",
    a: "Residential diagnostic $89 waived with repair. Typical Viking bands: water-inlet valve $240–$360; condenser cleaning $160–$260; evaporator plate service $280–$420; compressor start relay $200–$320; ice-thickness probe $240–$360; harvest valve $260–$400; control board $480–$680; door-seal gasket $200–$300; 7-Series column integrated modular swap $320–$480. Outdoor-kitchen installs add condenser cleaning more frequently than indoor. Viking parts 4-6 day typical through Middleby Greenwood MS distribution."
  }
];

const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair — Viking Ice Maker Service",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": canonical, "telephone": MAIN_PHONE_TEL, "priceRange": "$$$$"
  },
  { "@context": "https://schema.org", "@type": "Service", "serviceType": "Viking Ice Maker Repair",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "description": "Viking ice maker repair across LA — VUIM5240 / VUIM5220 undercounter, 7-Series VIFH / VUIM column integrated, Tuscany Collection bar-station. Middleby Greenwood MS 2002+. $89 residential diagnostic waived with repair.",
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, waived with repair" } }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "Viking", "item": "https://samedayappliance.repair/brands/viking/" },
      { "@type": "ListItem", "position": 4, "name": "Viking Ice Maker Repair", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">{schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}</Fragment>
  <div class="call-banner"><div class="wrap"><span>Viking ice maker service? Same-day across LA:</span><a href={`tel:${MAIN_PHONE_TEL}`} class="phone-lg">{MAIN_PHONE}</a></div></div>

  <section class="hero"><div class="wrap">
    <div class="crumb"><a href="/">Home</a> › <a href="/brands/">Brands</a> › Viking › Ice Maker Repair</div>
    <h1>Viking Ice Maker Repair</h1>
    <p class="lede">Viking residential ice makers (Middleby Corporation since 2002, Greenwood MS manufacturing) cover two primary formats: VUIM5240 / VUIM5220 undercounter standalone (common in Tuscany Collection bar-station and outdoor-kitchen builds) + 7-Series VIFH / VUIM column integrated (pairs with 648/630 Viking column refrigerators in luxury-kitchen suites). LA Viking ice maker installs concentrate in Bel Air + Beverly Hills + Pacific Palisades + Malibu + Montecito luxury estates with outdoor-kitchen or dedicated bar-station. Same-day dispatch, $89 residential diagnostic waived with the repair.</p>
    <div class="hero-cta"><a href={`tel:${MAIN_PHONE_TEL}`} class="btn btn-primary">Call {MAIN_PHONE}</a><a href="#book" class="btn btn-ghost">Request a Visit</a></div>
    <ul class="hero-facts">
      <li><b>Middleby since 2002, Greenwood MS</b> — residential division</li>
      <li><b>VUIM undercounter + 7-Series column</b> — two primary formats</li>
      <li><b>Tuscany bar-station common</b> — LA outdoor-kitchen luxury</li>
      <li><b>$89 residential diagnostic</b> — waived when you authorize the repair</li>
    </ul>
  </div></section>

  <BrandBranchesGrid />

  <section class="trust-bar"><div class="wrap"><span>CSLB #1138898 · Insured</span><span>Same-day in 5 SoCal counties</span><span>Residential diagnostic $89 · waived with repair</span></div></section>

  <section class="section"><div class="wrap narrow">
    <h2>Viking ice maker service in LA — luxury undercounter + column integrated</h2>
    <p>Viking residential ice makers fall into two LA installation patterns. Undercounter VUIM units live in bar-stations, outdoor kitchens, wine-cellars, and dedicated ice-service cabinets — typical locations: Malibu / Pacific Palisades estate bar-stations, Bel Air wine-cellar ice service, Beverly Hills home-theater bar-zones. Column-integrated 7-Series VIFH/VUIM units are part of comprehensive Viking kitchen suites pairing ice maker columns with refrigerator + freezer + wine-cellar columns. Service approach respects Tuscany + Brilliance color-finish integrity on outdoor-kitchen installs; parts chain through Middleby Greenwood MS is 4-6 day typical.</p>
  </div></section>

  <section class="section alt"><div class="wrap">
    <h2>Viking ice maker failures our techs see most often in LA</h2>
    <div class="fail-block"><h3>Water-inlet valve</h3><p>Valve $240–$360.</p></div>
    <div class="fail-block"><h3>Condenser coil cleaning (outdoor installs)</h3><p>Clean $160–$260. More frequent on outdoor-kitchen.</p></div>
    <div class="fail-block"><h3>Evaporator plate + harvest valve</h3><p>Plate service $280–$420; harvest valve $260–$400.</p></div>
    <div class="fail-block"><h3>Compressor start relay</h3><p>Relay $200–$320.</p></div>
    <div class="fail-block"><h3>Ice-thickness probe</h3><p>Probe $240–$360.</p></div>
    <div class="fail-block"><h3>7-Series column integrated module swap</h3><p>Column modular swap $320–$480.</p></div>
  </div></section>

  <section class="section"><div class="wrap">
    <h2>Viking ice maker product lines we service</h2>
    <div class="model-grid">
      <div class="model-card"><h3>VUIM5240 (24" undercounter)</h3><p>Standalone 24" undercounter. Tuscany bar-station common in LA.</p></div>
      <div class="model-card"><h3>VUIM5220 (15" undercounter)</h3><p>Compact 15" undercounter. Bar-station + outdoor-kitchen.</p></div>
      <div class="model-card"><h3>7-Series VIFH column integrated</h3><p>Pairs with 648/630 Viking column refrigerators. Flake-ice variant.</p></div>
      <div class="model-card"><h3>7-Series VUIM column integrated</h3><p>Cube ice column variant.</p></div>
      <div class="model-card"><h3>Tuscany Collection bar-package</h3><p>WR48GSLP + VUIM5240 combo. LA outdoor-kitchen signature.</p></div>
      <div class="model-card"><h3>Middleby Greenwood MS parts</h3><p>4-6 day typical lead.</p></div>
    </div>
  </div></section>

  <section class="section alt"><div class="wrap narrow">
    <h2>Viking residential vs Viking commercial</h2>
    <p>Viking Residential and Viking Commercial are separate Middleby divisions. Residential produces up to ~80 lb/day on VUIM; commercial serves restaurant production at 200+ lb/day through separate product line. See <a href="/commercial/ice-machine-repair/">commercial ice machine repair</a> for Manitowoc / Hoshizaki / Scotsman / Follett commercial production units.</p>
  </div></section>

  <section class="section"><div class="wrap">
    <h2>What Viking ice maker repair costs in LA</h2>
    <table class="price-table">
      <tr><th>Service</th><th>Typical Range</th><th>Notes</th></tr>
      <tr><td>Residential diagnostic</td><td>$89</td><td>Waived with repair</td></tr>
      <tr><td>Water-inlet valve</td><td>$240 – $360</td><td>VUIM + 7-Series</td></tr>
      <tr><td>Condenser coil cleaning</td><td>$160 – $260</td><td>More frequent outdoor</td></tr>
      <tr><td>Evaporator plate service</td><td>$280 – $420</td><td>Plate + harvest</td></tr>
      <tr><td>Harvest valve</td><td>$260 – $400</td><td>Hot-gas harvest cycle</td></tr>
      <tr><td>Compressor start relay</td><td>$200 – $320</td><td>Start circuit</td></tr>
      <tr><td>Ice-thickness probe</td><td>$240 – $360</td><td>Cycle trigger</td></tr>
      <tr><td>Control board</td><td>$480 – $680</td><td>Main control</td></tr>
      <tr><td>7-Series column modular swap</td><td>$320 – $480</td><td>Column-integrated</td></tr>
      <tr><td>Door-seal gasket</td><td>$200 – $300</td><td>Cavity integrity</td></tr>
    </table>
    <p class="small">Related: <a href="/brands/viking/">Viking brand hub</a> · <a href="/brands/viking-refrigerator-repair/">Viking refrigerator repair</a> · <a href="/brands/viking-stove-repair/">Viking stove repair</a> · <a href="/brands/sub-zero-ice-maker-repair/">Sub-Zero ice maker (luxury alt)</a> · <a href="/services/ice-maker-repair/">Ice maker repair (service hub)</a>.</p>
  </div></section>

  <section class="section alt"><div class="wrap">
    <h2>LA service areas</h2>
    <div class="area-grid">
      <div><h4>Bel Air + Beverly Hills</h4><p><a href="/beverly-hills/">Beverly Hills</a> · Bel Air · Holmby Hills</p></div>
      <div><h4>Pacific Palisades + Brentwood</h4><p>Pacific Palisades · Brentwood · Rustic Canyon</p></div>
      <div><h4>Malibu + outdoor-kitchen</h4><p><a href="/malibu/">Malibu</a> · Palos Verdes</p></div>
      <div><h4>Pasadena + San Marino</h4><p><a href="/pasadena/">Pasadena</a> · San Marino</p></div>
      <div><h4>Hollywood Hills</h4><p>Hollywood Hills · Laurel Canyon</p></div>
      <div><h4>OC ultra-luxury</h4><p>Newport Coast · Corona del Mar · <a href="/irvine/">Irvine</a></p></div>
    </div>
  </div></section>

  <section class="section"><div class="wrap narrow">
    <h2>Related Viking and luxury pages</h2>
    <ul class="related-links">
      <li><a href="/brands/viking/">Viking brand hub →</a></li>
      <li><a href="/brands/viking-refrigerator-repair/">Viking refrigerator repair →</a></li>
      <li><a href="/brands/viking-stove-repair/">Viking stove repair →</a></li>
      <li><a href="/brands/sub-zero-ice-maker-repair/">Sub-Zero ice maker repair →</a></li>
      <li><a href="/brands/thermador-ice-maker-repair/">Thermador ice maker repair →</a></li>
      <li><a href="/services/ice-maker-repair/">Ice maker repair (service hub) →</a></li>
      <li><a href="/price-list/ice-maker-repair-cost/">Ice maker repair cost guide →</a></li>
      <li><a href="/commercial/ice-machine-repair/">Commercial ice machine repair →</a></li>
    </ul>
  </div></section>

  <section class="section alt"><div class="wrap narrow">
    <h2>Viking ice maker repair — frequently asked</h2>
    {faqs.map(f => (<details class="faq"><summary>{f.q}</summary><p set:html={f.a}></p></details>))}
  </div></section>

  <section id="book" class="cta-bottom"><div class="wrap">
    <h2>Viking ice maker service? Call the branch closest to your home.</h2>
    <p>Same-day appliance repair in Los Angeles, Orange County, Ventura County. Residential diagnostic $89, waived with repair.</p>
  </div></section>
  <a href={`tel:${MAIN_PHONE_TEL}`} class="float-call" aria-label="Call now">☎ Call {MAIN_PHONE}</a>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  body { color: var(--text); } .wrap { max-width: 1200px; margin: 0 auto; padding: 0 24px; } .wrap.narrow { max-width: 820px; }
  h1 { font-size: 2.4rem; line-height: 1.15; margin: 12px 0 20px; color: var(--black); }
  h2 { font-size: 1.8rem; margin: 0 0 16px; color: var(--black); }
  h3 { font-size: 1.2rem; margin: 0 0 10px; color: var(--black); }
  h4 { font-size: 1.02rem; margin: 0 0 6px; color: var(--black); }
  p { line-height: 1.65; margin: 0 0 14px; }
  .call-banner { background: var(--red); color: #fff; padding: 10px 0; }
  .call-banner .wrap { display:flex; gap: 14px; align-items: center; justify-content: center; flex-wrap: wrap; }
  .call-banner .phone-lg { color:#fff; font-weight: 800; text-decoration: underline; font-size: 1.05rem; }
  .hero { background: var(--black); color: #fff; padding: 42px 0 56px; } .hero h1 { color: #fff; }
  .hero .lede { font-size: 1.06rem; color: #d7d7d7; max-width: 680px; }
  .hero .crumb { color: #9a9a9a; font-size: 0.85rem; margin-bottom: 6px; } .hero .crumb a { color: #c9c9c9; text-decoration: none; }
  .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; margin: 18px 0 24px; }
  .btn { display: inline-block; padding: 12px 20px; border-radius: 4px; text-decoration: none; font-weight: 700; }
  .btn-primary { background: var(--red); color: #fff; } .btn-ghost { background: transparent; color: #fff; border: 1px solid #fff; }
  .hero-facts { list-style: none; padding: 0; margin: 0; color: #c9c9c9; font-size: 0.95rem; }
  .hero-facts li { padding: 6px 0; border-top: 1px solid #222; } .hero-facts li:first-child { border-top: 0; }
  .trust-bar { background: var(--red); color: #fff; padding: 14px 0; }
  .trust-bar .wrap { display: flex; gap: 28px; flex-wrap: wrap; justify-content: center; font-size: 0.95rem; font-weight: 600; }
  .section { padding: 56px 0; } .section.alt { background: var(--gray); }
  .model-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 20px; margin-top: 24px; }
  .model-card { background: #fff; border: 1px solid var(--border); padding: 20px; border-radius: 6px; }
  .section.alt .model-card { background: #fff; }
  .fail-block { background: #fff; border-left: 3px solid var(--red); padding: 20px 22px; margin: 16px 0; }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 14px; background: #fff; }
  .price-table th, .price-table td { text-align: left; padding: 11px 12px; border-bottom: 1px solid var(--border); }
  .price-table th { background: var(--black); color: #fff; font-weight: 700; font-size: 0.95rem; }
  .small { color: var(--muted); font-size: 0.92rem; margin-top: 12px; }
  .area-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 18px; }
  .area-grid > div { background: #fff; border: 1px solid var(--border); padding: 16px; border-radius: 6px; }
  .related-links { list-style: none; padding: 0; } .related-links li { padding: 10px 0; border-bottom: 1px solid var(--border); }
  .related-links a { color: var(--red); font-weight: 600; text-decoration: none; } .related-links a:hover { text-decoration: underline; }
  .faq { background: #fff; border: 1px solid var(--border); padding: 12px 16px; margin-bottom: 8px; border-radius: 4px; }
  .faq summary { font-weight: 700; cursor: pointer; padding: 4px 0; } .faq p { margin: 8px 0 0; }
  .cta-bottom { background: var(--black); color: #fff; padding: 48px 0; } .cta-bottom h2 { color: #fff; } .cta-bottom p { color: #c9c9c9; }
  .float-call { position: fixed; bottom: 18px; right: 18px; background: var(--red); color: #fff; padding: 14px 18px; border-radius: 40px; text-decoration: none; font-weight: 700; box-shadow: 0 6px 18px rgba(0,0,0,0.28); z-index: 50; font-size: 0.95rem; }
  @media (max-width: 820px) { h1 { font-size: 1.9rem; } h2 { font-size: 1.45rem; } .float-call { padding: 11px 14px; font-size: 0.88rem; } .trust-bar .wrap { gap: 14px; font-size: 0.85rem; } }
</style>
