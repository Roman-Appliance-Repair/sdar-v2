---
import Layout from '../../layouts/Layout.astro';
import BrandHubPlaceholder from '../../components/BrandHubPlaceholder.astro';

const title = "Samsung Appliance Repair Los Angeles | Same Day Service";
const description = "Expert Samsung appliance repair across LA, Orange, Ventura counties. All Samsung categories — refrigerator, washer, dryer, dishwasher, range, microwave. Call (424) 325-0520.";

const categories = [
  { label: "Refrigerator", url: "/brands/samsung-refrigerator-repair/" },
  { label: "Washer", url: "/brands/samsung-washer-repair/" },
  { label: "Dryer", url: "/brands/samsung-dryer-repair/" },
  { label: "Dishwasher", url: "/brands/samsung-dishwasher-repair/" },
  { label: "Range", url: "/brands/samsung-range-repair/" },
  { label: "Microwave", url: "/brands/samsung-microwave-repair/" }
];
---

<Layout title={title} description={description}>
  <BrandHubPlaceholder brandName="Samsung" brandSlug="samsung" categories={categories} />
</Layout>
