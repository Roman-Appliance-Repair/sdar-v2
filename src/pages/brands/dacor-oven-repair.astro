      <div><h4>Orange County luxury</h4><p><a href="/irvine/">Irvine</a> · Newport Beach · Corona del Mar · Laguna Beach</p></div>
    </div>
  </div></section>

  <section class="section alt"><div class="wrap narrow">
    <h2>Related Dacor and Samsung-family pages</h2>
    <ul class="related-links">
