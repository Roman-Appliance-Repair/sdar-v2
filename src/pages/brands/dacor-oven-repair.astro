      <tr><td>Inner door glass</td><td>$325 – $445</td><td>Premium pane</td></tr>
      <tr><td>Main control board</td><td>$425 – $605</td><td>Samsung-platform shared</td></tr>
      <tr><td>Graphical touch display</td><td>$445 – $625</td><td>Modernist flagship</td></tr>
      <tr><td>Steam-assist reservoir service</td><td>$85 flat</td><td>Clean + reseal</td></tr>
      <tr><td>Reservoir replacement</td><td>$165 – $245</td><td>Cartridge assembly</td></tr>
      <tr><td>Steam injection valve</td><td>$195 – $285</td><td>Scale-damage swap</td></tr>
      <tr><td>LA hard-water steam descaling</td><td>$145 flat</td><td>Lighter than full Combi-Steam</td></tr>
      <tr><td>Samsung-platform Wi-Fi module</td><td>$265 – $385</td><td>SmartThings substitution</td></tr>
      <tr><td>Firmware update</td><td>$85 flat</td><td>Current-version refresh</td></tr>
