  { "@type": "Service", "serviceType": "Wood Stone Pizza Oven Repair", "provider": { "@id": canonical + "#business" }, "areaServed": "Los Angeles", "description": "Wood Stone commercial pizza oven repair across Los Angeles — Mt Adams hybrid wood-plus-gas deck, Fire Deck wood/gas/hybrid decks, Bistro smaller deck, Plancha open-fired grill, Stratos rotating deck. Independent family-owned, Bellingham Washington since 1989. LA Neapolitan-certified pizza cluster wood-fired standard." },
  { "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a.replace(/<[^>]+>/g, '') } })) },
