      <div><h4>OC luxury</h4><p>Newport Coast · Corona del Mar · Laguna Beach · <a href="/irvine/">Irvine</a></p></div>
    </div>
  </div></section>

  <section class="section"><div class="wrap narrow">
    <h2>Related Wolf and Sub-Zero Group pages</h2>
    <ul class="related-links">
      <li><a href="/brands/wolf-range-repair/">Wolf range repair →</a></li>
      <li><a href="/brands/wolf-cooktop-repair/">Wolf cooktop repair →</a></li>
      <li><a href="/brands/wolf-oven-repair/">Wolf oven repair →</a></li>
      <li><a href="/brands/sub-zero-refrigerator-repair/">Sub-Zero refrigerator repair (sibling) →</a></li>
      <li><a href="/brands/cove-dishwasher-repair/">Cove dishwasher repair (sibling) →</a></li>
      <li><a href="/brands/viking-stove-repair/">Viking stove repair (luxury alternative) →</a></li>
      <li><a href="/brands/thermador-stove-repair/">Thermador stove repair (BSH alternative) →</a></li>
      <li><a href="/services/stove-repair/">Stove repair (service hub) →</a></li>
      <li><a href="/price-list/stove-repair-cost/">Stove repair cost guide →</a></li>
    </ul>
  </div></section>

  <section class="section alt"><div class="wrap narrow">
    <h2>Wolf stove repair — frequently asked</h2>
    {faqs.map(f => (<details class="faq"><summary>{f.q}</summary><p set:html={f.a}></p></details>))}
