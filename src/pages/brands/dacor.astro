---
import Layout from '../../layouts/Layout.astro';
import BrandBranchesGrid from '../../components/BrandBranchesGrid.astro';
import { MAIN_PHONE, MAIN_PHONE_TEL } from '../../data/branches';

const title = "Dacor Appliance Repair | Southern California | Modernist · Contemporary · Discovery, Samsung Luxury Sub-Brand";
const description = "Dacor appliance repair across Southern California. Modernist (2016+), Contemporary transitional, Discovery legacy. Samsung-owned luxury kitchen brand. Factory-trained, BHGS #A49573, $89 diagnostic waived with repair. Same-day available. Call (424) 325-0520.";
const canonical = "https://samedayappliance.repair/brands/dacor/";

const faqs = [
  {
    q: "Is Dacor the same as Samsung now?",
    a: "Same parent since August 2016, distinct positioning. Samsung Electronics acquired Dacor and operates it as the luxury premium sub-brand, positioned against Viking, Wolf, and Thermador rather than against mainstream Samsung. Post-acquisition Modernist flagship (2016+) shares some control architecture and component chassis with upper-tier Samsung kitchen appliances, which gives us parts-chain reciprocity on shared components. Discovery-era units (pre-2016) use the legacy Dacor parts channel through Diamond Bar CA distribution, pre-acquisition chassis, different inventory depth, longer typical lead times. We identify generation at diagnostic before sourcing parts."
  },
  {
    q: "What Dacor appliances do you repair?",
    a: "Ranges, wall ovens, cooktops (gas, induction, electric, downdraft), range hoods, refrigerators (column built-in and freestanding), dishwashers, microwaves, and warming drawers. All three generations, Modernist (2016+ flagship), Contemporary (transitional 2012-2018), Discovery (pre-2016 legacy). Dacor doesn't make washers or dryers, they're a kitchen-appliance-only brand. For laundry, see Miele or Bosch."
  },
  {
    q: "Are you Dacor-authorized?",
    a: "Factory-trained but independent, same positioning we hold with Viking, Wolf, Thermador, Miele, and every other luxury brand. Dacor's in-warranty service routes through Samsung Home Appliance dispatch (post-2016 integration) at no parts cost, the right call during the base 1-year coverage. Post-warranty (year 2 and beyond) is where we operate. Most Dacor calls in our service area are 3-to-15-year-old units past the original warranty. Same factory training as authorized dispatch, faster response, lower labor rate."
  },
  {
    q: "How much does Dacor repair cost in LA?",
    a: "Diagnostic $89, waived with repair. Modernist (2016+) common service bands: thermal sensor $165-$235, bake element $275-$375, convection fan motor $295-$415, control board $425-$605, steam-assist water reservoir replacement $165-$245. Contemporary and Discovery generation parts run 15-30% above Modernist on legacy-specific components and add 5-10 day parts-lead time through the pre-Samsung Dacor channel. All parts and labor quoted before work starts. On 12-15+ year Discovery units we provide honest repair-vs-replace assessment rather than defaulting to costly repairs on aged electronics."
  }
];

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": canonical + "#business",
    "name": "Same Day Appliance Repair, Dacor Service",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": canonical,
    "telephone": MAIN_PHONE_TEL,
    "priceRange": "$$$$",
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Dacor Appliance Repair",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "description": "Dacor appliance repair across Southern California, ranges, ovens, cooktops, range hoods, refrigerators, dishwashers, microwaves. Modernist (2016+ post-Samsung), Contemporary transitional, Discovery pre-2016 legacy. Samsung Electronics-owned luxury premium sub-brand. Factory-trained, post-warranty specialists. $89 residential diagnostic waived with repair.",
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, waived with repair" } }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "Dacor", "item": canonical }
    ]
  }
];
---
<Layout title={title} description={description}>
  <Fragment slot="head-scripts">
    <link rel="canonical" href={canonical} />
    {schemaJsons.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </Fragment>

  <section class="hero">
    <div class="hero-inner">
      <div class="hero-content">
        <p class="hero-eyebrow">LA · Orange · Ventura · San Bernardino · Riverside Counties</p>
        <h1>Dacor Appliance Repair</h1>
        <p class="hero-sub">Factory-trained service on Dacor ranges, wall ovens, cooktops, range hoods, refrigerators, and dishwashers. All three generations, Modernist (2016+), Contemporary, and Discovery legacy. Samsung Electronics-owned luxury sub-brand. Same-day service available. $89 diagnostic waived with repair.</p>
        <div class="hero-ctas">
          <a href={`tel:${MAIN_PHONE_TEL}`} class="btn-primary">☎ {MAIN_PHONE}</a>
          <a href="/contact/" class="btn-outline">Book Online</a>
        </div>
      </div>
      <div class="hero-img-wrap">
        <div class="hero-img-placeholder">
          <p>Dacor Appliance Repair</p>
          <p>Across Southern California</p>
        </div>
      </div>
    </div>
  </section>

  <div class="trust-bar">
    <div class="trust-bar-inner">
      <div class="trust-item"><span class="trust-icon">🏅</span> BHGS Licensed #A49573</div>
      <div class="trust-item"><span class="trust-icon">❄</span> EPA 608 Universal (#1346255700410) Certified</div>
      <div class="trust-item"><span class="trust-icon">⚡</span> Same Day Available</div>
      <div class="trust-item"><span class="trust-icon">🔩</span> OEM Parts on Truck</div>
      <div class="trust-item"><span class="trust-icon">💬</span> $89 Diagnostic, Waived With Repair</div>
    </div>
  </div>

  <!-- ── ABOUT DACOR ── -->
  <section class="section">
    <div class="container narrow">
      <p class="eyebrow-sub">About Dacor service</p>
      <h2>Dacor appliance repair, Samsung's luxury kitchen sub-brand.</h2>
      <p>Dacor was founded in 1965 in Pasadena, California, originally as a high-end residential cooking-appliance maker positioned against Viking and Wolf. Samsung Electronics acquired Dacor in August 2016 and operates it as Samsung's luxury premium sub-brand, distinct from mainstream Samsung kitchen appliances and positioned at the Viking/Wolf/Thermador price tier rather than the GE/LG/Whirlpool mainstream tier.</p>
      <p>For service, the post-2016 platform integration is a practical advantage. Modernist (2016+ flagship) shares control architecture and select component chassis with upper-tier Samsung kitchen appliances, which means parts-chain reciprocity, faster sourcing on shared components, and meaningful cross-brand technical knowledge depth. Discovery-era units (pre-2016) use the legacy Dacor parts channel through Dacor's Diamond Bar CA distribution, a different supply chain with longer typical lead times and lower stock depth.</p>
      <p>Our techs identify Dacor generation at diagnostic before sourcing parts. Modernist runs current Samsung-shared parts-chain; Contemporary (transitional 2012-2018) is a mixed channel; Discovery is legacy pre-acquisition. This matters because parts lead time and labor approach differ materially between generations on the same nominal failure.</p>
    </div>
  </section>

  <!-- ── RANGES & OVENS ── -->
  <section class="section section-alt">
    <div class="container narrow">
      <p class="eyebrow-sub">Ranges and wall ovens</p>
      <h2>Dacor ranges and ovens, three generations, three parts channels.</h2>
      <p>Dacor's professional-style ranges and built-in wall ovens are the brand's flagship category and the bulk of our Dacor call volume. We service all configurations and generations.</p>
      <p><strong>Modernist (2016+ flagship)</strong>, current generation, pro-style stainless with premium build spec, graphical touchscreen displays, distinctive Dacor Modernist design language. Often specified in 30" and 48" wall oven configurations and 36"/48" pro-style ranges. Steam-assist on higher-tier models. Common service: thermal sensor (RTD), bake and broil elements, convection fan motor, main control board, graphical touch display, steam-assist water reservoir, Wi-Fi module (SmartThings substitution on shared-platform units).</p>
      <p><strong>Contemporary (transitional 2012-2018)</strong>, upgraded from Discovery but pre-full-Modernist refresh. Stainless with digital controls plus touchscreen on higher tiers. Mixed parts channel: some Samsung-compatible, some pre-acquisition Dacor-specific. Sensor and element parts typically 3-5 day lead; control boards and displays 5-10 day.</p>
      <p><strong>Discovery (pre-2016 legacy)</strong>, analog-style knobs and simpler control panels, model-number prefixes like EORS, DCO, RO, RNO depending on product type. Parts chain is pre-Samsung-acquisition with limited inventory depth. Most common service: thermal fuse, bake element, door gasket, hinge service. Control board failure on 12+ year Discovery sometimes runs 10-15 day sourcing through aftermarket cross-reference.</p>
      <p>Detailed pricing and procedures: see our <a href="/brands/dacor-oven-repair/">Dacor oven repair</a> page for built-in ovens and pro-style range ovens.</p>
    </div>
  </section>

  <!-- ── COOKTOPS & HOODS ── -->
  <section class="section">
    <div class="container narrow">
      <p class="eyebrow-sub">Cooktops and ventilation</p>
      <h2>Dacor cooktops, ranges, and range hoods.</h2>
      <p>Dacor cooktops cover gas sealed-burner, induction, electric ceramic, and downdraft-integrated configurations across 30", 36", and 48" widths. Service includes spark module and igniter replacement on gas, induction generator board service on induction tops, ceramic surface element replacement, and infinite switch service.</p>
      <p>Dacor range hoods include the Modernist line (touch controls, integrated lighting, designer finishes), Discovery legacy chimney-style hoods, and undercabinet configurations. Common service: blower motor replacement, control board service, LED panel replacement, damper actuator service. See our <a href="/brands/dacor-range-hood-repair/">Dacor range hood repair</a> page for ventilation-specific procedures.</p>
      <p>For Dacor refrigerators (column built-in and freestanding), dishwashers, and microwaves, we have category-specific pages: <a href="/brands/dacor-refrigerator-repair/">refrigerator repair</a>, <a href="/brands/dacor-dishwasher-repair/">dishwasher repair</a>, and <a href="/brands/dacor-microwave-repair/">microwave repair</a>. Dacor doesn't make laundry, so no washer or dryer service, kitchen-appliance-only brand.</p>
    </div>
  </section>

  <!-- ── MODELS WE SERVICE ── -->
  <section class="section section-alt">
    <div class="container narrow">
      <p class="eyebrow-sub">Models we service</p>
      <h2>Dacor models, by generation and product line.</h2>
      <p><strong>Modernist (2016+).</strong> 30" and 48" built-in wall ovens (DOP, DOC series), 36" and 48" pro-style ranges (DRR, DRG series), induction and gas cooktops, column refrigerators (DRZ, DRR series), Modernist Heritage dishwashers (DDW series), microwave drawers and combination wall ovens. Steam-assist on higher-tier wall ovens. SmartThings connectivity on Wi-Fi-equipped units.</p>
      <p><strong>Contemporary (2012-2018).</strong> Renaissance and Distinctive series transitional units. Wall ovens, cooktops, and select ranges, digital control upgrade from Discovery, pre-Modernist styling.</p>
      <p><strong>Discovery (pre-2016 legacy).</strong> EORS / DCO / RO / RNO prefix wall ovens, ER / SGM / RNRP series ranges, classic Discovery cooktops and downdraft systems. Heritage cooking ranges (HR series) from late-Discovery era. Many still in service across LA, original buyers held them well.</p>
      <p>Don't recognize your model number? Our techs identify generation at diagnostic from the prefix and finish, service approach and parts lead time depend on generation, not on the model name alone. Call (424) 325-0520 with the model number on your data plate (typically on the front frame or inside the door).</p>
    </div>
  </section>

  <!-- ── SERVICE AREAS ── -->
  <section class="section">
    <div class="container">
      <p class="eyebrow-sub">Where we work</p>
      <h2>Dacor service across Southern California</h2>
      <p>Dacor density is highest in Beverly Hills, Brentwood, Hollywood Hills, Bel Air, Pacific Palisades, Hancock Park, Pasadena, San Marino, Sherman Oaks, Encino, Calabasas, and Malibu on the LA side; Newport Coast, Newport Beach, Pelican Hill, and Coto de Caza in Orange County; Westlake Village, Thousand Oaks, and Hidden Hills in Ventura County; and Rancho Cucamonga and Temecula wine-country in the Inland Empire. Strong concentration of Discovery-era Dacor in Pasadena and San Marino specifically (Dacor's original Pasadena hometown, many original buyers still in those homes). Modernist density is strongest in 2016+ luxury renovations across Newport Coast, Brentwood, and Sherman Oaks. Eight service territories cover all five counties with same-day availability.</p>
      <BrandBranchesGrid showHeader={false} />
    </div>
  </section>

  <!-- ── PRICING ── -->
  <section class="section section-alt">
    <div class="container narrow">
      <p class="eyebrow-sub">Pricing</p>
      <h2>Honest pricing, $89 diagnostic, waived with repair.</h2>
      <p>Residential diagnostic is $89 flat, waived when you authorize the repair. We quote all parts and labor before work starts. No surprise charges, no upsell pressure.</p>
      <p>Modernist (2016+) common service bands: thermal sensor $165-$235, bake element $275-$375, convection fan motor $295-$415, main control board $425-$605, graphical touch display $445-$625, steam-assist water reservoir replacement $165-$245, steam injection valve $195-$285, hard-water steam descaling $145 flat, SmartThings Wi-Fi module $265-$385, firmware update $85 flat.</p>
      <p>Contemporary and Discovery generation parts run 15-30% above Modernist on legacy-specific components, counter-intuitive to the usual newer-is-more-expensive pattern, but Discovery parts command a premium because of lower stock and pre-Samsung supply chain. Add 5-10 day parts-lead on legacy-specific items.</p>
      <p>On 12-15+ year Discovery units with multi-component failure, we provide honest repair-vs-replace assessment. We'd rather lose the repair revenue and keep your trust than sell you work that doesn't pencil out.</p>
    </div>
  </section>

  <!-- ── FAQ ── -->
  <section class="section">
    <div class="container narrow">
      <p class="eyebrow-sub">FAQ</p>
      <h2>Common Dacor questions</h2>

      {faqs.map((f) => (
        <details class="faq">
          <summary>{f.q}</summary>
          <p set:html={f.a} />
        </details>
      ))}
    </div>
  </section>

  <!-- ── BOTTOM CTA ── -->
  <section class="bottom-cta">
    <div class="container">
      <h2>Ready to schedule Dacor service?</h2>
      <p>Same day available. $89 diagnostic, waived with repair. Labor and parts quoted before we start.</p>
      <div class="hero-ctas">
        <a href={`tel:${MAIN_PHONE_TEL}`} class="btn-primary">☎ Call {MAIN_PHONE}</a>
        <a href="/contact/" class="btn-outline">Book Online</a>
      </div>
    </div>
  </section>

<style>
  :root {
    --red: #C8102E;
    --black: #0a0a0a;
    --gray: #f5f5f5;
    --border: #e2e2e2;
    --text: #1a1a1a;
    --muted: #6b6b6b;
    --white: #ffffff;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; color: var(--text); line-height: 1.6; }

  .hero { background: var(--black); color: #fff; padding: 80px 24px 72px; }
  .hero-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; max-width: 1100px; margin: 0 auto; align-items: center; }
  .hero-eyebrow { font-size: 13px; color: var(--red); text-transform: uppercase; letter-spacing: .12em; margin-bottom: 16px; font-weight: 600; }
  .hero h1 { font-size: clamp(28px, 4vw, 46px); font-weight: 700; color: #fff; margin-bottom: 20px; line-height: 1.15; font-family: 'Playfair Display', Georgia, serif; }
  .hero-sub { font-size: 17px; color: rgba(255,255,255,.72); margin-bottom: 28px; }
  .hero-ctas { display: flex; gap: 12px; margin-bottom: 28px; flex-wrap: wrap; }
  .btn-primary { display: inline-block; padding: 14px 28px; background: var(--red); color: #fff; text-decoration: none; border-radius: 6px; font-weight: 600; font-size: 16px; transition: background .2s; }
  .btn-primary:hover { background: #a50d25; }
  .btn-outline { display: inline-block; padding: 14px 28px; border: 1.5px solid rgba(255,255,255,.35); color: #fff; text-decoration: none; border-radius: 6px; font-weight: 600; font-size: 16px; transition: all .2s; }
  .btn-outline:hover { background: rgba(255,255,255,.08); border-color: #fff; }
  .hero-img-wrap { aspect-ratio: 4/3; background: #1a1a1a; border-radius: 4px; display: flex; align-items: center; justify-content: center; }
  .hero-img-placeholder { color: rgba(255,255,255,.35); font-size: 14px; text-align: center; }
  @media (max-width: 768px) { .hero-inner { grid-template-columns: 1fr; } .hero-img-wrap { display: none; } }

  .trust-bar { background: var(--red); color: #fff; padding: 16px 24px; }
  .trust-bar-inner { max-width: 1100px; margin: 0 auto; display: flex; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
  .trust-item { font-size: 13px; font-weight: 600; display: flex; align-items: center; gap: 8px; }
  .trust-icon { font-size: 16px; }

  .section { padding: 72px 24px; }
  .section-alt { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; }
  .container.narrow { max-width: 780px; }
  .eyebrow-sub { font-size: 13px; color: var(--red); text-transform: uppercase; letter-spacing: .12em; margin-bottom: 12px; font-weight: 600; }
  h2 { font-size: clamp(24px, 3vw, 34px); font-weight: 700; margin-bottom: 20px; line-height: 1.2; font-family: 'Playfair Display', Georgia, serif; }
  .section p { margin-bottom: 16px; color: var(--text); }
  .section p a { color: var(--red); text-decoration: underline; }

  .faq { margin-bottom: 12px; border: 1px solid var(--border); border-radius: 6px; padding: 16px 20px; background: #fff; }
  .faq summary { font-weight: 600; cursor: pointer; font-size: 16px; color: var(--black); }
  .faq[open] summary { margin-bottom: 12px; }
  .faq p { font-size: 15px; color: var(--text); margin-bottom: 0; }
  .faq p :global(b) { color: var(--black); }

  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { color: #fff; }
  .bottom-cta p { color: rgba(255,255,255,.72); margin-bottom: 24px; }
  .bottom-cta .hero-ctas { justify-content: center; }
</style>
</Layout>
