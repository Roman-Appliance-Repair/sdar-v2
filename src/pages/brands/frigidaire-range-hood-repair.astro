---
import Layout from '../../layouts/Layout.astro';
import BrandBranchesGrid from '../../components/BrandBranchesGrid.astro';
import { MAIN_PHONE, MAIN_PHONE_TEL } from '../../data/branches';

const title = "Frigidaire Range Hood Repair | Southern California | FGBD + FHWC Electrolux";
const description = "Frigidaire range hood repair across Southern California — FGBD Gallery + FHWC under-cabinet + chimney wall. Electrolux 1986+ parts. $89 diagnostic. (424) 325-0520.";
const canonical = "https://samedayappliance.repair/brands/frigidaire-range-hood-repair/";

const faqs = [
  {
    q: "What Frigidaire range hood models are most common in LA?",
    a: "<b>FGBD Gallery</b> (premium sub-tier) + <b>FHWC under-cabinet + chimney wall</b> (standard tier) cover the Frigidaire residential range hood lineup. 30-36 inch format; 200-600 CFM typical. LED lighting standard on current-production units. Ductless recirculation option on most models for LA condo / apartment installs where exterior ducting isn't practical."
  },
  {
    q: "Is Frigidaire the same as Electrolux?",
    a: "Frigidaire is the North American value + mid-market brand under <b>Electrolux AB</b> Swedish parent since 1986. Residential Frigidaire and Electrolux-branded residential share engineering + parts. Important disambig: <b>Electrolux Professional</b> is a SEPARATE commercial brand (EPRO 2020 Nasdaq spin-off) — not related to Frigidaire residential. For commercial kitchen exhaust hoods, see <a href='/commercial/exhaust-hood-repair/'>commercial exhaust hood repair</a>."
  },
  {
    q: "Frigidaire range hood motor or control fault — diagnostic?",
    a: "Standard Electrolux-family diagnostic: (1) variable-speed motor at 10-15 year mark; motor swap $220–$360; (2) control-switch $80–$160; (3) LED driver $100–$200; (4) grease-filter latch $120–$200; (5) ductless charcoal filter $30–$80 every 6-12 months; (6) damper flap $120–$200. Electrolux Charlotte NC distribution 1-2 day LA-local."
  },
  {
    q: "What does Frigidaire range hood repair cost in LA?",
    a: "Residential diagnostic $89 waived with repair. Typical Frigidaire bands: variable-speed motor $220–$360; control-switch $80–$160; LED driver $100–$200; grease-filter latch $120–$200; ductless charcoal filter $30–$80; damper flap $120–$200; baffle-filter replacement $40–$80. Electrolux 1-2 day LA-local parts."
  },
  {
    q: "Frigidaire vs commercial exhaust?",
    a: "Frigidaire is residential-only. Electrolux Professional (EPRO commercial brand) is separate. For commercial kitchen exhaust (2000+ CFM Captive-Aire / Halton / Greenheck / Gaylord), see <a href='/commercial/exhaust-hood-repair/'>commercial exhaust hood repair</a>."
  }
];

const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair — Frigidaire Range Hood Service",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": canonical, "telephone": MAIN_PHONE_TEL, "priceRange": "$$"
  },
  { "@context": "https://schema.org", "@type": "Service", "serviceType": "Frigidaire Range Hood Repair",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "description": "Frigidaire range hood repair across LA — FGBD Gallery + FHWC under-cabinet + chimney wall. Electrolux AB Swedish parent since 1986; Charlotte NC parts chain. $89 residential diagnostic waived with repair.",
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, waived with repair" } }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "Frigidaire", "item": "https://samedayappliance.repair/brands/frigidaire/" },
      { "@type": "ListItem", "position": 4, "name": "Frigidaire Range Hood Repair", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">{schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}</Fragment>
  <div class="call-banner"><div class="wrap"><span>Frigidaire range hood service? Same-day across LA:</span><a href={`tel:${MAIN_PHONE_TEL}`} class="phone-lg">{MAIN_PHONE}</a></div></div>

  <section class="hero"><div class="wrap">
    <div class="crumb"><a href="/">Home</a> › <a href="/brands/">Brands</a> › Frigidaire › Range Hood Repair</div>
    <h1>Frigidaire Range Hood Repair</h1>
    <p class="lede">Frigidaire range hoods (FGBD Gallery + FHWC under-cabinet + chimney wall) represent Electrolux AB's North American value + mid-market brand ventilation lineup. Electrolux Charlotte NC distribution 1-2 day LA-local on parts. Electrolux Professional commercial brand (EPRO 2020 Nasdaq spin-off) is separate — residential Frigidaire only this page. Same-day dispatch, $89 residential diagnostic waived with the repair.</p>
    <div class="hero-cta"><a href={`tel:${MAIN_PHONE_TEL}`} class="btn btn-primary">Call {MAIN_PHONE}</a><a href="#book" class="btn btn-ghost">Request a Visit</a></div>
    <ul class="hero-facts">
      <li><b>Electrolux AB since 1986</b> — NA value + mid-market brand</li>
      <li><b>FGBD Gallery + FHWC standard</b> — 30-36 inch format</li>
      <li><b>Electrolux Professional separate</b> — EPRO commercial not this page</li>
      <li><b>$89 residential diagnostic</b> — waived when you authorize the repair</li>
    </ul>
  </div></section>

  <BrandBranchesGrid />

  <section class="trust-bar"><div class="wrap"><span>BHGS #A49573 · Insured</span><span>Same-day in 5 SoCal counties</span><span>Residential diagnostic $89 · waived with repair</span></div></section>

  <section class="section"><div class="wrap">
    <h2>What Frigidaire range hood repair costs in LA</h2>
    <table class="price-table">
      <tr><th>Service</th><th>Typical Range</th><th>Notes</th></tr>
      <tr><td>Residential diagnostic</td><td>$89</td><td>Waived with repair</td></tr>
      <tr><td>Variable-speed motor</td><td>$220 – $360</td><td>10-15 year service</td></tr>
      <tr><td>Control-switch</td><td>$80 – $160</td><td>Wall / rocker</td></tr>
      <tr><td>LED driver</td><td>$100 – $200</td><td>Task lighting</td></tr>
      <tr><td>Ductless charcoal filter</td><td>$30 – $80</td><td>6-12 month routine</td></tr>
      <tr><td>Grease-filter latch</td><td>$120 – $200</td><td>Interlock trigger</td></tr>
      <tr><td>Damper flap</td><td>$120 – $200</td><td>Anti-backdraft</td></tr>
      <tr><td>Baffle-filter replacement</td><td>$40 – $80</td><td>Per filter routine</td></tr>
    </table>
    <p class="small">Related: <a href="/brands/frigidaire/">Frigidaire brand hub</a> · <a href="/services/range-hood-repair/">Range hood repair (service hub)</a> · <a href="/price-list/range-hood-repair-cost/">Range hood repair cost guide</a> · <a href="/commercial/exhaust-hood-repair/">Commercial exhaust hood repair</a>.</p>
  </div></section>

  <section class="section alt"><div class="wrap narrow">
    <h2>Frigidaire range hood repair — frequently asked</h2>
    {faqs.map(f => (<details class="faq"><summary>{f.q}</summary><p set:html={f.a}></p></details>))}
  </div></section>

  <section id="book" class="cta-bottom"><div class="wrap">
    <h2>Frigidaire range hood service? Call the branch closest to your home.</h2>
    <p>Same-day appliance repair in Los Angeles, Orange County, Ventura County. Residential diagnostic $89, waived with repair.</p>
  </div></section>
  <a href={`tel:${MAIN_PHONE_TEL}`} class="float-call" aria-label="Call now">☎ Call {MAIN_PHONE}</a>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  body { color: var(--text); } .wrap { max-width: 1200px; margin: 0 auto; padding: 0 24px; } .wrap.narrow { max-width: 820px; }
  h1 { font-size: 2.4rem; line-height: 1.15; margin: 12px 0 20px; color: var(--black); }
  h2 { font-size: 1.8rem; margin: 0 0 16px; color: var(--black); }
  p { line-height: 1.65; margin: 0 0 14px; }
  .call-banner { background: var(--red); color: #fff; padding: 10px 0; }
  .call-banner .wrap { display:flex; gap: 14px; align-items: center; justify-content: center; flex-wrap: wrap; }
  .call-banner .phone-lg { color:#fff; font-weight: 800; text-decoration: underline; font-size: 1.05rem; }
  .hero { background: var(--black); color: #fff; padding: 42px 0 56px; } .hero h1 { color: #fff; }
  .hero .lede { font-size: 1.06rem; color: #d7d7d7; max-width: 680px; }
  .hero .crumb { color: #9a9a9a; font-size: 0.85rem; margin-bottom: 6px; } .hero .crumb a { color: #c9c9c9; text-decoration: none; }
  .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; margin: 18px 0 24px; }
  .btn { display: inline-block; padding: 12px 20px; border-radius: 4px; text-decoration: none; font-weight: 700; }
  .btn-primary { background: var(--red); color: #fff; } .btn-ghost { background: transparent; color: #fff; border: 1px solid #fff; }
  .hero-facts { list-style: none; padding: 0; margin: 0; color: #c9c9c9; font-size: 0.95rem; }
  .hero-facts li { padding: 6px 0; border-top: 1px solid #222; } .hero-facts li:first-child { border-top: 0; }
  .trust-bar { background: var(--red); color: #fff; padding: 14px 0; }
  .trust-bar .wrap { display: flex; gap: 28px; flex-wrap: wrap; justify-content: center; font-size: 0.95rem; font-weight: 600; }
  .section { padding: 56px 0; } .section.alt { background: var(--gray); }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 14px; background: #fff; }
  .price-table th, .price-table td { text-align: left; padding: 11px 12px; border-bottom: 1px solid var(--border); }
  .price-table th { background: var(--black); color: #fff; font-weight: 700; font-size: 0.95rem; }
  .small { color: var(--muted); font-size: 0.92rem; margin-top: 12px; }
  .faq { background: #fff; border: 1px solid var(--border); padding: 12px 16px; margin-bottom: 8px; border-radius: 4px; }
  .faq summary { font-weight: 700; cursor: pointer; padding: 4px 0; } .faq p { margin: 8px 0 0; }
  .cta-bottom { background: var(--black); color: #fff; padding: 48px 0; } .cta-bottom h2 { color: #fff; } .cta-bottom p { color: #c9c9c9; }
  .float-call { position: fixed; bottom: 18px; right: 18px; background: var(--red); color: #fff; padding: 14px 18px; border-radius: 40px; text-decoration: none; font-weight: 700; box-shadow: 0 6px 18px rgba(0,0,0,0.28); z-index: 50; font-size: 0.95rem; }
  @media (max-width: 820px) { h1 { font-size: 1.9rem; } .float-call { padding: 11px 14px; font-size: 0.88rem; } .trust-bar .wrap { gap: 14px; font-size: 0.85rem; } }
</style>
