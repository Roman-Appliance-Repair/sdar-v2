    "description": "Gaggenau built-in oven repair across LA — 400 Series flagship (Built-In Oven, Combi-Steam, Speed Microwave, Warming Drawer) + 200 Series entry tier. BSH Hausgeräte luxury brand, BSH Irvine CA parts chain for LA-local parts speed. Combi-Steam annual descaling service. $89 residential diagnostic waived with repair.",
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, waived with repair" } }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList",
