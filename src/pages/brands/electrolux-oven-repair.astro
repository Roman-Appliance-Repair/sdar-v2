    "description": "Electrolux oven repair across Southern California — LA, Orange, Ventura, San Bernardino, Riverside. single wall oven, double wall oven (38 imp GSC dedicated sub-demand), built-in single + microwave combo, Icon Professional pro-style tier, Smoothtop electric, gas oven. IQ-Touch capacitive control diagnostic, Perfect Temp Conversion, Luxury-Glide rack service. Swedish AB parent since 1986 Frigidaire acquisition. $89 residential diagnostic waived with repair.",
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, waived with repair" } }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList",
