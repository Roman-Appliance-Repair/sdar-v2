---
import Layout from '../../layouts/Layout.astro';
import BrandDetailPlaceholder from '../../components/BrandDetailPlaceholder.astro';

const title = "LG Dryer Repair Los Angeles | Same Day Service";
const description = "Expert LG dryer repair in Los Angeles. Same-day appointments, OEM parts, licensed technicians. Call (424) 325-0520.";
---

<Layout title={title} description={description}>
  <BrandDetailPlaceholder
    brandName="LG"
    brandSlug="lg"
    category="Dryer"
    categorySlug="dryer-repair"
    hubUrl="/brands/lg/"
  />
</Layout>
