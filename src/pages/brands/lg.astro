---
import Layout from '../../layouts/Layout.astro';
import BrandHubPlaceholder from '../../components/BrandHubPlaceholder.astro';

const title = "LG Appliance Repair Los Angeles | Same Day Service";
const description = "Expert LG appliance repair across LA, Orange, Ventura counties. All LG categories — refrigerator, washer, dryer, dishwasher, range, microwave, freezer. Call (424) 325-0520.";

const categories = [
  { label: "Refrigerator", url: "/brands/lg-refrigerator-repair/" },
  { label: "Washer", url: "/brands/lg-washer-repair/" },
  { label: "Dryer", url: "/brands/lg-dryer-repair/" },
  { label: "Dishwasher", url: "/brands/lg-dishwasher-repair/" },
  { label: "Range", url: "/brands/lg-range-repair/" },
  { label: "Microwave", url: "/brands/lg-microwave-repair/" },
  { label: "Freezer", url: "/brands/lg-freezer-repair/" }
];
---

<Layout title={title} description={description}>
  <BrandHubPlaceholder brandName="LG" brandSlug="lg" categories={categories} />
</Layout>
