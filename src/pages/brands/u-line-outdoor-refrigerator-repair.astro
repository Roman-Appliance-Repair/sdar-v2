---
import Layout from '../../layouts/Layout.astro';

const title = "U-Line Outdoor Refrigerator Repair LA | 1 Class · 2 Class Outdoor Refrigeration";
const description = "U-Line outdoor refrigerator repair LA — 1 Class + 2 Class outdoor undercounter, outdoor wine + beverage. UL-rated. $89 diagnostic. (424) 325-0520.";
const canonical = "https://samedayappliance.repair/brands/u-line-outdoor-refrigerator-repair/";

const faqs = [
  {
    "q": "1 Class vs 2 Class — what’s the difference?",
    "a": "2 Class is U-Line’s premium tier with stainless interior, soft-close doors, convection cooling, and digital touch controls. 1 Class is the standard tier. Both have outdoor variants."
  },
  {
    "q": "Is U-Line outdoor as durable as Sub-Zero outdoor?",
    "a": "Sub-Zero outdoor edges U-Line on coastal salt resistance and compressor lifespan. U-Line is excellent for inland installs (Hidden Hills, Calabasas) at 60-70% of the price."
  },
  {
    "q": "How much does U-Line outdoor refrigerator repair cost?",
    "a": "Diagnostic $89. Compressor relay $180–$240. Door gasket $260–$340. Evaporator fan $300–$420. Control board $440–$620. Refrigerant work $450–$750."
  }
];

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": "https://samedayappliance.repair/brands/u-line-outdoor-refrigerator-repair/#business",
    "name": "Same Day Appliance Repair",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": "https://samedayappliance.repair/brands/u-line-outdoor-refrigerator-repair/",
    "telephone": "+1-424-325-0520",
    "priceRange": "$$$",
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "U-Line Outdoor Refrigerator Repair",
    "provider": {
      "@id": "https://samedayappliance.repair/brands/u-line-outdoor-refrigerator-repair/#business"
    },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "description": "U-Line outdoor refrigerator repair LA — 1 Class + 2 Class outdoor undercounter, outdoor wine + beverage. UL-rated. $89 diagnostic. (424) 325-0520.",
    "offers": {
      "@type": "Offer",
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "89.00",
        "priceCurrency": "USD",
        "description": "Residential diagnostic fee, waived with repair"
      }
    }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://samedayappliance.repair/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Brands",
      "item": "https://samedayappliance.repair/brands/"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": "U-Line",
      "item": "https://samedayappliance.repair/brands/u-line/"
    },
    {
      "@type": "ListItem",
      "position": 4,
      "name": "Outdoor Refrigerator Repair",
      "item": "https://samedayappliance.repair/brands/u-line-outdoor-refrigerator-repair/"
    }
  ] }
];
---
<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">
    {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
  </Fragment>

  <section class="ph-hero">
    <div class="ph-wrap">
      <p class="ph-eyebrow">Placeholder · Content Coming Soon</p>
      <h1>U-Line Outdoor Refrigerator Repair in Los Angeles</h1>
      <p class="ph-intro">U-Line is the largest outdoor undercounter refrigeration specialist in the US — 1 Class and 2 Class outdoor variants in refrigerator, wine, beverage center, and ice maker configurations. UL-listed weather-rated compressor and cabinetry. Common alternative to Sub-Zero and Viking when budget or scope is more modest — Newport Beach, Manhattan Beach, Palos Verdes. We service the full U-Line outdoor lineup.</p>
      <div class="ph-ctas">
        <a href="tel:+14243250520" class="ph-btn">Call (424) 325-0520</a>
        <a href="/contact/" class="ph-btn ph-btn-ghost">Contact Us</a>
      </div>
    </div>
  </section>

  <section class="ph-faq">
    <div class="ph-wrap">
      <h2>Frequently Asked</h2>
      {faqs.map(f => (<details class="ph-detail"><summary>{f.q}</summary><p>{f.a}</p></details>))}
    </div>
  </section>
</Layout>

<style>
  .ph-wrap { max-width: 820px; margin: 0 auto; padding: 0 24px; }
  .ph-hero { background: #0a0a0a; color: #fff; padding: 64px 0; }
  .ph-eyebrow { color: #C8102E; font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.14em; margin: 0 0 14px; }
  .ph-hero h1 { font-size: clamp(1.6rem, 3.2vw, 2.4rem); font-weight: 800; margin: 0 0 16px; line-height: 1.2; }
  .ph-intro { color: rgba(255,255,255,0.85); font-size: 1.05rem; margin: 0 0 28px; line-height: 1.65; }
  .ph-ctas { display: flex; gap: 12px; flex-wrap: wrap; }
  .ph-btn { display: inline-block; background: #C8102E; color: #fff; padding: 12px 24px; text-decoration: none; font-weight: 700; border-radius: 4px; font-size: 0.95rem; }
  .ph-btn-ghost { background: transparent; border: 1px solid rgba(255,255,255,0.4); }
  .ph-faq { padding: 56px 0; background: #f5f5f5; }
  .ph-faq h2 { font-size: 1.5rem; margin: 0 0 20px; color: #0a0a0a; }
  .ph-detail { background: #fff; border: 1px solid #e2e2e2; padding: 14px 18px; border-radius: 4px; margin-bottom: 8px; }
  .ph-detail summary { font-weight: 600; cursor: pointer; color: #0a0a0a; }
  .ph-detail p { margin: 10px 0 0; color: #444; line-height: 1.6; }
</style>
