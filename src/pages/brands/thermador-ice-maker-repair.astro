---
import Layout from '../../layouts/Layout.astro';
import BrandBranchesGrid from '../../components/BrandBranchesGrid.astro';
import { MAIN_PHONE, MAIN_PHONE_TEL } from '../../data/branches';

const title = "Thermador Ice Maker Repair Los Angeles — Same Day";
const description = "Thermador ice maker repair across SoCal, T24IR / T24UI / T24IC Freedom Collection 24 inch integrated. BSH Irvine CA parts 1-2 day. $89 dx.";
const canonical = "https://samedayappliance.repair/brands/thermador-ice-maker-repair/";

const faqs = [
  {
    q: "What's Thermador Freedom Collection ice maker?",
    a: "<b>Freedom Collection</b> is Thermador's modular built-in refrigeration system, T24IR / T24UI / T24IC 24\" ice makers pair with Freedom Collection column refrigerator (T30IR/T36IR/T48IR) + wine column for full luxury kitchen suite. BSH engineering with Irvine CA parts warehouse (1-2 day LA-local parts, same advantage as Thermador stove / cooktop / refrigerator)."
  },
  {
    q: "Thermador ice maker no-ice diagnostic?",
    a: "T24 series diagnostic: (1) water-inlet valve $220–$340; (2) evaporator plate + harvest cycle $280–$420; (3) compressor start relay $200–$320; (4) ice-thickness probe $220–$340; (5) control board $460–$660; (6) Home Connect firmware update (app-side fix often resolves communication faults). BSH Irvine parts 1-2 day LA-local through authorized distribution."
  },
  {
    q: "Home Connect app not linking?",
    a: "Thermador Home Connect (BSH's smart-appliance ecosystem) ties T24 ice maker to remote monitoring. Fault path: (1) WiFi config (2.4GHz required); (2) app re-pair via Home Connect account; (3) firmware update; (4) communication module hardware $280–$420 only when confirmed. Conventional ice-making operates independently of Home Connect."
  },
  {
    q: "Thermador vs Sub-Zero vs Viking ice maker?",
    a: "Three luxury LA options. Thermador Freedom Collection uses BSH Irvine 1-2 day parts advantage + integrates with Bosch Benchmark column refrigerators. Sub-Zero uses Madison WI Sub-Zero Group parts + matched-suite with refrigerator + freezer + wine columns (see <a href='/brands/sub-zero-ice-maker-repair/'>Sub-Zero ice maker</a>). Viking uses Middleby Greenwood MS 4-6 day parts + Tuscany outdoor-kitchen positioning (see <a href='/brands/viking-ice-maker-repair/'>Viking ice maker</a>). All three are residential-only; none have commercial lines."
  },
  {
    q: "What does Thermador ice maker repair cost in LA?",
    a: "Residential diagnostic $89 waived with repair. Typical bands: water-inlet valve $220–$340; evaporator plate service $280–$420; compressor start relay $200–$320; ice-thickness probe $220–$340; control board $460–$660; Home Connect module $280–$420; condenser cleaning $140–$240; door-seal gasket $200–$300. BSH Irvine 1-2 day LA-local parts."
  },
  {
    q: "Thermador vs commercial ice machines?",
    a: "Thermador is residential-only. BSH no commercial ice line. For restaurant / commercial 200+ lb/day see <a href='/commercial/ice-machines/'>commercial ice machine repair</a>."
  }
];

const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair, Thermador Ice Maker Service",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": canonical, "telephone": MAIN_PHONE_TEL, "priceRange": "$$$$"
  },
  { "@context": "https://schema.org", "@type": "Service", "serviceType": "Thermador Ice Maker Repair",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "description": "Thermador ice maker repair across Southern California, LA, Orange, Ventura, San Bernardino, Riverside. T24IR / T24UI / T24IC Freedom Collection 24 inch integrated ice maker. BSH Hausgeräte Irvine CA parts warehouse (1-2 day LA-local). $89 residential diagnostic waived with repair.",
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, waived with repair" } }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "Thermador", "item": "https://samedayappliance.repair/brands/thermador/" },
      { "@type": "ListItem", "position": 4, "name": "Thermador Ice Maker Repair", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">{schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}</Fragment>
  <div class="call-banner"><div class="wrap"><span>Thermador ice maker service? Same-day across all 5 SoCal counties:</span><a href={`tel:${MAIN_PHONE_TEL}`} class="phone-lg">{MAIN_PHONE}</a></div></div>

  <section class="hero"><div class="wrap">
    <div class="crumb"><a href="/">Home</a> › <a href="/brands/">Brands</a> › Thermador › Ice Maker Repair</div>
    <h1>Thermador Ice Maker Repair</h1>
    <p class="lede">Thermador Freedom Collection ice makers (T24IR + T24UI + T24IC 24" integrated formats) are BSH Hausgeräte's luxury built-in solution, pairing with Freedom Collection column refrigerators (T30/T36/T48) + wine column for full luxury kitchen suites. BSH Irvine CA parts warehouse delivers 1-2 day LA-local parts on common components, the same LA-proximity advantage that applies to Thermador stoves + cooktops + refrigerators. Same-day dispatch, $89 residential diagnostic waived with the repair.</p>
    <div class="hero-cta"><a href={`tel:${MAIN_PHONE_TEL}`} class="btn btn-primary">Call {MAIN_PHONE}</a><a href="#book" class="btn btn-ghost">Request a Visit</a></div>
    <ul class="hero-facts">
      <li><b>BSH since 1998, Irvine parts 1-2 day</b>, LA-local advantage</li>
      <li><b>Freedom Collection T24</b>, integrates with column refrigerator / wine suite</li>
      <li><b>Home Connect app</b>, BSH smart-appliance ecosystem</li>
      <li><b>$89 residential diagnostic</b>, waived when you authorize the repair</li>
    </ul>
  </div></section>

  <BrandBranchesGrid />

  <section class="trust-bar"><div class="wrap"><span>BHGS #A49573 · Insured</span><span>Same-day in 5 SoCal counties</span><span>Residential diagnostic $89 · waived with repair</span></div></section>

  <section class="section"><div class="wrap narrow">
    <h2>Thermador ice maker service in LA, BSH Irvine parts advantage</h2>
    <p>Thermador Freedom Collection ice makers concentrate in LA luxury kitchen suites, Bel Air + Beverly Hills + Pacific Palisades remodels specifying full Thermador suite (column refrigerator + ice maker + wine column + cooktop + wall oven). The BSH Irvine CA parts warehouse is the defining service advantage: 1-2 day LA-local parts delivery on common T24 components vs 4-10 days on most luxury competitors. Our techs handle T24IR / T24UI / T24IC variants through BSH Irvine channel.</p>
  </div></section>

  <section class="section alt"><div class="wrap">
    <h2>Thermador ice maker failures our techs see most often</h2>
    <div class="fail-block"><h3>Water-inlet valve</h3><p>Valve $220–$340.</p></div>
    <div class="fail-block"><h3>Evaporator plate + harvest</h3><p>Plate service $280–$420.</p></div>
    <div class="fail-block"><h3>Compressor start relay</h3><p>Relay $200–$320.</p></div>
    <div class="fail-block"><h3>Ice-thickness probe</h3><p>Probe $220–$340.</p></div>
    <div class="fail-block"><h3>Home Connect firmware / connectivity</h3><p>WiFi config + app re-pair first; module $280–$420 only if confirmed.</p></div>
    <div class="fail-block"><h3>Condenser cleaning</h3><p>Clean $140–$240.</p></div>
  </div></section>

  <section class="section"><div class="wrap">
    <h2>Thermador ice maker product lines we service</h2>
    <div class="model-grid">
      <div class="model-card"><h3>T24IR Freedom Collection integrated</h3><p>24" ice room integrated. Column-kitchen pairing.</p></div>
      <div class="model-card"><h3>T24UI undercounter variant</h3><p>24" undercounter Freedom Collection.</p></div>
      <div class="model-card"><h3>T24IC column ice-only</h3><p>24" column dedicated ice. Pairs with refrigerator / wine columns.</p></div>
      <div class="model-card"><h3>Home Connect integration</h3><p>BSH smart-appliance ecosystem.</p></div>
      <div class="model-card"><h3>Bosch Benchmark pairing</h3><p>Freedom Collection cross-compatibility with Bosch premium.</p></div>
      <div class="model-card"><h3>BSH Irvine parts 1-2 day</h3><p>LA-local parts distribution advantage.</p></div>
    </div>
  </div></section>

  <section class="section alt"><div class="wrap narrow">
    <h2>Residential Thermador vs commercial ice machines</h2>
    <p>Thermador is residential-only, BSH has no commercial ice line. For restaurant / commercial 200+ lb/day see <a href="/commercial/ice-machines/">commercial ice machine repair</a>.</p>
  </div></section>

  <section class="section"><div class="wrap">
    <h2>What Thermador ice maker repair typically costs</h2>
    <table class="price-table">
      <tr><th>Service</th><th>Typical Range</th><th>Notes</th></tr>
      <tr><td>Residential diagnostic</td><td>$89</td><td>Waived with repair</td></tr>
      <tr><td>Water-inlet valve</td><td>$220 – $340</td><td>T24 series</td></tr>
      <tr><td>Evaporator plate service</td><td>$280 – $420</td><td>Plate + harvest</td></tr>
      <tr><td>Compressor start relay</td><td>$200 – $320</td><td>Start circuit</td></tr>
      <tr><td>Ice-thickness probe</td><td>$220 – $340</td><td>Cycle trigger</td></tr>
      <tr><td>Control board</td><td>$460 – $660</td><td>Main control</td></tr>
      <tr><td>Home Connect module</td><td>$280 – $420</td><td>Smart connectivity</td></tr>
      <tr><td>Condenser cleaning</td><td>$140 – $240</td><td>Airflow restoration</td></tr>
      <tr><td>Door-seal gasket</td><td>$200 – $300</td><td>Cavity integrity</td></tr>
    </table>
    <p class="small">Related: <a href="/brands/thermador-refrigerator-repair/">Thermador brand hub</a> · <a href="/brands/thermador-stove-repair/">Thermador stove repair</a> · <a href="/brands/gaggenau-ice-maker-repair/">Gaggenau ice maker (BSH sibling)</a> · <a href="/brands/sub-zero-ice-maker-repair/">Sub-Zero ice maker (column alt)</a>.</p>
  </div></section>

  <section class="section alt"><div class="wrap">
    <h2>LA service areas</h2>
    <div class="area-grid">
      <div><h4>Bel Air + Beverly Hills</h4><p><a href="/beverly-hills/">Beverly Hills</a> · Bel Air</p></div>
      <div><h4>Pacific Palisades + Brentwood</h4><p>Pacific Palisades · Brentwood</p></div>
      <div><h4>Pasadena + San Marino</h4><p><a href="/pasadena/">Pasadena</a> · San Marino</p></div>
      <div><h4>OC ultra-luxury (closest Irvine)</h4><p>Newport Coast · Corona del Mar · <a href="/irvine/">Irvine</a></p></div>
      <div><h4>Coastal luxury</h4><p><a href="/malibu/">Malibu</a> · Manhattan Beach</p></div>
      <div><h4>Hollywood Hills</h4><p>Hollywood Hills · Laurel Canyon</p></div>
    </div>
  </div></section>

  <section class="section"><div class="wrap narrow">
    <h2>Related Thermador and BSH-family pages</h2>
    <ul class="related-links">
      <li><a href="/brands/thermador-refrigerator-repair/">Thermador brand hub →</a></li>
      <li><a href="/brands/thermador-stove-repair/">Thermador stove repair →</a></li>
      <li><a href="/brands/gaggenau-ice-maker-repair/">Gaggenau ice maker (BSH sibling) →</a></li>
      <li><a href="/brands/sub-zero-ice-maker-repair/">Sub-Zero ice maker →</a></li>
      <li><a href="/brands/viking-ice-maker-repair/">Viking ice maker →</a></li>
      <li><a href="/services/ice-maker-repair/">Ice maker repair (service hub) →</a></li>
      <li><a href="/price-list/ice-maker-repair-cost/">Ice maker repair cost guide →</a></li>
      <li><a href="/commercial/ice-machines/">Commercial ice machine repair →</a></li>
    </ul>
  </div></section>

  <section class="section alt"><div class="wrap narrow">
    <h2>Thermador ice maker repair, frequently asked</h2>
    {faqs.map(f => (<details class="faq"><summary>{f.q}</summary><p set:html={f.a}></p></details>))}
  </div></section>

  <section id="book" class="cta-bottom"><div class="wrap">
    <h2>Thermador ice maker service? Call the branch closest to your home.</h2>
    <p>Same-day appliance repair across Los Angeles, Orange, Ventura, San Bernardino, and Riverside counties. Residential diagnostic $89, waived with repair.</p>
  </div></section>
  <a href={`tel:${MAIN_PHONE_TEL}`} class="float-call" aria-label="Call now">☎ Call {MAIN_PHONE}</a>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  body { color: var(--text); } .wrap { max-width: 1200px; margin: 0 auto; padding: 0 24px; } .wrap.narrow { max-width: 820px; }
  h1 { font-size: 2.4rem; line-height: 1.15; margin: 12px 0 20px; color: var(--black); }
  h2 { font-size: 1.8rem; margin: 0 0 16px; color: var(--black); }
  h3 { font-size: 1.2rem; margin: 0 0 10px; color: var(--black); }
  h4 { font-size: 1.02rem; margin: 0 0 6px; color: var(--black); }
  p { line-height: 1.65; margin: 0 0 14px; }
  .call-banner { background: var(--red); color: #fff; padding: 10px 0; }
  .call-banner .wrap { display:flex; gap: 14px; align-items: center; justify-content: center; flex-wrap: wrap; }
  .call-banner .phone-lg { color:#fff; font-weight: 800; text-decoration: underline; font-size: 1.05rem; }
  .hero { background: var(--black); color: #fff; padding: 42px 0 56px; } .hero h1 { color: #fff; }
  .hero .lede { font-size: 1.06rem; color: #d7d7d7; max-width: 680px; }
  .hero .crumb { color: #9a9a9a; font-size: 0.85rem; margin-bottom: 6px; } .hero .crumb a { color: #c9c9c9; text-decoration: none; }
  .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; margin: 18px 0 24px; }
  .btn { display: inline-block; padding: 12px 20px; border-radius: 4px; text-decoration: none; font-weight: 700; }
  .btn-primary { background: var(--red); color: #fff; } .btn-ghost { background: transparent; color: #fff; border: 1px solid #fff; }
  .hero-facts { list-style: none; padding: 0; margin: 0; color: #c9c9c9; font-size: 0.95rem; }
  .hero-facts li { padding: 6px 0; border-top: 1px solid #222; } .hero-facts li:first-child { border-top: 0; }
  .trust-bar { background: var(--red); color: #fff; padding: 14px 0; }
  .trust-bar .wrap { display: flex; gap: 28px; flex-wrap: wrap; justify-content: center; font-size: 0.95rem; font-weight: 600; }
  .section { padding: 56px 0; } .section.alt { background: var(--gray); }
  .model-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 20px; margin-top: 24px; }
  .model-card { background: #fff; border: 1px solid var(--border); padding: 20px; border-radius: 6px; }
  .section.alt .model-card { background: #fff; }
  .fail-block { background: #fff; border-left: 3px solid var(--red); padding: 20px 22px; margin: 16px 0; }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 14px; background: #fff; }
  .price-table th, .price-table td { text-align: left; padding: 11px 12px; border-bottom: 1px solid var(--border); }
  .price-table th { background: var(--black); color: #fff; font-weight: 700; font-size: 0.95rem; }
  .small { color: var(--muted); font-size: 0.92rem; margin-top: 12px; }
  .area-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 18px; }
  .area-grid > div { background: #fff; border: 1px solid var(--border); padding: 16px; border-radius: 6px; }
  .related-links { list-style: none; padding: 0; } .related-links li { padding: 10px 0; border-bottom: 1px solid var(--border); }
  .related-links a { color: var(--red); font-weight: 600; text-decoration: none; } .related-links a:hover { text-decoration: underline; }
  .faq { background: #fff; border: 1px solid var(--border); padding: 12px 16px; margin-bottom: 8px; border-radius: 4px; }
  .faq summary { font-weight: 700; cursor: pointer; padding: 4px 0; } .faq p { margin: 8px 0 0; }
  .cta-bottom { background: var(--black); color: #fff; padding: 48px 0; } .cta-bottom h2 { color: #fff; } .cta-bottom p { color: #c9c9c9; }
  .float-call { position: fixed; bottom: 18px; right: 18px; background: var(--red); color: #fff; padding: 14px 18px; border-radius: 40px; text-decoration: none; font-weight: 700; box-shadow: 0 6px 18px rgba(0,0,0,0.28); z-index: 50; font-size: 0.95rem; }
  @media (max-width: 820px) { h1 { font-size: 1.9rem; } h2 { font-size: 1.45rem; } .float-call { padding: 11px 14px; font-size: 0.88rem; } .trust-bar .wrap { gap: 14px; font-size: 0.85rem; } }
</style>
