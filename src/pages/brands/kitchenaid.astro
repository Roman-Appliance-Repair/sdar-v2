---
import Layout from '../../layouts/Layout.astro';
import BrandHubPlaceholder from '../../components/BrandHubPlaceholder.astro';

const title = "KitchenAid Appliance Repair | Southern California | Same Day Service";
const description = "Expert KitchenAid appliance repair across Southern California, Orange, Ventura counties. All KitchenAid categories — refrigerator, dishwasher, oven, stand mixer, cooktop. Call (424) 325-0520.";

const categories = [
  { label: "Refrigerator", url: "/brands/kitchenaid-refrigerator-repair/" },
  { label: "Dishwasher", url: "/brands/kitchenaid-dishwasher-repair/" },
  { label: "Oven", url: "/brands/kitchenaid-oven-repair/" },
  { label: "Stand Mixer", url: "/brands/kitchenaid-stand-mixer-repair/" },
  { label: "Cooktop", url: "/brands/kitchenaid-cooktop-repair/" }
];
---

<Layout title={title} description={description}>
  <BrandHubPlaceholder brandName="KitchenAid" brandSlug="kitchenaid" categories={categories} />
</Layout>
