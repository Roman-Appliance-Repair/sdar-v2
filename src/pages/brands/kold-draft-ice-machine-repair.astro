      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ]
    },
    {
      "@type": "Service",
      "serviceType": "Kold-Draft Ice Machine Repair",
      "provider": { "@id": canonical + "#business" },
      "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
      "description": "Kold-Draft 1-1/4-inch perfect-cube commercial ice machine repair — GT-series self-contained, KP-series modular. LA craft cocktail bar specialists: WeHo, DTLA, Santa Monica, Arts District. Ali Group parts network since 2021. After-hours emergency response for Friday-Saturday bar failures. Same-day dispatch across Southern California.",
      "offers": {
        "@type": "Offer",
        "price": "120",
        "priceCurrency": "USD",
        "description": "Commercial diagnostic fee — waived with authorized repair"
