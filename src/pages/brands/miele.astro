---
import Layout from '../../layouts/Layout.astro';
import BrandBranchesGrid from '../../components/BrandBranchesGrid.astro';
import { MAIN_PHONE, MAIN_PHONE_TEL } from '../../data/branches';

const title = "Miele Repair | Southern California | Dishwasher, Washer, Dryer, Oven, Cooktop, Coffee, Fridge";
const description = "Miele appliance repair SoCal — G 7000 dishwashers, W1 washers, T1 dryers, H 7000 ovens, MasterCool refrigerators, CM coffee. $89 diagnostic waived.";

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": "https://samedayappliance.repair/brands/miele/#business",
    "name": "Same Day Appliance Repair, Miele Service",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": "https://samedayappliance.repair/brands/miele/",
    "telephone": MAIN_PHONE_TEL,
    "priceRange": "$$$$",
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Do you service Miele W1/T1 laundry, the 24-inch compact models?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Miele W1 washers and T1 heat-pump dryers are 24\" European compact units, not the 27\" full-size standard of most American laundry. We service both generations: the W1 front-load washer with TwinDos dispensing and HomeCare 2.0 internals, and the T1 heat-pump dryer that runs on a regular 120V outlet and vents nothing (the heat pump recirculates and condenses moisture). These are premium laundry pairs common in condos, townhouses, and smaller-format luxury homes in Bel Air, Beverly Hills, West Hollywood, Pacific Palisades, and Malibu. Most of our W1/T1 calls are 2021-2023 generation units now coming out of the 2-year Miele USA warranty."
        }
      },
      {
        "@type": "Question",
        "name": "Are you Miele-authorized?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No, we're factory-trained but independent. Miele USA runs their own Authorized Service Agent network; during the warranty window, call Miele USA at 1-800-843-7231 and they'll dispatch an authorized technician at no parts cost. Post-warranty, we're the better call: faster response, lower labor rate, same training on the G 7000, W1/T1, H 7000, MasterCool, KM, and CM platforms. Most of our Miele calls are units 3+ years old where the warranty has closed but the appliance has another 15+ years of service life left."
        }
      },
      {
        "@type": "Question",
        "name": "Does Miele make ranges or stoves?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Miele makes ranges (induction and dual-fuel in 30\", 36\", 48\" widths), built-in ovens (H 7000 series), cooktops (KM Series induction, gas, and electric), steam ovens, speed ovens, and warming drawers. They do NOT make standalone stoves as a distinct product category, what Miele calls a range IS their cooking platform. We service all Miele cooking categories. If you're searching for 'Miele stove repair,' you probably mean either the range (freestanding or slide-in) or the cooktop (drop-in). We cover both."
        }
      },
      {
        "@type": "Question",
        "name": "How much does Miele appliance repair cost?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Diagnostic is $89 and waived with repair. Typical Miele repairs vary by category. Dishwashers (G 7000): drain pump $185-$285, AquaStop valve $245-$345, circulation pump $385-$540, control board $580-$820. Washers (W1): drain pump $285-$385, shock absorber set $225-$325, door lock $195-$285, control board $640-$920. Dryers (T1): heat pump module $840-$1,250, NTC sensor $145-$215, circulation fan $340-$460. Ovens (H 7000): heating element $285-$420, cooling fan $265-$385, temp probe $165-$235, touch control $540-$780. Refrigerators (MasterCool): inverter board $685-$945, door cam $185-$265, evaporator fan $385-$540. Labor and parts quoted before work starts."
        }
      },
      {
        "@type": "Question",
        "name": "Do you stock Miele parts?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Common wear parts for G 7000 dishwashers, W1 washers, and T1 dryers ride on the truck, drain pumps, AquaStop valves, shock absorbers, NTC sensors, door locks, common control elements. Less common parts, specific H 7000 oven relay boards, MasterCool inverter modules, CM coffee machine brew units, come next-day from Miele USA parts distribution in Princeton, NJ. Very specific legacy parts (older G 4000 series, pre-2015 W1 generations, discontinued coffee machine components) sometimes require longer lead times and we flag those upfront."
        }
      }
    ]
  }
];
---
<Layout title={title} description={description}>
  <Fragment slot="head-scripts">
    {schemaJsons.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </Fragment>

  <section class="hero">
    <div class="hero-inner">
      <div class="hero-content">
        <p class="hero-eyebrow">LA · Orange · Ventura · San Bernardino · Riverside Counties</p>
        <h1>Miele Appliance Repair</h1>
        <p class="hero-sub">Factory-trained service for the full Miele platform: G 7000 dishwashers, W1 washers, T1 heat-pump dryers, H 7000 ovens, KM cooktops, MasterCool refrigerators, CM coffee machines, and the 24-inch European compact product family. Post-warranty specialists for premium homes across Southern California, LA's Westside, Newport Beach and Laguna Beach in OC, Westlake Village and Thousand Oaks in Ventura, and the Murrieta and Temecula estate corridors in Riverside.</p>
        <div class="hero-ctas">
          <a href={`tel:${MAIN_PHONE_TEL}`} class="btn-primary">☎ {MAIN_PHONE}</a>
          <a href="/contact/" class="btn-outline">Book Online</a>
        </div>
      </div>
      <div class="hero-img-wrap">
        <div class="hero-img-placeholder">
          <p>Miele Repair</p>
          <p>Across Southern California</p>
        </div>
      </div>
    </div>
  </section>

  <div class="trust-bar">
    <div class="trust-bar-inner">
      <div class="trust-item"><span class="trust-icon">🏅</span> BHGS Licensed #A49573</div>
      <div class="trust-item"><span class="trust-icon">🛡</span> Fully Insured</div>
      <div class="trust-item"><span class="trust-icon">⚡</span> Same Day Available</div>
      <div class="trust-item"><span class="trust-icon">🔩</span> OEM Parts on Truck</div>
      <div class="trust-item"><span class="trust-icon">💬</span> $89 Diagnostic, Waived With Repair</div>
    </div>
  </div>

  <!-- ── ABOUT ── -->
  <section class="section">
    <div class="container">
      <p class="eyebrow-sub">About the brand</p>
      <h2>Miele builds for 20 years. Service should match that standard.</h2>
      <p>Miele tests every machine it builds to a 20-year service life specification, not a marketing number, an engineering target that shapes the way motors, seals, bearings, and controls are specified. A W1 washer motor is rated for 10,000 operating hours. A T1 heat-pump dryer's compression system is rated for similar duty. G 7000 dishwashers run a 24-hour endurance test at the factory before shipping. What that discipline delivers to the owner is longevity: it's common to service original-install Miele dishwashers from 2012 and W1 washers from 2015 across Southern California kitchens and condos, Westside LA, Newport Beach and Irvine, Westlake Village, and Temecula corridor, still running on original pumps and motors, needing only consumable wear-parts replacement.</p>
      <p>What the 20-year target means for repair service: the right technician respects the engineering. Swapping a Miele drain pump for a generic doesn't work, motor specifications and flow rates are tuned to the control logic, and a generic part triggers fault codes or causes water pressure errors that never existed before the "repair." We use genuine Miele parts from USA distribution, we carry the M-Care-style diagnostic protocols for each platform, and we document serial numbers and service history so the machine's maintenance record stays coherent over its full life.</p>
      <p>Most of our Miele calls come from districts where Miele was specified for the 24-inch European compact laundry footprint, the integrated panel-ready dishwasher, or the fully-integrated MasterCool refrigeration, Bel Air, Beverly Hills, Holmby Hills, West Hollywood, Brentwood, Pacific Palisades, and Malibu on LA's Westside; the Pasadena and La Cañada foothills in the SGV; Newport Beach, Laguna Beach, and Irvine in Orange County; Westlake Village, Thousand Oaks, and Hidden Hills in Ventura; and Murrieta and Temecula estate kitchens in Riverside. These are post-warranty units where the 2-year Miele USA warranty has closed but the appliance has 10-to-17 years of life left. We're the right fit for that phase.</p>
    </div>
  </section>

  <!-- ── CATEGORIES ── -->
  <section class="section section-alt">
    <div class="container">
      <p class="eyebrow-sub">What we repair</p>
      <h2>Miele categories we service</h2>
      <div class="cat-grid">
        <a href="/brands/miele-dishwasher-repair/" class="cat-card">
          <h3>Miele Dishwasher Repair</h3>
          <p>G 7000 Series with AutoDos PowerDisk, G 5000 Series, Futura, and integrated panel-ready models. AquaStop leak protection, 3D MultiFlex tray, AutoOpen drying. The reference dishwasher platform.</p>
          <span class="cat-cta">View dishwasher repair →</span>
        </a>
        <a href="/brands/miele-washer-repair/" class="cat-card">
          <h3>Miele Washer Repair (W1)</h3>
          <p>W1 24-inch front-load washers. TwinDos two-cartridge dispensing, HomeCare 2.0 internals, CapDosing, quiet Honeycomb drum design. The premium compact washer for Southern California condos and townhouses, Wilshire Corridor, Newport Beach high-rises, Long Beach towers, and IE attached-home corridors.</p>
          <span class="cat-cta">View washer repair →</span>
        </a>
        <a href="/brands/miele-dryer-repair/" class="cat-card">
          <h3>Miele Dryer Repair (T1)</h3>
          <p>T1 heat-pump condenser dryers. 120V outlet, no external venting required, EcoDry system, FragranceDos, PerfectDry sensor system. Uniquely American-compatible heat-pump technology.</p>
          <span class="cat-cta">View dryer repair →</span>
        </a>
        <div class="cat-card static">
          <h3>Miele Oven &amp; Range Service</h3>
          <p>H 7000 Series wall ovens, MasterChef Plus automatic programs, Moisture Plus, SensorTronic touch controls. Miele induction ranges and dual-fuel ranges in 30", 36", 48" widths. Section coverage on hub; standalone page coming.</p>
          <span class="cat-cta">Call {MAIN_PHONE}</span>
        </div>
        <div class="cat-card static">
          <h3>Miele Cooktop Service</h3>
          <p>KM Series induction cooktops (KM 6800 flagship, KM 7000 newest), KM gas cooktops, KM electric. PowerFlex cooking zones, TempControl temperature-limited cooking. Section coverage; standalone page coming.</p>
          <span class="cat-cta">Call {MAIN_PHONE}</span>
        </div>
        <div class="cat-card static">
          <h3>Miele Refrigerator (MasterCool)</h3>
          <p>MasterCool built-in refrigeration, 30" and 36" columns, 48" side-by-side, wine storage. FlexiFrame, PerfectFresh Pro drawers, inverter compressor architecture. Section coverage; standalone page coming.</p>
          <span class="cat-cta">Call {MAIN_PHONE}</span>
        </div>
        <div class="cat-card static">
          <h3>Miele Coffee Machines (CM)</h3>
          <p>CM 5 Series freestanding, CM 6 Series, CM 7 Series flagship, CVA 7000 built-in. AromaticSystem, OneTouch specialties, descaling programs. Section coverage on hub.</p>
          <span class="cat-cta">Call {MAIN_PHONE}</span>
        </div>
        <div class="cat-card static">
          <h3>Miele Steam &amp; Speed Ovens</h3>
          <p>DG combi-steam, DGM microwave-combi, M Series speed ovens. Steam-only cooking, full combi-steam modes, automatic descaling. Section coverage on hub.</p>
          <span class="cat-cta">Call {MAIN_PHONE}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── 24-INCH CONTEXT ── -->
  <section class="section">
    <div class="container narrow">
      <p class="eyebrow-sub">Understanding Miele's format</p>
      <h2>Why Miele is 24 inches, not 27</h2>
      <p>The most common source of confusion on Miele laundry service calls is format. American laundry norms are 27-inch washers and dryers, that's what Whirlpool, LG, Samsung, GE, and Maytag build. Miele W1 washers and T1 dryers are 24 inches wide. That's the European residential standard and it's the reason Miele fits the spaces where 27-inch laundry won't: stackable closets in Wilshire Corridor condos, butler's pantries in Bel Air, service rooms in Malibu beachfront properties, and compact laundry nooks in West Hollywood townhouses.</p>
      <p>The 24-inch format has service implications beyond width. Capacity per cycle is smaller (about 4.0 cubic feet for the W1 versus 5.0+ for a 27-inch American washer), cycle times are longer (Miele's default "cotton" program runs 2:45 for a full load, optimized for gentler fabric handling), and the electrical profile is different (T1 dryers run on a standard 120V 15-amp outlet, no 240V installation required, which is why they fit condos that were never plumbed for a dryer circuit). The heat-pump technology in the T1 is the enabling feature: instead of venting hot humid air outside (needing an exterior vent installation), the heat pump recirculates air through a condenser that removes moisture into a drain pan or drain line.</p>
      <p>For service: the 24-inch compact format is a reference standard Miele invests in. Parts availability is excellent, the diagnostic protocols are well-documented, and the technician has to understand the differences from 27-inch norms. A generic "washer repair" technician who's never worked a W1 can make avoidable mistakes. We specialize in this format because most of our Miele work is laundry.</p>
    </div>
  </section>

  <!-- ── PLATFORM OVERVIEW ── -->
  <section class="section section-alt">
    <div class="container">
      <p class="eyebrow-sub">Platform overview</p>
      <h2>Miele product platforms we service</h2>
      <div class="model-grid">
        <div class="model-card">
          <h3>G 7000 Dishwashers (Flagship)</h3>
          <p class="model-list">G 7966 SCVi AutoDos · G 7966 SCVi · G 7316 SCU · G 7104 SCU</p>
          <p>Miele's current dishwasher flagship. AutoDos automatic detergent dispensing via PowerDisk, AquaStop full leak protection, 3D MultiFlex middle rack, QuickPowerWash 58-minute cycle, AutoOpen drying.</p>
        </div>
        <div class="model-card">
          <h3>W1 Washers (24" Compact)</h3>
          <p class="model-list">WWB 020 WCS · WWH 860 WCS · WWH 660 WCS · WXI 860 WCS · WXR 860 WCS</p>
          <p>24-inch front-load European compact. TwinDos two-cartridge dispensing with UltraPhase 1 and 2, Honeycomb drum, HomeCare 2.0, 10,000-hour motor rating, CapDosing for specialty detergents.</p>
        </div>
        <div class="model-card">
          <h3>T1 Heat-Pump Dryers (120V)</h3>
          <p class="model-list">TXI 680 WP · TXR 860 WP · TWI 180 WP · TWF 160 WP</p>
          <p>Ventless heat-pump drying on a standard 120V 15-amp outlet. EcoDry heat pump, PerfectDry moisture sensors, FragranceDos capsules, steam refresh, no exterior vent required.</p>
        </div>
        <div class="model-card">
          <h3>H 7000 Ovens &amp; MasterCool Refrigeration</h3>
          <p class="model-list">H 7364 BP · H 7164 BP · KF 2982 Vi · F 2412 Vi · K 2902 Vi</p>
          <p>H 7000 wall ovens with MasterChef Plus, Moisture Plus, SensorTronic touch. MasterCool built-in columns 30"/36", 48" side-by-side, FlexiFrame, PerfectFresh Pro, inverter compressor architecture.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ── WARRANTY ── -->
  <section class="section">
    <div class="container narrow">
      <p class="eyebrow-sub">Warranty context</p>
      <h2>Inside the Miele USA warranty window? Call them first.</h2>
      <p>Miele USA residential warranty runs 2 years on all parts and labor, with a 10-year limited warranty on the motor/drum for W1 washers and T1 dryers. During the warranty window, call Miele USA customer service at <strong>1-800-843-7231</strong> and they'll dispatch an Authorized Service Agent at no parts cost.</p>
      <p>Post-warranty is where we work. Most of our Miele calls are 3-to-15-year-old units, units installed between 2011 and 2023 where the parts warranty has closed but the appliance has another decade-plus of service life left. Same factory training, faster response, lower labor rate than a post-warranty Authorized Service dispatch. We're also the right choice for warranty-overflow situations, where Miele USA has a multi-week backlog and a critical appliance needs attention now.</p>
    </div>
  </section>

  <!-- ── SERVICE AREAS ── -->
  <section class="section section-alt">
    <div class="container">
      <p class="eyebrow-sub">Where we work</p>
      <h2>Miele service across Southern California</h2>
      <p>Eight service territories cover all five counties, Los Angeles, Orange, Ventura, San Bernardino, and Riverside. Miele density is highest in condominiums along the Wilshire Corridor and Century City (24-inch laundry fits where 27-inch won't), luxury single-family in Bel Air, Beverly Hills, Brentwood, Pacific Palisades, and Malibu (MasterCool refrigeration, G 7000 dishwashers, H 7000 ovens), Newport Beach and Laguna Beach waterfront condos in Orange County, Westlake Village and Thousand Oaks estates in Ventura, Pasadena and San Marino traditional homes with integrated German-brand kitchen specs, and Temecula and Murrieta wine-country estates in Riverside. All eight branches stock Miele parts for the most common failures.</p>
      <BrandBranchesGrid showHeader={false} />
    </div>
  </section>

  <!-- ── CREDENTIALS ── -->
  <section class="section">
    <div class="container narrow">
      <p class="eyebrow-sub">Credentials</p>
      <h2>Licensed, insured, EPA-certified</h2>
      <p>We hold an active CSLB C-20 HVAC license, covering HVAC scope work. Miele MasterCool service on sealed refrigeration systems requires EPA 608 refrigerant handling certification; all our technicians are EPA 608 Universal certified (#1346255700410) plus BHGS #A49573. We carry general liability and workers' comp. BHGS-registered under <strong>#A49573</strong>. BBB A+ since 2022.</p>
      <p>See the <a href="/credentials/">full credentials page</a> for license verification links.</p>
    </div>
  </section>

  <!-- ── FAQ ── -->
  <section class="section section-alt">
    <div class="container narrow">
      <p class="eyebrow-sub">FAQ</p>
      <h2>Miele service, common questions</h2>

      <details class="faq">
        <summary>Do you service 24-inch Miele W1/T1 laundry?</summary>
        <p>Yes, W1 washers (TwinDos, HomeCare 2.0) and T1 heat-pump dryers (120V ventless) are our core Miele specialty. Most of our W1/T1 calls are 2021-2023 generation units coming out of the 2-year Miele USA warranty.</p>
      </details>

      <details class="faq">
        <summary>Are you Miele-authorized?</summary>
        <p>No, factory-trained but independent. Inside the 2-year Miele USA warranty, call 1-800-843-7231 for Authorized Service Agent at no parts cost. Post-warranty, we're the better call: faster response, lower labor rate, same training on G 7000, W1/T1, H 7000, MasterCool, KM, CM platforms.</p>
      </details>

      <details class="faq">
        <summary>Does Miele make stoves?</summary>
        <p>Miele makes ranges (induction, dual-fuel, 30"/36"/48"), cooktops (KM Series), ovens (H 7000), steam ovens, speed ovens. No distinct "stove" product category, the range IS the cooking platform. "Miele stove repair" typically means either range or cooktop. We cover both.</p>
      </details>

      <details class="faq">
        <summary>How long does a Miele last?</summary>
        <p>Designed for 20-year service life. Motors tested to 10,000 operating hours. We routinely service original-install Miele dishwashers from 2012 and W1 washers from 2015, running on original pumps and motors.</p>
      </details>

      <details class="faq">
        <summary>How much does Miele repair cost?</summary>
        <p>Diagnostic $89, waived with repair. Category-specific pricing on individual pages: dishwasher drain pump $185-$285, W1 drain pump $285-$385, T1 heat-pump module $840-$1,250, H 7000 heating element $285-$420, MasterCool inverter $685-$945.</p>
      </details>

      <details class="faq">
        <summary>Do you stock Miele parts?</summary>
        <p>Common wear parts for G 7000, W1, T1 on the truck, drain pumps, AquaStop valves, NTC sensors, shock absorbers, door locks, control elements. Less common parts (H 7000 relay boards, MasterCool inverter modules, CM brew units) next-day from Miele USA Princeton.</p>
      </details>

      <details class="faq">
        <summary>How fast can you come out?</summary>
        <p>Same-day for calls before 1 PM weekday inside coverage. Malibu, Hidden Hills, Pacific Palisades get next-morning priority. For a leaking dishwasher or dead washer with laundry piling up, call and say so, we rearrange.</p>
      </details>
    </div>
  </section>

  <!-- ── BOTTOM CTA ── -->
  <section class="bottom-cta">
    <div class="container">
      <h2>Ready to schedule Miele service?</h2>
      <p>Same day available. $89 diagnostic, waived with repair. Labor and parts quoted before we start.</p>
      <div class="hero-ctas">
        <a href={`tel:${MAIN_PHONE_TEL}`} class="btn-primary">☎ Call {MAIN_PHONE}</a>
        <a href="/contact/" class="btn-outline">Book Online</a>
      </div>
    </div>
  </section>

<style>
  :root {
    --red: #C8102E;
    --black: #0a0a0a;
    --gray: #f5f5f5;
    --border: #e2e2e2;
    --text: #1a1a1a;
    --muted: #6b6b6b;
    --white: #ffffff;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; color: var(--text); line-height: 1.6; }

  .hero { background: var(--black); color: #fff; padding: 80px 24px 72px; }
  .hero-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; max-width: 1100px; margin: 0 auto; align-items: center; }
  .hero-eyebrow { font-size: 13px; color: var(--red); text-transform: uppercase; letter-spacing: .12em; margin-bottom: 16px; font-weight: 600; }
  .hero h1 { font-size: clamp(28px, 4vw, 46px); font-weight: 700; color: #fff; margin-bottom: 20px; line-height: 1.15; font-family: 'Playfair Display', Georgia, serif; }
  .hero-sub { font-size: 17px; color: rgba(255,255,255,.72); margin-bottom: 28px; }
  .hero-ctas { display: flex; gap: 12px; margin-bottom: 28px; flex-wrap: wrap; }
  .btn-primary { display: inline-block; padding: 14px 28px; background: var(--red); color: #fff; text-decoration: none; border-radius: 6px; font-weight: 600; font-size: 16px; transition: background .2s; }
  .btn-primary:hover { background: #a50d25; }
  .btn-outline { display: inline-block; padding: 14px 28px; border: 1.5px solid rgba(255,255,255,.35); color: #fff; text-decoration: none; border-radius: 6px; font-weight: 600; font-size: 16px; transition: all .2s; }
  .btn-outline:hover { background: rgba(255,255,255,.08); border-color: #fff; }
  .hero-img-wrap { aspect-ratio: 4/3; background: #1a1a1a; border-radius: 4px; display: flex; align-items: center; justify-content: center; }
  .hero-img-placeholder { color: rgba(255,255,255,.35); font-size: 14px; text-align: center; }
  @media (max-width: 768px) { .hero-inner { grid-template-columns: 1fr; } .hero-img-wrap { display: none; } }

  .trust-bar { background: var(--red); color: #fff; padding: 16px 24px; }
  .trust-bar-inner { max-width: 1100px; margin: 0 auto; display: flex; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
  .trust-item { font-size: 13px; font-weight: 600; display: flex; align-items: center; gap: 8px; }
  .trust-icon { font-size: 16px; }

  .section { padding: 72px 24px; }
  .section-alt { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; }
  .container.narrow { max-width: 780px; }
  .eyebrow-sub { font-size: 13px; color: var(--red); text-transform: uppercase; letter-spacing: .12em; margin-bottom: 12px; font-weight: 600; }
  h2 { font-size: clamp(24px, 3vw, 34px); font-weight: 700; margin-bottom: 20px; line-height: 1.2; font-family: 'Playfair Display', Georgia, serif; }
  .section p { margin-bottom: 16px; color: var(--text); }

  .cat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 20px; margin-top: 32px; }
  .cat-card { display: block; padding: 24px; background: #fff; border: 1px solid var(--border); border-radius: 8px; text-decoration: none; color: inherit; transition: all .2s; }
  .cat-card:hover { border-color: var(--red); transform: translateY(-2px); box-shadow: 0 4px 16px rgba(0,0,0,.08); }
  .cat-card.static { cursor: default; }
  .cat-card.static:hover { transform: none; box-shadow: none; border-color: var(--border); }
  .cat-card h3 { font-size: 17px; font-weight: 700; margin-bottom: 10px; color: var(--black); font-family: 'Playfair Display', Georgia, serif; }
  .cat-card p { font-size: 14px; color: var(--muted); margin-bottom: 14px; }
  .cat-cta { font-size: 13px; color: var(--red); font-weight: 600; }

