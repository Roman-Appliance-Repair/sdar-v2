---
import Layout from '../../layouts/Layout.astro';
import BrandHubPlaceholder from '../../components/BrandHubPlaceholder.astro';

const title = "Miele Appliance Repair Los Angeles | Same Day Service";
const description = "Expert Miele appliance repair across LA, Orange, Ventura counties. All Miele categories — dishwasher, washer, dryer. Call (424) 325-0520.";

const categories = [
  { label: "Dishwasher", url: "/brands/miele-dishwasher-repair/" },
  { label: "Washer", url: "/brands/miele-washer-repair/" },
  { label: "Dryer", url: "/brands/miele-dryer-repair/" }
];
---

<Layout title={title} description={description}>
  <BrandHubPlaceholder brandName="Miele" brandSlug="miele" categories={categories} />
</Layout>
