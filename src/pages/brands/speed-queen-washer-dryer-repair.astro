---
import Layout from '../../layouts/Layout.astro';
import BrandBranchesGrid from '../../components/BrandBranchesGrid.astro';
import { MAIN_PHONE, MAIN_PHONE_TEL } from '../../data/branches';

const title = "Speed Queen Washer + Dryer Repair | Southern California | Commercial-Grade";
const description = "$89 diagnostic waived. Speed Queen washer/dryer repair Southern California — commercial-grade residential, TR/TC top-load, AWNA/AFNE front-load + matched dryers. Ripon WI. (424) 325-0520.";
const canonical = "https://samedayappliance.repair/brands/speed-queen-washer-dryer-repair/";

const faqs = [
  {
    q: "Speed Queen's 'commercial-grade residential' positioning — is it real?",
    a: "<b>Yes, structurally.</b> Speed Queen is the residential arm of Alliance Laundry Systems (Ripon Wisconsin) — the company that builds coin-operated commercial laundry machines for laundromats and hotels worldwide. The Speed Queen residential product line uses <b>the same chassis, motors, transmissions, and gear reductions as the commercial equipment</b>, de-rated for household use but with the commercial durability intact. Typical residential washer lifespan is 8-12 years; Speed Queen routinely runs 18-25 years with normal household cycles. Repair economics follow suit: Speed Queen parts are built for commercial-load duty, which means lower failure rate but higher part cost when something does need replacement. Net repair cost over 20 years is lower than equivalent mass-market brands because you replace fewer parts over longer intervals."
  },
  {
    q: "Speed Queen US lineup in LA — which models?",
    a: "<b>TR/TC-series top-load washers</b> (TR3003, TR5000, TR7) — the traditional Speed Queen agitator top-load; deep-fill capable (one of the last US residential washers that still lets you set water level manually); 3.2 cu ft. <b>AWNA/AFNE-series front-load</b> — more recent addition, 3.5 cu ft, stackable with matching Speed Queen dryer. <b>DR/DC-series dryers</b> — matching gas or electric dryers for both top-load and front-load pairings; 7.0 cu ft vented. <b>DF/DFNE heat-pump dryer</b> — recent addition for vent-less installs. LA Speed Queen customers split between new-install luxury customers (spec'd for longevity) and property-manager installs (rental + duplex + small apartment buildings where commercial durability survives tenant rotation)."
  },
  {
    q: "Why a bundled washer + dryer page instead of separate?",
    a: "Honest answer: <b>Speed Queen customers almost always run the matched pair</b>, and the service economics + part-chain + failure modes overlap enough that one page reads clearer than two. When a Speed Queen call comes in, we typically diagnose the whole laundry pair — washer + dryer sharing the same 240V circuit, the same Alliance parts catalog, often the same vintage. Separating into dedicated washer and dryer pages would duplicate 70% of the content. If you landed here searching specifically for washer OR dryer individually, everything below applies to your unit; we've organized the service content by subsystem rather than by which unit is in front of you."
  },
  {
    q: "Speed Queen top-load vs front-load — which lasts longer?",
    a: "<b>Top-load TR/TC has the longer historical track record</b> (Speed Queen's commercial heritage is in the agitator-transmission design; 25+ year service life common). Front-load AWNA/AFNE is more recent and less longitudinally tested, though its shared chassis with Speed Queen's commercial front-load implies similar durability. Mechanical failure modes differ: top-load failures skew toward transmission ($380-$580 service), agitator dogs ($120-$220), and lid switch ($100-$180). Front-load failures skew toward bellows ($220-$340), door-lock mechanism ($180-$280), and shock absorbers ($160-$260). Both pairs have strong parts availability through Alliance's Ripon Wisconsin distribution."
  },
  {
    q: "Commercial Speed Queen vs residential Speed Queen — same parts?",
    a: "Meaningful overlap but not identical. Alliance Laundry Systems' commercial line (laundromat coin-op + hospitality + institutional) runs higher-duty-cycle specifications — commercial-spec motors, heavier transmissions, industrial control boards with coin-handling hardware. Residential Speed Queen uses the <b>same core mechanicals at de-rated household duty cycle</b> but without the coin-op controls. For parts: many chassis + motor + transmission SKUs cross-reference at Alliance's Ripon catalog, but residential electronics + control boards are residential-specific. If you're servicing an actual commercial Speed Queen (laundromat or small-business install), that's our <a href='/brands/speed-queen-commercial-laundry-repair/'>commercial Speed Queen page</a>; the residential scope is this page."
  },
  {
    q: "What does Speed Queen washer/dryer repair cost in LA?",
    a: "Residential diagnostic $89 waived with repair. Typical Speed Queen bands — <b>TR/TC top-load washer</b>: transmission service $380–$580, agitator dogs $120–$220, lid switch $100–$180, drive belt $80–$140, inlet valve $80–$140, water-level pressure switch $100–$160. <b>AWNA/AFNE front-load washer</b>: bellows / door boot seal $220–$340, door-lock mechanism $180–$280, shock absorbers (pair) $160–$260, drain pump $160–$260. <b>DR/DC-series dryer</b>: heating element $180–$260, drum belt $80–$140, drum rollers (set) $120–$200, thermostat $80–$140, lint-sensor thermistor $80–$140. <b>DF heat-pump dryer</b>: evaporator coil cleaning $140–$220, compressor rare-failure $680–$980. Alliance Ripon WI parts chain; commercial-grade parts cost more upfront, fail less often over 20-year service life."
  }
];

const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair — Speed Queen Washer + Dryer Service",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": canonical, "telephone": "+1-424-325-0520", "priceRange": "$$$"
  },
  { "@context": "https://schema.org", "@type": "Service", "serviceType": "Speed Queen Washer and Dryer Repair",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "description": "Speed Queen residential washer + dryer repair across LA — TR/TC top-load, AWNA/AFNE front-load, DR/DC-series gas + electric dryers, DF heat-pump dryer. Commercial-grade residential; Alliance Laundry Systems Ripon Wisconsin parent. 18-25 year typical service life. $89 residential diagnostic waived with repair.",
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, waived with repair" } }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "Speed Queen", "item": "https://samedayappliance.repair/brands/speed-queen/" },
      { "@type": "ListItem", "position": 4, "name": "Speed Queen Washer + Dryer Repair", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">{schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}</Fragment>
  <div class="call-banner"><div class="wrap"><span>Speed Queen laundry service?</span><a href={`tel:${MAIN_PHONE_TEL}`} class="phone-lg">{MAIN_PHONE}</a></div></div>

  <section class="hero"><div class="wrap">
    <div class="crumb"><a href="/">Home</a> › <a href="/brands/">Brands</a> › Speed Queen › Washer + Dryer Repair</div>
    <h1>Speed Queen Washer + Dryer Repair</h1>
    <p class="lede">Speed Queen is the residential arm of Alliance Laundry Systems (Ripon Wisconsin) — the company behind commercial coin-op laundry machines in laundromats worldwide. The residential product line uses the same chassis, motors, and transmissions as commercial equipment, de-rated for household duty but with commercial durability intact. Result: 18-25 year typical service life versus 8-12 for mass-market brands. LA customers split between new-install luxury customers (spec'd for longevity) and property-manager installs (rental + duplex + small apartment buildings where commercial durability survives tenant rotation). Lineup runs TR/TC top-load washers, AWNA/AFNE front-load, DR/DC matching vented dryers gas + electric, and the newer DF heat-pump dryer for vent-less installs. Same-day dispatch, $89 residential diagnostic waived with the repair.</p>
    <div class="hero-cta"><a href={`tel:${MAIN_PHONE_TEL}`} class="btn btn-primary">Call {MAIN_PHONE}</a><a href="#book" class="btn btn-ghost">Request a Visit</a></div>
    <ul class="hero-facts">
      <li><b>Alliance Laundry Systems Ripon WI</b> — commercial-grade residential</li>
      <li><b>TR/TC top-load + AWNA/AFNE front-load + DR/DC dryers + DF heat-pump</b></li>
      <li><b>18-25 year typical service life</b> — commercial DNA in household duty</li>
      <li><b>$89 residential diagnostic</b> — waived when you authorize the repair</li>
    </ul>
  </div></section>

  <BrandBranchesGrid />

  <section class="trust-bar"><div class="wrap"><span>CSLB #1138898 · Insured</span><span>Same-day in 5 SoCal counties</span><span>Residential diagnostic $89 · waived with repair</span></div></section>

  <section class="section"><div class="wrap">
    <h2>What Speed Queen washer + dryer repair costs in LA</h2>
    <table class="price-table">
      <tr><th>Service</th><th>Typical Range</th><th>Notes</th></tr>
      <tr><td>Residential diagnostic</td><td>$89</td><td>Waived with repair</td></tr>
      <tr><td>TR/TC top-load transmission service</td><td>$380 – $580</td><td>Flagship durability part</td></tr>
      <tr><td>Agitator dogs (top-load)</td><td>$120 – $220</td><td>Drive engagement wear</td></tr>
      <tr><td>Lid switch (top-load)</td><td>$100 – $180</td><td>Safety interlock</td></tr>
      <tr><td>AWNA/AFNE front-load bellows</td><td>$220 – $340</td><td>8-10 year service</td></tr>
      <tr><td>Front-load door-lock mechanism</td><td>$180 – $280</td><td>Safety-critical</td></tr>
      <tr><td>Inlet valve (both platforms)</td><td>$80 – $140</td><td>Low-flow diagnostic</td></tr>
      <tr><td>DR/DC dryer heating element</td><td>$180 – $260</td><td>Gas or electric variant</td></tr>
      <tr><td>DR/DC dryer drum belt</td><td>$80 – $140</td><td>Squealing / no-turn</td></tr>
      <tr><td>DF heat-pump evaporator cleaning</td><td>$140 – $220</td><td>Vent-less variant maintenance</td></tr>
    </table>
    <p class="small">Related: <a href="/brands/speed-queen/">Speed Queen brand hub</a> · <a href="/brands/speed-queen-commercial-laundry-repair/">Speed Queen commercial (laundromat scope)</a> · <a href="/brands/miele-washer-repair/">Miele washer (longevity peer)</a> · <a href="/brands/fisher-paykel-washer-repair/">F&P washer (direct-drive peer)</a> · <a href="/services/washer-repair/">Washer repair (service hub)</a> · <a href="/services/dryer-repair/">Dryer repair (service hub)</a> · <a href="/price-list/washer-repair-cost/">Washer repair cost</a>.</p>
  </div></section>

  <section class="section alt"><div class="wrap narrow">
    <h2>Why the bundled page — service + economics overlap</h2>
    <p>Most LA Speed Queen installs are the matched washer-and-dryer pair, and the service economics + parts chain + diagnostic workflow overlap enough to cover them together here. When a Speed Queen call comes in we typically look at both units during the service visit — shared 240V circuit, shared Alliance Ripon Wisconsin parts catalog, often same install vintage. Separating into two pages would duplicate most of the content (commercial-grade positioning, Alliance parent, 18-25 year service life, parts chain) without adding new information. Below-the-fold content is organized by subsystem (washer mechanics, dryer mechanics) so the page reads clearly whether you landed here for washer-specific or dryer-specific intent.</p>
    <p>If you run a <b>commercial Speed Queen</b> install (laundromat, hotel, property-management coin-op), that's a separate service relationship — different parts catalog, different duty cycle, different service economics. See <a href="/brands/speed-queen-commercial-laundry-repair/">Speed Queen commercial laundry repair</a> for that scope.</p>
  </div></section>

  <section class="section"><div class="wrap narrow">
    <h2>Speed Queen washer + dryer repair — frequently asked</h2>
    {faqs.map(f => (<details class="faq"><summary>{f.q}</summary><p set:html={f.a}></p></details>))}
  </div></section>

  <section id="book" class="cta-bottom"><div class="wrap">
    <h2>Speed Queen laundry service? Call the branch closest to your home.</h2>
    <p>Same-day appliance repair in Los Angeles, Orange County, Ventura County. Residential diagnostic $89, waived with repair.</p>
  </div></section>
  <a href={`tel:${MAIN_PHONE_TEL}`} class="float-call" aria-label="Call now">☎ Call {MAIN_PHONE}</a>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  body { color: var(--text); } .wrap { max-width: 1200px; margin: 0 auto; padding: 0 24px; } .wrap.narrow { max-width: 820px; }
  h1 { font-size: 2.4rem; line-height: 1.15; margin: 12px 0 20px; color: var(--black); }
  h2 { font-size: 1.8rem; margin: 0 0 16px; color: var(--black); }
  p { line-height: 1.65; margin: 0 0 14px; }
  .call-banner { background: var(--red); color: #fff; padding: 10px 0; }
  .call-banner .wrap { display:flex; gap: 14px; align-items: center; justify-content: center; flex-wrap: wrap; }
  .call-banner .phone-lg { color:#fff; font-weight: 800; text-decoration: underline; font-size: 1.05rem; }
  .hero { background: var(--black); color: #fff; padding: 42px 0 56px; } .hero h1 { color: #fff; }
  .hero .lede { font-size: 1.06rem; color: #d7d7d7; max-width: 680px; }
  .hero .crumb { color: #9a9a9a; font-size: 0.85rem; margin-bottom: 6px; } .hero .crumb a { color: #c9c9c9; text-decoration: none; }
  .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; margin: 18px 0 24px; }
  .btn { display: inline-block; padding: 12px 20px; border-radius: 4px; text-decoration: none; font-weight: 700; }
  .btn-primary { background: var(--red); color: #fff; } .btn-ghost { background: transparent; color: #fff; border: 1px solid #fff; }
  .hero-facts { list-style: none; padding: 0; margin: 0; color: #c9c9c9; font-size: 0.95rem; }
  .hero-facts li { padding: 6px 0; border-top: 1px solid #222; } .hero-facts li:first-child { border-top: 0; }
  .trust-bar { background: var(--red); color: #fff; padding: 14px 0; }
  .trust-bar .wrap { display: flex; gap: 28px; flex-wrap: wrap; justify-content: center; font-size: 0.95rem; font-weight: 600; }
  .section { padding: 56px 0; } .section.alt { background: var(--gray); }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 14px; background: #fff; }
  .price-table th, .price-table td { text-align: left; padding: 11px 12px; border-bottom: 1px solid var(--border); }
  .price-table th { background: var(--black); color: #fff; font-weight: 700; font-size: 0.95rem; }
  .small { color: var(--muted); font-size: 0.92rem; margin-top: 12px; }
  .faq { background: #fff; border: 1px solid var(--border); padding: 12px 16px; margin-bottom: 8px; border-radius: 4px; }
  .faq summary { font-weight: 700; cursor: pointer; padding: 4px 0; } .faq p { margin: 8px 0 0; }
  .cta-bottom { background: var(--black); color: #fff; padding: 48px 0; } .cta-bottom h2 { color: #fff; } .cta-bottom p { color: #c9c9c9; }
  .float-call { position: fixed; bottom: 18px; right: 18px; background: var(--red); color: #fff; padding: 14px 18px; border-radius: 40px; text-decoration: none; font-weight: 700; box-shadow: 0 6px 18px rgba(0,0,0,0.28); z-index: 50; font-size: 0.95rem; }
  @media (max-width: 820px) { h1 { font-size: 1.9rem; } .float-call { padding: 11px 14px; font-size: 0.88rem; } .trust-bar .wrap { gap: 14px; font-size: 0.85rem; } }
</style>
