---
import Layout from '../../layouts/Layout.astro';

const title = "Bosch Dishwasher Repair Los Angeles | Same-Day, $89 Diagnostic";
const description = "Bosch dishwasher repair across LA. Factory-Trained, Post-Warranty specialists. AquaStop E15, door spring, Benchmark CrystalDry. 800/500/300 Series. OEM parts. $89 diagnostic waived with repair. Call (424) 325-0520.";

/* === 5 BRANCH PHONES — routing by neighborhood === */
const branches = [
  { name: "West Hollywood",  phone: "(323) 870-4790", tel: "+13238704790", areas: "WeHo · Beverly Hills · Hollywood · Mid-City" },
  { name: "Los Angeles",     phone: "(424) 325-0520", tel: "+14243250520", areas: "Mid-Wilshire · Brentwood · Santa Monica · Culver City · Westside" },
  { name: "Thousand Oaks",   phone: "(424) 208-0228", tel: "+14242080228", areas: "Ventura County · Calabasas · Agoura · Westlake · Malibu" },
  { name: "Pasadena",        phone: "(626) 376-4458", tel: "+16263764458", areas: "Pasadena · San Marino · Arcadia · Glendale · San Gabriel Valley" },
  { name: "Irvine",          phone: "(213) 401-9019", tel: "+12134019019", areas: "Orange County · Newport Beach · Irvine · Anaheim" },
];
const mainPhone = branches[1]; // LA main NAP

/* === NAMED TECHNICIANS — placeholders, replace with real photos === */
const namedTechs = [
  { name: "Mikhail V.", role: "Bosch/Thermador Specialist · 12 yrs", photo: "/images/techs/placeholder-1.jpg", areas: "Westside · West Hollywood · Beverly Hills" },
  { name: "Artur S.",   role: "Built-in Installation & Repair · 9 yrs", photo: "/images/techs/placeholder-2.jpg", areas: "Pasadena · San Marino · Arcadia" },
  { name: "David K.",   role: "European Appliance Specialist · 14 yrs", photo: "/images/techs/placeholder-3.jpg", areas: "Malibu · Pacific Palisades · Calabasas" },
];

const faqs = [
  {
    q: "How much does Bosch dishwasher repair cost in Los Angeles?",
    a: "Most Bosch dishwasher repairs in LA land between $180 and $420 all-in, parts and labor combined. A drain pump replacement averages $220. A recirculation pump on an 800 Series runs $380–$480 because the part itself is $240+. Control board replacement lands around $350. Door spring or door latch work comes in at $160–$240. Our $89 diagnostic fee is waived the moment you approve the repair — we don't charge a separate $179 call-out fee on top like Bosch Factory Service, and we don't meter labor in 6-minute increments."
  },
  {
    q: "What does E15 mean on my Bosch dishwasher?",
    a: "E15 means Bosch's AquaStop leak-protection system detected water in the base pan and shut the unit down to prevent flooding. The cause is almost always a real leak — a failed sump gasket, a worn door seal, a loose hose clamp, or over-sudsing from the wrong detergent. You can temporarily clear E15 by tilting the dishwasher forward 45° to drain the base pan, but that's a diagnostic step, not a fix. If you restart and the code returns, stop using the unit — repeated cycles worsen the leak and risk cabinet damage. Our technicians locate the exact leak source and repair only what's failed."
  },
  {
    q: "Is it worth repairing a 10-year-old Bosch dishwasher?",
    a: "Usually yes, if the stainless tub and frame are intact. Here's the rule we use: if parts and labor would exceed 40% of the replacement cost AND the unit is over 12 years old, replacement may make more sense. Otherwise, repair almost always wins. Bosch parts are well-supported 15+ years back, and a $400 pump replacement beats a $1,400+ new unit. Repair also preserves the 10-year EcoSilence motor warranty on qualifying models — but only when we use Bosch manufacturer-approved parts."
  },
  {
    q: "Do you service panel-ready built-in Bosch dishwashers without damaging cabinetry?",
    a: "Yes — this is a routine part of our work in Bel Air, Holmby Hills, and Pacific Palisades, where most Bosch units are panel-ready and integrated into custom millwork. Our technicians use non-invasive pull-out procedures: protective floor covering, careful disconnection of the custom panel, and controlled unit extraction without scratching adjacent cabinetry or flooring. We photograph the installation before we start and reinstall to the exact original fit. On built-ins this means a 20–30 minute longer service call, but no damage to your kitchen."
  },
  {
    q: "Are you a Bosch Factory-Trained repair company?",
    a: "Our technicians complete manufacturer training on Bosch dishwasher platforms each year — 800 Series, Benchmark CrystalDry, 500 Series, 300 Series. We're licensed (CA), insured ($2M liability), BBB A+ rated, and EPA-certified for refrigerant work on related appliances. We're an independent repair company, not a Bosch Factory Service subcontractor, which is why our pricing structure is different — no separate $179 call-out fee, no 6-minute metered labor, and the $89 diagnostic is waived when you approve the repair."
  },
  {
    q: "Why does my Bosch dishwasher door spring keep breaking?",
    a: "The door spring and its braided cable carry every open-and-close cycle for the life of the unit. On 500 and 800 Series units past year 6–7, the spring fatigues and the cable frays, usually showing up as a door that drops hard or won't stay open at any angle. It's a known wear item, not a defect. The repair is a full spring and cable assembly swap — manufacturer-approved part, about 30–40 minutes on site. Running a Bosch with a broken door spring eventually damages the hinge bracket, so we recommend fixing it sooner rather than later."
  },
  {
    q: "Do you work on Bosch units after the factory warranty expires?",
    a: "Post-warranty Bosch service is our specialty. Bosch's own factory warranty covers one year on most parts and labor — after that, owners are directed to Factory Service at $179 call-out plus metered labor, or to independent shops. We focus specifically on units aged 2–15 years, which is the window where the 800 Series recirculation pump, heating element, and door spring all tend to fail in LA water. We carry the manufacturer-approved parts for these failures on the truck."
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
};

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Same Day Appliance Repair",
  "image": "https://samedayappliance.repair/logo.png",
  "telephone": "(424) 325-0520",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "6230 Wilshire Blvd Ste A PMB 2267",
    "addressLocality": "Los Angeles",
    "addressRegion": "CA",
    "postalCode": "90048",
    "addressCountry": "US"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.6",
    "reviewCount": "37"
  }
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Bosch Dishwasher Repair",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Same Day Appliance Repair",
    "telephone": "(424) 325-0520"
  },
  "areaServed": { "@type": "City", "name": "Los Angeles" }
};
---

<Layout title={title} description={description}>
  <Fragment slot="head-scripts">
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  </Fragment>

  <!-- 0. CALL BANNER ABOVE FOLD (sticky under navbar) -->
  <div class="call-banner">
    <div class="container call-banner-inner">
      <span class="cb-label">Same-Day Bosch Dishwasher Repair —</span>
      <a href={`tel:${mainPhone.tel}`} class="cb-phone">Call {mainPhone.phone}</a>
      <span class="cb-sep">·</span>
      <a href={`sms:${mainPhone.tel}`} class="cb-sms">Text us a photo</a>
    </div>
  </div>

  <!-- 1. HERO -->
  <section class="bosch-hero">
    <div class="container hero-grid">
      <div class="hero-text">
        <div class="hero-eyebrow">Factory-Trained · Post-Warranty Bosch Specialists</div>
        <h1>Bosch Dishwasher Repair in Los Angeles</h1>
        <p class="hero-sub">
          AquaStop E15. Recirculation pump failures. Door spring breaks. Benchmark
          CrystalDry. Our Factory-Trained technicians work on Bosch dishwashers
          every day across LA — 800 Series, Benchmark, 500, 300. Manufacturer-approved
          parts on the truck. Same-day appointments.
        </p>

        <!-- BRANCH SELECTOR — route call by neighborhood -->
        <div class="branch-select">
          <label for="branchPicker" class="bs-label">Your area:</label>
          <select id="branchPicker" class="bs-dropdown" onchange="
            const b = this.options[this.selectedIndex];
            const phoneEl = document.getElementById('heroPhoneBtn');
            phoneEl.href = 'tel:' + b.dataset.tel;
            phoneEl.textContent = 'Call ' + b.dataset.phone;
          ">
            {branches.map((b, i) => (
              <option value={b.name} data-tel={b.tel} data-phone={b.phone} selected={i === 1}>
                {b.name} — {b.areas}
              </option>
            ))}
          </select>
        </div>

        <div class="hero-ctas">
          <a id="heroPhoneBtn" href={`tel:${mainPhone.tel}`} class="btn btn-red">Call {mainPhone.phone}</a>
          <a href="/schedule/" class="btn btn-hero-outline">Schedule Online</a>
          <a href={`sms:${mainPhone.tel}?body=Bosch dishwasher photo — `} class="btn btn-hero-outline btn-sms">📷 Text Photo</a>
        </div>

        <div class="hero-badge">
          <span class="badge-amount">$89</span>
          <span class="badge-text">Diagnostic — <strong>waived</strong> when you approve the repair. No $179 call-out fee.</span>
        </div>
      </div>
      <div class="hero-image">
        <div class="image-frame">
          <div class="image-ring"></div>
          <img src="/images/bosch-dishwasher-repair.jpg" alt="Bosch 800 Series dishwasher repair Los Angeles" loading="eager" />
        </div>
      </div>
    </div>
  </section>

  <!-- 2. CREDENTIALS BAR (BBB A+ / Licensed / Insured / EPA / Factory-Trained) -->
  <section class="creds-bar">
    <div class="container">
      <div class="creds-grid">
        <div class="cred"><span class="cred-icon">★</span><div><strong>BBB A+ Rated</strong><span>Accredited business</span></div></div>
        <div class="cred"><span class="cred-icon">✓</span><div><strong>Factory-Trained</strong><span>Bosch 800 · Benchmark · 500 · 300</span></div></div>
        <div class="cred"><span class="cred-icon">⚖</span><div><strong>Licensed &amp; Insured</strong><span>CA Lic. · $2M liability</span></div></div>
        <div class="cred"><span class="cred-icon">⚡</span><div><strong>EPA-Certified</strong><span>Refrigerant-safe</span></div></div>
        <div class="cred"><span class="cred-icon">⌚</span><div><strong>Same-Day Service</strong><span>Most calls before 2 PM</span></div></div>
      </div>
    </div>
  </section>

  <!-- 3. POST-WARRANTY POSITIONING -->
  <section class="positioning">
    <div class="container container-narrow">
      <div class="pos-eyebrow">Who We Serve</div>
      <h2>LA's Post-Warranty Bosch Dishwasher Specialists</h2>
      <p>
        Bosch's factory warranty covers one year. After that, owners face a choice:
        pay Bosch Factory Service $179 per call plus $25 every 6 minutes of labor,
        or find an independent shop that actually knows the 800 Series and
        Benchmark platforms. We built our practice around the second option.
      </p>
      <p>
        Most of our Bosch calls are units aged 2–15 years, post-warranty, still
        several thousand dollars from replacement. The failures follow a pattern —
        recirculation pump at year 7–8, heating element around year 5 in hard
        water, door spring on 500 Series after year 6. We carry the manufacturer-
        approved parts for all of these on the truck, so your repair happens
        today, not after a parts order.
      </p>
    </div>
  </section>

  <!-- 4. INTRO -->
  <section class="intro">
    <div class="container container-narrow">
      <p class="lead">
        Bosch dishwashers have a specific failure pattern in Los Angeles water —
        hard water kills the recirculation pump around year 7 or 8, and we see it
        weekly from Beverly Hills to Brentwood to Studio City.
      </p>
      <p>
        That's the single most common Bosch dishwasher repair we run in LA. The
        stainless tub and quiet motor keep these units going long after cheaper
        brands have failed, but the pump assembly, heating element, and spray arms
        take a beating from calcium buildup. Our technicians carry Bosch
        manufacturer-approved pump assemblies on every van specifically because we
        know what's coming through the door on a decade-old 800 Series.
      </p>
      <p>
        The second biggest category is the AquaStop E-codes — E15, E09, E22, E24
        — flashing on the front panel with no clear explanation in the owner's
        manual. Most of them point to real failures, not random glitches. We read
        them, diagnose the root cause, and fix it the same visit. No parts
        chasing, no second appointments for the same problem.
      </p>
    </div>
  </section>

  <!-- 5. NAMED TECHNICIANS -->
  <section class="techs">
    <div class="container">
      <div class="section-heading">
        <span class="section-num">01</span>
        <h2>Meet the Technicians Who Will Service Your Bosch</h2>
      </div>
      <p class="section-lead">
        You'll know the name and face of the tech before they arrive. Our Bosch
        specialists are Factory-Trained, background-checked, and assigned by
        neighborhood — the same person who serviced your Beverly Hills neighbor
        last month is likely coming to you.
      </p>
      <div class="techs-grid">
        {namedTechs.map(t => (
          <div class="tech-card">
            <div class="tech-photo">
              <img src={t.photo} alt={`${t.name} — ${t.role}`} loading="lazy" />
            </div>
            <div class="tech-info">
              <h3>{t.name}</h3>
              <div class="tech-role">{t.role}</div>
              <div class="tech-areas">Primary areas: {t.areas}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 6. TRY THIS FIRST -->
  <section class="diy-check">
    <div class="container container-narrow">
      <div class="section-heading">
        <span class="section-num">02</span>
        <h2>Before You Call — Try These Four Things</h2>
      </div>
      <p class="section-lead">
        About one in five Bosch dishwasher calls we dispatch turn out to be
        something the homeowner can clear in two minutes. Worth a look before
        scheduling a visit.
      </p>
      <ol class="diy-list">
        <li>
          <strong>The door has to latch fully.</strong> If the top rack is bowed
          or a tall item is sticking up, the latch won't click and the cycle
          won't start. Re-seat the rack, close firmly, try again.
        </li>
        <li>
          <strong>Check the Delay button.</strong> If Delay is active, the unit
          looks dead but it's just counting down. Press Cancel-Drain (hold 3
          seconds on most models) to reset.
        </li>
        <li>
          <strong>Pull out the fine filter at the bottom and rinse it.</strong>
          Twist-out on 500/800 Series, takes 30 seconds. Clogged filter is the
          #1 cause of "dishes not clean" calls. Clean it monthly — biweekly in
          hard-water areas or if you cook daily.
        </li>
        <li>
          <strong>If you see an E-code, write it down.</strong> E15 especially
          means AquaStop has activated — turn off the water supply at the valve
          under the sink and call us. Running the cycle again with E15 active
          risks cabinet and floor damage.
        </li>
      </ol>
      <p class="diy-foot">
        Still broken? That's what we're here for. <a href={`tel:${mainPhone.tel}`}>{mainPhone.phone}</a>
        or <a href={`sms:${mainPhone.tel}?body=Bosch dishwasher photo — `}>text us a photo</a>.
      </p>
    </div>
  </section>

  <!-- 7. COMMON PROBLEMS -->
  <section class="problems">
    <div class="container">
      <div class="section-heading">
        <span class="section-num">03</span>
        <h2>Bosch Dishwasher Problems We Fix Every Week</h2>
      </div>
      <div class="problems-grid">
        <div class="problem-card">
          <h3>E15 — AquaStop Activated</h3>
          <p><strong>What it means:</strong> a float sensor in the base pan detected water. AquaStop shuts off all pumps to prevent flooding.</p>
          <p><strong>How we fix it:</strong> pull the unit, drain the base pan, find the leak source — usually sump gasket, door seal, cracked fill hose, or over-sudsing from regular dish soap. Replace what failed, reset the sensor.</p>
        </div>
        <div class="problem-card">
          <h3>E09 — Heating Element Failure</h3>
          <p><strong>What it means:</strong> the in-line heater isn't reaching temperature. Dishes come out wet, cycles run cold.</p>
          <p><strong>How we fix it:</strong> test heating element and thermistor with a meter. Replace the failed part — we carry the 800 Series element in stock. Descaling prevents a repeat in 18 months.</p>
        </div>
        <div class="problem-card">
          <h3>E22 — Filter / Drainage Clogged</h3>
          <p><strong>What it means:</strong> flow sensor reads restricted water movement. Control board throws E22 to warn before the pump burns out pushing against the blockage.</p>
          <p><strong>How we fix it:</strong> deep-clean the filter assembly, check spray arm jets for scale, verify drain pump flow. If impeller is scored, replace.</p>
        </div>
        <div class="problem-card">
          <h3>Recirculation Pump Dead</h3>
          <p><strong>What it means:</strong> wash pump runs but grinds or doesn't move water. Cycle finishes without cleaning. On 800 Series and Benchmark this is the #1 LA failure at year 7–8.</p>
          <p><strong>How we fix it:</strong> replace the full recirculation pump assembly with a manufacturer-approved part. Descale spray arms and tub while we're in there.</p>
        </div>
        <div class="problem-card">
          <h3>Won't Drain / Water in Bottom</h3>
          <p><strong>What it means:</strong> water pools at the base after a cycle. Drain pump impeller jam, clogged drain hose, kinked hose to disposal, or burned-out drain motor.</p>
          <p><strong>How we fix it:</strong> check drain pump impeller first — usually glass, a fruit pit, or shrimp shell. If clear, meter the motor. Hose last. Same-visit fix 80%+ of the time.</p>
        </div>
        <div class="problem-card">
          <h3>Door Spring / Door Latch Broken</h3>
          <p><strong>What it means:</strong> door drops hard when opened, won't stay open at angle, or cycle won't start. Spring and cable are wear items; latch microswitches fail intermittently on 500/800 past year 5.</p>
          <p><strong>How we fix it:</strong> full door spring-and-cable assembly swap, or full latch module replacement. Manufacturer-approved parts. 30–40 minutes on site.</p>
        </div>
        <div class="problem-card">
          <h3>Control Board / Touch Panel Dead</h3>
          <p><strong>What it means:</strong> no lights, unresponsive touch controls, random errors that don't match symptoms. LA's power surges during brownout months are the usual culprit.</p>
          <p><strong>How we fix it:</strong> isolate main control board from user interface — they fail separately. Replace whichever is failing. 800 Series boards in stock.</p>
        </div>
        <div class="problem-card">
          <h3>Not Drying (Benchmark CrystalDry)</h3>
          <p><strong>What it means:</strong> dishes come out wet on Benchmark units with CrystalDry zeolite drying. Zeolite saturated or drying sensor failed.</p>
          <p><strong>How we fix it:</strong> test drying module and blower fan. Replace zeolite unit if saturated. Benchmark-specific part, 24-hour order when not on the truck.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 8. BUILT-IN / PANEL-READY NON-INVASIVE DIAGNOSTIC -->
  <section class="builtin">
    <div class="container container-narrow">
      <div class="section-heading">
        <span class="section-num">04</span>
        <h2>Panel-Ready &amp; Built-In Bosch Dishwashers — Non-Invasive Service</h2>
      </div>
      <p>
        Half of the Bosch dishwashers we service in Bel Air, Holmby Hills, Pacific
        Palisades, and Beverly Hills flats are panel-ready — custom millwork
        attached to the door, integrated flush with the surrounding cabinetry.
        One scratch to the adjacent cabinetry or wood floor during an extraction
        is a $2,000–$8,000 cabinet-maker callback.
      </p>
      <div class="builtin-list">
        <div class="bl-item">
          <div class="bl-num">1</div>
          <div>
            <strong>Protective floor covering before anything else.</strong>
            Moving blankets under the unit footprint, cardboard runner from
            kitchen to front door if we need to stage parts outside.
          </div>
        </div>
        <div class="bl-item">
          <div class="bl-num">2</div>
          <div>
            <strong>Custom panel documented and detached carefully.</strong>
            We photograph the installation (hinge position, toe-kick alignment,
            rubber gaskets) before touching a screw, so reinstall is identical
            to original.
          </div>
        </div>
        <div class="bl-item">
          <div class="bl-num">3</div>
          <div>
            <strong>Controlled extraction.</strong> Level adjusters retracted
            evenly. Unit walked out on protective sliders, never dragged. No
            pressure on the adjacent cabinet faces.
          </div>
        </div>
        <div class="bl-item">
          <div class="bl-num">4</div>
          <div>
            <strong>Reinstall to exact original fit.</strong> Panel gap
            tolerances re-checked against pre-service photos. Level adjusters
            re-set. Door swing checked. No cosmetic damage is the standard, not
            a hope.
          </div>
        </div>
      </div>
      <p class="builtin-note">
        Built-in service takes 20–30 minutes longer than a standard call. The
        price is the same — we don't charge extra for doing the job properly.
      </p>
    </div>
  </section>

  <!-- 9. MODELS -->
  <section class="models">
    <div class="container">
      <div class="section-heading">
        <span class="section-num">05</span>
        <h2>Bosch Dishwasher Models We Service</h2>
      </div>
      <p class="section-lead">
        Our technicians are trained across the full US-market Bosch dishwasher
        lineup. These are the series and common LA model numbers — if yours isn't
        listed, call us anyway, we almost certainly do it.
      </p>
      <div class="models-grid">
        <div class="models-col">
          <h3>Benchmark Series</h3>
          <p class="series-desc">Flagship. CrystalDry zeolite drying, flexible third rack, 38 dBA.</p>
          <ul>
            <li>SHP88PZ55N</li><li>SHV88PZ53N</li><li>SHP9PCM5N</li>
            <li>SHV9PCM53N</li><li>SHE89PW75N</li>
          </ul>
        </div>
        <div class="models-col">
          <h3>800 Series</h3>
          <p class="series-desc">The LA workhorse. Most common we repair. 42 dBA, MyWay third rack.</p>
          <ul>
            <li>SHPM88Z75N</li><li>SHXM88Z75N</li><li>SHP865ZD5N</li>
            <li>SHX878ZD5N</li><li>SHV878ZD3N</li><li>SHP878ZD5N</li>
          </ul>
        </div>
        <div class="models-col">
          <h3>500 Series</h3>
          <p class="series-desc">Mid-tier. Third rack optional, 44 dBA. Strong reliability after break-in.</p>
          <ul>
            <li>SHPM65Z55N</li><li>SHEM63W55N</li><li>SHPM65W55N</li>
            <li>SHX65Q55N</li><li>SHE53B75N</li>
          </ul>
        </div>
        <div class="models-col">
          <h3>300 Series</h3>
          <p class="series-desc">Entry tier. 46 dBA, no third rack. Common in rentals and secondary kitchens.</p>
          <ul>
            <li>SHE3AR75UC</li><li>SHXM4AY55N</li><li>SHX3AR75UC</li>
            <li>SHEM3AY55N</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- 10. FACTORY SERVICE COMPARISON -->
  <section class="comparison">
    <div class="container container-narrow">
      <div class="section-heading">
        <span class="section-num">06</span>
        <h2>How Our Pricing Compares to Bosch Factory Service</h2>
      </div>
      <p class="section-lead">
        Bosch Factory Service is one option after warranty expires. Here's how
        our LA pricing stacks up, based on Bosch's publicly posted rates.
      </p>
      <div class="compare-table">
        <div class="compare-row compare-header">
          <span>Cost Item</span>
          <span>Bosch Factory Service</span>
          <span>Same Day Appliance Repair</span>
        </div>
        <div class="compare-row">
          <span>Call-out / trip fee</span>
          <span>$179 flat</span>
          <span>$0 separate trip fee</span>
        </div>
        <div class="compare-row">
          <span>Diagnostic fee</span>
          <span>$25 per 6 minutes (metered)</span>
          <span>$89 flat — waived with repair</span>
        </div>
        <div class="compare-row">
          <span>Labor during repair</span>
          <span>$25 per 6 minutes (metered)</span>
          <span>Flat price quoted before work</span>
        </div>
        <div class="compare-row">
          <span>Parts</span>
          <span>Bosch manufacturer-approved</span>
          <span>Bosch manufacturer-approved</span>
        </div>
        <div class="compare-row">
          <span>Panel-ready / built-in handling</span>
          <span>Standard pull-out</span>
          <span>Non-invasive protocol (no extra charge)</span>
        </div>
      </div>
      <p class="compare-note">
        Typical drain pump replacement: Bosch Factory Service pricing works out
