---
// src/pages/brands/ge-cooktop-repair.astro
// Niche combo, GE cooktop repair (~0 GSC impressions; brand portfolio completion).
// Parent: /brands/ge/. Voice: Haier ownership since 2016, Louisville KY manufacturing,
// GE / Profile / Café / Monogram tier distinction, control board solder-joint failure pattern.
import Layout from '../../layouts/Layout.astro';
import ServiceHero from '../../components/ServiceHero.astro';
import { MAIN_PHONE } from '../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/brands/ge-cooktop-repair/";

const title = "GE Cooktop Repair, Profile · Café · Monogram | Same Day Appliance Repair";
const description = `GE cooktop repair across SoCal, base GE, Profile (PHB / PP), Café (CHP / CGP), Monogram (ZGU / ZHU). $89 dx waived. BHGS #A49573. Call.`;

const faqs = [
  {
    q: "What's the difference between GE, Profile, Café, and Monogram cooktops?",
    a: "Four tiers from the same Louisville, Kentucky engineering platform. Base GE cooktops (JP / JEP series), value-tier with mechanical or basic electronic controls. GE Profile (PHB / PP series), premium consumer tier, advanced touch controls, fit-and-finish upgrade. GE Café (CHP / CGP series), design-forward premium, customizable hardware (brushed bronze, brushed copper, matte white finishes), shares engineering with Profile but adds finish-specific cosmetic items. GE Monogram (ZGU / ZHU series), luxury tier with built-in pro-style cooktop hardware competing with Wolf and Thermador. Service tree differs slightly per tier, base GE and Profile share most parts, Café adds finish-specific cosmetic items, Monogram has dedicated heavy-duty components.",
  },
  {
    q: "Why does my GE Profile induction cooktop show a 'C' code or random shutoff?",
    a: "GE Profile induction cooktops have a documented control-board solder-joint failure pattern, the same family of failures that affects GE control boards across the lineup. Symptoms include intermittent C-codes, individual zones cutting out mid-cook, or full cooktop shutdowns that resolve after a power cycle. The root cause is solder joints under the IGBT power transistors fatiguing from thermal cycling. Diagnostic order: full breaker reset for 10 minutes (clears latched faults, about 15% resolve here at no parts cost), reseat connectors at the control board, then determine whether reflow / replacement is needed. Replacement on the main control board $345-$525 depending on Profile model and parts availability through GE/Haier authorized distribution.",
  },
  {
    q: "How much does GE cooktop repair cost?",
    a: `Diagnostic is $89, applied toward the repair when you approve work. Common GE cooktop repair ranges: spark electrode or ignition switch (gas) $145-$285; gas valve assembly $280-$440; bake / surface element on JEP / JP electric coil $145-$245; radiant element on glass-top $185-$285; induction zone module on Profile / Café induction $345-$525; main control board $345-$525; touch control glass + assembly $480-$780; full glass-ceramic surface replacement $620-$980. Profile and Café tiers add roughly 15-25% above base GE; Monogram adds 30-50% given dedicated parts and pro-style components. We give a written estimate before any work begins.`,
  },
];

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": canonical + "#service",
    "serviceType": "GE Cooktop Repair",
    "name": "GE Cooktop Repair, Same Day Appliance Repair",
    "url": canonical,
    "description": "Same-day GE cooktop repair across Los Angeles, Orange, Ventura, San Bernardino, and Riverside counties. Base GE (JP / JEP), Profile (PHB / PP), Café (CHP / CGP), Monogram (ZGU / ZHU). Induction, gas, electric glass-top, electric coil. Control boards, induction modules, spark electrodes, gas valves, glass-ceramic surfaces. $89 residential diagnostic, applied toward repair.",
    "provider": {
      "@type": "LocalBusiness",
      "name": "Same Day Appliance Repair",
      "url": "https://samedayappliance.repair/",
      "telephone": phone,
      "priceRange": "$$$",
    },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" },
    ],
    "offers": {
      "@type": "Offer",
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "89.00",
        "priceCurrency": "USD",
        "description": "Residential diagnostic fee, applied toward repair",
      },
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map((f) => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "GE", "item": "https://samedayappliance.repair/brands/ge/" },
      { "@type": "ListItem", "position": 4, "name": "GE Cooktop Repair", "item": canonical },
    ],
  },
];
---

<Layout title={title} description={description} canonical={canonical}>

<Fragment slot="head-scripts">
  {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
</Fragment>

<ServiceHero
  eyebrow="LA · Orange · Ventura · San Bernardino · Riverside Counties"
  title="GE Cooktop Repair, Across Southern California"
  subtitle="Base GE, Profile (PHB / PP), Café (CHP / CGP), Monogram (ZGU / ZHU). Induction, gas, electric glass-top. Control boards, igniters, induction modules. $89 diagnostic, applied toward repair."
  heroImageTitle="GE Cooktop Repair"
  showBranches={true}
/>

<!-- 01 INTRO -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">01, About this service</p>
    <h2 class="section-title">GE cooktops across base, Profile, Café, and Monogram tiers.</h2>

    <p>GE Appliances has been a Haier-owned subsidiary since 2016, with engineering and manufacturing concentrated at Appliance Park in Louisville, Kentucky. The cooktop catalog spans four tiers from the same engineering platform: base GE (JP / JEP series), GE Profile (PHB / PP series with premium controls and finishes), GE Café (CHP / CGP series with customizable hardware), and GE Monogram (ZGU / ZHU pro-style luxury cooktops competing with Wolf and Thermador). We service all four tiers across our 5-county Southern California territory.</p>

    <p>The most consequential thing to know about GE cooktop service is the <strong>control board solder-joint failure pattern</strong> documented across GE Profile and Café electronic controls, the same root cause affecting GE refrigerator and dishwasher control boards. Solder joints under power transistors fatigue from thermal cycling, producing intermittent codes, random shutoffs, and zone failures. Diagnostic order: full breaker reset (clears latched faults), connector reseat, then board replacement if needed. Parts availability through Haier authorized distribution is unchanged from pre-2016. <a href="/brands/ge/">Brand hub</a> covers GE refrigerators, ranges, ovens, dishwashers, and laundry; this page is cooktop-specific.</p>
  </div>
</section>

<!-- 02 COMMON FAILURES -->
<section class="section section-gray">
  <div class="container">
    <p class="section-number">02, Common failures</p>
    <h2 class="section-title">What we diagnose most often on GE cooktops.</h2>

    <div class="problem-grid">
      <div class="problem-card">
        <h3>Profile / Café control board solder-joint failure</h3>
        <p>Documented GE pattern, solder joints under IGBT power transistors fatigue from thermal cycling. Symptoms: intermittent C-codes, single zones cutting out mid-cook, full cooktop shutdowns that resolve after a power cycle. Diagnostic starts with full 10-minute breaker reset (about 15% resolve here at no parts cost), then connector reseat, then board replacement at $345-$525.</p>
      </div>
      <div class="problem-card">
        <h3>Touch control glass unresponsive</h3>
        <p>Profile / Café cooktops use touch-glass controls sensitive to liquid intrusion at the front edge seal. Boil-over running across the front edge can short the touch traces, leaving controls unresponsive in one zone or globally. Replacement is the glass-and-touch-assembly part. We confirm failure mode with a power-cycle reset before quoting because apparent touch failures sometimes resolve at reset.</p>
      </div>
      <div class="problem-card">
        <h3>Gas burner won't ignite (JGP / Profile gas)</h3>
        <p>Spark clicks but no flame. Most common cause is corroded or wet spark electrode at the burner base, spilled liquid shorting the spark path. About 35% of single-burner ignition calls resolve at the cleaning step with no parts cost. Remaining failures: clogged orifice, failed ignition switch ($145-$245), gas valve failure ($280-$440), or spark module on multiple-burner failure.</p>
      </div>
      <div class="problem-card">
        <h3>Induction zone module failure (Profile / Café induction)</h3>
        <p>One zone of the induction surface stops heating while others still function. The cooktop's modular architecture means failure is module-level rather than full-cooktop, repair scope is one module replacement at $345-$525 plus diagnostic verification. We confirm whether the issue is module-level or full control board before quoting.</p>
      </div>
    </div>
  </div>
</section>

<!-- 03 MODELS -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">03, GE cooktop models we service</p>
    <h2 class="section-title">Base GE, Profile, Café, Monogram.</h2>

    <p><strong>Base GE (JP / JEP series):</strong> JP3030, JP3036, JEP4030, JEP5030, value-tier 30" gas and electric cooktops with mechanical or basic-electronic controls. Common service: spark electrodes, ignition switches, surface elements, oven sensor.</p>

    <p><strong>GE Profile (PHB / PP series):</strong> PHB920SJSS, PP9030SJSS, PP9036SJSS, premium 30" and 36" induction, gas, and electric glass-top cooktops with advanced touch controls. Common service: control boards (solder-joint pattern), induction modules, touch glass, gas valves.</p>

    <p><strong>GE Café (CHP / CGP series):</strong> CHP90301TSS, CGP9536SLSS, CGP6536SLSS, design-forward 30" and 36" induction and gas cooktops with customizable hardware finishes (brushed bronze, brushed copper, matte white). Same engineering platform as Profile with finish-specific cosmetic parts.</p>

    <p><strong>GE Monogram (ZGU / ZHU series):</strong> ZGU384LSS, ZGU484LSS, ZHU30RSPSS, luxury pro-style 30", 36", and 48" gas cooktops with brass burner hardware competing with Wolf and Thermador. Dedicated parts chain through GE Monogram authorized distribution. Common service: brass burner caps, ignition system, gas valves, premium hardware.</p>
  </div>
</section>

<!-- 04 PRICING -->
<section class="section section-gray">
  <div class="container">
    <p class="section-number">04, Pricing</p>
    <h2 class="section-title">GE cooktop repair pricing.</h2>

    <p class="lead">Diagnostic is $89, applied toward the repair when you approve work. Profile / Café tiers add 15-25% above base GE; Monogram adds 30-50% given dedicated parts. Written estimate before any parts go on.</p>

    <div class="pricing-grid">
      <div class="price-card">
        <div class="price-label">Diagnostic</div>
        <div class="price-amount">$89</div>
        <div class="price-desc">Waived when you approve repair</div>
      </div>
      <div class="price-card">
        <div class="price-label">Standard band</div>
        <div class="price-amount">$145–$285</div>
        <div class="price-desc">Spark electrode · ignition switch · element</div>
      </div>
      <div class="price-card">
        <div class="price-label">Control board / induction module</div>
        <div class="price-amount">$345–$525</div>
        <div class="price-desc">Profile / Café board · induction zone module</div>
      </div>
      <div class="price-card">
        <div class="price-label">Touch glass / surface</div>
        <div class="price-amount">$480–$980</div>
        <div class="price-desc">Touch assembly · full glass-ceramic surface</div>
      </div>
    </div>

    <p class="price-note">Gas valve replacement $280-$440. Monogram pro-style cooktops carry premium parts uplift through dedicated GE Monogram authorized distribution. Burner cap and head replacement on Monogram brass hardware $245-$385 per burner. We tell you the tier-specific cost differential before you authorize repair.</p>
  </div>
</section>

<!-- 05 FAQ -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">05, FAQ</p>
    <h2 class="section-title">GE cooktop repair, common questions.</h2>

    <div class="faq-list">
      {faqs.map((f) => (
        <details class="faq-item">
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- 06 BOTTOM CTA -->
<section class="bottom-cta">
  <div class="container">
    <h2>GE cooktop down? Same-day service across Southern California.</h2>
    <p>$89 diagnostic, applied toward the repair. Base GE, Profile, Café, Monogram, Louisville KY platform service across all five SoCal counties.</p>
    <div class="cta-row">
      <a href={phoneHref} class="btn-primary">☎ Call {phone}</a>
      <a href="/contact/" class="btn-secondary">Book Online</a>
    </div>
  </div>
</section>

</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .section { padding: 72px 24px; }
  .section-gray { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; }
  .container.narrow { max-width: 820px; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  h2.section-title { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; margin: 0 0 20px; line-height: 1.2; color: var(--text); }
  .lead { font-size: 1.05rem; line-height: 1.75; color: var(--text); margin-bottom: 20px; }
  .section p { margin: 0 0 18px; font-size: 1rem; line-height: 1.75; color: var(--text); }
  .section a { color: var(--red); font-weight: 600; text-decoration: none; }
  .section a:hover { text-decoration: underline; }

  .problem-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-top: 32px; }
  .problem-card { background: #fff; border: 1px solid var(--border); border-left: 4px solid var(--red); border-radius: 6px; padding: 26px 28px; }
  .problem-card h3 { font-size: 1.1rem; font-weight: 800; margin: 0 0 12px; color: var(--text); }
  .problem-card p { font-size: 0.95rem; color: var(--text); margin: 0; line-height: 1.7; }
  @media (max-width: 768px) { .problem-grid { grid-template-columns: 1fr; } }

  .pricing-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-top: 32px; }
  .price-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 26px 22px; text-align: center; }
  .price-card .price-label { font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--muted); margin-bottom: 10px; font-weight: 700; }
  .price-card .price-amount { font-size: 1.85rem; font-weight: 800; color: var(--text); line-height: 1; margin-bottom: 10px; }
  .price-card .price-desc { font-size: 0.85rem; color: var(--muted); line-height: 1.55; }
  .price-note { margin-top: 24px; font-size: 0.95rem; color: var(--text); line-height: 1.7; }

  .faq-list { margin-top: 32px; }
  .faq-item { background: #fff; border: 1px solid var(--border); border-radius: 6px; padding: 18px 22px; margin-bottom: 12px; }
  .faq-item summary { font-weight: 700; cursor: pointer; font-size: 1rem; color: var(--text); list-style: none; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::before { content: "+ "; color: var(--red); font-weight: 800; margin-right: 6px; }
  .faq-item[open] summary::before { content: "− "; }
  .faq-item p { font-size: 0.95rem; color: var(--text); line-height: 1.75; margin: 14px 0 0; }

  .bottom-cta { background: var(--black); color: #fff; padding: 72px 24px; text-align: center; }
  .bottom-cta h2 { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; margin: 0 0 16px; color: #fff; line-height: 1.25; }
  .bottom-cta p { color: #c9c9c9; margin: 0 0 30px; font-size: 1.02rem; line-height: 1.6; }
  .cta-row { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 16px 34px; border-radius: 5px; font-size: 1rem; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 16px 34px; border-radius: 5px; font-size: 1rem; font-weight: 600; text-decoration: none; border: 2px solid rgba(255,255,255,0.35); }
</style>
