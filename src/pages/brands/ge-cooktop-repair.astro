import BrandDetailPlaceholder from '../../components/BrandDetailPlaceholder.astro';

const title = "GE Cooktop Repair | Southern California | Same Day Service";
const description = "Expert GE cooktop repair across Southern California. Same-day appointments, OEM parts, licensed technicians. Call (424) 325-0520.";
