---
import Layout from '../../layouts/Layout.astro';
import BrandDetailPlaceholder from '../../components/BrandDetailPlaceholder.astro';

const title = "Frigidaire Refrigerator Repair Los Angeles | Gallery, Pro";
const description = "Frigidaire fridge repair across LA — Gallery, Professional, French Door, side-by-side. Electrolux-owned since 1986. $89 diagnostic waived. (424) 325-0520.";
const canonical = "https://samedayappliance.repair/brands/frigidaire-refrigerator-repair/";
---

<Layout title={title} description={description} canonical={canonical}>
  <BrandDetailPlaceholder
    brandName="Frigidaire"
    brandSlug="frigidaire"
    category="Refrigerator"
    categorySlug="refrigerator-repair"
    hubUrl="/brands/frigidaire/"
  />
</Layout>
