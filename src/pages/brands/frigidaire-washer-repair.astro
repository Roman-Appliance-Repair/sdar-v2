---
// src/pages/brands/frigidaire-washer-repair.astro
// Niche combo — Frigidaire washer repair (~0 GSC impressions; brand portfolio completion).
// Parent: /brands/frigidaire/. Voice: Electrolux ownership, Augusta GA laundry plant,
// E10/E20/E30/E70 fault codes, Affinity FAFW front-load, basic top-load FFTW.
import Layout from '../../layouts/Layout.astro';
import ServiceHero from '../../components/ServiceHero.astro';
import { MAIN_PHONE } from '../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/brands/frigidaire-washer-repair/";

const title = "Frigidaire Washer Repair — Affinity Front-Load · Top-Load · E10 / E20 / E70 | Same Day Appliance Repair";
const description = `Frigidaire washer repair across Southern California — Affinity FAFW front-load, FFTW top-load, Gallery FFFW. E10 / E20 / E30 / E70 diagnostic codes. Drain pump, lid switch, door latch, drive belt. $89 diagnostic, applied toward repair. Call ${phone}.`;

const faqs = [
  {
    q: "What does the E20 code mean on my Frigidaire washer?",
    a: "E20 is the long-drain code on Frigidaire washers (front-load and top-load) — water didn't pump out within the cycle window. Diagnostic order: (1) clogged drain-pump filter — accessible from the lower kickplate on front-load Affinity FAFW models, about 35% of E20 calls resolve at the filter clean-out; (2) kinked or clogged drain hose; (3) failed drain pump itself — replacement $245-$385; (4) blocked house drain plumbing behind the washer. The E20 fault often pairs with EF0 / EF2 (over-sudsing detection) when too much detergent has been used or non-HE detergent in an HE machine. We work the cheap items first.",
  },
  {
    q: "My Frigidaire front-load washer leaks water during the wash cycle — what's wrong?",
    a: "Most common cause on Affinity FAFW front-load washers is door-boot (bellows) failure. The rubber boot that seals the door against the drum gets cut by underwire bras, coins, or hairpins; small tears leak water during agitation. Door boot replacement $245-$385. Less common causes: failed door latch seal, water-inlet hose connection, or cracked detergent dispenser housing. We pull the front panel and inspect the boot path before quoting because a torn boot often has secondary issues (mold buildup, wash-cycle balance issues) that should be addressed at the same time.",
  },
  {
    q: "How much does Frigidaire washer repair cost?",
    a: `Diagnostic is $89, applied toward the repair when you approve work. Common Frigidaire washer repair ranges: lid switch (top-load) $145-$245; door latch / lock (front-load) $185-$285; drain pump $245-$385; door boot / bellows (front-load) $245-$385; water inlet valve $185-$285; pressure switch $185-$285; drive belt $185-$285; motor coupling $245-$345; main control board $345-$525. Frigidaire Gallery uplift typically 10-15% above base. We give a written estimate before any work begins. Most Frigidaire washer repairs complete same-day with parts on the truck.`,
  },
];

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": canonical + "#service",
    "serviceType": "Frigidaire Washer Repair",
    "name": "Frigidaire Washer Repair — Same Day Appliance Repair",
    "url": canonical,
    "description": "Same-day Frigidaire washer repair across Los Angeles, Orange, Ventura, San Bernardino, and Riverside counties. Affinity FAFW front-load, FFTW top-load, Gallery FFFW. E10 / E20 / E30 / E70 / EF0 fault codes. Drain pumps, door boots, lid switches, water inlet valves, drive belts, motor couplings, control boards. Electrolux platform. $89 residential diagnostic, applied toward repair.",
    "provider": {
      "@type": "LocalBusiness",
      "name": "Same Day Appliance Repair",
      "url": "https://samedayappliance.repair/",
      "telephone": phone,
      "priceRange": "$$",
    },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" },
    ],
    "offers": {
      "@type": "Offer",
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "89.00",
        "priceCurrency": "USD",
        "description": "Residential diagnostic fee, applied toward repair",
      },
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map((f) => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "Frigidaire", "item": "https://samedayappliance.repair/brands/frigidaire/" },
      { "@type": "ListItem", "position": 4, "name": "Frigidaire Washer Repair", "item": canonical },
    ],
  },
];
---

<Layout title={title} description={description} canonical={canonical}>

<Fragment slot="head-scripts">
  {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
</Fragment>

<ServiceHero
  eyebrow="LA · Orange · Ventura · San Bernardino · Riverside Counties"
  title="Frigidaire Washer Repair — Across Southern California"
  subtitle="Affinity FAFW front-load, FFTW top-load, Gallery FFFW. E10 / E20 / E30 / E70 diagnostic codes. Drain pump, door boot, lid switch, drive belt. Electrolux platform. $89 diagnostic, applied toward repair."
  heroImageTitle="Frigidaire Washer Repair"
  showBranches={true}
/>

<!-- 01 INTRO -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">01 — About this service</p>
    <h2 class="section-title">Frigidaire washers on the Electrolux platform.</h2>

    <p>Frigidaire has been part of Electrolux since 1986, with US laundry manufacturing concentrated in Augusta, Georgia. The washer catalog spans three lines: Affinity front-load (FAFW series — the brand's flagship front-load platform from the late-2000s through current production), FFTW top-load (entry-tier top-load with mechanical agitator), and the Gallery FFFW front-load tier (premium controls, steam cycles, Wi-Fi on newer models). We service all three across our 5-county Southern California territory.</p>

    <p>Frigidaire's E-series fault codes are some of the more direct diagnostic paths in the appliance industry — E10 (water-fill problem), E20 (long-drain), E30 (drum overfill), E70 (cold-water-only inlet fault), and the EF-series for over-sudsing detection (EF0 / EF2). About 30% of Frigidaire washer codes resolve at the homeowner-troubleshooting layer (power cycle, water-supply check, filter clean-out) at no parts cost. <a href="/brands/frigidaire/">Brand hub</a> covers Frigidaire's full appliance lineup; this page is washer-specific.</p>
  </div>
</section>

<!-- 02 COMMON FAILURES -->
<section class="section section-gray">
  <div class="container">
    <p class="section-number">02 — Common failures</p>
    <h2 class="section-title">What we diagnose most often on Frigidaire washers.</h2>

    <div class="problem-grid">
      <div class="problem-card">
        <h3>E20 long-drain code (front-load + top-load)</h3>
        <p>Water didn't pump out in the cycle window. Diagnostic order: clogged drain-pump filter (front-load Affinity has it accessible from the lower kickplate; about 35% resolve here at no parts cost), kinked drain hose, failed drain pump ($245-$385), blocked house drain. E20 often pairs with EF0 / EF2 over-sudsing codes when non-HE detergent has been used in an HE machine.</p>
      </div>
      <div class="problem-card">
        <h3>Door boot tear (Affinity FAFW front-load)</h3>
        <p>Most common front-load washer leak. The rubber boot sealing the door against the drum gets cut by underwire bras, coins, or hairpins. Small tears leak water during agitation; the laundry-room floor shows water after a wash cycle. Boot replacement $245-$385. We also clean any mold buildup behind the boot — common on year-5+ front-load Frigidaire units, especially when the door is left closed between cycles.</p>
      </div>
      <div class="problem-card">
        <h3>Lid switch failure (FFTW top-load)</h3>
        <p>FFTW top-load Frigidaire washers won't agitate or spin when the lid switch reads open — a safety lockout. Failed switch reads "open" even when the lid is closed, the washer stops mid-cycle. Replacement $145-$245. Common wear pattern at year 4-7. About 60% of "won't spin" calls on top-load Frigidaire trace here.</p>
      </div>
      <div class="problem-card">
        <h3>E10 water-fill fault</h3>
        <p>Water isn't entering the machine. Diagnostic order: confirm water-supply taps are open, inspect inlet hoses for kinks, check the screen filter at the inlet valve (often clogged in hard-water areas like the Inland Empire and parts of the SFV), replace water inlet valve if the screens are clean and water pressure is confirmed. Inlet valve replacement $185-$285.</p>
      </div>
    </div>
  </div>
</section>

<!-- 03 MODELS -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">03 — Frigidaire washer models we service</p>
    <h2 class="section-title">Affinity FAFW, FFTW top-load, Gallery FFFW.</h2>

    <p><strong>Affinity FAFW front-load:</strong> FAFW3801, FAFW3517, FAFW4011, FAFW3577 — the brand's flagship front-load platform from the late-2000s through current production. Common service: door boot, drain pump, door latch, water inlet valve, control board.</p>

    <p><strong>FFTW top-load:</strong> FFTW4120, FFTW4220, FFTW4225 — entry-tier top-load washers with mechanical agitator and basic electronic controls. Common service: lid switch, drain pump, drive belt, motor coupling, water inlet valve.</p>

    <p><strong>Gallery FFFW front-load:</strong> FFFW5170, FFFW5000, GLEH1642 — premium-tier front-load washers with steam cycles, Wi-Fi connectivity on newer models, and improved drain-pump filter access. Common service mirrors Affinity FAFW plus advanced control board diagnostics.</p>

    <p><strong>Frigidaire Professional:</strong> Discontinued or narrowed Professional washers from late-2010s production are still serviceable through Electrolux authorized parts; we identify production year from the model and serial tag before scheduling.</p>
  </div>
</section>

<!-- 04 PRICING -->
<section class="section section-gray">
  <div class="container">
    <p class="section-number">04 — Pricing</p>
    <h2 class="section-title">Frigidaire washer repair pricing.</h2>

    <p class="lead">Diagnostic is $89, applied toward the repair when you approve work. Frigidaire Gallery uplift typically 10-15% above base. Written estimate before any parts go on.</p>

    <div class="pricing-grid">
      <div class="price-card">
        <div class="price-label">Diagnostic</div>
        <div class="price-amount">$89</div>
        <div class="price-desc">Waived when you approve repair</div>
      </div>
      <div class="price-card">
        <div class="price-label">Standard band</div>
        <div class="price-amount">$145–$285</div>
        <div class="price-desc">Lid switch · door latch · water valve · belt</div>
      </div>
      <div class="price-card">
        <div class="price-label">Drain pump / door boot</div>
        <div class="price-amount">$245–$385</div>
        <div class="price-desc">E20 pump · Affinity bellows replacement</div>
      </div>
      <div class="price-card">
        <div class="price-label">Major component</div>
        <div class="price-amount">$345–$525</div>
        <div class="price-desc">Main control board · motor coupling rebuild</div>
      </div>
    </div>

    <p class="price-note">Year-12+ Affinity front-load units approaching $400+ in repair: we'll tell you the math against replacement on a comparable Frigidaire or Gallery unit. Front-load mechanics get more expensive at the back end of their service life because the door boot, drum bearing, and shock absorbers tend to wear together.</p>
  </div>
</section>

<!-- 05 FAQ -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">05 — FAQ</p>
    <h2 class="section-title">Frigidaire washer repair — common questions.</h2>

    <div class="faq-list">
      {faqs.map((f) => (
        <details class="faq-item">
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- 06 BOTTOM CTA -->
<section class="bottom-cta">
  <div class="container">
    <h2>Frigidaire washer down? Same-day service across Southern California.</h2>
    <p>$89 diagnostic, applied toward the repair. Affinity, FFTW, Gallery — Electrolux platform service across all five SoCal counties.</p>
    <div class="cta-row">
      <a href={phoneHref} class="btn-primary">☎ Call {phone}</a>
      <a href="/contact/" class="btn-secondary">Book Online</a>
    </div>
  </div>
</section>

</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .section { padding: 72px 24px; }
  .section-gray { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; }
  .container.narrow { max-width: 820px; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  h2.section-title { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; margin: 0 0 20px; line-height: 1.2; color: var(--text); }
  .lead { font-size: 1.05rem; line-height: 1.75; color: var(--text); margin-bottom: 20px; }
  .section p { margin: 0 0 18px; font-size: 1rem; line-height: 1.75; color: var(--text); }
  .section a { color: var(--red); font-weight: 600; text-decoration: none; }
  .section a:hover { text-decoration: underline; }

  .problem-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-top: 32px; }
  .problem-card { background: #fff; border: 1px solid var(--border); border-left: 4px solid var(--red); border-radius: 6px; padding: 26px 28px; }
  .problem-card h3 { font-size: 1.1rem; font-weight: 800; margin: 0 0 12px; color: var(--text); }
  .problem-card p { font-size: 0.95rem; color: var(--text); margin: 0; line-height: 1.7; }
  @media (max-width: 768px) { .problem-grid { grid-template-columns: 1fr; } }

  .pricing-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-top: 32px; }
  .price-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 26px 22px; text-align: center; }
  .price-card .price-label { font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--muted); margin-bottom: 10px; font-weight: 700; }
  .price-card .price-amount { font-size: 1.85rem; font-weight: 800; color: var(--text); line-height: 1; margin-bottom: 10px; }
  .price-card .price-desc { font-size: 0.85rem; color: var(--muted); line-height: 1.55; }
  .price-note { margin-top: 24px; font-size: 0.95rem; color: var(--text); line-height: 1.7; }

  .faq-list { margin-top: 32px; }
  .faq-item { background: #fff; border: 1px solid var(--border); border-radius: 6px; padding: 18px 22px; margin-bottom: 12px; }
  .faq-item summary { font-weight: 700; cursor: pointer; font-size: 1rem; color: var(--text); list-style: none; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::before { content: "+ "; color: var(--red); font-weight: 800; margin-right: 6px; }
  .faq-item[open] summary::before { content: "− "; }
  .faq-item p { font-size: 0.95rem; color: var(--text); line-height: 1.75; margin: 14px 0 0; }

  .bottom-cta { background: var(--black); color: #fff; padding: 72px 24px; text-align: center; }
  .bottom-cta h2 { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; margin: 0 0 16px; color: #fff; line-height: 1.25; }
  .bottom-cta p { color: #c9c9c9; margin: 0 0 30px; font-size: 1.02rem; line-height: 1.6; }
  .cta-row { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 16px 34px; border-radius: 5px; font-size: 1rem; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 16px 34px; border-radius: 5px; font-size: 1rem; font-weight: 600; text-decoration: none; border: 2px solid rgba(255,255,255,0.35); }
</style>
