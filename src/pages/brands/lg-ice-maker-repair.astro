---
import Layout from '../../layouts/Layout.astro';

const title = "LG Ice Maker Repair LA | Craft Ice Sphere + InstaView";
const description = "LG ice maker repair in LA — Craft Ice spherical ice, InstaView French-door, LRFVC/LRFDS models. LT800P filter, auger motor, ER-code diagnostic. $89 diagnostic. (424) 325-0520.";
const canonical = "https://samedayappliance.repair/brands/lg-ice-maker-repair/";

const faqs = [
  {
    q: "What is LG Craft Ice and what goes wrong with it?",
    a: "<b>Craft Ice</b> is LG's 2019+ signature feature on InstaView French-door refrigerators (LRFVC / LRFOC model families) — a dedicated secondary ice maker that produces 2\" diameter crystal-clear spherical ice for whiskey and cocktails, typically 3-4 spheres per day via a 4-stage slow-freeze mechanism with a dedicated auger. When Craft Ice fails: (1) Craft Ice auger motor — highest-frequency Craft Ice fault; motor swap $320–$480 (LG-specific Craft Ice auger, not interchangeable with standard auger); (2) ice-tray heater element (the controlled-melt element that slow-forms the sphere) $260–$380; (3) Craft Ice-specific water-inlet solenoid $240–$340; (4) control-board Craft Ice cycle logic $440–$640. Standard cube ice maker on the same unit operates independently — Craft Ice failure doesn't break regular ice production."
  },
  {
    q: "My LG ice maker stopped making ice entirely — what's the diagnostic order?",
    a: "Standard LG ice maker diagnostic: (1) LG-specific ice-maker test-mode — press the test button for 3 seconds, observe ejector rotation + fill cycle — tells us whether motor, heater, sensor, or water-valve side; (2) water-inlet valve — LG valves fail at 4-7 year mark on LA hard water; valve swap $220–$340; (3) ice-maker assembly module (LG uses a common modular ice maker across many models) — full module $280–$420; (4) water filter LT800P clog — clogged filter reduces fill pressure; filter $60–$90 as routine replacement every 6 months; (5) thermistor / ice-bin sensor $180–$280; (6) ejector motor inside the modular ice maker $180–$280; (7) ER-code readout from control panel (ER FF = fan; ER IF = ice-maker fan; ER dH = defrost heater) — specific ER codes narrow diagnostic. Our techs run test-mode diagnostic first before parts ordering."
  },
  {
    q: "What's LG InstaView and does the door-panel affect ice maker service?",
    a: "<b>InstaView</b> is LG's knock-twice-to-view glass panel on the left French-door. On Craft Ice models the ice maker module sits directly behind the InstaView panel. Service access requires temporary removal of the InstaView panel assembly — more involved than standard French-door ice-maker service, but routine for techs familiar with the platform. Service window adds 30-45 minutes vs non-InstaView French-door service. Important: avoid stress on the InstaView glass during reinstall — we use factory-spec alignment checks to prevent panel-seat issues. InstaView ice-maker service uses the same parts as non-InstaView Craft Ice models (the glass panel itself isn't a service component)."
  },
  {
    q: "Is the Linear Compressor class-action affecting my ice maker service?",
    a: "<b>No</b> — the LG Linear Compressor class-action (2014-2017 production years) applies to the main sealed-system compressor, not to the ice maker assembly. Your ice maker can fail completely independent of any compressor-warranty scenario. If your LG refrigerator has compressor-side issues (not cooling, linear-compressor failure) that's a separate service with separate warranty-claim process (LG offers 10-year compressor warranty on Linear Compressor units through 2023 production); if your ice maker specifically is failing (not producing, Craft Ice auger, water-valve, etc.) that's standard LA ice-maker service at our $89 diagnostic regardless of compressor-warranty status. Our diagnostic identifies whether the fault is compressor-side or ice-maker-side before recommending any warranty-claim direction."
  },
  {
    q: "LG ice maker making slushy or undersized ice — what's wrong?",
    a: "Slushy or undersized ice points to freeze-cycle problems: (1) temperature setting — verify freezer compartment at 0°F or colder; setting issue often misread as fault; (2) water-inlet fill time drift — LG control logic uses timed water fill; over-fill creates slush, under-fill creates undersized cubes; fill-timing adjustment + valve inspection $180–$280; (3) thermistor in the ice-maker module — reads ice-tray temp to trigger harvest; drift $180–$280; (4) ambient heat exposure — ice maker module too close to refrigerator heat source via failed gasket / door-seal — door-seal service $180–$260; (5) evaporator fan motor (behind rear wall) — reduced airflow affects freezer-cavity temp consistency; fan motor $260–$380. Our techs verify compartment temp at three points before attributing to ice-maker module itself."
  },
  {
    q: "Can I repair the countertop portable ice maker myself, or do you service those too?",
    a: "LG doesn't currently sell countertop portable ice makers (that's a GE Profile Opal / Igloo / Euhomy / NewAir category). LG ice maker service is exclusively refrigerator-integrated: French-door Craft Ice + standard cube, side-by-side ice + water dispenser, column-integrated ice maker modules. If you have a portable countertop unit, that's bench-serviceable and a different product category — see our <a href='/brands/ge-profile-ice-maker-repair/'>GE Profile</a> or <a href='/brands/ge-ice-maker-repair/'>GE Opal</a> pages if unit is GE-branded, or call for cross-brand portable service."
  },
  {
    q: "What's the difference between LG ice maker service and commercial restaurant-scale ice?",
    a: "LG is residential-only — no LG commercial ice machine line exists. Residential LG ice makers produce 3-8 lb/day typical; commercial restaurant / bar ice machines (Manitowoc, Hoshizaki, Scotsman, Follett) produce 200-2,000+ lb/day with completely different refrigeration architecture, service requirements, and health-department coding. If you're running a restaurant or commercial bar and looking at production-scale ice equipment, see our <a href='/commercial/ice-machine-repair/'>commercial ice machine repair</a> page. This page and our residential LG service covers the refrigerator-integrated ice maker scale only — InstaView French-door, Craft Ice, standard cube, and side-by-side integrated."
  },
  {
    q: "What does LG ice maker repair cost in LA?",
    a: "Residential diagnostic $89 waived with repair. Typical LG ice maker bands: water-inlet valve $220–$340; ice-maker modular assembly (full module) $280–$420; ejector motor (inside module) $180–$280; thermistor / ice-bin sensor $180–$280; LT800P water filter $60–$90 routine; Craft Ice auger motor $320–$480; Craft Ice heater element $260–$380; Craft Ice water-inlet solenoid $240–$340; control board (main or Craft Ice cycle logic) $440–$640; evaporator fan motor $260–$380; door-seal gasket $180–$260; compressor service (if class-action-eligible, separate path). LG parts ship same-day or 1-day LA-local through authorized distribution. Our techs carry the most common LG modular ice-maker parts on the truck for single-visit resolution on 70-80% of calls."
  }
];

const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair — LG Ice Maker Service",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": canonical, "telephone": "+1-424-325-0520", "priceRange": "$$",
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ]
  },
  { "@context": "https://schema.org", "@type": "Service", "serviceType": "LG Ice Maker Repair",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "description": "LG ice maker repair across LA — InstaView French-door with Craft Ice spherical ice maker, LRFVC / LRFOC / LRFDS / LRSDS model families, standard cube + Craft Ice dual systems. Auger motor, water-inlet valve, LT800P filter, ER-code diagnostic. $89 residential diagnostic waived with repair.",
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, waived with repair" } }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "LG", "item": "https://samedayappliance.repair/brands/lg/" },
      { "@type": "ListItem", "position": 4, "name": "LG Ice Maker Repair", "item": canonical }
    ]
  }
];
