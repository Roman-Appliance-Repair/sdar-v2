      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "description": "AHT Cooling Systems plug-in commercial refrigeration repair across Los Angeles — MALTA mode-switchable chests, MIAMI island merchandisers, RIO ice-cream freezers, ATHEN upright merchandisers. Austrian-engineered, Daikin family since 2017. LA grocery, convenience, and specialty retail specialists.",
    "offers": {
      "@type": "Offer",
