---
import Layout from '../../layouts/Layout.astro';
import BrandDetailPlaceholder from '../../components/BrandDetailPlaceholder.astro';

const title = "Viking Refrigerator Repair Los Angeles | Same Day Service";
const description = "Expert Viking refrigerator repair in Los Angeles. Same-day appointments, OEM parts, licensed technicians. Call (424) 325-0520.";
---

<Layout title={title} description={description}>
  <BrandDetailPlaceholder
    brandName="Viking"
    brandSlug="viking"
    category="Refrigerator"
    categorySlug="refrigerator-repair"
    hubUrl="/brands/viking/"
  />
</Layout>
