---
import Layout from '../../layouts/Layout.astro';
import BrandBranchesGrid from '../../components/BrandBranchesGrid.astro';
import { MAIN_PHONE, MAIN_PHONE_TEL } from '../../data/branches';

const title = "Bull Grill Repair | Southern California | Lonestar, Angus, Brahma, Diablo";
const description = "$89 diagnostic waived. Bull grill repair Southern California — Lonestar Select, Angus, Brahma, Diablo. 60k-105k BTU 4/5/6-burner. Ontario CA. (424) 325-0520.";
const canonical = "https://samedayappliance.repair/brands/bull-grill-repair/";

const faqs = [
  {
    q: "Bull grill lineup — Lonestar vs Angus vs Brahma vs Diablo?",
    a: "Bull Outdoor Products ships four built-in/cart tiers in the US. <b>Lonestar Select</b> is the entry tier (3-4 burner, 60-75k BTU output, standard stainless construction, spark ignition) — retail $1,500-$2,500. <b>Angus</b> is the mid tier (4-burner standard, 75-85k BTU, heavier-gauge stainless, upgraded ignition) — retail $2,500-$4,000. <b>Brahma</b> is the premium tier (5-burner, 90-100k BTU, hot-surface igniter on later models, Bull's better-grade stainless + upgraded cooking grates) — retail $3,500-$5,500. <b>Diablo</b> is the flagship (6-burner, up to 105k BTU total output, premium 304 stainless heavy-gauge, infrared rotisserie back burner, integrated lights) — retail $5,000-$7,500. Model name on the control panel + serial plate tells us which tier. Made in Ontario California — LA-adjacent parts chain."
  },
  {
    q: "Ontario California factory — how fast are Bull parts for LA?",
    a: "Bull Outdoor Products manufactures in <b>Ontario California</b> — ~40 miles east of DTLA in the Inland Empire. For LA service this gives Bull <b>2-4 day typical parts delivery</b> on common items, faster than Midwest or East Coast luxury-tier brands (Kalamazoo 5-10 day, Wolf 4-7 day) but not as fast as the 1-3 day LA-local brands (Hestan Anaheim, DCS Huntington Beach via F&P, Thermador BSH Irvine). Common service items — burners, igniters, orifices, thermocouples, control valves — have decent Ontario distributor stock; specialty or discontinued parts may run 1 week factory-direct. The Ontario-adjacent advantage is one of Bull's value propositions in the LA outdoor-kitchen market vs Weber (Illinois) or Napoleon (Ontario Canada)."
  },
  {
    q: "Diablo 105k BTU 6-burner won't reach max temperature — burner or regulator?",
    a: "Diablo is Bull's flagship 6-burner at 105,000 total BTU output. When max-temperature underperforms, common causes: (1) <b>Burner tube clogged</b> — one or more of the 6 burners has reduced output; cleaning service $140-$220 often resolves without parts. (2) <b>Gas regulator drift</b> — high-BTU 6-burner installs put more demand on the regulator; if output drifts 10-15% low, the effect on max temp is meaningful without an obvious failure; $180-$280 replacement. (3) <b>Gas line undersized</b> — sometimes a 6-burner install gets connected to a 4-burner-spec gas line; this isn't a grill repair issue but we'll identify if it's the root cause at diagnostic. (4) <b>Burner-tube warpage</b> at 8-10 year mark — $260-$400 per tube. We test each burner individually before concluding regulator or gas-line issues."
  },
  {
    q: "Hot-surface igniter (Brahma/Diablo later models) stopped working — part or module?",
    a: "Later-model Bull Brahma + Diablo units ship with hot-surface igniters (glow-plug style, electric current heats a ceramic element to ignition temperature). Earlier models use spark ignition. Diagnostic sequence: (1) <b>Igniter resistance check</b> — 40-120 ohms healthy, open-circuit = failed; $160-$260 replacement for Bull-spec igniter. (2) <b>Ignition module output</b> — if igniter tests good but doesn't heat, module may not be driving current; $220-$360 replacement. (3) <b>Wiring harness</b> — outdoor moisture accumulation in connectors; $140-$240 service. (4) <b>Battery</b> on early hybrid ignition systems (spark-assist with hot-surface backup) — $89 diag only, battery included in call. Tell us year + model at booking so we know which ignition architecture you have."
  },
  {
    q: "Entry-tier Lonestar Select vs premium Diablo — does repair economics differ?",
    a: "Yes, meaningfully. <b>Lonestar Select at $1,500-$2,500 retail</b> has a narrower repair-vs-replace window — at 8-10 years with a $400-$600 repair bill, replacement economics can favor buying new (especially if multiple components need attention). <b>Diablo at $5,000-$7,500 retail</b> favors repair well into year 15 — a $500-$800 service call extends service life 3-5 years on components that are still structurally sound. We run honest repair-vs-replace numbers during diagnostic based on: current Bull pricing, your unit's specific failure pattern, remaining useful life of other components, and install complexity if replacement involves outdoor-kitchen cabinetry modifications. The right answer varies by unit — we don't default to repair at all costs."
  },
  {
    q: "What does Bull grill repair cost in LA?",
    a: "Residential diagnostic $89 waived with repair. Typical Bull bands: burner (Lonestar/Angus) $180–$280; burner (Brahma/Diablo) $260–$400; burner cleaning service $140–$220; spark module (earlier models) $140–$220; hot-surface igniter (later Brahma/Diablo) $160–$260; ignition module $220–$360; infrared rotisserie back burner (Diablo) $200–$320; rotisserie motor $240–$380; gas regulator $180–$280; thermocouple $100–$180; halogen grill light $80–$140; control panel assembly $320–$480; gas valve $200–$320; grate set (stainless) $180–$320 (varies by tier). Ontario CA 2-4 day parts chain keeps common-parts turnaround reasonable."
  }
];

const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair — Bull Grill Service",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": canonical, "telephone": MAIN_PHONE_TEL, "priceRange": "$$$"
  },
  { "@context": "https://schema.org", "@type": "Service", "serviceType": "Bull Grill Repair",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "description": "Bull grill repair across LA — Lonestar Select entry (3-4 burner 60-75k BTU), Angus mid (4-burner 75-85k BTU), Brahma premium (5-burner 90-100k BTU), Diablo flagship (6-burner 105k BTU). Bull Outdoor Products Ontario California 2-4 day parts chain. $89 residential diagnostic waived with repair.",
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, waived with repair" } }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "Bull", "item": "https://samedayappliance.repair/brands/bull/" },
      { "@type": "ListItem", "position": 4, "name": "Bull Grill Repair", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">{schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}</Fragment>
  <div class="call-banner"><div class="wrap"><span>Bull grill service?</span><a href={`tel:${MAIN_PHONE_TEL}`} class="phone-lg">{MAIN_PHONE}</a></div></div>

  <section class="hero"><div class="wrap">
    <div class="crumb"><a href="/">Home</a> › <a href="/brands/">Brands</a> › Bull › Grill Repair</div>
    <h1>Bull Grill Repair</h1>
    <p class="lede">Bull Outdoor Products ships four US built-in/cart tiers from its Ontario California factory — <b>Lonestar Select</b> entry (3-4 burner, 60-75k BTU), <b>Angus</b> mid (4-burner, 75-85k BTU), <b>Brahma</b> premium (5-burner, 90-100k BTU, hot-surface igniter), and <b>Diablo</b> flagship (6-burner, 105k BTU, infrared rotisserie back burner). Retail $1,500-$7,500 depending on tier + features, making Bull the premium-value choice in LA outdoor kitchens where the builder wanted real BTU output and good stainless construction without luxury-tier pricing. Ontario California factory gives Bull a 2-4 day LA parts chain — faster than Midwest/East Coast brands, not as fast as LA-local Hestan or DCS. Same-day dispatch, $89 residential diagnostic waived with the repair.</p>
    <div class="hero-cta"><a href={`tel:${MAIN_PHONE_TEL}`} class="btn btn-primary">Call {MAIN_PHONE}</a><a href="#book" class="btn btn-ghost">Request a Visit</a></div>
    <ul class="hero-facts">
      <li><b>Lonestar + Angus + Brahma + Diablo</b> — four-tier $1,500-$7,500 lineup</li>
      <li><b>60k-105k BTU total output</b> — 3-6 burner configurations</li>
      <li><b>Ontario California factory</b> — 2-4 day LA parts chain</li>
      <li><b>$89 residential diagnostic</b> — waived when you authorize the repair</li>
    </ul>
  </div></section>

  <BrandBranchesGrid />

  <section class="trust-bar"><div class="wrap"><span>BHGS #A49573 · Insured</span><span>Same-day in 5 SoCal counties</span><span>Residential diagnostic $89 · waived with repair</span></div></section>

  <section class="section"><div class="wrap">
    <h2>What Bull grill repair costs in LA</h2>
    <table class="price-table">
      <tr><th>Service</th><th>Typical Range</th><th>Notes</th></tr>
      <tr><td>Residential diagnostic</td><td>$89</td><td>Waived with repair</td></tr>
      <tr><td>Burner (Lonestar / Angus)</td><td>$180 – $280</td><td>Entry-mid tier</td></tr>
      <tr><td>Burner (Brahma / Diablo)</td><td>$260 – $400</td><td>Premium tier heavier-gauge</td></tr>
      <tr><td>Burner cleaning service</td><td>$140 – $220</td><td>Often resolves without parts</td></tr>
      <tr><td>Spark module (earlier models)</td><td>$140 – $220</td><td>Lonestar / Angus older</td></tr>
      <tr><td>Hot-surface igniter (Brahma/Diablo)</td><td>$160 – $260</td><td>Later-model architecture</td></tr>
      <tr><td>Ignition module</td><td>$220 – $360</td><td>Electronic control</td></tr>
      <tr><td>Infrared rotisserie back burner (Diablo)</td><td>$200 – $320</td><td>Flagship feature</td></tr>
      <tr><td>Rotisserie motor</td><td>$240 – $380</td><td>Bi-directional on premium</td></tr>
      <tr><td>Gas regulator</td><td>$180 – $280</td><td>High-BTU flow-rate diagnostic</td></tr>
    </table>
    <p class="small">Related: <a href="/brands/bull/">Bull brand hub</a> · <a href="/brands/coyote-grill-repair/">Coyote (premium peer)</a> · <a href="/brands/napoleon-grill-repair/">Napoleon (Canadian premium)</a> · <a href="/brands/alfresco-grill-repair/">Alfresco (Commerce CA peer)</a> · <a href="/brands/hestan-outdoor-grill-repair/">Hestan (Anaheim LA-local luxury)</a> · <a href="/services/bbq-grill-repair/">BBQ grill repair (service hub)</a>.</p>
  </div></section>

  <section class="section alt"><div class="wrap narrow">
    <h2>Four-tier lineup + Ontario parts chain — Bull's LA value proposition</h2>
    <p>Bull occupies a specific niche in LA outdoor-kitchen service: real premium-tier BTU output and stainless construction at $1,500-$7,500 price points that undercut luxury-tier brands (Twin Eagles $6k+, Hestan $6-12k, Lynx Professional $8-18k, Kalamazoo $19-26k). The Ontario California factory gives Bull the parts-chain advantage the East Coast and Midwest luxury brands can't match on 2-4 day turnaround. Repair economics differ meaningfully across the four tiers — a Lonestar Select at 10 years with major component failure may favor replacement over a $500+ repair; a Diablo at 10 years favors repair well into year 15 because the capital investment justifies extending service life. We run the honest numbers during diagnostic rather than defaulting to repair-at-all-costs. Model tier + service-call budget determine the right answer — we tell you which way the math points.</p>
  </div></section>

  <section class="section"><div class="wrap narrow">
    <h2>Bull grill repair — frequently asked</h2>
    {faqs.map(f => (<details class="faq"><summary>{f.q}</summary><p set:html={f.a}></p></details>))}
  </div></section>

  <section id="book" class="cta-bottom"><div class="wrap">
    <h2>Bull grill service? Call the branch closest to your home.</h2>
    <p>Same-day appliance repair in Los Angeles, Orange County, Ventura County. Residential diagnostic $89, waived with repair.</p>
  </div></section>
  <a href={`tel:${MAIN_PHONE_TEL}`} class="float-call" aria-label="Call now">☎ Call {MAIN_PHONE}</a>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  body { color: var(--text); } .wrap { max-width: 1200px; margin: 0 auto; padding: 0 24px; } .wrap.narrow { max-width: 820px; }
  h1 { font-size: 2.4rem; line-height: 1.15; margin: 12px 0 20px; color: var(--black); }
  h2 { font-size: 1.8rem; margin: 0 0 16px; color: var(--black); }
  p { line-height: 1.65; margin: 0 0 14px; }
  .call-banner { background: var(--red); color: #fff; padding: 10px 0; }
  .call-banner .wrap { display:flex; gap: 14px; align-items: center; justify-content: center; flex-wrap: wrap; }
  .call-banner .phone-lg { color:#fff; font-weight: 800; text-decoration: underline; font-size: 1.05rem; }
  .hero { background: var(--black); color: #fff; padding: 42px 0 56px; } .hero h1 { color: #fff; }
  .hero .lede { font-size: 1.06rem; color: #d7d7d7; max-width: 680px; }
  .hero .crumb { color: #9a9a9a; font-size: 0.85rem; margin-bottom: 6px; } .hero .crumb a { color: #c9c9c9; text-decoration: none; }
  .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; margin: 18px 0 24px; }
  .btn { display: inline-block; padding: 12px 20px; border-radius: 4px; text-decoration: none; font-weight: 700; }
  .btn-primary { background: var(--red); color: #fff; } .btn-ghost { background: transparent; color: #fff; border: 1px solid #fff; }
  .hero-facts { list-style: none; padding: 0; margin: 0; color: #c9c9c9; font-size: 0.95rem; }
  .hero-facts li { padding: 6px 0; border-top: 1px solid #222; } .hero-facts li:first-child { border-top: 0; }
  .trust-bar { background: var(--red); color: #fff; padding: 14px 0; }
  .trust-bar .wrap { display: flex; gap: 28px; flex-wrap: wrap; justify-content: center; font-size: 0.95rem; font-weight: 600; }
  .section { padding: 56px 0; } .section.alt { background: var(--gray); }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 14px; background: #fff; }
  .price-table th, .price-table td { text-align: left; padding: 11px 12px; border-bottom: 1px solid var(--border); }
  .price-table th { background: var(--black); color: #fff; font-weight: 700; font-size: 0.95rem; }
  .small { color: var(--muted); font-size: 0.92rem; margin-top: 12px; }
  .faq { background: #fff; border: 1px solid var(--border); padding: 12px 16px; margin-bottom: 8px; border-radius: 4px; }
  .faq summary { font-weight: 700; cursor: pointer; padding: 4px 0; } .faq p { margin: 8px 0 0; }
  .cta-bottom { background: var(--black); color: #fff; padding: 48px 0; } .cta-bottom h2 { color: #fff; } .cta-bottom p { color: #c9c9c9; }
  .float-call { position: fixed; bottom: 18px; right: 18px; background: var(--red); color: #fff; padding: 14px 18px; border-radius: 40px; text-decoration: none; font-weight: 700; box-shadow: 0 6px 18px rgba(0,0,0,0.28); z-index: 50; font-size: 0.95rem; }
  @media (max-width: 820px) { h1 { font-size: 1.9rem; } .float-call { padding: 11px 14px; font-size: 0.88rem; } .trust-bar .wrap { gap: 14px; font-size: 0.85rem; } }
</style>
