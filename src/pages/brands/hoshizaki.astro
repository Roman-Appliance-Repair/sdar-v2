const canonical = "https://samedayappliance.repair/brands/hoshizaki/";

const faqs = [
  {
    q: "What is Hoshizaki Alliance?",
    a: "Hoshizaki Alliance is the group of independent North American companies that share a common parent — Hoshizaki USA Holdings. Core members: Hoshizaki America (ice machines and commercial refrigeration), Jackson Warewashing Systems (commercial dishwashers, acquired 2013), Lancer Worldwide (beverage dispensers), Fogel Group (refrigeration), Hoshizaki Macom (Latin America foodservice), and Structural Concepts (food display and merchandising refrigeration, acquired 2025). For LA operators this matters: one service call can cover Hoshizaki ice, Hoshizaki refrigeration, and Jackson dishwashers — all sister brands with shared parts distribution."
  },
  {
    q: "Is Hoshizaki Japanese or American?",
    a: "Both. Hoshizaki Corporation is Japanese — founded in 1947, headquartered in Toyoake, Aichi. Hoshizaki America is a US subsidiary based in Peachtree City, Georgia, with manufacturing in Georgia and Arkansas and a California parts warehouse. Globally the Hoshizaki Group runs 46 affiliated companies with more than 10,000 employees."
  },
  {
    q: "Do you service Hoshizaki ice machines?",
    a: "Yes. We handle the full ice lineup: KM-series cube ice machines (100–2,500 lb/day), F-series flakers, DCM-series ice & water dispensers, FM-series mini cubes, and countertop units. Typical repairs we run in LA: compressor start, water solenoid failures, CleanCycle12 sensor issues, condenser fouling from LA air quality, and water-filter scale from hard-water service."
  },
  {
    q: "Do you service Jackson dishwashers?",
    a: "Yes. Jackson WWS is part of Hoshizaki Alliance since 2013, and we treat them as a sister brand to Hoshizaki refrigeration and ice. We service NXP high-temp and low-temp undercounters, Avenger door-type dishmachines, conveyor and flight-type systems, and glasswashers. If your kitchen runs Jackson plus Hoshizaki ice, one visit covers both."
  },
  {
    q: "How does Hoshizaki compare to True Refrigeration?",
    a: "Both are commercial-kitchen staples, but they solve different problems. True is a US family-owned company (O'Fallon, Missouri) with the largest installed base of reach-in refrigerators and freezers in the US — straightforward, high-volume, parts everywhere. Hoshizaki is Japanese-engineered, often specced into higher-end or tech-forward kitchens for antimicrobial stainless, CleanCycle12 self-cleaning ice machines, and tighter control tolerances. For LA sushi, kaiseki, and Korean BBQ concepts, flake ice and Hoshizaki's reputation for precision push operators toward Hoshizaki."
  },
  {
    q: "Why does flake ice matter for LA sushi and poke restaurants?",
    a: "Flake ice packs tightly around product without bruising delicate fish, and it melts at a controlled rate that doesn't wash flavors out. Sushi bars, poke shops, and seafood markets across Sawtelle Japantown, Little Tokyo, West LA, and Orange County's Japanese restaurant cluster run Hoshizaki F-series flakers almost by default. When an F-series goes down in the middle of service, the whole display case turns into a liability — we prioritize same-day dispatch."
  },
  {
    q: "What's the pricing?",
    a: "Commercial diagnostic is $120 flat, waived with repair authorization. Typical Hoshizaki ice machine repairs: water solenoid $220–$340, float switch $180–$260, CleanCycle12 sensor $260–$380, condenser cleaning and refrigerant top-off $350–$600, compressor replacement $900–$1,600 installed. Hoshizaki refrigeration repairs land in similar bands; Jackson dishwashers are a separate trade but we quote on-site."
  }
];

const schema = {
