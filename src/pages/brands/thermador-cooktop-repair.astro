---
// src/pages/brands/thermador-cooktop-repair.astro
// Niche combo, Thermador cooktop repair (~0 GSC impressions; brand-portfolio completion).
// Thermador = BSH Home Appliances (Bosch Group); signature Star Burner gas + Freedom Induction (CIT).
import Layout from '../../layouts/Layout.astro';
import ServiceHero from '../../components/ServiceHero.astro';
import { MAIN_PHONE } from '../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/brands/thermador-cooktop-repair/";

const title = "Thermador Cooktop Repair, Star Burner · Freedom Induction";
const description = `Thermador cooktop repair across SoCal, Star Burner gas (SGSXP), Freedom Induction (CIT304), Masterpiece. $89 dx waived. BHGS #A49573. Call.`;

const faqs = [
  {
    q: "Do you service Thermador's Freedom Induction CIT304 and CIT365?",
    a: "Yes. The Freedom Induction line is Thermador's signature induction platform, full-surface induction with no fixed zones, the entire cooktop is one large induction array. Common service items: failed touch control glass after liquid intrusion, individual induction module failure (one quadrant of the surface stops working while others still heat), and E-codes pointing to coil temperature sensors. Parts come through BSH/Thermador authorized distribution; common modules are 2-3 day lead, less common items 4-7 days. Diagnostic identifies whether the issue is module-level or full control board before quoting."
  },
  {
    q: "My Thermador Star Burner won't ignite, what's wrong?",
    a: "Thermador's Star Burner is the brand's signature gas burner pattern (5-prong instead of round), designed for more even heat distribution under cookware. Failure tree on a Star Burner that won't light: (1) corroded spark electrode at the burner base, often resolves with cleaning rather than replacement; (2) failed ignition switch under the burner knob; (3) clogged burner cap orifice producing too lean a mixture for the spark to catch; (4) gas valve failure (least common, most expensive). We diagnose in that order. About 40% of Star Burner ignition calls resolve at the cleaning step with no parts."
  },
  {
    q: "How much does Thermador cooktop repair cost?",
    a: `Diagnostic is $89, applied toward the repair when you approve work. Common Thermador cooktop repair ranges: spark electrode or ignition switch $180-$320; gas valve assembly $320-$520; Freedom Induction touch glass + control assembly $480-$780 (premium parts uplift through BSH authorized distribution); individual induction module $380-$680; full glass-ceramic surface replacement $620-$980. Star Burner cap and head replacement $145-$245. We give a written estimate before any work begins. Same-day across our 5-county service area when parts are stocked.`
  }
];

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": canonical + "#service",
    "serviceType": "Thermador Cooktop Repair",
    "name": "Thermador Cooktop Repair, Same Day Appliance Repair",
    "url": canonical,
    "description": "Same-day Thermador cooktop repair across Los Angeles, Orange, Ventura, San Bernardino, and Riverside counties. Star Burner gas (SGSXP series), Freedom Induction (CIT304, CIT365), Masterpiece induction (CIS series), and electric cooktops. BSH Home Appliances (Bosch Group) luxury platform. Spark electrodes, ignition switches, gas valves, induction modules, touch control assemblies, glass-ceramic surface replacement. $89 residential diagnostic, applied toward repair.",
    "provider": {
      "@type": "LocalBusiness",
      "name": "Same Day Appliance Repair",
      "url": "https://samedayappliance.repair/",
      "telephone": phone,
      "priceRange": "$$$"
    },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "offers": {
      "@type": "Offer",
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "89.00",
        "priceCurrency": "USD",
        "description": "Residential diagnostic fee, applied toward repair"
      }
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map((f) => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "Thermador", "item": "https://samedayappliance.repair/brands/thermador/" },
      { "@type": "ListItem", "position": 4, "name": "Thermador Cooktop Repair", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>

<Fragment slot="head-scripts">
  {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
</Fragment>

<ServiceHero
  eyebrow="LA · Orange · Ventura · San Bernardino · Riverside Counties"
  title="Thermador Cooktop Repair, Across Southern California"
  subtitle="Star Burner gas (SGSXP), Freedom Induction (CIT304), Masterpiece induction. BSH Home Appliances (Bosch Group) luxury platform specialists. $89 diagnostic, applied toward repair. Same day across five SoCal counties."
  heroImageTitle="Thermador Cooktop Repair"
  showBranches={true}
/>

<!-- 01 INTRO -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">01, About this service</p>
    <h2 class="section-title">Thermador cooktop repair across the full lineup.</h2>

    <p>Thermador has been part of BSH Home Appliances Group (the Bosch-Siemens joint venture) since 1998, positioned as the BSH luxury cooking line in the US market. The cooktop catalog is built around two signature features: the Star Burner gas pattern (a 5-pointed star burner head designed to distribute heat more evenly under round cookware than a circular ring) and Freedom Induction (full-surface induction with no fixed zones, the entire cooktop face is one continuous induction array). We service both signature lines plus the supporting Masterpiece induction (CIS series) and the older electric radiant cooktops still in service in homes built 2008–2018.</p>

    <p>Thermador cooktops sit on BSH platforms, which means parts chains run through the same authorized distribution as Bosch, generally 2-7 day lead on premium parts, well-documented service procedures, and reasonable parts availability for current and recent-generation models. The brand-specific service knowledge is in the Star Burner ignition system (different from a standard ring burner) and in the Freedom Induction full-surface architecture. Our techs handle both. <a href="/brands/thermador/">Brand hub</a> covers Thermador wall ovens, ranges, and dishwashers; this page is cooktop-specific.</p>
  </div>
</section>

<!-- 02 PROBLEMS -->
<section class="section section-gray">
  <div class="container">
    <p class="section-number">02, Common failures</p>
    <h2 class="section-title">What we diagnose most often on Thermador cooktops.</h2>

    <div class="problem-grid">
      <div class="problem-card">
        <h3>Star Burner won't ignite</h3>
        <p>The most common Thermador cooktop call. The 5-prong Star Burner uses a spark electrode that's exposed to spillover and grease more directly than a standard round burner. About 40% of "won't light" calls resolve at the cleaning step with no parts cost, corroded electrode contact responding to a careful service rather than replacement. The remaining failures trace to ignition switch, gas valve, or a clogged orifice in that order.</p>
      </div>
      <div class="problem-card">
        <h3>Freedom Induction module failure</h3>
        <p>On the CIT304 and CIT365, the cooktop is a continuous induction surface composed of multiple modules under the glass. When one module fails, you'll see one rectangular zone of the surface stop heating while the rest still functions. The failure pattern is module-level rather than full-cooktop, so the repair scope is one module replacement plus diagnostic verification, substantially less than a complete control system swap. We carry the most common module sizes through BSH authorized parts.</p>
      </div>
      <div class="problem-card">
        <h3>Touch control glass unresponsive</h3>
        <p>Both Star Burner gas (electronic ignition models) and Freedom Induction use touch-glass controls that are sensitive to liquid intrusion at the edge seal. A boil-over running across the front edge can short the touch traces, leaving controls unresponsive in one zone or globally. Replacement is a single glass-and-touch-assembly part on most models. We confirm the failure mode before quoting because power-cycle resets sometimes resolve apparent touch failures.</p>
      </div>
      <div class="problem-card">
        <h3>Gas valve stuck or leaking</h3>
        <p>Thermador's gas valves on the SGSXP series are heavy-duty professional-grade components designed to outlast the cooktop, but valves do fail, usually a stuck valve that won't open fully (leaving the burner running at less than rated BTU) or a partially seized valve that won't close completely (small flame remains after knob is at OFF). Both are immediate service items. We replace valves through BSH authorized parts only, third-party gas valve substitutes are not safe practice on luxury cooktops.</p>
      </div>
    </div>
  </div>
</section>

<!-- 03 MODELS -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">03, Thermador cooktop models we service</p>
    <h2 class="section-title">Star Burner gas, Freedom Induction, Masterpiece, electric.</h2>

    <p><strong>Star Burner gas (SGSXP series):</strong> SGSXP304TS, SGSXP365TS, SGSXP485, 30", 36", and 48" Star Burner gas cooktops, sealed-burner design with the 5-prong star pattern. Common service: spark electrodes, ignition switches, gas valves, burner cap and head assemblies.</p>

    <p><strong>Freedom Induction (CIT304, CIT365):</strong> CIT304KB, CIT365KB, CIT365XB, 30" and 36" full-surface induction cooktops, the brand's flagship induction product. Common service: induction module replacement, touch control assemblies, coil temperature sensors, E-code diagnostics.</p>

    <p><strong>Masterpiece induction (CIS series):</strong> CIS365 and similar, fixed-zone induction cooktops in Thermador's mid-tier. Common service: zone coil failure, touch board, surface glass replacement.</p>

    <p><strong>Electric radiant:</strong> Older CES and CET-series glass-ceramic radiant cooktops still in service in 2008-2018 homes. Common service: surface element replacement, control board, surface temperature limiters.</p>

    <p>Pre-1998 Thermador cooktops (pre-BSH-acquisition vintage) we still service when parts can be sourced through specialty distribution; we identify production year from the model and serial tag and confirm parts chain before scheduling.</p>
  </div>
</section>

<!-- 04 PRICING -->
<section class="section section-gray">
  <div class="container">
    <p class="section-number">04, Pricing</p>
    <h2 class="section-title">Thermador cooktop repair pricing.</h2>

    <p class="lead">Diagnostic is $89, applied toward the repair when you approve work. Written estimate before any parts go on. These ranges reflect typical Thermador cooktop repair pricing through BSH authorized parts distribution.</p>

    <div class="pricing-grid">
      <div class="price-card">
        <div class="price-label">Diagnostic</div>
        <div class="price-amount">$89</div>
        <div class="price-desc">Waived when you approve repair</div>
      </div>
      <div class="price-card">
        <div class="price-label">Spark electrode / ignition</div>
        <div class="price-amount">$180–$320</div>
        <div class="price-desc">Star Burner SGSXP ignition system</div>
      </div>
      <div class="price-card">
        <div class="price-label">Induction module</div>
        <div class="price-amount">$380–$680</div>
        <div class="price-desc">CIT304 / CIT365 single module</div>
      </div>
      <div class="price-card">
        <div class="price-label">Freedom Induction touch glass</div>
        <div class="price-amount">$480–$780</div>
        <div class="price-desc">Full glass + touch control assembly</div>
      </div>
    </div>

    <p class="price-note">Gas valve replacement $320-$520. Burner cap and head $145-$245 per burner. Full glass-ceramic surface (Masterpiece or electric radiant) $620-$980. Thermador parts carry a real premium-brand uplift through BSH authorized distribution, third-party substitutes are not safe practice on luxury cooktops, and we don't quote them. We tell you the brand-specific cost before you authorize repair.</p>
  </div>
</section>

<!-- 05 FAQ -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">05, FAQ</p>
    <h2 class="section-title">Thermador cooktop repair, common questions.</h2>

    <div class="faq-list">
      {faqs.map((f) => (
        <details class="faq-item">
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- 06 BOTTOM CTA -->
<section class="bottom-cta">
  <div class="container">
    <h2>Thermador cooktop down? Same-day service across Southern California.</h2>
    <p>$89 diagnostic, applied toward the repair. Star Burner gas, Freedom Induction, Masterpiece, BSH luxury platform service across all five SoCal counties.</p>
    <div class="cta-row">
      <a href={phoneHref} class="btn-primary">☎ Call {phone}</a>
      <a href="/contact/" class="btn-secondary">Book Online</a>
    </div>
  </div>
</section>

</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .section { padding: 72px 24px; }
  .section-gray { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; }
  .container.narrow { max-width: 820px; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  h2.section-title { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; margin: 0 0 20px; line-height: 1.2; color: var(--text); }
  .lead { font-size: 1.05rem; line-height: 1.75; color: var(--text); margin-bottom: 20px; }
  .section p { margin: 0 0 18px; font-size: 1rem; line-height: 1.75; color: var(--text); }
  .section a { color: var(--red); font-weight: 600; text-decoration: none; }
  .section a:hover { text-decoration: underline; }

  .problem-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-top: 32px; }
  .problem-card { background: #fff; border: 1px solid var(--border); border-left: 4px solid var(--red); border-radius: 6px; padding: 26px 28px; }
  .problem-card h3 { font-size: 1.1rem; font-weight: 800; margin: 0 0 12px; color: var(--text); }
  .problem-card p { font-size: 0.95rem; color: var(--text); margin: 0; line-height: 1.7; }
  @media (max-width: 768px) { .problem-grid { grid-template-columns: 1fr; } }

  .pricing-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-top: 32px; }
  .price-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 26px 22px; text-align: center; }
  .price-card .price-label { font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--muted); margin-bottom: 10px; font-weight: 700; }
  .price-card .price-amount { font-size: 1.85rem; font-weight: 800; color: var(--text); line-height: 1; margin-bottom: 10px; }
  .price-card .price-desc { font-size: 0.85rem; color: var(--muted); line-height: 1.55; }
  .price-note { margin-top: 24px; font-size: 0.95rem; color: var(--text); line-height: 1.7; }

  .faq-list { margin-top: 32px; }
  .faq-item { background: #fff; border: 1px solid var(--border); border-radius: 6px; padding: 18px 22px; margin-bottom: 12px; }
  .faq-item summary { font-weight: 700; cursor: pointer; font-size: 1rem; color: var(--text); list-style: none; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::before { content: "+ "; color: var(--red); font-weight: 800; margin-right: 6px; }
  .faq-item[open] summary::before { content: "− "; }
  .faq-item p { font-size: 0.95rem; color: var(--text); line-height: 1.75; margin: 14px 0 0; }

  .bottom-cta { background: var(--black); color: #fff; padding: 72px 24px; text-align: center; }
  .bottom-cta h2 { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; margin: 0 0 16px; color: #fff; line-height: 1.25; }
  .bottom-cta p { color: #c9c9c9; margin: 0 0 30px; font-size: 1.02rem; line-height: 1.6; }
  .cta-row { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 16px 34px; border-radius: 5px; font-size: 1rem; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 16px 34px; border-radius: 5px; font-size: 1rem; font-weight: 600; text-decoration: none; border: 2px solid rgba(255,255,255,0.35); }
</style>
