---
import Layout from '../../layouts/Layout.astro';
import BrandBranchesGrid from '../../components/BrandBranchesGrid.astro';
import { MAIN_PHONE, MAIN_PHONE_TEL } from '../../data/branches';

const title = "Samsung Range Repair Los Angeles — Same Day";
const description = "$89 dx waived. Samsung range repair SoCal, Flex Duo divider, Dual Cook Steam, Air Fry, SmartThings WiFi. NE/NX/NY series + Bespoke.";
const canonical = "https://samedayappliance.repair/brands/samsung-range-repair/";

const faqs = [
  {
    q: "Flex Duo divider won't seal or stay in place, what's failing?",
    a: "Flex Duo is Samsung's split-oven divider system, a removable metal barrier creates two independent cavities with separate temperature control. Common failure pattern: at the <b>6-10 year mark the divider insulation compresses</b>, the seal gaps, and the upper cavity leaks heat into the lower. Symptoms: uneven results when using Split Mode, oven temperature sensor mismatch between cavities, sometimes an E-code. Fix: replace the divider assembly (insulation is part of the assembly, not a separate service part) at $280–$420. Also check the <b>upper cavity temperature sensor</b> and the <b>divider-detection switch</b> that tells the control board the divider is in place, both can false-trigger in this failure chain."
  },
  {
    q: "Dual Cook Steam not producing steam, reservoir or heater?",
    a: "Samsung Dual Cook Steam adds a water reservoir + steam generator to the oven for reheat and proof modes. Common failures: (1) <b>reservoir-level sensor</b>, sensor thinks the reservoir is empty even when full; $160–$260 including install. (2) <b>Steam-generator heating element</b>, 8-12 year service item; $240–$380. (3) <b>Scale buildup inside the steam generator</b>, LA has hard water in the east and southeast (Burbank, Pasadena, Eastside); scale accumulates faster than in west-side soft-water zones. A descaling service ($120–$180) can restore function without replacing a part. We check for scale condition before recommending the heater swap."
  },
  {
    q: "Air Fry preset not working, convection issue or preset problem?",
    a: "Samsung Air Fry mode is a <b>software preset</b> built on top of the standard convection system, there's no separate Air Fry element. If \"Air Fry\" itself fails while standard convection works, it's firmware: a <b>SmartThings firmware update</b> or <b>power-cycle reset</b> usually restores the preset. If both Air Fry AND standard convection fail together, then the <b>convection element</b> ($140–$240) or <b>fan motor</b> ($220–$380) is the likely cause. We diagnose both together during the service call rather than assuming Air Fry is its own subsystem."
  },
  {
    q: "Samsung and Dacor ranges, why do parts sometimes cross-fit?",
    a: "Samsung acquired Dacor in 2016, and since then the Samsung + Dacor parts supply chains have increasingly overlapped, not for every component, but for <b>motor assemblies, LED modules, igniter sparks, and oven temperature sensors</b> on newer (2018+) units. For LA service this means: when a hard-to-source Samsung control board is backordered, a Dacor cross-reference part with stock sometimes applies; and conversely, Dacor service parts that aren't on immediate stock sometimes have a Samsung equivalent. Not every part crosses, control boards and front-panel aesthetics remain brand-specific, but enough common parts do that we check cross-references before telling a customer we can't source. See <a href='/brands/dacor-range-repair/'>Dacor range repair</a>."
  },
  {
    q: "SmartThings pairing failed after firmware update, what to do?",
    a: "Common Samsung range issue post-firmware-update: the SmartThings app shows the range as offline even when WiFi is connected, or new-device pairing fails partway through setup. Recovery steps: (1) power-cycle the range at the breaker for 60 seconds; (2) in the SmartThings app, remove the range completely and re-add from scratch (don't try to reconnect an existing entry); (3) ensure router is 2.4 GHz compatible, Samsung appliances generally don't pair on 5 GHz-only networks; (4) if your router supports band separation, use a 2.4 GHz-only SSID for pairing. If pairing fails after all four steps, the WiFi module inside the range ($180–$280) is the likely cause. We run the sequence during diagnostic before quoting the module."
  },
  {
    q: "What does Samsung range repair cost in LA?",
    a: "Residential diagnostic $89 waived with repair. Typical Samsung bands: bake element $140–$240; gas surface igniter $120–$220; oven temperature sensor $80–$140; main control board $280–$440; Flex Duo divider assembly $280–$420; Dual Cook Steam heating element $240–$380; Dual Cook reservoir sensor $160–$260; steam-generator descale service $120–$180; convection element / fan motor $140–$380; Air Fry firmware recovery included in diagnostic; SmartThings WiFi module $180–$280; Bespoke panel swap $220–$380 (2021+ customizable-panel units)."
  }
];

const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair, Samsung Range Service",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": canonical, "telephone": MAIN_PHONE_TEL, "priceRange": "$$"
  },
  { "@context": "https://schema.org", "@type": "Service", "serviceType": "Samsung Range Repair",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "description": "Samsung range repair across LA, NE electric, NX/NSE gas, NY dual-fuel + Bespoke panel customization. Flex Duo split-oven divider, Dual Cook Steam generator, Air Fry preset, SmartThings WiFi. Samsung Newberry SC factory 2018+ and Dacor parts-chain reciprocity since 2016. $89 residential diagnostic waived with repair.",
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, waived with repair" } }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "Samsung", "item": "https://samedayappliance.repair/brands/samsung/" },
      { "@type": "ListItem", "position": 4, "name": "Samsung Range Repair", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">{schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}</Fragment>
  <div class="call-banner"><div class="wrap"><span>Samsung range service?</span><a href={`tel:${MAIN_PHONE_TEL}`} class="phone-lg">{MAIN_PHONE}</a></div></div>

  <section class="hero"><div class="wrap">
    <div class="crumb"><a href="/">Home</a> › <a href="/brands/">Brands</a> › Samsung › Range Repair</div>
    <h1>Samsung Range Repair</h1>
    <p class="lede">Samsung Electronics (Suwon, South Korea; US manufacturing at Newberry South Carolina since 2018) ships ranges across the NE (electric), NX/NSE (gas), and NY (dual-fuel) series with signature features that need brand-specific service knowledge, Flex Duo split-oven divider, Dual Cook Steam generator, Air Fry preset, and the Bespoke customizable-panel aesthetic from 2021+. Since Samsung acquired Dacor in 2016, Samsung and Dacor parts supply chains have increasingly overlapped on motor assemblies, LED modules, and temperature sensors, useful when a specific Samsung part is backordered. Same-day dispatch, $89 residential diagnostic waived with the repair.</p>
    <div class="hero-cta"><a href={`tel:${MAIN_PHONE_TEL}`} class="btn btn-primary">Call {MAIN_PHONE}</a><a href="#book" class="btn btn-ghost">Request a Visit</a></div>
    <ul class="hero-facts">
      <li><b>NE / NX / NY series + Bespoke panels 2021+</b>, electric, gas, dual-fuel</li>
      <li><b>Flex Duo + Dual Cook Steam + Air Fry</b>, signature features</li>
      <li><b>Samsung-Dacor parts-chain reciprocity since 2016</b>, cross-reference advantage</li>
      <li><b>$89 residential diagnostic</b>, waived when you authorize the repair</li>
    </ul>
  </div></section>

  <BrandBranchesGrid />

  <section class="trust-bar"><div class="wrap"><span>BHGS #A49573 · Insured</span><span>Same-day in 5 SoCal counties</span><span>Residential diagnostic $89 · waived with repair</span></div></section>

  <section class="section"><div class="wrap">
    <h2>What Samsung range repair costs in LA</h2>
    <table class="price-table">
      <tr><th>Service</th><th>Typical Range</th><th>Notes</th></tr>
      <tr><td>Residential diagnostic</td><td>$89</td><td>Waived with repair</td></tr>
      <tr><td>Bake element / gas igniter</td><td>$120 – $240</td><td>NE electric / NX gas</td></tr>
      <tr><td>Oven temperature sensor</td><td>$80 – $140</td><td>Standard across series</td></tr>
      <tr><td>Main control board</td><td>$280 – $440</td><td>Model-specific SKU</td></tr>
      <tr><td>Flex Duo divider assembly</td><td>$280 – $420</td><td>Insulation + seal + detect switch</td></tr>
      <tr><td>Dual Cook Steam heater</td><td>$240 – $380</td><td>Steam-generator element</td></tr>
      <tr><td>Dual Cook reservoir sensor</td><td>$160 – $260</td><td>False-empty trigger common</td></tr>
      <tr><td>Convection element / fan motor</td><td>$140 – $380</td><td>Air Fry rides on convection</td></tr>
      <tr><td>SmartThings WiFi module</td><td>$180 – $280</td><td>Post-firmware pairing recovery</td></tr>
      <tr><td>Bespoke panel swap</td><td>$220 – $380</td><td>Customizable 2021+ units</td></tr>
    </table>
    <p class="small">Related: <a href="/brands/samsung-refrigerator-repair/">Samsung brand hub</a> · <a href="/brands/samsung-microwave-repair/">Samsung microwave</a> · <a href="/brands/samsung-refrigerator-repair/">Samsung refrigerator</a> · <a href="/brands/dacor-range-repair/">Dacor range (Samsung family)</a> · <a href="/brands/lg-range-repair/">LG range (Korean peer)</a> · <a href="/services/stove-repair/">Range / stove repair (service hub)</a> · <a href="/price-list/range-repair-cost/">Range repair cost</a>.</p>
  </div></section>

  <section class="section alt"><div class="wrap narrow">
    <h2>Bespoke + Flex Duo + Dual Cook, the Samsung signature features</h2>
    <p><b>Bespoke</b> (2021+) lets you swap the front-panel color/finish without replacing the whole range, customer-swappable aesthetic change. Service consideration: Bespoke panels aren't just cosmetic, they include mounting hardware; when a panel is damaged, replacement includes the mounting kit ($220–$380). <b>Flex Duo</b> splits the oven into two independent cavities with separate temperature control via a removable metal divider, the divider insulation compresses at the 6-10 year mark and that's the failure call we see most. <b>Dual Cook Steam</b> adds a water reservoir + steam generator for reheat and proof modes, scale buildup (LA hard-water zones) and reservoir-level sensor failure are the two common service items. <b>Air Fry</b> is a firmware preset riding on the standard convection system, not a separate element.</p>
  </div></section>

  <section class="section"><div class="wrap narrow">
    <h2>Samsung range repair, frequently asked</h2>
    {faqs.map(f => (<details class="faq"><summary>{f.q}</summary><p set:html={f.a}></p></details>))}
  </div></section>

  <section id="book" class="cta-bottom"><div class="wrap">
    <h2>Samsung range service? Call the branch closest to your home.</h2>
    <p>Same-day appliance repair in Los Angeles, Orange County, Ventura County. Residential diagnostic $89, waived with repair.</p>
  </div></section>
  <a href={`tel:${MAIN_PHONE_TEL}`} class="float-call" aria-label="Call now">☎ Call {MAIN_PHONE}</a>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  body { color: var(--text); } .wrap { max-width: 1200px; margin: 0 auto; padding: 0 24px; } .wrap.narrow { max-width: 820px; }
  h1 { font-size: 2.4rem; line-height: 1.15; margin: 12px 0 20px; color: var(--black); }
  h2 { font-size: 1.8rem; margin: 0 0 16px; color: var(--black); }
  p { line-height: 1.65; margin: 0 0 14px; }
  .call-banner { background: var(--red); color: #fff; padding: 10px 0; }
  .call-banner .wrap { display:flex; gap: 14px; align-items: center; justify-content: center; flex-wrap: wrap; }
  .call-banner .phone-lg { color:#fff; font-weight: 800; text-decoration: underline; font-size: 1.05rem; }
  .hero { background: var(--black); color: #fff; padding: 42px 0 56px; } .hero h1 { color: #fff; }
  .hero .lede { font-size: 1.06rem; color: #d7d7d7; max-width: 680px; }
  .hero .crumb { color: #9a9a9a; font-size: 0.85rem; margin-bottom: 6px; } .hero .crumb a { color: #c9c9c9; text-decoration: none; }
  .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; margin: 18px 0 24px; }
  .btn { display: inline-block; padding: 12px 20px; border-radius: 4px; text-decoration: none; font-weight: 700; }
  .btn-primary { background: var(--red); color: #fff; } .btn-ghost { background: transparent; color: #fff; border: 1px solid #fff; }
  .hero-facts { list-style: none; padding: 0; margin: 0; color: #c9c9c9; font-size: 0.95rem; }
  .hero-facts li { padding: 6px 0; border-top: 1px solid #222; } .hero-facts li:first-child { border-top: 0; }
  .trust-bar { background: var(--red); color: #fff; padding: 14px 0; }
  .trust-bar .wrap { display: flex; gap: 28px; flex-wrap: wrap; justify-content: center; font-size: 0.95rem; font-weight: 600; }
  .section { padding: 56px 0; } .section.alt { background: var(--gray); }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 14px; background: #fff; }
  .price-table th, .price-table td { text-align: left; padding: 11px 12px; border-bottom: 1px solid var(--border); }
  .price-table th { background: var(--black); color: #fff; font-weight: 700; font-size: 0.95rem; }
  .small { color: var(--muted); font-size: 0.92rem; margin-top: 12px; }
  .faq { background: #fff; border: 1px solid var(--border); padding: 12px 16px; margin-bottom: 8px; border-radius: 4px; }
  .faq summary { font-weight: 700; cursor: pointer; padding: 4px 0; } .faq p { margin: 8px 0 0; }
  .cta-bottom { background: var(--black); color: #fff; padding: 48px 0; } .cta-bottom h2 { color: #fff; } .cta-bottom p { color: #c9c9c9; }
  .float-call { position: fixed; bottom: 18px; right: 18px; background: var(--red); color: #fff; padding: 14px 18px; border-radius: 40px; text-decoration: none; font-weight: 700; box-shadow: 0 6px 18px rgba(0,0,0,0.28); z-index: 50; font-size: 0.95rem; }
  @media (max-width: 820px) { h1 { font-size: 1.9rem; } .float-call { padding: 11px 14px; font-size: 0.88rem; } .trust-bar .wrap { gap: 14px; font-size: 0.85rem; } }
</style>
