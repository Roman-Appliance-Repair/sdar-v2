---
import Layout from '../../layouts/Layout.astro';
import BrandDetailPlaceholder from '../../components/BrandDetailPlaceholder.astro';

const title = "Sub-Zero Ice Maker Repair Los Angeles | Same Day Service";
const description = "Expert Sub-Zero ice maker repair in Los Angeles. Same-day appointments, OEM parts, licensed technicians. Call (424) 325-0520.";
---

<Layout title={title} description={description}>
  <BrandDetailPlaceholder
    brandName="Sub-Zero"
    brandSlug="sub-zero"
    category="Ice Maker"
    categorySlug="ice-maker-repair"
    hubUrl="/brands/sub-zero/"
  />
</Layout>
