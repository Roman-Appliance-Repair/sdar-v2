---
import Layout from '../../layouts/Layout.astro';
import BrandBranchesGrid from '../../components/BrandBranchesGrid.astro';
import { MAIN_PHONE, MAIN_PHONE_TEL } from '../../data/branches';

const title = "Gaggenau Range Hood Repair | Southern California | 400/200 Series BSH Irvine";
const description = "Gaggenau range hood repair across SoCal, 400 Series integrated + 200 Series pull-out Vario modular. BSH Irvine CA parts 1-2 day LA-local. $89 dx.";
const canonical = "https://samedayappliance.repair/brands/gaggenau-range-hood-repair/";

const faqs = [
  {
    q: "Gaggenau, BSH family, LA parts, and where's the factory?",
    a: "Gaggenau is the ultra-luxury brand in the <b>BSH Home Appliances</b> trio (Bosch + Siemens + Gaggenau; BSH was formerly Bosch-Siemens). Hoods are built at the <b>Lipsheim France factory</b>, the same BSH facility that builds the Gaggenau 400 Series oven line. US service parts route through <b>BSH Irvine California, 1-2 day LA-local parts</b> on common components, matching <a href='/brands/thermador-range-hood-repair/'>Thermador</a> + <a href='/brands/hestan-range-hood-repair/'>Hestan</a> + <a href='/brands/fisher-paykel-range-hood-repair/'>F&P</a> as the LA-local-advantage luxury residential brands. Specialty Vario architecture trim + flush-integrated panel parts 2-3 week direct from Lipsheim."
  },
  {
    q: "What Gaggenau range hood configurations show up in LA?",
    a: "<b>400 Series AW 442 / AW 230 / AI 200 integrated ceiling + wall + flush-integrated hoods</b>, Gaggenau's flagship ultra-luxury tier, part of the Vario modular architecture where each element is designed as an interchangeable module. Typical 400 Series installations are architect-specified luxury kitchens with flush-integrated ceiling hoods disappearing into the cabinetry. <b>200 Series AL 200 pull-out + downdraft hoods</b>, slide-out front-face for when not in use; common in contemporary luxury condo and downtown loft installations. 600-1200 CFM; halogen + LED; Home Connect WiFi app integration."
  },
  {
    q: "Gaggenau hood diagnostic, what actually breaks?",
    a: "Standard Gaggenau hood diagnostic: (1) variable-speed motor at 10-12 year mark; motor swap $380–$560 (Gaggenau ultra-luxury tier; premium motor spec); (2) control-board $520–$760 (Home Connect-enabled; Vario modular compatibility); (3) LED driver $220–$340; (4) grease-filter latch $180–$260; (5) 400 Series flush-integrated ceiling panel damage, 2-3 week Lipsheim factory quote $600–$1400+ depending on panel + fit; (6) 200 Series pull-out mechanism service, slide-rail + motor $300–$500; (7) Home Connect firmware pairing diagnostic. BSH Irvine 1-2 day LA-local on common items."
  },
  {
    q: "What does Gaggenau range hood repair cost in LA?",
    a: "Residential diagnostic $89 waived with repair. Typical Gaggenau bands: motor $380–$560; control-board $520–$760; LED driver $220–$340; grease-filter latch $180–$260; 400 Series flush-panel quoted 2-3 week lead; 200 Series pull-out mechanism $300–$500. Ultra-luxury tier service economics at the very top of the European luxury bracket alongside <a href='/brands/la-cornue-range-hood-repair/'>La Cornue</a>. BSH Irvine LA-local parts-chain advantage keeps common service windows short compared to other European ultra-luxury."
  },
  {
    q: "Gaggenau 400 Series vs 200 Series, which do I have?",
    a: "<b>400 Series</b> = Gaggenau's flagship ultra-luxury Vario modular architecture, flush-integrated ceiling or wall hoods that disappear into the cabinetry, architect-specified luxury kitchen installations, typically $8,000+ for the hood alone. Model prefixes AW (wall), AI (integrated island/ceiling). <b>200 Series</b> = the more accessible Gaggenau tier positioned above Thermador but below 400 Series, includes the pull-out front-face hood (AL 200) common in contemporary luxury condos, typically $3,000-$5,000. Both route through BSH Irvine parts but Vario modular 400 Series parts are Gaggenau-specific, not shared with 200 Series or Thermador/Bosch. Confirm series when calling for correct first-dispatch parts."
  }
];

const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair, Gaggenau Range Hood Service",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": canonical, "telephone": MAIN_PHONE_TEL, "priceRange": "$$$$"
  },
  { "@context": "https://schema.org", "@type": "Service", "serviceType": "Gaggenau Range Hood Repair",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "description": "Gaggenau range hood repair across LA, 400 Series AW/AI flush-integrated Vario modular + 200 Series AL pull-out. BSH Lipsheim France factory + BSH Irvine CA parts 1-2 day LA-local. Home Connect WiFi. $89 residential diagnostic waived with repair.",
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, waived with repair" } }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "Gaggenau", "item": "https://samedayappliance.repair/brands/gaggenau/" },
      { "@type": "ListItem", "position": 4, "name": "Gaggenau Range Hood Repair", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">{schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}</Fragment>
  <div class="call-banner"><div class="wrap"><span>Gaggenau range hood service?</span><a href={`tel:${MAIN_PHONE_TEL}`} class="phone-lg">{MAIN_PHONE}</a></div></div>

  <section class="hero"><div class="wrap">
    <div class="crumb"><a href="/">Home</a> › <a href="/brands/">Brands</a> › Gaggenau › Range Hood Repair</div>
    <h1>Gaggenau Range Hood Repair</h1>
    <p class="lede">Gaggenau is the ultra-luxury brand in the BSH Home Appliances trio (Bosch + Siemens + Gaggenau). Hoods are built at the Lipsheim France BSH factory, the same facility behind the 400 Series oven line, and US service parts route through BSH Irvine California for 1-2 day LA-local delivery on common components. The 400 Series flush-integrated ceiling and wall hoods define the Vario modular architecture that is Gaggenau's signature: modules designed to disappear into the cabinetry so the kitchen reads as architecture, not as appliance. The 200 Series AL pull-out addresses contemporary condo and loft installations where ceiling integration isn't available. In LA, Gaggenau shows up in architect-specified luxury builds in Bel Air, Beverly Hills, Malibu, and high-end downtown lofts. Same-day dispatch, $89 residential diagnostic waived with the repair.</p>
    <div class="hero-cta"><a href={`tel:${MAIN_PHONE_TEL}`} class="btn btn-primary">Call {MAIN_PHONE}</a><a href="#book" class="btn btn-ghost">Request a Visit</a></div>
    <ul class="hero-facts">
      <li><b>BSH Lipsheim France factory</b>, Vario modular architecture flagship</li>
      <li><b>400 Series flush-integrated + 200 Series pull-out</b>, two ultra-luxury tiers</li>
      <li><b>BSH Irvine CA 1-2 day LA-local parts</b>, one of LA's four local-advantage luxury brands</li>
      <li><b>$89 residential diagnostic</b>, waived when you authorize the repair</li>
    </ul>
  </div></section>

  <BrandBranchesGrid />

  <section class="trust-bar"><div class="wrap"><span>BHGS #A49573 · Insured</span><span>Same-day in 5 SoCal counties</span><span>Residential diagnostic $89 · waived with repair</span></div></section>

  <section class="section"><div class="wrap">
    <h2>What Gaggenau range hood repair costs in LA</h2>
    <table class="price-table">
      <tr><th>Service</th><th>Typical Range</th><th>Notes</th></tr>
      <tr><td>Residential diagnostic</td><td>$89</td><td>Waived with repair</td></tr>
      <tr><td>Variable-speed motor</td><td>$380 – $560</td><td>10-12 year service</td></tr>
      <tr><td>Control-board (Home Connect)</td><td>$520 – $760</td><td>Vario modular-compatible</td></tr>
      <tr><td>LED driver</td><td>$220 – $340</td><td>Task lighting</td></tr>
      <tr><td>Grease-filter latch</td><td>$180 – $260</td><td>Interlock trigger</td></tr>
      <tr><td>200 Series pull-out mechanism</td><td>$300 – $500</td><td>Slide-rail + motor</td></tr>
      <tr><td>400 Series flush-integrated panel</td><td>Quoted</td><td>2-3 week Lipsheim</td></tr>
    </table>
    <p class="small">Related: <a href="/brands/gaggenau/">Gaggenau brand hub</a> · <a href="/brands/gaggenau-stove-repair/">Gaggenau Vario range / stove</a> · <a href="/brands/gaggenau-wine-cooler-repair/">Gaggenau wine cooler</a> · <a href="/brands/thermador-range-hood-repair/">Thermador range hood (BSH sibling)</a> · <a href="/brands/la-cornue-range-hood-repair/">La Cornue range hood (French ultra-luxury peer)</a> · <a href="/services/range-hood-repair/">Range hood repair (service hub)</a> · <a href="/commercial/exhaust-hood-repair/">Commercial exhaust hood repair</a>. For commercial kitchen exhaust hood repair (restaurant/foodservice Captive-Aire, Halton scope), see our <a href="/commercial/exhaust-hood-repair/">commercial page</a>.</p>
  </div></section>

  <section class="section alt"><div class="wrap narrow">
    <h2>Gaggenau range hood repair, frequently asked</h2>
    {faqs.map(f => (<details class="faq"><summary>{f.q}</summary><p set:html={f.a}></p></details>))}
  </div></section>

  <section id="book" class="cta-bottom"><div class="wrap">
    <h2>Gaggenau range hood service? Call the branch closest to your home.</h2>
    <p>Same-day appliance repair in Los Angeles, Orange County, Ventura County. Residential diagnostic $89, waived with repair.</p>
  </div></section>
  <a href={`tel:${MAIN_PHONE_TEL}`} class="float-call" aria-label="Call now">☎ Call {MAIN_PHONE}</a>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  body { color: var(--text); } .wrap { max-width: 1200px; margin: 0 auto; padding: 0 24px; } .wrap.narrow { max-width: 820px; }
  h1 { font-size: 2.4rem; line-height: 1.15; margin: 12px 0 20px; color: var(--black); }
  h2 { font-size: 1.8rem; margin: 0 0 16px; color: var(--black); }
  p { line-height: 1.65; margin: 0 0 14px; }
  .call-banner { background: var(--red); color: #fff; padding: 10px 0; }
  .call-banner .wrap { display:flex; gap: 14px; align-items: center; justify-content: center; flex-wrap: wrap; }
  .call-banner .phone-lg { color:#fff; font-weight: 800; text-decoration: underline; font-size: 1.05rem; }
  .hero { background: var(--black); color: #fff; padding: 42px 0 56px; } .hero h1 { color: #fff; }
  .hero .lede { font-size: 1.06rem; color: #d7d7d7; max-width: 680px; }
  .hero .crumb { color: #9a9a9a; font-size: 0.85rem; margin-bottom: 6px; } .hero .crumb a { color: #c9c9c9; text-decoration: none; }
  .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; margin: 18px 0 24px; }
  .btn { display: inline-block; padding: 12px 20px; border-radius: 4px; text-decoration: none; font-weight: 700; }
  .btn-primary { background: var(--red); color: #fff; } .btn-ghost { background: transparent; color: #fff; border: 1px solid #fff; }
  .hero-facts { list-style: none; padding: 0; margin: 0; color: #c9c9c9; font-size: 0.95rem; }
  .hero-facts li { padding: 6px 0; border-top: 1px solid #222; } .hero-facts li:first-child { border-top: 0; }
  .trust-bar { background: var(--red); color: #fff; padding: 14px 0; }
  .trust-bar .wrap { display: flex; gap: 28px; flex-wrap: wrap; justify-content: center; font-size: 0.95rem; font-weight: 600; }
  .section { padding: 56px 0; } .section.alt { background: var(--gray); }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 14px; background: #fff; }
  .price-table th, .price-table td { text-align: left; padding: 11px 12px; border-bottom: 1px solid var(--border); }
  .price-table th { background: var(--black); color: #fff; font-weight: 700; font-size: 0.95rem; }
  .small { color: var(--muted); font-size: 0.92rem; margin-top: 12px; }
  .faq { background: #fff; border: 1px solid var(--border); padding: 12px 16px; margin-bottom: 8px; border-radius: 4px; }
  .faq summary { font-weight: 700; cursor: pointer; padding: 4px 0; } .faq p { margin: 8px 0 0; }
  .cta-bottom { background: var(--black); color: #fff; padding: 48px 0; } .cta-bottom h2 { color: #fff; } .cta-bottom p { color: #c9c9c9; }
  .float-call { position: fixed; bottom: 18px; right: 18px; background: var(--red); color: #fff; padding: 14px 18px; border-radius: 40px; text-decoration: none; font-weight: 700; box-shadow: 0 6px 18px rgba(0,0,0,0.28); z-index: 50; font-size: 0.95rem; }
  @media (max-width: 820px) { h1 { font-size: 1.9rem; } .float-call { padding: 11px 14px; font-size: 0.88rem; } .trust-bar .wrap { gap: 14px; font-size: 0.85rem; } }
</style>
