---
import Layout from '../../layouts/Layout.astro';
import BrandDetailPlaceholder from '../../components/BrandDetailPlaceholder.astro';

const title = "Maytag Refrigerator Repair Los Angeles | French Door, Ice";
const description = "Maytag fridge repair across LA — French Door, side-by-side, ice maker module, 10-year compressor warranty. Whirlpool-owned. $89 diagnostic. (424) 325-0520.";
const canonical = "https://samedayappliance.repair/brands/maytag-refrigerator-repair/";
---

<Layout title={title} description={description} canonical={canonical}>
  <BrandDetailPlaceholder
    brandName="Maytag"
    brandSlug="maytag"
    category="Refrigerator"
    categorySlug="refrigerator-repair"
    hubUrl="/brands/maytag/"
  />
</Layout>
