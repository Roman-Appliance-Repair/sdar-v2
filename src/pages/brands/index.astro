---
import Layout from '../../layouts/Layout.astro';

const title = 'Brands | Same Day Appliance Repair';
const description = 'Brand-specific appliance repair pages — new catalog in development. We service every major residential and commercial appliance brand.';
---

<Layout title={title} description={description}>
  <section class="hub">
    <div class="container">
      <p class="hub-eyebrow">Brands</p>
      <h1 class="hub-title">Brand-specific Repair</h1>
      <p class="hub-intro">
        New brand catalog is in development. In the meantime, you can browse all service categories — we repair every major residential and commercial appliance brand.
      </p>

      <div class="cta-row">
        <a href="/services/" class="btn-primary">All Appliance Services →</a>
        <a href="/commercial/" class="btn-secondary">Commercial Equipment →</a>
      </div>

      <p class="hub-note">
        Brand-specific deep-dives (Sub-Zero, Wolf, Thermador, Miele, Viking, Bosch, KitchenAid, LG, Samsung, GE, Whirlpool, and more) will roll out through Q2–Q3 2026.
      </p>
    </div>
  </section>
</Layout>

<style>
  .hub { padding: 80px 0; }
  .hub-eyebrow {
    font-size: 12px; font-weight: 700; letter-spacing: 0.18em;
    text-transform: uppercase; color: var(--red); margin-bottom: 12px;
  }
  .hub-title { font-size: clamp(2rem, 5vw, 3.5rem); margin-bottom: 20px; }
  .hub-intro {
    max-width: 680px; font-size: 17px; line-height: 1.6; color: var(--muted);
    margin-bottom: 32px;
  }
  .cta-row {
    display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: 40px;
  }
  .btn-primary, .btn-secondary {
    display: inline-flex; align-items: center;
    padding: 14px 24px; font-weight: 600; font-size: 15px;
    border-radius: 4px; text-decoration: none;
    transition: all 0.15s var(--ease);
  }
  .btn-primary { background: var(--red); color: var(--white); }
  .btn-primary:hover { background: var(--red-dark); color: var(--white); }
  .btn-secondary {
    background: var(--white); color: var(--black);
    border: 1px solid var(--border);
  }
  .btn-secondary:hover { border-color: var(--black); color: var(--black); }
  .hub-note {
    font-size: 14px; color: var(--muted); max-width: 680px;
    padding-top: 24px; border-top: 1px solid var(--border);
  }
</style>
