const title = "All Appliance Brands We Repair | Los Angeles | Same Day Service";
const description = "40+ residential and commercial appliance brands. Sub-Zero, Wolf, Miele, Thermador, Viking, LG, Samsung, GE. 17 commercial equipment categories. Same-day service across LA, Orange, Ventura, San Bernardino, Riverside.";
---

<Layout title={title} description={description}>

  <ServiceHero
    title="Every Major Appliance Brand. One Number."
    subtitle="40+ residential and commercial brands across 20+ appliance categories. Same-day service across Los Angeles, Orange, Ventura, San Bernardino, and Riverside counties."
    heroImageTitle="All Brands"
  />

  <section class="brands-section">
    <div class="container">

      {/* ── TOGGLE ── */}
      <div class="mode-toggle" role="tablist" aria-label="Residential or Commercial">
        <button class="mode-toggle-btn active" data-mode="residential" type="button" role="tab" aria-selected="true">
          <span>🏠 Residential</span>
          <span class="toggle-count">20 brands · 55 pages</span>
        </button>
        <button class="mode-toggle-btn" data-mode="commercial" type="button" role="tab" aria-selected="false">
          <span>🏢 Commercial</span>
          <span class="toggle-count">13 brands · 11 categories</span>
        </button>
      </div>

      {/* ── RESIDENTIAL MODE ── */}
      <div class="mode-grids active" data-mode="residential">

        <div class="column-left">
          <h2 class="column-title">Find Your Appliance</h2>
          <p class="column-subtitle">Pick your appliance type to see brands, models, and common failures.</p>

          {residentialSections.map((sec) => (
            <div class="section-block">
              <div class="section-heading">
                <h3><span class="section-icon">{sec.icon}</span> {sec.title}</h3>
                <span class="section-count">{sec.count}</span>
              </div>
              {sec.tiers.map((tier) => (
                <div class="tier-group">
                  <p class="tier-label">{tier.label}</p>
                  <div class="tier-tags">
                    {tier.items.map((item) => (
                      has(item.slug, residentialFiles) ? (
                        <a href={`/brands/${item.slug}/`} class="brand-tag">{item.label}</a>
                      ) : (
                        <span class="brand-tag disabled">{item.label} 🟡</span>
                      )
                    ))}
                  </div>
                </div>
              ))}
              {sec.future && sec.future.length > 0 && (
                <div class="tier-group future">
                  <p class="tier-label muted">Coming Soon</p>
                  <div class="tier-tags">
                    {sec.future.map((name) => (
                      <span class="brand-tag disabled">{name} 🟡</span>
                    ))}
                  </div>
                </div>
              )}
            </div>
          ))}

          {/* SECTION 4 — Ranges, Ovens & Cooktops */}
          <div class="section-block">
            <div class="section-heading">
