<script is:inline>
  document.querySelectorAll('.mode-toggle-btn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var mode = btn.dataset.mode;
      document.querySelectorAll('.mode-toggle-btn').forEach(function (b) {
        var isActive = b === btn;
        b.classList.toggle('active', isActive);
        b.setAttribute('aria-selected', String(isActive));
      });
      document.querySelectorAll('.mode-grids').forEach(function (g) {
        g.classList.toggle('active', g.dataset.mode === mode);
      });
      window.scrollTo({ top: document.querySelector('.brands-section').offsetTop - 80, behavior: 'smooth' });
    });
  });
</script>

