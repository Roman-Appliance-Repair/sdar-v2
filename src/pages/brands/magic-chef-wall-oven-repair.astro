      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ] },
  { "@context": "https://schema.org", "@type": "Service", "serviceType": "Magic Chef Wall Oven Repair", "provider": { "@id": canonical + "#business" }, "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ], "description": "Magic Chef wall oven repair across LA, 24\" compact + 30\" standard built-in, value-tier positioning. Apartment + ADU + rental property + institutional kitchen service. $89 residential diagnostic waived with repair.", "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, waived with repair" } } },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [ { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" }, { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" }, { "@type": "ListItem", "position": 3, "name": "Magic Chef", "item": "https://samedayappliance.repair/brands/magic-chef/" }, { "@type": "ListItem", "position": 4, "name": "Magic Chef Wall Oven Repair", "item": canonical } ] }
];
---

<Layout title={title} description={description} canonical={canonical}>
