---
import Layout from '../../layouts/Layout.astro';
import BrandDetailPlaceholder from '../../components/BrandDetailPlaceholder.astro';

const title = "Samsung Dryer Repair | Southern California | Same Day Service";
const description = "Expert Samsung dryer repair across Southern California. Same-day appointments, OEM parts, licensed technicians. Call (424) 325-0520.";
---

<Layout title={title} description={description}>
  <BrandDetailPlaceholder
    brandName="Samsung"
    brandSlug="samsung"
    category="Dryer"
    categorySlug="dryer-repair"
    hubUrl="/brands/samsung/"
  />
</Layout>
