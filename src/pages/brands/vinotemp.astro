---
// Phase 2 Cluster 4 #2 — Vinotemp wine cooler + custom cellar pillar.
// Brand: Vinotemp International, California, 30+ years heritage. Specialty
// wine cooler company + custom wine cellar systems. Mirrored / ProTech /
// Connoisseur / Standard series. Custom cellars often integrate
// CellarPro/WhisperKool/Breezaire cooling units (similar pattern к Le Cache).
// Residential pricing ($89). NEW schema pattern via mergeCredentials().

import Layout from '../../layouts/Layout.astro';
import ServiceHero from '../../components/ServiceHero.astro';
import { mergeCredentials } from '../../data/credentials-schema';

const phone = '(323) 870-4790';
const phoneRaw = phone.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/brands/vinotemp/";

const title = "Vinotemp Wine Cooler + Cellar Repair LA — Same Day";
const description = "Vinotemp wine cooler and custom cellar repair across LA. Mirrored, ProTech, Connoisseur series. Custom cellar systems integrating CellarPro/WhisperKool.";

const faqs = [
  { q: "Same-day Vinotemp service in LA?", a: "Yes for diagnostic and most common repairs. Most calls received before 2 PM get a tech on-site the same business day. Standard Vinotemp wine coolers (Mirrored, ProTech, Connoisseur, Standard) get diagnosed и repaired same-day for routine service items. Custom cellar installations с aftermarket cooling units run а little longer because identifying the cooling unit (CellarPro vs WhisperKool vs Breezaire) is the first diagnostic step и parts sourcing depends on which manufacturer is inside." },
  { q: "What's inside my Vinotemp custom wine cellar — is it a Vinotemp cooling unit или something else?", a: "Often something else. Vinotemp's specialty в the custom cellar category — entire room builds running $5,000-25,000+ — frequently uses aftermarket cooling units from CellarPro (1800/3000 series), WhisperKool (SC Pro / Platinum Split / Slimline / Mini Ceiling Mount families), or occasionally Breezaire (WKB through-cabinet units). The cabinet и shelving и wood-finishing work are Vinotemp; the cooling unit is the brand printed on the mechanical compartment. Our diagnostic identifies which cooling unit is installed during the first visit, и we service all three brands directly — see /brands/cellarpro/, /brands/whisperkool/, /brands/breezaire/ for the dedicated cooling-unit service approach. Standard Vinotemp wine coolers (Mirrored Series freestanding, ProTech undercounter, etc.) use Vinotemp's own cooling system; those service through Vinotemp parts directly." },
  { q: "Do you carry Vinotemp OEM parts on the truck?", a: "Common service parts ride on every wine cooler truck: door gaskets in standard Vinotemp configurations, evaporator and condenser fan motors, common control board components, drain heaters, и thermostat replacements for standard models. Mirrored Series specific parts (mirror-front door assemblies, premium hinges) и custom cellar specific parts come through Vinotemp distribution, typically 1-7 business days. For custom cellars с aftermarket cooling units inside, parts sourcing routes through whichever manufacturer's cooling unit is installed (CellarPro, WhisperKool, Breezaire) — we cover all three." },
  { q: "Can my standard Vinotemp wine cooler be repaired, или is replacement better math?", a: "Depends на which Series и age. ProTech Series и Connoisseur Series ($800-2000 retail when new) — repair almost always makes sense, even на 7-10 year-old units. Mirrored Series ($1000-2500) — same answer, repair typically wins. Standard Vinotemp consumer ($400-800 retail) — repair viable when quote comes in под $300; past that, replacement math gets close. Entry-level Vinotemp units ($300-500) — replacement usually wins. We identify your specific Series during diagnostic и frame the math honestly before you commit к parts cost." },
  { q: "Is Vinotemp still a California company, или has it been acquired?", a: "Vinotemp International is a California-based wine cooler specialist company с 30+ years heritage. Family-style operation в the wine cooler industry. We confirm current ownership status against the manufacturer's own corporate page when ownership questions matter for warranty или parts-source decisions; if you need a current verification before you make a purchase decision, the Vinotemp corporate site is the authoritative reference. Operating context for service — California-based parts distribution generally means reasonable lead times for OEM components." },
  { q: "Can you handle the entire custom cellar — cooling unit + cabinet + shelving?", a: "Yes — but our scope is service, not new construction. На existing Vinotemp custom cellars, we diagnose и repair the cooling system (whichever manufacturer's unit is installed), service the cabinet (door alignment, gasket replacement, shelving repair), и assess humidity и temperature management. New cellar builds, cabinet refurbishing, или major architectural modifications go through Vinotemp's installer network or qualified wine cellar contractors. We coordinate with those partners когда the scope crosses the service-vs-construction line." }
];

const localBusinessSchema = mergeCredentials({
  '@context': 'https://schema.org', '@type': 'HomeAndConstructionBusiness', '@id': canonical + '#business',
  name: 'Same Day Appliance Repair — Vinotemp Wine Cooler Service',
  url: canonical, telephone: phone, email: 'support@samedayappliance.repair', priceRange: '$$$',
  openingHoursSpecification: [
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'], opens: '08:00', closes: '20:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: 'Sunday', opens: '00:00', closes: '00:00' }
  ],
  areaServed: [
    { '@type': 'AdministrativeArea', name: 'Los Angeles County' }, { '@type': 'AdministrativeArea', name: 'Orange County' },
    { '@type': 'AdministrativeArea', name: 'Ventura County' }, { '@type': 'AdministrativeArea', name: 'San Bernardino County' },
    { '@type': 'AdministrativeArea', name: 'Riverside County' }
  ]
});

const serviceSchema = {
  '@context': 'https://schema.org', '@type': 'Service', '@id': canonical + '#service',
  serviceType: 'Vinotemp Wine Cooler Repair',
  name: 'Vinotemp Wine Cooler Repair, Same Day Appliance Repair',
  url: canonical,
  description: 'Same-day Vinotemp wine cooler and custom cellar repair across LA, Orange, Ventura, San Bernardino, and Riverside counties. Mirrored Series, ProTech Series, Connoisseur Series, Standard Vinotemp wine coolers, and custom cellar systems integrating CellarPro/WhisperKool/Breezaire cooling units. California specialty company, 30+ years heritage. EPA 608 Universal certified (#1346255700410), BHGS #A49573, CSLB C-20 HVAC. $89 residential diagnostic, applied toward repair.',
  provider: { '@id': canonical + '#business' },
  areaServed: [
    { '@type': 'AdministrativeArea', name: 'Los Angeles County' }, { '@type': 'AdministrativeArea', name: 'Orange County' },
    { '@type': 'AdministrativeArea', name: 'Ventura County' }, { '@type': 'AdministrativeArea', name: 'San Bernardino County' },
    { '@type': 'AdministrativeArea', name: 'Riverside County' }
  ],
  brand: { '@type': 'Brand', name: 'Vinotemp', sameAs: 'https://www.vinotemp.com/' },
  offers: { '@type': 'Offer', priceSpecification: { '@type': 'PriceSpecification', price: '89.00', priceCurrency: 'USD', description: 'Residential diagnostic fee, applied toward repair' } }
};

const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
const breadcrumbSchema = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
  { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://samedayappliance.repair/' },
  { '@type': 'ListItem', position: 2, name: 'Brands', item: 'https://samedayappliance.repair/brands/' },
  { '@type': 'ListItem', position: 3, name: 'Vinotemp', item: canonical }
]};
const schemaJsons = [localBusinessSchema, serviceSchema, faqSchema, breadcrumbSchema];
---

<Layout title={title} description={description} canonical={canonical}>
<Fragment slot="head-scripts">
  {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
</Fragment>

<ServiceHero
  eyebrow="Wine Cooler · Custom Cellars · California Heritage 30+ Years"
  title="Vinotemp Wine Cooler & Cellar Repair, Across Southern California"
  subtitle="Mirrored Series · ProTech · Connoisseur · Standard wine coolers, plus custom cellar systems. California specialty company с 30+ years experience. Custom cellars frequently integrate CellarPro / WhisperKool / Breezaire cooling units — our techs identify и service the actual cooling unit. EPA 608 Universal certified, BHGS #A49573. $89 residential diagnostic, waived with repair."
  heroImageTitle="Vinotemp Wine Cooler Repair"
  showBranches={true}
/>

<section class="section">
  <div class="container narrow">
    <p class="section-number">01, About this service</p>
    <h2>The California specialty name в wine storage, серьезный custom cellar tier</h2>
    <p>
      Vinotemp International is a California-based specialty wine cooler company с 30+ years of heritage. Unlike full-line
      appliance manufacturers, Vinotemp's entire business focuses on wine storage — freestanding wine coolers, undercounter
      built-ins, и most distinctively, full custom wine cellar systems that anchor serious LA collector homes. The custom
      cellar tier (entire room builds running $5,000-25,000+) is what differentiates Vinotemp from typical wine cooler brands;
      this is where Vinotemp competes against EuroCave's Origine family и Le Cache's Vista Series for serious collector
      installations.
    </p>
    <p>
      <strong>The technical detail that matters most for service:</strong> Vinotemp's custom cellars frequently integrate
      cooling units from <em>other manufacturers</em>. CellarPro (1800/3000 series) и WhisperKool (SC Pro, Platinum Split,
      Slimline, Mini Ceiling Mount families) are the most common cooling-unit choices in custom Vinotemp cellars; Breezaire
      WKB through-cabinet units appear less frequently но we see them. Standard Vinotemp wine coolers (Mirrored Series,
      ProTech, Connoisseur) use Vinotemp's own cooling system. Our diagnostic identifies which cooling unit is installed
      during the first visit и services it directly — we cover all three aftermarket cooling brands, see <a href="/brands/cellarpro/">/brands/cellarpro/</a>,
      <a href="/brands/whisperkool/">/brands/whisperkool/</a>, и <a href="/brands/breezaire/">/brands/breezaire/</a> для the
      dedicated service approaches.
    </p>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">02, Series and product coverage</p>
    <h2>What we service across the Vinotemp lineup</h2>

    <h3>Mirrored Series — luxury mirror-front design</h3>
    <p>
      Premium Vinotemp wine cooler line с reflective mirror-finish doors. Common в modern LA luxury homes where the wine
      cooler doubles as a design statement в kitchen или dining room. Capacity varies by configuration. Service approach is
      conventional wine cooler diagnostic с extra care на the mirrored door assembly during access work — the front-facing
      finish is part of the design value, и careless service can damage it.
    </p>

    <h3>ProTech Series — premium professional</h3>
    <p>
      Vinotemp's premium tier с upgraded construction, dual-zone temperature control on most configurations, и professional
      finish quality. Service items cluster around the standard wine cooler patterns: condenser cleanliness, gasket integrity,
      fan motor wear, control board electronics. Repair value math typically favors repair on units under 10 years.
    </p>

    <h3>Connoisseur Series — commercial-grade</h3>
    <p>
      Heavier-duty construction для restaurant и hospitality use, sometimes specified by serious residential collectors who
      want commercial-grade reliability. Build quality differentiates from consumer Vinotemp meaningfully. Used в Hollywood
      и Beverly Hills restaurants, hotel bars, и custom residential cellar setups where the homeowner wanted commercial-grade
      cooling without going к full custom cellar build.
    </p>

    <h3>Standard Vinotemp consumer wine coolers</h3>
    <p>
      Mid-market consumer line — entry through mid-tier residential wine cooler offerings. Build quality solid for the consumer
      tier, но service-life expectations adjust accordingly (7-10 years typical с maintenance vs 12-15 на ProTech/Connoisseur).
      Repair value math becomes a discussion above $300 quote on units under $800 retail.
    </p>

    <h3>Custom cellar systems — Vinotemp's specialty tier</h3>
    <p>
      Entire room builds running $5,000-25,000+ with custom cabinetry, shelving, climate control, и integrated cooling. The
      cooling unit inside a Vinotemp custom cellar is often a CellarPro 1800/3000 series или WhisperKool SC Pro/Platinum
      Split/Slimline. Our diagnostic identifies which cooling unit is installed; we service all three aftermarket brands
      directly. Service approach respects the surrounding architecture (custom cellar rooms аре serious investments — we don't
      damage finishes or shelving during access).
    </p>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">03, Common failure patterns</p>
    <h2>What we look at first on a Vinotemp call</h2>
    <ul class="bullet-list">
      <li><strong>Diagnostic order на standard Vinotemp wine coolers:</strong> condenser cleanliness first (LA dust + kitchen environments fou condensers in 6-8 weeks), door gasket compression set after 5-7 years on heavy-cycled units, evaporator fan motor wear на year 8-12 cluster, control board capacitor aging on units 10+ years с electronic displays, compressor end-of-life year 12-15 typical.</li>
      <li><strong>Mirrored Series specific:</strong> front-facing mirror finish requires careful access during repair work. Hinge wear sometimes shows on these — the mirror-finish doors can be slightly heavier than standard wine cooler doors, и hinges show wear faster on heavily-cycled units.</li>
      <li><strong>Custom cellar humidity drift в LA dry climate.</strong> LA's dry environment stresses humidification systems в custom cellars. Symptom is cellar humidity dropping below ideal range (corks aging prematurely), even на cellars с adequate cooling. Diagnostic checks the cooling unit's humidity management capability и cellar seal integrity. Sometimes the answer is а small humidity-supplement source inside the cellar; sometimes the cooling unit needs service для its dehumidification cycle.</li>
      <li><strong>Custom cellar cooling unit identification — first step.</strong> На custom cellar service calls, we identify which cooling unit is installed before anything else. CellarPro 1800/3000 series, WhisperKool SC Pro/Platinum Split/etc., or Breezaire WKB. Once identified, the service approach follows the cooling unit manufacturer's specific patterns. See dedicated cooling unit pillars.</li>
      <li><strong>Cabinet door seal aging on custom cellars.</strong> Custom cellar doors are usually wood-paneled с premium gasket systems. After 10-15 years, gaskets compress и lose seal. Replacement gaskets are available для most current Vinotemp custom cellar door designs through the manufacturer's parts channels.</li>
      <li><strong>Shelf system wear on heavily-accessed cellars.</strong> Vinotemp custom cellars use sliding shelf systems с beechwood или другими hardwood rails. After 10+ years of daily access, rails и slides develop wear. We service this when needed — это not a failure that takes the cellar offline, но affects user experience accessing the collection.</li>
    </ul>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">04, Where we work most on Vinotemp</p>
    <h2>The LA Vinotemp footprint our techs know best</h2>
    <p><strong>Bel Air, Beverly Hills, и Hidden Hills custom cellar rooms.</strong> Vinotemp custom cellar systems anchoring serious wine collections в estate-tier properties. Service approach is careful work — we coordinate с the homeowner's property manager or original cellar designer when needed, и we never force access where there's risk к the surrounding architecture.</p>
    <p><strong>Pacific Palisades и Newport Beach coastal homes.</strong> Mix of standard Vinotemp wine coolers и occasional custom cellar installations. Coastal exposure changes maintenance picture — we recommend more aggressive cleaning protocols для coastal installs.</p>
    <p><strong>Hollywood Hills и Studio City design-forward homes.</strong> Mirrored Series и ProTech Series в kitchen integrations или dining room display configurations. Service approach standard residential с extra care на the mirror-finish components.</p>
    <p><strong>Restaurant и hotel installations of Connoisseur Series.</strong> Commercial-grade Connoisseur deployments в LA restaurants и boutique hotel bars. Service work between meal services or during slow afternoon blocks.</p>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">05, Recent repairs</p>
    <h2>What this month looked like on Vinotemp</h2>
    <div class="repair-cards">
      <div class="repair-card">
        <p class="repair-quote">"My custom Vinotemp cellar is climbing temperature, и I have no idea what cooling unit is inside."</p>
        <p>Bel Air home, Vinotemp custom cellar room, install date per the homeowner approximately 2014. Diagnostic immediately identified the cooling unit: a CellarPro 1800 series mounted в the cellar's rear mechanical compartment. Condenser was heavily fouled — first cleaning since installation. Deep-cleaned coil, verified refrigerant charge under EPA 608, ran cabinet pull-down for 2 hours. Cabinet at 55°F by late afternoon. Recommended quarterly cleaning contract; homeowner signed up. Customer was specifically pleased that we identified the cooling unit on the first visit без needing to research или send а separate diagnostic — это why he called us instead of his original cellar designer.</p>
      </div>
      <div class="repair-card">
        <p class="repair-quote">"Mirrored Series stopped cooling, the mirror-front door is showing condensation на the bottom."</p>
        <p>Beverly Hills home, Mirrored Series freestanding wine cooler, install year per the homeowner approximately 2018. Diagnostic confirmed door gasket compression set on the bottom seal — the mirror-finish doors weigh slightly more than standard Vinotemp doors и cycle faster wear на the bottom seal. Replaced gasket с OEM Vinotemp part (sourced through California distribution, three business days), verified door alignment after replacement. The homeowner specifically chose Mirrored Series для the design statement — repair restored the design value plus the cooling functionality.</p>
      </div>
      <div class="repair-card">
        <p class="repair-quote">"Connoisseur in our wine bar is alarming intermittently — temperature hovering at 60°F instead of 55°F."</p>
        <p>Hollywood restaurant с wine bar program, Connoisseur Series commercial-grade built-in, install year per facility approximately 2017. Diagnostic ran condenser cleanliness first (acceptable — kitchen distance enough that fouling was limited), then verified refrigerant charge (within spec), then control board diagnostic. Confirmed evaporator fan motor degradation — bearings noisy on test, airflow measurably reduced. Sourced replacement через Vinotemp parts (4 business days). Returned for install on second visit, replaced motor, verified normal cabinet cooling. Documented service for facility records.</p>
      </div>
    </div>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">06, Why us, specifically</p>
    <h2>What makes us a fit for Vinotemp service</h2>
    <ul class="bullet-list">
      <li><strong>We identify custom cellar cooling units during diagnostic.</strong> CellarPro, WhisperKool, Breezaire — we service all three directly. Our diagnostic doesn't waste time figuring out who made the cooling unit; we know all three cooling-unit families.</li>
      <li><strong>EPA 608 Universal certification (#1346255700410).</strong> Required для refrigerant work на standard Vinotemp coolers и custom cellar cooling systems.</li>
      <li><strong>BHGS Registration #A49573 plus CSLB C-20 HVAC.</strong> California state coverage.</li>
      <li><strong>OEM parts only.</strong> Vinotemp parts через Vinotemp authorized distribution; CellarPro/WhisperKool/Breezaire parts через those manufacturers' channels.</li>
      <li><strong>$89 residential diagnostic, waived с repair.</strong> Honest tier-split repair-vs-replace math during diagnostic — we don't push repairs on disposable units, и we don't undersell repair value on premium ProTech/Connoisseur/Mirrored Series.</li>
      <li><strong>Custom cellar service experience.</strong> Most LA custom cellar service work involves Vinotemp installations с aftermarket cooling units inside — we navigate this routinely.</li>
      <li><strong>BBB Accredited Business and $1M general liability insured.</strong></li>
    </ul>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">07, Frequently asked questions</p>
    <h2>The questions we get most on Vinotemp calls</h2>
    <div class="faq-list">
      {faqs.map(f => (<details class="faq-item"><summary>{f.q}</summary><p>{f.a}</p></details>))}
    </div>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">08, Cooling unit pillars и related wine cellar services</p>
    <h2>Vinotemp service в context</h2>
    <p>Vinotemp custom cellars frequently house cooling units from manufacturers we service directly. Links below cover those dedicated service pages plus other premium wine cellar brands:</p>
    <ul class="cross-links">
      <li><a href="/brands/cellarpro/">CellarPro wine cellar cooling</a> — cooling unit common в Vinotemp custom cellars</li>
      <li><a href="/brands/whisperkool/">WhisperKool wine cellar cooling</a> — cooling unit common в Vinotemp custom cellars</li>
      <li><a href="/brands/breezaire/">Breezaire wine cellar cooling</a> — cooling unit occasionally в Vinotemp custom cellars</li>
      <li><a href="/brands/eurocave/">EuroCave wine cellars</a> — French luxury alternative</li>
      <li><a href="/brands/le-cache/">Le Cache wine cabinets</a> — American hardwood specialist (similar cooling-unit identification pattern)</li>
      <li><a href="/brands/summit-wine-cooler/">Summit wine cooler</a> — commercial-grade alternative</li>
      <li><a href="/services/wine-cooler-repair/">Wine cooler repair (all brands)</a></li>
    </ul>
  </div>
</section>

<section class="bottom-cta">
  <div class="container narrow">
    <h2>Same-day Vinotemp service across Southern California</h2>
    <p>$89 residential diagnostic, waived with repair. EPA 608 Universal certified, BHGS #A49573, CSLB C-20 HVAC, BBB Accredited.</p>
    <div class="cta-row">
      <a href={phoneHref} class="btn-red">Call {phone}</a>
      <a href="/contact/" class="btn-outline">Request service →</a>
    </div>
  </div>
</section>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .section { padding: 64px 24px; }
  .section-gray { background: var(--gray); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .container.narrow { max-width: 820px; margin: 0 auto; }
  .section-number { font-size: 12px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--red); margin: 0 0 12px; }
  h2 { font-size: clamp(22px, 3vw, 32px); font-weight: 700; line-height: 1.2; margin: 0 0 20px; color: var(--text); letter-spacing: -.01em; }
  h3 { font-size: 18px; font-weight: 700; margin: 24px 0 10px; color: var(--text); }
  p { font-size: 16px; line-height: 1.7; color: var(--text); margin: 0 0 14px; }
  strong { font-weight: 700; }
  em { font-style: italic; }
  a { color: var(--red); text-decoration: none; }
  a:hover { text-decoration: underline; }
  .bullet-list { list-style: none; padding: 0; margin: 16px 0; }
  .bullet-list li { position: relative; padding: 12px 0 12px 22px; font-size: 15.5px; line-height: 1.65; border-bottom: 1px solid var(--border); }
  .bullet-list li:last-child { border-bottom: none; }
  .bullet-list li::before { content: "▸"; position: absolute; left: 0; color: var(--red); font-weight: 700; }
  .repair-cards { display: grid; gap: 20px; margin-top: 20px; }
  .repair-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 22px 26px; }
  .repair-quote { font-style: italic; color: var(--red); font-weight: 600; margin: 0 0 12px; font-size: 15px; }
  .repair-card p:last-child { margin-bottom: 0; }
  .faq-list { margin-top: 20px; }
  .faq-item { border-bottom: 1px solid var(--border); padding: 16px 0; }
  .faq-item:last-child { border-bottom: none; }
  .faq-item summary { cursor: pointer; font-weight: 700; font-size: 16px; color: var(--text); padding: 4px 0; }
  .faq-item summary:hover { color: var(--red); }
  .faq-item p { margin: 12px 0 4px; font-size: 15.5px; color: var(--text); }
  .cross-links { list-style: none; padding: 0; margin: 16px 0 0; }
  .cross-links li { padding: 10px 0; border-bottom: 1px solid var(--border); font-size: 15px; }
  .cross-links li:last-child { border-bottom: none; }
  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { color: #fff; }
  .bottom-cta p { color: rgba(255,255,255,.85); max-width: 640px; margin: 0 auto 24px; }
  .bottom-cta a { color: #fff; }
  .cta-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-red { background: var(--red); color: #fff; padding: 14px 28px; border-radius: 6px; font-weight: 600; text-decoration: none; }
  .btn-outline { border: 1.5px solid rgba(255,255,255,.3); color: #fff; padding: 14px 28px; border-radius: 6px; font-weight: 600; text-decoration: none; }
</style>
