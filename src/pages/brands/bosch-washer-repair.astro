---
import Layout from '../../layouts/Layout.astro';

const title = "Bosch Washer Repair Los Angeles | 300/500/800 Series, Axxis Compact";
const description = "Bosch washer repair across LA. Factory-Trained specialists for 300/500/800 Series 24\" compact front-load and Axxis washers. Drum bearings, E04/E18/E23 codes, door boot seal. $89 diagnostic waived with repair. Call (424) 325-0520.";

/* 5 BRANCH PHONES */
const branches = [
  { name: "West Hollywood",  phone: "(323) 870-4790", tel: "+13238704790", areas: "WeHo · Beverly Hills · Hollywood · Mid-City" },
  { name: "Los Angeles",     phone: "(424) 325-0520", tel: "+14243250520", areas: "Mid-Wilshire · Brentwood · Santa Monica · Culver City" },
  { name: "Thousand Oaks",   phone: "(424) 208-0228", tel: "+14242080228", areas: "Ventura County · Calabasas · Agoura · Westlake · Malibu" },
  { name: "Pasadena",        phone: "(626) 376-4458", tel: "+16263764458", areas: "Pasadena · San Marino · Arcadia · Glendale · SGV" },
  { name: "Irvine",          phone: "(213) 401-9019", tel: "+12134019019", areas: "Orange County · Newport Beach · Irvine · Anaheim" },
];
const mainPhone = branches[1];

const namedTechs = [
  { name: "Mikhail V.", role: "Bosch/Thermador Specialist · 12 yrs", photo: "/images/techs/placeholder-1.jpg", areas: "Westside · West Hollywood · Beverly Hills" },
  { name: "Artur S.",   role: "Built-in Installation & Repair · 9 yrs", photo: "/images/techs/placeholder-2.jpg", areas: "Pasadena · San Marino · Arcadia" },
  { name: "David K.",   role: "European Appliance Specialist · 14 yrs", photo: "/images/techs/placeholder-3.jpg", areas: "Malibu · Pacific Palisades · Calabasas" },
];

const faqs = [
  {
    q: "How much does Bosch washer repair cost in Los Angeles?",
    a: "Most Bosch washer repairs in LA land between $220 and $580 all-in, parts and labor combined. Drum bearing replacement runs $480–$650 because it's labor-intensive — 4+ hours of disassembly. Drain pump replacement averages $240. Door boot seal replacement lands $280–$380. Water inlet valve is $220–$300. Control board replacement comes in around $380. Our $89 diagnostic is waived when you approve the repair — no $179 call-out fee, no 6-minute metered labor."
  },
  {
    q: "What does E04 / E18 / E23 mean on my Bosch washer?",
    a: "These are Bosch water-system error codes. E04 means the water level sensor detects a fill problem — usually a failed pressure switch, clogged air dome tube, or stuck inlet valve. E18 means the washer can't drain — drain pump jam, clogged pump filter, or kinked drain hose. E23 specifically means the drain pump motor itself is not running — impeller seized or motor windings open. If you clear the error and it returns within one cycle, stop running the washer and call us. Running with a water-system code active risks water damage."
  },
  {
    q: "My Bosch washer is loud on spin — is the bearing going?",
    a: "Almost certainly yes, if the noise is a deep rumble that's louder on high-speed spin and quieter or gone on low-speed. Bosch drum bearings on 300/500/800 Series wear out around years 7–9 in a typical LA household — sooner on heavy users with 2+ loads a day. The bearing replacement is the single most expensive Bosch washer repair because the outer tub on most Bosch models is welded, not bolted — we replace the entire tub-and-bearing assembly. It's a 4+ hour job, manufacturer-approved part. If the unit is over 10 years old and needs a bearing, we help you run the repair-vs-replace math honestly before starting."
  },
  {
    q: "Why do 24-inch Bosch washers fail differently than 27-inch American washers?",
    a: "Bosch's US lineup is 24\" compact (European format) — smaller drum, faster spin (up to 1400 RPM), smaller load capacity. The 24\" drum spins at higher G-forces than a 27\" American washer to extract more water, which means the bearings, suspension springs, and shock absorbers wear on a different timeline. LA condos, townhouses, and stacked laundry closets almost always have Bosch 24\" because the 27\" doesn't fit — so our LA repair volume skews heavily toward this format. We stock the 24\" parts."
  },
  {
    q: "Do you service stacked Bosch washer-dryer units?",
    a: "Yes, constantly. In LA condos and lofts, stacked Axxis and 300 Series pairs in laundry closets are the rule, not the exception. We bring a stack-unstack protocol: safely lowering the dryer, servicing the washer underneath, restacking with the proper stacking kit hardware. No dings in the closet wall, no scratched side panels. Stacked service takes 30–45 minutes longer than a freestanding unit — price is the same, we don't charge extra."
  },
  {
    q: "Is it worth repairing a 9-year-old Bosch washer?",
    a: "Depends on the specific failure. Drum bearing ($500+) on a 9-year-old unit is a closer call — we'd honestly tell you to weigh replacement, since the clock is starting on the motor and control board too. But a drain pump ($240), inlet valve ($280), door boot ($350), or control board ($380) on a 9-year-old Bosch is almost always worth repairing. The stainless drum and cabinet will run another 5+ years. Replacement Bosch washer new is $1,000–$1,800, so most component failures pencil out as repair."
  },
  {
    q: "Are you Bosch Factory-Trained for washers specifically?",
    a: "Our technicians complete manufacturer training on Bosch laundry platforms each year — 300, 500, 800 Series front-loaders, and Axxis compact models. We're licensed (CA), insured ($2M liability), BBB A+ rated. We're independent, not Bosch Factory Service subcontractors, which is why our pricing is different: no $179 call-out fee, no 6-minute metered labor, flat price quoted before work. Same manufacturer-approved parts either way."
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
};

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Same Day Appliance Repair",
  "image": "https://samedayappliance.repair/logo.png",
  "telephone": "(424) 325-0520",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "6230 Wilshire Blvd Ste A PMB 2267",
    "addressLocality": "Los Angeles",
    "addressRegion": "CA",
    "postalCode": "90048",
    "addressCountry": "US"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.6",
    "reviewCount": "37"
  }
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Bosch Washer Repair",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Same Day Appliance Repair",
    "telephone": "(424) 325-0520"
  },
  "areaServed": { "@type": "City", "name": "Los Angeles" }
};
---

<Layout title={title} description={description}>
  <Fragment slot="head-scripts">
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  </Fragment>

  <!-- 0. CALL BANNER -->
  <div class="call-banner">
    <div class="container call-banner-inner">
      <span class="cb-label">Bosch Washer Not Working? —</span>
      <a href={`tel:${mainPhone.tel}`} class="cb-phone">Call {mainPhone.phone}</a>
      <span class="cb-sep">·</span>
      <a href={`sms:${mainPhone.tel}`} class="cb-sms">Text us a photo</a>
    </div>
  </div>

  <!-- 1. HERO -->
  <section class="bosch-hero">
    <div class="container hero-grid">
      <div class="hero-text">
        <div class="hero-eyebrow">Factory-Trained · Post-Warranty Bosch Specialists</div>
        <h1>Bosch Washer Repair in Los Angeles</h1>
        <p class="hero-sub">
          Drum bearing failures. E04/E18/E23 error codes. Door boot seal tears.
          Stacked laundry closets. Our Factory-Trained technicians work on
          Bosch 24" compact washers every day across LA — 300, 500, 800 Series,
          Axxis. Manufacturer-approved parts. Same-day appointments.
        </p>

        <div class="branch-select">
          <label for="branchPicker" class="bs-label">Your area:</label>
          <select id="branchPicker" class="bs-dropdown" onchange="
            const b = this.options[this.selectedIndex];
            const phoneEl = document.getElementById('heroPhoneBtn');
            phoneEl.href = 'tel:' + b.dataset.tel;
            phoneEl.textContent = 'Call ' + b.dataset.phone;
          ">
            {branches.map((b, i) => (
              <option value={b.name} data-tel={b.tel} data-phone={b.phone} selected={i === 1}>
                {b.name} — {b.areas}
              </option>
            ))}
          </select>
        </div>

        <div class="hero-ctas">
          <a id="heroPhoneBtn" href={`tel:${mainPhone.tel}`} class="btn btn-red">Call {mainPhone.phone}</a>
          <a href="/schedule/" class="btn btn-hero-outline">Schedule Online</a>
          <a href={`sms:${mainPhone.tel}?body=Bosch washer photo — `} class="btn btn-hero-outline btn-sms">📷 Text Photo</a>
        </div>

        <div class="hero-badge">
          <span class="badge-amount">$89</span>
          <span class="badge-text">Diagnostic — <strong>waived</strong> when you approve the repair. No $179 call-out fee.</span>
        </div>
      </div>
      <div class="hero-image">
        <div class="image-frame">
          <div class="image-ring"></div>
          <img src="/images/bosch-washer-repair.jpg" alt="Bosch 800 Series compact washer repair Los Angeles" loading="eager" />
        </div>
      </div>
    </div>
  </section>

  <!-- 2. CREDS BAR -->
  <section class="creds-bar">
    <div class="container">
      <div class="creds-grid">
        <div class="cred"><span class="cred-icon">★</span><div><strong>BBB A+ Rated</strong><span>Accredited business</span></div></div>
        <div class="cred"><span class="cred-icon">✓</span><div><strong>Factory-Trained</strong><span>300 · 500 · 800 · Axxis</span></div></div>
        <div class="cred"><span class="cred-icon">⚖</span><div><strong>Licensed &amp; Insured</strong><span>CA Lic. · $2M liability</span></div></div>
        <div class="cred"><span class="cred-icon">⚡</span><div><strong>EPA-Certified</strong><span>Refrigerant-safe</span></div></div>
        <div class="cred"><span class="cred-icon">⌚</span><div><strong>Same-Day Service</strong><span>Stacked unit specialists</span></div></div>
      </div>
    </div>
  </section>

  <!-- 3. POST-WARRANTY POSITIONING -->
  <section class="positioning">
    <div class="container container-narrow">
      <div class="pos-eyebrow">Who We Serve</div>
      <h2>LA's Post-Warranty Bosch Washer Specialists</h2>
      <p>
        Bosch's factory warranty covers one year on parts and labor. After that,
        owners face a choice — call Bosch Factory Service at $179 per visit plus
        $25 every 6 minutes of metered labor, or find an independent shop that
        actually knows the 24" compact front-loader platforms.
      </p>
      <p>
        Most of our Bosch washer calls are units aged 2–12 years. The drain
        pump, water inlet valve, door boot seal, and control board all fail in
        predictable windows. The big one — the drum bearing — typically shows
        up around years 7–9 as a deep rumble on high-speed spin. Catch it
        early, the repair stays contained; wait too long, and the bearing
        destroys the shaft seal, then water reaches the motor.
      </p>
      <p>
        Because LA condos, townhouses, and lofts almost always use 24" compact
        rather than 27" American washers, our repair volume on Bosch is
        disproportionately high. We stock the 24" parts that freestanding
        appliance shops rarely carry.
      </p>
    </div>
  </section>

  <!-- 4. INTRO -->
  <section class="intro">
    <div class="container container-narrow">
      <p class="lead">
        Bosch washers have a specific failure curve in Los Angeles — drum
        bearings at year 7–9 are the single biggest repair, and E04/E18/E23
        water-system codes are the most common service calls.
      </p>
      <p>
        The 24" compact format spins faster than American 27" units — up to
        1,400 RPM on high-spin cycles — which extracts more water but puts more
        load on bearings, suspension springs, and shock absorbers. In a
        two-person household doing 4–6 loads a week, bearings typically last 8–10
        years. In a family of four doing 10+ loads a week, closer to 5–7 years.
      </p>
      <p>
        The second biggest category is drain-system failures. A loose coin, a
        hairpin, or a wire from an underwire bra jams the pump impeller. LA
        hard water also sends calcium scale into the pump over time. Most of
        these we fix same visit — pull the filter, clear the debris, verify
        pump motor function, and the washer is back online in 45 minutes.
      </p>
    </div>
  </section>

  <!-- 5. NAMED TECHNICIANS -->
  <section class="techs">
    <div class="container">
      <div class="section-heading">
        <span class="section-num">01</span>
        <h2>Meet the Technicians Who Service Your Bosch</h2>
      </div>
      <p class="section-lead">
        You'll know the name and face of the tech before they arrive. Our Bosch
        washer specialists are Factory-Trained, background-checked, and
        assigned by neighborhood.
      </p>
      <div class="techs-grid">
        {namedTechs.map(t => (
          <div class="tech-card">
            <div class="tech-photo">
              <img src={t.photo} alt={`${t.name} — ${t.role}`} loading="lazy" />
            </div>
            <div class="tech-info">
              <h3>{t.name}</h3>
              <div class="tech-role">{t.role}</div>
              <div class="tech-areas">Primary areas: {t.areas}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 6. TRY THIS FIRST -->
  <section class="diy-check">
    <div class="container container-narrow">
      <div class="section-heading">
        <span class="section-num">02</span>
        <h2>Before You Call — Four Quick Checks</h2>
      </div>
      <p class="section-lead">
        A few Bosch washer calls we dispatch turn out to be simple fixes.
        Worth 60 seconds before scheduling.
      </p>
      <ol class="diy-list">
        <li>
          <strong>Check the drain pump filter.</strong> Bottom-front of most
          Bosch washers — small access panel, twist-out filter. Put a towel
          and shallow pan down first, it'll dump about a quart of water. Clear
          coins, hairpins, and debris. Runs 5 minutes. Fixes maybe 20% of
          "won't drain" calls.
        </li>
        <li>
          <strong>Make sure the door is latching fully.</strong> The
          interlock has to engage or the cycle won't start. If the door
          "feels" closed but the unit shows a door-open warning, the latch
          microswitch may be failing — worth a gentle re-close before
          calling.
        </li>
        <li>
          <strong>Check the drain hose for kinks.</strong> Behind the unit —
          the drain hose can get compressed against the wall, especially on
          stacked units in tight closets. A fully kinked hose throws E18
          within one cycle.
        </li>
        <li>
          <strong>Run a Drum Clean cycle with Affresh (or vinegar).</strong>
          If you're getting smell, visible mold on the door boot, or black
          spots on the drum gasket, the fix is usually not a service call
          yet — it's a hot Drum Clean cycle. If the smell persists after two
          cleans, then call.
        </li>
      </ol>
      <p class="diy-foot">
        Still broken? That's what we're here for. <a href={`tel:${mainPhone.tel}`}>{mainPhone.phone}</a>
        or <a href={`sms:${mainPhone.tel}?body=Bosch washer photo — `}>text us a photo</a>.
      </p>
    </div>
  </section>

  <!-- 7. COMMON PROBLEMS -->
  <section class="problems">
    <div class="container">
      <div class="section-heading">
        <span class="section-num">03</span>
        <h2>Bosch Washer Problems We Fix Every Week</h2>
      </div>
      <div class="problems-grid">
        <div class="problem-card">
          <h3>Drum Bearing Failure</h3>
          <p><strong>What it means:</strong> deep rumble or grinding noise on high-speed spin, louder with heavier loads. Year 7–9 pattern on 300/500/800 Series. Left too long, the bearing destroys the shaft seal and water reaches the motor.</p>
          <p><strong>How we fix it:</strong> full tub-and-bearing assembly replacement with manufacturer-approved part. 4+ hour job because the Bosch outer tub on most models is welded, not bolted. Labor-intensive but extends unit life 5+ years.</p>
        </div>
        <div class="problem-card">
          <h3>E04 — Water Level Sensor Fault</h3>
          <p><strong>What it means:</strong> the pressure switch or air dome tube is failing — washer can't read water level accurately. Often cycles without filling, or fills and won't progress.</p>
          <p><strong>How we fix it:</strong> inspect air dome tube for kinks or calcium blockage, test pressure switch with a hand pump, verify wiring continuity. Replace failed component — pressure switch is the most common cause.</p>
        </div>
        <div class="problem-card">
          <h3>E18 / E23 — Drain Pump Problems</h3>
          <p><strong>What it means:</strong> E18 = can't drain (blockage or pump issue). E23 = pump motor itself not running (seized impeller or failed windings). Both leave water in the tub at cycle end.</p>
          <p><strong>How we fix it:</strong> pull the pump filter and clear debris (coins, hairpins, wire). Meter the pump motor. Replace pump assembly if motor failed. Clear drain hose path if separately clogged.</p>
        </div>
        <div class="problem-card">
          <h3>Door Boot Seal Tear / Mold</h3>
          <p><strong>What it means:</strong> rubber gasket between door and tub torn or moldy. Underwire bras and loose buttons are the usual cause. Tear allows water leakage; mold allows odor and potential allergen exposure.</p>
          <p><strong>How we fix it:</strong> full door boot seal replacement, inspection of outer tub for additional damage, replacement of drum-bearing seals if water has leaked past. Manufacturer-approved gasket only — aftermarket boots fail within 18 months.</p>
        </div>
        <div class="problem-card">
          <h3>Won't Fill / Slow Fill</h3>
          <p><strong>What it means:</strong> washer starts but takes 10+ minutes to reach fill level, or doesn't reach it at all. LA hard water clogs the inlet valve screen with calcium.</p>
          <p><strong>How we fix it:</strong> test water pressure at supply, check and clean inlet valve screens, meter the solenoid. Replace the inlet valve if solenoid failed. 30-minute fix typically.</p>
        </div>
        <div class="problem-card">
          <h3>Door Lock / Interlock Failure</h3>
          <p><strong>What it means:</strong> door won't latch, or latches but unit won't start. Microswitch inside the latch assembly failed, or the lock solenoid isn't engaging. E32 code is the specific indicator.</p>
          <p><strong>How we fix it:</strong> test interlock circuit, verify door strike alignment, replace latch assembly if microswitch or solenoid failed. Keep in mind — a failing door lock can be a safety issue; we don't kluge this repair.</p>
        </div>
        <div class="problem-card">
          <h3>Motor Brush Wear / Motor Control Failure</h3>
          <p><strong>What it means:</strong> drum turns slowly, stops mid-cycle, or doesn't turn at all. Carbon brushes on the drive motor wear through year 8–10. Motor control board can also fail from power surges.</p>
          <p><strong>How we fix it:</strong> inspect brushes — replace if worn to spec minimum. Meter the motor control board. Replace whichever component is failing. Brushes are a $150 part; boards are $280–$380.</p>
        </div>
        <div class="problem-card">
          <h3>Control Board / Display Dead</h3>
          <p><strong>What it means:</strong> no lights, unresponsive touch controls, random errors that don't match symptoms. LA brownouts and surges cause most main board failures.</p>
          <p><strong>How we fix it:</strong> isolate main control board from user interface — they fail separately. Replace whichever is failing. 800 Series boards in stock for most models.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 8. STACKED & COMPACT PROTOCOL -->
  <section class="builtin">
    <div class="container container-narrow">
      <div class="section-heading">
        <span class="section-num">04</span>
        <h2>Stacked Units &amp; Tight Laundry Closets — Our Service Protocol</h2>
      </div>
      <p>
        Most LA condos, townhouses, and lofts have stacked Bosch pairs in
        laundry closets with 2–4 inches of clearance on each side. On Axxis
        units and 300/500 Series pairs, service means dropping the dryer off
        the washer to reach the pump, boot seal, or inlet valve. Done wrong,
        you gouge the closet walls, scratch side panels, or drop a 130 lb
        dryer.
      </p>
      <div class="builtin-list">
        <div class="bl-item">
          <div class="bl-num">1</div>
          <div>
            <strong>Protective floor and wall covering first.</strong>
            Moving blankets under the unit, cardboard on adjacent walls if
            clearance is under 3 inches. Service-call carpet runner from
            closet to staging area.
          </div>
        </div>
        <div class="bl-item">
          <div class="bl-num">2</div>
          <div>
            <strong>Two-technician dryer lift for stacked pairs.</strong>
            Dryer disconnected, walked off the washer with two hands per
            side, staged on protective padding. Single-tech drop risks
            damaged closet framing and personal injury.
          </div>
        </div>
        <div class="bl-item">
          <div class="bl-num">3</div>
          <div>
            <strong>Service access from the front when possible.</strong>
            Bosch 24" units are designed for front access — pump filter,
            door boot, most electrical accessed without pulling the unit.
            We pull only when the repair requires it.
          </div>
        </div>
        <div class="bl-item">
          <div class="bl-num">4</div>
          <div>
            <strong>Restack with proper stacking kit hardware.</strong>
            Bosch uses specific stacking kits (WTZ11400, WTZ11310) —
            mismatched or missing hardware means the dryer can walk during
            high-spin cycles. We verify kit and reinstall to factory spec.
          </div>
        </div>
      </div>
      <p class="builtin-note">
        Stacked service takes 30–45 minutes longer than a freestanding call.
        Price is the same.
      </p>
    </div>
  </section>

  <!-- 9. MODELS -->
  <section class="models">
    <div class="container">
      <div class="section-heading">
        <span class="section-num">05</span>
        <h2>Bosch Washer Models We Service</h2>
      </div>
      <p class="section-lead">
        Our technicians are trained across the full US-market Bosch washer
        lineup. All 24" compact front-loaders. If your model isn't listed,
        call us — we almost certainly do it.
      </p>
      <div class="models-grid">
        <div class="models-col">
          <h3>800 Series</h3>
          <p class="series-desc">Top tier. Home Connect Wi-Fi, 15 cycles, 1400 RPM spin. 2.2 cu ft.</p>
          <ul>
            <li>WAW285H2UC</li><li>WGA12400UC</li>
            <li>WAT28402UC</li><li>WAT28400UC</li>
          </ul>
        </div>
        <div class="models-col">
          <h3>500 Series</h3>
          <p class="series-desc">Mid-tier. ActiveWater, AquaStop, 1200 RPM spin. 2.2 cu ft.</p>
          <ul>
            <li>WAT28400UC</li><li>WAT28401UC</li>
            <li>WFVC5400UC</li>
          </ul>
        </div>
        <div class="models-col">
          <h3>300 Series</h3>
          <p class="series-desc">Entry-compact. ActiveWater tech, 1200 RPM spin. Common in rentals.</p>
          <ul>
            <li>WFMC5301UC</li><li>WFMC3301UC</li>
            <li>WAS24460UC</li>
          </ul>
        </div>
        <div class="models-col">
          <h3>Axxis Compact</h3>
          <p class="series-desc">Legacy compact line, still in service across LA condos. 120V.</p>
          <ul>
            <li>WFL2060UC</li><li>WFL2090UC</li>
            <li>WFR2450UC</li><li>WFR2460UC</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- 10. FACTORY SERVICE COMPARISON -->
  <section class="comparison">
    <div class="container container-narrow">
      <div class="section-heading">
        <span class="section-num">06</span>
        <h2>How Our Pricing Compares to Bosch Factory Service</h2>
      </div>
      <p class="section-lead">
        Bosch Factory Service is one option after warranty expires. Here's how
        our LA pricing stacks up, based on Bosch's publicly posted rates.
      </p>
      <div class="compare-table">
        <div class="compare-row compare-header">
          <span>Cost Item</span>
          <span>Bosch Factory Service</span>
          <span>Same Day Appliance Repair</span>
        </div>
        <div class="compare-row">
          <span>Call-out / trip fee</span>
          <span>$179 flat</span>
          <span>$0 separate trip fee</span>
        </div>
        <div class="compare-row">
          <span>Diagnostic fee</span>
          <span>$25 per 6 minutes (metered)</span>
          <span>$89 flat — waived with repair</span>
        </div>
        <div class="compare-row">
          <span>Labor during repair</span>
          <span>$25 per 6 minutes (metered)</span>
          <span>Flat price quoted before work</span>
        </div>
        <div class="compare-row">
          <span>Stacked unit handling</span>
          <span>Standard drop</span>
          <span>Two-tech lift protocol (no extra charge)</span>
        </div>
        <div class="compare-row">
          <span>Parts</span>
          <span>Bosch manufacturer-approved</span>
          <span>Bosch manufacturer-approved</span>
