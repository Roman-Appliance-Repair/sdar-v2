---
import Layout from '../../layouts/Layout.astro';
import BrandBranchesGrid from '../../components/BrandBranchesGrid.astro';
import { MAIN_PHONE, MAIN_PHONE_TEL } from '../../data/branches';

const title = "Maytag Ice Maker Repair | Southern California | 10-Year Warranty + Whirlpool-Family";
const description = "Maytag ice maker repair across Southern California — MFI French-door, MSS side-by-side, MZC counter-depth. Whirlpool-family cross-fit parts, EveryDrop filter. $89 diagnostic. (424) 325-0520.";
const canonical = "https://samedayappliance.repair/brands/maytag-ice-maker-repair/";

const faqs = [
  {
    q: "Is Maytag the same as Whirlpool for ice maker parts?",
    a: "Largely yes — Maytag has been a Whirlpool Corporation brand since 2006 (Whirlpool acquired Maytag Corp + moved production to Benton Harbor MI). The core modular ice-maker assembly shared across Whirlpool / Maytag / KitchenAid / Amana means industry-standard W10190961-class parts typically drop into Maytag refrigerators. Our techs carry the common W-series modules on the truck — if your Maytag needs an ice-maker module, we likely have it in stock. Some Maytag models use brand-specific trim or dispenser parts that differ from Whirlpool baseline, but the core ice-maker module cross-fits in most cases. See <a href='/brands/whirlpool-ice-maker-repair/'>Whirlpool ice maker repair</a> for the parent-brand context."
  },
  {
    q: "Does the Maytag 10-Year Warranty cover my ice maker?",
    a: "Maytag's Dependability 10-year limited warranty is a signature consumer-trust marker but coverage is selective — the 10-year typically covers specific parts (compressor, drive motor on laundry, certain refrigerator components) rather than every component. Ice-maker modular assembly is generally NOT covered under the 10-year warranty, but water-inlet valve, some sensors, and certain drive components may be. At diagnostic we verify your specific model's current warranty terms and quote both warranty-claim and out-of-warranty service paths. Even if the 10-year doesn't apply, standard residential service at $89 diagnostic waived with repair covers the work."
  },
  {
    q: "Maytag ice maker not making ice — what's the diagnostic order?",
    a: "Same core diagnostic as Whirlpool-family: (1) water-inlet valve — Maytag valves typically fail at 5-8 year mark; valve swap $180–$280; (2) modular ice-maker assembly $220–$360; (3) EveryDrop water filter clog (EDR1/EDR2/EDR3 depending on model); filter $55–$85; (4) thermistor $160–$240; (5) ejector motor inside module $140–$220; (6) freezer temperature verification 0°F or colder. Our techs run the standard Whirlpool-family diagnostic sequence on Maytag — 80% of calls resolve at valve or module replacement."
  },
  {
    q: "Maytag ice maker ice tastes bad or cloudy — what's wrong?",
    a: "Water-quality issues typically trace to: (1) EveryDrop filter at or past 6-month replacement mark — neglected filter causes cloudy ice + off-taste; filter $55–$85 is the first fix; (2) water-line scale or biofilm buildup in LA hard water — fill-tube + line clean $140–$240; (3) water-inlet valve partial restriction — reduced fill pressure creates cloudy ice; valve $180–$280 when filter + line clean doesn't resolve; (4) ice-bin cleaning — household-side maintenance clears mineral / dust buildup from old ice. Our techs check filter age first (cheapest fix), then check fill-line + valve."
  },
  {
    q: "What does Maytag ice maker repair cost in LA?",
    a: "Residential diagnostic $89 waived with repair. Typical Maytag bands: water-inlet valve $180–$280; modular ice-maker assembly $220–$360; ejector motor $140–$220; thermistor $160–$240; EveryDrop filter $55–$85; fill-tube / line clean $140–$240; evaporator fan motor $240–$360; door-seal gasket $160–$240; control board $380–$560. Whirlpool-family parts cross-fit means strong availability + same-day parts through multiple LA distributors."
  },
  {
    q: "Maytag vs Whirlpool vs Amana — why pick Maytag?",
    a: "All three are Whirlpool Corp brands with shared ice-maker parts architecture, but distinct market positions. <b>Maytag</b> carries the Dependability 10-year warranty badge + premium-mass-market positioning — customers picking Maytag are typically choosing for the warranty + brand-trust story. <b>Whirlpool</b> is the mainstream mass-market baseline. <b>Amana</b> is the value-tier within the family. Same core ice-maker service applies across all three. See <a href='/brands/whirlpool-ice-maker-repair/'>Whirlpool</a> for parent-brand context."
  },
  {
    q: "Maytag ice maker vs commercial ice machines?",
    a: "Maytag is residential-only in ice — no Maytag commercial ice machine line. Maytag Commercial exists for laundry (see <a href='/commercial/laundry-repair/'>commercial laundry repair</a>) but not for ice. For restaurant / bar / commercial 200+ lb/day ice production, see <a href='/commercial/ice-machine-repair/'>commercial ice machine repair</a> (Manitowoc, Hoshizaki, Scotsman, Follett)."
  }
];

const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair — Maytag Ice Maker Service",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": canonical, "telephone": MAIN_PHONE_TEL, "priceRange": "$$"
  },
  { "@context": "https://schema.org", "@type": "Service", "serviceType": "Maytag Ice Maker Repair",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "description": "Maytag ice maker repair across LA — MFI French-door, MSS side-by-side, MZC counter-depth. Whirlpool-family cross-fit parts (W10190961 class), EveryDrop filter. $89 residential diagnostic waived with repair.",
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, waived with repair" } }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "Maytag", "item": "https://samedayappliance.repair/brands/maytag/" },
      { "@type": "ListItem", "position": 4, "name": "Maytag Ice Maker Repair", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">{schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}</Fragment>
  <div class="call-banner"><div class="wrap"><span>Maytag ice maker service? Same-day across LA:</span><a href={`tel:${MAIN_PHONE_TEL}`} class="phone-lg">{MAIN_PHONE}</a></div></div>

  <section class="hero"><div class="wrap">
    <div class="crumb"><a href="/">Home</a> › <a href="/brands/">Brands</a> › Maytag › Ice Maker Repair</div>
    <h1>Maytag Ice Maker Repair</h1>
    <p class="lede">Maytag is a Whirlpool Corporation brand since 2006 — positioned as premium-mass-market with the signature Dependability 10-year limited warranty. Core ice-maker architecture is shared with Whirlpool family (Whirlpool / Maytag / KitchenAid / Amana / Roper), so industry-standard W10190961-class modular parts drop into most Maytag refrigerators. Our LA Maytag ice maker service covers MFI French-door, MSS side-by-side, and MZC counter-depth lineup with standard modular-assembly swap + water-inlet valve + EveryDrop filter service. Same-day dispatch, $89 residential diagnostic waived with the repair.</p>
    <div class="hero-cta"><a href={`tel:${MAIN_PHONE_TEL}`} class="btn btn-primary">Call {MAIN_PHONE}</a><a href="#book" class="btn btn-ghost">Request a Visit</a></div>
    <ul class="hero-facts">
      <li><b>Whirlpool family since 2006</b> — Dependability 10-year warranty badge</li>
      <li><b>Whirlpool-family parts cross-fit</b> — W10190961 class assemblies</li>
      <li><b>EveryDrop water filter</b> — 6-month replacement schedule</li>
      <li><b>$89 residential diagnostic</b> — waived when you authorize the repair</li>
    </ul>
  </div></section>

  <BrandBranchesGrid />

  <section class="trust-bar"><div class="wrap"><span>CSLB #1138898 · Insured</span><span>Same-day in 5 SoCal counties</span><span>Residential diagnostic $89 · waived with repair</span></div></section>

  <section class="section"><div class="wrap narrow">
    <h2>Maytag ice maker service in LA</h2>
    <p>Maytag's LA residential install base concentrates in family-home kitchens where the Dependability 10-year warranty badge drives brand choice — customers pick Maytag for the warranty + brand-trust story and expect service quality to match. Our approach respects that expectation: we verify warranty eligibility at diagnostic, apply Whirlpool-family parts cross-fit for fast parts availability, and handle the full MFI / MSS / MZC residential lineup through standard Whirlpool-family service protocol.</p>
  </div></section>

  <section class="section alt"><div class="wrap">
    <h2>Maytag ice maker failures our techs see most often in LA</h2>
    <div class="fail-block"><h3>Water-inlet valve</h3><p>5-8 year typical. Valve swap $180–$280.</p></div>
    <div class="fail-block"><h3>Modular ice-maker assembly</h3><p>Whirlpool-family W10190961 class. Full module swap $220–$360.</p></div>
    <div class="fail-block"><h3>EveryDrop filter clog (EDR1/2/3)</h3><p>6-month routine. Filter $55–$85.</p></div>
    <div class="fail-block"><h3>Ice-bridging / freeze-up</h3><p>Auger motor + freezer temp verification. Auger $140–$220; cavity temp first.</p></div>
    <div class="fail-block"><h3>Thermistor drift</h3><p>Sensor $160–$240. Harvest trigger accuracy.</p></div>
    <div class="fail-block"><h3>Fill-tube / line clean (hard water)</h3><p>Scale buildup in LA hard water. Clean $140–$240.</p></div>
  </div></section>

  <section class="section"><div class="wrap">
    <h2>Maytag ice maker product lines we service</h2>
    <div class="model-grid">
      <div class="model-card"><h3>MFI French-door</h3><p>Standard French-door through-door ice + water.</p></div>
      <div class="model-card"><h3>MSS side-by-side</h3><p>Side-by-side through-door ice + water dispenser.</p></div>
      <div class="model-card"><h3>MZC counter-depth</h3><p>Counter-depth luxury-mid French-door.</p></div>
      <div class="model-card"><h3>MSC 2018+ refreshed series</h3><p>Newer generation with updated ice-maker module.</p></div>
      <div class="model-card"><h3>Whirlpool-family cross-fit</h3><p>W10190961-class parts. See <a href="/brands/whirlpool-ice-maker-repair/">Whirlpool</a>.</p></div>
      <div class="model-card"><h3>10-year Dependability warranty</h3><p>Selective component coverage. Verify at diagnostic.</p></div>
    </div>
  </div></section>

  <section class="section alt"><div class="wrap narrow">
    <h2>Residential Maytag ice maker vs commercial ice machines</h2>
    <p>Maytag is residential-only in ice. Maytag Commercial exists for laundry only. For commercial ice machines at 200+ lb/day, see <a href="/commercial/ice-machine-repair/">commercial ice machine repair</a>.</p>
  </div></section>

  <section class="section"><div class="wrap">
    <h2>What Maytag ice maker repair costs in LA</h2>
    <table class="price-table">
      <tr><th>Service</th><th>Typical Range</th><th>Notes</th></tr>
      <tr><td>Residential diagnostic</td><td>$89</td><td>Waived with repair</td></tr>
      <tr><td>Water-inlet valve</td><td>$180 – $280</td><td>5-8 year service</td></tr>
      <tr><td>Modular ice-maker assembly</td><td>$220 – $360</td><td>Whirlpool-family cross-fit</td></tr>
      <tr><td>Ejector motor</td><td>$140 – $220</td><td>Inside module</td></tr>
      <tr><td>Thermistor</td><td>$160 – $240</td><td>Harvest trigger</td></tr>
      <tr><td>EveryDrop filter</td><td>$55 – $85</td><td>6-month routine</td></tr>
      <tr><td>Fill-tube / line clean</td><td>$140 – $240</td><td>Hard-water scale</td></tr>
      <tr><td>Auger motor</td><td>$140 – $220</td><td>Bin dispensing</td></tr>
      <tr><td>Evaporator fan motor</td><td>$240 – $360</td><td>Freezer airflow</td></tr>
      <tr><td>Control board</td><td>$380 – $560</td><td>Main control</td></tr>
      <tr><td>Door-seal gasket</td><td>$160 – $240</td><td>Cavity heat leak</td></tr>
    </table>
    <p class="small">Related: <a href="/brands/maytag/">Maytag brand hub</a> · <a href="/brands/whirlpool-ice-maker-repair/">Whirlpool (parent-family)</a> · <a href="/services/ice-maker-repair/">Ice maker repair (service hub)</a> · <a href="/price-list/ice-maker-repair-cost/">Ice maker repair cost guide</a>.</p>
  </div></section>

  <section class="section alt"><div class="wrap">
    <h2>LA service areas</h2>
    <div class="area-grid">
      <div><h4>San Fernando Valley</h4><p>Studio City · Sherman Oaks · Encino · Van Nuys</p></div>
      <div><h4>Eastside</h4><p>Silver Lake · Echo Park · Highland Park</p></div>
      <div><h4>South Bay</h4><p>Manhattan Beach · Torrance · Long Beach</p></div>
      <div><h4>Pasadena + San Gabriel</h4><p><a href="/pasadena/">Pasadena</a> · Arcadia · Alhambra</p></div>
      <div><h4>Whittier + La Habra</h4><p>Whittier · La Habra · Cerritos</p></div>
      <div><h4>OC + Ventura</h4><p><a href="/irvine/">Irvine</a> · Anaheim · Thousand Oaks</p></div>
    </div>
  </div></section>

  <section class="section"><div class="wrap narrow">
    <h2>Related Maytag and Whirlpool-family pages</h2>
    <ul class="related-links">
      <li><a href="/brands/maytag/">Maytag brand hub →</a></li>
      <li><a href="/brands/maytag-refrigerator-repair/">Maytag refrigerator repair →</a></li>
      <li><a href="/brands/whirlpool-ice-maker-repair/">Whirlpool ice maker (parent-family) →</a></li>
      <li><a href="/brands/lg-ice-maker-repair/">LG ice maker repair →</a></li>
      <li><a href="/services/ice-maker-repair/">Ice maker repair (service hub) →</a></li>
      <li><a href="/price-list/ice-maker-repair-cost/">Ice maker repair cost guide →</a></li>
      <li><a href="/commercial/ice-machine-repair/">Commercial ice machine repair →</a></li>
    </ul>
  </div></section>

  <section class="section alt"><div class="wrap narrow">
    <h2>Maytag ice maker repair — frequently asked</h2>
    {faqs.map(f => (<details class="faq"><summary>{f.q}</summary><p set:html={f.a}></p></details>))}
  </div></section>

  <section id="book" class="cta-bottom"><div class="wrap">
    <h2>Maytag ice maker service? Call the branch closest to your home.</h2>
    <p>Same-day appliance repair in Los Angeles, Orange County, Ventura County. Residential diagnostic $89, waived with repair.</p>
  </div></section>
  <a href={`tel:${MAIN_PHONE_TEL}`} class="float-call" aria-label="Call now">☎ Call {MAIN_PHONE}</a>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  body { color: var(--text); } .wrap { max-width: 1200px; margin: 0 auto; padding: 0 24px; } .wrap.narrow { max-width: 820px; }
  h1 { font-size: 2.4rem; line-height: 1.15; margin: 12px 0 20px; color: var(--black); }
  h2 { font-size: 1.8rem; margin: 0 0 16px; color: var(--black); }
  h3 { font-size: 1.2rem; margin: 0 0 10px; color: var(--black); }
  h4 { font-size: 1.02rem; margin: 0 0 6px; color: var(--black); }
  p { line-height: 1.65; margin: 0 0 14px; }
  .call-banner { background: var(--red); color: #fff; padding: 10px 0; }
  .call-banner .wrap { display:flex; gap: 14px; align-items: center; justify-content: center; flex-wrap: wrap; }
  .call-banner .phone-lg { color:#fff; font-weight: 800; text-decoration: underline; font-size: 1.05rem; }
  .hero { background: var(--black); color: #fff; padding: 42px 0 56px; } .hero h1 { color: #fff; }
  .hero .lede { font-size: 1.06rem; color: #d7d7d7; max-width: 680px; }
  .hero .crumb { color: #9a9a9a; font-size: 0.85rem; margin-bottom: 6px; } .hero .crumb a { color: #c9c9c9; text-decoration: none; }
  .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; margin: 18px 0 24px; }
  .btn { display: inline-block; padding: 12px 20px; border-radius: 4px; text-decoration: none; font-weight: 700; }
  .btn-primary { background: var(--red); color: #fff; } .btn-ghost { background: transparent; color: #fff; border: 1px solid #fff; }
  .hero-facts { list-style: none; padding: 0; margin: 0; color: #c9c9c9; font-size: 0.95rem; }
  .hero-facts li { padding: 6px 0; border-top: 1px solid #222; } .hero-facts li:first-child { border-top: 0; }
  .trust-bar { background: var(--red); color: #fff; padding: 14px 0; }
  .trust-bar .wrap { display: flex; gap: 28px; flex-wrap: wrap; justify-content: center; font-size: 0.95rem; font-weight: 600; }
  .section { padding: 56px 0; } .section.alt { background: var(--gray); }
  .model-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 20px; margin-top: 24px; }
  .model-card { background: #fff; border: 1px solid var(--border); padding: 20px; border-radius: 6px; }
  .section.alt .model-card { background: #fff; }
  .fail-block { background: #fff; border-left: 3px solid var(--red); padding: 20px 22px; margin: 16px 0; }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 14px; background: #fff; }
  .price-table th, .price-table td { text-align: left; padding: 11px 12px; border-bottom: 1px solid var(--border); }
  .price-table th { background: var(--black); color: #fff; font-weight: 700; font-size: 0.95rem; }
  .small { color: var(--muted); font-size: 0.92rem; margin-top: 12px; }
  .area-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 18px; }
  .area-grid > div { background: #fff; border: 1px solid var(--border); padding: 16px; border-radius: 6px; }
  .related-links { list-style: none; padding: 0; } .related-links li { padding: 10px 0; border-bottom: 1px solid var(--border); }
  .related-links a { color: var(--red); font-weight: 600; text-decoration: none; } .related-links a:hover { text-decoration: underline; }
  .faq { background: #fff; border: 1px solid var(--border); padding: 12px 16px; margin-bottom: 8px; border-radius: 4px; }
  .faq summary { font-weight: 700; cursor: pointer; padding: 4px 0; } .faq p { margin: 8px 0 0; }
  .cta-bottom { background: var(--black); color: #fff; padding: 48px 0; } .cta-bottom h2 { color: #fff; } .cta-bottom p { color: #c9c9c9; }
  .float-call { position: fixed; bottom: 18px; right: 18px; background: var(--red); color: #fff; padding: 14px 18px; border-radius: 40px; text-decoration: none; font-weight: 700; box-shadow: 0 6px 18px rgba(0,0,0,0.28); z-index: 50; font-size: 0.95rem; }
  @media (max-width: 820px) { h1 { font-size: 1.9rem; } h2 { font-size: 1.45rem; } .float-call { padding: 11px 14px; font-size: 0.88rem; } .trust-bar .wrap { gap: 14px; font-size: 0.85rem; } }
</style>
