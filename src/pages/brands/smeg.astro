---

<Layout title={title} description={description} canonical={canonical}>

<Fragment slot="head-scripts">
  {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
</Fragment>

<ServiceHero
  eyebrow="LA · Orange · Ventura · San Bernardino · Riverside Counties"
  title="Smeg Appliance Repair Los Angeles"
  subtitle="FAB retro refrigerators (FAB28 / FAB32 / FAB50, 20-plus colors) · ST/STA dishwashers · SF dual-fuel and gas ranges · Wall ovens · Cooktops · Range hoods. Guastalla, Italy since 1948. Factory-trained on FAB color-matched gasket service and the 2015-2020 STA6047 door latch pattern. $89 diagnostic, same day across five SoCal counties."
  heroImageTitle="Smeg Appliance Repair"
