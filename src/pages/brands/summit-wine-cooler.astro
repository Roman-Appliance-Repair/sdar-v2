---
// Phase 2 Cluster 4 #1 — Summit wine cooler pillar.
// Brand: Felix Storch Inc, Bronx NY, founded 1968. Specialty в commercial-
// grade built-in wine coolers + residential. SCR commercial-grade,
// SWC undercounter, VC Vinotique luxury sub-line. Restaurants, hotels,
// hospitals, labs, serious LA wine collectors.
// Residential pricing ($89). NEW schema pattern via mergeCredentials().

import Layout from '../../layouts/Layout.astro';
import ServiceHero from '../../components/ServiceHero.astro';
import { mergeCredentials } from '../../data/credentials-schema';

const phone = '(323) 870-4790';
const phoneRaw = phone.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/brands/summit-wine-cooler/";

const title = "Summit Wine Cooler Repair Los Angeles — Same Day";
const description = "Summit wine cooler repair across LA. Commercial-grade SCR + undercounter SWC + Vinotique luxury sub-line. Felix Storch Inc since 1968. EPA 608, $89 dx.";

const faqs = [
  { q: "Same-day Summit service in LA?", a: "Yes for diagnostic and most common repairs. Most calls received before 2 PM get a tech on-site the same business day. Common service items — door gaskets, evaporator and condenser fan motors, electronic control components on SCR Series, lock and alarm components on commercial-grade configurations — typically ride on the truck. Less common items may add 1-5 business days for parts ordering through Felix Storch parts distribution. We confirm availability during the diagnostic and tell you the realistic timeline before scheduling labor." },
  { q: "Which Summit tier do I have, and how does it affect the repair-vs-replace decision?", a: "Three tiers, three different math results. Commercial-grade SCR Series (24-inch built-ins, $1500-3000 retail when new) — repair almost always makes sense, even on 10+ year-old units. The build quality and parts ecosystem support meaningful service life. Consumer SWC Series (undercounter, $600-1000 retail) — repair viable when the quote comes in under $400. Past that, replacement math gets close. Entry-level Summit ($300-500 retail) — replacement usually wins, even on a $200 repair, because the unit's remaining service life expectancy is short. We identify your tier during the diagnostic by model number and serial-plate verification, then frame the math honestly before you commit к anything. We don't push $400 repairs on $300 units." },
  { q: "Is Summit's commercial-grade certification meaningful for residential service?", a: "Yes, in two ways. First, the build quality difference is real — commercial-grade SCR Series uses heavier compressor mounts, better gaskets, and more robust electrical components than typical residential wine coolers, which translates к longer service life and better repair value. Second, the certification matters for restaurants, hotels, hospitals, and labs that require UL commercial approval for the equipment they install — those operators choose Summit specifically because the certification supports their compliance. We service both contexts (residential + commercial deployments of the same equipment) and adjust the diagnostic approach accordingly." },
  { q: "Do you carry Summit OEM parts on the truck?", a: "Common service parts ride on every wine cooler truck: door gaskets in standard configurations, evaporator and condenser fan motors, common control board components, lock and alarm assemblies for commercial models, drain heaters, и thermostat replacements. SCR Series-specific parts (digital display modules, specific gasket profiles for commercial built-ins) come through Felix Storch parts distribution, typically 1-7 business days. Vinotique luxury sub-line parts may take longer (2-3 weeks for less-stocked items) — we confirm availability before scheduling labor." },
  { q: "Can you handle restaurant and hospitality service contracts?", a: "Yes. Multi-unit accounts (restaurants with multiple Summit wine units, hotels with bar refrigeration spread across the property, lab facilities with sample storage requirements) get a named account manager and net-30 invoicing after the first visit. Quarterly preventative maintenance contracts cover door gasket inspection, condenser cleaning, refrigerant-charge verification under EPA 608, lock и alarm system testing on commercial models, и documentation для health-department or compliance records. We coordinate scheduling with operational hours to minimize disruption." },
  { q: "How long should a Summit commercial-grade wine cooler last?", a: "SCR Series commercial-grade — 10-15 years с routine maintenance, sometimes longer in mild operating environments. Heavier-gauge construction and better compressor sourcing translate к longer service life than typical residential wine coolers. The biggest variable is condenser cleanliness and door-cycle frequency — restaurants that keep up with quarterly cleaning routinely run SCR Series past 12 years; units that get neglected on maintenance show end-of-life closer к 8 years. SWC consumer Series typically 7-10 years, entry-tier Summit 5-7 years. Annual maintenance is the highest-ROI service line item на commercial-grade models." }
];

const localBusinessSchema = mergeCredentials({
  '@context': 'https://schema.org', '@type': 'HomeAndConstructionBusiness', '@id': canonical + '#business',
  name: 'Same Day Appliance Repair — Summit Wine Cooler Service',
  url: canonical, telephone: phone, email: 'support@samedayappliance.repair', priceRange: '$$',
  openingHoursSpecification: [
    { '@type': 'OpeningHoursSpecification', dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'], opens: '08:00', closes: '20:00' },
    { '@type': 'OpeningHoursSpecification', dayOfWeek: 'Sunday', opens: '00:00', closes: '00:00' }
  ],
  areaServed: [
    { '@type': 'AdministrativeArea', name: 'Los Angeles County' }, { '@type': 'AdministrativeArea', name: 'Orange County' },
    { '@type': 'AdministrativeArea', name: 'Ventura County' }, { '@type': 'AdministrativeArea', name: 'San Bernardino County' },
    { '@type': 'AdministrativeArea', name: 'Riverside County' }
  ]
});

const serviceSchema = {
  '@context': 'https://schema.org', '@type': 'Service', '@id': canonical + '#service',
  serviceType: 'Summit Wine Cooler Repair',
  name: 'Summit Wine Cooler Repair, Same Day Appliance Repair',
  url: canonical,
  description: 'Same-day Summit wine cooler repair across Los Angeles, Orange, Ventura, San Bernardino, and Riverside counties. SCR Series commercial-grade 24-inch built-ins, SWC undercounter consumer line, VC Vinotique luxury sub-line. UL commercial certification on SCR Series for restaurants, hotels, hospitals, and labs. Felix Storch Inc OEM parts. EPA 608 Universal certified (#1346255700410), BHGS #A49573, CSLB C-20 HVAC. $89 residential diagnostic, applied toward repair.',
  provider: { '@id': canonical + '#business' },
  areaServed: [
    { '@type': 'AdministrativeArea', name: 'Los Angeles County' }, { '@type': 'AdministrativeArea', name: 'Orange County' },
    { '@type': 'AdministrativeArea', name: 'Ventura County' }, { '@type': 'AdministrativeArea', name: 'San Bernardino County' },
    { '@type': 'AdministrativeArea', name: 'Riverside County' }
  ],
  brand: { '@type': 'Brand', name: 'Summit', sameAs: 'https://www.summitappliance.com/' },
  offers: { '@type': 'Offer', priceSpecification: { '@type': 'PriceSpecification', price: '89.00', priceCurrency: 'USD', description: 'Residential diagnostic fee, applied toward repair' } }
};

const faqSchema = { '@context': 'https://schema.org', '@type': 'FAQPage', mainEntity: faqs.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) };
const breadcrumbSchema = { '@context': 'https://schema.org', '@type': 'BreadcrumbList', itemListElement: [
  { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://samedayappliance.repair/' },
  { '@type': 'ListItem', position: 2, name: 'Brands', item: 'https://samedayappliance.repair/brands/' },
  { '@type': 'ListItem', position: 3, name: 'Summit', item: canonical }
]};
const schemaJsons = [localBusinessSchema, serviceSchema, faqSchema, breadcrumbSchema];
---

<Layout title={title} description={description} canonical={canonical}>
<Fragment slot="head-scripts">
  {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
</Fragment>

<ServiceHero
  eyebrow="Wine Cooler · Commercial-Grade · Felix Storch Since 1968"
  title="Summit Wine Cooler Repair, Across Southern California"
  subtitle="SCR commercial-grade · SWC undercounter consumer · VC Vinotique luxury sub-line. Felix Storch Inc family company since 1968. UL commercial certification on SCR Series. EPA 608 Universal certified, BHGS #A49573. $89 residential diagnostic, waived with repair."
  heroImageTitle="Summit Wine Cooler Repair"
  showBranches={true}
/>

<section class="section">
  <div class="container narrow">
    <p class="section-number">01, About this service</p>
    <h2>The commercial-grade specialist в the wine cooler category</h2>
    <p>
      Summit Appliance is the trade name for Felix Storch Inc, a Bronx, NY family company that has been building specialty
      compact appliances since 1968. The brand sits в a different position than typical wine cooler manufacturers — instead
      of competing in the mass-market commodity tier, Summit specializes в commercial-grade built-in wine coolers с UL
      certification for use в restaurants, hotels, hospitals, laboratories, и serious residential wine collector contexts.
      The SCR Series 24-inch commercial-grade built-ins are the brand's signature product, and they show up regularly across
      LA's serious wine and hospitality scenes.
    </p>
    <p>
      The pricing structure is straightforward: $89 residential diagnostic, waived when you approve the repair. EPA 608
      Universal certified для refrigerant work, BHGS Registration #A49573, CSLB C-20 HVAC. The commercial-grade angle matters
      for repair-vs-replace math — SCR Series units in the $1500-3000 retail tier deserve repair where consumer-tier wine
      coolers might not. We frame the math honestly during the diagnostic и identify your specific tier before recommending
      anything.
    </p>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">02, Series and product coverage</p>
    <h2>What we service across the Summit lineup</h2>

    <h3>SCR Series — commercial-grade 24-inch built-ins</h3>
    <p>
      Summit's signature category. UL commercial certification, front-vented design for built-in installation in restaurant
      back-bars and serious residential cellar rooms, lock и alarm features standard on most configurations, digital
      temperature display и electronic controls. Capacity varies by specific model but typically falls in the 24-50 bottle
      range. Used heavily в Hollywood and West Hollywood restaurants, Beverly Hills hotel bars, hospital food service for
      pharma sample storage, и residential collectors who want commercial-grade reliability without the premium-luxury price
      tag of EuroCave or Sub-Zero. Service items cluster around door gaskets, fan motors, control electronics, и the
      lock/alarm assemblies on commercial deployments.
    </p>

    <h3>SWC Series — undercounter consumer wine coolers</h3>
    <p>
      Summit's consumer-tier built-in wine coolers — undercounter installations в residential kitchens, smaller capacity than
      SCR Series, simpler control systems, no commercial certification. Build quality is solid for the consumer tier — Summit
      doesn't really make disposable wine coolers — but service-life expectations и repair value math shift compared к the
      commercial-grade SCR. We service these regularly, и the diagnostic approach is similar к other consumer wine cooler
      brands. Repair viable when the quote comes in под $400; past that, replacement math gets close.
    </p>

    <h3>VC Vinotique — luxury sub-line</h3>
    <p>
      Summit's premium sub-brand for higher-end residential applications. More refined finishes, expanded capacity options,
      и in some configurations, dual-zone temperature control. Less common than SCR or SWC в LA market но present в higher-end
      builds where the homeowner wanted commercial-grade reliability с residential-luxury aesthetics. Service approach is
      similar к SCR Series; parts come through Felix Storch with occasional longer lead times for less-stocked items.
    </p>

    <h3>Entry-tier Summit consumer line</h3>
    <p>
      Smaller capacity, simpler construction, lower price point ($300-500 retail). We service these но frame the
      repair-vs-replace math honestly during the diagnostic — for entry-tier units, replacement usually wins the math
      decision over significant repair costs. The single fairest approach is к identify the tier during diagnostic и tell the
      customer where their unit falls before they commit к parts cost.
    </p>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">03, Common failure patterns</p>
    <h2>What we look at first on a Summit call</h2>
    <ul class="bullet-list">
      <li><strong>Door gasket compression set on commercial-grade SCR.</strong> SCR Series doors cycle hundreds of times per service shift в restaurant deployments. After 4-6 years on heavy commercial use, gaskets compress permanently и lose seal. Symptom is icing on the evaporator from moisture infiltration plus a cabinet struggling к hold setpoint. Replacement gaskets stocked для common SCR configurations.</li>
      <li><strong>Condenser fouling — LA dust and grease.</strong> Restaurants и kitchen environments fou condenser coils faster than the manufacturer's specification anticipates. Symptom is a unit running constantly with warm cabinet и hot exterior near the compressor. About 30-35% of "not cooling" Summit calls trace to a clogged condenser, no parts needed, just a deep clean and re-test.</li>
      <li><strong>Evaporator fan motor wear.</strong> Year 8-12 cluster shows fan bearing wear or motor failure. Symptom is uneven cabinet cooling, warm spots in the upper or rear bottle positions. Replacement через Felix Storch parts.</li>
      <li><strong>Control board fade на SCR digital displays.</strong> Newer SCR Series units с digital temperature display и electronic controls show capacitor aging after 8-12 years of duty. Symptom is intermittent display issues, temperature setpoint drift, или controls not responding. We diagnose carefully — control board replacement is meaningful labor и parts cost, и we don't swap on suspicion.</li>
      <li><strong>Lock and alarm components на commercial models.</strong> Restaurant и hospitality SCR Series often have keyed lock и temperature alarm features. Lock cylinders wear over years of daily use; alarm contacts can develop intermittent connection issues. Replacement parts available through Felix Storch для common configurations.</li>
      <li><strong>Compressor end-of-life on heavy-cycled commercial units.</strong> Year 12-15 cluster on SCR Series в restaurant duty. We frame the math honestly: compressor swap on a commercial-grade SCR runs $600-1200 typical с EPA 608 refrigerant work, against $1500-2500 replacement for an equivalent new unit. Math usually favors repair on units under 14 years; closer call past that.</li>
    </ul>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">04, Where we work most on Summit</p>
    <h2>The LA Summit footprint our techs know best</h2>
    <p><strong>Hollywood, West Hollywood, и Beverly Hills restaurants с serious wine programs.</strong> SCR Series commercial-grade built-ins anchor wine storage в restaurant back-bars и server stations. Service approach respects operational hours — work between meal services or during slow afternoon blocks.</p>
    <p><strong>Boutique hotels with bar programs.</strong> Beverly Hills, West Hollywood, Santa Monica boutique properties с serious F&B programs use Summit SCR в bar back configurations. Service approach matches restaurant work — careful around the bar staff, COI on file, scheduling around guest service hours.</p>
    <p><strong>Hospital и pharmacy facilities.</strong> Cedars-Sinai network, UCLA Medical, и independent pharmacies use SCR Series для controlled-temperature pharma sample storage. Service is more careful work — facility engineering coordination, badge access protocols.</p>
    <p><strong>Serious residential wine collectors.</strong> Bel Air, Beverly Hills, и Newport Beach homeowners who chose Summit specifically для the commercial-grade reliability without the premium-luxury price of EuroCave or Sub-Zero. Service approach standard residential — но we recognize the customer chose this brand for build-quality reasons.</p>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">05, Recent repairs</p>
    <h2>What this month looked like on Summit</h2>
    <div class="repair-cards">
      <div class="repair-card">
        <p class="repair-quote">"SCR built-in cooling poorly during dinner service, our wine selection is at risk."</p>
        <p>Hollywood Boulevard restaurant с SCR Series 24-inch built-in, install year per the operator approximately 2017. Diagnostic ran condenser first — heavily fouled с airborne grease from the kitchen pass adjacent. Deep-cleaned coil, verified refrigerant charge under EPA 608, ran cabinet pull-down for 90 minutes между lunch и dinner service. Cabinet at 55°F by 4 PM, ready for evening service. Recommended quarterly cleaning contract going forward — operator signed up.</p>
      </div>
      <div class="repair-card">
        <p class="repair-quote">"Lock won't engage on the bar wine cooler, и temperature alarm went off twice last week."</p>
        <p>Beverly Hills boutique hotel bar, SCR Series commercial-grade built-in with lock и alarm features, install year per facility approximately 2014. Diagnostic confirmed two issues: lock cylinder wear from daily commercial use (replace lock assembly), и alarm contact intermittent connection from years of cycling (clean и tighten contacts). Sourced lock assembly through Felix Storch (4 business days), returned for install, verified both functions. Documented service для facility engineering records.</p>
      </div>
      <div class="repair-card">
        <p class="repair-quote">"Vinotique luxury cabinet stopped cooling, my cellar inventory is climbing temperature."</p>
        <p>Brentwood home, VC Vinotique luxury sub-line undercounter, install year per the homeowner approximately 2015. Diagnostic confirmed evaporator fan motor failure — bearings noisy on test, airflow measurably reduced. Sourced replacement через Felix Storch parts (5 business days, slightly longer lead than standard SCR parts). Returned для install, verified normal cabinet cooling. The homeowner specifically chose Summit Vinotique для commercial-grade reliability — repair restored the build-quality value he originally paid for.</p>
      </div>
    </div>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">06, Why us, specifically</p>
    <h2>What makes us a fit for Summit service</h2>
    <ul class="bullet-list">
      <li><strong>EPA 608 Universal certification (#1346255700410).</strong> Required for refrigerant work on Summit's commercial-grade и consumer wine coolers. We perform refrigerant work legally и document для service records.</li>
      <li><strong>BHGS Registration #A49573 plus CSLB C-20 HVAC.</strong> California state coverage for appliance repair и adjacent HVAC scope.</li>
      <li><strong>Honest tier identification и repair-vs-replace math.</strong> We identify your Summit tier during the diagnostic (SCR commercial-grade vs SWC consumer vs entry-tier vs VC Vinotique luxury) и frame the repair-vs-replace math honestly. We don't push repairs on disposable units, и we don't undersell repair value on commercial-grade SCR.</li>
      <li><strong>Felix Storch OEM parts only.</strong> No aftermarket substitutions on commercial-grade или luxury sub-line units.</li>
      <li><strong>$89 residential diagnostic, waived with repair.</strong> Transparent flat fee.</li>
      <li><strong>Restaurant и hospitality service contracts.</strong> Multi-unit accounts get named account management, net-30 invoicing, и quarterly preventative maintenance. COI on request.</li>
      <li><strong>BBB Accredited Business and $1M general liability insured.</strong></li>
    </ul>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">07, Frequently asked questions</p>
    <h2>The questions we get most on Summit calls</h2>
    <div class="faq-list">
      {faqs.map(f => (<details class="faq-item"><summary>{f.q}</summary><p>{f.a}</p></details>))}
    </div>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">08, Other wine cooler brands we cover</p>
    <h2>Summit service in context</h2>
    <ul class="cross-links">
      <li><a href="/brands/eurocave/">EuroCave wine cellars</a> — French luxury, $5-25K range</li>
      <li><a href="/brands/le-cache/">Le Cache wine cabinets</a> — American hardwood specialist</li>
      <li><a href="/brands/whisperkool/">WhisperKool wine cellar cooling</a></li>
      <li><a href="/brands/cellarpro/">CellarPro wine cellar cooling</a></li>
      <li><a href="/brands/breezaire/">Breezaire wine cellar cooling</a></li>
      <li><a href="/services/wine-cooler-repair/">Wine cooler repair (all brands)</a></li>
    </ul>
  </div>
</section>

<section class="bottom-cta">
  <div class="container narrow">
    <h2>Same-day Summit service across Southern California</h2>
    <p>$89 residential diagnostic, waived with repair. EPA 608 Universal certified, BHGS #A49573, CSLB C-20 HVAC, BBB Accredited.</p>
    <div class="cta-row">
      <a href={phoneHref} class="btn-red">Call {phone}</a>
      <a href="/contact/" class="btn-outline">Request service →</a>
    </div>
  </div>
</section>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .section { padding: 64px 24px; }
  .section-gray { background: var(--gray); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); }
  .container.narrow { max-width: 820px; margin: 0 auto; }
  .section-number { font-size: 12px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--red); margin: 0 0 12px; }
  h2 { font-size: clamp(22px, 3vw, 32px); font-weight: 700; line-height: 1.2; margin: 0 0 20px; color: var(--text); letter-spacing: -.01em; }
  h3 { font-size: 18px; font-weight: 700; margin: 24px 0 10px; color: var(--text); }
  p { font-size: 16px; line-height: 1.7; color: var(--text); margin: 0 0 14px; }
  strong { font-weight: 700; }
  a { color: var(--red); text-decoration: none; }
  a:hover { text-decoration: underline; }
  .bullet-list { list-style: none; padding: 0; margin: 16px 0; }
  .bullet-list li { position: relative; padding: 12px 0 12px 22px; font-size: 15.5px; line-height: 1.65; border-bottom: 1px solid var(--border); }
  .bullet-list li:last-child { border-bottom: none; }
  .bullet-list li::before { content: "▸"; position: absolute; left: 0; color: var(--red); font-weight: 700; }
  .repair-cards { display: grid; gap: 20px; margin-top: 20px; }
  .repair-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 22px 26px; }
  .repair-quote { font-style: italic; color: var(--red); font-weight: 600; margin: 0 0 12px; font-size: 15px; }
  .repair-card p:last-child { margin-bottom: 0; }
  .faq-list { margin-top: 20px; }
  .faq-item { border-bottom: 1px solid var(--border); padding: 16px 0; }
  .faq-item:last-child { border-bottom: none; }
  .faq-item summary { cursor: pointer; font-weight: 700; font-size: 16px; color: var(--text); padding: 4px 0; }
  .faq-item summary:hover { color: var(--red); }
  .faq-item p { margin: 12px 0 4px; font-size: 15.5px; color: var(--text); }
  .cross-links { list-style: none; padding: 0; margin: 16px 0 0; }
  .cross-links li { padding: 10px 0; border-bottom: 1px solid var(--border); font-size: 15px; }
  .cross-links li:last-child { border-bottom: none; }
  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { color: #fff; }
  .bottom-cta p { color: rgba(255,255,255,.85); max-width: 640px; margin: 0 auto 24px; }
  .bottom-cta a { color: #fff; }
  .cta-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-red { background: var(--red); color: #fff; padding: 14px 28px; border-radius: 6px; font-weight: 600; text-decoration: none; }
  .btn-outline { border: 1.5px solid rgba(255,255,255,.3); color: #fff; padding: 14px 28px; border-radius: 6px; font-weight: 600; text-decoration: none; }
</style>
