  .cta-bottom { background: var(--black); color: #fff; padding: 48px 0; } .cta-bottom h2 { color: #fff; } .cta-bottom p { color: #c9c9c9; } .cta-bottom .branches { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 14px; margin-top: 22px; } .cta-bottom .branches a { display: flex; justify-content: space-between; background: #1a1a1a; border: 1px solid #333; padding: 14px 18px; color: #fff; text-decoration: none; border-radius: 4px; } .cta-bottom .branches a span { color: var(--red); font-weight: 800; }
