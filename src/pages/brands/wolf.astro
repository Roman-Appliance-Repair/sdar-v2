---
import Layout from '../../layouts/Layout.astro';
import BrandHubPlaceholder from '../../components/BrandHubPlaceholder.astro';

const title = "Wolf Appliance Repair Los Angeles | Same Day Service";
const description = "Expert Wolf appliance repair across LA, Orange, Ventura counties. All Wolf categories — range, oven, cooktop. Call (424) 325-0520.";

const categories = [
  { label: "Range", url: "/brands/wolf-range-repair/" },
  { label: "Oven", url: "/brands/wolf-oven-repair/" },
  { label: "Cooktop", url: "/brands/wolf-cooktop-repair/" }
];
---

<Layout title={title} description={description}>
  <BrandHubPlaceholder brandName="Wolf" brandSlug="wolf" categories={categories} />
</Layout>
