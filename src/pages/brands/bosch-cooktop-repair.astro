---
import Layout from '../../layouts/Layout.astro';

const title = "Bosch Cooktop Repair Los Angeles | Gas, Induction, Electric Glass-Top";
const description = "Bosch cooktop repair across LA. Factory-Trained technicians for Benchmark 20,000 BTU dual-stacked gas, induction touch panel failures, electric glass-top radiant elements. Manufacturer-approved parts. $89 diagnostic waived with repair. Call (424) 325-0520.";

const branches = [
  { name: "West Hollywood",  phone: "(323) 870-4790", tel: "+13238704790", areas: "WeHo · Beverly Hills · Hollywood · Mid-City" },
  { name: "Los Angeles",     phone: "(424) 325-0520", tel: "+14243250520", areas: "Mid-Wilshire · Brentwood · Santa Monica · Culver City" },
  { name: "Thousand Oaks",   phone: "(424) 208-0228", tel: "+14242080228", areas: "Ventura County · Calabasas · Agoura · Westlake · Malibu" },
  { name: "Pasadena",        phone: "(626) 376-4458", tel: "+16263764458", areas: "Pasadena · San Marino · Arcadia · Glendale · SGV" },
  { name: "Irvine",          phone: "(213) 401-9019", tel: "+12134019019", areas: "Orange County · Newport Beach · Irvine · Anaheim" },
];
const mainPhone = branches[1];

const namedTechs = [
  { name: "Mikhail V.", role: "Bosch/Thermador Specialist · 12 yrs", photo: "/images/techs/placeholder-1.jpg", areas: "Westside · West Hollywood · Beverly Hills" },
  { name: "Artur S.",   role: "Built-in Installation & Repair · 9 yrs", photo: "/images/techs/placeholder-2.jpg", areas: "Pasadena · San Marino · Arcadia" },
  { name: "David K.",   role: "European Appliance Specialist · 14 yrs", photo: "/images/techs/placeholder-3.jpg", areas: "Malibu · Pacific Palisades · Calabasas" },
];

const faqs = [
  {
    q: "How much does Bosch cooktop repair cost in Los Angeles?",
    a: "Most Bosch cooktop repairs in LA land between $240 and $620 all-in, parts and labor combined. Spark module replacement on gas units averages $320. Single spark electrode replacement lands $180–$260. Capacitive touch panel assembly on induction cooktops comes in at $420–$520. Radiant element replacement on electric glass-top is $240–$320. Infinite switch replacement averages $260. Full glass panel replacement depends on size and series — 30\" and 36\" Benchmark glass runs $620–$1,100. Our $89 diagnostic is waived when you approve the repair. No $179 call-out fee, no 6-minute metered labor."
  },
  {
    q: "How do I tell if my igniter failed or the spark module failed?",
    a: "The pattern of which burners are affected tells us. If ONE burner clicks and won't light while the others work fine, it's a spark electrode (the ceramic spark point at that specific burner) — a $180–$260 fix. If ALL burners click continuously without lighting, or NONE spark when you turn the knobs, the spark module itself has failed — the central electrical unit that sends voltage to each burner. Spark module replacement runs $280–$380. If the burners don't click at all (no sound when turning knobs), the issue is upstream — power supply, spark ignition switch, or control board. We meter each component before replacing to avoid swapping the wrong part."
  },
  {
    q: "Why does one burner on my Bosch induction cooktop not respond to touch?",
    a: "Almost always a capacitive touch sensor strip failure beneath the glass over that specific zone. Bosch induction cooktops don't use physical buttons — the icons you touch are capacitive sensors that detect the electrical change when your finger approaches. When the sensor strip degrades at one point (from moisture infiltration, cleaning chemicals, or simple age), that zone stops responding even though the zone's heating element is still functional. Placing something under the glass doesn't help — the sensor is electronic, not mechanical. The repair is a full touch panel assembly replacement, manufacturer-approved part. Our technicians carry these for NIT8668UC, NIT8665UC, and other common 800 Series induction models."
  },
  {
    q: "My induction cooktop doesn't heat even though it powers on — is it broken?",
    a: "Before assuming hardware failure, verify cookware compatibility. Induction only works with ferromagnetic cookware — place a magnet on the bottom of your pan. If it sticks, it's induction-compatible. If not, that's the issue (no repair needed — you need different cookware). Also check the pan size against the cooking zone. Pans significantly smaller than the zone may not trigger pot-detection. Warped pan bottoms that don't sit flat also cause inconsistent heating. If cookware is confirmed compatible and properly placed, the next diagnostic is the zone inverter board underneath the glass — this is the component that generates the electromagnetic field. Inverter board replacement runs $440–$580."
  },
  {
    q: "My Bosch Benchmark has a 20,000 BTU dual-stacked burner — can you service it?",
    a: "Yes — the dual-stacked burner is the signature Benchmark gas feature. It delivers maximum-output cooking at the high setting and true low simmer on the same burner by stacking two burner rings. Repair-wise it's the same sealed-burner platform as standard 800 Series but with the extra ring, dedicated orifice, and specific burner cap geometry. Misalignment on the dual-stacked cap shows up as uneven flame because both rings have to seat correctly. Our technicians carry Benchmark-specific burner caps, spark electrodes, and orifices for the 20,000 BTU burner assembly."
  },
  {
    q: "Can you replace cracked Bosch cooktop glass?",
    a: "Yes — glass replacement is our most expensive cooktop repair, but usually worth it versus replacing the whole unit. Bosch cooktop glass comes in specific cutout dimensions that have to match your existing counter cutout. Full glass panel replacement runs $620–$1,100 for 30\" and 36\" Benchmark and 800 Series units, depending on platform and whether it's induction, electric, or gas. Manufacturer-approved glass only — aftermarket replacement glass fails to seat properly and often cracks again within a year. Install is a full cooktop extraction from the countertop, glass swap, and reseat with new gasket."
  },
  {
    q: "Are you Bosch Factory-Trained for all three cooktop platforms?",
    a: "Yes. Our technicians complete manufacturer training on Bosch gas (including Benchmark), induction, and electric glass-top cooktops each year. We're licensed (CA), insured ($2M liability), BBB A+ rated. We're an independent repair company, not Bosch Factory Service subcontractors — which is why our pricing is different: no $179 call-out fee, no 6-minute metered labor, flat price quoted before work. Manufacturer-approved parts are identical either way."
  }
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(f => ({
    "@type": "Question",
    "name": f.q,
    "acceptedAnswer": { "@type": "Answer", "text": f.a }
  }))
};

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Same Day Appliance Repair",
  "image": "https://samedayappliance.repair/logo.png",
  "telephone": "(424) 325-0520",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "6230 Wilshire Blvd Ste A PMB 2267",
    "addressLocality": "Los Angeles",
    "addressRegion": "CA",
    "postalCode": "90048",
    "addressCountry": "US"
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.6",
    "reviewCount": "37"
  }
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Bosch Cooktop Repair",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Same Day Appliance Repair",
    "telephone": "(424) 325-0520"
  },
  "areaServed": { "@type": "City", "name": "Los Angeles" }
};
---

<Layout title={title} description={description}>
  <Fragment slot="head-scripts">
    <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
  </Fragment>

  <!-- 0. CALL BANNER -->
  <div class="call-banner">
    <div class="container call-banner-inner">
      <span class="cb-label">Bosch Cooktop Not Working? —</span>
      <a href={`tel:${mainPhone.tel}`} class="cb-phone">Call {mainPhone.phone}</a>
      <span class="cb-sep">·</span>
      <a href={`sms:${mainPhone.tel}`} class="cb-sms">Text us a photo</a>
    </div>
  </div>

  <!-- 1. HERO -->
  <section class="bosch-hero">
    <div class="container hero-grid">
      <div class="hero-text">
        <div class="hero-eyebrow">Factory-Trained · Post-Warranty Bosch Specialists</div>
        <h1>Bosch Cooktop Repair in Los Angeles</h1>
        <p class="hero-sub">
          Spark module failures on gas burners. Capacitive touch sensor strip
          drops on induction. Radiant element burnouts on electric glass-top.
          Our Factory-Trained technicians work on all three Bosch cooktop
          platforms every day across LA — Benchmark, 800 Series, 500 Series.
          Manufacturer-approved parts. Same-day appointments.
        </p>

        <div class="branch-select">
          <label for="branchPicker" class="bs-label">Your area:</label>
          <select id="branchPicker" class="bs-dropdown" onchange="
            const b = this.options[this.selectedIndex];
            const phoneEl = document.getElementById('heroPhoneBtn');
            phoneEl.href = 'tel:' + b.dataset.tel;
            phoneEl.textContent = 'Call ' + b.dataset.phone;
          ">
            {branches.map((b, i) => (
              <option value={b.name} data-tel={b.tel} data-phone={b.phone} selected={i === 1}>
                {b.name} — {b.areas}
              </option>
            ))}
          </select>
        </div>

        <div class="hero-ctas">
          <a id="heroPhoneBtn" href={`tel:${mainPhone.tel}`} class="btn btn-red">Call {mainPhone.phone}</a>
          <a href="/schedule/" class="btn btn-hero-outline">Schedule Online</a>
          <a href={`sms:${mainPhone.tel}?body=Bosch cooktop photo — `} class="btn btn-hero-outline btn-sms">📷 Text Photo</a>
        </div>

        <div class="hero-badge">
          <span class="badge-amount">$89</span>
          <span class="badge-text">Diagnostic — <strong>waived</strong> when you approve the repair. No $179 call-out fee.</span>
        </div>
      </div>
      <div class="hero-image">
        <div class="image-frame">
          <div class="image-ring"></div>
          <img src="/images/bosch-cooktop-repair.jpg" alt="Bosch Benchmark 36-inch gas cooktop repair Los Angeles" loading="eager" />
        </div>
      </div>
    </div>
  </section>

  <!-- 2. CREDS BAR -->
  <section class="creds-bar">
    <div class="container">
      <div class="creds-grid">
        <div class="cred"><span class="cred-icon">★</span><div><strong>BBB A+ Rated</strong><span>Accredited business</span></div></div>
        <div class="cred"><span class="cred-icon">✓</span><div><strong>Factory-Trained</strong><span>Gas · Induction · Electric</span></div></div>
        <div class="cred"><span class="cred-icon">⚖</span><div><strong>Licensed &amp; Insured</strong><span>CA Lic. · $2M liability</span></div></div>
        <div class="cred"><span class="cred-icon">⚡</span><div><strong>EPA-Certified</strong><span>Refrigerant-safe</span></div></div>
        <div class="cred"><span class="cred-icon">⌚</span><div><strong>Same-Day Service</strong><span>Calls before 2 PM</span></div></div>
      </div>
    </div>
  </section>

  <!-- 3. POST-WARRANTY POSITIONING -->
  <section class="positioning">
    <div class="container container-narrow">
      <div class="pos-eyebrow">Who We Serve — Three Platforms</div>
      <h2>LA's Post-Warranty Bosch Cooktop Specialists</h2>
      <p>
        Bosch makes three very different cooktop platforms in the US market,
        and each one fails differently. Sealed-burner gas cooktops — including
        the Benchmark line with its signature 20,000 BTU dual-stacked burner
        that delivers both high heat and low simmer on the same ring.
        Induction cooktops — glass-top with electromagnetic coils beneath,
        running off capacitive touch controls wired into a single control
        board. Traditional electric glass-top — radiant heating elements
        beneath smoothtop ceramic, each burner switched independently. Bosch
        also offers these heating technologies in slide-in ranges, but on
        this page we're focused on standalone cooktops only — for ranges,
        see our Bosch range repair page.
      </p>
      <p>
        The parts are completely different. The diagnostic procedures are
        completely different. A shop that only knows gas cooktops can't
        meaningfully service an induction unit — the touch panel, zone
        inverter, and pot-detection system are unfamiliar territory. Our
        technicians are trained across all three platforms, and we stock the
        right parts for each.
      </p>
      <p>
        Bosch's factory warranty covers cooktops for one year on parts and
        labor. After that, owners face the usual choice — call Bosch Factory
        Service at $179 per visit plus $25 every 6 minutes of metered labor,
        or find an independent shop that knows your specific platform.
      </p>
    </div>
  </section>

  <!-- 4. INTRO -->
  <section class="intro">
    <div class="container container-narrow">
      <p class="lead">
        Bosch cooktops have three distinct failure patterns in Los Angeles
        depending on the platform — and on gas units the dominant call type
        is spark ignition, not burner replacement.
      </p>
      <p>
        On gas cooktops, the spark module is the central electrical unit that
        sends voltage to every burner spark electrode. When it fails, all the
        burners click but none light. When a single spark electrode fails,
        one burner clicks and won't light while the others work fine.
        Misaligned burner caps throw off the spark gap and cause uneven
        flames — cleaned and re-seated, it often fixes what looked like a
        hardware failure. Burner knobs and their underlying ignition switches
        are another common wear point: using a cooktop for years means those
        mechanical contacts eventually stick or open erratically.
      </p>
      <p>
        On induction cooktops, the complaint is almost always the same: one
        zone stops responding to finger taps while the others work fine. The
        heating element beneath that zone is fine — the capacitive touch
        sensor strip beneath the glass has degraded. A full touch panel
        assembly replacement solves it.
      </p>
      <p>
        On electric glass-top, a single radiant element burns out or the
        infinite switch fails and the burner won't cycle between heat levels.
        Cracked glass across any of the three platforms almost always means
        a full glass panel replacement — food debris falls through and
        damages internals fast.
      </p>
    </div>
  </section>

  <!-- 5. NAMED TECHNICIANS -->
  <section class="techs">
    <div class="container">
      <div class="section-heading">
        <span class="section-num">01</span>
        <h2>Meet the Technicians Who Service Your Bosch</h2>
      </div>
      <p class="section-lead">
        You'll know the name and face of the tech before they arrive. Our
        Bosch cooktop specialists are Factory-Trained across gas, induction,
        and electric glass-top platforms, background-checked, and assigned
        by neighborhood.
      </p>
      <div class="techs-grid">
        {namedTechs.map(t => (
          <div class="tech-card">
            <div class="tech-photo">
              <img src={t.photo} alt={`${t.name} — ${t.role}`} loading="lazy" />
            </div>
            <div class="tech-info">
              <h3>{t.name}</h3>
              <div class="tech-role">{t.role}</div>
              <div class="tech-areas">Primary areas: {t.areas}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 6. TRY THIS FIRST -->
  <section class="diy-check">
    <div class="container container-narrow">
      <div class="section-heading">
        <span class="section-num">02</span>
        <h2>Before You Call — Platform-Specific Quick Checks</h2>
      </div>
      <p class="section-lead">
        Each Bosch cooktop platform has its own common non-repair
        explanations. A few of our dispatched calls turn out to be simple
        fixes — worth 60 seconds before scheduling.
      </p>

      <h3 class="diy-sub">Gas Cooktops</h3>
      <ol class="diy-list">
        <li>
          <strong>Check burner cap alignment.</strong> An off-center cap
          causes spark failure and uneven flames. Cool the cooktop, lift
          the cap, verify it seats flat on the burner base. Most frequent
          cause of "one burner won't light" after cleaning.
        </li>
        <li>
          <strong>Clear debris from burner ports.</strong> Food debris or
          grease clogging the burner ports restricts gas flow and blocks
          ignition. Remove the burner cap and grate, clean the burner head
          with a soft brush or compressed air.
        </li>
        <li>
          <strong>Make sure the igniter is dry.</strong> A wet igniter after
          cleaning won't spark. Allow time to air-dry before trying again —
          usually 30 minutes after a wet wipe-down is enough.
        </li>
      </ol>

      <h3 class="diy-sub">Induction Cooktops</h3>
      <ol class="diy-list">
        <li>
          <strong>Magnet test your cookware.</strong> Bosch induction
          cooktops require ferromagnetic cookware. Place a magnet on the
          bottom of the pan — if it sticks, it's induction-compatible. If
          not, that's your problem (no repair needed).
        </li>
        <li>
          <strong>Check pan size against the cooking zone.</strong> Pans
          significantly smaller than the zone may not trigger the
          pot-detection sensor. Use appropriate-size cookware for each zone.
        </li>
        <li>
          <strong>Deactivate child lock.</strong> Look for the key or padlock
          icon on the control panel. Press and hold for 3–5 seconds to turn
          off. A locked cooktop looks broken but isn't.
        </li>
      </ol>

      <h3 class="diy-sub">All Platforms</h3>
      <ol class="diy-list">
        <li>
          <strong>Check the circuit breaker.</strong> Bosch cooktops run
          on dedicated circuits — induction and electric at 240V, gas on
          a 120V ignition circuit. A partially tripped breaker shows up
          as "lights but no heat" on induction, "no click" on gas.
        </li>
      </ol>

      <p class="diy-foot">
        Still broken? That's what we're here for. <a href={`tel:${mainPhone.tel}`}>{mainPhone.phone}</a>
        or <a href={`sms:${mainPhone.tel}?body=Bosch cooktop photo — `}>text us a photo</a>.
      </p>
    </div>
  </section>

  <!-- 7. COMMON PROBLEMS -->
  <section class="problems">
    <div class="container">
      <div class="section-heading">
        <span class="section-num">03</span>
        <h2>Bosch Cooktop Problems We Fix Every Week</h2>
      </div>
      <div class="problems-grid">
        <div class="problem-card">
          <h3>Spark Module Failure (All Burners Click, None Light)</h3>
          <p><strong>What it means:</strong> the central electrical unit that
          sends voltage to every burner spark electrode has failed. All burners
          click continuously or none spark at all. Year 6–10 pattern on gas
          cooktops.</p>
          <p><strong>How we fix it:</strong> meter the spark module against
          manufacturer spec, verify upstream power supply first. Replace with
          manufacturer-approved module. 45-minute job on most 800 Series gas
          units.</p>
        </div>
        <div class="problem-card">
          <h3>Single Burner Won't Light (Spark Electrode)</h3>
          <p><strong>What it means:</strong> one burner clicks and doesn't
          light while the others work fine. Spark electrode or spark wire for
          that specific burner has failed. Electrode ceramic can crack from
          heat cycling or get fouled by grease.</p>
          <p><strong>How we fix it:</strong> listen for clicking at the dead
          burner (confirms power is reaching it), test electrode continuity,
          replace electrode and spark wire if damaged. Verify flame test on
          all burners before closing.</p>
        </div>
        <div class="problem-card">
          <h3>Continuous Clicking (Spark Ignition Switch Stuck)</h3>
          <p><strong>What it means:</strong> cooktop tries to spark endlessly
          even with knobs off. Spark ignition switch contact stuck closed, or
          moisture behind the knob assembly keeping the contact made.</p>
          <p><strong>How we fix it:</strong> diagnose which knob position is
          triggering the stuck signal, pull the knob and test the ignition
          switch. Dry moisture if that's the cause, replace switch if
          mechanically failed.</p>
        </div>
        <div class="problem-card">
          <h3>Burner Cap Misalignment / Uneven Flame</h3>
          <p><strong>What it means:</strong> cap rotated or cocked after
          cleaning. Flame is uneven or off-center, spark hits the wrong part
          of the burner head. Most common non-hardware gas cooktop issue.</p>
          <p><strong>How we fix it:</strong> cool burner, lift cap, inspect
          base for alignment pins, re-seat cap on the burner base. Verify
          proper flame pattern. Walk owner through correct post-cleaning
          cap re-seating.</p>
        </div>
        <div class="problem-card">
          <h3>Induction Burner Unresponsive to Touch</h3>
          <p><strong>What it means:</strong> specific zone no longer responds
          when finger taps the control icon. The icons aren't physical
          buttons — they're capacitive sensors under the glass tied to the
          control board. When the sensor strip degrades at one zone, the
          control board stops seeing touches there even though the heating
          element is fine.</p>
          <p><strong>How we fix it:</strong> verify clean glass (residue can
          interfere with capacitance), confirm other zones respond, confirm
          not a control lock issue. If only one zone is affected, replace
          the touch panel assembly. If the control board itself has failed,
          multiple zones typically act up — that's a full control board
          swap with manufacturer-approved part.</p>
        </div>
        <div class="problem-card">
          <h3>Induction Zone Not Detecting Cookware</h3>
          <p><strong>What it means:</strong> pan placed on zone but cooktop
          doesn't heat. Either cookware isn't induction-compatible (fails
          magnet test), pan is too small for zone, or zone inverter board
          has failed.</p>
          <p><strong>How we fix it:</strong> verify cookware compatibility
          first (always — this is a free check that saves hundreds in
          unnecessary parts). If cookware confirmed good, diagnose zone
          inverter board, replace if failed. $440–$580 repair.</p>
        </div>
        <div class="problem-card">
          <h3>Electric Glass-Top Radiant Element Dead</h3>
          <p><strong>What it means:</strong> single zone doesn't heat while
          others work. Radiant element burned out — visible as a black burn
          mark or broken coil through the glass. Year 7–12 pattern with
          moderate use.</p>
          <p><strong>How we fix it:</strong> access from below (usually
          possible without full cooktop extraction), disconnect terminals,
          swap in new radiant element. Test heat output at multiple
          infinite switch settings before closing.</p>
        </div>
        <div class="problem-card">
          <h3>Electric Glass-Top Infinite Switch Failure</h3>
          <p><strong>What it means:</strong> burner either full-on or
          full-off — no simmer control, no partial heat. Infinite switch
          contact has failed in one state. Other burners cycle normally.</p>
          <p><strong>How we fix it:</strong> confirm the element itself
          cycles properly (by swapping into another circuit), replace the
          infinite switch at that burner's control. Calibrate heat
          positions before closing.</p>
        </div>
        <div class="problem-card">
          <h3>Low Flame / Weak Simmer Across All Burners</h3>
          <p><strong>What it means:</strong> flames weak across the whole
          cooktop, even at maximum knob setting. Often gas supply pressure
          from utility, sometimes a failed gas regulator at the cooktop
          inlet. Rarely burner-specific.</p>
          <p><strong>How we fix it:</strong> test inlet line pressure with
          manometer. If pressure is at spec, inspect gas regulator and
          orifice. If low from supply, refer owner to utility. Replace
          regulator if it's the failure point.</p>
        </div>
        <div class="problem-card">
          <h3>Cracked Glass Surface</h3>
          <p><strong>What it means:</strong> spider crack from a dropped pan,
          heat stress crack, or impact crack at the edge. Any crack on
          induction or electric glass-top needs full glass replacement —
          food debris falls through and damages internals quickly.</p>
          <p><strong>How we fix it:</strong> measure the cutout, order
          manufacturer-approved glass panel matched to your Series and
          size, full cooktop extraction from countertop, glass swap, gasket
          replacement, reinstall flush.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 8. BUILT-IN COOKTOP PROTOCOL -->
  <section class="builtin">
    <div class="container container-narrow">
      <div class="section-heading">
        <span class="section-num">04</span>
        <h2>Built-In Cooktop Service Protocol</h2>
      </div>
      <p>
        Bosch cooktops are built-in — dropped into a countertop cutout and
        secured with mounting clips underneath. Most burner and igniter
        work on gas units happens from the top: lift the cooking surface
        or remove grates and caps, reach the sparks and regulators without
        pulling the unit. Touch panels, zone inverters, and gas regulators
        are below-access — we clear the cabinet space under the cooktop to
        reach them without extracting the whole unit.
      </p>
      <div class="builtin-list">
        <div class="bl-item">
          <div class="bl-num">1</div>
          <div>
            <strong>Top-access first when possible.</strong> Most gas
            cooktop repairs — spark electrodes, burner heads, caps, drip
            trays — happen without pulling the unit. Saves time, protects
            countertop finish.
          </div>
        </div>
        <div class="bl-item">
          <div class="bl-num">2</div>
          <div>
            <strong>Clear the cabinet below for induction/electric work.</strong>
            Touch panels, zone inverters, radiant element connections, gas
            regulators all reached from below. Pull contents of the
            cabinet, protect with drop cloth.
          </div>
        </div>
        <div class="bl-item">
          <div class="bl-num">3</div>
          <div>
            <strong>Full extraction only for glass panel replacement.</strong>
            Cracked glass means the whole cooktop comes out of the
            countertop. Mounting clips released, unit lifted straight up,
            staged on protected counter surface for glass swap.
          </div>
        </div>
        <div class="bl-item">
          <div class="bl-num">4</div>
          <div>
            <strong>Two-tech protocol on 36" induction units.</strong>
            36" induction glass is 40+ pounds. Two technicians required for
            safe lifting and reinstallation to avoid edge chips and back
            injury. No extra charge.
          </div>
        </div>
        <div class="bl-item">
          <div class="bl-num">5</div>
          <div>
            <strong>Cutout dimension match for glass replacement.</strong>
            Bosch cutout tolerances are strict — 1/16" off and the
            replacement glass won't seat properly. We verify dimensions
            against your existing cutout before ordering the panel.
          </div>
        </div>
      </div>
