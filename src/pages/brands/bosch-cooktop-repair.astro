          <tr><td>Home Connect firmware update</td><td>$85 flat</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <!-- ── SERVICE AREAS ── -->
  <section class="section section-alt">
    <div class="container">
      <p class="eyebrow-sub">Where we go</p>
      <h2>Service areas for Bosch cooktop repair</h2>
      <BrandBranchesGrid showHeader={false} />
    </div>
  </section>

  <!-- ── RELATED ── -->
  <section class="section">
    <div class="container">
      <p class="eyebrow-sub">Related Bosch services</p>
      <h2>Other Bosch categories we service</h2>
      <div class="cat-grid">
        <a href="/brands/bosch/" class="cat-card">
          <h3>Bosch Appliance Repair</h3>
          <p>Hub page — all Bosch categories in LA.</p>
          <span class="cat-cta">View hub →</span>
