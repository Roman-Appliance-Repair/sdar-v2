---
import Layout from '../../layouts/Layout.astro';
import BrandDetailPlaceholder from '../../components/BrandDetailPlaceholder.astro';

const title = "GE Range Repair Los Angeles | Same Day Service";
const description = "Expert GE range repair in Los Angeles. Same-day appointments, OEM parts, licensed technicians. Call (424) 325-0520.";
---

<Layout title={title} description={description}>
  <BrandDetailPlaceholder
    brandName="GE"
    brandSlug="ge"
    category="Range"
    categorySlug="stove-repair"
    hubUrl="/brands/ge/"
  />
</Layout>
