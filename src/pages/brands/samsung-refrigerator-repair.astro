---
import Layout from '../../layouts/Layout.astro';
import BrandDetailPlaceholder from '../../components/BrandDetailPlaceholder.astro';

const title = "Samsung Refrigerator Repair Los Angeles | Family Hub";
const description = "Samsung fridge repair across LA — Family Hub, ice maker module, French Door, Flex Zone. Same-day, $89 diagnostic waived with repair. Call (424) 325-0520.";
const canonical = "https://samedayappliance.repair/brands/samsung-refrigerator-repair/";
---

<Layout title={title} description={description} canonical={canonical}>
  <BrandDetailPlaceholder
    brandName="Samsung"
    brandSlug="samsung"
    category="Refrigerator"
    categorySlug="refrigerator-repair"
    hubUrl="/brands/samsung/"
  />
</Layout>
