---
import Layout from '../../layouts/Layout.astro';
import BrandBranchesGrid from '../../components/BrandBranchesGrid.astro';
import { MAIN_PHONE, MAIN_PHONE_TEL } from '../../data/branches';

const title = "Fisher & Paykel Washer Repair | Southern California | SmartDrive Direct-Drive";
const description = "Fisher & Paykel washer repair across SoCal. WA/WH SmartDrive direct-drive, Series 9 front-load. Huntington Beach LA-local. BHGS #A49573. $89 dx waived.";
const canonical = "https://samedayappliance.repair/brands/fisher-paykel-washer-repair/";

const faqs = [
  {
    q: "What is SmartDrive and why does it matter for repair?",
    a: "<b>SmartDrive</b> is Fisher & Paykel's signature direct-drive washing-machine technology, a brushless DC motor drives the drum directly, with no drive belt and no transmission between motor and drum. Most US washers use a belt or a mechanical transmission (which wears and needs replacement). <b>SmartDrive eliminates both failure modes.</b> Practical repair impact: no belt to replace ($60-$120 typical savings vs belt-drive washers), no transmission rebuild (a $400-$700 major-repair cost on conventional washers), fewer moving parts overall. The failure modes on SmartDrive concentrate on the <b>control board</b> (managing the direct-drive motor) and the <b>motor-tachometer sensor</b> (reports drum speed to the control). F&P SmartDrive machines routinely run 12-18 years with modest service, an engineered longevity advantage that shows up at repair time."
  },
  {
    q: "F&P washer models in US, what's the lineup?",
    a: "<b>WH-series top-load (SmartDrive)</b>, the F&P signature product in the US, 4.2-5.0 cu ft capacity, no agitator (impeller-plate design), aggressive-efficiency positioning. <b>WE-series front-load (SmartDrive)</b>, stackable with matching F&P dryer, 4.0-4.4 cu ft, same direct-drive motor architecture as WH top-load. <b>Intuitive Eco</b> is the US-market aesthetic; CoolDrive is a premium-tier variant on select models. Fisher & Paykel is NZ-founded (1934) and Haier-owned since 2012, the Haier acquisition gave F&P access to the broader Haier + GE Appliances parts network, though F&P uniqueness (SmartDrive especially) remains F&P-specific."
  },
  {
    q: "Huntington Beach LA-local, what does that mean for parts?",
    a: "<b>Fisher & Paykel's US parts + service HQ is Huntington Beach, California</b>, 30 miles from downtown LA. For LA service this is a real advantage: common F&P washer parts (motor-tachometer sensor, drain pumps, door-lock mechanisms, pressure switches) ship 1-3 day LA-local from Huntington Beach. Specialty or serial-matched SmartDrive motor assemblies + unique CoolDrive parts may require 3-5 day factory-direct order or occasionally Auckland NZ routing. F&P joins Hestan (Anaheim), Thermador (BSH Irvine), and Gaggenau (BSH Irvine) as LA's four local-parts-advantage luxury residential brands, fastest parts chain among premium washer brands in the market."
  },
  {
    q: "SmartDrive motor sounds loud / vibration, normal or failing?",
    a: "SmartDrive motors have a characteristic acoustic signature that's different from belt-drive washers, a higher-pitched hum during spin cycles because the motor runs at wider RPM variation and does direct-drive torque control. <b>That hum is normal.</b> What's NOT normal: (1) grinding or clicking during spin, suggests motor bearing failure or debris in the impeller; (2) very loud vibration that walks the machine across the floor, shock-absorber failure or off-balance load; (3) a burned-plastic smell from the motor area, motor winding damage, immediate power-off and diagnostic call. We test motor-tachometer feedback against expected RPM during diagnostic rather than going off sound alone."
  },
  {
    q: "F&P vs Miele front-load, both premium, both long-lived, what's the difference for LA service?",
    a: "Both are premium front-load washers with 12-18 year service life expectations. <b>Miele</b> is Gütersloh-Germany-family-owned (1899+), ships through a more-concentrated luxury-dealer US parts chain. <b>F&P</b> is Haier-owned (since 2012), ships through Huntington Beach LA-local US parts, faster parts chain for LA. Mechanically different: Miele uses conventional belt-drive motors with honeycomb drum design; F&P uses SmartDrive direct-drive. For service economics, F&P tends to run slightly cheaper on routine parts + faster turnaround because of the Huntington Beach proximity. Miele holds a slight edge on drum longevity + overall build density. Both are honest recommendations at premium tier. See <a href='/brands/miele-washer-repair/'>Miele washer</a>."
  },
  {
    q: "What does F&P washer repair cost in LA?",
    a: "Residential diagnostic $89 waived with repair. Typical F&P bands: motor-tachometer sensor $140–$220; main control board $320–$480 (SmartDrive-specific motor-drive logic); door-lock mechanism $140–$240; drain pump $160–$260; inlet valve $80–$140; pressure switch $100–$160; shock absorbers (pair) $140–$220; drum bearing service $520–$820 (major repair, 12+ year units); SmartDrive motor itself rarely fails but if it does $580–$880; Haier-branded cross-reference parts (since 2012 acquisition) occasionally lower backorder waits on shared components. Huntington Beach 1-3 day LA-local parts chain."
  }
];

const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair, Fisher & Paykel Washer Service",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": canonical, "telephone": MAIN_PHONE_TEL, "priceRange": "$$$"
  },
  { "@context": "https://schema.org", "@type": "Service", "serviceType": "Fisher & Paykel Washer Repair",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "description": "Fisher & Paykel washer repair across LA, WH-series top-load SmartDrive, WE-series front-load SmartDrive. Direct-drive DC motor (no belt, no transmission). Haier parent since 2012. Huntington Beach CA LA-local 1-3 day parts. $89 residential diagnostic waived with repair.",
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, waived with repair" } }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "Fisher & Paykel", "item": "https://samedayappliance.repair/brands/fisher-paykel/" },
      { "@type": "ListItem", "position": 4, "name": "Fisher & Paykel Washer Repair", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">{schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}</Fragment>
  <div class="call-banner"><div class="wrap"><span>F&P washer service?</span><a href={`tel:${MAIN_PHONE_TEL}`} class="phone-lg">{MAIN_PHONE}</a></div></div>

  <section class="hero"><div class="wrap">
    <div class="crumb"><a href="/">Home</a> › <a href="/brands/">Brands</a> › Fisher & Paykel › Washer Repair</div>
    <h1>Fisher & Paykel Washer Repair</h1>
    <p class="lede">Fisher & Paykel's signature engineering is SmartDrive, a brushless DC direct-drive motor that eliminates both the drive belt and the transmission found in conventional US washers. No belt to replace, no transmission to rebuild, and fewer moving parts overall translates into 12-18 year typical service life on a well-maintained F&P washer. The US lineup runs WH-series top-load (5.0 cu ft impeller-plate, no agitator) and WE-series front-load (4.0-4.4 cu ft, stackable with F&P dryer). F&P is NZ-founded (1934), Haier-owned since 2012, with US parts + service headquartered at Huntington Beach California, 30 miles from downtown LA for 1-3 day LA-local parts advantage. Same-day dispatch, $89 residential diagnostic waived with the repair.</p>
    <div class="hero-cta"><a href={`tel:${MAIN_PHONE_TEL}`} class="btn btn-primary">Call {MAIN_PHONE}</a><a href="#book" class="btn btn-ghost">Request a Visit</a></div>
    <ul class="hero-facts">
      <li><b>SmartDrive direct-drive</b>, no belt, no transmission, 12-18 year service life</li>
      <li><b>WH top-load + WE front-load</b>, both SmartDrive architecture</li>
      <li><b>Huntington Beach LA-local parts</b>, 1-3 day; one of LA's 4 local-advantage brands</li>
      <li><b>$89 residential diagnostic</b>, waived when you authorize the repair</li>
    </ul>
  </div></section>

  <BrandBranchesGrid />

  <section class="trust-bar"><div class="wrap"><span>BHGS #A49573 · Insured</span><span>Same-day in 5 SoCal counties</span><span>Residential diagnostic $89 · waived with repair</span></div></section>

  <section class="section"><div class="wrap">
    <h2>What Fisher & Paykel washer repair costs in LA</h2>
    <table class="price-table">
      <tr><th>Service</th><th>Typical Range</th><th>Notes</th></tr>
      <tr><td>Residential diagnostic</td><td>$89</td><td>Waived with repair</td></tr>
      <tr><td>Motor-tachometer sensor</td><td>$140 – $220</td><td>SmartDrive RPM feedback</td></tr>
      <tr><td>Main control board</td><td>$320 – $480</td><td>SmartDrive motor-drive logic</td></tr>
      <tr><td>Door-lock mechanism</td><td>$140 – $240</td><td>Common 8-12 year service</td></tr>
      <tr><td>Drain pump</td><td>$160 – $260</td><td>Standard service item</td></tr>
      <tr><td>Inlet valve</td><td>$80 – $140</td><td>Low-flow diagnostic</td></tr>
      <tr><td>Pressure switch</td><td>$100 – $160</td><td>Water-level sensing</td></tr>
      <tr><td>Shock absorbers (pair)</td><td>$140 – $220</td><td>Vibration fix</td></tr>
      <tr><td>SmartDrive motor</td><td>$580 – $880</td><td>Rare failure; 12-18 year lifespan</td></tr>
      <tr><td>Drum bearing service</td><td>$520 – $820</td><td>Major repair at 12+ years</td></tr>
    </table>
    <p class="small">Related: <a href="/brands/fisher-paykel-refrigerator-repair/">F&P brand hub</a> · <a href="/brands/fisher-paykel-dishwasher-repair/">F&P dishwasher</a> · <a href="/brands/fisher-paykel-range-hood-repair/">F&P range hood</a> · <a href="/brands/fisher-paykel-oven-repair/">F&P oven</a> · <a href="/brands/miele-washer-repair/">Miele washer (premium peer)</a> · <a href="/services/washer-repair/">Washer repair (service hub)</a> · <a href="/price-list/washer-repair-cost/">Washer repair cost</a>.</p>
  </div></section>

  <section class="section alt"><div class="wrap narrow">
    <h2>SmartDrive, the engineering that shows up at repair time</h2>
    <p>Most US washers use a drive belt to connect motor to drum, a clutch or transmission for direction change, and an agitator or impeller powered through the transmission. Each of those mechanical stages introduces wear and a failure mode. F&P's SmartDrive replaces the belt + transmission stack with a <b>single brushless DC motor driving the drum directly</b>, the motor can reverse direction in milliseconds, vary RPM continuously, and doesn't have belts to slip or gears to strip. Fewer moving parts, fewer failure modes, longer service life.</p>
    <p>Practical impact at repair time: SmartDrive units don't get the common belt-replacement call ($60-$120 saved on every 5-year interval) or the transmission-rebuild call ($400-$700 major repair avoided). Failures concentrate on the control board (complex motor-drive logic) and the motor-tachometer sensor (RPM feedback); the motor itself rarely fails. When a 15-year-old F&P washer walks into our diagnostic queue with a control-board issue, repair usually wins over replace because the rest of the machine is built to keep running.</p>
  </div></section>

  <section class="section"><div class="wrap narrow">
    <h2>F&P washer repair, frequently asked</h2>
    {faqs.map(f => (<details class="faq"><summary>{f.q}</summary><p set:html={f.a}></p></details>))}
  </div></section>

  <section id="book" class="cta-bottom"><div class="wrap">
    <h2>F&P washer service? Call the branch closest to your home.</h2>
    <p>Same-day appliance repair in Los Angeles, Orange County, Ventura County. Residential diagnostic $89, waived with repair.</p>
  </div></section>
  <a href={`tel:${MAIN_PHONE_TEL}`} class="float-call" aria-label="Call now">☎ Call {MAIN_PHONE}</a>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  body { color: var(--text); } .wrap { max-width: 1200px; margin: 0 auto; padding: 0 24px; } .wrap.narrow { max-width: 820px; }
  h1 { font-size: 2.4rem; line-height: 1.15; margin: 12px 0 20px; color: var(--black); }
  h2 { font-size: 1.8rem; margin: 0 0 16px; color: var(--black); }
  p { line-height: 1.65; margin: 0 0 14px; }
  .call-banner { background: var(--red); color: #fff; padding: 10px 0; }
  .call-banner .wrap { display:flex; gap: 14px; align-items: center; justify-content: center; flex-wrap: wrap; }
  .call-banner .phone-lg { color:#fff; font-weight: 800; text-decoration: underline; font-size: 1.05rem; }
  .hero { background: var(--black); color: #fff; padding: 42px 0 56px; } .hero h1 { color: #fff; }
  .hero .lede { font-size: 1.06rem; color: #d7d7d7; max-width: 680px; }
  .hero .crumb { color: #9a9a9a; font-size: 0.85rem; margin-bottom: 6px; } .hero .crumb a { color: #c9c9c9; text-decoration: none; }
  .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; margin: 18px 0 24px; }
  .btn { display: inline-block; padding: 12px 20px; border-radius: 4px; text-decoration: none; font-weight: 700; }
  .btn-primary { background: var(--red); color: #fff; } .btn-ghost { background: transparent; color: #fff; border: 1px solid #fff; }
  .hero-facts { list-style: none; padding: 0; margin: 0; color: #c9c9c9; font-size: 0.95rem; }
  .hero-facts li { padding: 6px 0; border-top: 1px solid #222; } .hero-facts li:first-child { border-top: 0; }
  .trust-bar { background: var(--red); color: #fff; padding: 14px 0; }
  .trust-bar .wrap { display: flex; gap: 28px; flex-wrap: wrap; justify-content: center; font-size: 0.95rem; font-weight: 600; }
  .section { padding: 56px 0; } .section.alt { background: var(--gray); }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 14px; background: #fff; }
  .price-table th, .price-table td { text-align: left; padding: 11px 12px; border-bottom: 1px solid var(--border); }
  .price-table th { background: var(--black); color: #fff; font-weight: 700; font-size: 0.95rem; }
  .small { color: var(--muted); font-size: 0.92rem; margin-top: 12px; }
  .faq { background: #fff; border: 1px solid var(--border); padding: 12px 16px; margin-bottom: 8px; border-radius: 4px; }
  .faq summary { font-weight: 700; cursor: pointer; padding: 4px 0; } .faq p { margin: 8px 0 0; }
  .cta-bottom { background: var(--black); color: #fff; padding: 48px 0; } .cta-bottom h2 { color: #fff; } .cta-bottom p { color: #c9c9c9; }
  .float-call { position: fixed; bottom: 18px; right: 18px; background: var(--red); color: #fff; padding: 14px 18px; border-radius: 40px; text-decoration: none; font-weight: 700; box-shadow: 0 6px 18px rgba(0,0,0,0.28); z-index: 50; font-size: 0.95rem; }
  @media (max-width: 820px) { h1 { font-size: 1.9rem; } .float-call { padding: 11px 14px; font-size: 0.88rem; } .trust-bar .wrap { gap: 14px; font-size: 0.85rem; } }
</style>
