---
import Layout from '../../layouts/Layout.astro';
import BrandBranchesGrid from '../../components/BrandBranchesGrid.astro';
import { MAIN_PHONE, MAIN_PHONE_TEL } from '../../data/branches';

const title = "Jenn-Air Microwave Repair | Southern California | Obsidian, Rise, Noir Built-In";
const description = "$89 diagnostic waived. Jenn-Air microwave repair Southern California — JMC/JMD built-in + OTR, Obsidian/Rise/Noir trim, JennAir Connect. Whirlpool family parts. (424) 325-0520.";
const canonical = "https://samedayappliance.repair/brands/jennair-microwave-repair/";

const faqs = [
  {
    q: "Obsidian vs Rise vs Noir — which trim is my Jenn-Air microwave?",
    a: "Jenn-Air's 2018+ design-statement program runs three named trim collections across the appliance suite. <b>Obsidian</b> — the original black-glass touch-front aesthetic with hidden controls; premium touch surfaces. <b>Rise</b> — stainless panels with brass-accent handles and visible precision hardware (pro-style-meets-modernist). <b>Noir</b> — matte black with black stainless trim, darker kitchen aesthetic. The three collections share a common Jenn-Air chassis underneath but ship with distinct front-fascia SKUs, so when we order a damaged panel we need to confirm which collection the rest of the kitchen matches. Model prefix JMC/JMD + a serial-plate trim code will tell us."
  },
  {
    q: "What Jenn-Air microwave models are most common in LA?",
    a: "<b>JMC-series built-in microwave</b> (24/27/30 inch cabinetry-integrated; the workhorse of Jenn-Air's microwave line — typical Westside premium remodel spec). <b>JMD-series drawer microwave</b> (under-counter pull-out; shares the Whirlpool-family drawer architecture, not the Sharp OEM chassis used by Wolf / Thermador / Miele). <b>JMV-series over-the-range</b> (OTR with Jenn-Air aesthetic trim over a Whirlpool-family chassis). <b>Combi convection + microwave built-in</b> on select premium lines. All route through the Whirlpool family parts chain at Benton Harbor Michigan with Jenn-Air-specific trim and firmware layered on top."
  },
  {
    q: "Jenn-Air vs KitchenAid — they share a Whirlpool parent, so same parts?",
    a: "Similar chassis, different aesthetic tier, and parts cross-fit at some levels but not others. Whirlpool Corporation owns both brands (KitchenAid acquired 1986, Jenn-Air 1982), and both route through Benton Harbor Michigan. <b>Mechanical components cross-fit</b>: turntable motors, door switches, some magnetrons, oven temperature sensors — often same part, different nameplate. <b>Control boards and front-fascia assemblies do NOT cross-fit</b> — Jenn-Air Obsidian/Rise/Noir firmware and touch-panel hardware are distinct from KitchenAid Architect II. When we service a Jenn-Air microwave, we use Jenn-Air-SKU boards even when cross-referencing to a KitchenAid part number on a mechanical item. See <a href='/brands/kitchenaid-microwave-repair/'>KitchenAid microwave</a> for the sibling context."
  },
  {
    q: "JennAir Connect pairing lost — app vs module issue?",
    a: "JennAir Connect (the Whirlpool Connected Kitchen platform, similar to Maytag Commercial Laundry's app platform) has predictable post-firmware pairing failures. Standard recovery: (1) power-cycle the microwave at the breaker for 60 seconds; (2) remove the appliance completely from the JennAir Connect app and re-pair from scratch (don't try to reconnect an existing entry); (3) confirm router is 2.4 GHz — JennAir Connect doesn't pair on 5 GHz-only networks; (4) if pairing fails after all three steps, the internal WiFi module ($180-$280) is the likely cause. We run the sequence during diagnostic before quoting the module swap."
  },
  {
    q: "Jenn-Air downdraft microwave — is that a thing?",
    a: "Not exactly. Jenn-Air is famous as the <b>downdraft cooktop pioneer</b> (1960s innovation, still a brand signature on cooktop lineups), but Jenn-Air microwaves are not downdraft-specific — the downdraft heritage lives in the cooktop + range product lines, not microwave. If you're thinking of an OTR microwave with downdraft ventilation, that's a combination design that Jenn-Air's JMV over-the-range addresses with standard upward venting rather than downdraft-to-duct. The downdraft aesthetic + functionality is specifically a Jenn-Air cooktop + range feature. See <a href='/brands/jennair-range-repair/'>Jenn-Air range</a> for downdraft product context."
  },
  {
    q: "What does Jenn-Air microwave repair cost in LA?",
    a: "Residential diagnostic $89 waived with repair. Typical Jenn-Air bands: magnetron $220–$380; main control board $320–$520 (Obsidian/Rise/Noir tier premium); touch-panel assembly $340–$520; door switch / interlock $100–$180; turntable motor $80–$140; <b>JMC built-in</b> door hinge spring $120–$200, door latch $140–$240; <b>JMV OTR</b> vent fan motor $140–$240; <b>JMD drawer</b> (Whirlpool-family chassis) linear actuator $200–$320; JennAir Connect WiFi module $180–$280; trim-panel swap (Obsidian/Rise/Noir damage) $280–$460 + specific collection surcharge. Whirlpool-family mechanical cross-fit often saves time on backordered SKUs."
  }
];

const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair — Jenn-Air Microwave Service",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": canonical, "telephone": MAIN_PHONE_TEL, "priceRange": "$$$"
  },
  { "@context": "https://schema.org", "@type": "Service", "serviceType": "Jenn-Air Microwave Repair",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "description": "Jenn-Air microwave repair across LA — JMC built-in, JMV OTR, JMD drawer (Whirlpool-family chassis). Obsidian / Rise / Noir trim collections 2018+. JennAir Connect WiFi. Whirlpool-family parts chain via Benton Harbor MI since 1982 acquisition. $89 residential diagnostic waived with repair.",
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, waived with repair" } }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "Jenn-Air", "item": "https://samedayappliance.repair/brands/jennair/" },
      { "@type": "ListItem", "position": 4, "name": "Jenn-Air Microwave Repair", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">{schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}</Fragment>
  <div class="call-banner"><div class="wrap"><span>Jenn-Air microwave service?</span><a href={`tel:${MAIN_PHONE_TEL}`} class="phone-lg">{MAIN_PHONE}</a></div></div>

  <section class="hero"><div class="wrap">
    <div class="crumb"><a href="/">Home</a> › <a href="/brands/">Brands</a> › Jenn-Air › Microwave Repair</div>
    <h1>Jenn-Air Microwave Repair</h1>
    <p class="lede">Jenn-Air (Whirlpool Corporation since 1982) built its design-forward luxury identity on the downdraft cooktop pioneer heritage and the 2018+ Obsidian / Rise / Noir trim collections. The microwave lineup runs across the JMC built-in (24/27/30 inch cabinetry-integrated), JMV over-the-range, and JMD drawer microwave (Whirlpool-family chassis — distinct from the Sharp OEM drawer used by Wolf / Thermador / Miele). All route through the Whirlpool family parts chain at Benton Harbor Michigan, which means Jenn-Air mechanical parts often cross-reference with Whirlpool / KitchenAid / Maytag / Amana at the motor + igniter + sensor level — Jenn-Air-specific only at the trim, firmware, and control-board layer. Same-day dispatch, $89 residential diagnostic waived with the repair.</p>
    <div class="hero-cta"><a href={`tel:${MAIN_PHONE_TEL}`} class="btn btn-primary">Call {MAIN_PHONE}</a><a href="#book" class="btn btn-ghost">Request a Visit</a></div>
    <ul class="hero-facts">
      <li><b>JMC built-in + JMV OTR + JMD drawer</b> — three microwave formats</li>
      <li><b>Obsidian / Rise / Noir trim collections</b> — 2018+ design-statement program</li>
      <li><b>Whirlpool family since 1982</b> — Benton Harbor MI parts cross-fit</li>
      <li><b>$89 residential diagnostic</b> — waived when you authorize the repair</li>
    </ul>
  </div></section>

  <BrandBranchesGrid />

  <section class="trust-bar"><div class="wrap"><span>CSLB #1138898 · Insured</span><span>Same-day in 5 SoCal counties</span><span>Residential diagnostic $89 · waived with repair</span></div></section>

  <section class="section"><div class="wrap">
    <h2>What Jenn-Air microwave repair costs in LA</h2>
    <table class="price-table">
      <tr><th>Service</th><th>Typical Range</th><th>Notes</th></tr>
      <tr><td>Residential diagnostic</td><td>$89</td><td>Waived with repair</td></tr>
      <tr><td>Magnetron</td><td>$220 – $380</td><td>JMC / JMV / JMD</td></tr>
      <tr><td>Main control board</td><td>$320 – $520</td><td>Obsidian/Rise/Noir premium tier</td></tr>
      <tr><td>Touch-panel assembly</td><td>$340 – $520</td><td>Collection-specific SKU</td></tr>
      <tr><td>JMC built-in door hinge spring</td><td>$120 – $200</td><td>8-12 year service</td></tr>
      <tr><td>Door latch interlock</td><td>$140 – $240</td><td>Safety-critical</td></tr>
      <tr><td>JMV OTR vent fan motor</td><td>$140 – $240</td><td>Dual-function cooling + vent</td></tr>
      <tr><td>JMD drawer linear actuator</td><td>$200 – $320</td><td>Whirlpool-family chassis</td></tr>
      <tr><td>JennAir Connect WiFi module</td><td>$180 – $280</td><td>Pairing / firmware recovery</td></tr>
      <tr><td>Trim-panel swap (O/R/N)</td><td>$280 – $460</td><td>Plus collection surcharge</td></tr>
    </table>
    <p class="small">Related: <a href="/brands/jennair/">Jenn-Air brand hub</a> · <a href="/brands/jennair-range-repair/">Jenn-Air range (downdraft pioneer)</a> · <a href="/brands/jennair-refrigerator-repair/">Jenn-Air refrigerator</a> · <a href="/brands/kitchenaid-microwave-repair/">KitchenAid microwave (Whirlpool family peer)</a> · <a href="/brands/whirlpool-microwave-repair/">Whirlpool microwave (parent family)</a> · <a href="/services/microwave-repair/">Microwave repair (service hub)</a> · <a href="/price-list/microwave-repair-cost/">Microwave repair cost</a>.</p>
  </div></section>

  <section class="section alt"><div class="wrap narrow">
    <h2>Obsidian / Rise / Noir — design collections that matter for parts</h2>
    <p>Jenn-Air relaunched in 2018 with three named design collections — Obsidian (black-glass hidden-control), Rise (stainless + brass-accent pro-style), Noir (matte black + black stainless). All three ship across the same core Jenn-Air appliance lineup (microwave, range, oven, refrigerator, dishwasher) with distinct front-fascia + handle + touch-panel SKUs. When we service a damaged-panel microwave, the part order depends on collection: Obsidian panels ship with hidden-touch hardware, Rise with brass accent, Noir with matte-black stainless trim. Mixing collections accidentally means a mismatched kitchen — we confirm collection from the serial plate before ordering any visible-surface part.</p>
  </div></section>

  <section class="section"><div class="wrap narrow">
    <h2>Jenn-Air microwave repair — frequently asked</h2>
    {faqs.map(f => (<details class="faq"><summary>{f.q}</summary><p set:html={f.a}></p></details>))}
  </div></section>

  <section id="book" class="cta-bottom"><div class="wrap">
    <h2>Jenn-Air microwave service? Call the branch closest to your home.</h2>
    <p>Same-day appliance repair in Los Angeles, Orange County, Ventura County. Residential diagnostic $89, waived with repair.</p>
  </div></section>
  <a href={`tel:${MAIN_PHONE_TEL}`} class="float-call" aria-label="Call now">☎ Call {MAIN_PHONE}</a>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  body { color: var(--text); } .wrap { max-width: 1200px; margin: 0 auto; padding: 0 24px; } .wrap.narrow { max-width: 820px; }
  h1 { font-size: 2.4rem; line-height: 1.15; margin: 12px 0 20px; color: var(--black); }
  h2 { font-size: 1.8rem; margin: 0 0 16px; color: var(--black); }
  p { line-height: 1.65; margin: 0 0 14px; }
  .call-banner { background: var(--red); color: #fff; padding: 10px 0; }
  .call-banner .wrap { display:flex; gap: 14px; align-items: center; justify-content: center; flex-wrap: wrap; }
  .call-banner .phone-lg { color:#fff; font-weight: 800; text-decoration: underline; font-size: 1.05rem; }
  .hero { background: var(--black); color: #fff; padding: 42px 0 56px; } .hero h1 { color: #fff; }
  .hero .lede { font-size: 1.06rem; color: #d7d7d7; max-width: 680px; }
  .hero .crumb { color: #9a9a9a; font-size: 0.85rem; margin-bottom: 6px; } .hero .crumb a { color: #c9c9c9; text-decoration: none; }
  .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; margin: 18px 0 24px; }
  .btn { display: inline-block; padding: 12px 20px; border-radius: 4px; text-decoration: none; font-weight: 700; }
  .btn-primary { background: var(--red); color: #fff; } .btn-ghost { background: transparent; color: #fff; border: 1px solid #fff; }
  .hero-facts { list-style: none; padding: 0; margin: 0; color: #c9c9c9; font-size: 0.95rem; }
  .hero-facts li { padding: 6px 0; border-top: 1px solid #222; } .hero-facts li:first-child { border-top: 0; }
  .trust-bar { background: var(--red); color: #fff; padding: 14px 0; }
  .trust-bar .wrap { display: flex; gap: 28px; flex-wrap: wrap; justify-content: center; font-size: 0.95rem; font-weight: 600; }
  .section { padding: 56px 0; } .section.alt { background: var(--gray); }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 14px; background: #fff; }
  .price-table th, .price-table td { text-align: left; padding: 11px 12px; border-bottom: 1px solid var(--border); }
  .price-table th { background: var(--black); color: #fff; font-weight: 700; font-size: 0.95rem; }
  .small { color: var(--muted); font-size: 0.92rem; margin-top: 12px; }
  .faq { background: #fff; border: 1px solid var(--border); padding: 12px 16px; margin-bottom: 8px; border-radius: 4px; }
  .faq summary { font-weight: 700; cursor: pointer; padding: 4px 0; } .faq p { margin: 8px 0 0; }
  .cta-bottom { background: var(--black); color: #fff; padding: 48px 0; } .cta-bottom h2 { color: #fff; } .cta-bottom p { color: #c9c9c9; }
  .float-call { position: fixed; bottom: 18px; right: 18px; background: var(--red); color: #fff; padding: 14px 18px; border-radius: 40px; text-decoration: none; font-weight: 700; box-shadow: 0 6px 18px rgba(0,0,0,0.28); z-index: 50; font-size: 0.95rem; }
  @media (max-width: 820px) { h1 { font-size: 1.9rem; } .float-call { padding: 11px 14px; font-size: 0.88rem; } .trust-bar .wrap { gap: 14px; font-size: 0.85rem; } }
</style>
