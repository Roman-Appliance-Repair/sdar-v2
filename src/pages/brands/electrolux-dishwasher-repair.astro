---
import Layout from '../../layouts/Layout.astro';
import BrandBranchesGrid from '../../components/BrandBranchesGrid.astro';
import { MAIN_PHONE, MAIN_PHONE_TEL } from '../../data/branches';

const title = "Electrolux Dishwasher Repair | Southern California | Swedish AB";
const description = "Electrolux dishwasher repair across SoCal, EI24ID + EDSH families, Stockholm Swedish AB parent since 1919. $89 dx.";
const canonical = "https://samedayappliance.repair/brands/electrolux-dishwasher-repair/";

const faqs = [
  {
    q: "Is Electrolux Professional the same as the Electrolux residential dishwasher we bought?",
    a: "No, different product scope, different corporate entity since 2020. Electrolux Professional is Electrolux's former commercial foodservice division that spun off as a separate publicly-traded company in March 2020. Electrolux Professional focuses on commercial dishwashers, commercial laundry, commercial food prep, and foodservice equipment, its own product lines, service network, and parts channel. AB Electrolux (the Stockholm-headquartered Swedish parent) retained the residential side: Electrolux-branded residential dishwashers + Frigidaire. If you have a commercial dishwasher at a restaurant, cafe, hotel, or institutional kitchen with \"Electrolux Professional\" branding, different company, different service path, go through Electrolux Professional factory-authorized commercial service. If you have a residential Electrolux dishwasher in a home kitchen, that's AB Electrolux's consumer line, serviced by our team with the $89 residential diagnostic. Easy to confirm which you have: the exterior badge says either \"Electrolux\" (residential AB Electrolux) or \"Electrolux Professional\" (commercial spin-off)."
  },
  {
    q: "What Electrolux dishwasher models are most common in LA?",
    a: "EI24ID and EDSH families dominate our LA Electrolux dishwasher service. EI24ID built-in configurations are the premium-tier volume platform, 24-inch stainless tub, fully-integrated panel-ready, 45 dB noise profiles typical, IQ-Touch control interface on higher trim, Perfect Dry heat-pump drying on current-generation upper trim. Mid-market kitchen remodels and premium-kitchen installs. EDSH families at slightly lower price points retain Electrolux-platform core engineering with reduced feature trim. Electrolux also markets Icon and ICON models at upper-premium tier though these are lower LA volume than mainstream EI24ID. LA installs concentrate in mid-premium kitchen remodels across Westside (Culver City, Mar Vista, Santa Monica), Hollywood Hills, Valley mid-premium (Encino, Sherman Oaks, Studio City), Pasadena + San Marino, Newport Beach + Laguna premium OC."
  },
  {
    q: "Electrolux and Frigidaire are the same parent, why does Electrolux cost more?",
    a: "Shared AB Electrolux parent, shared chassis engineering at the platform level, different finished-good specification. Electrolux-branded residential sits one tier above Frigidaire in the AB Electrolux North American lineup. Where they differ: Electrolux ships with Perfect Dry heat-pump drying, IQ-Touch control interface, quieter noise profiles (45 dB typical vs Frigidaire Gallery 49-52 dB), premium trim materials, stainless interior baseline. Frigidaire Professional + Electrolux overlap in price and feature at the upper tier but with distinct brand positioning. For service, Electrolux-platform parts cross-reference broadly with Frigidaire, our Electrolux-platform parts inventory accelerates first-visit repair on both brands. Price separation at retail ($1,200-$2,200 Electrolux vs $800-$1,500 Frigidaire Gallery / $1,300-$1,900 Frigidaire Professional) reflects the finish + feature + brand-positioning spread."
  },
  {
    q: "Electrolux Perfect Dry won't dry properly, what's the diagnostic?",
    a: "Perfect Dry is Electrolux's heat-pump drying system (current-generation upper-trim). Instead of condensation drying or standard heating-element dry, Perfect Dry uses an inverter-compressor heat-pump cycle to evacuate moisture efficiently. Failure modes: (1) rinse aid, even heat-pump drying depends on rinse aid for final sheeting; $89 diagnostic if dispenser is empty or clogged ($140–$220 dispenser service); (2) heat-pump inverter-compressor fault, specialty service, $480–$720 swap, 7-14 day Electrolux-specialty parts lead; (3) drying fan motor, $280–$440; (4) vent flap mechanism stuck, $180–$280 service; (5) control-board drying-cycle logic, $440–$620. Perfect Dry heat-pump units have longer parts-lead times than mass-market dishwashers because of the specialty heat-pump-dryer architecture. Worth knowing before diagnosing, we set realistic expectations on parts lead at intake."
  },
  {
    q: "What does Electrolux dishwasher repair cost in LA?",
    a: "Residential diagnostic is $89, waived when you authorize the repair. Common Electrolux bands: drain filter clean $89 (often free at diagnostic); drain pump $240–$380 (Electrolux-platform); inlet valve $240–$380; door latch + switch $220–$340; door gasket $260–$440 (panel-ready premium profile); heating element $280–$440; IQ-Touch interface panel $280–$440 (membrane/control swap); Perfect Dry drying-fan motor $280–$440; Perfect Dry heat-pump inverter-compressor $480–$720 (7-14 day specialty lead); control board $440–$620; circulation pump $440–$620; panel-ready trim hardware quoted individually. Electrolux parts through AB Electrolux North America distribution, common items 3-7 day typical, specialty 7-14 day. Parts cross-reference with Frigidaire on platform-shared items."
  }
];

const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair, Electrolux Dishwasher Service",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": canonical, "telephone": MAIN_PHONE_TEL, "priceRange": "$$$",
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ]
  },
  { "@context": "https://schema.org", "@type": "Service", "serviceType": "Electrolux Dishwasher Repair",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "description": "Electrolux dishwasher repair across Southern California, LA, Orange, Ventura, San Bernardino, Riverside. EI24ID and EDSH families, Perfect Dry heat-pump drying, IQ-Touch interface, panel-ready built-in. AB Electrolux Swedish parent since 1919. Distinct from Electrolux Professional commercial spin-off (2020). $89 residential diagnostic waived with repair.",
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, waived with repair" } }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "Electrolux", "item": "https://samedayappliance.repair/brands/electrolux/" },
      { "@type": "ListItem", "position": 4, "name": "Electrolux Dishwasher Repair", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">{schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}</Fragment>

  <div class="call-banner"><div class="wrap"><span>Electrolux dishwasher service? Same-day across all 5 SoCal counties:</span><a href={`tel:${MAIN_PHONE_TEL}`} class="phone-lg">{MAIN_PHONE}</a></div></div>

  <section class="hero"><div class="wrap">
    <div class="crumb"><a href="/">Home</a> › <a href="/brands/">Brands</a> › Electrolux › Dishwasher Repair</div>
    <h1>Electrolux Dishwasher Repair</h1>
    <p class="lede">Electrolux is the Swedish home-appliance brand, AB Electrolux (Stockholm, founded 1919), mid-premium positioned one tier above Frigidaire in the AB Electrolux North America lineup. The Electrolux residential dishwasher line features EI24ID and EDSH families with Perfect Dry heat-pump drying on current-gen upper trim, IQ-Touch control interface, 45 dB noise profiles, stainless tub baseline, panel-ready integration. Our LA service concentrates in mid-premium kitchen remodels across Westside, Hollywood Hills, Valley premium, Pasadena + San Marino, and Orange County premium kitchens. Platform cross-reference with Frigidaire accelerates parts sourcing on common service items. <b>Important:</b> Electrolux residential is distinct from Electrolux Professional, the commercial foodservice spin-off that became a separate publicly-traded company in March 2020. Same-day dispatch, $89 residential diagnostic waived with the repair.</p>
    <div class="hero-cta"><a href={`tel:${MAIN_PHONE_TEL}`} class="btn btn-primary">Call {MAIN_PHONE}</a><a href="#book" class="btn btn-ghost">Request a Visit</a></div>
    <ul class="hero-facts">
      <li><b>AB Electrolux Swedish since 1919</b>, mid-premium residential tier</li>
      <li><b>Distinct from Electrolux Professional commercial</b>, separate 2020 spin-off</li>
      <li><b>Perfect Dry + IQ-Touch</b>, current-gen signature features</li>
      <li><b>$89 residential diagnostic</b>, waived when you authorize the repair</li>
    </ul>
  </div></section>

  <BrandBranchesGrid />

  <section class="trust-bar"><div class="wrap"><span>BHGS #A49573 · Insured</span><span>Same-day in 5 SoCal counties</span><span>Residential diagnostic $89 · waived with repair</span></div></section>

  <section class="section"><div class="wrap narrow">
    <h2>Electrolux Professional disambiguation, important before diagnosing service</h2>
    <p>AB Electrolux operated both residential and commercial divisions under the Electrolux brand for most of its history. In March 2020, the commercial division spun off as a separate publicly-traded company called Electrolux Professional AB. That spin-off is now a distinct corporate entity from the AB Electrolux that owns residential Electrolux + Frigidaire + AEG + Westinghouse.</p>
    <p><b>If your dishwasher has \"Electrolux\" branding in a home kitchen</b>: that's AB Electrolux residential. We service it. $89 residential diagnostic path applies.</p>
    <p><b>If your dishwasher has \"Electrolux Professional\" branding in a restaurant, cafe, hotel, institutional kitchen, or any commercial food-service context</b>: that's the 2020 commercial spin-off company. It uses a separate factory-authorized commercial service network with different parts channels and different service economics. Commercial dishwashers are also outside our residential $89 diagnostic tier, commercial service runs at $120 diagnostic minimum through our commercial division.</p>
    <p>This disambiguation matters because Google searches for \"Electrolux dishwasher\" sometimes surface commercial-spec information that's not applicable to residential units. Our residential service page addresses residential AB Electrolux products only. For commercial foodservice Electrolux Professional service, contact Electrolux Professional directly or our commercial service team.</p>
  </div></section>

  <section class="section alt"><div class="wrap">
    <h2>Electrolux residential dishwasher failures our techs see most often</h2>
    <div class="fail-block"><h3>Drain pump + filter service</h3><p>Electrolux-platform drain system. Filter clean often free; drain pump $240–$380.</p></div>
    <div class="fail-block"><h3>IQ-Touch interface / membrane switch</h3><p>Touch-control layer fails at 5-8 years on daily-use households. Swap $280–$440.</p></div>
    <div class="fail-block"><h3>Perfect Dry heat-pump inverter-compressor (upper trim)</h3><p>Specialty heat-pump drying service. Inverter-compressor $480–$720 with 7-14 day Electrolux-specialty parts lead.</p></div>
    <div class="fail-block"><h3>Door gasket on panel-ready integration</h3><p>Panel-ready door gasket alignment-sensitive. $260–$440 swap + alignment.</p></div>
    <div class="fail-block"><h3>Heating element on hard-water LA units</h3><p>Element swap $280–$440. Scale accelerates on 7-10 year service interval.</p></div>
    <div class="fail-block"><h3>Control board + Frigidaire-platform parts cross-reference</h3><p>Board $440–$620. Electrolux-platform shares with Frigidaire on some common parts, accelerated first-visit repair.</p></div>
  </div></section>

  <section class="section"><div class="wrap">
    <h2>Electrolux dishwasher product lines we service</h2>
    <div class="model-grid">
      <div class="model-card"><h3>EI24ID built-in (premium volume)</h3><p>24-inch built-in with stainless tub, IQ-Touch, panel-ready, 45 dB noise. LA mid-premium volume.</p></div>
      <div class="model-card"><h3>EDSH families</h3><p>Similar platform at slightly lower trim tier.</p></div>
      <div class="model-card"><h3>Icon / ICON upper-premium</h3><p>Upper-tier Electrolux with enhanced trim. Lower LA volume.</p></div>
      <div class="model-card"><h3>Perfect Dry heat-pump drying</h3><p>Current-gen upper-trim drying system. Specialty service path.</p></div>
      <div class="model-card"><h3>IQ-Touch interface</h3><p>Capacitive touch control on higher trim. Membrane swap service.</p></div>
      <div class="model-card"><h3>Frigidaire platform cross-reference</h3><p>Common parts shared with Frigidaire, parts inventory advantage.</p></div>
    </div>
  </div></section>

  <section class="section alt"><div class="wrap narrow">
    <h2>Electrolux vs Frigidaire, the same-parent sibling question</h2>
    <p>AB Electrolux acquired Frigidaire in 1986. Since then, both brands share chassis platforms at the engineering level with distinct finished-good specifications. Electrolux sits one tier above Frigidaire across trim + noise profile + premium features + price point.</p>
    <p><b>Electrolux</b>, this page. Mid-premium, Perfect Dry, IQ-Touch, 45 dB typical, stainless tub baseline, $1,200-$2,200 retail.</p>
    <p><b>Frigidaire Professional</b>, upper-tier Frigidaire, 49 dB, dual OrbitClean, $1,300-$1,900 retail. See <a href="/brands/frigidaire-dishwasher-repair/">Frigidaire dishwasher repair</a>.</p>
    <p><b>Frigidaire Gallery</b>, mid-tier, EvenDry fan-assisted, 49-52 dB, $900-$1,400 retail. See <a href="/brands/frigidaire-dishwasher-repair/">Frigidaire dishwasher repair</a>.</p>
    <p><b>Frigidaire base</b>, mass-market, $500-$800 retail.</p>
    <p>For households deciding: Electrolux for mid-premium quiet-noise + heat-pump drying spec; Frigidaire Professional for upper-tier Frigidaire with cost spread below Electrolux; Frigidaire Gallery or base for value-tier rental + mass-market applications.</p>
  </div></section>

  <section class="section"><div class="wrap">
    <h2>What Electrolux dishwasher repair typically costs</h2>
    <table class="price-table">
      <tr><th>Service</th><th>Typical Range</th><th>Notes</th></tr>
      <tr><td>Residential diagnostic</td><td>$89</td><td>Waived with repair</td></tr>
      <tr><td>Drain filter clean</td><td>$89</td><td>Often free at diagnostic</td></tr>
      <tr><td>Drain pump replacement</td><td>$240 – $380</td><td>Electrolux-platform</td></tr>
      <tr><td>Inlet valve</td><td>$240 – $380</td><td>Fill fault</td></tr>
      <tr><td>Door latch + switch</td><td>$220 – $340</td><td>5-8 year wear</td></tr>
      <tr><td>Door gasket (panel-ready)</td><td>$260 – $440</td><td>Alignment service</td></tr>
      <tr><td>Heating element</td><td>$280 – $440</td><td>Hard-water scale</td></tr>
      <tr><td>IQ-Touch interface / membrane</td><td>$280 – $440</td><td>Capacitive touch fault</td></tr>
      <tr><td>Perfect Dry fan motor</td><td>$280 – $440</td><td>Heat-pump drying system</td></tr>
      <tr><td>Perfect Dry heat-pump compressor</td><td>$480 – $720</td><td>7-14 day specialty lead</td></tr>
      <tr><td>Control board</td><td>$440 – $620</td><td>Frigidaire platform cross-ref</td></tr>
      <tr><td>Circulation pump</td><td>$440 – $620</td><td>8-plus-year service</td></tr>
      <tr><td>Panel-ready trim hardware</td><td>Quoted individually</td><td>Custom panel units</td></tr>
    </table>
    <p class="small">Related: <a href="/brands/frigidaire-dishwasher-repair/">Frigidaire dishwasher repair (sibling)</a> · <a href="/brands/electrolux-refrigerator-repair/">Electrolux refrigerator repair</a> · <a href="/price-list/dishwasher-repair-cost/">dishwasher cost guide</a>.</p>
  </div></section>

  <section class="section alt"><div class="wrap">
    <h2>Service areas, where our Electrolux calls come from</h2>
    <div class="area-grid">
      <div><h4>Westside mid-premium</h4><p>Culver City · Mar Vista · <a href="/santa-monica/">Santa Monica</a> · <a href="/west-hollywood/">West Hollywood</a></p></div>
      <div><h4>Hollywood Hills</h4><p>Hollywood Hills · Laurel Canyon · Outpost Estates</p></div>
      <div><h4>Valley mid-premium</h4><p><a href="/encino/">Encino</a> · Sherman Oaks · Studio City · Woodland Hills</p></div>
      <div><h4>Pasadena + San Marino</h4><p><a href="/pasadena/">Pasadena</a> · San Marino · La Cañada · South Pasadena</p></div>
      <div><h4>Beverly Hills + Westside luxury</h4><p><a href="/beverly-hills/">Beverly Hills</a> · Brentwood · Pacific Palisades</p></div>
      <div><h4>Ventura + Orange County</h4><p><a href="/thousand-oaks/">Thousand Oaks</a> · <a href="/irvine/">Irvine</a> · Newport Beach · Laguna Beach</p></div>
    </div>
  </div></section>

  <section class="section"><div class="wrap narrow">
    <h2>Related Electrolux and AB Electrolux-family pages</h2>
    <ul class="related-links">
      <li><a href="/brands/electrolux-refrigerator-repair/">Electrolux refrigerator repair →</a></li>
      <li><a href="/brands/frigidaire-dishwasher-repair/">Frigidaire dishwasher repair (sibling) →</a></li>
      <li><a href="/brands/frigidaire-refrigerator-repair/">Frigidaire refrigerator repair →</a></li>
      <li><a href="/brands/bosch-dishwasher-repair/">Bosch dishwasher repair (alternative premium) →</a></li>
      <li><a href="/brands/miele-dishwasher-repair/">Miele dishwasher repair (alternative luxury) →</a></li>
      <li><a href="/services/dishwasher-repair/">Dishwasher repair (service hub) →</a></li>
      <li><a href="/price-list/dishwasher-repair-cost/">Dishwasher repair cost guide →</a></li>
    </ul>
  </div></section>

  <section class="section alt"><div class="wrap narrow">
    <h2>Electrolux dishwasher repair, frequently asked</h2>
    {faqs.map(f => (<details class="faq"><summary>{f.q}</summary><p set:html={f.a}></p></details>))}
  </div></section>

  <section id="book" class="cta-bottom"><div class="wrap">
    <h2>Electrolux dishwasher service? Call the branch closest to your home.</h2>
    <p>Same-day appliance repair across Los Angeles, Orange, Ventura, San Bernardino, and Riverside counties. Residential diagnostic $89, waived with repair.</p>
  </div></section>
  <a href={`tel:${MAIN_PHONE_TEL}`} class="float-call" aria-label="Call now">☎ Call {MAIN_PHONE}</a>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  body { color: var(--text); } .wrap { max-width: 1200px; margin: 0 auto; padding: 0 24px; } .wrap.narrow { max-width: 820px; }
  h1 { font-size: 2.4rem; line-height: 1.15; margin: 12px 0 20px; color: var(--black); }
  h2 { font-size: 1.8rem; margin: 0 0 16px; color: var(--black); }
  h3 { font-size: 1.2rem; margin: 0 0 10px; color: var(--black); }
  h4 { font-size: 1.02rem; margin: 0 0 6px; color: var(--black); }
  p { line-height: 1.65; margin: 0 0 14px; }
  .call-banner { background: var(--red); color: #fff; padding: 10px 0; }
  .call-banner .wrap { display:flex; gap: 14px; align-items: center; justify-content: center; flex-wrap: wrap; }
  .call-banner .phone-lg { color:#fff; font-weight: 800; text-decoration: underline; font-size: 1.05rem; }
  .hero { background: var(--black); color: #fff; padding: 42px 0 56px; } .hero h1 { color: #fff; }
  .hero .lede { font-size: 1.06rem; color: #d7d7d7; max-width: 680px; }
  .hero .crumb { color: #9a9a9a; font-size: 0.85rem; margin-bottom: 6px; } .hero .crumb a { color: #c9c9c9; text-decoration: none; }
  .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; margin: 18px 0 24px; }
  .btn { display: inline-block; padding: 12px 20px; border-radius: 4px; text-decoration: none; font-weight: 700; }
  .btn-primary { background: var(--red); color: #fff; } .btn-ghost { background: transparent; color: #fff; border: 1px solid #fff; }
  .hero-facts { list-style: none; padding: 0; margin: 0; color: #c9c9c9; font-size: 0.95rem; }
  .hero-facts li { padding: 6px 0; border-top: 1px solid #222; } .hero-facts li:first-child { border-top: 0; }
  .trust-bar { background: var(--red); color: #fff; padding: 14px 0; }
  .trust-bar .wrap { display: flex; gap: 28px; flex-wrap: wrap; justify-content: center; font-size: 0.95rem; font-weight: 600; }
  .section { padding: 56px 0; } .section.alt { background: var(--gray); }
  .model-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 20px; margin-top: 24px; }
  .model-card { background: #fff; border: 1px solid var(--border); padding: 20px; border-radius: 6px; }
  .section.alt .model-card { background: #fff; }
  .fail-block { background: #fff; border-left: 3px solid var(--red); padding: 20px 22px; margin: 16px 0; }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 14px; background: #fff; }
  .price-table th, .price-table td { text-align: left; padding: 11px 12px; border-bottom: 1px solid var(--border); }
  .price-table th { background: var(--black); color: #fff; font-weight: 700; font-size: 0.95rem; }
  .small { color: var(--muted); font-size: 0.92rem; margin-top: 12px; }
  .area-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 18px; }
  .area-grid > div { background: #fff; border: 1px solid var(--border); padding: 16px; border-radius: 6px; }
  .related-links { list-style: none; padding: 0; } .related-links li { padding: 10px 0; border-bottom: 1px solid var(--border); }
  .related-links a { color: var(--red); font-weight: 600; text-decoration: none; } .related-links a:hover { text-decoration: underline; }
  .faq { background: #fff; border: 1px solid var(--border); padding: 12px 16px; margin-bottom: 8px; border-radius: 4px; }
  .faq summary { font-weight: 700; cursor: pointer; padding: 4px 0; } .faq p { margin: 8px 0 0; }
  .cta-bottom { background: var(--black); color: #fff; padding: 48px 0; } .cta-bottom h2 { color: #fff; } .cta-bottom p { color: #c9c9c9; }
  .float-call { position: fixed; bottom: 18px; right: 18px; background: var(--red); color: #fff; padding: 14px 18px; border-radius: 40px; text-decoration: none; font-weight: 700; box-shadow: 0 6px 18px rgba(0,0,0,0.28); z-index: 50; font-size: 0.95rem; }
  @media (max-width: 820px) { h1 { font-size: 1.9rem; } h2 { font-size: 1.45rem; } .float-call { padding: 11px 14px; font-size: 0.88rem; } .trust-bar .wrap { gap: 14px; font-size: 0.85rem; } }
</style>
