---
import Layout from '../../layouts/Layout.astro';
import BrandBranchesGrid from '../../components/BrandBranchesGrid.astro';
import { MAIN_PHONE, MAIN_PHONE_TEL } from '../../data/branches';

const title = "Sub-Zero Repair | Southern California | Built-In, Column, Wine Storage, Ice Maker | Same Day";
const description = "Sub-Zero refrigerator, wine cooler, ice maker repair across SoCal. Classic, Designer column, Pro series. Factory-trained. $89 diagnostic waived with repair.";

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": "https://samedayappliance.repair/brands/sub-zero/#business",
    "name": "Same Day Appliance Repair, Sub-Zero Service",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": "https://samedayappliance.repair/brands/sub-zero/",
    "telephone": MAIN_PHONE_TEL,
    "priceRange": "$$$$",
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Are you Sub-Zero Factory-Certified?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No, we're factory-trained but independent. The Sub-Zero Factory-Certified Service Network is a specific group of contractors authorized for warranty work (Roadrunner, Sub-Zero Metro LA, and others in LA). Our technicians are trained on the Sub-Zero platform, dual refrigeration, Classic, Designer, and Professional series architecture, but we're not on that Factory-Certified list. If your Sub-Zero is inside the 2-year major-parts warranty or 12-year compressor warranty, call Sub-Zero customer service at 1-800-222-7820, they'll dispatch Factory-Certified at no parts cost. We're the right call post-warranty or when the Factory-Certified dispatch window doesn't fit your schedule."
        }
      },
      {
        "@type": "Question",
        "name": "Does Sub-Zero make ovens, dishwashers, or laundry?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No. Sub-Zero is a refrigeration-only brand, built-in refrigerators, column refrigerators and freezers, wine storage, undercounter refrigeration, ice makers. Cooking in the Sub-Zero Group is handled by Wolf; dishwashers by Cove. Sub-Zero has never made washers or dryers. For a full integrated kitchen we service all three brands plus Miele and Bosch laundry, see our Wolf and Cove brand pages."
        }
      },
      {
        "@type": "Question",
        "name": "Is it worth repairing a 15-year-old Sub-Zero?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Usually yes. Sub-Zero refrigerators are engineered for 20+ years of service, 15 years is mid-life for a well-maintained unit. A new Sub-Zero BI-36U built-in runs $12,000–$14,500 installed; a new PRO 48 approaches $19,000. Most common repairs on older units, compressor start relay, evaporator fan, defrost system, door gasket, control board, fall between $300 and $1,200 parts-and-labor. Even a sealed-system compressor replacement at $1,850–$2,800 is far cheaper than a new unit. Exception: units past 20 years with cascading failures (compressor plus control plus fan in quick succession) sometimes flip the math toward replacement. We give honest assessments, no upsell to repair when replacement makes more sense."
        }
      },
      {
        "@type": "Question",
        "name": "Do you stock Sub-Zero parts?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Common wear parts for Classic and Designer Series on the truck, compressor start relays, overload protectors, evaporator fan motors, condenser fan motors, door gaskets, ice maker modules, water inlet valves, defrost thermostats. Less common parts, specific Professional Series 648PRO control boards, CL series inverter boards, wine column humidity sensors, come next-day from Sub-Zero parts distribution. Very legacy parts (pre-2005 BI series, discontinued components) we source through specialty channels and flag the timeline upfront."
        }
      },
      {
        "@type": "Question",
        "name": "How much does Sub-Zero repair cost?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Diagnostic is $89 and waived when you book the repair. Typical Sub-Zero repairs: compressor start relay $85–$145, overload protector $65–$125, evaporator fan motor $320–$460, condenser fan motor $285–$385, defrost thermostat $125–$195, door gasket $385–$540 (Sub-Zero gaskets run more than generic brands), main control board $680–$980, ice maker module $320–$450, wine column humidity sensor $215–$295, sealed-system compressor replacement $1,850–$2,800. Labor and parts quoted before work starts."
        }
      }
    ]
  }
];
---
<Layout title={title} description={description}>
  <Fragment slot="head-scripts">
    {schemaJsons.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </Fragment>

  <section class="hero">
    <div class="hero-inner">
      <div class="hero-content">
        <p class="hero-eyebrow">LA · Orange · Ventura · San Bernardino · Riverside Counties</p>
        <h1>Sub-Zero Repair</h1>
        <p class="hero-sub">Factory-trained service for Sub-Zero built-in refrigerators, Designer column refrigerators and freezers, Wine Storage, Undercounter, and Ice Makers. Classic, Designer, and Professional series. Post-warranty specialists for premium kitchens across Southern California, LA's Westside (Bel Air, Beverly Hills, Malibu), Newport Coast and Pelican Hill in OC, Westlake Village and Hidden Hills in Ventura, and the Temecula and Rancho Cucamonga estate corridors.</p>
        <div class="hero-ctas">
          <a href={`tel:${MAIN_PHONE_TEL}`} class="btn-primary">☎ {MAIN_PHONE}</a>
          <a href="/contact/" class="btn-outline">Book Online</a>
        </div>
      </div>
      <div class="hero-img-wrap">
        <div class="hero-img-placeholder">
          <p>Sub-Zero Repair</p>
          <p>Across Southern California</p>
        </div>
      </div>
    </div>
  </section>

  <div class="trust-bar">
    <div class="trust-bar-inner">
      <div class="trust-item"><span class="trust-icon">🏅</span> BHGS #A49573</div>
      <div class="trust-item"><span class="trust-icon">🛡</span> Fully Insured</div>
      <div class="trust-item"><span class="trust-icon">⚡</span> Same Day Available</div>
      <div class="trust-item"><span class="trust-icon">🔩</span> OEM Parts on Truck</div>
      <div class="trust-item"><span class="trust-icon">💬</span> $89 Diagnostic, Waived With Repair</div>
    </div>
  </div>

  <!-- ── ABOUT ── -->
  <section class="section">
    <div class="container">
      <p class="eyebrow-sub">About the brand</p>
      <h2>Sub-Zero is refrigeration. That focus is the whole point.</h2>
      <p>Sub-Zero has made refrigerators since 1945 and nothing else. Not cooking, not dishwashers, not laundry, just refrigeration. In the Sub-Zero Group (the parent holding company), cooking is handled by Wolf and dishwashers by Cove. Each brand stays in its lane, and each has deeper engineering than a generalist brand could support. That's why a Sub-Zero BI-36U built-in lasts 20 years in a Bel Air, Newport Coast, or Westlake Village kitchen while a comparable mass-market fridge gets replaced at year 8.</p>
      <p>The engineering that makes Sub-Zero last is dual refrigeration, two independent cooling systems (one for the fridge, one for the freezer), each with its own compressor and evaporator. Cross-contamination of food smells is eliminated because the air between the two compartments never mixes. Humidity is controlled independently in each compartment. Temperature holds within a degree of setpoint. The downside: more components means more things that can fail, and the repair approach has to understand both cooling systems as independent circuits.</p>
      <p>One important context about Sub-Zero service in LA: the Sub-Zero Factory-Certified Service Network is real and it matters. Owners inside the 2-year major-parts warranty and 12-year compressor warranty should call <strong>1-800-222-7820</strong> first, Factory-Certified contractors (Roadrunner, Sub-Zero Metro LA, and others) dispatch at no parts cost. We serve the post-warranty market, most of our Sub-Zero calls are 6-to-20-year-old units where the warranty is closed but the fridge has another 10 years of service life left. Our factory training is the same; we're independent, faster to respond, and don't carry the Factory-Certified overhead.</p>
    </div>
  </section>

  <!-- ── CATEGORIES ── -->
  <section class="section section-alt">
    <div class="container">
      <p class="eyebrow-sub">What we repair</p>
      <h2>Sub-Zero categories we service</h2>
      <div class="cat-grid">
        <a href="/brands/sub-zero-refrigerator-repair/" class="cat-card">
          <h3>Sub-Zero Refrigerator &amp; Freezer Repair</h3>
          <p>Classic built-in (BI series), Designer column (IC/IT/ID series), Professional (PRO 48/3650/4850), Classic New (CL series). French door, over-under, side-by-side, column configurations. Freezer columns included (F series).</p>
          <span class="cat-cta">View refrigerator repair →</span>
        </a>
        <a href="/brands/sub-zero-wine-cooler-repair/" class="cat-card">
          <h3>Sub-Zero Wine Cooler &amp; Wine Storage Repair</h3>
          <p>Wine columns (IW-18, IW-24, IW-30), undercounter wine (UW-24, 315W series), dual-zone wine storage. Humidity control, compressor service, door seal specialized for wine preservation temperatures.</p>
          <span class="cat-cta">View wine cooler repair →</span>
        </a>
        <a href="/brands/sub-zero-ice-maker-repair/" class="cat-card">
          <h3>Sub-Zero Ice Maker Repair</h3>
          <p>Standalone ice makers, UC-15I (clear ice), UC-24CI (nugget ice), integrated ice makers in refrigerator columns. Condenser, water system, and harvest motor service.</p>
          <span class="cat-cta">View ice maker repair →</span>
        </a>
        <a href="/brands/wolf/" class="cat-card">
          <h3>Wolf Cooking Repair (Partner Brand)</h3>
          <p>The cooking partner in the Sub-Zero Group. Dual-fuel ranges, rangetops, wall ovens, induction cooktops. We service both brands in a single visit for Sub-Zero/Wolf/Cove kitchens.</p>
          <span class="cat-cta">View Wolf →</span>
        </a>
        <div class="cat-card static">
          <h3>Sub-Zero Outdoor Refrigerators</h3>
          <p>UC-24RO outdoor undercounter, IT-24CI integrated outdoor drawers, outdoor wine storage. UL-listed weather-rated for Bel Air, Pacific Palisades, Malibu, Newport Coast, and Hidden Hills outdoor kitchens. Coming soon, call for current service.</p>
          <span class="cat-cta">Call {MAIN_PHONE}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ── WHAT SUB-ZERO DOESN'T MAKE ── -->
  <section class="section">
    <div class="container narrow">
      <p class="eyebrow-sub">Scope honesty</p>
      <h2>What Sub-Zero doesn't make, and where to go</h2>
      <p>Sub-Zero is refrigeration-only. Some customers assume the brand covers more because they've seen matching Wolf/Cove appliances in the same kitchen, but each is a separate brand inside the group.</p>
      <ul class="scope-list">
        <li><strong>Ovens and ranges</strong>, Sub-Zero doesn't make them. The matching brand in the Sub-Zero Group is Wolf. See our <a href="/brands/wolf/">Wolf repair page</a> for dual-fuel ranges, wall ovens, and rangetops.</li>
        <li><strong>Dishwashers</strong>, handled by Cove, the third brand in the Sub-Zero Group. See our <a href="/brands/cove/">Cove dishwasher repair page</a>.</li>
        <li><strong>Cooktops</strong>, Wolf territory. Induction, gas, electric, all under the <a href="/brands/wolf-cooktop-repair/">Wolf cooktop page</a>.</li>
        <li><strong>Washers and dryers</strong>, Sub-Zero has never made laundry. For a premium laundry brand to match Sub-Zero/Wolf/Cove kitchens, we service Miele, Bosch, LG, Samsung, Whirlpool, Speed Queen, and Asko.</li>
        <li><strong>Microwaves</strong>, not made by Sub-Zero. Wolf produces drawer and convection microwaves, see the <a href="/brands/wolf-oven-repair/">Wolf oven repair page</a>.</li>
      </ul>
    </div>
  </section>

  <!-- ── SERIES OVERVIEW ── -->
  <section class="section section-alt">
    <div class="container narrow">
      <p class="eyebrow-sub">Understanding the product lines</p>
      <h2>Classic, Designer, Professional, which series is yours?</h2>
      <p>Sub-Zero has three main product lines in current production. Each has a different installation philosophy and a different service approach.</p>
      <p><strong>Classic Series (BI models).</strong> The flagship built-in refrigerators, stainless steel or panel-ready, 30" to 48" widths, built flush into cabinetry with a signature top grille. Most common configurations: BI-36U (over-and-under fridge/freezer), BI-42S (side-by-side), BI-48S (48" side-by-side). Classic refrigerators have dual refrigeration with dedicated compressors in the top compartment, service access through the upper toe-kick and grille, usually without pulling the unit from the cabinet.</p>
      <p><strong>Designer Series (IC / IT / ID models).</strong> Column and drawer refrigeration that integrates fully into custom cabinetry, no visible grille, panel-ready only, no stainless finish option. Columns are dedicated fridge (IC-30R, IC-36R), dedicated freezer (IC-36FI, IC-24FI), or dedicated wine (IW-18, IW-24). Drawer units (ID-24R, ID-30R, ID-36R) sit under counters for prep or beverage stations. Service on Designer columns is more demanding than Classic because there's no top compartment, everything is compact and accessed through side or toe-kick panels.</p>
      <p><strong>Professional Series (PRO 48, PRO 3650, PRO 4850).</strong> Stainless-only, 48" pro-style refrigerators with a commercial aesthetic. Dual compressors, integrated water filtration, often specified alongside a Wolf Pro range for a matched kitchen. The PRO 48 (648PRO) is the flagship, $19,000+ installed, 20-year expected life, commonly seen in serious cooking kitchens across Brentwood, Beverly Hills, Newport Coast, Westlake Village, and Temecula wine-country estates. PRO Series service requires specialized training on the commercial-grade compressor systems.</p>
      <p>Two older product lines also worth mentioning: <strong>Classic New (CL Series)</strong>, introduced around 2019 to replace some BI models, uses new inverter compressor technology and updated controls; and <strong>Undercounter (UC Series)</strong>, small beverage fridges, drawer fridges, and ice makers for kitchen islands and outdoor bars.</p>
    </div>
  </section>

  <!-- ── SERVICE AREAS ── -->
  <section class="section">
    <div class="container">
      <p class="eyebrow-sub">Where we work</p>
      <h2>Sub-Zero service across Southern California</h2>
      <p>Eight service territories cover all five counties, Los Angeles, Orange, Ventura, San Bernardino, and Riverside. Sub-Zero concentration is highest in Bel Air, Beverly Hills, Holmby Hills, Brentwood, Malibu, and Pacific Palisades on LA's Westside; Newport Coast, Pelican Hill, and Shady Canyon in OC; Westlake Village, Hidden Hills, and Calabasas in the Conejo Valley and SGV foothills; and the Temecula wine-country and Rancho Cucamonga estate corridors in the Inland Empire. These districts get same-day priority routing, for a warm Sub-Zero with $2,000+ of food at risk, we push routing regardless of time of day.</p>
      <BrandBranchesGrid showHeader={false} />
    </div>
  </section>

  <!-- ── CREDENTIALS ── -->
  <section class="section section-alt">
    <div class="container narrow">
      <p class="eyebrow-sub">Credentials</p>
      <h2>Licensed, insured, EPA-certified</h2>
      <p>We hold an active  license, covering HVAC scope work. Sub-Zero service requires EPA 608 refrigerant handling certification for sealed-system work; all our technicians are EPA 608 Universal certified (#1346255700410) plus BHGS #A49573. We carry general liability and workers' comp. Every technician is background-checked and BHGS-registered under <strong>#A49573</strong>. BBB A+ since 2022.</p>
      <p>See the <a href="/credentials/">full credentials page</a> for license verification links.</p>
    </div>
  </section>

  <!-- ── FAQ ── -->
  <section class="section">
    <div class="container narrow">
      <p class="eyebrow-sub">FAQ</p>
      <h2>Sub-Zero service questions</h2>

      <details class="faq">
        <summary>Are you Sub-Zero Factory-Certified?</summary>
        <p>No, factory-trained but independent. Factory-Certified Service Network in LA is Roadrunner, Sub-Zero Metro LA, and others on the Sub-Zero dispatch list. Inside the 2-year parts warranty or 12-year compressor warranty, call Sub-Zero at 1-800-222-7820, Factory-Certified dispatches at no parts cost. We're the post-warranty specialist: faster response, lower labor rate, same training.</p>
      </details>

      <details class="faq">
        <summary>Does Sub-Zero make cooking or dishwashers?</summary>
        <p>No. Sub-Zero is refrigeration-only. Cooking is handled by Wolf, dishwashers by Cove, both separate brands in the Sub-Zero Group. We service all three in integrated kitchens. Sub-Zero never made laundry; for matching premium laundry we service Miele and Bosch.</p>
      </details>

      <details class="faq">
        <summary>Is it worth repairing a 15-year-old Sub-Zero?</summary>
        <p>Usually yes. Sub-Zero units are engineered for 20+ years. Most common repairs ($300–$1,200) are far cheaper than replacement ($12,000–$19,000 installed). Even sealed-system compressor replacement at $1,850–$2,800 is better math than buying new. Exception: 20+ year units with cascading failures, sometimes replacement wins. We give honest assessments.</p>
      </details>

      <details class="faq">
        <summary>How fast can you come out for a warm Sub-Zero?</summary>
        <p>Priority dispatch, same-day regardless of hour for a warm column or built-in. A $12,000+ fridge full of food is not something to schedule for Tuesday. Call and tell us it's warming; we rearrange routing. Same-day priority across Southern California, Westside LA, Newport Coast OC, Westlake Village Ventura, Rancho Cucamonga Inland Empire, usually under four hours from call to arrival.</p>
      </details>

      <details class="faq">
        <summary>Do you stock Sub-Zero parts?</summary>
        <p>Common wear parts on the truck, compressor start relays, overload protectors, evaporator and condenser fan motors, door gaskets, ice maker modules, water inlet valves, defrost thermostats. Less common (Professional Series boards, CL inverters, wine column humidity sensors) come next-day from Sub-Zero distribution. Lead times quoted upfront.</p>
      </details>

      <details class="faq">
        <summary>How much does Sub-Zero repair cost?</summary>
        <p>Diagnostic $89, waived with repair. Common jobs: start relay $85–$145, evaporator fan $320–$460, door gasket $385–$540, ice maker module $320–$450, control board $680–$980, sealed-system compressor $1,850–$2,800. See individual service pages (refrigerator, wine cooler, ice maker) for detailed pricing.</p>
      </details>
    </div>
  </section>
  <!-- ── ALL CATEGORY LINKS (Wave 40b — pillar-to-category cross-links) ── -->
  <section class="section section-light">
    <div class="container narrow">
      <p class="eyebrow-sub">Every Sub-Zero category we cover</p>
      <h2>All Sub-Zero repair services in one place</h2>
      <ul class="cat-list">
        <li><a href="/brands/sub-zero-built-in-refrigerator-repair/">Sub-Zero Built In Refrigerator Repair</a></li>
        <li><a href="/brands/sub-zero-ice-maker-repair/">Sub-Zero Ice Maker Repair</a></li>
        <li><a href="/brands/sub-zero-outdoor-refrigerator-repair/">Sub-Zero Outdoor Refrigerator Repair</a></li>
        <li><a href="/brands/sub-zero-refrigerator-repair/">Sub-Zero Refrigerator Repair</a></li>
        <li><a href="/brands/sub-zero-wine-cooler-repair/">Sub-Zero Wine Cooler Repair</a></li>
      </ul>
    </div>
  </section>



  <!-- ── BOTTOM CTA ── -->
  <section class="bottom-cta">
    <div class="container">
      <h2>Ready to schedule Sub-Zero service?</h2>
      <p>Same day available. $89 diagnostic, waived with repair. Labor and parts quoted before we start.</p>
      <div class="hero-ctas">
        <a href={`tel:${MAIN_PHONE_TEL}`} class="btn-primary">☎ Call {MAIN_PHONE}</a>
        <a href="/contact/" class="btn-outline">Book Online</a>
      </div>
    </div>
  </section>

<style>
  :root {
    --red: #C8102E;
    --black: #0a0a0a;
    --gray: #f5f5f5;
    --border: #e2e2e2;
    --text: #1a1a1a;
    --muted: #6b6b6b;
    --white: #ffffff;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; color: var(--text); line-height: 1.6; }

  .hero { background: var(--black); color: #fff; padding: 80px 24px 72px; }
  .hero-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; max-width: 1100px; margin: 0 auto; align-items: center; }
  .hero-eyebrow { font-size: 13px; color: var(--red); text-transform: uppercase; letter-spacing: .12em; margin-bottom: 16px; font-weight: 600; }
  .hero h1 { font-size: clamp(28px, 4vw, 46px); font-weight: 700; color: #fff; margin-bottom: 20px; line-height: 1.15; font-family: 'Playfair Display', Georgia, serif; }
  .hero-sub { font-size: 17px; color: rgba(255,255,255,.72); margin-bottom: 28px; }
  .hero-ctas { display: flex; gap: 12px; margin-bottom: 28px; flex-wrap: wrap; }
  .btn-primary { display: inline-block; padding: 14px 28px; background: var(--red); color: #fff; text-decoration: none; border-radius: 6px; font-weight: 600; font-size: 16px; transition: background .2s; }
  .btn-primary:hover { background: #a50d25; }
  .btn-outline { display: inline-block; padding: 14px 28px; border: 1.5px solid rgba(255,255,255,.35); color: #fff; text-decoration: none; border-radius: 6px; font-weight: 600; font-size: 16px; transition: all .2s; }
  .btn-outline:hover { background: rgba(255,255,255,.08); border-color: #fff; }
  .hero-img-wrap { aspect-ratio: 4/3; background: #1a1a1a; border-radius: 4px; display: flex; align-items: center; justify-content: center; }
  .hero-img-placeholder { color: rgba(255,255,255,.35); font-size: 14px; text-align: center; }
  @media (max-width: 768px) { .hero-inner { grid-template-columns: 1fr; } .hero-img-wrap { display: none; } }

  .trust-bar { background: var(--red); color: #fff; padding: 16px 24px; }
  .trust-bar-inner { max-width: 1100px; margin: 0 auto; display: flex; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
  .trust-item { font-size: 13px; font-weight: 600; display: flex; align-items: center; gap: 8px; }
  .trust-icon { font-size: 16px; }

  .section { padding: 72px 24px; }
  .section-alt { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; }
  .container.narrow { max-width: 780px; }
  .eyebrow-sub { font-size: 13px; color: var(--red); text-transform: uppercase; letter-spacing: .12em; margin-bottom: 12px; font-weight: 600; }
  h2 { font-size: clamp(24px, 3vw, 34px); font-weight: 700; margin-bottom: 20px; line-height: 1.2; font-family: 'Playfair Display', Georgia, serif; }
  .section p { margin-bottom: 16px; color: var(--text); }

  .cat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; margin-top: 32px; }
  .cat-card { display: block; padding: 28px; background: #fff; border: 1px solid var(--border); border-radius: 8px; text-decoration: none; color: inherit; transition: all .2s; }
  .cat-card:hover { border-color: var(--red); transform: translateY(-2px); box-shadow: 0 4px 16px rgba(0,0,0,.08); }
  .cat-card h3 { font-size: 18px; font-weight: 700; margin-bottom: 10px; color: var(--black); font-family: 'Playfair Display', Georgia, serif; }
  .cat-card p { font-size: 14px; color: var(--muted); margin-bottom: 16px; }
  .cat-cta { font-size: 13px; color: var(--red); font-weight: 600; }

  .scope-list { margin: 20px 0; padding-left: 20px; }
  .scope-list li { margin-bottom: 12px; color: var(--text); }
  .scope-list a { color: var(--red); text-decoration: underline; }

  .faq { margin-bottom: 12px; border: 1px solid var(--border); border-radius: 6px; padding: 16px 20px; background: #fff; }
  .faq summary { font-weight: 600; cursor: pointer; font-size: 16px; color: var(--black); }
  .faq[open] summary { margin-bottom: 12px; }
  .faq p { font-size: 15px; color: var(--text); margin-bottom: 0; }

  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { color: #fff; }
  .bottom-cta p { color: rgba(255,255,255,.72); margin-bottom: 24px; }
  .bottom-cta .hero-ctas { justify-content: center; }
</style>
</Layout>
