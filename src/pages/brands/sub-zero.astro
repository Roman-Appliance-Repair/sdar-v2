---
import Layout from '../../layouts/Layout.astro';
import BrandHubPlaceholder from '../../components/BrandHubPlaceholder.astro';

const title = "Sub-Zero Appliance Repair Los Angeles | Same Day Service";
const description = "Expert Sub-Zero appliance repair across LA, Orange, Ventura counties. All Sub-Zero categories — refrigerator, wine cooler, ice maker. Call (424) 325-0520.";

const categories = [
  { label: "Refrigerator", url: "/brands/sub-zero-refrigerator-repair/" },
  { label: "Wine Cooler", url: "/brands/sub-zero-wine-cooler-repair/" },
  { label: "Ice Maker", url: "/brands/sub-zero-ice-maker-repair/" }
];
---

<Layout title={title} description={description}>
  <BrandHubPlaceholder brandName="Sub-Zero" brandSlug="sub-zero" categories={categories} />
</Layout>
