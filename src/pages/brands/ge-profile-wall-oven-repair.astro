      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ], "description": "GE Profile wall oven repair across LA — 30\" single + double built-in, True European Convection third-element system, SmartHQ Wi-Fi, Air Fry mode. Premium feature-focused tier within Haier-owned GE Appliances. $89 residential diagnostic waived with repair.", "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, waived with repair" } } },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [ { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" }, { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" }, { "@type": "ListItem", "position": 3, "name": "GE Profile", "item": "https://samedayappliance.repair/brands/ge-profile/" }, { "@type": "ListItem", "position": 4, "name": "GE Profile Wall Oven Repair", "item": canonical } ] }
];
