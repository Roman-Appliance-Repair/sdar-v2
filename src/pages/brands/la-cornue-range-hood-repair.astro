---
import Layout from '../../layouts/Layout.astro';
import BrandBranchesGrid from '../../components/BrandBranchesGrid.astro';
import { MAIN_PHONE, MAIN_PHONE_TEL } from '../../data/branches';

const title = "La Cornue Range Hood Repair Los Angeles — Same Day";
const description = "La Cornue range hood repair across SoCal, Château + CornuFé handbuilt French luxury. Saint-Ouen-l'Aumône factory + Middleby US parts. $89 dx.";
const canonical = "https://samedayappliance.repair/brands/la-cornue-range-hood-repair/";

const faqs = [
  {
    q: "La Cornue, French factory, US parts, and lead times?",
    a: "La Cornue has handbuilt French luxury ranges at <b>Saint-Ouen-l'Aumône outside Paris since 1908</b>, founded by Albert Dupuy. In 2017 the company was acquired by Middleby Corporation, which joined La Cornue to the same US parts and service network that serves Viking (Middleby Greenwood MS 1987) and AGA (Middleby 2015+). For LA service: common motor + control + lighting parts 2-3 week via Middleby US depot; specialty trim + enamel + brass/nickel/chrome-accent parts direct from Saint-Ouen-l'Aumône at 3-5 week typical lead. La Cornue carries 33 standard factory colors plus a fully bespoke color program, custom color means custom lead time."
  },
  {
    q: "What La Cornue range hood configurations show up in LA?",
    a: "<b>Château Hood</b> matched to the Château range (La Cornue's flagship handbuilt product, 75cm/90cm/120cm/150cm widths, brass/chrome/nickel accent options, 33 factory colors plus bespoke) + <b>CornuFé Hood</b> matched to the CornuFé range (the more accessible La Cornue line built in Albi, France, 90cm / 110cm). Château hoods are the ultra-premium handbuilt product line; CornuFé is the series-produced line. Both pair to the range aesthetic as a matched suite. 600-1200 CFM; halogen or LED lighting."
  },
  {
    q: "La Cornue hood service diagnostic, common failures?",
    a: "Standard La Cornue hood diagnostic: (1) variable-speed motor at 10-12 year mark; motor swap $380–$560 (French factory motor premium); (2) control-switch assembly $420–$620; (3) halogen transformer or LED driver $220–$340; (4) grease-filter latch $180–$260; (5) brass/chrome/nickel accent trim damage, 3-5 week Saint-Ouen-l'Aumône factory match quote $500–$1200+ depending on metal accent + color; (6) handbuilt Château-specific parts (serial-number-matched) 3-5 week factory order. CornuFé Albi-built parts share some common components with other Middleby brands, faster 2-3 week on common items."
  },
  {
    q: "What does La Cornue range hood repair cost in LA?",
    a: "Residential diagnostic $89 waived with repair. Typical La Cornue bands: motor $380–$560; control-switch $420–$620; halogen/LED $220–$340; grease-filter latch $180–$260; brass/chrome accent trim quoted individually 3-5 week lead. Ultra-premium handbuilt French tier; La Cornue service economics sit at the very top of European luxury alongside Gaggenau + custom Molteni; typically $1,000+ total repair for anything beyond basic service, and matched-color Château parts can exceed that substantially. Appropriate for a $30k+ range investment."
  },
  {
    q: "La Cornue Château vs CornuFé, which do I have?",
    a: "<b>Château</b> = La Cornue flagship, handbuilt at Saint-Ouen-l'Aumône, serial-number matched, 75-150cm widths, bespoke color program, typically $30,000+ installed, this is the halo La Cornue product. <b>CornuFé</b> = series-produced at the Albi France factory (La Cornue bought Les Rosieres heritage), 90cm/110cm widths, 6-8 standard colors, typically $12,000-$20,000 installed, the more accessible La Cornue. Hood parts differ, Château is handbuilt-specific, CornuFé shares more with broader Middleby parts chain. Tell us which range you have when you call so we order correctly."
  }
];

const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair, La Cornue Range Hood Service",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": canonical, "telephone": MAIN_PHONE_TEL, "priceRange": "$$$$"
  },
  { "@context": "https://schema.org", "@type": "Service", "serviceType": "La Cornue Range Hood Repair",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "description": "La Cornue range hood repair across LA, Château handbuilt + CornuFé matched hoods. Saint-Ouen-l'Aumône France since 1908 Albert Dupuy + Middleby 2017+ parent. Middleby US parts + French factory specialty. $89 residential diagnostic waived with repair.",
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, waived with repair" } }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "La Cornue", "item": "https://samedayappliance.repair/brands/la-cornue/" },
      { "@type": "ListItem", "position": 4, "name": "La Cornue Range Hood Repair", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">{schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}</Fragment>
  <div class="call-banner"><div class="wrap"><span>La Cornue range hood service?</span><a href={`tel:${MAIN_PHONE_TEL}`} class="phone-lg">{MAIN_PHONE}</a></div></div>

  <section class="hero"><div class="wrap">
    <div class="crumb"><a href="/">Home</a> › <a href="/brands/">Brands</a> › La Cornue › Range Hood Repair</div>
    <h1>La Cornue Range Hood Repair</h1>
    <p class="lede">La Cornue has handbuilt French luxury ranges at Saint-Ouen-l'Aumône outside Paris since 1908, founded by Albert Dupuy. The Château flagship pairs with a matched Château hood in 33 factory colors plus a bespoke color program and brass, chrome, or nickel accent trim; the more accessible CornuFé range pairs with its own matched hood built at the Albi, France factory. Middleby Corporation's 2017 acquisition joined La Cornue to the same US service parts network that supports Viking and AGA. In LA we see these in Bel Air, Beverly Hills, and Malibu handbuilt kitchens where the French range is the centerpiece. Same-day dispatch, $89 residential diagnostic waived with the repair.</p>
    <div class="hero-cta"><a href={`tel:${MAIN_PHONE_TEL}`} class="btn btn-primary">Call {MAIN_PHONE}</a><a href="#book" class="btn btn-ghost">Request a Visit</a></div>
    <ul class="hero-facts">
      <li><b>Saint-Ouen-l'Aumône France since 1908</b>, Albert Dupuy handbuilt heritage</li>
      <li><b>Château handbuilt + CornuFé series hoods</b>, 33 factory colors + bespoke</li>
      <li><b>Middleby US parts + French factory specialty</b>, 2-5 week typical lead</li>
      <li><b>$89 residential diagnostic</b>, waived when you authorize the repair</li>
    </ul>
  </div></section>

  <BrandBranchesGrid />

  <section class="trust-bar"><div class="wrap"><span>BHGS #A49573 · Insured</span><span>Same-day in 5 SoCal counties</span><span>Residential diagnostic $89 · waived with repair</span></div></section>

  <section class="section"><div class="wrap">
    <h2>What La Cornue range hood repair costs in LA</h2>
    <table class="price-table">
      <tr><th>Service</th><th>Typical Range</th><th>Notes</th></tr>
      <tr><td>Residential diagnostic</td><td>$89</td><td>Waived with repair</td></tr>
      <tr><td>Variable-speed motor</td><td>$380 – $560</td><td>10-12 year service</td></tr>
      <tr><td>Control-switch assembly</td><td>$420 – $620</td><td>French factory control</td></tr>
      <tr><td>Halogen transformer / LED driver</td><td>$220 – $340</td><td>Task lighting</td></tr>
      <tr><td>Grease-filter latch</td><td>$180 – $260</td><td>Interlock trigger</td></tr>
      <tr><td>Brass / chrome / nickel accent trim</td><td>Quoted</td><td>3-5 week Saint-Ouen-l'Aumône</td></tr>
    </table>
    <p class="small">Related: <a href="/brands/la-cornue/">La Cornue brand hub</a> · <a href="/brands/la-cornue-stove-repair/">La Cornue Château / CornuFé range</a> · <a href="/brands/aga-range-hood-repair/">AGA range hood (British peer, also Middleby)</a> · <a href="/brands/gaggenau-range-hood-repair/">Gaggenau range hood (German ultra-luxury peer)</a> · <a href="/services/range-hood-repair/">Range hood repair (service hub)</a> · <a href="/commercial/exhaust-hood-repair/">Commercial exhaust hood repair</a>. For commercial kitchen exhaust hood repair (restaurant/foodservice Captive-Aire, Halton scope), see our <a href="/commercial/exhaust-hood-repair/">commercial page</a>.</p>
  </div></section>

  <section class="section alt"><div class="wrap narrow">
    <h2>La Cornue range hood repair, frequently asked</h2>
    {faqs.map(f => (<details class="faq"><summary>{f.q}</summary><p set:html={f.a}></p></details>))}
  </div></section>

  <section id="book" class="cta-bottom"><div class="wrap">
    <h2>La Cornue range hood service? Call the branch closest to your home.</h2>
    <p>Same-day appliance repair in Los Angeles, Orange County, Ventura County. Residential diagnostic $89, waived with repair.</p>
  </div></section>
  <a href={`tel:${MAIN_PHONE_TEL}`} class="float-call" aria-label="Call now">☎ Call {MAIN_PHONE}</a>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  body { color: var(--text); } .wrap { max-width: 1200px; margin: 0 auto; padding: 0 24px; } .wrap.narrow { max-width: 820px; }
  h1 { font-size: 2.4rem; line-height: 1.15; margin: 12px 0 20px; color: var(--black); }
  h2 { font-size: 1.8rem; margin: 0 0 16px; color: var(--black); }
  p { line-height: 1.65; margin: 0 0 14px; }
  .call-banner { background: var(--red); color: #fff; padding: 10px 0; }
  .call-banner .wrap { display:flex; gap: 14px; align-items: center; justify-content: center; flex-wrap: wrap; }
  .call-banner .phone-lg { color:#fff; font-weight: 800; text-decoration: underline; font-size: 1.05rem; }
  .hero { background: var(--black); color: #fff; padding: 42px 0 56px; } .hero h1 { color: #fff; }
  .hero .lede { font-size: 1.06rem; color: #d7d7d7; max-width: 680px; }
  .hero .crumb { color: #9a9a9a; font-size: 0.85rem; margin-bottom: 6px; } .hero .crumb a { color: #c9c9c9; text-decoration: none; }
  .hero-cta { display: flex; gap: 12px; flex-wrap: wrap; margin: 18px 0 24px; }
  .btn { display: inline-block; padding: 12px 20px; border-radius: 4px; text-decoration: none; font-weight: 700; }
  .btn-primary { background: var(--red); color: #fff; } .btn-ghost { background: transparent; color: #fff; border: 1px solid #fff; }
  .hero-facts { list-style: none; padding: 0; margin: 0; color: #c9c9c9; font-size: 0.95rem; }
  .hero-facts li { padding: 6px 0; border-top: 1px solid #222; } .hero-facts li:first-child { border-top: 0; }
  .trust-bar { background: var(--red); color: #fff; padding: 14px 0; }
  .trust-bar .wrap { display: flex; gap: 28px; flex-wrap: wrap; justify-content: center; font-size: 0.95rem; font-weight: 600; }
  .section { padding: 56px 0; } .section.alt { background: var(--gray); }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 14px; background: #fff; }
  .price-table th, .price-table td { text-align: left; padding: 11px 12px; border-bottom: 1px solid var(--border); }
  .price-table th { background: var(--black); color: #fff; font-weight: 700; font-size: 0.95rem; }
  .small { color: var(--muted); font-size: 0.92rem; margin-top: 12px; }
  .faq { background: #fff; border: 1px solid var(--border); padding: 12px 16px; margin-bottom: 8px; border-radius: 4px; }
  .faq summary { font-weight: 700; cursor: pointer; padding: 4px 0; } .faq p { margin: 8px 0 0; }
  .cta-bottom { background: var(--black); color: #fff; padding: 48px 0; } .cta-bottom h2 { color: #fff; } .cta-bottom p { color: #c9c9c9; }
  .float-call { position: fixed; bottom: 18px; right: 18px; background: var(--red); color: #fff; padding: 14px 18px; border-radius: 40px; text-decoration: none; font-weight: 700; box-shadow: 0 6px 18px rgba(0,0,0,0.28); z-index: 50; font-size: 0.95rem; }
  @media (max-width: 820px) { h1 { font-size: 1.9rem; } .float-call { padding: 11px 14px; font-size: 0.88rem; } .trust-bar .wrap { gap: 14px; font-size: 0.85rem; } }
</style>
