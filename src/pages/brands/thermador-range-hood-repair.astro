---
import Layout from '../../layouts/Layout.astro';

const title = "Thermador Range Hood Repair | Southern California | HMWB + Home Connect";
const description = "Thermador range hood repair across Southern California — HMWB Masterpiece + HMIB island + HDDB downdraft + HPWB Professional. BSH Irvine parts 1-2 day. Home Connect WiFi. $89 diagnostic.";
const canonical = "https://samedayappliance.repair/brands/thermador-range-hood-repair/";

const faqs = [
  {
    q: "What Thermador range hood models are most common in LA?",
    a: "<b>HMWB Masterpiece wall hood</b> 30-48 inch matched to Thermador Pro Grand rangetop dominates LA Thermador installs. <b>HMIB Masterpiece island</b> for open-plan kitchens. <b>HDDB downdraft</b> + <b>HPWB Professional</b> cover alternate architectures. <b>HPIS custom liner</b> for built-in integration. 600-1200 CFM tier; halogen + LED lighting; Home Connect WiFi flagship. BSH Home Appliances trio (Bosch/Siemens/Thermador) shares platform engineering — entry-Thermador HPWB often shares platform with Bosch premium hood."
  },
  {
    q: "Thermador range hood motor or Home Connect issue — diagnostic?",
    a: "Standard BSH diagnostic: (1) variable-speed motor at 8-12 year mark; motor swap $320–$480; (2) control-board + Home Connect WiFi module $460–$660 + $280–$420; (3) halogen transformer $180–$280 / LED driver $180–$280; (4) grease-filter latch $120–$200; (5) downdraft motor-lift mechanism on HDDB $380–$560; (6) firmware update via Home Connect app — often resolves communication-fault issues without hardware. BSH Irvine CA parts warehouse 1-2 day LA-local advantage on common HMWB service components."
  },
  {
    q: "Home Connect app not working — is the hood broken?",
    a: "Home Connect is BSH's smart-appliance ecosystem (Thermador + Bosch + Siemens). App connection issues are typically not hardware faults: (1) 2.4GHz WiFi required (5GHz-only routers block); (2) app account re-pair; (3) firmware update via app; (4) WiFi module hardware $280–$420 only when confirmed failed. Conventional hood operation (motor + lighting + filter) works independently of Home Connect — WiFi layer is additive, not a dependency."
  },
  {
    q: "Thermador hood vs Wolf vs Viking in LA luxury kitchens?",
    a: "<b>Thermador (this page)</b> — BSH Irvine CA parts 1-2 day LA-local + Home Connect WiFi integration. HMWB Masterpiece matched to Thermador Pro Grand. <b>Wolf</b> — Sub-Zero Group Madison WI coordinated suite. See <a href='/brands/wolf-range-hood-repair/'>Wolf range hood repair</a>. <b>Viking</b> — Middleby Greenwood MS heritage + Tuscany crossover. See <a href='/brands/viking-range-hood-repair/'>Viking range hood repair</a>. Choice drivers: Thermador for BSH + Irvine parts + Home Connect; Wolf for coordinated Sub-Zero Group suite; Viking for Middleby heritage."
  },
  {
    q: "Thermador hood vs commercial exhaust hood?",
    a: "Thermador is residential-only — BSH has no commercial line. For commercial restaurant / foodservice exhaust (Captive-Aire / Halton / Greenheck / Gaylord 2000+ CFM grease-duct scope), see <a href='/commercial/exhaust-hood-repair/'>commercial exhaust hood repair</a>."
  },
  {
    q: "What does Thermador range hood repair cost in LA?",
    a: "Residential diagnostic $89 waived with repair. Typical HMWB + HPWB + HDDB bands: variable-speed motor $320–$480; control-board $460–$660; Home Connect WiFi module $280–$420; halogen transformer $180–$280 / LED driver $180–$280; baffle-filter latch $120–$200; downdraft motor-lift (HDDB) $380–$560; external-blower wiring $220–$340; light fixture $180–$280. BSH Irvine 1-2 day parts advantage reduces service window vs most luxury brands."
  }
];

const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair — Thermador Range Hood Service",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": canonical, "telephone": "+1-424-325-0520", "priceRange": "$$$$"
  },
  { "@context": "https://schema.org", "@type": "Service", "serviceType": "Thermador Range Hood Repair",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "description": "Thermador range hood repair across LA — HMWB Masterpiece wall + HMIB island + HDDB downdraft + HPWB Professional. BSH Irvine CA parts warehouse 1-2 day LA-local + Home Connect WiFi. $89 residential diagnostic waived with repair.",
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "89.00", "priceCurrency": "USD", "description": "Residential diagnostic fee, waived with repair" } }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "Thermador", "item": "https://samedayappliance.repair/brands/thermador/" },
      { "@type": "ListItem", "position": 4, "name": "Thermador Range Hood Repair", "item": canonical }
    ]
  }
];
