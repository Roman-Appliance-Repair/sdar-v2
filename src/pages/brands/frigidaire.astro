---
import Layout from '../../layouts/Layout.astro';
import BrandHubPlaceholder from '../../components/BrandHubPlaceholder.astro';

const title = "Frigidaire Appliance Repair | Southern California | Same Day Service";
const description = "Expert Frigidaire appliance repair across Southern California, Orange, Ventura counties. All Frigidaire categories — refrigerator, freezer, dishwasher, range, washer, dryer, microwave. Call (424) 325-0520.";

const categories = [
  { label: "Refrigerator", url: "/brands/frigidaire-refrigerator-repair/" },
  { label: "Freezer", url: "/brands/frigidaire-freezer-repair/" },
  { label: "Dishwasher", url: "/brands/frigidaire-dishwasher-repair/" },
  { label: "Range", url: "/brands/frigidaire-range-repair/" },
  { label: "Washer", url: "/brands/frigidaire-washer-repair/" },
  { label: "Dryer", url: "/brands/frigidaire-dryer-repair/" },
  { label: "Microwave", url: "/brands/frigidaire-microwave-repair/" }
];
---

<Layout title={title} description={description}>
  <BrandHubPlaceholder brandName="Frigidaire" brandSlug="frigidaire" categories={categories} />
</Layout>
