      <tr><td>Main heating element</td><td>$300 – $460</td><td>Main wash cycle</td></tr>
      <tr><td>TrueSteam generator element</td><td>$320 – $480</td><td>Separate from main element</td></tr>
      <tr><td>TrueSteam descaling</td><td>$280 – $420</td><td>LA hard-water</td></tr>
