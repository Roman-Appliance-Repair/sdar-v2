import { MAIN_PHONE, MAIN_PHONE_TEL } from '../../data/branches';

const title = "Miele Dryer Repair | Southern California | T1 Heat-Pump 120V Ventless, F50/F55/F66 Error Codes";
const description = "Miele T1 heat-pump dryer repair across Southern California. 120V ventless condenser dryers, EcoDry heat pump, PerfectDry moisture sensors, FragranceDos. F50/F55/F66/F105 error diagnostics, plinth filter, heat exchanger, NTC sensor service. Factory-trained. $89 diagnostic waived with repair. Call (424) 325-0520.";

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": "https://samedayappliance.repair/brands/miele-dryer-repair/#business",
    "name": "Same Day Appliance Repair, Miele Dryer Service",
    "image": "https://samedayappliance.repair/images/same-day-appliance-repair.png",
    "url": "https://samedayappliance.repair/brands/miele-dryer-repair/",
    "telephone": MAIN_PHONE_TEL,
    "priceRange": "$$$$"
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "serviceType": "Miele Dryer Repair",
    "provider": { "@type": "LocalBusiness", "name": "Same Day Appliance Repair" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "offers": {
      "@type": "Offer",
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "89.00",
        "priceCurrency": "USD",
        "description": "Diagnostic fee, waived with repair"
      }
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How does a Miele T1 heat-pump dryer work without a vent?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The T1 runs a closed-loop refrigerant system inside the dryer cabinet, same principle as a heat-pump HVAC unit, miniaturized. Hot air from the drum passes through an evaporator coil where moisture condenses out, then reheats through the condenser coil before returning to the drum. Moisture collects in an internal condensate tank (empties automatically via a small internal pump to a drain line) or a manually-emptied reservoir on some models. No exterior venting needed, which is the key reason T1 fits condos and apartments that don't have 240V outlets or dedicated dryer vents. Electrical requirement is a standard 120V 15-amp outlet. Drying cycles run longer than conventional vented dryers (90-120 minutes for a normal load vs. 40-60) because heat-pump drying runs at lower temperatures that are gentler on fabric."
        }
      },
      {
        "@type": "Question",
        "name": "My T1 shows F55, clothes still damp after 180 minutes",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "F55 fires when the machine reaches maximum drying time without achieving the target moisture threshold. Six common causes in diagnostic order: (1) plinth filter sponge clogged with lint, most frequent, free cleanup with warm water wash and dry cycle; (2) fine mesh lint filter in door opening clogged, same free cleanup; (3) heat exchanger fins dust-caked, vacuum access from plinth compartment; (4) condenser intake at top of unit obstructed by closet shelving or installation clearance; (5) PerfectDry moisture sensor (NTC) drifted and reading higher moisture than actual; (6) drum overloaded beyond capacity at cycle start. About 80% of F55 calls resolve at the cleaning stage with no parts. If cleaning doesn't fix it, we test moisture sensors ($145-$215) and check heat-pump refrigerant circuit. Full heat-pump assembly replacement is $840-$1,250 and rarely needed."
        }
      },
      {
        "@type": "Question",
        "name": "F66 or F066, what does it mean?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "F66 is a ventilation fault, insufficient airflow through the dryer's internal heat-exchange circuit. Not a vent in the traditional sense (T1 doesn't have external venting), but a cooling-airflow fault. Causes: condenser intake grille at the TOP of the unit blocked by a shelf, cabinet, or stacked laundry (T1 breathes cooling air from the top, not the back, installation clearance is often overlooked); plinth filter clogged; heat exchanger fins impacted; laundry space itself is too small for the cooling air to dissipate heat back into. Fix: clear top ventilation clearance (Miele specifies 4 inches minimum above unit), clean plinth filter, check heat exchanger. No parts typically needed for F66."
        }
      },
      {
        "@type": "Question",
        "name": "F50, control board fault, what now?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "F50 is a general control board or memory fault. First step: unplug the dryer for 10 minutes (not 30 seconds, needs full capacitor discharge), then restart. 30% of F50 codes resolve with a full power cycle. If the code returns: main control board replacement, typically $640-$920 including install. We verify the board is genuinely failed, sometimes F50 is triggered by a bad NTC sensor feeding garbage values that look like board faults. Power surges from LA grid events can trip F50 too; a quality surge protector ($30-$50) on the dryer circuit prevents recurrence. The 2020-2023 generation T1 boards have been robust, F50 on those units is rare outside a surge event."
        }
      },
      {
        "@type": "Question",
        "name": "F105, heat exchanger or heating element fault",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "F105 points to the heating element or heat exchanger sensor system. Diagnostic: enter service mode via control sequence (we have the codes), read thermistor values against actual drum temperature, visually inspect heat exchanger fins for damage or heavy dust impaction. Common causes: residual moisture sensor degraded (sensor cleanup with isopropyl alcohol, no parts), temperature sensor NTC failed ($145-$215 replacement), heating element in the heat pump circuit has shorted internally (heat-pump assembly $840-$1,250). Sensor-level resolution 70% of the time, heat-pump assembly rare. Power surges correlate with F105 on older units, surge protector recommended post-repair."
        }
      },
      {
        "@type": "Question",
        "name": "How much does Miele T1 dryer repair cost?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Diagnostic is $89, waived with repair. Typical Miele T1 repairs: plinth filter sponge replacement $45 flat, lint filter assembly $95-$145, NTC temperature sensor $145-$215, PerfectDry moisture sensor $165-$225, circulation fan motor $340-$460, condensate pump $285-$385, heat exchanger cleaning service $185 flat, heat-pump assembly (full module) $840-$1,250, door gasket $185-$265, drum drive belt $125-$185, drum bearing set $245-$345, FragranceDos flacon holder $95-$145, main control board $640-$920, user interface $385-$560. Labor and parts quoted before work starts."
        }
      }
    ]
  }
];
