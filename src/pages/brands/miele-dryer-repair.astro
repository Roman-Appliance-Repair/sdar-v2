---
import Layout from '../../layouts/Layout.astro';
import BrandDetailPlaceholder from '../../components/BrandDetailPlaceholder.astro';

const title = "Miele Dryer Repair Los Angeles | Same Day Service";
const description = "Expert Miele dryer repair in Los Angeles. Same-day appointments, OEM parts, licensed technicians. Call (424) 325-0520.";
---

<Layout title={title} description={description}>
  <BrandDetailPlaceholder
    brandName="Miele"
    brandSlug="miele"
    category="Dryer"
    categorySlug="dryer-repair"
    hubUrl="/brands/miele/"
  />
</Layout>
