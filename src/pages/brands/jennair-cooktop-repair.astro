---
// src/pages/brands/jennair-cooktop-repair.astro
// Niche combo — JennAir cooktop repair (~0 GSC impressions; brand-portfolio completion).
// JennAir = Whirlpool Corp luxury brand; signature downdraft, induction (JIC), gas (JGC), electric (JEC).
import Layout from '../../layouts/Layout.astro';
import ServiceHero from '../../components/ServiceHero.astro';
import { MAIN_PHONE } from '../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/brands/jennair-cooktop-repair/";

const title = "JennAir Cooktop Repair — Induction · Gas · Downdraft | Same Day Appliance Repair";
const description = `JennAir cooktop repair across Southern California — induction (JIC4), gas (JGC), electric (JEC), and downdraft systems. Whirlpool Corp luxury brand specialists. $89 diagnostic, applied toward repair. Call ${phone}.`;

const faqs = [
  {
    q: "Do you service the induction cooktops in the JIC4 series?",
    a: "Yes. JennAir's JIC4 induction cooktops use Whirlpool-platform power boards and induction coils that we service routinely. The most common JIC4 calls are F11 and F2 error codes (board communication and pan-detection faults), failed touch-control panels after liquid intrusion, and individual coil failure where one zone stops heating while the others still work. We carry the most-requested touch boards and coil assemblies through Whirlpool/JennAir authorized parts; less common boards are typically 2-3 day lead.",
  },
  {
    q: "My JennAir downdraft cooktop fan isn't pulling air — what's the fix?",
    a: "JennAir's downdraft system is the brand's signature feature and also its most-serviced subsystem. The fan motor itself, the damper assembly that opens when the fan is engaged, and the control board that sequences them all fail in roughly that order. We diagnose by isolating each: pull the grease screen, run the fan with the damper visible, and confirm the airflow path top-to-bottom. About half of 'downdraft not working' calls turn out to be a stuck damper or a clogged duct path rather than the motor — a much cheaper repair than the homeowner expects.",
  },
  {
    q: "How much does JennAir cooktop repair cost?",
    a: `Our diagnostic fee is $89, applied toward the repair when you approve work. Common JennAir cooktop repair ranges: igniter or surface-element replacement $180-$320; touch control board on JIC4 induction $380-$580; downdraft fan motor $420-$680; gas valve assembly $280-$440; full glass-ceramic surface replacement $580-$980 (parts uplift on JennAir glass is real — premium-brand pricing through Whirlpool authorized distribution). We give a written estimate before any work begins. Same-day across our 5-county service area when parts are stocked.`,
  },
];

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": canonical + "#service",
    "serviceType": "JennAir Cooktop Repair",
    "name": "JennAir Cooktop Repair — Same Day Appliance Repair",
    "url": canonical,
    "description": "Same-day JennAir cooktop repair across Los Angeles, Orange, Ventura, San Bernardino, and Riverside counties. Induction (JIC4 series), gas (JGC series), electric (JEC), and signature downdraft systems. Whirlpool Corp luxury platform. Touch control boards, induction coils, downdraft fan motors, gas valves, glass-ceramic surface replacement. $89 residential diagnostic, applied toward repair.",
    "provider": {
      "@type": "LocalBusiness",
      "name": "Same Day Appliance Repair",
      "url": "https://samedayappliance.repair/",
      "telephone": phone,
      "priceRange": "$$$",
    },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" },
    ],
    "offers": {
      "@type": "Offer",
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "89.00",
        "priceCurrency": "USD",
        "description": "Residential diagnostic fee, applied toward repair",
      },
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map((f) => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })),
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "JennAir", "item": "https://samedayappliance.repair/brands/jennair/" },
      { "@type": "ListItem", "position": 4, "name": "JennAir Cooktop Repair", "item": canonical },
    ],
  },
];
---

<Layout title={title} description={description} canonical={canonical}>

<Fragment slot="head-scripts">
  {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
</Fragment>

<ServiceHero
  eyebrow="LA · Orange · Ventura · San Bernardino · Riverside Counties"
  title="JennAir Cooktop Repair — Across Southern California"
  subtitle="Induction (JIC4), gas (JGC), electric (JEC), and signature downdraft systems. Whirlpool Corp luxury platform specialists. $89 diagnostic, applied toward repair. Same day across five SoCal counties."
  heroImageTitle="JennAir Cooktop Repair"
  showBranches={true}
/>

<!-- 01 INTRO -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">01 — About this service</p>
    <h2 class="section-title">JennAir cooktop repair across the full lineup.</h2>

    <p>JennAir has been part of Whirlpool Corporation since 1986, positioned as the corporation's luxury cooktop and built-in appliance line. The cooktop catalog spans induction (JIC4 series with the brand's flush-mount frameless designs), traditional gas (JGC series including the JGC9536 6-burner pro-style), electric radiant (JEC4), and the brand's signature downdraft systems that pull cooking exhaust through an integrated rear vent rather than an overhead hood. We service all four families across our 5-county Southern California territory — Los Angeles, Orange, Ventura, San Bernardino, and Riverside.</p>

    <p>JennAir cooktops sit on Whirlpool platforms, which means parts chains and service procedures are well-documented and parts availability is generally good. The brand-specific service knowledge is in the downdraft assembly (no other major brand uses it as a default) and in the JennAir-specific touch control panels on the induction line. Our techs handle both. <a href="/brands/jennair/">Brand hub</a> covers JennAir refrigeration and ranges; this page is cooktop-specific.</p>
  </div>
</section>

<!-- 02 PROBLEMS -->
<section class="section section-gray">
  <div class="container">
    <p class="section-number">02 — Common failures</p>
    <h2 class="section-title">What we diagnose most often on JennAir cooktops.</h2>

    <div class="problem-grid">
      <div class="problem-card">
        <h3>Induction error codes (F11, F2)</h3>
        <p>F11 is a communication fault between the touch control and the power board; F2 is a pan-detection error that often points to a failed coil sensor rather than a "wrong cookware" issue. We test the coil sensors directly before recommending board replacement — about a third of F2 calls resolve with a sensor swap rather than the more expensive control board.</p>
      </div>
      <div class="problem-card">
        <h3>Touch control panel unresponsive</h3>
        <p>The flush-mount touch glass on JIC4 induction cooktops is sensitive to liquid intrusion at the edge seal. A boil-over that runs across the front edge can short the touch traces, leaving one or more zones unresponsive. Replacement of the glass-and-touch assembly is a single part on most JIC4 models; we confirm the failure mode before quoting because a clean reset sometimes resolves apparent touch failures.</p>
      </div>
      <div class="problem-card">
        <h3>Downdraft fan won't pull or run</h3>
        <p>The downdraft is the most-serviced subsystem on JennAir cooktops. Failure tree, in order: stuck damper assembly (cheapest fix), clogged exhaust duct (no parts cost — cleaning only), failed fan motor, control board sequencing fault. We work through them top-down and quote at each step.</p>
      </div>
      <div class="problem-card">
        <h3>Gas burner won't ignite</h3>
        <p>JGC series igniter failures usually trace to one of three causes: corroded spark electrode, failed ignition switch under the burner knob, or a clogged orifice that produces too lean a mixture for the spark to catch. We carry JennAir igniters and switches for JGC9536, JGC7430, and JGC7530 specifically; less common models are 1-2 day lead through Whirlpool authorized parts.</p>
      </div>
    </div>
  </div>
</section>

<!-- 03 MODELS -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">03 — JennAir cooktop models we service</p>
    <h2 class="section-title">Across induction, gas, electric, and downdraft.</h2>

    <p><strong>Induction (JIC4 series):</strong> JIC4430, JIC4536, JIC4636, JIC4736 — flush-mount frameless designs in 30" and 36" formats. Common service: touch control boards, induction coils, F11/F2 diagnostics.</p>

    <p><strong>Gas (JGC series):</strong> JGC7430, JGC7530, JGC9536 — sealed-burner gas cooktops in 30", 36", and 36" 6-burner pro-style configurations. Common service: igniters, ignition switches, gas valves, surface burner replacement.</p>

    <p><strong>Electric radiant (JEC4 series):</strong> JEC4430, JEC4536 — glass-ceramic radiant cooktops. Common service: surface elements (radiant heating coils), control boards, surface temperature limiters.</p>

    <p><strong>Downdraft:</strong> JED4536 and similar — JennAir's signature downdraft cooktop with integrated rear-vent exhaust. Common service: fan motor, damper assembly, downdraft control board, duct cleaning.</p>

    <p>Older Maytag-era JennAir cooktops (pre-2006 acquisition consolidation) we still service when parts are available; we identify production year from the model and serial tag and confirm parts chain before scheduling.</p>
  </div>
</section>

<!-- 04 PRICING -->
<section class="section section-gray">
  <div class="container">
    <p class="section-number">04 — Pricing</p>
    <h2 class="section-title">JennAir cooktop repair pricing.</h2>

    <p class="lead">Diagnostic is $89, applied toward the repair when you approve work. Written estimate before any parts go on. These ranges reflect typical JennAir cooktop repair pricing through Whirlpool authorized parts distribution.</p>

    <div class="pricing-grid">
      <div class="price-card">
        <div class="price-label">Diagnostic</div>
        <div class="price-amount">$89</div>
        <div class="price-desc">Waived when you approve repair</div>
      </div>
      <div class="price-card">
        <div class="price-label">Igniter / surface element</div>
        <div class="price-amount">$180–$320</div>
        <div class="price-desc">JGC ignition · JEC4 radiant element</div>
      </div>
      <div class="price-card">
        <div class="price-label">Induction touch board</div>
        <div class="price-amount">$380–$580</div>
        <div class="price-desc">JIC4 series control panel + glass</div>
      </div>
      <div class="price-card">
        <div class="price-label">Downdraft fan motor</div>
        <div class="price-amount">$420–$680</div>
        <div class="price-desc">JED series exhaust assembly</div>
      </div>
    </div>

    <p class="price-note">Gas valve replacement $280-$440. Glass-ceramic surface replacement (induction or radiant) $580-$980 — JennAir surface glass carries a real premium-brand parts uplift through Whirlpool authorized distribution. We tell you the brand-specific cost differential before you authorize repair.</p>
  </div>
</section>

<!-- 05 FAQ -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">05 — FAQ</p>
    <h2 class="section-title">JennAir cooktop repair — common questions.</h2>

    <div class="faq-list">
      {faqs.map((f) => (
        <details class="faq-item">
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- 06 BOTTOM CTA -->
<section class="bottom-cta">
  <div class="container">
    <h2>JennAir cooktop down? Same-day service across Southern California.</h2>
    <p>$89 diagnostic, applied toward the repair. Induction, gas, electric, and downdraft — Whirlpool Corp luxury platform service across all five SoCal counties.</p>
    <div class="cta-row">
      <a href={phoneHref} class="btn-primary">☎ Call {phone}</a>
      <a href="/contact/" class="btn-secondary">Book Online</a>
    </div>
  </div>
</section>

</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .section { padding: 72px 24px; }
  .section-gray { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; }
  .container.narrow { max-width: 820px; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  h2.section-title { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; margin: 0 0 20px; line-height: 1.2; color: var(--text); }
  .lead { font-size: 1.05rem; line-height: 1.75; color: var(--text); margin-bottom: 20px; }
  .section p { margin: 0 0 18px; font-size: 1rem; line-height: 1.75; color: var(--text); }
  .section a { color: var(--red); font-weight: 600; text-decoration: none; }
  .section a:hover { text-decoration: underline; }

  .problem-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-top: 32px; }
  .problem-card { background: #fff; border: 1px solid var(--border); border-left: 4px solid var(--red); border-radius: 6px; padding: 26px 28px; }
  .problem-card h3 { font-size: 1.1rem; font-weight: 800; margin: 0 0 12px; color: var(--text); }
  .problem-card p { font-size: 0.95rem; color: var(--text); margin: 0; line-height: 1.7; }
  @media (max-width: 768px) { .problem-grid { grid-template-columns: 1fr; } }

  .pricing-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-top: 32px; }
  .price-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 26px 22px; text-align: center; }
  .price-card .price-label { font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--muted); margin-bottom: 10px; font-weight: 700; }
  .price-card .price-amount { font-size: 1.85rem; font-weight: 800; color: var(--text); line-height: 1; margin-bottom: 10px; }
  .price-card .price-desc { font-size: 0.85rem; color: var(--muted); line-height: 1.55; }
  .price-note { margin-top: 24px; font-size: 0.95rem; color: var(--text); line-height: 1.7; }

  .faq-list { margin-top: 32px; }
  .faq-item { background: #fff; border: 1px solid var(--border); border-radius: 6px; padding: 18px 22px; margin-bottom: 12px; }
  .faq-item summary { font-weight: 700; cursor: pointer; font-size: 1rem; color: var(--text); list-style: none; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::before { content: "+ "; color: var(--red); font-weight: 800; margin-right: 6px; }
  .faq-item[open] summary::before { content: "− "; }
  .faq-item p { font-size: 0.95rem; color: var(--text); line-height: 1.75; margin: 14px 0 0; }

  .bottom-cta { background: var(--black); color: #fff; padding: 72px 24px; text-align: center; }
  .bottom-cta h2 { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; margin: 0 0 16px; color: #fff; line-height: 1.25; }
  .bottom-cta p { color: #c9c9c9; margin: 0 0 30px; font-size: 1.02rem; line-height: 1.6; }
  .cta-row { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 16px 34px; border-radius: 5px; font-size: 1rem; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 16px 34px; border-radius: 5px; font-size: 1rem; font-weight: 600; text-decoration: none; border: 2px solid rgba(255,255,255,0.35); }
</style>
