---
// src/pages/brands/amana-range-repair.astro
// Niche combo, Amana range repair (~0 GSC impressions; brand portfolio completion).
// Parent: /brands/amana/. Voice: Whirlpool Corp ownership (2006), Iowa heritage, value-tier
// positioning, AGR gas / AER electric, F-codes shared with Whirlpool platform.
import Layout from '../../layouts/Layout.astro';
import ServiceHero from '../../components/ServiceHero.astro';
import { MAIN_PHONE } from '../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/brands/amana-range-repair/";

const title = "Amana Range Repair, AGR Gas · AER Electric · Glass-Top";
const description = `Amana range repair across SoCal, AGR gas, AER electric coil + glass-top freestanding ranges. $89 dx waived. BHGS #A49573. Call.`;

const faqs = [
  {
    q: "My Amana gas range burner clicks but won't ignite, what's wrong?",
    a: "Most common cause on AGR gas Amana ranges is a corroded or wet spark electrode at the burner base. Spilled food and liquid short the spark path; the electrode keeps clicking but no spark jumps to light the burner. Diagnostic order: (1) clean and dry the electrode, about 35% of 'clicks but no light' calls resolve here at no parts cost; (2) confirm gas supply at the unit (check that other burners light); (3) failed ignition switch under the knob ($145-$245); (4) clogged orifice in the burner cap; (5) gas valve failure (least common, $280-$440). When all four burners click but none ignite, the diagnostic shifts toward the spark module rather than individual igniters."
  },
  {
    q: "My Amana electric oven heats unevenly, what's the fix?",
    a: "Three things usually cause uneven oven heat on Amana AER electric models. (1) Failed bake or broil element, visible damage on inspection (cracks, blistering, broken loop). Bake element $185-$285; broil element similar. (2) Oven temperature sensor drift, the sensor's resistance value changes over time, the control board reads incorrect temperature and overshoots or undershoots. Replacement $145-$215, takes 20 minutes. (3) Convection fan motor failure on convection-equipped Amana models, leaving the oven heating but not circulating. We always test oven calibration after element or sensor replacement to confirm temperature reads correctly across the bake range."
  },
  {
    q: "How much does Amana range repair cost?",
    a: `Diagnostic is $89, applied toward the repair when you approve work. Common Amana range repair ranges: surface igniter (gas AGR) $145-$215; ignition switch / spark module $145-$285; gas valve $280-$440; bake / broil element (electric AER) $185-$285; oven temperature sensor $145-$215; convection fan motor $245-$385; surface coil element (electric coil-top) $145-$245; radiant element (glass-top electric) $185-$285; main control board $345-$525. Amana ranges sit at the value tier of the Whirlpool family, pricing typically lands at the lower end of the Whirlpool-platform band. Most repairs complete same-day with parts on the truck.`
  },

    {
      q: "Where can I find the official Amana manual or warranty information?",
      a: `Our technicians work independently of Amana's factory service network - we're often faster and available same-day in Southern California.`
    },
  ];

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": canonical + "#service",
    "serviceType": "Amana Range Repair",
    "name": "Amana Range Repair, Same Day Appliance Repair",
    "url": canonical,
    "description": "Same-day Amana range repair across Los Angeles, Orange, Ventura, San Bernardino, and Riverside counties. AGR gas, AER electric coil-top + glass-top freestanding ranges. Whirlpool-platform parts and diagnostic procedures. Spark electrodes, ignition switches, gas valves, bake / broil elements, oven temperature sensors, control boards. $89 residential diagnostic, applied toward repair.",
    "provider": {
      "@type": "LocalBusiness",
      "name": "Same Day Appliance Repair",
      "url": "https://samedayappliance.repair/",
      "telephone": phone,
      "priceRange": "$$"
    },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "offers": {
      "@type": "Offer",
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "89.00",
        "priceCurrency": "USD",
        "description": "Residential diagnostic fee, applied toward repair"
      }
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map((f) => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Brands", "item": "https://samedayappliance.repair/brands/" },
      { "@type": "ListItem", "position": 3, "name": "Amana", "item": "https://samedayappliance.repair/brands/amana/" },
      { "@type": "ListItem", "position": 4, "name": "Amana Range Repair", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>

<Fragment slot="head-scripts">
  {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
</Fragment>

<ServiceHero
  eyebrow="LA · Orange · Ventura · San Bernardino · Riverside Counties"
  title="Amana Range Repair, Across Southern California"
  subtitle="AGR gas, AER electric coil-top + glass-top freestanding ranges. Whirlpool-platform parts, surface igniter, bake/broil elements, oven sensor. $89 diagnostic, applied toward repair."
  heroImageTitle="Amana Range Repair"
  showBranches={true}
/>

<!-- 01 INTRO -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">01, About this service</p>
    <h2 class="section-title">Amana ranges on the Whirlpool platform.</h2>

    <p>Amana has been part of Whirlpool Corporation since 2006, positioned as the value-tier brand within the Whirlpool family. The range catalog is straightforward: AGR series gas freestanding ranges (sealed-burner design, electronic ignition, basic clock and oven controls) and AER series electric ranges in coil-top and glass-top variants. Mechanically the ranges share Whirlpool platform engineering, same surface igniters as base Whirlpool, same bake / broil elements, same oven temperature sensors, same control board architecture. We service all of them across our 5-county Southern California territory.</p>

    <p>Amana ranges are competitive value-tier units at price points designed for rental properties, first-apartment installations, and budget-conscious renovations. The repair calculation reflects the positioning: under year 8, repair is almost always the right call; year 12+ tilts harder toward replacement because the Whirlpool-platform parts cost is the same on Amana, but the original purchase price was lower. We tell you that math out loud at diagnostic. <a href="/brands/amana-refrigerator-repair/">Brand hub</a> covers Amana's full appliance lineup; this page is range-specific.</p>
  </div>
</section>

<!-- 02 COMMON FAILURES -->
<section class="section section-gray">
  <div class="container">
    <p class="section-number">02, Common failures</p>
    <h2 class="section-title">What we diagnose most often on Amana ranges.</h2>

    <div class="problem-grid">
      <div class="problem-card">
        <h3>AGR gas burner won't ignite</h3>
        <p>Spark clicks but no flame. Most common cause: corroded or wet spark electrode from spilled food. About 35% resolve at the cleaning step with no parts cost. Remaining failures trace to ignition switch ($145-$245), clogged orifice, gas valve, or spark module on units showing multiple-burner failure simultaneously. We work the cheap items first.</p>
      </div>
      <div class="problem-card">
        <h3>AER bake or broil element failure</h3>
        <p>Element shows visible damage on inspection, cracks, blistering, or a broken section of the loop. Cooking time runs longer than usual; eventually heat fails entirely. Bake element $185-$285. We always run the oven through a calibration test after replacement to confirm temperature reads correctly across the bake range.</p>
      </div>
      <div class="problem-card">
        <h3>Oven temperature sensor drift (year 6-9)</h3>
        <p>Oven runs hotter or colder than the set temperature without the homeowner noticing for weeks. The sensor's resistance value drifts as it ages, and the control board reads the wrong temperature. Replacement is a quick 20-minute job at $145-$215. Common wear pattern at year 6-9 across Amana, Whirlpool, and Maytag ranges on the shared platform.</p>
      </div>
      <div class="problem-card">
        <h3>Surface coil element failure (electric coil-top)</h3>
        <p>One of the coil burners stops heating, or heats only partially. Often visible damage at the coil terminal block, corrosion, scorching, or a loose connection. Coil replacement $145-$245. We test the receptacle (the socket the coil plugs into) at the same time because a damaged receptacle will burn out the new coil within months.</p>
      </div>
    </div>
  </div>
</section>

<!-- 03 MODELS -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">03, Amana range models we service</p>
    <h2 class="section-title">AGR gas, AER electric coil-top, AER glass-top.</h2>

    <p><strong>AGR gas (freestanding 30"):</strong> AGR4230, AGR5330, AGR6303, AGR6603, sealed-burner gas ranges with electronic ignition, mechanical or basic-electronic oven controls. Common service: spark electrodes, ignition switches, surface igniters, gas valves, oven temperature sensors.</p>

    <p><strong>AER electric coil-top (freestanding 30"):</strong> AER4203, AER5330, AER6303, coil-top electric ranges with mechanical or basic-electronic controls. Common service: surface coil elements, coil receptacles, bake / broil elements, oven sensor.</p>

    <p><strong>AER electric glass-top:</strong> AER6303MFW, AER6603SFB, glass-ceramic radiant cooktop with electric oven below. Common service: radiant elements under the glass, surface temperature limiters, control board, oven sensor.</p>

    <p>Pre-2006 Amana ranges (pre-Whirlpool acquisition vintage) we still service when parts can be sourced; the older Amana platform had different internals and we identify production year from the model and serial tag before scheduling.</p>
  </div>
</section>

<!-- 04 PRICING -->
<section class="section section-gray">
  <div class="container">
    <p class="section-number">04, Pricing</p>
    <h2 class="section-title">Amana range repair pricing.</h2>

    <p class="lead">Diagnostic is $89, applied toward the repair when you approve work. Amana ranges sit at the value tier of the Whirlpool family, pricing usually lands at the lower end of the Whirlpool-platform band. Written estimate before any parts go on.</p>

    <div class="pricing-grid">
      <div class="price-card">
        <div class="price-label">Diagnostic</div>
        <div class="price-amount">$89</div>
        <div class="price-desc">Waived when you approve repair</div>
      </div>
      <div class="price-card">
        <div class="price-label">Standard band</div>
        <div class="price-amount">$145–$285</div>
        <div class="price-desc">Surface igniter · ignition switch · sensor</div>
      </div>
      <div class="price-card">
        <div class="price-label">Bake / broil element</div>
        <div class="price-amount">$185–$285</div>
        <div class="price-desc">Electric element · convection fan motor</div>
      </div>
      <div class="price-card">
        <div class="price-label">Major component</div>
        <div class="price-amount">$345–$525</div>
        <div class="price-desc">Main control board · gas valve assembly</div>
      </div>
    </div>

    <p class="price-note">Year-12+ Amana ranges approaching $400+ in repair: we tell you the math against replacement out loud at diagnostic. Whirlpool-platform parts cross-reference means same-day completion on most repairs with parts already on the truck.</p>
  </div>
</section>

<!-- 05 FAQ -->
<section class="section">
  <div class="container narrow">
    <p class="section-number">05, FAQ</p>
    <h2 class="section-title">Amana range repair, common questions.</h2>

    <div class="faq-list">
      {faqs.map((f) => (
        <details class="faq-item">
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<!-- 06 BOTTOM CTA -->
<section class="bottom-cta">
  <div class="container">
    <h2>Amana range down? Same-day service across Southern California.</h2>
    <p>$89 diagnostic, applied toward the repair. AGR gas, AER electric, Whirlpool platform service across all five SoCal counties.</p>
    <div class="cta-row">
      <a href={phoneHref} class="btn-primary">☎ Call {phone}</a>
      <a href="/contact/" class="btn-secondary">Book Online</a>
    </div>
  </div>
</section>

</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .section { padding: 72px 24px; }
  .section-gray { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; }
  .container.narrow { max-width: 820px; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  h2.section-title { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; margin: 0 0 20px; line-height: 1.2; color: var(--text); }
  .lead { font-size: 1.05rem; line-height: 1.75; color: var(--text); margin-bottom: 20px; }
  .section p { margin: 0 0 18px; font-size: 1rem; line-height: 1.75; color: var(--text); }
  .section a { color: var(--red); font-weight: 600; text-decoration: none; }
  .section a:hover { text-decoration: underline; }

  .problem-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-top: 32px; }
  .problem-card { background: #fff; border: 1px solid var(--border); border-left: 4px solid var(--red); border-radius: 6px; padding: 26px 28px; }
  .problem-card h3 { font-size: 1.1rem; font-weight: 800; margin: 0 0 12px; color: var(--text); }
  .problem-card p { font-size: 0.95rem; color: var(--text); margin: 0; line-height: 1.7; }
  @media (max-width: 768px) { .problem-grid { grid-template-columns: 1fr; } }

  .pricing-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-top: 32px; }
  .price-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 26px 22px; text-align: center; }
  .price-card .price-label { font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--muted); margin-bottom: 10px; font-weight: 700; }
  .price-card .price-amount { font-size: 1.85rem; font-weight: 800; color: var(--text); line-height: 1; margin-bottom: 10px; }
  .price-card .price-desc { font-size: 0.85rem; color: var(--muted); line-height: 1.55; }
  .price-note { margin-top: 24px; font-size: 0.95rem; color: var(--text); line-height: 1.7; }

  .faq-list { margin-top: 32px; }
  .faq-item { background: #fff; border: 1px solid var(--border); border-radius: 6px; padding: 18px 22px; margin-bottom: 12px; }
  .faq-item summary { font-weight: 700; cursor: pointer; font-size: 1rem; color: var(--text); list-style: none; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::before { content: "+ "; color: var(--red); font-weight: 800; margin-right: 6px; }
  .faq-item[open] summary::before { content: "− "; }
  .faq-item p { font-size: 0.95rem; color: var(--text); line-height: 1.75; margin: 14px 0 0; }

  .bottom-cta { background: var(--black); color: #fff; padding: 72px 24px; text-align: center; }
  .bottom-cta h2 { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; margin: 0 0 16px; color: #fff; line-height: 1.25; }
  .bottom-cta p { color: #c9c9c9; margin: 0 0 30px; font-size: 1.02rem; line-height: 1.6; }
  .cta-row { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 16px 34px; border-radius: 5px; font-size: 1rem; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 16px 34px; border-radius: 5px; font-size: 1rem; font-weight: 600; text-decoration: none; border: 2px solid rgba(255,255,255,0.35); }
</style>
