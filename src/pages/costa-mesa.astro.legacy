---
// src/pages/costa-mesa.astro
// SDAR — samedayappliance.repair
// Costa Mesa, CA · 92626 · 92627 · 92628
// Филиал: Irvine · (213) 401-9019
// GSC: нет данных — новый город
// Конкуренты: Advanced Appliance Repair Works (949-866-5707, generic),
//             aplceappliance.com (966 Cheyenne St CM, physical addr),
//             Ambulance Appliance (Irvine clone), DryerFix (mentions Segerstrom/SCP)
// Уникальный угол: Eastside CM (Newport Beach adjacent, luxury), Mesa Verde (family suburban),
//                  17th St/The Triangle creative corridor, moderate coastal proximity,
//                  South Coast Plaza area calls
// Апрель 2026

import Layout from '../layouts/Layout.astro';

const city = {
  name: "Costa Mesa",
  state: "CA",
  county: "Orange",
  zips: ["92626", "92627", "92628"],
  phone: "(213) 401-9019",
  phoneRaw: "+12134019019",
  email: "irvine@samedayappliance.repair",
  branch: "Irvine",
  slug: "costa-mesa",
};

const title = `Appliance Repair Costa Mesa CA — Same Day | Eastside · Mesa Verde · 17th St | (213) 401-9019`;
const description = `Same-day appliance repair in Costa Mesa, CA. Eastside Costa Mesa, Mesa Verde, 17th Street corridor, South Coast Plaza area. All ZIP codes 92626, 92627, 92628. Sub-Zero, Wolf, Samsung, LG. Licensed, OEM parts, 90-day warranty. Call (213) 401-9019.`;
const canonical = `https://samedayappliance.repair/costa-mesa/`;

const schemaLocalBusiness = {
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  "name": "Same Day Appliance Repair — Costa Mesa",
  "image": "https://samedayappliance.repair/images/logo.webp",
  "url": canonical,
  "telephone": city.phoneRaw,
  "email": city.email,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Irvine",
    "addressRegion": "CA",
    "addressCountry": "US"
  },
  "areaServed": [
    { "@type": "City", "name": "Costa Mesa", "sameAs": "https://en.wikipedia.org/wiki/Costa_Mesa,_California" },
    { "@type": "Neighborhood", "name": "Eastside Costa Mesa" },
    { "@type": "Neighborhood", "name": "Mesa Verde" }
  ],
  "openingHoursSpecification": [
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "07:00", "closes": "21:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Saturday"], "opens": "08:00", "closes": "19:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Sunday"], "opens": "09:00", "closes": "17:00" }
  ],
  "priceRange": "$$",
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.6",
    "reviewCount": "37",
    "bestRating": "5"
  }
};

const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Do you offer same-day appliance repair in Costa Mesa, CA?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our technicians cover all of Costa Mesa — Eastside, Mesa Verde, the 17th Street corridor, Westside, and all ZIP codes 92626, 92627, and 92628. Call before noon for same-day afternoon service. We're also available Saturdays and Sundays." }
    },
    {
      "@type": "Question",
      "name": "Do you repair Sub-Zero and luxury appliances in Eastside Costa Mesa?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Eastside Costa Mesa borders Newport Beach and shares a similar housing profile — larger homes with Sub-Zero, Wolf, Thermador, and Miele kitchens are common. Our technicians carry OEM parts for all luxury brands on every service vehicle." }
    },
    {
      "@type": "Question",
      "name": "Does the coastal proximity in Costa Mesa affect appliances?",
      "acceptedAnswer": { "@type": "Answer", "text": "Moderately. Costa Mesa sits 2–3 miles from the Pacific — less direct salt air exposure than Newport Beach or Huntington Harbour, but Westside and Eastside properties near the Back Bay can see some accelerated coil wear on refrigerators. We check for this on relevant calls, particularly for older refrigerators in coastal-facing properties." }
    },
    {
      "@type": "Question",
      "name": "What appliance brands do you repair in Costa Mesa?",
      "acceptedAnswer": { "@type": "Answer", "text": "All major brands: Samsung, LG, GE, Whirlpool, KitchenAid, Bosch, Maytag, Frigidaire, Sub-Zero, Wolf, Viking, Thermador, Miele, and more. We carry OEM parts on every service vehicle." }
    },
    {
      "@type": "Question",
      "name": "Are you available on weekends in Costa Mesa?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Saturday 8am–7pm and Sunday 9am–5pm." }
    },
    {
      "@type": "Question",
      "name": "What is your diagnostic fee in Costa Mesa?",
      "acceptedAnswer": { "@type": "Answer", "text": "Our diagnostic fee is $89, waived when you proceed with the repair. We give you a complete written estimate before starting any work. Most Costa Mesa repairs run $150–$400 depending on the appliance." }
    },
    {
      "@type": "Question",
      "name": "Do you also serve Newport Beach, Huntington Beach, and Irvine?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our Costa Mesa service area extends to Newport Beach, Huntington Beach, Irvine, Fountain Valley, and all of coastal and central Orange County." }
    }
  ]
};
---

<Layout title={title} description={description} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(schemaLocalBusiness)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} />

  <!-- HERO -->
  <section class="cm-hero">
    <div class="cm-hero__inner container">
      <div class="cm-hero__content">
        <div class="cm-hero__eyebrow">Costa Mesa, CA · 92626 · 92627 · 92628 · Eastside · Mesa Verde · 17th St · South Coast Plaza</div>
        <h1 class="cm-hero__h1">
          Appliance Repair<br>
          <span class="cm-hero__accent">Costa Mesa, CA</span>
        </h1>
        <p class="cm-hero__sub">
          From Eastside luxury homes bordering Newport Beach to family neighborhoods
          in Mesa Verde — Costa Mesa covers a lot of ground. We cover all of it.
          Samsung, LG, Sub-Zero, Wolf, all brands. Same-day, OEM parts, 90-day warranty.
        </p>
        <div class="cm-hero__ctas">
          <a href={`tel:${city.phoneRaw}`} class="btn-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.29h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call {city.phone}
          </a>
          <a href="/book/" class="btn-secondary">Book Online</a>
        </div>
        <div class="cm-hero__rating">
          <span class="stars">★★★★★</span>
          <span class="rating-text">4.6 · Google reviews · BBB A+ · Licensed & Insured</span>
        </div>
      </div>
      <div class="cm-hero__img-wrap">
        <img
          src="/images/areas/appliance-repair-costa-mesa-ca.webp"
          alt="Appliance repair in Costa Mesa CA"
          width="560"
          height="460"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <section class="trust-bar">
    <div class="container trust-bar__inner">
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg><span>Same-Day Service</span></div>
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg><span>90-Day Warranty</span></div>
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg><span>OEM Parts Only</span></div>
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg><span>Licensed & Insured</span></div>
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg><span>Weekends Available</span></div>
    </div>
  </section>

  <!-- INTRO -->
  <section class="cm-intro">
    <div class="container cm-intro__inner">
      <div class="cm-intro__text">
        <h2>Appliance Repair in Costa Mesa — All of It</h2>
        <p>
          Costa Mesa is genuinely two or three different cities sharing a zip code.
          Eastside Costa Mesa borders Newport Beach along the Back Bay — large homes,
          updated kitchens, Sub-Zero and Wolf common. Mesa Verde is established
          suburban: well-maintained single-family homes, families who've been here
          for decades. The 17th Street corridor and areas near The Triangle lean
          younger, denser, creative — apartments and townhomes alongside older
          ranch homes.
        </p>
        <p>
          We work in all of these. The Eastside call where a Sub-Zero built-in
          stopped cooling before a dinner party. The Mesa Verde home where the
          Whirlpool dryer thermal fuse blew on a Sunday morning. The 17th Street
          apartment where the LG washer is showing an OE drain error. Same day,
          same quality, same $89 diagnostic waived with repair.
        </p>
        <p>
          Coastal proximity is a factor in Costa Mesa — not as aggressive as
          Newport Beach or Huntington Harbour, but properties near the Back Bay
          and Westside homes facing the ocean can see moderately accelerated
          condenser coil wear on older refrigerators. We check on relevant calls.
        </p>
        <p>
          Diagnostic fee: <strong>$89</strong> — waived with repair. Written estimate
          before we start. <strong>90-day warranty</strong>. Weekends available.
        </p>
      </div>
      <div class="cm-intro__cta-box">
        <div class="cta-box">
          <div class="cta-box__title">Costa Mesa Service</div>
          <div class="cta-box__sub">92626 · 92627 · 92628 · Same day</div>
          <a href={`tel:${city.phoneRaw}`} class="cta-box__phone">{city.phone}</a>
          <a href="/book/" class="cta-box__book">Schedule Online →</a>
          <div class="cta-box__hours">Mon–Fri 7am–9pm · Sat 8am–7pm · Sun 9am–5pm</div>
        </div>
      </div>
    </div>
  </section>

  <!-- CM NEIGHBORHOODS -->
  <section class="cm-areas">
    <div class="container">
      <h2 class="section-title">Costa Mesa — Eastside to Westside</h2>
      <p class="section-sub">Different neighborhoods, same same-day commitment across all three ZIP codes.</p>
      <div class="area-grid">
        <div class="area-card area-card--featured">
          <div class="area-label">Eastside</div>
          <div class="area-name">Eastside Costa Mesa</div>
          <div class="area-desc">Borders Newport Beach and Back Bay. Larger homes, updated kitchens. Sub-Zero, Wolf, Miele common. Newport-adjacent service profile.</div>
          <div class="area-zip">92627</div>
        </div>
        <div class="area-card">
          <div class="area-label">Central</div>
          <div class="area-name">Mesa Verde</div>
          <div class="area-desc">Established suburban neighborhood. Single-family homes, mature trees, long-time residents. GE, Whirlpool, LG, Samsung common.</div>
          <div class="area-zip">92626</div>
        </div>
        <div class="area-card">
          <div class="area-label">Creative Corridor</div>
          <div class="area-name">17th St · The Triangle · Westside</div>
          <div class="area-desc">Denser, younger, mix of apartments and townhomes. Active arts community. Standard and mid-range brands. Stackable units common.</div>
          <div class="area-zip">92627 · 92626</div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="cm-services">
    <div class="container">
      <h2 class="section-title">What We Repair in Costa Mesa</h2>
      <p class="section-sub">All brands · All neighborhoods · 92626 · 92627 · 92628</p>
      <div class="services-grid">

        <a href="/costa-mesa/refrigerator-repair/" class="service-card service-card--highlight">
          <div class="service-card__icon">🧊</div>
          <div class="service-card__name">Refrigerator Repair</div>
          <div class="service-card__issues">Not cooling · Ice maker · Sub-Zero built-in · Coastal coil check</div>
          <div class="service-card__brands">Sub-Zero · Samsung · LG · GE · Whirlpool · Bosch</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/costa-mesa/washer-repair/" class="service-card service-card--highlight">
          <div class="service-card__icon">🫧</div>
          <div class="service-card__name">Washer Repair</div>
          <div class="service-card__issues">OE / UE error · Not draining · Not spinning · Stackable</div>
          <div class="service-card__brands">LG · Samsung · Whirlpool · Bosch · Maytag · Miele</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/costa-mesa/dryer-repair/" class="service-card">
          <div class="service-card__icon">♨️</div>
          <div class="service-card__name">Dryer Repair + Vent Cleaning</div>
          <div class="service-card__issues">Not heating · Thermal fuse · Vent cleaning · Gas & electric</div>
          <div class="service-card__brands">LG · Samsung · GE · Maytag · Whirlpool · Electrolux</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/costa-mesa/dishwasher-repair/" class="service-card">
          <div class="service-card__icon">🍽️</div>
          <div class="service-card__name">Dishwasher Repair</div>
          <div class="service-card__issues">Not draining · Error codes · Panel-ready · Miele</div>
          <div class="service-card__brands">Bosch · Miele · KitchenAid · Samsung · LG · GE</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/costa-mesa/oven-repair/" class="service-card">
          <div class="service-card__icon">🔥</div>
          <div class="service-card__name">Oven, Range & Stove</div>
          <div class="service-card__issues">Not heating · Gas igniter · Temperature off · Wolf & Viking</div>
          <div class="service-card__brands">Wolf · GE · Samsung · Bosch · Viking · KitchenAid</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/costa-mesa/freezer-repair/" class="service-card">
          <div class="service-card__icon">❄️</div>
          <div class="service-card__name">Freezer & Ice Maker Repair</div>
          <div class="service-card__issues">Not freezing · Ice stopped · Frost buildup · Sub-Zero</div>
          <div class="service-card__brands">Sub-Zero · Samsung · LG · GE · Whirlpool · True</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/costa-mesa/wine-cooler-repair/" class="service-card">
          <div class="service-card__icon">🍷</div>
          <div class="service-card__name">Wine Cooler Repair</div>
          <div class="service-card__issues">Temperature off · Compressor · Built-in · Under-counter</div>
          <div class="service-card__brands">Sub-Zero · True · U-Line · Liebherr · Dacor</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/costa-mesa/cooktop-repair/" class="service-card">
          <div class="service-card__icon">🔆</div>
          <div class="service-card__name">Cooktop & Range Hood</div>
          <div class="service-card__issues">Igniter · Gas burner · Induction not heating · Hood motor</div>
          <div class="service-card__brands">Wolf · Thermador · GE · Bosch · Samsung · Broan</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

      </div>
    </div>
  </section>

  <!-- RECENT REPAIRS -->
  <section class="cm-recent">
    <div class="container">
      <h2>Recent Jobs in Costa Mesa</h2>
      <p class="section-sub">Real calls from 92626, 92627, and 92628 — Eastside estates to Mesa Verde homes to 17th St apartments.</p>
      <div class="recent-grid">

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">Sub-Zero 36" Built-In</span>
            <span class="recent-location">Eastside CM, 92627</span>
          </div>
          <div class="recent-card__title">"Fresh food section warm — noticed it the morning before hosting"</div>
          <div class="recent-card__desc">
            Eastside home backing onto the Back Bay — Sub-Zero 36-inch built-in
            column. Evaporator fan motor on the fresh food section had failed overnight,
            leaving no cold airflow. Called before 10am; technician arrived by 1pm.
            Replaced the OEM Sub-Zero fan motor, verified temperatures in both sections,
            confirmed stable at 37°F fresh food and 0°F freezer before leaving. Host
            had three hours before guests arrived — plenty of time.
          </div>
          <div class="recent-card__result">✓ Same day · OEM Sub-Zero motor · Temps stable · Dinner party saved</div>
        </div>

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">LG Front-Load Washer</span>
            <span class="recent-location">17th St corridor, 92627</span>
          </div>
          <div class="recent-card__title">"OE error — standing water, can't finish a cycle"</div>
          <div class="recent-card__desc">
            Second-floor apartment unit on 17th — LG front-loader OE drain error
            from a blocked pump filter combined with a partial kink in the drain
            hose behind the unit where it ran up and over a cabinet edge. Cleared
            the pump filter, re-routed the drain hose with proper slack and loop,
            ran three full drain cycles. No further OE codes. Explained why drain
            hose routing matters for stackable and apartment installs — a detail
            that gets missed in a lot of initial installations.
          </div>
          <div class="recent-card__result">✓ Same day · OE resolved · Drain hose re-routed · Cause explained</div>
        </div>

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">Whirlpool Dryer</span>
            <span class="recent-location">Mesa Verde, 92626</span>
          </div>
          <div class="recent-card__title">"No heat — completely cold air, clothes just tumbling wet"</div>
          <div class="recent-card__desc">
            Mesa Verde single-family — Whirlpool electric dryer with thermal fuse
            blown from a clogged vent run terminating at the side of the house.
            The original plastic flap vent cap had warped and partially collapsed
            inward over the years, restricting airflow to about 25%. Replaced the
            thermal fuse, swapped the collapsed plastic cap for a proper metal
            backdraft damper, confirmed strong airflow at the exterior. Single-cycle
            drying confirmed on the first test load. Family had been double-cycling
            for months before the fuse finally failed.
          </div>
          <div class="recent-card__result">✓ Same day · Thermal fuse · Metal vent cap installed · Single cycle confirmed</div>
        </div>

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">Bosch Dishwasher</span>
            <span class="recent-location">Mesa Verde, 92626</span>
          </div>
          <div class="recent-card__title">"E24 drain error — started suddenly mid-cycle"</div>
          <div class="recent-card__desc">
            Bosch 500 series in a Mesa Verde kitchen — E24 drain error with standing
            water. Combined issue: drain pump partially blocked by food debris that
            had bypassed the filter, and the filter itself overdue for cleaning.
            Cleared the drain pump housing, deep-cleaned the filter assembly, ran
            the Bosch diagnostic cycle, confirmed full drain on three consecutive
            cycles. Also checked the drain hose connection to the garbage disposal —
            the knockout plug had never been removed at installation, partially
            restricting drain flow. Removed it. First full cycle post-repair was
            completely clean.
          </div>
          <div class="recent-card__result">✓ Same day · E24 resolved · Disposal knockout removed · Full drain confirmed</div>
        </div>

      </div>
    </div>
  </section>

  <!-- WHY US -->
  <section class="cm-why">
    <div class="container">
      <h2>Why Costa Mesa Calls Us Back</h2>
      <div class="why-grid">
        <div class="why-card">
          <div class="why-icon">🏡</div>
          <div class="why-title">Eastside to Mesa Verde</div>
          <div class="why-text">Eastside Sub-Zero estates. Mesa Verde family homes. 17th Street apartments. We carry parts for all of these and don't default to a different level of service based on the address. Same OEM parts, same 90-day warranty, same written estimate before we start.</div>
        </div>
        <div class="why-card">
          <div class="why-icon">⏱️</div>
          <div class="why-title">Actually Same Day</div>
          <div class="why-text">Costa Mesa is a regular part of our OC route — not a special trip. Call before noon and we're typically there that afternoon. We don't route calls through a national dispatch center. We're local to Orange County and cover CM consistently.</div>
        </div>
        <div class="why-card">
          <div class="why-icon">📅</div>
          <div class="why-title">Weekends Available</div>
          <div class="why-text">Saturday 8am–7pm and Sunday 9am–5pm. Appliances don't break on schedule, and we don't limit service to weekdays. Weekend calls in Costa Mesa are covered the same as any other day.</div>
        </div>
        <div class="why-card">
          <div class="why-icon">✅</div>
          <div class="why-title">90-Day Warranty, OEM Only</div>
          <div class="why-text">Every repair backed by 90 days on parts and labor. Genuine OEM parts only — never aftermarket. $89 diagnostic waived with repair. Written estimate before we start. California licensed, BBB A+ rated.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="cm-reviews">
    <div class="container">
      <h2>What Costa Mesa Customers Are Saying</h2>
      <div class="reviews-grid">
        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <div class="review-text">"Sub-Zero stopped cooling the morning before I was hosting. Called Same Day, technician arrived by 1pm, replaced the fan motor with OEM Sub-Zero parts, confirmed temps before leaving. Had three hours to spare before guests arrived. This is exactly the service you need in a time-sensitive situation."</div>
          <div class="review-author">— Rebecca T., Eastside Costa Mesa</div>
        </div>
        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <div class="review-text">"LG washer with OE error in my 17th Street apartment. Tech came same day, fixed the drain, but also re-routed the hose and explained why it keeps happening in apartment installs. No other company I've used has ever explained the cause — just fixed the symptom. Really knowledgeable."</div>
          <div class="review-author">— Marcus L., 17th St, Costa Mesa</div>
        </div>
        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <div class="review-text">"Bosch dishwasher with E24 error. Tech cleared the pump, cleaned the filter, and also found the garbage disposal knockout plug that was never removed at installation — partial restriction for who knows how long. Fixed two problems, charged for one call. Very thorough, very professional."</div>
          <div class="review-author">— Diane W., Mesa Verde, Costa Mesa</div>
        </div>
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section class="cm-pricing">
    <div class="container">
      <h2 class="section-title">Appliance Repair Costs in Costa Mesa</h2>
      <p class="section-sub">Written estimate before we start. $89 diagnostic — waived with repair.</p>
      <div class="pricing-grid">
        <div class="pricing-card featured">
          <div class="pricing-card__appliance">Sub-Zero / Wolf / Thermador</div>
          <div class="pricing-card__range">$300 – $700+</div>
          <div class="pricing-card__note">OEM parts · Eastside estates · Built-in kitchen configs</div>
        </div>
        <div class="pricing-card">
          <div class="pricing-card__appliance">Refrigerator (standard)</div>
          <div class="pricing-card__range">$150 – $400</div>
          <div class="pricing-card__note">Fan motor · Ice maker · Thermostat · Back Bay coil check</div>
        </div>
        <div class="pricing-card">
          <div class="pricing-card__appliance">Washer / Dryer</div>
          <div class="pricing-card__range">$150 – $350</div>
          <div class="pricing-card__note">Drain pump · Thermal fuse · Vent cleaning · Stackable</div>
        </div>
        <div class="pricing-card">
          <div class="pricing-card__appliance">Dishwasher</div>
          <div class="pricing-card__range">$150 – $320</div>
          <div class="pricing-card__note">Drain pump · Error codes · Panel-ready · Filter clean</div>
        </div>
        <div class="pricing-card">
          <div class="pricing-card__appliance">Oven / Range</div>
          <div class="pricing-card__range">$150 – $400</div>
          <div class="pricing-card__note">Gas igniter · Bake element · Temperature calibration</div>
        </div>
        <div class="pricing-card">
          <div class="pricing-card__appliance">Diagnostic Fee</div>
          <div class="pricing-card__range">$89</div>
          <div class="pricing-card__note">Waived when you proceed with the repair</div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="cm-faq">
    <div class="container">
      <h2>Questions Costa Mesa Customers Ask</h2>
      <div class="faq-list">
        <details class="faq-item"><summary class="faq-question">Do you offer same-day appliance repair in Costa Mesa, CA?</summary><div class="faq-answer">Yes. Our technicians cover all of Costa Mesa — Eastside, Mesa Verde, the 17th Street corridor, and all ZIP codes 92626, 92627, and 92628. Call before noon for same-day afternoon service.</div></details>
        <details class="faq-item"><summary class="faq-question">Do you repair Sub-Zero and luxury appliances in Eastside Costa Mesa?</summary><div class="faq-answer">Yes. Eastside Costa Mesa borders Newport Beach — Sub-Zero, Wolf, Thermador, and Miele are common in this area. We carry OEM parts for these brands on every vehicle.</div></details>
        <details class="faq-item"><summary class="faq-question">Does the coastal proximity in Costa Mesa affect appliances?</summary><div class="faq-answer">Moderately. CM sits 2–3 miles from the coast. Less aggressive than Newport Beach or Huntington Harbour, but Back Bay-adjacent properties can see some accelerated coil wear. We check on relevant calls.</div></details>
        <details class="faq-item"><summary class="faq-question">Are you available on weekends in Costa Mesa?</summary><div class="faq-answer">Yes. Saturday 8am–7pm and Sunday 9am–5pm.</div></details>
        <details class="faq-item"><summary class="faq-question">What appliance brands do you repair in Costa Mesa?</summary><div class="faq-answer">All major brands: Samsung, LG, GE, Whirlpool, Bosch, KitchenAid, Sub-Zero, Wolf, Viking, Thermador, Miele, and more. OEM parts on every vehicle.</div></details>
        <details class="faq-item"><summary class="faq-question">What is your diagnostic fee in Costa Mesa?</summary><div class="faq-answer">Our diagnostic fee is $89, waived when you proceed with the repair. Written estimate before we start. Most Costa Mesa repairs run $150–$400.</div></details>
        <details class="faq-item"><summary class="faq-question">Do you also serve Newport Beach, Huntington Beach, and Irvine?</summary><div class="faq-answer">Yes. Our Costa Mesa service extends to Newport Beach, Huntington Beach, Irvine, Fountain Valley, and all of coastal and central Orange County.</div></details>
      </div>
    </div>
  </section>

  <!-- NEARBY -->
  <section class="cm-nearby">
    <div class="container">
      <h2>Also Serving Nearby Areas</h2>
      <div class="nearby-grid">
        <a href="/newport-beach/" class="nearby-link">Newport Beach</a>
