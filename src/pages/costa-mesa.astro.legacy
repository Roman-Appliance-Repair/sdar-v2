          <a href={`tel:${city.phoneRaw}`} class="btn-primary btn-large">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.29h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            {city.phone}
          </a>
          <a href="/book/" class="btn-secondary btn-large">Book Online</a>
        </div>
        <div class="bottom-cta__nap">
          <span>Same Day Appliance Repair — Costa Mesa, CA 92626 · 92627 · 92628</span>
          <span>·</span>
          <a href={`mailto:${city.email}`}>{city.email}</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  :root { --cm-red: #C8102E; --cm-black: #0a0a0a; --cm-gray: #f5f5f5; --cm-border: #e2e2e2; --cm-text: #1a1a1a; --cm-muted: #6b6b6b; }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  .cm-hero { background: var(--cm-black); color: white; padding: 80px 0 60px; }
  .cm-hero__inner { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
  .cm-hero__eyebrow { font-size: 13px; font-weight: 500; color: var(--cm-red); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 16px; }
  .cm-hero__h1 { font-size: clamp(36px, 5vw, 52px); font-weight: 700; line-height: 1.1; margin-bottom: 20px; color: white; }
  .cm-hero__accent { color: var(--cm-red); }
  .cm-hero__sub { font-size: 17px; line-height: 1.6; color: rgba(255,255,255,0.75); margin-bottom: 32px; max-width: 520px; }
  .cm-hero__ctas { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 24px; }
  .cm-hero__rating { display: flex; align-items: center; gap: 10px; }
  .stars { color: #FFD700; font-size: 18px; letter-spacing: 2px; }
  .rating-text { font-size: 14px; color: rgba(255,255,255,0.7); }
  .cm-hero__img-wrap img { width: 100%; height: auto; border-radius: 12px; object-fit: cover; }
  .btn-primary { display: inline-flex; align-items: center; gap: 8px; background: var(--cm-red); color: white; padding: 14px 28px; border-radius: 8px; font-weight: 600; font-size: 16px; text-decoration: none; transition: background 0.2s; }
  .btn-primary:hover { background: #a50e25; }
  .btn-secondary { display: inline-flex; align-items: center; gap: 8px; background: transparent; color: white; padding: 14px 28px; border-radius: 8px; font-weight: 600; font-size: 16px; text-decoration: none; border: 1.5px solid rgba(255,255,255,0.35); }
  .btn-large { padding: 16px 36px; font-size: 17px; }
  .cm-bottom-cta .btn-secondary { color: var(--cm-text); border-color: var(--cm-border); }
  .trust-bar { background: var(--cm-red); padding: 16px 0; }
  .trust-bar__inner { display: flex; justify-content: space-between; flex-wrap: wrap; gap: 12px; }
  .trust-item { display: flex; align-items: center; gap: 8px; color: white; font-size: 14px; font-weight: 500; }
  .cm-intro { padding: 72px 0; background: white; }
  .cm-intro__inner { display: grid; grid-template-columns: 1fr 340px; gap: 60px; align-items: start; }
  .cm-intro__text h2 { font-size: 28px; font-weight: 700; color: var(--cm-black); margin-bottom: 20px; }
  .cm-intro__text p { font-size: 16px; line-height: 1.7; color: var(--cm-text); margin-bottom: 16px; }
  .cta-box { background: var(--cm-black); color: white; border-radius: 12px; padding: 32px; text-align: center; position: sticky; top: 80px; }
  .cta-box__title { font-size: 18px; font-weight: 700; margin-bottom: 4px; }
  .cta-box__sub { font-size: 13px; color: rgba(255,255,255,0.6); margin-bottom: 24px; }
  .cta-box__phone { display: block; font-size: 24px; font-weight: 700; color: var(--cm-red); text-decoration: none; margin-bottom: 12px; }
  .cta-box__book { display: block; font-size: 15px; color: white; text-decoration: none; padding: 12px; border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; margin-bottom: 16px; }
  .cta-box__hours { font-size: 12px; color: rgba(255,255,255,0.5); }
  .cm-areas { padding: 72px 0; background: var(--cm-gray); }
  .area-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .area-card { background: white; border: 1px solid var(--cm-border); border-radius: 12px; padding: 24px; }
  .area-card--featured { border-color: var(--cm-red); background: #fff5f7; }
  .area-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--cm-muted); margin-bottom: 6px; }
  .area-name { font-size: 16px; font-weight: 600; color: var(--cm-black); margin-bottom: 10px; }
  .area-desc { font-size: 14px; color: var(--cm-muted); line-height: 1.6; margin-bottom: 12px; }
  .area-zip { font-size: 12px; font-weight: 500; color: var(--cm-red); }
  .section-title { font-size: 30px; font-weight: 700; color: var(--cm-black); margin-bottom: 8px; text-align: center; }
  .section-sub { font-size: 16px; color: var(--cm-muted); text-align: center; margin-bottom: 40px; }
  .cm-services { padding: 72px 0; background: white; }
  .services-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
  .service-card { background: white; border: 1px solid var(--cm-border); border-radius: 12px; padding: 24px 20px; text-decoration: none; color: var(--cm-text); transition: box-shadow 0.2s, transform 0.2s; display: block; }
  .service-card:hover { box-shadow: 0 4px 24px rgba(0,0,0,0.1); transform: translateY(-2px); }
  .service-card--highlight { border-color: var(--cm-red); background: #fff5f7; }
  .service-card__icon { font-size: 28px; margin-bottom: 10px; }
  .service-card__name { font-size: 16px; font-weight: 600; color: var(--cm-black); margin-bottom: 8px; }
  .service-card__issues { font-size: 13px; color: var(--cm-muted); line-height: 1.5; margin-bottom: 8px; }
  .service-card__brands { font-size: 12px; color: var(--cm-muted); margin-bottom: 12px; }
  .service-card__cta { font-size: 13px; color: var(--cm-red); font-weight: 500; }
  .cm-recent { padding: 72px 0; background: var(--cm-gray); }
  .cm-recent h2 { font-size: 30px; font-weight: 700; color: var(--cm-black); margin-bottom: 8px; text-align: center; }
  .recent-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .recent-card { background: white; border: 1px solid var(--cm-border); border-radius: 12px; padding: 24px; }
  .recent-card__header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; flex-wrap: wrap; gap: 6px; }
  .recent-badge { background: var(--cm-red); color: white; font-size: 11px; font-weight: 600; padding: 3px 10px; border-radius: 20px; }
  .recent-location { font-size: 12px; color: var(--cm-muted); }
  .recent-card__title { font-size: 15px; font-weight: 600; color: var(--cm-black); margin-bottom: 10px; font-style: italic; }
  .recent-card__desc { font-size: 14px; color: var(--cm-text); line-height: 1.6; margin-bottom: 12px; }
  .recent-card__result { font-size: 13px; color: #2a7a2a; font-weight: 500; }
  .cm-why { padding: 72px 0; background: white; }
  .cm-why h2 { font-size: 30px; font-weight: 700; color: var(--cm-black); margin-bottom: 40px; text-align: center; }
  .why-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
  .why-card { background: var(--cm-gray); border-radius: 12px; padding: 28px 24px; }
  .why-icon { font-size: 28px; margin-bottom: 14px; }
  .why-title { font-size: 16px; font-weight: 600; color: var(--cm-black); margin-bottom: 10px; }
  .why-text { font-size: 14px; color: var(--cm-muted); line-height: 1.6; }
  .cm-reviews { padding: 72px 0; background: var(--cm-gray); }
  .cm-reviews h2 { font-size: 30px; font-weight: 700; color: var(--cm-black); margin-bottom: 40px; text-align: center; }
  .reviews-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .review-card { background: white; border: 1px solid var(--cm-border); border-radius: 12px; padding: 28px; }
  .review-stars { color: #FFD700; font-size: 18px; margin-bottom: 12px; }
  .review-text { font-size: 14px; color: var(--cm-text); line-height: 1.7; margin-bottom: 16px; font-style: italic; }
  .review-author { font-size: 13px; color: var(--cm-muted); font-weight: 500; }
  .cm-pricing { padding: 72px 0; background: white; }
  .pricing-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 20px; }
  .pricing-card { background: var(--cm-gray); border-radius: 10px; padding: 20px 24px; border: 1px solid var(--cm-border); }
  .pricing-card.featured { background: #fff5f7; border-color: var(--cm-red); }
  .pricing-card__appliance { font-size: 14px; color: var(--cm-muted); margin-bottom: 6px; }
  .pricing-card__range { font-size: 22px; font-weight: 700; color: var(--cm-black); margin-bottom: 6px; }
  .pricing-card.featured .pricing-card__range { color: var(--cm-red); }
  .pricing-card__note { font-size: 13px; color: var(--cm-muted); }
  .cm-faq { padding: 72px 0; background: var(--cm-gray); }
  .cm-faq h2 { font-size: 30px; font-weight: 700; color: var(--cm-black); margin-bottom: 40px; text-align: center; }
  .faq-list { max-width: 800px; margin: 0 auto; }
  .faq-item { border: 1px solid var(--cm-border); border-radius: 8px; background: white; margin-bottom: 10px; overflow: hidden; }
  .faq-question { padding: 18px 24px; font-size: 16px; font-weight: 600; color: var(--cm-black); cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; }
  .faq-question::after { content: '+'; font-size: 22px; color: var(--cm-red); flex-shrink: 0; margin-left: 16px; }
  details[open] .faq-question::after { content: '−'; }
  .faq-answer { padding: 0 24px 20px; font-size: 15px; line-height: 1.7; color: var(--cm-text); }
  .cm-nearby { padding: 48px 0; background: white; border-top: 1px solid var(--cm-border); }
  .cm-nearby h2 { font-size: 20px; font-weight: 600; color: var(--cm-black); margin-bottom: 20px; text-align: center; }
  .nearby-grid { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; }
  .nearby-link { padding: 8px 20px; border: 1px solid var(--cm-border); border-radius: 20px; font-size: 14px; color: var(--cm-text); text-decoration: none; transition: border-color 0.2s, color 0.2s; }
  .nearby-link:hover { border-color: var(--cm-red); color: var(--cm-red); }
  .cm-bottom-cta { padding: 72px 0; background: var(--cm-black); color: white; }
  .bottom-cta__inner { text-align: center; }
  .bottom-cta__text h2 { font-size: 34px; font-weight: 700; color: white; margin-bottom: 12px; }
  .bottom-cta__text p { font-size: 16px; color: rgba(255,255,255,0.7); margin-bottom: 32px; }
  .bottom-cta__actions { display: flex; gap: 12px; justify-content: center; margin-bottom: 24px; flex-wrap: wrap; }
  .bottom-cta__nap { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; font-size: 13px; color: rgba(255,255,255,0.4); }
  .bottom-cta__nap a { color: rgba(255,255,255,0.4); text-decoration: none; }
  @media (max-width: 1024px) { .services-grid { grid-template-columns: repeat(2, 1fr); } .why-grid { grid-template-columns: repeat(2, 1fr); } .reviews-grid { grid-template-columns: 1fr 1fr; } .cm-intro__inner { grid-template-columns: 1fr; } .area-grid { grid-template-columns: 1fr; } .pricing-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 768px) { .cm-hero__inner { grid-template-columns: 1fr; } .cm-hero__img-wrap { display: none; } .recent-grid { grid-template-columns: 1fr; } .reviews-grid { grid-template-columns: 1fr; } .why-grid { grid-template-columns: 1fr 1fr; } .trust-bar__inner { justify-content: center; } }
  @media (max-width: 480px) { .services-grid { grid-template-columns: 1fr; } .why-grid { grid-template-columns: 1fr; } .pricing-grid { grid-template-columns: 1fr; } .cm-hero { padding: 48px 0 40px; } .bottom-cta__text h2 { font-size: 26px; } }
</style>
