      { "@type": "Question", "name": "Which cities do you cover in Ventura County?", "acceptedAnswer": { "@type": "Answer", "text": "Thousand Oaks, Westlake Village, Agoura Hills, Camarillo, Simi Valley, Moorpark, Ventura, Newbury Park, Oak Park." } }
    ]
  }
  </script>

  <style>
    :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Inter', -apple-system, sans-serif; color: var(--text); line-height: 1.6; }
    a { color: inherit; text-decoration: none; }
    .hero { background: #0a0a0a; color: #fff; padding: 80px 24px 72px; }
    .hero-inner { max-width: 1100px; margin: 0 auto; }
    .hero-eyebrow { font-size: 13px; font-weight: 600; letter-spacing: .12em; text-transform: uppercase; color: var(--red); margin-bottom: 14px; }
    .hero h1 { font-size: clamp(30px, 4vw, 50px); font-weight: 700; line-height: 1.1; margin-bottom: 18px; letter-spacing: -.02em; max-width: 760px; color: #fff; }
    .hero-sub { font-size: 18px; color: rgba(255,255,255,.85); margin-bottom: 32px; max-width: 620px; line-height: 1.65; }
    .hero-ctas { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 28px; }
    .btn-red { background: var(--red); color: #fff; padding: 14px 28px; border-radius: 6px; font-size: 15px; font-weight: 600; }
    .btn-outline { border: 1.5px solid rgba(255,255,255,.3); color: #fff; padding: 14px 28px; border-radius: 6px; font-size: 15px; }
    .hero-stats { display: flex; gap: 32px; flex-wrap: wrap; }
    .hero-stat-num { font-size: 28px; font-weight: 700; color: #fff; }
    .hero-stat-label { font-size: 12px; color: rgba(255,255,255,.45); margin-top: 2px; }
    .stars { color: #f59e0b; }
    .trust-bar { background: var(--red); padding: 14px 24px; }
    .trust-bar-inner { max-width: 1100px; margin: 0 auto; display: flex; gap: 20px; flex-wrap: wrap; justify-content: center; }
    .ti { display: flex; align-items: center; gap: 8px; font-size: 13px; font-weight: 500; color: #fff; }
    .section { padding: 72px 24px; }
    .section-gray { background: var(--gray); }
    .section-black { background: var(--black); color: #fff; }
    .container { max-width: 1100px; margin: 0 auto; }
    .sl { font-size: 12px; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--red); margin-bottom: 12px; }
    h2 { font-size: clamp(24px, 3.2vw, 36px); font-weight: 700; line-height: 1.2; letter-spacing: -.02em; margin-bottom: 18px; }
    .section-black h2 { color: #fff; }
    .lead { font-size: 17px; line-height: 1.7; color: var(--muted); max-width: 700px; margin-bottom: 40px; }
    .section-black .lead { color: rgba(255,255,255,.62); }
    .body-text p { font-size: 16px; line-height: 1.75; margin-bottom: 16px; color: var(--text); }
    .cities-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 10px; margin-top: 32px; }
    .city-link { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 14px 16px; display: flex; align-items: center; justify-content: space-between; font-size: 14px; font-weight: 500; }
    .city-link:hover { border-color: var(--red); color: var(--red); }
    .city-arrow { font-size: 12px; color: var(--muted); }
    .services-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 16px; margin-top: 32px; }
    .svc-card { background: #fff; border: 1px solid var(--border); border-radius: 10px; padding: 20px; }
    .svc-icon { font-size: 24px; margin-bottom: 10px; }
    .svc-card h3 { font-size: 14px; font-weight: 700; margin-bottom: 5px; }
    .svc-card p { font-size: 13px; color: var(--muted); line-height: 1.5; }
    .context-cols { display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: start; }
    .context-text p { font-size: 16px; line-height: 1.75; color: rgba(255,255,255,.72); margin-bottom: 14px; }
    .context-facts { display: flex; flex-direction: column; gap: 12px; }
    .cfact { background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1); border-radius: 10px; padding: 16px; }
    .cfact h4 { font-size: 13px; font-weight: 700; color: #fff; margin-bottom: 5px; }
    .cfact p { font-size: 13px; color: rgba(255,255,255,.55); line-height: 1.5; }
    .repairs-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 16px; margin-top: 32px; }
    .repair-card { background: #fff; border: 1px solid var(--border); border-radius: 10px; padding: 20px; }
    .rtag { display: inline-block; background: var(--gray); font-size: 11px; font-weight: 600; letter-spacing: .08em; text-transform: uppercase; color: var(--muted); padding: 3px 8px; border-radius: 4px; margin-bottom: 10px; }
    .repair-card h3 { font-size: 14px; font-weight: 700; margin-bottom: 7px; line-height: 1.3; }
    .repair-card p { font-size: 13px; color: var(--muted); line-height: 1.6; }
    .pricing-table { width: 100%; border-collapse: collapse; margin-top: 28px; font-size: 15px; }
    .pricing-table th { text-align: left; padding: 12px 16px; background: var(--black); color: #fff; font-size: 13px; font-weight: 600; }
    .pricing-table td { padding: 13px 16px; border-bottom: 1px solid var(--border); }
    .pricing-table tr:last-child td { border-bottom: none; }
    .pricing-table tr:nth-child(even) td { background: #fafafa; }
    .price-val { font-weight: 700; color: var(--red); }
    .pricing-note { font-size: 13px; color: var(--muted); margin-top: 14px; padding: 13px 16px; background: var(--gray); border-radius: 6px; border-left: 3px solid var(--red); }
    .faq-list { margin-top: 36px; }
    .faq-item { border-bottom: 1px solid var(--border); padding: 18px 0; }
    .faq-item:first-child { border-top: 1px solid var(--border); }
    .faq-q { font-size: 16px; font-weight: 700; margin-bottom: 8px; }
    .faq-a { font-size: 15px; line-height: 1.7; color: var(--muted); }
    .nearby-grid { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 26px; }
    .nb { background: var(--gray); border: 1px solid var(--border); border-radius: 6px; padding: 8px 14px; font-size: 14px; }
    .bottom-cta { background: var(--black); color: #fff; padding: 72px 24px; text-align: center; }
    .bottom-cta h2 { color: #fff; margin-bottom: 14px; }
    .bottom-cta p { font-size: 17px; color: rgba(255,255,255,.62); margin-bottom: 30px; max-width: 540px; margin-left: auto; margin-right: auto; }
    .bottom-ctas { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
    @media (max-width: 768px) { .context-cols { grid-template-columns: 1fr; } }
  </style>

