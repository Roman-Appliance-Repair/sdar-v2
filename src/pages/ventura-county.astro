---
// Appliance Repair Ventura County | Same Day Appliance Repair
// /ventura-county/
import Layout from '../layouts/Layout.astro';
import CountyMap from '../components/CountyMap.astro';

const title = "Appliance Repair Ventura County CA | Same Day Service";
const description = "Appliance repair across Ventura County — Thousand Oaks, Westlake Village, Camarillo, Simi Valley and more. $89 diagnostic. (424) 208-0228.";
---

<Layout title={title} description={description}>
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "HomeAndConstructionBusiness",
    "name": "Same Day Appliance Repair — Ventura County",
    "telephone": "(424) 208-0228",
    "url": "https://samedayappliance.repair/ventura-county/",
        "areaServed": { "@type": "AdministrativeArea", "name": "Ventura County" },
    "openingHoursSpecification": [
      { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "07:00", "closes": "21:00" },
      { "@type": "OpeningHoursSpecification", "dayOfWeek": "Saturday", "opens": "08:00", "closes": "19:00" },
      { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "09:00", "closes": "17:00" }
    ],
    "priceRange": "$$"
  }
  </script>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "Do you offer same day appliance repair across Ventura County?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We cover 9 cities across Ventura County. Call (424) 208-0228 for availability." } },
