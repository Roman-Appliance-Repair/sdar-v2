---
// src/pages/thousand-oaks.astro
// SDAR — samedayappliance.repair
// Thousand Oaks, CA · 91360 · 91361 · 91362 · 91320
// Филиал: Thousand Oaks · (424) 208-0228
// GSC: "appliance repair thousand oaks" — 659 показов, поз 33 (!!)
//      "appliance repair thousand oaks ca" — 640 показов, поз 32
//      "thousand oaks freezer repair" — 313 показов, поз 29
//      "thousand oaks washer repair" — 295 показов, поз 32
//      "thousand oaks refrigerator repair" — 294 показов, поз 35
//      "appliance repair in thousand oaks" — поз 2.79 (!!! почти топ-3)
//      "dishwasher repair thousand oaks" — поз 8.3
//      "washer repair thousand oaks" — поз 11.7
// Конкуренты: All Trust Appliance (747-877-8770, strong — Dos Vientos, Sub-Zero/Thermador/Miele),
//             Airtexno (factory-trained, 1-yr warranty), Krupo Repair (Conejo Valley language)
// Уникальный угол: Conejo Valley luxury + Dos Vientos gated + Lynn Ranch equestrian +
//                  hot dry climate (coil dust, not salt air) + Sub-Zero/Thermador standard
// Апрель 2026

import Layout from '../layouts/Layout.astro';

const city = {
  name: "Thousand Oaks",
  state: "CA",
  county: "Ventura",
  zips: ["91360", "91361", "91362", "91320"],
  phone: "(424) 208-0228",
  phoneRaw: "+14242080228",
  email: "thousandoaks@samedayappliance.repair",
  branch: "Thousand Oaks",
  slug: "thousand-oaks",
};

const title = `Appliance Repair Thousand Oaks CA — Same Day | Dos Vientos · Lynn Ranch · Newbury Park | (424) 208-0228`;
const description = `Same-day appliance repair in Thousand Oaks, CA. Dos Vientos, Lynn Ranch, Newbury Park, Westlake Village area. Sub-Zero, Wolf, Thermador, Miele, Samsung, LG. Licensed, OEM parts, 90-day warranty. Call (424) 208-0228.`;
const canonical = `https://samedayappliance.repair/thousand-oaks/`;

const schemaLocalBusiness = {
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  "name": "Same Day Appliance Repair — Thousand Oaks",
  "image": "https://samedayappliance.repair/images/logo.webp",
  "url": canonical,
  "telephone": city.phoneRaw,
  "email": city.email,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Thousand Oaks",
    "addressRegion": "CA",
    "postalCode": "91360",
    "addressCountry": "US"
  },
  "areaServed": [
    { "@type": "City", "name": "Thousand Oaks", "sameAs": "https://en.wikipedia.org/wiki/Thousand_Oaks,_California" },
    { "@type": "Neighborhood", "name": "Dos Vientos" },
    { "@type": "Neighborhood", "name": "Newbury Park" },
    { "@type": "Neighborhood", "name": "Lynn Ranch" }
  ],
  "openingHoursSpecification": [
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "07:00", "closes": "21:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Saturday"], "opens": "08:00", "closes": "19:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Sunday"], "opens": "09:00", "closes": "17:00" }
  ],
  "priceRange": "$$",
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.6",
    "reviewCount": "37",
    "bestRating": "5"
  }
};

const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Do you offer same-day appliance repair in Thousand Oaks, CA?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our Thousand Oaks branch covers all of 91360, 91361, 91362, and 91320 — Dos Vientos, Lynn Ranch, Newbury Park, North Ranch, Westlake Village area, and every neighborhood throughout the Conejo Valley. Call before noon for same-day afternoon service." }
    },
    {
      "@type": "Question",
      "name": "Does the hot, dry Conejo Valley climate affect appliances in Thousand Oaks?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. The Conejo Valley's hot, dry summers combined with dusty hillside air cause condenser coils on refrigerators to accumulate dust and debris faster than in coastal or urban environments. We check condenser coils on every Thousand Oaks refrigerator call — it's a consistent finding here, especially in hillside properties with landscaping dust." }
    },
    {
      "@type": "Question",
      "name": "Do you repair Sub-Zero, Thermador, Miele, and Wolf appliances in Thousand Oaks?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Sub-Zero, Wolf, Thermador, Miele, Viking, and Gaggenau are common throughout Thousand Oaks — particularly in Dos Vientos, North Ranch, and the larger Westlake Village estates. Our technicians carry OEM parts for these brands on every service vehicle." }
    },
    {
      "@type": "Question",
      "name": "Can you service appliances in Dos Vientos and other gated communities?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our technicians are familiar with the gate access protocols for Dos Vientos and other gated Thousand Oaks communities. We coordinate entry in advance and work with property managers and household staff as needed." }
    },
    {
      "@type": "Question",
      "name": "Are you available on weekends in Thousand Oaks?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Saturday 8am–7pm and Sunday 9am–5pm." }
    },
    {
      "@type": "Question",
      "name": "What is your diagnostic fee in Thousand Oaks?",
      "acceptedAnswer": { "@type": "Answer", "text": "Our diagnostic fee is $89, waived when you proceed with the repair. Written estimate before we start. Most Thousand Oaks repairs run $150–$450 depending on brand and appliance." }
    },
    {
      "@type": "Question",
      "name": "Do you also serve Westlake Village, Calabasas, and Simi Valley?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our Thousand Oaks service extends to Westlake Village, Calabasas, Agoura Hills, Oak Park, Newbury Park, Moorpark, and Simi Valley. All Conejo Valley and surrounding communities." }
    }
  ]
};
---

<Layout title={title} description={description} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(schemaLocalBusiness)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} />

  <!-- HERO -->
  <section class="to-hero">
    <div class="to-hero__inner container">
      <div class="to-hero__content">
        <div class="to-hero__eyebrow">Thousand Oaks, CA · Conejo Valley · Dos Vientos · Lynn Ranch · Newbury Park · North Ranch</div>
        <h1 class="to-hero__h1">
          Appliance Repair<br>
          <span class="to-hero__accent">Thousand Oaks, CA</span>
        </h1>
        <p class="to-hero__sub">
          Conejo Valley's mix of luxury estates and established suburban homes —
          Sub-Zero, Thermador, Miele alongside Samsung and LG. Local Thousand Oaks
          branch, same-day service, OEM parts, 90-day warranty. Gated communities
          welcome. Weekends available.
        </p>
        <div class="to-hero__ctas">
          <a href={`tel:${city.phoneRaw}`} class="btn-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.29h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call {city.phone}
          </a>
          <a href="/book/" class="btn-secondary">Book Online</a>
        </div>
        <div class="to-hero__rating">
          <span class="stars">★★★★★</span>
          <span class="rating-text">4.6 · Google reviews · BBB A+ · Licensed & Insured</span>
        </div>
      </div>
      <div class="to-hero__img-wrap">
        <img
          src="/images/areas/appliance-repair-thousand-oaks-ca.webp"
          alt="Appliance repair in Thousand Oaks CA"
          width="560"
          height="460"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <section class="trust-bar">
    <div class="container trust-bar__inner">
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg><span>Same-Day Service</span></div>
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg><span>90-Day Warranty</span></div>
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg><span>OEM Parts Only</span></div>
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg><span>Licensed & Insured</span></div>
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg><span>Gated Community Ready</span></div>
    </div>
  </section>

  <!-- INTRO -->
  <section class="to-intro">
    <div class="container to-intro__inner">
      <div class="to-intro__text">
        <h2>Appliance Repair in Thousand Oaks — The Conejo Valley Difference</h2>
        <p>
          Thousand Oaks is one of the most consistently well-kept communities in
          Southern California — and the appliances inside these homes reflect that.
          The Dos Vientos and North Ranch estates have Sub-Zero built-ins, Thermador
          pro ranges, and Miele dishwashers as standard. The established neighborhoods
          throughout the rest of 91360 and 91361 have LG, Samsung, GE, and Whirlpool
          machines that need the same reliable same-day service.
        </p>
        <p>
          One environmental factor that matters here but rarely gets mentioned:
          the Conejo Valley's hot, dry summers push significant particulate through
          the air — particularly in hillside properties with mature landscaping.
          Refrigerator condenser coils accumulate dust and debris faster than in
          coastal or urban environments. We check condenser coils on every Thousand
          Oaks refrigerator call. A coil that's loaded with dusty buildup runs the
          compressor harder, drives up energy costs, and shortens the unit's life.
          It's a consistent finding here.
        </p>
        <p>
          We're familiar with the gate access protocols for Dos Vientos and other
          gated communities throughout Thousand Oaks. Estate managers, household
          staff, and property managers are all part of our normal workflow in
          this area.
        </p>
        <p>
          Diagnostic fee: <strong>$89</strong> — waived with repair. Written estimate
          before we start. <strong>90-day warranty</strong>. Weekends available.
        </p>
        <div class="to-tip">
          <div class="to-tip__icon">🌡️</div>
          <div class="to-tip__text">
            <strong>Conejo Valley climate tip:</strong> Thousand Oaks summers are
            hot and dry, and hillside properties see significant dust load through
            the condenser. If your refrigerator has been running longer cycles than
            usual — particularly after a dry, windy stretch or after landscaping
            work — dusty condenser coils are almost certainly the cause. Clean coils
            every 6–9 months in this environment, not the 12-month recommendation
            written for temperate climates.
          </div>
        </div>
      </div>
      <div class="to-intro__cta-box">
        <div class="cta-box">
          <div class="cta-box__title">Thousand Oaks Branch</div>
          <div class="cta-box__sub">Local office · All Conejo Valley · Same day</div>
          <a href={`tel:${city.phoneRaw}`} class="cta-box__phone">{city.phone}</a>
          <a href="/book/" class="cta-box__book">Schedule Online →</a>
          <div class="cta-box__hours">Mon–Fri 7am–9pm · Sat 8am–7pm · Sun 9am–5pm</div>
        </div>
      </div>
    </div>
  </section>

  <!-- NEIGHBORHOODS -->
  <section class="to-communities">
    <div class="container">
      <h2 class="section-title">Thousand Oaks — Every Community</h2>
      <p class="section-sub">From Dos Vientos estates to Lynn Ranch to central TO — same same-day commitment.</p>
      <div class="community-grid">
        <div class="community-card community-card--featured">
          <div class="community-name">Dos Vientos</div>
          <div class="community-detail">Gated · Sub-Zero / Thermador estates · Estate manager coordination · Gate access arranged</div>
        </div>
        <div class="community-card community-card--featured">
          <div class="community-name">North Ranch</div>
          <div class="community-detail">Luxury hillside · Wolf / Miele common · Large format kitchens · Outdoor kitchen service</div>
        </div>
        <div class="community-card community-card--featured">
          <div class="community-name">Lynn Ranch</div>
          <div class="community-detail">Equestrian estates · Large lot properties · Mix of luxury and standard brands</div>
        </div>
        <div class="community-card">
          <div class="community-name">Newbury Park</div>
          <div class="community-detail">91320 · Established suburban · LG, Samsung, GE common</div>
        </div>
        <div class="community-card">
          <div class="community-name">Lang Ranch</div>
          <div class="community-detail">91362 · Newer construction · KitchenAid, Bosch common</div>
        </div>
        <div class="community-card">
          <div class="community-name">Central Thousand Oaks</div>
          <div class="community-detail">91360 · All brands · Townhomes & single-family</div>
        </div>
        <div class="community-card">
          <div class="community-name">Westlake Village adjacent</div>
          <div class="community-detail">91361 · Premium homes · Sub-Zero and Wolf frequent</div>
        </div>
        <div class="community-card">
          <div class="community-name">Oak Park / Agoura Hills</div>
          <div class="community-detail">Adjacent coverage · All brands · Same-day route</div>
        </div>
        <div class="community-card">
          <div class="community-name">Moorpark</div>
          <div class="community-detail">93021 · Adjacent Ventura County · Same-day covered</div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="to-services">
    <div class="container">
      <h2 class="section-title">What We Repair in Thousand Oaks</h2>
      <p class="section-sub">Luxury & standard brands · Conejo Valley climate aware · All ZIP codes</p>
      <div class="services-grid">

        <a href="/thousand-oaks/refrigerator-repair/" class="service-card service-card--highlight">
          <div class="service-card__icon">🧊</div>
          <div class="service-card__name">Refrigerator Repair</div>
          <div class="service-card__issues">Dusty coil inspection · Sub-Zero built-in · Not cooling · Ice maker</div>
          <div class="service-card__brands">Sub-Zero · Samsung · LG · GE · Thermador · Bosch</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/thousand-oaks/oven-repair/" class="service-card service-card--highlight">
          <div class="service-card__icon">🔥</div>
          <div class="service-card__name">Oven, Range & Pro Range</div>
          <div class="service-card__issues">Thermador pro-style · Wolf dual-fuel · Gas igniter · Temperature off</div>
          <div class="service-card__brands">Wolf · Thermador · Gaggenau · Viking · GE · Samsung</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/thousand-oaks/dishwasher-repair/" class="service-card service-card--highlight">
          <div class="service-card__icon">🍽️</div>
          <div class="service-card__name">Dishwasher Repair</div>
          <div class="service-card__issues">Miele · Bosch · Panel-ready · Not draining · Error codes</div>
          <div class="service-card__brands">Miele · Bosch · Thermador · KitchenAid · Samsung · GE</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/thousand-oaks/washer-repair/" class="service-card">
          <div class="service-card__icon">🫧</div>
          <div class="service-card__name">Washer Repair</div>
          <div class="service-card__issues">OE / UE error · Not draining · Not spinning · Error codes</div>
          <div class="service-card__brands">LG · Samsung · Whirlpool · Maytag · Bosch · Speed Queen</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/thousand-oaks/dryer-repair/" class="service-card">
          <div class="service-card__icon">♨️</div>
          <div class="service-card__name">Dryer Repair + Vent Cleaning</div>
          <div class="service-card__issues">Not heating · Thermal fuse · Vent buildup · Gas & electric</div>
          <div class="service-card__brands">LG · Samsung · GE · Maytag · Whirlpool · Miele</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/thousand-oaks/freezer-repair/" class="service-card">
          <div class="service-card__icon">❄️</div>
          <div class="service-card__name">Freezer & Ice Maker Repair</div>
          <div class="service-card__issues">Not freezing · Ice stopped · Frost buildup · Sub-Zero</div>
          <div class="service-card__brands">Sub-Zero · Samsung · LG · GE · True · Whirlpool</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/thousand-oaks/wine-cellar-repair/" class="service-card">
          <div class="service-card__icon">🍷</div>
          <div class="service-card__name">Wine Cellar & Cooler Repair</div>
          <div class="service-card__issues">Temperature off · WhisperKOOL · Sub-Zero wine · Compressor</div>
          <div class="service-card__brands">Sub-Zero · EuroCave · True · WhisperKOOL · Liebherr</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/thousand-oaks/cooktop-repair/" class="service-card">
          <div class="service-card__icon">🔆</div>
          <div class="service-card__name">Cooktop & Range Hood</div>
          <div class="service-card__issues">Thermador star burner · Wolf igniter · Induction · Hood motor</div>
          <div class="service-card__brands">Wolf · Thermador · Gaggenau · Miele · Viking · Dacor</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

      </div>
    </div>
  </section>

  <!-- RECENT REPAIRS -->
  <section class="to-recent">
    <div class="container">
      <h2>Recent Jobs in Thousand Oaks</h2>
      <p class="section-sub">Real calls from Conejo Valley — luxury kitchens, gated communities, hot dry climate.</p>
      <div class="recent-grid">

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">Sub-Zero Built-In Fridge</span>
            <span class="recent-location">Dos Vientos, 91362</span>
          </div>
          <div class="recent-card__title">"Running longer and longer — electric bill noticeably higher"</div>
          <div class="recent-card__desc">
            Dos Vientos estate — gate access coordinated through the property manager.
            Sub-Zero 48-inch built-in with condenser coils packed with fine dust
            and debris from hillside landscaping. The dry Conejo Valley air carries
            significant particulate in the summer months. Thorough coil cleaning,
            inspected the condenser fan, confirmed door seal integrity across both
            columns. Cycling immediately returned to normal intervals. Placed on
            an 8-month inspection schedule appropriate for a hillside property with
            active landscaping. Sub-Zero recommends annual — Dos Vientos hillside
            properties realistically need it twice.
          </div>
          <div class="recent-card__result">✓ Same day · Gate coordinated · Coils cleaned · 8-month plan · Normal cycling</div>
        </div>

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">Thermador Pro Range</span>
            <span class="recent-location">North Ranch, 91361</span>
          </div>
          <div class="recent-card__title">"Two star burners not lighting — clicking but no flame"</div>
          <div class="recent-card__desc">
            North Ranch home — Thermador 48-inch pro range with two ExtraLow
            star burners failing to light. Found both igniter electrodes weakened
            and one with a small crack from thermal cycling — common in high-use
            pro ranges in active cooking households. Replaced both igniter assemblies
            with OEM Thermador parts, tested all six burners and both oven cavities.
            Also calibrated the left oven after the owner mentioned it was running
            slightly cool. All temperatures confirmed accurate within 5 degrees.
          </div>
          <div class="recent-card__result">✓ Same day · OEM Thermador igniters · All burners · Ovens calibrated</div>
        </div>

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">Miele Dishwasher</span>
            <span class="recent-location">Lynn Ranch, 91360</span>
          </div>
          <div class="recent-card__title">"F11 error — no water filling, machine completely stopped"</div>
          <div class="recent-card__desc">
            Lynn Ranch home — Miele G 7000 F11 water intake fault. Found the
            water inlet valve assembly partially blocked — not hard water scale
            (Thousand Oaks water is moderate hardness) but fine sediment from
            the household supply. The sediment filter screen in the valve was
            clogged. Cleared the inlet filter, tested valve flow, replaced the
            valve given partial obstruction had been stressing the solenoid.
            Ran the Miele diagnostics cycle, confirmed full water intake on
            three cycles. Also performed a maintenance descale cycle given
            the age of the machine.
          </div>
          <div class="recent-card__result">✓ Same day · F11 resolved · OEM Miele valve · Diagnostic cycle clear</div>
        </div>

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">LG Washer</span>
            <span class="recent-location">Central Thousand Oaks, 91360</span>
          </div>
          <div class="recent-card__title">"UE error every cycle — violent vibration even with small loads"</div>
          <div class="recent-card__desc">
            LG front-loader in a Thousand Oaks single-family — UE unbalanced
            error on every cycle regardless of load size or distribution.
            Found two rear shock absorbers failed and two more weakened.
            Replaced all four with OEM LG parts, levelled the machine, tested
            three full spin cycles at maximum speed. Completely smooth.
            The family had assumed they were overloading — they weren't.
            The shocks had been degrading for months and triggering the
            balance sensor even with correctly distributed loads.
          </div>
          <div class="recent-card__result">✓ Same day · OEM LG shocks · All four replaced · Full spin confirmed</div>
        </div>

      </div>
    </div>
  </section>

  <!-- WHY US -->
  <section class="to-why">
    <div class="container">
      <h2>Why Thousand Oaks Calls Us Back</h2>
      <div class="why-grid">
        <div class="why-card">
          <div class="why-icon">🌡️</div>
          <div class="why-title">Conejo Valley Climate Aware</div>
          <div class="why-text">Hot, dry Thousand Oaks summers push significant dust through hillside condenser coils — especially near active landscaping. We check coils on every relevant TO refrigerator call. This isn't a coastal salt-air issue; it's a dry-climate dust load issue specific to the Conejo Valley.</div>
        </div>
        <div class="why-card">
          <div class="why-icon">🏡</div>
          <div class="why-title">Luxury Brands — All of Them</div>
          <div class="why-text">Sub-Zero, Thermador, Wolf, Miele, Gaggenau, Viking — all common throughout Thousand Oaks from Dos Vientos to Westlake Village. We carry OEM parts for these brands on every vehicle and are trained on the specific failure modes of each. No generics, no substitutes.</div>
        </div>
        <div class="why-card">
          <div class="why-icon">🔐</div>
          <div class="why-title">Gated Community Ready</div>
          <div class="why-text">Dos Vientos, North Ranch, and other gated Thousand Oaks communities require coordinated access. We handle the gate logistics professionally, work with property managers and household staff, and arrive on time — not in a sedan, not without calling ahead.</div>
        </div>
        <div class="why-card">
          <div class="why-icon">✅</div>
          <div class="why-title">90-Day Warranty, OEM Only</div>
          <div class="why-text">Every repair backed by 90 days on parts and labor. Genuine OEM parts only. $89 diagnostic waived with repair. Written estimate before we start. Local Thousand Oaks branch. California licensed, BBB A+ rated.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="to-reviews">
    <div class="container">
      <h2>What Thousand Oaks Customers Are Saying</h2>
      <div class="reviews-grid">
        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <div class="review-text">"Sub-Zero in our Dos Vientos home was running constantly and our electric bill had spiked. Same Day coordinated gate access through our property manager, cleaned the dusty coils from our hillside landscaping, put us on an 8-month schedule. Back to normal immediately. They understood the hillside dust issue specifically — not just generic advice."</div>
          <div class="review-author">— Patricia N. (via property manager), Dos Vientos</div>
        </div>
        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <div class="review-text">"Thermador 48-inch range with two star burners clicking but not lighting. Same Day came out, replaced both igniter assemblies with OEM Thermador parts, tested everything, then calibrated the oven because I mentioned it was running cool. Done in under 90 minutes. This is what service for a premium appliance should look like."</div>
          <div class="review-author">— Michael T., North Ranch, Thousand Oaks</div>
        </div>
        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <div class="review-text">"Miele dishwasher F11 error in our Lynn Ranch home. Tech found the inlet filter clogged with sediment, replaced the valve with OEM Miele parts, ran the full diagnostic cycle. Explained the difference between hard water scale and sediment blockage — our water here is moderate hardness but the sediment was the culprit. Very thorough."</div>
          <div class="review-author">— Karen L., Lynn Ranch, Thousand Oaks</div>
        </div>
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section class="to-pricing">
    <div class="container">
      <h2 class="section-title">Appliance Repair Costs in Thousand Oaks</h2>
      <p class="section-sub">Written estimate before we start. $89 diagnostic — waived with repair. OEM parts only.</p>
      <div class="pricing-grid">
        <div class="pricing-card featured">
          <div class="pricing-card__appliance">Sub-Zero / Wolf / Gaggenau</div>
          <div class="pricing-card__range">$300 – $800+</div>
          <div class="pricing-card__note">OEM parts · Conejo Valley coil inspection · Gated access</div>
        </div>
        <div class="pricing-card featured">
          <div class="pricing-card__appliance">Thermador / Miele / Viking</div>
          <div class="pricing-card__range">$250 – $600+</div>
          <div class="pricing-card__note">OEM parts · Pro-style ranges · Panel-ready dishwashers</div>
        </div>
        <div class="pricing-card">
          <div class="pricing-card__appliance">Refrigerator (standard)</div>
          <div class="pricing-card__range">$150 – $400</div>
          <div class="pricing-card__note">Conejo dust coil check · Fan motor · Ice maker · Thermostat</div>
        </div>
        <div class="pricing-card">
          <div class="pricing-card__appliance">Washer / Dryer</div>
          <div class="pricing-card__range">$150 – $350</div>
          <div class="pricing-card__note">Hall sensor · Drain pump · Thermal fuse · Vent cleaning</div>
        </div>
        <div class="pricing-card">
          <div class="pricing-card__appliance">Dishwasher / Oven</div>
          <div class="pricing-card__range">$150 – $450</div>
          <div class="pricing-card__note">Miele · Bosch · Gas igniter · Error codes · Calibration</div>
        </div>
        <div class="pricing-card">
          <div class="pricing-card__appliance">Diagnostic Fee</div>
          <div class="pricing-card__range">$89</div>
          <div class="pricing-card__note">Waived when you proceed with the repair</div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="to-faq">
    <div class="container">
      <h2>Questions Thousand Oaks Customers Ask</h2>
      <div class="faq-list">
        <details class="faq-item"><summary class="faq-question">Do you offer same-day appliance repair in Thousand Oaks, CA?</summary><div class="faq-answer">Yes. Our Thousand Oaks branch covers all of 91360, 91361, 91362, and 91320 — Dos Vientos, Lynn Ranch, Newbury Park, North Ranch, and all communities throughout the Conejo Valley. Call before noon for same-day afternoon service.</div></details>
        <details class="faq-item"><summary class="faq-question">Does the hot, dry Conejo Valley climate affect appliances in Thousand Oaks?</summary><div class="faq-answer">Yes. Hot, dry summers with hillside dust load cause refrigerator condenser coils to accumulate debris faster than coastal environments. We check coils on every relevant TO refrigerator call — it's a consistent finding, especially in hillside properties.</div></details>
        <details class="faq-item"><summary class="faq-question">Do you repair Sub-Zero, Thermador, Miele, and Wolf appliances in Thousand Oaks?</summary><div class="faq-answer">Yes. Sub-Zero, Wolf, Thermador, Miele, Viking, and Gaggenau are common throughout Thousand Oaks. We carry OEM parts for these brands on every vehicle and are trained on their specific systems.</div></details>
        <details class="faq-item"><summary class="faq-question">Can you service appliances in Dos Vientos and other gated communities?</summary><div class="faq-answer">Yes. We coordinate gate access in advance and work with property managers and household staff. Gated community logistics are a routine part of our Thousand Oaks calls.</div></details>
        <details class="faq-item"><summary class="faq-question">Are you available on weekends in Thousand Oaks?</summary><div class="faq-answer">Yes. Saturday 8am–7pm and Sunday 9am–5pm.</div></details>
        <details class="faq-item"><summary class="faq-question">What is your diagnostic fee in Thousand Oaks?</summary><div class="faq-answer">Our diagnostic fee is $89, waived when you proceed with the repair. Written estimate before we start. Most Thousand Oaks repairs run $150–$450.</div></details>
        <details class="faq-item"><summary class="faq-question">Do you also serve Westlake Village, Calabasas, and Simi Valley?</summary><div class="faq-answer">Yes. Our Thousand Oaks service extends to Westlake Village, Calabasas, Agoura Hills, Oak Park, Moorpark, and Simi Valley — all Conejo Valley and surrounding communities.</div></details>
      </div>
    </div>
  </section>

  <!-- NEARBY -->
  <section class="to-nearby">
    <div class="container">
      <h2>Also Serving Nearby Areas</h2>
      <div class="nearby-grid">
        <a href="/calabasas/" class="nearby-link">Calabasas</a>
        <a href="/west-hollywood/" class="nearby-link">West Hollywood</a>
        <a href="/bel-air/" class="nearby-link">Bel Air</a>
        <a href="/beverly-hills/" class="nearby-link">Beverly Hills</a>
        <a href="/pacific-palisades/" class="nearby-link">Pacific Palisades</a>
        <a href="/malibu/" class="nearby-link">Malibu</a>
        <a href="/los-angeles/" class="nearby-link">Los Angeles</a>
        <a href="/pasadena/" class="nearby-link">Pasadena</a>
      </div>
    </div>
  </section>

  <!-- BOTTOM CTA -->
  <section class="to-bottom-cta">
    <div class="container">
      <div class="bottom-cta__inner">
        <div class="bottom-cta__text">
          <h2>Appliance broken in Thousand Oaks?</h2>
          <p>Dos Vientos · North Ranch · Lynn Ranch · Sub-Zero · Thermador · Miele · Gated communities welcome. $89 diagnostic waived with repair. 90-day warranty.</p>
        </div>
        <div class="bottom-cta__actions">
          <a href={`tel:${city.phoneRaw}`} class="btn-primary btn-large">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.29h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            {city.phone}
          </a>
          <a href="/book/" class="btn-secondary btn-large">Book Online</a>
        </div>
        <div class="bottom-cta__nap">
          <span>Same Day Appliance Repair — Thousand Oaks, CA · Conejo Valley</span>
          <span>·</span>
          <a href={`mailto:${city.email}`}>{city.email}</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  :root { --to-red: #C8102E; --to-black: #0a0a0a; --to-gray: #f5f5f5; --to-border: #e2e2e2; --to-text: #1a1a1a; --to-muted: #6b6b6b; }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  .to-hero { background: var(--to-black); color: white; padding: 80px 0 60px; }
  .to-hero__inner { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
  .to-hero__eyebrow { font-size: 13px; font-weight: 500; color: var(--to-red); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 16px; }
  .to-hero__h1 { font-size: clamp(36px, 5vw, 52px); font-weight: 700; line-height: 1.1; margin-bottom: 20px; color: white; }
  .to-hero__accent { color: var(--to-red); }
  .to-hero__sub { font-size: 17px; line-height: 1.6; color: rgba(255,255,255,0.75); margin-bottom: 32px; max-width: 520px; }
  .to-hero__ctas { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 24px; }
  .to-hero__rating { display: flex; align-items: center; gap: 10px; }
  .stars { color: #FFD700; font-size: 18px; letter-spacing: 2px; }
  .rating-text { font-size: 14px; color: rgba(255,255,255,0.7); }
  .to-hero__img-wrap img { width: 100%; height: auto; border-radius: 12px; object-fit: cover; }
  .btn-primary { display: inline-flex; align-items: center; gap: 8px; background: var(--to-red); color: white; padding: 14px 28px; border-radius: 8px; font-weight: 600; font-size: 16px; text-decoration: none; transition: background 0.2s; }
  .btn-primary:hover { background: #a50e25; }
  .btn-secondary { display: inline-flex; align-items: center; gap: 8px; background: transparent; color: white; padding: 14px 28px; border-radius: 8px; font-weight: 600; font-size: 16px; text-decoration: none; border: 1.5px solid rgba(255,255,255,0.35); }
  .btn-large { padding: 16px 36px; font-size: 17px; }
  .to-bottom-cta .btn-secondary { color: var(--to-text); border-color: var(--to-border); }
  .trust-bar { background: var(--to-red); padding: 16px 0; }
  .trust-bar__inner { display: flex; justify-content: space-between; flex-wrap: wrap; gap: 12px; }
  .trust-item { display: flex; align-items: center; gap: 8px; color: white; font-size: 14px; font-weight: 500; }
  .to-intro { padding: 72px 0; background: white; }
  .to-intro__inner { display: grid; grid-template-columns: 1fr 340px; gap: 60px; align-items: start; }
  .to-intro__text h2 { font-size: 28px; font-weight: 700; color: var(--to-black); margin-bottom: 20px; }
  .to-intro__text p { font-size: 16px; line-height: 1.7; color: var(--to-text); margin-bottom: 16px; }
  .to-tip { display: flex; gap: 14px; background: #fdf4e7; border: 1px solid #e8c97a; border-radius: 10px; padding: 16px 20px; margin-top: 24px; }
  .to-tip__icon { font-size: 20px; flex-shrink: 0; }
  .to-tip__text { font-size: 14px; color: var(--to-text); line-height: 1.6; }
  .cta-box { background: var(--to-black); color: white; border-radius: 12px; padding: 32px; text-align: center; position: sticky; top: 80px; }
  .cta-box__title { font-size: 18px; font-weight: 700; margin-bottom: 4px; }
  .cta-box__sub { font-size: 13px; color: rgba(255,255,255,0.6); margin-bottom: 24px; }
  .cta-box__phone { display: block; font-size: 24px; font-weight: 700; color: var(--to-red); text-decoration: none; margin-bottom: 12px; }
  .cta-box__book { display: block; font-size: 15px; color: white; text-decoration: none; padding: 12px; border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; margin-bottom: 16px; }
  .cta-box__hours { font-size: 12px; color: rgba(255,255,255,0.5); }
  .to-communities { padding: 72px 0; background: var(--to-gray); }
  .community-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
  .community-card { background: white; border: 1px solid var(--to-border); border-radius: 10px; padding: 18px 20px; }
  .community-card--featured { border-color: var(--to-red); background: #fff5f7; }
  .community-name { font-size: 15px; font-weight: 600; color: var(--to-black); margin-bottom: 6px; }
  .community-detail { font-size: 13px; color: var(--to-muted); line-height: 1.5; }
  .section-title { font-size: 30px; font-weight: 700; color: var(--to-black); margin-bottom: 8px; text-align: center; }
  .section-sub { font-size: 16px; color: var(--to-muted); text-align: center; margin-bottom: 40px; }
  .to-services { padding: 72px 0; background: white; }
  .services-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
  .service-card { background: white; border: 1px solid var(--to-border); border-radius: 12px; padding: 24px 20px; text-decoration: none; color: var(--to-text); transition: box-shadow 0.2s, transform 0.2s; display: block; }
  .service-card:hover { box-shadow: 0 4px 24px rgba(0,0,0,0.1); transform: translateY(-2px); }
  .service-card--highlight { border-color: var(--to-red); background: #fff5f7; }
  .service-card__icon { font-size: 28px; margin-bottom: 10px; }
  .service-card__name { font-size: 16px; font-weight: 600; color: var(--to-black); margin-bottom: 8px; }
  .service-card__issues { font-size: 13px; color: var(--to-muted); line-height: 1.5; margin-bottom: 8px; }
  .service-card__brands { font-size: 12px; color: var(--to-muted); margin-bottom: 12px; }
  .service-card__cta { font-size: 13px; color: var(--to-red); font-weight: 500; }
  .to-recent { padding: 72px 0; background: var(--to-gray); }
  .to-recent h2 { font-size: 30px; font-weight: 700; color: var(--to-black); margin-bottom: 8px; text-align: center; }
  .recent-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .recent-card { background: white; border: 1px solid var(--to-border); border-radius: 12px; padding: 24px; }
  .recent-card__header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; flex-wrap: wrap; gap: 6px; }
  .recent-badge { background: var(--to-red); color: white; font-size: 11px; font-weight: 600; padding: 3px 10px; border-radius: 20px; }
  .recent-location { font-size: 12px; color: var(--to-muted); }
  .recent-card__title { font-size: 15px; font-weight: 600; color: var(--to-black); margin-bottom: 10px; font-style: italic; }
  .recent-card__desc { font-size: 14px; color: var(--to-text); line-height: 1.6; margin-bottom: 12px; }
  .recent-card__result { font-size: 13px; color: #2a7a2a; font-weight: 500; }
  .to-why { padding: 72px 0; background: white; }
  .to-why h2 { font-size: 30px; font-weight: 700; color: var(--to-black); margin-bottom: 40px; text-align: center; }
  .why-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
  .why-card { background: var(--to-gray); border-radius: 12px; padding: 28px 24px; }
  .why-icon { font-size: 28px; margin-bottom: 14px; }
  .why-title { font-size: 16px; font-weight: 600; color: var(--to-black); margin-bottom: 10px; }
  .why-text { font-size: 14px; color: var(--to-muted); line-height: 1.6; }
  .to-reviews { padding: 72px 0; background: var(--to-gray); }
  .to-reviews h2 { font-size: 30px; font-weight: 700; color: var(--to-black); margin-bottom: 40px; text-align: center; }
  .reviews-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .review-card { background: white; border: 1px solid var(--to-border); border-radius: 12px; padding: 28px; }
  .review-stars { color: #FFD700; font-size: 18px; margin-bottom: 12px; }
  .review-text { font-size: 14px; color: var(--to-text); line-height: 1.7; margin-bottom: 16px; font-style: italic; }
  .review-author { font-size: 13px; color: var(--to-muted); font-weight: 500; }
  .to-pricing { padding: 72px 0; background: white; }
  .pricing-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 20px; }
  .pricing-card { background: var(--to-gray); border-radius: 10px; padding: 20px 24px; border: 1px solid var(--to-border); }
  .pricing-card.featured { background: #fff5f7; border-color: var(--to-red); }
  .pricing-card__appliance { font-size: 14px; color: var(--to-muted); margin-bottom: 6px; }
  .pricing-card__range { font-size: 22px; font-weight: 700; color: var(--to-black); margin-bottom: 6px; }
  .pricing-card.featured .pricing-card__range { color: var(--to-red); }
  .pricing-card__note { font-size: 13px; color: var(--to-muted); }
  .to-faq { padding: 72px 0; background: var(--to-gray); }
  .to-faq h2 { font-size: 30px; font-weight: 700; color: var(--to-black); margin-bottom: 40px; text-align: center; }
  .faq-list { max-width: 800px; margin: 0 auto; }
  .faq-item { border: 1px solid var(--to-border); border-radius: 8px; background: white; margin-bottom: 10px; overflow: hidden; }
  .faq-question { padding: 18px 24px; font-size: 16px; font-weight: 600; color: var(--to-black); cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; }
  .faq-question::after { content: '+'; font-size: 22px; color: var(--to-red); flex-shrink: 0; margin-left: 16px; }
  details[open] .faq-question::after { content: '−'; }
  .faq-answer { padding: 0 24px 20px; font-size: 15px; line-height: 1.7; color: var(--to-text); }
  .to-nearby { padding: 48px 0; background: white; border-top: 1px solid var(--to-border); }
  .to-nearby h2 { font-size: 20px; font-weight: 600; color: var(--to-black); margin-bottom: 20px; text-align: center; }
  .nearby-grid { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; }
  .nearby-link { padding: 8px 20px; border: 1px solid var(--to-border); border-radius: 20px; font-size: 14px; color: var(--to-text); text-decoration: none; transition: border-color 0.2s, color 0.2s; }
  .nearby-link:hover { border-color: var(--to-red); color: var(--to-red); }
  .to-bottom-cta { padding: 72px 0; background: var(--to-black); color: white; }
  .bottom-cta__inner { text-align: center; }
  .bottom-cta__text h2 { font-size: 34px; font-weight: 700; color: white; margin-bottom: 12px; }
  .bottom-cta__text p { font-size: 16px; color: rgba(255,255,255,0.7); margin-bottom: 32px; }
  .bottom-cta__actions { display: flex; gap: 12px; justify-content: center; margin-bottom: 24px; flex-wrap: wrap; }
  .bottom-cta__nap { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; font-size: 13px; color: rgba(255,255,255,0.4); }
  .bottom-cta__nap a { color: rgba(255,255,255,0.4); text-decoration: none; }
  @media (max-width: 1024px) { .services-grid { grid-template-columns: repeat(2, 1fr); } .why-grid { grid-template-columns: repeat(2, 1fr); } .reviews-grid { grid-template-columns: 1fr 1fr; } .to-intro__inner { grid-template-columns: 1fr; } .community-grid { grid-template-columns: repeat(2, 1fr); } .pricing-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 768px) { .to-hero__inner { grid-template-columns: 1fr; } .to-hero__img-wrap { display: none; } .recent-grid { grid-template-columns: 1fr; } .reviews-grid { grid-template-columns: 1fr; } .why-grid { grid-template-columns: 1fr 1fr; } .community-grid { grid-template-columns: 1fr 1fr; } .trust-bar__inner { justify-content: center; } }
  @media (max-width: 480px) { .services-grid { grid-template-columns: 1fr; } .why-grid { grid-template-columns: 1fr; } .pricing-grid { grid-template-columns: 1fr; } .community-grid { grid-template-columns: 1fr; } .to-hero { padding: 48px 0 40px; } .bottom-cta__text h2 { font-size: 26px; } }
</style>
