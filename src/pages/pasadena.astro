---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import CustomNarrative from '../components/cities/v2/CustomNarrative.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

const citySlug = 'pasadena';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = 'Pasadena';
const zips = ['91101', '91103', '91104', '91105', '91106', '91107'];

const phone = branch.phone;
const phoneRaw = `+1${phone.replace(/\D/g, '')}`;

const title = `Appliance Repair Pasadena CA — Same Day | All Brands | ${phone}`;
const description = `Same-day appliance repair in Pasadena, CA. Our technicians serve Old Town, South Pasadena, Arcadia, San Gabriel Valley. Refrigerator, washer, dryer, oven. Licensed, OEM parts, 90-day warranty. Call ${phone}.`;
const canonical = 'https://samedayappliance.repair/pasadena/';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { '@type': 'City', name: 'Pasadena', sameAs: 'https://en.wikipedia.org/wiki/Pasadena,_California' },
    { '@type': 'City', name: 'Arcadia' },
    { '@type': 'City', name: 'San Marino' },
    { '@type': 'City', name: 'South Pasadena' },
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$',
  license: 'CA BHGS #A49573'

};

const introParagraphs = [
  "Our technicians drive through Pasadena every single day — down Orange Grove past the Tournament of Roses houses, through Old Town where the restaurants need their walk-ins running, up into the hills near Caltech where you find everything from 1920s Craftsman kitchens to fully renovated modern appliances. We know this city.",
  "When you call Same Day Appliance Repair, you're not calling a dispatch center that'll send whoever is closest. You're calling our Pasadena team — the same technicians who've been fixing refrigerators on Garfield Ave, washers in South Pasadena, and commercial ovens on Colorado Blvd for years. We pick up the phone, we give you a straight answer, and if we can make it the same day — we will.",
  "Our diagnostic fee is <strong>$89</strong> — and that goes away the moment you say yes to the repair. We bring the written estimate to you before we touch anything. No surprises. Every job leaves with a <strong>90-day warranty</strong> on parts and labor.",
  "<strong>Quick tip from our techs:</strong> If your refrigerator is running constantly and the back feels warm, pull it out and vacuum the condenser coils at the bottom. In Pasadena's dry heat, dust buildup is the #1 cause of early compressor failure we see. Five minutes every six months can save you a $300+ repair.",
  "<strong>Dryer safety tip:</strong> A blocked dryer vent isn't just an appliance problem — it's a fire hazard. If your dryer takes two cycles to dry a normal load, the vent is likely restricted. We do dryer vent inspections and cleaning as part of every dryer repair call in Pasadena. Don't wait for a thermal fuse to blow to find out there's a problem.",
];

const services = [
  { icon: '🧊', name: 'Refrigerator Repair', slug: 'refrigerator', issues: 'Not cooling · Leaking · Ice maker down · Noisy · Freezer fine but fridge warm', brands: 'Sub-Zero · Samsung · LG · GE · Whirlpool · KitchenAid' },
  { icon: '🫧', name: 'Washer Repair', slug: 'washer', issues: 'Not spinning · Not draining · Leaking · Shaking · Error codes', brands: 'LG · Samsung · Whirlpool · Maytag · Bosch · Speed Queen' },
  { icon: '♨️', name: 'Dryer Repair', slug: 'dryer', issues: 'Not heating · Not spinning · Takes 2 cycles · Dryer vent cleaning · Gas & electric', brands: 'LG · Samsung · Maytag · GE · Whirlpool · Electrolux' },
  { icon: '🔥', name: 'Oven, Stove & Range Repair', slug: 'oven', issues: 'Not heating · Uneven baking · Igniter clicking · Gas valve issues · Control board', brands: 'Viking · Thermador · GE · Whirlpool · Bosch · Wolf' },
  { icon: '🍽️', name: 'Dishwasher Repair', slug: 'dishwasher', issues: "Not cleaning · Not draining · Leaking · Won't latch · Noisy", brands: 'Bosch · Miele · KitchenAid · Samsung · LG' },
  { icon: '🍷', name: 'Wine Cooler Repair', slug: 'wine-cooler', issues: 'Not cooling · Temperature swings · Compressor issues', brands: 'Sub-Zero · EuroCave · Liebherr · Thermador · Vinotemp' },
  { icon: '🔆', name: 'Cooktop Repair', slug: 'cooktop', issues: "Burner won't light · Induction not heating · Control issues", brands: 'Thermador · Viking · Bosch · GE · Miele' },
  { icon: '❄️', name: 'Freezer Repair', slug: 'freezer', issues: 'Not freezing · Ice buildup · Temperature drifting · Noisy', brands: 'Whirlpool · GE · Samsung · LG · Sub-Zero' },
];

const commercialNarrative = {
  eyebrow: 'For Old Town Restaurants & Businesses',
  headline: 'Commercial Appliance Repair in Pasadena',
  paragraphs: [
    "Old Town Pasadena has one of the densest restaurant districts in the San Gabriel Valley. Our technicians know what it means when a walk-in cooler goes down during dinner prep or a commercial dishwasher quits mid-service. That's not a \"schedule for next week\" situation — that's a phone call we pick up and respond to today.",
    "We repair commercial refrigerators, walk-in coolers and freezers, commercial ovens, dishwashers, and laundry units for Pasadena restaurants, cafés, hotels, and multi-unit properties. Same approach as our residential work: we diagnose it honestly, quote it upfront, and fix it right the first time.",
    "<strong>What we handle:</strong> Walk-in cooler & freezer repair — same day for emergencies. Commercial refrigerator & ice machine repair. Restaurant oven, range & dishwasher service. Call us for commercial pricing.",
  ]
};

const neighborhoods = [
  { name: 'Old Town Pasadena', zip: '91103', featured: true },
  { name: 'Caltech / South Lake Ave', zip: '91106', featured: true },
  { name: 'Historic Highlands', zip: '91105', featured: true },
  { name: 'Madison Heights', zip: '91101' },
  { name: 'Bungalow Heaven', zip: '91103' },
  { name: 'Lamanda Park', zip: '91107' },
  { name: 'San Rafael Hills', zip: '91107' },
  { name: 'Linda Vista', zip: '91103' },
  { name: 'Rose Bowl Area', zip: '91103' },
  { name: 'Hastings Ranch', zip: '91107' },
];

const keyStreets = ['Colorado Blvd', 'Orange Grove Blvd', 'Lake Ave', 'Walnut St', 'Foothill Blvd', 'Sierra Madre Blvd', 'Garfield Ave', 'Rosemead Blvd'];

const recentJobs = [
  {
    appliance: 'Sub-Zero Refrigerator',
    location: 'Historic Highlands, 91105',
    quote: 'Freezer working fine, but the fridge section is warm',
    description: "Classic evaporator fan failure in a Sub-Zero 650 — the fridge side stops cooling but freezer still runs. Our tech replaced the evaporator fan motor with an OEM Sub-Zero part, defrosted the coils, and tested the temperatures before leaving. Customer had dinner guests coming — we made it by 4pm.",
    outcome: '✓ Same day · OEM Sub-Zero part · 90-day warranty'
  },
  {
    appliance: 'Commercial Walk-In',
    location: 'Old Town Pasadena restaurant, 91103',
    quote: 'Walk-in cooler temperature rising during Friday lunch',
    description: "Owner called at 11:30am during service. We were there by 1pm. Found a failed condenser fan motor — the coils were icing over and blocking airflow. Replaced the fan, cleared the ice, ran the unit back down to temp. Restaurant stayed open. About $800 in product was saved.",
    outcome: '✓ Emergency same-day · Restaurant stayed open'
  },
  {
    appliance: 'LG Washer',
    location: 'Bungalow Heaven, 91103',
    quote: "OE error code, won't drain, clothes soaking wet",
    description: "OE on LG usually means a drain pump issue or a blocked filter. In this case — both. The pump was partially clogged and the impeller was cracked. Our tech cleaned the filter, replaced the drain pump assembly, and ran three cycles to confirm clean drainage. Customer had a mountain of wet laundry — we got her sorted by noon.",
    outcome: '✓ Completed same morning · OEM LG drain pump'
  },
  {
    appliance: 'Thermador Range',
    location: 'San Rafael Hills, 91107',
    quote: "Star burner igniter sparking constantly, won't stop",
    description: "Thermador Star burners are fantastic but they have a specific igniter design that wears differently than regular burners. The igniter switch was failing — it would trip and keep sparking even with the burner off. Replaced the igniter module. While there, we checked all five burners and the oven calibration. Everything good.",
    outcome: '✓ Same day · OEM Thermador igniter · Full check done'
  },
];

const whyReasons = [
  {
    iconKey: 'team' as const,
    title: 'We Pick Up the Phone',
    body: `When you call ${phone}, you're talking to our Pasadena team — not a national call center. We'll tell you honestly whether we can make it same day, and if we can't, we'll give you the next available slot that actually works.`
  },
  {
    iconKey: 'parts' as const,
    title: 'We Diagnose It Right',
    body: "Our technicians have seen every common failure pattern on every major brand. We don't replace parts hoping something works — we diagnose the actual problem first, explain it to you in plain language, and give you a real estimate."
  },
  {
    iconKey: 'clock' as const,
    title: 'Parts Are in the Van',
    body: 'We stock OEM parts for the most common failures on Samsung, LG, Whirlpool, GE, Bosch, Sub-Zero, Thermador and others. Most repairs are completed in one visit — no "we\'ll come back when the part arrives."'
  },
  {
    iconKey: 'shield' as const,
    title: 'We Stand Behind the Work',
    body: "Every repair we do comes with a 90-day warranty. If something goes wrong with the same part or the same issue within 90 days, we come back and fix it — no charge. That's not a marketing line, that's how we've kept customers in Pasadena coming back to us."
  },
];

const testimonials = [
  {
    stars: 5,
    text: '"Our Sub-Zero stopped cooling on a Thursday. I called Same Day Appliance Repair not really expecting same-day service for a Sub-Zero. They showed up by 2pm, had the part on the truck, and it was fixed before dinner. Genuinely impressed."',
    author: '— Catherine W., Historic Highlands, Pasadena'
  },
  {
    stars: 5,
    text: '"Our restaurant walk-in started warming up on a Friday morning. These guys picked up immediately, came within two hours, and had us back to temperature before the dinner rush. I keep their number saved and will call them every time."',
    author: '— Marco T., Restaurant owner, Old Town Pasadena'
  },
  {
    stars: 5,
    text: "\"The technician was straightforward, told me exactly what was wrong with my Thermador, gave me the price before starting, and fixed it cleanly. No upselling, no drama. That's rare. I've already recommended them to my neighbors on Orange Grove.\"",
    author: '— Robert H., San Rafael Hills, Pasadena'
  },
];

const pricingTiers = [
  { appliance: 'Refrigerator', range: '$200 – $450', note: 'Fan motor, thermostat, compressor relay, ice maker' },
  { appliance: 'Washer', range: '$150 – $350', note: 'Drain pump, door latch, bearing, control board' },
  { appliance: 'Dryer', range: '$150 – $320', note: 'Heating element, thermal fuse, drum roller, belt' },
  { appliance: 'Oven / Range', range: '$175 – $420', note: 'Igniter, bake element, gas valve, control board' },
  { appliance: 'Dishwasher', range: '$150 – $320', note: 'Drain pump, wash motor, door latch, spray arm' },
  { appliance: 'Diagnostic Fee', range: '$89', note: 'Waived when you proceed with the repair', featured: true },
];

const faqs = [
  {
    question: 'Do you offer same-day appliance repair in Pasadena, CA?',
    answer: "Yes. Our Pasadena technicians offer same-day service throughout the city — Old Town, South Pasadena, Arcadia, San Marino, La Cañada Flintridge, and across the San Gabriel Valley. Call us before noon and we'll do our best to be there the same afternoon. We serve ZIP codes 91101, 91103, 91104, 91105, 91106, and 91107."
  },
  {
    question: 'What appliances do your technicians repair in Pasadena?',
    answer: 'Our team repairs all major home and commercial appliances: refrigerators, washers, dryers, ovens, stoves, dishwashers, cooktops, freezers, wine coolers, microwaves, and range hoods. We work on all brands — from everyday Whirlpool and Samsung to high-end Sub-Zero, Viking, Thermador, and Miele.'
  },
  {
    question: 'How much does appliance repair cost in Pasadena?',
    answer: 'Most home appliance repairs in Pasadena run between $150 and $400 depending on the appliance and the issue. Our diagnostic fee is $89 and is waived when you go ahead with the repair. We give you a full written estimate before we start any work — no surprises on the invoice.'
  },
  {
    question: 'Do you repair Sub-Zero and Viking appliances in Pasadena?',
    answer: 'Yes. Pasadena has a lot of high-end appliances — Sub-Zero refrigerators, Viking ranges, Thermador cooktops — especially in the older estates and renovated Craftsman homes. Our technicians are trained on these brands and carry OEM parts for them on every service vehicle.'
  },
  {
    question: 'Do you also do commercial appliance repair in Pasadena?',
    answer: 'Yes. We repair commercial refrigerators, freezers, ovens, dishwashers, and walk-in coolers for Old Town Pasadena restaurants, cafés, and food businesses. Call us for commercial pricing. We understand that a down commercial fridge means lost product — we prioritize these calls.'
  },
  {
    question: 'What areas near Pasadena do you serve?',
    answer: 'Our Pasadena branch covers the wider San Gabriel Valley area including South Pasadena, Arcadia, San Marino, La Cañada Flintridge, Monrovia, Alhambra, Monterey Park, Glendale, Burbank, and North Hollywood.'
  },
  {
    question: 'What is your warranty on appliance repairs?',
    answer: 'Every repair comes with a 90-day warranty on both parts and labor. If the same problem comes back within 90 days, we return and fix it at no additional cost. We use genuine OEM parts — not aftermarket substitutes.'
  },
];

const nearbyCities = [
  { name: 'South Pasadena', slug: 'south-pasadena' },
  { name: 'Arcadia', slug: 'arcadia' },
  { name: 'San Marino', slug: 'san-marino' },
  { name: 'La Cañada Flintridge', slug: 'la-canada-flintridge' },
  { name: 'Glendale', slug: 'glendale' },
  { name: 'Burbank', slug: 'burbank' },
  { name: 'Alhambra', slug: 'alhambra' },
  { name: 'Monterey Park', slug: 'monterey-park' },
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair"
    headlineCity="Pasadena, CA"
    subheadline="Our Pasadena technicians are out on calls every day — Old Town, South Pasadena, Arcadia, San Marino, La Cañada. Same-day service, OEM parts, 90-day warranty. Call before noon and we're usually there today."
    zips={zips}
    tier={2}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance Repair in Pasadena — From Our Technicians"
    paragraphs={introParagraphs}
    bookingTitle="Talk to Our Pasadena Team"
    bookingSub="Same-day available · Call now"
  />

  <ServicesGrid
    cityName={cityName}
    headline="What We Fix in Pasadena"
    services={services}
  />

  <ServiceArea
    cityName={cityName}
    headline="Our Technicians Cover All of Pasadena & Surrounding Areas"
    subheadline="We're out in these neighborhoods every day — ZIP codes 91101 through 91107"
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={keyStreets}
  />

  <CustomNarrative
    eyebrow={commercialNarrative.eyebrow}
    headline={commercialNarrative.headline}
    paragraphs={commercialNarrative.paragraphs}
    background="black"
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Repairs Our Team Did in Pasadena"
    subhead="These are real jobs — not made up. Our technicians did these."
    jobs={recentJobs}
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="How We Work — Straight from the Team"
    reasons={whyReasons}
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What Pasadena Customers Are Saying"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Appliance Repair Costs in Pasadena — What to Expect"
    subhead="Honest estimates. Written before we start. Diagnostic fee waived with repair."
    tiers={pricingTiers}
    footnote="Premium brands (Sub-Zero, Viking, Thermador, Miele) may cost more due to OEM part pricing. We'll tell you upfront."
  />

  <FAQAccordion
    cityName={cityName}
    headline="Questions Our Pasadena Customers Ask"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby Areas"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance broken in Pasadena? Call us now."
    body="Our team is out on calls in Pasadena today. Diagnostic fee $89, waived with repair. 90-day warranty. We pick up the phone."
  />

