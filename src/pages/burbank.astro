<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair in"
    headlineCity="Burbank, CA"
    subheadline="Same-day service for all major appliances in Burbank — refrigerators, washers, dryers, ovens, dishwashers and more. Licensed technicians, OEM parts, 90-day warranty. Magnolia Park, Rancho, Toluca Lake, Media District."
    zips={zips}
    tier={1}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Our Team Is in Burbank Every Day"
    paragraphs={introParagraphs}
  />

  <ServicesGrid
    cityName={cityName}
    headline="Appliances We Repair in Burbank"
    services={services}
  />

  <ServiceArea
    cityName={cityName}
    headline="We Serve All Burbank Neighborhoods"
    subheadline="ZIP codes 91501 · 91502 · 91505 · 91506 — full coverage across the city"
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={keyStreets}
