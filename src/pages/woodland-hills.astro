---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import CustomNarrative from '../components/cities/v2/CustomNarrative.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

const citySlug = 'woodland-hills';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = 'Woodland Hills';
const zips = ['91364', '91367'];

const title = `Appliance Repair Woodland Hills CA | Valley Heat & Hard Water Specialists`;
const description = "Same-day appliance repair in Woodland Hills, CA 91364 & 91367. Hot Valley summers + LADWP hard water specialists. OEM parts.";
const canonical = 'https://samedayappliance.repair/woodland-hills/';

const phoneRaw = `+1${branch.phone.replace(/\D/g, '')}`;

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { '@type': 'Place', name: 'Woodland Hills', sameAs: 'https://en.wikipedia.org/wiki/Woodland_Hills,_Los_Angeles' },
    { '@type': 'Place', name: 'Walnut Acres' },
    { '@type': 'Place', name: 'Girard Tract' },
    { '@type': 'Place', name: 'College Acres' }
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$',
  license: 'BHGS #A49573'

};

const introParagraphs = [
  "Woodland Hills regularly records the highest summer temperatures in Los Angeles County. 100°F+ days are routine in July and August, and the appliance wear shows up exactly where you'd expect: refrigerator compressors run longer cycles, condenser coils accumulate dust faster in dry Valley air, and the cumulative load shortens compressor life if it's not addressed.",
  "If your refrigerator in Walnut Acres, Girard Tract, or College Acres is running longer cycles or louder than usual starting in late June, it's almost certainly due for a coil cleaning — not a failing compressor. This is the single most common finding our techs make in 91364 and 91367 every summer. Annual coil cleaning in May, before the heat season starts, is the most cost-effective maintenance you can do for a refrigerator in Woodland Hills.",
  "LADWP water hardness in this part of the Valley runs 230–310 mg/L. Ice maker inlet valves scale faster, dishwasher spray arms accumulate mineral deposits, and washing machine pump filters block from a combination of LADWP scale and lint. The combination of Valley heat stress on the mechanical side and LADWP scale on the water side means appliances in Woodland Hills need more attention than the manufacturer's generic schedule.",
  `Diagnostic fee is $89, credited toward repair when you proceed. Call <a href="tel:${phoneRaw}">${branch.phone}</a> for same-day service across 91364 and 91367.`,
  "<strong>Woodland Hills heat tip:</strong> If your refrigerator starts cycling more frequently or running louder starting in late June and through September, this is the Valley heat load on dusty condenser coils — not a failing compressor. Annual coil cleaning in May, before the heat season starts, is the most cost-effective maintenance you can do for a refrigerator in Woodland Hills. We offer this as a standalone service call."
];

const services = [
  { icon: '🧊', name: 'Refrigerator Repair', slug: 'refrigerator', issues: 'Valley heat coil inspection · LADWP ice maker · Not cooling · Fan motor', brands: 'Samsung · LG · GE · Whirlpool · Sub-Zero · KitchenAid' },
  { icon: '🫧', name: 'Washer Repair', slug: 'washer', issues: 'OE / UE error · Not draining · Not spinning · Error codes', brands: 'LG · Samsung · Whirlpool · Maytag · Bosch · Speed Queen' },
  { icon: '♨️', name: 'Dryer Repair + Vent Cleaning', slug: 'dryer', issues: 'Not heating · Thermal fuse · Vent buildup · Gas & electric', brands: 'LG · Samsung · GE · Maytag · Whirlpool · Electrolux' },
  { icon: '🍽️', name: 'Dishwasher Repair', slug: 'dishwasher', issues: 'LADWP spray arm scale · E24 · Not draining · Error codes', brands: 'Bosch · KitchenAid · Samsung · LG · GE · Miele' },
  { icon: '🔥', name: 'Oven, Range & Stove', slug: 'oven', issues: 'Not heating · Gas igniter · Temperature off · Element', brands: 'GE · Samsung · KitchenAid · Wolf · Thermador · Whirlpool' },
  { icon: '❄️', name: 'Freezer & Ice Maker Repair', slug: 'freezer', issues: 'LADWP inlet valve · Valley heat stress · Not freezing · Frost', brands: 'Samsung · LG · GE · Whirlpool · Sub-Zero · True' },
  { icon: '🍷', name: 'Wine Cooler Repair', slug: 'wine-cooler', issues: 'Temperature off · Valley heat stress · Compressor · Built-in', brands: 'True · U-Line · Liebherr · Sub-Zero · Dacor' },
  { icon: '🔆', name: 'Cooktop & Range Hood', slug: 'cooktop', issues: 'Gas igniter · Burner · Induction not heating · Hood motor', brands: 'GE · Bosch · Samsung · Wolf · KitchenAid · Broan' }
];

const neighborhoods = [
  { name: 'Walnut Acres', zip: '91364', featured: true },
  { name: 'Girard Tract', zip: '91364', featured: true },
  { name: 'College Acres', zip: '91364', featured: true },
  { name: 'Carlson Park', zip: '91367' },
  { name: 'Vista De Oro', zip: '91364' },
  { name: 'Woodland Hills Estates', zip: '91367' }
];

const recentJobs = [
  {
    appliance: 'Samsung French Door',
    location: 'Walnut Acres, 91364',
    quote: 'Running all day during the heat wave — electric bill doubled',
    description: "Walnut Acres home during a July heat wave — Samsung French door running near-continuously for three weeks, visible on the energy bill. Condenser coils loaded with a full season of Valley dust and debris, plus the refrigerator was located against a wall with less than 2 inches of clearance in an uncooled pantry room. Deep coil cleaning, repositioned slightly for better clearance, confirmed stable cycling within 40 minutes of service. Recommended annual pre-summer coil cleaning each May before the heat season — Valley refrigerators need this, coastal ones generally don't.",
    outcome: '✓ Same day · Coils cleaned · Cycling normalized · Annual May plan set'
  },
  {
    appliance: 'LG Washer',
    location: 'College Acres, 91364',
    quote: 'UE error on every load — shaking violently even half-full',
    description: "College Acres home — LG front-loader UE unbalanced error on every cycle. Found two rear shock absorbers fully failed and two more significantly weakened — causing the drum to vibrate independently of the balance sensor's threshold. Replaced all four OEM LG shock absorbers, levelled the machine on the laundry room floor, ran three full spin cycles at maximum speed. Quiet and smooth from the first test load. Family had been running half-loads trying to prevent the shaking — the shocks were the issue regardless of load size.",
    outcome: '✓ Same day · OEM LG shocks all four · Levelled · Full spin confirmed'
  },
  {
    appliance: 'GE Gas Range',
    location: 'Girard Tract, 91364',
    quote: "Oven igniter glowing but won't light — been two weeks",
    description: "Girard Tract home — GE freestanding gas range with classic igniter failure: glowing visually but drawing insufficient current to open the gas valve. OEM GE igniter replaced in under 30 minutes. Tested at 325°F, 375°F, and 450°F — all accurate. Also inspected the four surface igniter electrodes while on-site given the kitchen's proximity to the pool area where humidity and outdoor air can accelerate electrode degradation — all four surface igniters confirmed healthy.",
    outcome: '✓ Same day · OEM GE igniter · All temps accurate · Surface igniters confirmed'
  },
  {
    appliance: 'Bosch Dishwasher',
    location: 'Carlson Park, 91367',
    quote: 'E24 drain error — third time in 18 months',
    description: "Carlson Park home — Bosch 800 series E24 drain error occurring for the third time. Previous two visits (different companies) had cleared the pump filter each time without addressing the root cause. Found: pump filter accumulating LADWP mineral scale faster than average due to 91367 water hardness, and the drain hose routed through a cabinet with a subtle partial kink that restricted flow enough to allow debris buildup. Cleared the filter, re-routed the hose with proper clearance and high-loop, confirmed three drain cycles. Set on a 4-month filter cleaning reminder for LADWP hardness. No fourth occurrence since.",
    outcome: '✓ Same day · E24 resolved · Root cause found · Hose re-routed · 4-month plan'
  }
];

const whyReasons = [
  {
    iconKey: 'shield' as const,
    title: 'Valley Heat Specialists',
    body: "100°F+ summers in Walnut Acres, Girard Tract, and the rest of 91364/91367 push refrigerator compressors and condenser coils harder than coastal homes. We diagnose with that load in mind and recommend the right pre-summer maintenance cadence for each home."
  },
  {
    iconKey: 'parts' as const,
    title: 'LADWP Hard Water Aware',
    body: '230–310 mg/L hardness across Woodland Hills shows up first on ice maker inlet valves, dishwasher spray arms, and washing machine pump filters. We address the root cause, not just the symptom — descale, replace, and explain the maintenance interval.'
  },
  {
    iconKey: 'team' as const,
    title: 'Every Neighbourhood',
    body: 'Walnut Acres, Girard Tract, College Acres, Carlson Park, Vista De Oro, Woodland Hills Estates — we cover every part of 91364 and 91367 with a single Saturday-included schedule. No surcharge for elevated streets or gated entries.'
  },
  {
    iconKey: 'clock' as const,
    title: '90-Day Warranty, OEM Only',
    body: 'Every repair we do in Woodland Hills carries a 90-day warranty on parts and labor. We use OEM parts on every job. Same issue returns within 90 days — we come back at no charge.'
  }
];

const testimonials = [
  {
    stars: 5,
    text: '"Samsung fridge running constantly through the July heat wave, electric bill doubled. Tech came out, cleaned the Valley dust off the coils, showed me the clearance issue in my pantry room, recommended annual pre-summer cleaning. Normal cycling within the hour. This is exactly the Woodland Hills-specific knowledge I needed."',
    author: '— Linda T., Walnut Acres, 91364'
  },
  {
    stars: 5,
    text: '"Bosch dishwasher E24 error for the third time in 18 months — two other companies had cleared the filter without fixing anything. This tech found the hose kink and the LADWP hardness connection, re-routed the hose, put us on a 4-month filter plan. No fourth occurrence. Should have called them first."',
    author: '— Frank M., Carlson Park, 91367'
  },
  {
    stars: 5,
    text: '"LG washer shaking violently every cycle no matter the load size. Tech replaced all four shock absorbers with OEM parts, levelled the machine, confirmed three cycles before leaving. First quiet wash in months. Very professional and explained exactly why the load size didn\'t matter once the shocks are gone."',
    author: '— Maria G., College Acres, 91364'
  }
];

const pricingTiers = [
  { appliance: 'Refrigerator + Valley Coil Check', range: '$150–$400', note: 'Coil cleaning · LADWP inlet valve · Fan motor · Ice maker', featured: true },
  { appliance: 'Washer / Dryer', range: '$150–$350', note: 'OE/UE errors · Shock absorbers · Vent cleaning' },
  { appliance: 'Dishwasher', range: '$150–$320', note: 'LADWP spray arm descale · E24 · Pump filter' },
  { appliance: 'Oven / Range', range: '$150–$400', note: 'Igniter · Element · Temperature calibration' },
  { appliance: 'Sub-Zero / Wolf', range: '$300–$700+', note: 'OEM parts · Built-in column · Pro range' },
  { appliance: 'Diagnostic Fee', range: '$89', note: 'Credited toward repair · Written estimate' }
];

const faqs = [
  {
    question: 'Do you offer same-day appliance repair in Woodland Hills?',
    answer: "Yes — Woodland Hills is on our regular Valley route. We cover both 91364 and 91367 daily. Call before noon for same-day service."
  },
  {
    question: 'Does the hot Valley climate actually affect appliances in Woodland Hills?',
    answer: "Yes. Woodland Hills regularly records the highest summer temperatures in LA County — 100°F+ days are routine. Refrigerator compressors work harder in hot ambient conditions and condenser coils accumulate dust faster in dry Valley air. We see a predictable surge of refrigerator calls every June and July from appliances that were managing fine all spring. Annual pre-summer coil cleaning in May is the most cost-effective maintenance you can do here."
  },
  {
    question: 'How does LADWP hard water affect Woodland Hills appliances?',
    answer: "LADWP water hardness in 91364 and 91367 runs 230–310 mg/L. The most common impacts: ice maker inlet valves scale up faster, dishwasher spray arms accumulate mineral deposits that affect cleaning, and washing machine pump filters block from a combination of LADWP scale and lint. We descale and clean these on every relevant service call."
  },
  {
    question: 'What appliance brands do you repair in Woodland Hills?',
    answer: "All major brands: Samsung, LG, GE, Whirlpool, KitchenAid, Maytag, Bosch, Frigidaire, and luxury brands including Sub-Zero, Wolf, Thermador, and Miele. Walnut Acres and Girard Tract have a mix of mainstream and luxury suites; the Vista De Oro and Woodland Hills Estates areas tend toward higher-end builds. We carry OEM parts for all of these."
  },
  {
    question: 'Are weekend appointments available in Woodland Hills?',
    answer: "Yes — we offer Saturday appointments. Call to confirm the next available slot. Sunday appointments are limited but we answer the phone every day."
  },
  {
    question: 'What is your diagnostic fee in Woodland Hills?',
    answer: "Our diagnostic fee is $89. It covers the trip, full appliance inspection, and a written estimate. If you proceed with the repair, the $89 is credited toward your invoice."
  },
  {
    question: 'Do you also serve Calabasas, West Hills, and Tarzana from Woodland Hills?',
    answer: "Yes — our Valley coverage extends to Calabasas, West Hills, Tarzana, Canoga Park, and Chatsworth. Same-day service is typically available across this corridor."
  }
];

const nearbyCities = [
  { name: 'Calabasas', slug: 'calabasas' },
  { name: 'Thousand Oaks', slug: 'thousand-oaks' },
  { name: 'Encino', slug: 'encino' },
  { name: 'Sherman Oaks', slug: 'sherman-oaks' },
  { name: 'Studio City', slug: 'studio-city' },
  { name: 'West Hollywood', slug: 'west-hollywood' },
  { name: 'Beverly Hills', slug: 'beverly-hills' },
  { name: 'Los Angeles', slug: 'los-angeles' }
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair"
    headlineCity="Woodland Hills, CA"
    subheadline="Where the Valley meets the foothills — one of LA's hottest summer neighbourhoods, with the appliance wear to prove it. Hot Valley summers push refrigerator coils hard. LADWP hard water hits ice makers. We cover both. Same-day, OEM parts, 90-day warranty. All of 91364 and 91367."
    zips={zips}
    tier={2}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance Repair in Woodland Hills — The Valley Heat Factor"
    paragraphs={introParagraphs}
    bookingTitle="Woodland Hills Service"
    bookingSub="91364 · 91367 · Valley heat aware · Same day"
  />

  <ServicesGrid
    cityName={cityName}
    headline="What We Repair in Woodland Hills"
    services={services}
  />

  <ServiceArea
    cityName={cityName}
    headline="Woodland Hills Neighbourhoods We Service"
    subheadline="Walnut Acres, Girard Tract, College Acres, Carlson Park — every part of 91364 and 91367."
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={['Ventura Blvd', 'Topanga Canyon Blvd', 'Mulholland Dr (west)', 'De Soto Ave', 'Canoga Ave', 'Valley Circle Blvd']}
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Repairs in Woodland Hills"
    jobs={recentJobs}
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="Why Woodland Hills Residents Call Us"
    reasons={whyReasons}
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What Woodland Hills Clients Say"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Repair Pricing in Woodland Hills"
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="Frequently Asked Questions — Woodland Hills"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby Cities"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance broken in Woodland Hills?"
    body="Walnut Acres · Girard Tract · College Acres · Carlson Park · Valley heat + LADWP hard water aware. $89 diagnostic waived with repair. 90-day warranty."
  />
</CityLayoutV2>
