---
/**
 * West Hollywood, CA — v2 reference page.
 * Roman-approved live design rebuilt as composed v2 components.
 * Source content: legacy west-hollywood.astro.legacy (verbatim).
 *
 * Branch: West Hollywood (physical_pin) — only city with public street address.
 * Phone via cities.ts → branches.ts (no hardcoding).
 */

import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import NeighborhoodPhoto from '../components/cities/v2/NeighborhoodPhoto.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import LuxurySpecialists from '../components/cities/v2/LuxurySpecialists.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import PropertyManagers from '../components/cities/v2/PropertyManagers.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

import { mergeCredentials } from '../data/credentials-schema';
const citySlug = 'west-hollywood';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = 'West Hollywood';
const zips = ['90046', '90069', '90048'];

const title = `Appliance Repair West Hollywood CA — Same Day Service`;
const description = `Same-day appliance repair in West Hollywood, CA. Refrigerator, washer, dryer, oven. Sub-Zero + Thermador specialists. 90-day warranty. ${branch.phone}.`;
const canonical = 'https://samedayappliance.repair/west-hollywood/';

const phoneRaw = `+1${branch.phone.replace(/\D/g, '')}`;

// LocalBusiness schema — physical_pin so streetAddress is included.
const localBusinessSchema = mergeCredentials({
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  address: {
    '@type': 'PostalAddress',
    streetAddress: branch.address!.street,
    addressLocality: branch.address!.city,
    addressRegion: branch.address!.state,
    postalCode: branch.address!.zip,
    addressCountry: 'US'
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: branch.geo.cityCenterLat,
    longitude: branch.geo.cityCenterLng
  },
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  areaServed: { '@type': 'City', name: 'West Hollywood', sameAs: 'https://en.wikipedia.org/wiki/West_Hollywood,_California' },
  priceRange: '$$',
  license: 'BHGS #A49573',
  sameAs: [...(branch.sameAs ?? [])]
});

const introParagraphs = [
  "West Hollywood is one of our busiest service areas — our guys are out here constantly. The Sunset Strip high-rises, the vintage apartments off Melrose, the condos in Norma Triangle where the washer-dryer is stacked in a closet the size of a phone booth. We know this city, we know these buildings, and we know exactly what we're walking into before we knock on your door.",
  "When you search for same day appliance repair West Hollywood and call us, you're not getting a national dispatch center that'll send whoever happens to be free. You're calling our West Hollywood team — the same technicians who've been fixing Sub-Zeros off Robertson, Bosch dishwashers in Boystown, and Thermador ranges on the Strip for years. We pick up, we give you a straight answer, and if we can be there today — we will be.",
  "We charge <strong>$89</strong> to diagnose — and that disappears the moment you say yes to the repair. Full written estimate before we start. Every job covered by a <strong>90-day warranty</strong> on parts and labor."
];

const services = [
  { icon: '🧊', name: 'Refrigerator Repair', slug: 'refrigerator', issues: 'Not cooling · Leaking · Ice maker broken · Noisy compressor', brands: 'Sub-Zero · Samsung · LG · GE · Whirlpool' },
  { icon: '🫧', name: 'Washer Repair', slug: 'washer', issues: 'Not spinning · Not draining · Leaking · Error codes · Stackable & ventless combos', brands: 'LG · Samsung · Bosch · Miele · Maytag · Whirlpool' },
  { icon: '♨️', name: 'Dryer Repair', slug: 'dryer', issues: 'Not heating · Not spinning · Takes too long · Gas & electric', brands: 'LG · Samsung · GE · Maytag · Speed Queen' },
  { icon: '🔥', name: 'Oven & Stove Repair', slug: 'oven', issues: 'Not heating · Uneven temp · Igniter issues · Gas or electric', brands: 'Thermador · Viking · Wolf · GE · Bosch' },
  { icon: '🍽️', name: 'Dishwasher Repair', slug: 'dishwasher', issues: 'Not cleaning · Not draining · Leaking · Error codes', brands: 'Bosch · Miele · KitchenAid · Samsung · LG' },
  { icon: '🍷', name: 'Wine Cooler Repair', slug: 'wine-cooler', issues: 'Not cooling · Temperature off · Compressor issues · Noisy', brands: 'Sub-Zero · EuroCave · Liebherr · Vinotemp' },
  { icon: '🔆', name: 'Cooktop Repair', slug: 'cooktop', issues: 'Burner not working · Sparking · Induction issues', brands: 'Thermador · Bosch · GE · Viking · Miele' },
  { icon: '💨', name: 'Range Hood Repair', slug: 'range-hood', issues: 'Fan not working · Lights out · Motor failure · Noisy', brands: 'Zephyr · Broan · KitchenAid · Wolf · Thermador' }
];

const luxuryParagraphs = [
  "WeHo has more Sub-Zeros per block than almost anywhere in LA. Our technicians see them constantly — in the penthouses off Sunset, the renovated Craftsman kitchens in West Hollywood Heights, the luxury condos near Robertson. These aren't appliances you call just anyone about. A Sub-Zero with a failed evaporator fan or a Thermador with a sticking gas valve needs someone who actually knows the machine.",
  "Our team is trained on these brands specifically — the dual-compressor architecture in Sub-Zero refrigerators, the Star burner system in Thermador cooktops, how Viking gas valves behave when they age. We carry OEM parts for these brands on every service vehicle. Most luxury appliance repairs we complete in one visit without ordering anything.",
  "One thing our technicians mention to almost every Sub-Zero owner in WeHo: condenser coil cleaning. In West Hollywood's dry, dusty climate, coil buildup is the single most common cause of early compressor failure we see. A quick coil cleaning during our service visit — or once a year on your own — can prevent a $600+ compressor repair down the road."
];

const luxuryBrands = ['Sub-Zero', 'Viking', 'Thermador', 'Wolf', 'Miele', 'Bosch', 'Dacor', 'Fisher & Paykel'];

const neighborhoods = [
  { name: 'Norma Triangle', zip: '90046', featured: true },
  { name: 'Sunset Strip', zip: '90069', featured: true },
  { name: 'Melrose District', zip: '90046', featured: true },
  { name: 'West Hollywood West', zip: '90069' },
  { name: 'Boystown', zip: '90069' },
  { name: 'Kings Road', zip: '90069' },
  { name: 'Design District', zip: '90046' },
  { name: 'Santa Monica Blvd', zip: '90046' },
  { name: 'Fairfax District', zip: '90046' },
  { name: 'West Hollywood Heights', zip: '90046' }
];

const keyStreets = [
  'Santa Monica Blvd', 'Sunset Blvd', 'Melrose Ave', 'La Cienega Blvd',
  'Fountain Ave', 'Holloway Dr', 'Robertson Blvd', 'Beverly Blvd'
];

const propertyParagraphs = [
  "A significant part of our West Hollywood calls come from hosts and property managers. We get it — a fridge that stops cooling in a rental unit the night before a guest checks in is a genuine emergency, not a \"we'll be there Tuesday\" situation. Our technicians have been navigating WeHo buildings for years: the concierge buildings on Sunset, the older walk-ups off Melrose, the smart-lock units where you text us an access code.",
  "We work around your schedule, not ours. Tell us the check-in time and we'll make sure we're done before then. We leave the unit clean, appliance running, and we can send you a service confirmation for your records."
];

const propertyBullets = [
  'Coordinate with building management & concierge',
  'Key fob, smart lock & keybox access — no problem',
  'Certificate of Insurance (COI) available on request',
  'We leave units clean and guest-ready',
  'Same-day emergency service available for urgent situations'
];

const recentJobs = [
  { appliance: 'Sub-Zero Refrigerator', location: 'Robertson Blvd, 90046', quote: "Freezer is fine but the fridge side won't cool", description: "Classic evaporator fan failure on a Sub-Zero 650 — happens more than people realize in WeHo's dry climate. Our tech replaced the fan motor with an OEM Sub-Zero part, defrosted the coils that had iced over, and confirmed stable temperatures before leaving. Customer had dinner guests that evening — we were done by 4pm.", outcome: '✓ Same day · OEM Sub-Zero part · 90-day warranty' },
  { appliance: 'Bosch Dishwasher', location: 'Norma Triangle, 90069', quote: "Bosch 800 just sits there and doesn't drain", description: 'Found two things: a blockage in the drain pump and a cracked impeller that was letting water bypass. Cleared the blockage, replaced the drain pump assembly with an OEM Bosch part. Ran three full cycles before wrapping up — all clean. Building had tight hallway access, our tech brought a smaller kit. No drama.', outcome: '✓ Same day · OEM Bosch drain pump' },
  { appliance: 'LG Combo Dryer', location: 'Melrose District, 90046', quote: 'LG washer-dryer combo getting too hot and shutting off', description: "The building's internal exhaust duct was partially blocked — common in older WeHo apartments where venting runs a long way through the walls. The thermal fuse had already tripped from the heat. We cleared the duct, replaced the thermal fuse, and safety-tested before leaving. Told the tenant what to watch for going forward.", outcome: '✓ Same day · Duct cleared + fuse replaced' },
  { appliance: 'Thermador Range', location: 'Sunset Strip, 90069', quote: "Two burners sparking constantly, won't stop even when off", description: 'Both igniters had failed and were stuck in a loop — a known Thermador issue after a few years of use. Replaced both igniter modules with OEM Thermador parts, serviced the gas valve that was starting to stick, and tested all five burners plus the oven. Everything confirmed good before we left.', outcome: '✓ One visit · OEM Thermador parts · Full check done' }
];

const whyReasons = [
  { iconKey: 'clock' as const, title: 'We Actually Show Up Same Day', body: "Not \"we'll try.\" Call before noon and our WeHo technicians are typically at your door the same afternoon — weekdays and weekends. We know you can't just wait around all week." },
  { iconKey: 'parts' as const, title: 'The Part Is Usually on the Van', body: "We stock OEM parts for Sub-Zero, Thermador, Viking, Bosch, LG, Samsung, and the other brands we see most in WeHo. That's why 85% of our repairs are done in one visit — no \"we'll come back when it arrives.\"" },
  { iconKey: 'shield' as const, title: 'We Stand Behind the Work', body: "90-day warranty on every repair — parts and labor. If the same issue comes back within 90 days, we return and fix it at no charge. We're California licensed, insured, and BBB Accredited. That's not a logo — it means something to us." },
  { iconKey: 'team' as const, title: 'We Know WeHo Buildings', body: 'Parking permits, concierge access, service elevators, HOA rules — our technicians have dealt with all of it. We know which buildings on Sunset require a COI, which ones have key fob entry. Just tell us what to expect and we handle it.' }
];

const testimonials = [
  { stars: 5, text: '"My Sub-Zero stopped cooling on a Friday afternoon — nightmare timing. Called Same Day Appliance Repair, tech showed up in under three hours, had the part on his truck, and fixed it before dinner. I was genuinely shocked it went that smoothly."', author: '— Maria K., Norma Triangle' },
  { stars: 5, text: "\"I manage six rental units in WeHo. These guys are the only appliance repair company I call. They coordinate with my building managers, they show up when they say they will, and my tenants never have to follow up twice. That's worth everything in this business.\"", author: '— David R., Property Manager, West Hollywood West' },
  { stars: 5, text: '"Thermador oven stopped igniting two days before I was hosting a dinner party. Same-day appointment, technician replaced the igniters and serviced the gas valve, explained everything he was doing. Honest pricing, zero upselling. Left my kitchen cleaner than he found it."', author: '— Jennifer L., Sunset Strip' }
];

const pricingTiers = [
  { appliance: 'Refrigerator', range: '$200 – $450', note: 'Fan motor, thermostat, ice maker, compressor relay' },
  { appliance: 'Washer', range: '$150 – $350', note: 'Drain pump, door latch, bearing, stackable units' },
  { appliance: 'Dryer', range: '$150 – $320', note: 'Heating element, thermal fuse, vent cleaning, drum roller' },
  { appliance: 'Oven / Range', range: '$175 – $420', note: 'Igniter, bake element, gas valve, control board' },
  { appliance: 'Dishwasher', range: '$150 – $320', note: 'Drain pump, wash motor, door latch, spray arm' },
  { appliance: 'Diagnostic Fee', range: '$89', note: 'Waived when you proceed with the repair', featured: true }
];

const faqs = [
  { question: 'Do you offer same-day appliance repair in West Hollywood?', answer: 'Yes. We offer same-day service throughout West Hollywood, including the Sunset Strip, Melrose, Norma Triangle, and West Hollywood West. Call before noon and our technician can typically be at your door the same day. We serve ZIP codes 90046, 90069, and 90048.' },
  { question: 'Do you repair Sub-Zero and Thermador appliances in West Hollywood?', answer: 'Yes. We specialize in high-end appliance repair including Sub-Zero refrigerators, Thermador ovens and cooktops, Viking ranges, Bosch dishwashers, and Miele appliances. Our technicians are trained on luxury appliance systems and carry common OEM parts for these brands on every service vehicle.' },
  { question: 'What ZIP codes do you serve in West Hollywood?', answer: 'We serve all West Hollywood ZIP codes: 90046 (Sunset Strip, Melrose, Norma Triangle), 90069 (West Hollywood West, Santa Monica Blvd corridor), and 90048 (Beverly Grove / Fairfax border area).' },
  { question: 'Can you repair appliances in my Airbnb or rental unit in WeHo?', answer: 'Absolutely. We work regularly with Airbnb hosts, property managers, and short-term rental operators throughout West Hollywood. We coordinate with building management, handle key fob and concierge access, and work efficiently to keep your unit guest-ready. We provide a Certificate of Insurance (COI) on request — most high-rise buildings on Sunset Strip and Santa Monica Blvd require it, and we have it ready. Just let us know when you book.' },
  { question: 'What is your diagnostic fee in West Hollywood?', answer: 'Our diagnostic fee is $89, which is waived if you proceed with the repair — you only pay for the repair itself. We provide a full written estimate before any work begins, with no hidden fees.' },
  { question: 'What warranty do you offer on appliance repairs?', answer: 'All repairs come with a 90-day warranty on both parts and labor. If the same issue returns within 90 days, we come back and fix it at no additional charge. We use genuine OEM parts whenever available.' },
  { question: 'Do you service condos and apartment buildings in West Hollywood?', answer: 'Yes. West Hollywood is a dense city with many high-rises, condos, and multi-unit buildings. Our technicians are experienced with building access requirements including parking, service elevators, HOA rules, and concierge check-in. Just let us know the logistics when you book.' }
];

const nearbyCities = [
  { name: 'Beverly Hills', slug: 'beverly-hills' },
  { name: 'Hollywood', slug: 'hollywood' },
  { name: 'Brentwood', slug: 'brentwood' },
  { name: 'Silver Lake', slug: 'silver-lake' },
  { name: 'Los Feliz', slug: 'los-feliz' },
  { name: 'Los Angeles', slug: 'los-angeles' }
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair"
    headlineCity="West Hollywood, CA"
    subheadline="Same-day service on every major appliance. Sub-Zero, Thermador, Viking, Bosch, Samsung, LG — our licensed technicians cover all of WeHo from Norma Triangle to Sunset Strip."
    zips={zips}
    tier={1}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Our Technicians Are in WeHo Every Day"
    paragraphs={introParagraphs}
  />

  <NeighborhoodPhoto citySlug={citySlug} cityName={cityName} />

  <ServicesGrid cityName={cityName} services={services} />

  <LuxurySpecialists
    citySlug={citySlug}
    cityName={cityName}
    headline="Sub-Zero, Thermador & Viking Repair in West Hollywood"
    paragraphs={luxuryParagraphs}
    brands={luxuryBrands}
  />

  <ServiceArea
    cityName={cityName}
    cityShortName="WeHo"
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={keyStreets}
  />

  <PropertyManagers
    citySlug={citySlug}
    cityName={cityName}
    headline="Airbnb Hosts &amp; Property Managers — We Know How WeHo Works"
    paragraphs={propertyParagraphs}
    bullets={propertyBullets}
  />

  <RecentRepairs citySlug={citySlug} cityName={cityName} jobs={recentJobs} />

  <WhyCallsUsBack cityName={cityName} reasons={whyReasons} />

  <ReviewsBlock cityName={cityName} testimonials={testimonials} />

  <PricingCards cityName={cityName} tiers={pricingTiers} />

  <FAQAccordion cityName={cityName} faqs={faqs} />

  <AlsoServingNearby nearbyCities={nearbyCities} />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Need Appliance Repair in West Hollywood Today?"
    body="Call now — same-day service available for most repairs. Diagnostic fee $89, waived with repair. 90-day warranty on all work."
  />

