---
import Layout from '../../../layouts/Layout.astro';
import CommercialHero from '../../../components/CommercialHero.astro';
import { MAIN_PHONE } from '../../../data/branches';
const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/commercial/slicer-repair/motor-not-running/";
const title = "Commercial Slicer Motor Not Running LA | Capacitor, Brushes, Safety Interlock | $120";
const description = `Slicer motor won't run? LA same-day. Capacitor, motor brushes, safety interlock, switch, full motor failure. $120 commercial diagnostic. ${phone}.`;
const faqs = [
  { q: "Slicer powers on but motor won't engage. Most common cause?", a: "Safety interlock failure. Most commercial slicers (Hobart, Globe, Bizerba, Berkel) have safety interlocks at the door, blade guard, and on/off switch. Year 5-8 typical wear. Replacement runs $180-280." },
  { q: "Hum but no spin — capacitor?", a: "Yes, classic capacitor failure symptom. Motor energizes but can't start spinning due to bad capacitor. $80-180 capacitor replacement." },
  { q: "Motor brushes — when does this matter?", a: "Universal motors (most commercial slicers) use carbon brushes that wear with use. Year 6-9 typical brush life. Symptom: intermittent operation, sparking visible at brush, eventually motor won't run. $120-220 brush replacement." },
  { q: "Year 10+ slicer with motor failure — repair vs replace?", a: "Borderline. Year-10 mid-tier slicer (Globe GC512) with failed motor at $480-820 repair on $1,800-3,200 unit at end of design life is replace conversation. Premium tier (Hobart, Bizerba, Berkel) at year 10+ usually still justifies repair due to longer chassis life." },
  { q: "Switch issue — easy fix?", a: "Usually yes. On/off switch wear year 6-9, $120-220 replacement. We test switch operation as part of standard diagnostic." },
  { q: "Annual PM motor maintenance?", a: "Yes. PM ($120-180 motor-side) covers brush inspection, capacitor visual check, switch test. Catches issues before reactive failure." },
  { q: "What's your warranty?", a: "90 days SDAR labor and parts. Brand warranties through manufacturer authorized service. BHGS #A49573, BBB A+, EPA 608 Universal #1346255700410." }
];
const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business", "name": "Same Day Appliance Repair", "url": canonical, "telephone": phone, "priceRange": "$$",
    "openingHoursSpecification": [{ "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "08:00", "closes": "20:00" }],
    "areaServed": [{ "@type": "AdministrativeArea", "name": "Los Angeles County" },{ "@type": "AdministrativeArea", "name": "Orange County" },{ "@type": "AdministrativeArea", "name": "Ventura County" },{ "@type": "AdministrativeArea", "name": "San Bernardino County" },{ "@type": "AdministrativeArea", "name": "Riverside County" }]
  },
  { "@context": "https://schema.org", "@type": "Service", "@id": canonical + "#service", "serviceType": "Commercial Slicer Motor Not Running Repair", "name": "Slicer Motor Failure Diagnostic", "url": canonical,
    "description": "Commercial slicer motor diagnostic and repair across all five SoCal counties. Capacitor (year 6-9), motor brushes (year 6-9), safety interlock (year 5-8), switch failure, full motor replacement (year 8-12). $120 commercial diagnostic. BHGS #A49573, EPA 608 Universal #1346255700410.",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [{ "@type": "AdministrativeArea", "name": "Los Angeles County" },{ "@type": "AdministrativeArea", "name": "Orange County" },{ "@type": "AdministrativeArea", "name": "Ventura County" },{ "@type": "AdministrativeArea", "name": "San Bernardino County" },{ "@type": "AdministrativeArea", "name": "Riverside County" }],
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "120.00", "priceCurrency": "USD", "description": "Commercial diagnostic fee, applied toward repair" } }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
    { "@type": "ListItem", "position": 2, "name": "Commercial", "item": "https://samedayappliance.repair/commercial/" },
    { "@type": "ListItem", "position": 3, "name": "Slicer Repair", "item": "/commercial/slicer-repair/" },
    { "@type": "ListItem", "position": 4, "name": "Motor Not Running", "item": canonical }
  ]}
];
---
<Layout title={title} description={description} canonical={canonical}>
<Fragment slot="head-scripts">{schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}</Fragment>
<CommercialHero title="Commercial Slicer Motor Not Running, Same-Day Diagnostic"
  subtitle={`Capacitor, brushes, safety interlock, switch, full motor failure. $120 commercial. ${phone}`}
  heroImageTitle="Commercial Slicer Motor Not Running" showBranches={true} />

<section class="section"><div class="container narrow">
  <p class="section-number">Motor diagnostic</p>
  <h2>Five-step diagnostic, cheapest first. About 60 percent resolve at sub-$300 work.</h2>
  <p>Commercial slicer motor failures cluster around five mechanisms, by frequency. (1) Power supply (cord, plug, breaker) — about 5 percent of calls resolve at this. (2) Safety interlock (door switch, blade guard switch) wear year 5-8, $180-280. (3) Capacitor failure year 6-9, $80-180. (4) Motor brushes worn year 6-9, $120-220. (5) Full motor failure year 8-12, $480-820. About 60 percent of motor calls resolve at safety interlock, capacitor, or brushes (sub-$300 work).</p>
  <p>$120 commercial diagnostic, waived with repair. <strong>BHGS #A49573</strong>. <strong>EPA 608 Universal certified #1346255700410</strong>. BBB A+. Phones answered 24/7. Parent: <a href="/commercial/slicer-repair/">slicer repair</a>.</p>
</div></section>

<section class="section section-gray"><div class="container narrow">
  <p class="section-number">Field observations</p>
  <ol class="num-list">
    <li><strong>Power supply (cord, plug, breaker, ~5 percent of calls).</strong> Diagnostic only or plug repair $80-160.</li>
    <li><strong>Safety interlock wear (year 5-8).</strong> $180-280.</li>
    <li><strong>Capacitor failure (year 6-9).</strong> $80-180.</li>
    <li><strong>Motor brushes worn (year 6-9).</strong> $120-220.</li>
    <li><strong>Switch failure (on/off).</strong> $120-220.</li>
    <li><strong>Full motor failure (year 8-12).</strong> $480-820.</li>
    <li><strong>Motor capacitor + brush combination failure.</strong> $240-380 bundled.</li>
    <li><strong>Wiring harness loose / corroded.</strong> $120-220 reterminate.</li>
  </ol>
</div></section>

<section class="section"><div class="container narrow">
  <p class="section-number">Pricing</p>
  <table class="price-table"><thead><tr><th>Repair</th><th>Typical Cost</th></tr></thead><tbody>
        <tr><td>Diagnostic</td><td>$120, waived with repair</td></tr>
        <tr><td>Power supply diagnostic</td><td>Diagnostic only or $80 to $160</td></tr>
        <tr><td>Safety interlock replacement</td><td>$180 to $280</td></tr>
        <tr><td>Capacitor replacement</td><td>$80 to $180</td></tr>
        <tr><td>Motor brushes</td><td>$120 to $220</td></tr>
        <tr><td>Switch replacement</td><td>$120 to $220</td></tr>
        <tr><td>Full motor replacement</td><td>$480 to $820</td></tr>
        <tr><td>Multi-component (year 10+)</td><td>$680 to $1,200</td></tr>
        <tr><td>Warranty</td><td>90 days parts and labor</td></tr>
  </tbody></table>
</div></section>

<section class="section section-gray"><div class="container narrow">
  <p class="section-number">FAQ</p>
  <div class="faq-list">{faqs.map(f => (<details class="faq-item"><summary>{f.q}</summary><p>{f.a}</p></details>))}</div>
</div></section>

<section class="section"><div class="container narrow">
  <p class="section-number">Related</p>
  <ul class="bullet-list">
    <li><a href="/commercial/slicer-repair/">Slicer Repair (parent)</a></li>
    <li><a href="/commercial/slicer-repair/blade-issues/">Blade issues</a> · <a href="/commercial/slicer-repair/safety-interlock-issues/">Safety interlock issues</a></li>
    <li><a href="/commercial/slicer-repair/brands/hobart/">Hobart</a> · <a href="/commercial/slicer-repair/brands/globe/">Globe</a> · <a href="/commercial/slicer-repair/brands/bizerba/">Bizerba</a> · <a href="/commercial/slicer-repair/brands/berkel/">Berkel</a></li>
  </ul>
</div></section>

<section class="bottom-cta"><div class="container">
  <h2>Slicer motor not running? Same-day diagnostic.</h2>
  <p>Capacitor, brushes, interlock service across LA, OC, Ventura. $120 commercial. BHGS #A49573, EPA 608 Universal #1346255700410.</p>
  <div class="cta-row"><a href={phoneHref} class="btn-primary">☎ Call {phone}</a><a href="/contact/" class="btn-secondary">Book Online</a></div>
</div></section>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .section { padding: 72px 24px; } .section-gray { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; } .container.narrow { max-width: 820px; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  .section h2 { font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 800; margin: 0 0 18px; color: var(--text); line-height: 1.2; }
  .section p { font-size: 1rem; line-height: 1.75; margin: 0 0 16px; color: var(--text); }
  .section a { color: var(--red); font-weight: 600; text-decoration: none; } .section a:hover { text-decoration: underline; }
  .num-list { padding-left: 22px; margin: 14px 0 0; } .num-list li { font-size: 0.98rem; line-height: 1.7; color: var(--text); margin-bottom: 10px; }
  .bullet-list { padding-left: 22px; margin: 14px 0 18px; } .bullet-list li { font-size: 1rem; line-height: 1.65; color: var(--text); margin-bottom: 6px; }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 22px; background: #fff; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
  .price-table th, .price-table td { padding: 12px 16px; text-align: left; border-bottom: 1px solid var(--border); font-size: 0.95rem; }
  .price-table th { background: var(--gray); font-weight: 700; color: var(--text); } .price-table tr:last-child td { border-bottom: none; }
  .faq-list { margin-top: 24px; } .faq-item { background: #fff; border: 1px solid var(--border); border-radius: 6px; padding: 18px 22px; margin-bottom: 12px; }
  .faq-item summary { font-weight: 700; cursor: pointer; font-size: 1rem; color: var(--text); list-style: none; }
  .faq-item summary::-webkit-details-marker { display: none; } .faq-item summary::before { content: "+ "; color: var(--red); font-weight: 800; margin-right: 6px; } .faq-item[open] summary::before { content: "− "; }
  .faq-item p { font-size: 0.95rem; color: var(--text); line-height: 1.75; margin: 14px 0 0; }
  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { color: #fff; margin: 0 0 14px; font-size: 1.7rem; } .bottom-cta p { color: #c9c9c9; margin: 0 0 26px; max-width: 720px; margin-left: auto; margin-right: auto; }
  .cta-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 14px 28px; border-radius: 5px; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 14px 28px; border-radius: 5px; border: 2px solid rgba(255,255,255,0.35); font-weight: 600; text-decoration: none; }
</style>
