---
import Layout from '../../../../layouts/Layout.astro';
import CommercialHero from '../../../../components/CommercialHero.astro';
import { MAIN_PHONE } from '../../../../data/branches';
const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/commercial/slicer-repair/brands/bizerba/";
const title = "Bizerba Slicer Repair Los Angeles — Same Day";
const description = `Bizerba premium German slicer repair. LA same-day. VS12, SE12, GSP H, A 510. Independent German engineering since 1866. $120 commercial. ${phone}.`;
const faqs = [
  { q: "Why does Bizerba command premium pricing?", a: "German engineering depth and butcher-shop heritage. Bizerba (Balingen, Germany since 1866) builds at the high end of commercial slicers — VS12, SE12 manual gravity-feed, GSP H automatic, A 510 high-volume automatic. Service life year 15-20 typical with proper maintenance vs year 8-12 mid-tier. Common LA installs: high-end butcher shops (Lindy & Grundy, Vicente Foods butcher counter, premium hotel restaurant kitchens), prosciutto-and-charcuterie operations (Bestia, Felix, Mozza)." },
  { q: "Bizerba parts logistics for LA service?", a: "Parts via Bizerba USA distribution; typical 2-5 day order on out-of-region parts. Common service items (blade, sharpener stones, motor brushes) stocked at Bizerba USA Joppa Maryland facility, often same-day or next-day to LA via expedited shipping. Specialty parts on older legacy models (pre-2000) may require 1-2 week order from German factory direct." },
  { q: "Manual VS12 vs automatic GSP H service patterns?", a: "Manual gravity-feed (VS12, SE12): operator-driven product carriage, simpler mechanically. Failure pattern: blade year 6-9, sharpener stones year 4-7, motor year 12-15. Automatic (GSP H, A 510): motor-driven carriage with programmable cycles, more components but reduces operator labor. Failure pattern: same blade/sharpener cycles plus carriage motor year 8-11 ($580-880), automatic control board year 10-13 ($680-980)." },
  { q: "Sharpener system on Bizerba — different from Globe/Berkel?", a: "Bizerba uses proprietary integrated sharpener with grinding stones rated for the harder German blade steel. Stone replacement year 4-7 typical, $120-220 stones plus labor. Bizerba blades hold edge longer than mid-tier blades but cost more to replace ($380-580 vs $260-440 for Globe). Total cost-of-ownership often pencils similar over 10-year window despite higher upfront blade cost." },
  { q: "Health Department compliance for Bizerba?", a: "Same LA County DPH requirements as any commercial slicer: daily cleaning, sanitization, blade-guard verification. Premium stainless construction makes cleaning easier; less likely to get HD findings on surface sanitization. We document service for HD compliance file." },
  { q: "Annual PM for Bizerba?", a: "Strongly recommended given the equipment investment ($4,500-12,000 retail). Annual PM ($240-380) covers blade sharpening, sharpener stone inspection, motor brush inspection, lubrication, safety interlock test. Premium tier service preserves equipment value." },
  { q: "What's your warranty?", a: "90 days SDAR labor and parts. Bizerba component warranties processed through Bizerba USA Joppa Maryland authorized service. BHGS #A49573, BBB A+, EPA 608 Universal #1346255700410." }
];
const brandSchema = { "@context": "https://schema.org", "@type": "Brand", "@id": canonical + "#brand", "name": "Bizerba", "description": "Bizerba manufactures premium commercial slicers from Balingen Germany. Independent. Founded 1866. VS12, SE12, GSP H, A 510." };
const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business", "name": "Same Day Appliance Repair", "url": canonical, "telephone": phone, "priceRange": "$$",
    "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "08:00", "closes": "20:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "00:00", "closes": "00:00" }
      ],
    "areaServed": [{ "@type": "AdministrativeArea", "name": "Los Angeles County" },{ "@type": "AdministrativeArea", "name": "Orange County" },{ "@type": "AdministrativeArea", "name": "Ventura County" },{ "@type": "AdministrativeArea", "name": "San Bernardino County" },{ "@type": "AdministrativeArea", "name": "Riverside County" }]
  },
  { "@context": "https://schema.org", "@type": "Service", "@id": canonical + "#service", "serviceType": "Bizerba Slicer Repair", "name": "Bizerba Premium Slicer Repair Service", "url": canonical,
    "description": "Bizerba premium commercial slicer repair across all five SoCal counties. VS12, SE12 manual gravity-feed, GSP H automatic, A 510 high-volume automatic. German engineering year 15-20 service life with proper PM. High-end butcher shops, charcuterie, premium hotel restaurant kitchens. $120 commercial diagnostic. BHGS #A49573, EPA 608 Universal #1346255700410.",
    "provider": { "@id": canonical + "#business" }, "brand": { "@id": canonical + "#brand" },
    "areaServed": [{ "@type": "AdministrativeArea", "name": "Los Angeles County" },{ "@type": "AdministrativeArea", "name": "Orange County" },{ "@type": "AdministrativeArea", "name": "Ventura County" },{ "@type": "AdministrativeArea", "name": "San Bernardino County" },{ "@type": "AdministrativeArea", "name": "Riverside County" }],
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "120.00", "priceCurrency": "USD", "description": "Commercial diagnostic fee, applied toward repair" } }
  },
  brandSchema,
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
    { "@type": "ListItem", "position": 2, "name": "Commercial", "item": "https://samedayappliance.repair/commercial/" },
    { "@type": "ListItem", "position": 3, "name": "Slicer Repair", "item": "https://samedayappliance.repair/commercial/slicer-repair/" },
    { "@type": "ListItem", "position": 4, "name": "Bizerba", "item": canonical }
  ]}
];
---
<Layout title={title} description={description} canonical={canonical}>
<Fragment slot="head-scripts">{schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}</Fragment>
<CommercialHero title="Bizerba Premium Commercial Slicer Repair, Same-Day Across LA"
  subtitle={`VS12, SE12, GSP H, A 510. German engineering since 1866. Premium butcher shop + charcuterie standard. $120 commercial. ${phone}`}
  heroImageTitle="Bizerba Slicer Repair" showBranches={true} />

<section class="section"><div class="container narrow">
  <p class="section-number">German premium slicer specialty</p>
  <h2>Bizerba is the premium tier. Year 15-20 service life with proper maintenance.</h2>
  <p>Bizerba is independent German manufacturing (Balingen, since 1866). Premium tier positioning above Hobart 2912 and Berkel 829E. Common LA installs: high-end butcher shops (Lindy & Grundy, Vicente Foods butcher counter, McCall's Meat Hancock Park), prosciutto-and-charcuterie operations (Bestia Arts District, Felix Trattoria Venice, Mozza Hancock Park), premium hotel restaurant kitchens (Beverly Hills Hotel, Four Seasons LA, Bel-Air).</p>
  <p>$120 commercial diagnostic, waived with repair. <strong>BHGS #A49573</strong>. <strong>EPA 608 Universal certified #1346255700410</strong>. BBB A+. Phones answered 24/7. Parent: <a href="/commercial/slicer-repair/">commercial slicer repair</a>.</p>
</div></section>

<section class="section section-gray"><div class="container narrow">
  <p class="section-number">Top failure modes</p>
  <ol class="num-list">
    <li><strong>Blade replacement (year 6-9 commercial duty).</strong> $380-580 (premium German steel).</li>
    <li><strong>Sharpener stones (year 4-7).</strong> $120-220.</li>
    <li><strong>Motor brushes (year 6-9).</strong> $120-220.</li>
    <li><strong>Carriage motor (automatic GSP H, A 510, year 8-11).</strong> $580-880.</li>
    <li><strong>Automatic control board (year 10-13).</strong> $680-980.</li>
    <li><strong>Safety interlock (year 5-8).</strong> $180-280.</li>
    <li><strong>Slide carriage rail wear.</strong> $180-280.</li>
    <li><strong>Specialty parts logistics (pre-2000 legacy).</strong> 1-2 week German factory order.</li>
  </ol>
</div></section>

<section class="section"><div class="container narrow">
  <p class="section-number">Pricing</p>
  <table class="price-table"><thead><tr><th>Repair</th><th>Typical Cost</th></tr></thead><tbody>
    <tr><td>Diagnostic</td><td>$120, waived with repair</td></tr>
    <tr><td>Blade replacement (Bizerba premium)</td><td>$380 to $580</td></tr>
    <tr><td>Sharpener stones</td><td>$120 to $220</td></tr>
    <tr><td>Motor brushes</td><td>$120 to $220</td></tr>
    <tr><td>Carriage motor (automatic)</td><td>$580 to $880</td></tr>
    <tr><td>Automatic control board</td><td>$680 to $980</td></tr>
    <tr><td>Safety interlock</td><td>$180 to $280</td></tr>
    <tr><td>Slide carriage service</td><td>$180 to $280</td></tr>
    <tr><td>Annual PM contract</td><td>$240 to $380</td></tr>
    <tr><td>Warranty</td><td>90 days parts and labor</td></tr>
  </tbody></table>
</div></section>

<section class="section section-gray"><div class="container narrow">
  <p class="section-number">FAQ</p>
  <div class="faq-list">{faqs.map(f => (<details class="faq-item"><summary>{f.q}</summary><p>{f.a}</p></details>))}</div>
</div></section>

<section class="section"><div class="container narrow">
  <p class="section-number">Related</p>
  <ul class="bullet-list">
    <li><a href="/commercial/slicer-repair/">Slicer repair (parent)</a></li>
    <li><a href="/commercial/slicer-repair/brands/hobart/">Hobart</a> · <a href="/commercial/slicer-repair/brands/globe/">Globe</a> · <a href="/commercial/slicer-repair/brands/berkel/">Berkel</a></li>
    <li><a href="/commercial/slicer-repair/blade-issues/">Blade issues</a> · <a href="/commercial/slicer-repair/motor-not-running/">Motor not running</a> · <a href="/commercial/slicer-repair/safety-interlock-issues/">Safety interlock</a></li>
  </ul>
</div></section>

<section class="bottom-cta"><div class="container">
  <h2>Bizerba slicer down? Same-day priority.</h2>
  <p>VS12, SE12, GSP H, A 510 across LA, OC, Ventura. $120 commercial. BHGS #A49573, EPA 608 Universal #1346255700410.</p>
  <div class="cta-row"><a href={phoneHref} class="btn-primary">☎ Call {phone}</a><a href="/contact/" class="btn-secondary">Book Online</a></div>
</div></section>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .section { padding: 72px 24px; } .section-gray { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; } .container.narrow { max-width: 820px; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  .section h2 { font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 800; margin: 0 0 18px; color: var(--text); line-height: 1.2; }
  .section p { font-size: 1rem; line-height: 1.75; margin: 0 0 16px; color: var(--text); }
  .section a { color: var(--red); font-weight: 600; text-decoration: none; } .section a:hover { text-decoration: underline; }
  .num-list { padding-left: 22px; margin: 14px 0 0; } .num-list li { font-size: 0.98rem; line-height: 1.7; color: var(--text); margin-bottom: 10px; }
  .bullet-list { padding-left: 22px; margin: 14px 0 18px; } .bullet-list li { font-size: 1rem; line-height: 1.65; color: var(--text); margin-bottom: 6px; }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 22px; background: #fff; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
  .price-table th, .price-table td { padding: 12px 16px; text-align: left; border-bottom: 1px solid var(--border); font-size: 0.95rem; }
  .price-table th { background: var(--gray); font-weight: 700; color: var(--text); } .price-table tr:last-child td { border-bottom: none; }
  .faq-list { margin-top: 24px; } .faq-item { background: #fff; border: 1px solid var(--border); border-radius: 6px; padding: 18px 22px; margin-bottom: 12px; }
  .faq-item summary { font-weight: 700; cursor: pointer; font-size: 1rem; color: var(--text); list-style: none; }
  .faq-item summary::-webkit-details-marker { display: none; } .faq-item summary::before { content: "+ "; color: var(--red); font-weight: 800; margin-right: 6px; } .faq-item[open] summary::before { content: "− "; }
  .faq-item p { font-size: 0.95rem; color: var(--text); line-height: 1.75; margin: 14px 0 0; }
  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { color: #fff; margin: 0 0 14px; font-size: 1.7rem; } .bottom-cta p { color: #c9c9c9; margin: 0 0 26px; max-width: 720px; margin-left: auto; margin-right: auto; }
  .cta-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 14px 28px; border-radius: 5px; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 14px 28px; border-radius: 5px; border: 2px solid rgba(255,255,255,0.35); font-weight: 600; text-decoration: none; }
</style>
