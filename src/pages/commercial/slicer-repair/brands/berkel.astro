---
import Layout from '../../../../layouts/Layout.astro';
import CommercialHero from '../../../../components/CommercialHero.astro';
import { MAIN_PHONE } from '../../../../data/branches';
const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/commercial/slicer-repair/brands/berkel/";
const title = "Berkel Commercial Slicer Repair LA | 829E, 825E, X13, B14 | $120 Commercial";
const description = `Berkel commercial slicer repair. LA same-day. 829E, 825E, X13, B14 manual + automatic. US Foods Equipment brand. Italian heritage 1898. $120 commercial.`;
const faqs = [
  { q: "Berkel positioning vs Hobart and Bizerba?", a: "Berkel sits between Bizerba premium and Hobart workhorse — Italian heritage (Wilhelmus van Berkel 1898 Rotterdam, now US Foods Equipment ownership). Premium tier for delicatessen and butcher operations valuing Italian engineering. Models: 829E and 825E manual gravity-feed (most common LA), X13 mid-volume automatic, B14 high-volume automatic." },
  { q: "X13 automatic slicer service patterns?", a: "X13 is Berkel's mid-volume automatic — common at hotel banquet operations, large catering. Failure pattern: blade year 6-9, sharpener stones year 4-7, motor brushes year 6-9, carriage motor year 8-11 ($580-880), control board year 10-13 ($580-880)." },
  { q: "Berkel red-knob aesthetic — service implications?", a: "The signature red knobs are aesthetic but standard parts. Replacement knobs ($60-120) available through Berkel USA distribution. Operators often request red-knob replacement during refurb for the iconic look." },
  { q: "Italian heritage parts logistics?", a: "Berkel parts via US Foods Equipment Berkel USA distribution. Most common parts (blade, sharpener, motor brushes) stocked domestically; specialty parts on legacy models may require 1-2 week order from Italian factory direct." },
  { q: "Health Department compliance for Berkel?", a: "Standard LA County DPH requirements: daily cleaning, sanitization, blade-guard verification. Berkel polished aluminum + stainless construction is HD-friendly. We document service for HD compliance file." },
  { q: "Annual PM for Berkel?", a: "Recommended given equipment investment ($3,800-9,500). Annual PM ($180-280) covers blade sharpening, sharpener stones, motor brush inspection, lubrication." },
  { q: "What's your warranty?", a: "90 days SDAR labor and parts. Berkel component warranties through Berkel USA / US Foods Equipment authorized service. BHGS #A49573, BBB A+, EPA 608 Universal #1346255700410." },
];
const brandSchema = { "@context": "https://schema.org", "@type": "Brand", "@id": canonical + "#brand", "name": "Berkel", "description": "Berkel manufactures Italian-heritage commercial slicers. Founded 1898 Rotterdam by Wilhelmus van Berkel. US Foods Equipment ownership.", "foundingDate": "1898" };
const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business", "name": "Same Day Appliance Repair", "url": canonical, "telephone": phone, "priceRange": "$$",
    "openingHoursSpecification": [{ "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "08:00", "closes": "20:00" }],
    "areaServed": [{ "@type": "AdministrativeArea", "name": "Los Angeles County" },{ "@type": "AdministrativeArea", "name": "Orange County" },{ "@type": "AdministrativeArea", "name": "Ventura County" },{ "@type": "AdministrativeArea", "name": "San Bernardino County" },{ "@type": "AdministrativeArea", "name": "Riverside County" }],
  },
  { "@context": "https://schema.org", "@type": "Service", "@id": canonical + "#service", "serviceType": "Berkel Slicer Repair", "name": "Berkel Italian Premium Slicer Repair Service", "url": canonical,
    "description": "Berkel commercial slicer repair across all five SoCal counties. 829E, 825E manual gravity-feed, X13 mid-volume automatic, B14 high-volume automatic. Italian heritage 1898, US Foods Equipment brand. $120 commercial diagnostic. BHGS #A49573, EPA 608 Universal #1346255700410.",
    "provider": { "@id": canonical + "#business" }, "brand": { "@id": canonical + "#brand" },
    "areaServed": [{ "@type": "AdministrativeArea", "name": "Los Angeles County" },{ "@type": "AdministrativeArea", "name": "Orange County" },{ "@type": "AdministrativeArea", "name": "Ventura County" },{ "@type": "AdministrativeArea", "name": "San Bernardino County" },{ "@type": "AdministrativeArea", "name": "Riverside County" }],
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "120.00", "priceCurrency": "USD", "description": "Commercial diagnostic fee, applied toward repair" } },
  },
  brandSchema,
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
    { "@type": "ListItem", "position": 2, "name": "Commercial", "item": "https://samedayappliance.repair/commercial/" },
    { "@type": "ListItem", "position": 3, "name": "Slicer Repair", "item": "https://samedayappliance.repair/commercial/slicer-repair/" },
    { "@type": "ListItem", "position": 4, "name": "Berkel", "item": canonical },
  ]},
];
---
<Layout title={title} description={description} canonical={canonical}>
<Fragment slot="head-scripts">{schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}</Fragment>
<CommercialHero title="Berkel Italian Premium Slicer Repair, Same-Day Across LA"
  subtitle={`829E, 825E manual, X13 + B14 automatic. Italian heritage 1898. US Foods Equipment brand. $120 commercial. ${phone}`}
  heroImageTitle="Berkel Slicer Repair" showBranches={true} />

<section class="section"><div class="container narrow">
  <p class="section-number">Italian heritage premium slicer</p>
  <h2>Berkel sits between Bizerba premium and Hobart workhorse. Italian heritage since 1898.</h2>
  <p>Berkel was founded 1898 in Rotterdam by Wilhelmus van Berkel; current US Foods Equipment ownership. Italian-heritage manufacturing and the signature red-knob aesthetic make Berkel the choice for upscale delicatessen and Italian-concept restaurants. Common LA installs: Italian-concept restaurants (Bestia, Felix, Mozza, Bottega Louie), upscale delicatessens, hotel banquet operations.</p>
  <p>$120 commercial diagnostic, waived with repair. <strong>BHGS #A49573</strong>. <strong>EPA 608 Universal certified #1346255700410</strong>. BBB A+. Phones answered 24/7. Parent: <a href="/commercial/slicer-repair/">commercial slicer repair</a>.</p>
</div></section>

<section class="section section-gray"><div class="container narrow">
  <p class="section-number">Top failure modes</p>
  <ol class="num-list">
    <li><strong>Blade replacement (year 6-9 commercial duty).</strong> $340-540.</li>
    <li><strong>Sharpener stones (year 4-7).</strong> $120-220.</li>
    <li><strong>Motor brushes (year 6-9).</strong> $120-220.</li>
    <li><strong>Carriage motor (X13 + B14 automatic, year 8-11).</strong> $580-880.</li>
    <li><strong>Control board (X13 + B14, year 10-13).</strong> $580-880.</li>
    <li><strong>Safety interlock (year 5-8).</strong> $180-280.</li>
    <li><strong>Slide carriage rail wear.</strong> $180-280.</li>
    <li><strong>Red-knob replacement (aesthetic refurb).</strong> $60-120 per knob.</li>
  </ol>
</div></section>

<section class="section"><div class="container narrow">
  <p class="section-number">Pricing</p>
  <table class="price-table"><thead><tr><th>Repair</th><th>Typical Cost</th></tr></thead><tbody>
    <tr><td>Diagnostic</td><td>$120, waived with repair</td></tr>
    <tr><td>Blade replacement</td><td>$340 to $540</td></tr>
    <tr><td>Sharpener stones</td><td>$120 to $220</td></tr>
    <tr><td>Motor brushes</td><td>$120 to $220</td></tr>
    <tr><td>Carriage motor (automatic)</td><td>$580 to $880</td></tr>
    <tr><td>Control board (automatic)</td><td>$580 to $880</td></tr>
    <tr><td>Safety interlock</td><td>$180 to $280</td></tr>
    <tr><td>Red-knob replacement</td><td>$60 to $120</td></tr>
    <tr><td>Annual PM contract</td><td>$180 to $280</td></tr>
    <tr><td>Warranty</td><td>90 days parts and labor</td></tr>
  </tbody></table>
</div></section>

<section class="section section-gray"><div class="container narrow">
  <p class="section-number">FAQ</p>
  <div class="faq-list">{faqs.map(f => (<details class="faq-item"><summary>{f.q}</summary><p>{f.a}</p></details>))}</div>
</div></section>

<section class="section"><div class="container narrow">
  <p class="section-number">Related</p>
  <ul class="bullet-list">
    <li><a href="/commercial/slicer-repair/">Slicer repair (parent)</a></li>
    <li><a href="/commercial/slicer-repair/brands/hobart/">Hobart</a> · <a href="/commercial/slicer-repair/brands/globe/">Globe</a> · <a href="/commercial/slicer-repair/brands/bizerba/">Bizerba</a></li>
    <li><a href="/commercial/slicer-repair/blade-issues/">Blade issues</a> · <a href="/commercial/slicer-repair/motor-not-running/">Motor not running</a> · <a href="/commercial/slicer-repair/safety-interlock-issues/">Safety interlock</a></li>
  </ul>
</div></section>

<section class="bottom-cta"><div class="container">
  <h2>Berkel slicer down? Same-day priority.</h2>
  <p>829E, 825E, X13, B14 across LA, OC, Ventura. $120 commercial. BHGS #A49573, EPA 608 Universal #1346255700410.</p>
  <div class="cta-row"><a href={phoneHref} class="btn-primary">☎ Call {phone}</a><a href="/contact/" class="btn-secondary">Book Online</a></div>
</div></section>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .section { padding: 72px 24px; } .section-gray { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; } .container.narrow { max-width: 820px; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  .section h2 { font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 800; margin: 0 0 18px; color: var(--text); line-height: 1.2; }
  .section p { font-size: 1rem; line-height: 1.75; margin: 0 0 16px; color: var(--text); }
  .section a { color: var(--red); font-weight: 600; text-decoration: none; } .section a:hover { text-decoration: underline; }
  .num-list { padding-left: 22px; margin: 14px 0 0; } .num-list li { font-size: 0.98rem; line-height: 1.7; color: var(--text); margin-bottom: 10px; }
  .bullet-list { padding-left: 22px; margin: 14px 0 18px; } .bullet-list li { font-size: 1rem; line-height: 1.65; color: var(--text); margin-bottom: 6px; }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 22px; background: #fff; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
  .price-table th, .price-table td { padding: 12px 16px; text-align: left; border-bottom: 1px solid var(--border); font-size: 0.95rem; }
  .price-table th { background: var(--gray); font-weight: 700; color: var(--text); } .price-table tr:last-child td { border-bottom: none; }
  .faq-list { margin-top: 24px; } .faq-item { background: #fff; border: 1px solid var(--border); border-radius: 6px; padding: 18px 22px; margin-bottom: 12px; }
  .faq-item summary { font-weight: 700; cursor: pointer; font-size: 1rem; color: var(--text); list-style: none; }
  .faq-item summary::-webkit-details-marker { display: none; } .faq-item summary::before { content: "+ "; color: var(--red); font-weight: 800; margin-right: 6px; } .faq-item[open] summary::before { content: "− "; }
  .faq-item p { font-size: 0.95rem; color: var(--text); line-height: 1.75; margin: 14px 0 0; }
  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { color: #fff; margin: 0 0 14px; font-size: 1.7rem; } .bottom-cta p { color: #c9c9c9; margin: 0 0 26px; max-width: 720px; margin-left: auto; margin-right: auto; }
  .cta-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 14px 28px; border-radius: 5px; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 14px 28px; border-radius: 5px; border: 2px solid rgba(255,255,255,0.35); font-weight: 600; text-decoration: none; }
</style>
