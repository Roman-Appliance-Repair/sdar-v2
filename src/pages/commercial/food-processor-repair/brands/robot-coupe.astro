        <tr><td>Warranty (SDAR labor)</td><td>90 days parts and labor</td></tr>
      </tbody>
    </table>
  </div>
</section>

<section class="section">
  <div class="container">
    <p class="section-number">Related</p>
    <h2>Commercial smallwares service across the catalog.</h2>
    <div class="related-grid">
      <a href="/commercial/food-processor-repair/" class="related-card"><h3>Food Processor Repair Hub</h3><p>Parent pillar. Robot Coupe plus Hobart buffalo chopper, Univex, Vitamix Commercial coverage.</p></a>
