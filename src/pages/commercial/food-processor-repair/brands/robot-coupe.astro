// src/pages/commercial/food-processor-repair/brands/robot-coupe.astro
// Cluster 11 Tier 2 — Robot Coupe R-series cutter mixer brand page.
// Same template: 5 schemas. $120 commercial diagnostic. Em-dash ≤6.
// NO C-38, NO C-20. BHGS #A49573 + EPA 608 #1346255700410.
// Brand factual: SEB Group (French parent).

import Layout from '../../../../layouts/Layout.astro';
import CommercialHero from '../../../../components/CommercialHero.astro';
import { MAIN_PHONE } from '../../../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/commercial/food-processor-repair/brands/robot-coupe/";

const title = "Robot Coupe Food Processor Repair Los Angeles — Same Day";
const description = "Robot Coupe R-series cutter mixer repair across SoCal. R2, R4, R8, R10, R15, R30. SEB Group French. NSF + Health Dept compliant. $120 dx.";

const faqs = [
  {
    q: "Do you service Robot Coupe R2, R4, R8, R10, R15, and R30?",
    a: "Yes. The full R-series cutter mixer family is our most common food processor service call across LA-area restaurants, prep kitchens, salad operations, and ice cream programs. R2 (2.5 quart, smallest), R4 (4.5 quart), R8 (8 quart), R10 (10 quart), R15 (15 quart), R30 (30 quart, floor model). All use brushed motor architecture with S-blade primary cutting tool. OEM parts via SEB Group US distribution."
  },
  {
    q: "Is Robot Coupe French?",
    a: "Yes. Robot Coupe is part of SEB Group (Société d'Emboutissage de Bourgogne, French multinational). SEB Group also owns brands like Tefal, Krups, Rowenta, and All-Clad. Robot Coupe specifically focuses on commercial food processing equipment with R-series cutter mixers, vegetable prep attachments, and commercial blenders. US distribution via SEB Group North American operations; standard 5 to 7 day ship for most service items."
  },
  {
    q: "How long do Robot Coupe R-series last?",
    a: "Properly maintained, 8 to 14 years is typical commercial service life. R-series uses brushed motor architecture (different from brushless designs) which gives roughly 6 to 10 year brush life as the limiting factor. With brush replacement at year 6 to 10 plus periodic blade and safety interlock service, R-series units run reliably for the full 8 to 14 year window. Heavy-volume operations (high-output prep kitchens) compress the timeline; light-use operations extend it."
  },
  {
    q: "My Robot Coupe motor stops mid-cycle. What's wrong?",
    a: "Three causes in order: (1) overload trip from over-filling the bowl (R-series motors have thermal protection that trips on extended overload; reset by waiting 15-20 minutes for motor to cool, then reduce batch size and verify ingredient compatibility), (2) safety interlock fault on the lid (lid must be properly seated and latched for motor to run; year 5 to 9 typical interlock wear), (3) motor brushes worn to base (Robot Coupe motors are brushed, year 6 to 10 typical brush life). We diagnose with multimeter and visual inspection of brush block."
  },
  {
    q: "Can you sharpen Robot Coupe S-blades on-site?",
    a: "Yes, but with caveats. Robot Coupe S-blades can be sharpened 2 to 3 times during their service life with proper technique; further sharpening compromises blade geometry beyond safe operation. NSF-listed OEM Robot Coupe blades are required for Health Department compliance; aftermarket blades often fail inspection regardless of fitment. We sharpen when viable ($120 to $180 service charge), replace with NSF-listed OEM when sharpening is no longer appropriate ($180 to $360 depending on blade size)."
  },
  {
    q: "What does Robot Coupe repair cost in LA?",
    a: "$120 commercial diagnostic, waived with repair. Common Robot Coupe repairs: S-blade sharpening or replacement $180 to $360, motor brush replacement $260 to $440, safety interlock $260 to $440, bowl latch $140 to $260, drive coupling $200 to $360, motor replacement $680 to $1,200 (R8 through R30 sizes), pulse switch service $140 to $240. Multi-component repair on aged R-series $890 to $1,800."
  },
  {
    q: "What's your warranty?",
    a: "90 days SDAR labor warranty. Robot Coupe component warranties (where applicable through SEB Group US service network) processed separately. BHGS #A49573 and BBB A+. EPA 608 Universal #1346255700410."
  }
];

