---
// src/pages/commercial/stove-repair.astro
// Wave 5 — /commercial/ — PAGE 10 of 15
// GSC: "commercial stove repair" 191 imp pos 15.3 — near top-10
//      "commercial stove repair near me" 250 imp pos 24.9 — major volume
//      "commercial stove repair beverly hills" 7 imp pos 18.7
// KEY DISTINCTION FROM OVEN PAGE: open burners, high-BTU, wok ranges
// Unique angles: wok range / high-BTU LA context (Koreatown, SGV);
// gas safety SoCalGas (same as oven but different burner-specific framing);
// stove vs oven internal link + explicit differentiation

import Layout from '../../layouts/Layout.astro';
import CommercialHero from '../../components/CommercialHero.astro';
import { MAIN_PHONE } from '../../data/branches';

const title = "Commercial Stove Repair — Same-Day Service Across Southern California";
const description = "Same-day commercial stove and range repair across LA, Orange, Ventura, San Bernardino & Riverside counties. Wok ranges, open burners, high-BTU gas ranges — Vulcan, Garland, Southbend, Imperial. Gas-certified, BHGS Licensed #A49573. $120 diagnostic.";
const phone = MAIN_PHONE.display;
const phoneRaw = MAIN_PHONE.raw;
const phoneHref = MAIN_PHONE.href;
---

<Layout title={title} description={description}>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Commercial Stove and Range Repair",
  "serviceType": "Commercial Stove and Range Repair",
  "description": "Same-day commercial stove and range repair across Southern California — open burners, high-BTU wok ranges, griddles, charbroilers. Vulcan, Garland, Southbend, Imperial, Montague, American Range. Gas-certified technicians. BHGS Licensed #A49573. $120 commercial diagnostic.",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Same Day Appliance Repair",
    "telephone": phone,
    "url": "https://samedayappliance.repair/",
    "priceRange": "$$"
  },
  "areaServed": [
    {"@type":"AdministrativeArea","name":"Los Angeles County"},
    {"@type":"AdministrativeArea","name":"Orange County"},
    {"@type":"AdministrativeArea","name":"Ventura County"},
    {"@type":"AdministrativeArea","name":"San Bernardino County"},
    {"@type":"AdministrativeArea","name":"Riverside County"}
  ],
  "offers": {
    "@type": "Offer",
    "priceSpecification": {
      "@type": "PriceSpecification",
      "price": "120.00",
      "priceCurrency": "USD",
      "description": "Commercial diagnostic fee, applied toward the repair when approved."
    }
  }
})} />

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much does commercial stove repair cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Our commercial diagnostic fee is $120, applied toward the repair once you approve the work. Most commercial stove and range repairs run between $150 and $500. Igniter, thermocouple, gas valve, burner orifice cleaning, or spark module replacement is toward the lower end. Multiple burner assembly replacement or control valve bank work runs higher. We provide a full written estimate before any work begins."
      }
    },
    {
      "@type": "Question",
      "name": "Which areas of Southern California do you cover for commercial stove repair?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Same-day across Los Angeles, Orange, Ventura, San Bernardino, and Riverside counties — Koreatown and Chinatown LA wok ranges, San Gabriel Valley Chinese restaurants, Anaheim and Garden Grove OC Korean/Vietnamese kitchens, Thousand Oaks Conejo Valley restaurants, Rancho Cucamonga and Riverside IE foodservice. Eight service territories total. Vulcan, Garland, Southbend, Imperial — gas-certified across the entire footprint. BHGS Licensed #A49573."
      }
    },
    {
      "@type": "Question",
      "name": "My commercial gas stove smells like gas — what do I do first?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Call your gas utility first — not an appliance repair company. SoCalGas at 1-800-427-2200 across most of LA, OC, Ventura, and parts of SB; Southwest Gas at 1-877-860-6020 for Riverside, Anaheim, Long Beach, and parts of SB. They will respond, shut off gas safely at the source, and confirm the area is clear at no charge. Once the gas is secured, call us for the mechanical diagnosis and repair. Gas utility first, appliance repair second — this sequence is important for safety."
      }
    },
    {
      "@type": "Question",
      "name": "My commercial burner won't light — what causes that?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most common causes: failed igniter or spark module (no spark at all), clogged burner orifice from grease or food debris (spark present but no flame), or a failed gas valve not allowing gas to the burner. For standing pilot systems: a failed thermocouple. Before calling, try removing the burner cap and grate and cleaning any visible debris — a clogged orifice is a common cause that cleans up in minutes."
      }
    },
    {
      "@type": "Question",
      "name": "Do you repair wok ranges and high-BTU commercial ranges?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. High-BTU wok ranges (75,000–200,000 BTU per burner) common in Chinese, Korean, and Vietnamese restaurants across SoCal — LA's Koreatown and Chinatown, the San Gabriel Valley, OC's Anaheim/Garden Grove Korean and Vietnamese corridors, IE's growing Asian foodservice clusters — are a significant part of what we repair. The failure modes are the same as standard commercial ranges — igniter, gas valve, orifice — but the scale is different. We bring appropriate tools and parts for high-BTU burner assemblies."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between commercial stove repair and commercial oven repair?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Commercial stoves and ranges have open burners on the cooking surface — the igniter, gas valve, burner head, and grates are exposed and accessible. Commercial ovens have enclosed cooking chambers with their own heating systems. We have a separate commercial oven repair page for ovens and convection units. Most commercial ranges combine both — a range top (stove) with an oven section below. We repair both."
      }
    },
    {
      "@type": "Question",
      "name": "How often should a commercial stove be serviced?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Every 6 months minimum. A service visit includes burner orifice inspection and cleaning, igniter condition check, gas valve test, thermocouple verification on pilot systems, grate and burner cap condition, and BTU output check on high-BTU systems. In SoCal's busy restaurant environments, quarterly service is appropriate for high-volume operations running 16+ hours per day."
      }
    },
    {
      "@type": "Question",
      "name": "When does it make sense to repair vs replace a commercial range?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Commercial ranges last 12–20+ years with proper maintenance — Vulcan and Garland ranges from the 1990s are still running daily across SoCal kitchens. Repair almost always wins. New 6-burner Vulcan or Garland ranges run $4,000–$9,000+; high-BTU wok ranges $6,000–$15,000+; charbroilers $3,000–$7,000. A $400–$700 zone valve replacement on a $7,000 range with another decade of life is straightforward math. We tell you directly when a unit has reached end-of-life — usually only after a full burner-bank gas-valve assembly fails on a unit already 20+ years old."
      }
    }
  ]
})} />

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .hero { background: var(--black); color: #fff; padding: 80px 24px 64px; text-align: center; }
  .hero-eyebrow { display: inline-block; background: var(--red); color: #fff; font-size: 0.78rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 5px 14px; border-radius: 3px; margin-bottom: 20px; }
  .hero h1 { font-size: clamp(1.9rem, 4vw, 2.9rem); font-weight: 800; line-height: 1.15; margin: 0 0 20px; max-width: 860px; margin-left: auto; margin-right: auto; }
  .hero-sub { font-size: 1.1rem; color: #ccc; max-width: 640px; margin: 0 auto 32px; line-height: 1.6; }
  .cta-row { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 16px 34px; border-radius: 5px; font-size: 1rem; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 16px 34px; border-radius: 5px; font-size: 1rem; font-weight: 600; text-decoration: none; border: 2px solid rgba(255,255,255,0.35); }
  .hero-meta { margin-top: 28px; color: #aaa; font-size: 0.9rem; display: flex; gap: 24px; justify-content: center; flex-wrap: wrap; }
  .trust-bar { background: var(--red); padding: 18px 24px; }
  .trust-inner { max-width: 1100px; margin: 0 auto; display: flex; justify-content: center; flex-wrap: wrap; gap: 10px 32px; }
  .trust-item { color: #fff; font-size: 0.88rem; font-weight: 600; }
  .section { padding: 64px 24px; }
  .section-gray { background: var(--gray); }
  .section-black { background: var(--black); color: #fff; }
  .container { max-width: 1100px; margin: 0 auto; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  h2.section-title { font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 800; margin: 0 0 16px; line-height: 1.2; }
  .section-black h2.section-title { color: #fff; }
  .lead { font-size: 1.05rem; line-height: 1.75; color: var(--text); max-width: 760px; }
  .section-black .lead { color: #ccc; }
  .intro-grid { display: grid; grid-template-columns: 1fr 320px; gap: 48px; align-items: start; }
  @media (max-width: 768px) { .intro-grid { grid-template-columns: 1fr; } }
  .intro-body p { margin: 0 0 18px; font-size: 1.05rem; line-height: 1.8; color: var(--text); }
  .alert-gas { background: #0a0800; border: 2px solid #c08000; border-radius: 8px; padding: 20px 22px; margin-top: 24px; }
  .alert-gas .ag-label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #e0a000; margin-bottom: 10px; }
  .alert-gas p { font-size: 0.93rem; color: #b09050; margin: 0; line-height: 1.65; }
  .sticky-cta { position: sticky; top: 24px; background: var(--black); border-radius: 10px; padding: 28px 24px; color: #fff; text-align: center; }
  .sticky-cta .cta-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: #aaa; margin-bottom: 14px; }
  .sticky-cta .cta-phone { font-size: 1.5rem; font-weight: 800; color: #fff; text-decoration: none; display: block; margin-bottom: 12px; }
  .sticky-cta .btn-cta { display: block; background: var(--red); color: #fff; padding: 14px; border-radius: 5px; font-weight: 700; text-decoration: none; font-size: 0.95rem; margin-bottom: 10px; }
  .sticky-cta .cta-sub { font-size: 0.82rem; color: #888; }
  .cta-divider { border: none; border-top: 1px solid #222; margin: 18px 0; }
  .cta-detail { font-size: 0.85rem; color: #aaa; text-align: left; }
  .cta-detail li { margin-bottom: 6px; list-style: none; padding-left: 18px; position: relative; }
  .cta-detail li::before { content: "✓"; position: absolute; left: 0; color: var(--red); font-weight: 700; }
  /* Stove vs oven compare */
  .compare-block { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 32px; }
  @media (max-width: 580px) { .compare-block { grid-template-columns: 1fr; } }
  .compare-card { background: #111; border: 1px solid #222; border-radius: 8px; padding: 22px 18px; }
  .compare-card.active { border-color: #2a1a1a; }
  .compare-badge { display: inline-block; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; padding: 3px 10px; border-radius: 3px; margin-bottom: 10px; }
  .badge-this { background: #2a1a1a; color: #ff8080; }
  .badge-other { background: #1a1a2a; color: #8080c0; }
  .compare-card h3 { font-size: 0.95rem; font-weight: 700; color: #fff; margin: 0 0 10px; }
  .compare-card p { font-size: 0.84rem; color: #888; line-height: 1.6; margin: 0 0 10px; }
  .compare-card a { font-size: 0.83rem; color: var(--red); text-decoration: underline; }
  /* Range types */
  .type-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(215px, 1fr)); gap: 16px; margin-top: 32px; }
  .type-card { background: #111; border: 1px solid #222; border-radius: 8px; padding: 20px 18px; }
  .type-card h3 { font-size: 0.9rem; font-weight: 700; color: #fff; margin: 0 0 8px; }
  .type-card p { font-size: 0.82rem; color: #888; line-height: 1.6; margin: 0 0 6px; }
  .type-card .where { font-size: 0.78rem; color: #555; font-style: italic; }
  /* Wok spotlight */
  .wok-block { background: #0a0500; border: 1px solid #300d00; border-radius: 10px; padding: 32px 28px; margin-top: 36px; }
  .wok-block .w-label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: #e06020; margin-bottom: 12px; }
  .wok-block h3 { font-size: 1.15rem; font-weight: 800; color: #fff; margin: 0 0 12px; }
  .wok-block p { font-size: 0.92rem; color: #905030; line-height: 1.7; margin: 0 0 12px; }
  /* Problems */
  .problems-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 18px; margin-top: 36px; }
  .problem-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 22px 18px; }
  .problem-card h3 { font-size: 1rem; font-weight: 700; margin: 0 0 10px; color: var(--text); }
  .problem-card p { font-size: 0.9rem; color: var(--muted); line-height: 1.6; margin: 0; }
  /* Gas safety steps */
  .gas-steps { display: grid; grid-template-columns: repeat(auto-fill, minmax(195px, 1fr)); gap: 10px; margin-top: 16px; }
  .gas-step { background: #080500; border: 1px solid #301800; border-radius: 6px; padding: 14px; display: flex; gap: 10px; align-items: flex-start; }
  .gas-step .sn { min-width: 24px; height: 24px; background: #301800; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.78rem; font-weight: 800; color: #d09030; flex-shrink: 0; }
  .gas-step p { font-size: 0.82rem; color: #806030; line-height: 1.5; margin: 0; }
  /* Brands */
  .brands-grid { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 28px; }
  .brand-chip { background: #fff; border: 1px solid var(--border); border-radius: 4px; padding: 8px 18px; font-size: 0.88rem; font-weight: 600; color: var(--text); }
  .brand-chip.dark { background: #1a1a1a; color: #ddd; border-color: #333; }
  /* Repairs */
  .repairs-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(255px, 1fr)); gap: 22px; margin-top: 36px; }
  .repair-card { background: #111; border: 1px solid #222; border-radius: 8px; padding: 22px 18px; }
  .repair-card .repair-title { font-size: 0.82rem; font-weight: 700; color: #aaa; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 8px; }
  .repair-card h3 { font-size: 0.98rem; font-weight: 700; color: #fff; margin: 0 0 10px; line-height: 1.3; }
  .repair-card p { font-size: 0.87rem; color: #888; line-height: 1.6; margin: 0 0 12px; }
  .repair-card .repair-detail { font-size: 0.78rem; color: #555; border-top: 1px solid #1e1e1e; padding-top: 10px; }
  /* Pricing */
  .pricing-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 18px; margin-top: 32px; }
  .price-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 22px 18px; text-align: center; }
  .price-card .price-label { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); margin-bottom: 8px; }
  .price-card .price-amount { font-size: 1.8rem; font-weight: 800; color: var(--text); line-height: 1; margin-bottom: 8px; }
  .price-card .price-desc { font-size: 0.84rem; color: var(--muted); line-height: 1.5; }
  .price-note { margin-top: 18px; font-size: 0.9rem; color: var(--muted); line-height: 1.6; }
  .faq-list { margin-top: 36px; }
  .faq-item { border-bottom: 1px solid var(--border); padding: 20px 0; }
  .faq-item:first-child { border-top: 1px solid var(--border); }
  .faq-item h3 { font-size: 1rem; font-weight: 700; color: var(--text); margin: 0 0 10px; }
  .faq-item p { font-size: 0.95rem; color: var(--muted); line-height: 1.7; margin: 0; }
  .nearby-links { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 24px; }
  .nearby-links a { background: #fff; border: 1px solid var(--border); border-radius: 4px; padding: 8px 16px; font-size: 0.87rem; color: var(--text); text-decoration: none; font-weight: 500; }
  .nearby-links a:hover { border-color: var(--red); color: var(--red); }
  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; margin: 0 0 16px; }
  .bottom-cta p { color: #aaa; margin: 0 0 32px; font-size: 1.05rem; }
</style>

<!-- HERO + TRUST BAR (unified CommercialHero) -->
<CommercialHero
  title="Commercial Stove Repair Across Southern California"
  subtitle="Same-day across LA, Orange, Ventura, San Bernardino & Riverside counties. Burner won't light, weak flame, uneven cooking — open burners, high-BTU wok ranges, commercial gas ranges. Vulcan, Garland, Southbend, Imperial. Gas-certified, BHGS Licensed #A49573."
  heroImageTitle="Commercial Stove Repair"
/>

<!-- INTRO -->
<section class="section">
  <div class="container">
    <div class="intro-grid">
      <div class="intro-body">
        <p class="section-number">01 — About This Service</p>
        <h2 class="section-title">A commercial stove burner that won't light at morning prep stops your kitchen before service begins.</h2>

        <p>A commercial range with a dead burner section during service means reduced cooking capacity, slower ticket times, and a kitchen that's working around its own equipment. We dispatch commercial stove and range calls same day because a burner failure at 10am can become a dinner service problem by 5pm if it's not addressed.</p>

        <p>Commercial stoves and ranges — the open-burner cooking surface — have distinct failure modes from commercial ovens. This page covers stove surface repairs: igniters, gas valves, thermocouples, burner orifice cleaning, spark modules, and open burner assemblies. For oven section repairs (convection ovens, deck ovens, the enclosed oven cavity below the range top), see our <a href="/commercial/oven-repair/" style="color:var(--red);">Commercial Oven Repair page</a>.</p>

        <p>Southern California has one of the most diverse commercial kitchen landscapes in the US — from the high-BTU wok ranges running 150,000–200,000 BTU/burner in LA's Chinatown and Koreatown, the San Gabriel Valley Chinese restaurants, OC's Anaheim and Garden Grove Korean/Vietnamese corridors, and the IE's growing Asian foodservice clusters; to the charbroilers in Beverly Hills, Newport Beach, and Westlake Village steakhouses; to the standard 6-burner Vulcan or Garland ranges in every independent restaurant on the East Hollywood corridor and across all five counties. We repair all of these, and we come prepared for high-BTU burner work. Same-day priority dispatch — BHGS Licensed #A49573.</p>

        <div class="alert-gas">
          <div class="ag-label">⚠️ Gas Smell? Call Your Gas Utility First — Not Us.</div>
          <p>If you smell gas near your commercial stove: call your gas utility — <strong>SoCalGas at 1-800-427-2200</strong> across most of LA, OC, Ventura, and parts of SB; <strong>Southwest Gas at 1-877-860-6020</strong> for Riverside, Anaheim, Long Beach, and parts of SB. They respond quickly, shut off gas safely, and confirm the area is clear — at no charge. Once the gas is secured, call us at {phone} for the mechanical repair. Gas utility first, appliance repair second.</p>
        </div>
      </div>

      <aside class="sticky-cta">
        <div class="cta-label">Same Day Commercial Priority</div>
        <a href={phoneHref} class="cta-phone">{phone}</a>
        <a href={phoneHref} class="btn-cta">Call Now — Priority Dispatch</a>
        <a href="/book" class="btn-cta" style="background:#222; margin-top:-4px;">Schedule Online</a>
        <div class="cta-sub">Mon–Sun 7am–9pm · Commercial calls prioritized</div>
        <hr class="cta-divider" />
        <ul class="cta-detail">
          <li>Commercial diagnostic: $120</li>
          <li>Applied to repair if approved</li>
          <li>BHGS Licensed #A49573</li>
          <li>Gas-certified technicians</li>
          <li>Vulcan, Garland, Southbend parts</li>
          <li>Wok range / high-BTU service</li>
          <li>5-county SoCal coverage</li>
        </ul>
      </aside>
    </div>
  </div>
</section>

<!-- STOVE VS OVEN -->
<section class="section section-black">
  <div class="container">
    <p class="section-number">02 — Stove Repair vs. Oven Repair</p>
    <h2 class="section-title">Open burner surface repairs vs. enclosed oven chamber repairs — different systems</h2>

    <div class="compare-block">
      <div class="compare-card active">
        <div class="compare-badge badge-this">🔥 This Page — Stove / Range Top</div>
        <h3>Open burner surface repairs</h3>
        <p>The cooking surface — open burners, igniters, gas valves, thermocouples, burner orifices, grates, and burner caps. High-BTU wok ranges, standard 6-burner ranges, griddles, and charbroilers.</p>
        <p>Vulcan, Garland, Southbend, Imperial, Montague, American Range.</p>
      </div>
      <div class="compare-card">
        <div class="compare-badge badge-other">→ See Oven Page</div>
        <h3>Commercial oven repairs</h3>
        <p>The enclosed cooking chamber — heating element, convection fan, deck oven thermostat, door gasket, control board. Convection ovens, deck ovens, pizza ovens, conveyor ovens.</p>
        <a href="/commercial/oven-repair/">Commercial Oven Repair Los Angeles →</a>
      </div>
    </div>
  </div>
</section>

<!-- RANGE TYPES -->
<section class="section section-gray">
  <div class="container">
    <p class="section-number">03 — Commercial Range Types We Service</p>
    <h2 class="section-title">Every commercial cooking surface configuration in SoCal kitchens</h2>

    <div class="type-grid">
      <div class="type-card">
        <h3>Standard Gas Ranges (6–10 Burner)</h3>
        <p>The most common commercial range in SoCal independent restaurants. Vulcan V-series, Garland G-series, Southbend — typically 30,000–35,000 BTU per burner. Igniter, gas valve, thermocouple, orifice.</p>
        <div class="where">All restaurants · Cafes · Diners</div>
      </div>
      <div class="type-card">
        <h3>High-BTU Wok Ranges</h3>
        <p>75,000–200,000 BTU per burner for wok cooking. Chinese, Korean, Vietnamese restaurants in LA's Chinatown, Koreatown, San Gabriel Valley; OC's Anaheim/Garden Grove corridor; IE's growing Asian foodservice clusters. Larger orifice, higher-capacity gas valves — different repair approach from standard ranges.</p>
        <div class="where">Chinese · Korean · Vietnamese Restaurants</div>
      </div>
      <div class="type-card">
        <h3>Griddles &amp; Flat Tops</h3>
        <p>Gas flat-top griddles for breakfast service, burger operations, and short-order cooking. Thermostat, gas valve, igniter — plus surface cleaning and re-seasoning guidance.</p>
        <div class="where">Diners · Breakfast Spots · Fast Casual</div>
      </div>
      <div class="type-card">
        <h3>Charbroilers</h3>
        <p>Gas charbroilers for steakhouses, burger restaurants, and specialty grills. Radiants, burner assemblies, gas valve, igniter. Beverly Hills, Newport Beach, and Westlake Village fine dining and casual restaurant charbroiler service.</p>
        <div class="where">Steakhouses · Burger Restaurants · Grills</div>
      </div>
      <div class="type-card">
        <h3>Combination Ranges</h3>
        <p>Full commercial range with burner section above and oven section below. We repair both sections — burner surface and oven chamber — on the same visit when needed.</p>
        <div class="where">All full-service restaurants</div>
      </div>
      <div class="type-card">
        <h3>Commercial Induction Ranges</h3>
        <p>Commercial induction cooktops for SoCal kitchens electrifying their cooking suites — increasingly common in new restaurant buildouts across LA, OC, Ventura, and IE. Control board, induction coil, cooling fan.</p>
        <div class="where">Modern Restaurant Buildouts · Hotels</div>
      </div>
    </div>

    <!-- WOK SPOTLIGHT -->
    <div class="wok-block">
      <div class="w-label">🥢 High-BTU Wok Ranges — SoCal's Most Powerful Commercial Burners</div>
      <h3>LA Koreatown / Chinatown / SGV + OC Anaheim/Garden Grove + IE Asian foodservice clusters — the wok range capital of the western US</h3>
      <p>Southern California has the largest concentration of Chinese, Korean, and Vietnamese restaurants outside of Asia — and these cuisines demand high-BTU wok burners that standard commercial range repair technicians often haven't worked on. A wok range running 150,000 BTU per burner requires larger orifice jets, higher-capacity gas supply lines, and different igniter assemblies than a standard 35,000 BTU burner.</p>
      <p>Common failure modes on high-BTU wok ranges: clogged wok ring orifice jets from carbon buildup (high-BTU burners produce more carbon than standard burners), failed high-capacity gas valve, igniter failure from the intense heat environment. We carry appropriate parts and tools for high-BTU burner repair across all five SoCal counties. When you call, mention "wok range" and we'll confirm the right tech and parts for your visit.</p>
