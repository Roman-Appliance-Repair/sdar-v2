// src/pages/commercial/range-repair/burner-not-igniting.astro
// Wave 13 — Range burner not igniting failure-mode sub-service.
// Open burner / hot-top / even-heat plate distinctions. 6/10/12 burner configurations.
import Layout from '../../../layouts/Layout.astro';
import CommercialHero from '../../../components/CommercialHero.astro';
import { MAIN_PHONE } from '../../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/commercial/range-repair/burner-not-igniting/";

const title = "Commercial Range Burner Not Igniting LA — Same Day";
const description = `Commercial range burner won't ignite? LA same-day. Open burner, hot-top, even-heat plate. Pilot cluster, spark, gas valve. $120.`;

const faqs = [
  {
    q: "One burner on our 6-burner Vulcan VR-36 won't light. Others fine.",
    a: "Single-burner-out diagnostic depends on the architecture. (1) Open-burner range: each burner has its own pilot or spark electrode plus its own gas valve. Single-burner failure typically means that station's spark electrode failed (electronic ignition) or pilot/thermocouple failed (standing pilot). $220-440 station-specific repair. (2) Hot-top or even-heat plate range: large heating element under a steel plate, single-plate failure usually means the heating element burned out (electric) or the under-plate burner cluster failed (gas). $480-880 plate-element repair. Most commercial ranges in LA are open-burner; we identify which type at the diagnostic visit."
  },
  {
    q: "Pilot light cluster issue. Adjacent burners affecting each other?",
    a: "Real on standing-pilot range tops. On many open-burner range models (Vulcan VR, older Garland, older Imperial), adjacent burners share a pilot cluster: one pilot serves 2 to 3 burners. If that pilot weakens or extinguishes, all burners served by that pilot won't light reliably. Symptom: 2 or 3 burners in a cluster pattern fail together, not random scattered. Diagnosis: identify the pilot cluster pattern, replace the failing thermocouple ($220 to $340) or pilot orifice ($120 to $200) at the cluster level rather than per-burner."
  },
  {
    q: "Whole range top dead, oven works fine. What's the issue?",
    a: "Range top failures with working oven point to: (1) Range-top gas valve master shutoff (separate from oven gas valve on most commercial ranges) failed or in safety lockout, $120 reset to $480 replacement. (2) Range-top main gas line obstruction or kinked supply, supply-line repair. (3) Master ignition module dedicated to the range-top section (electronic ignition models), $260-440 replacement. (4) Gas pressure drop only at range-top stations (pressure adequate at oven section but inadequate at range top, points to manifold balancing issue). About 20 percent of whole-range-top failures resolve at the safety reset alone."
  },
  {
    q: "Brand failure-pattern map for commercial ranges?",
    a: "Vulcan VR (ITW Food Equipment Group, since 1986): pilot cluster thermocouple year 4-7, $220-340 typical. Garland Master Series M (Welbilt, formerly Manitowoc Foodservice): high-voltage spark module year 5-8 on electronic models, $260-440. Imperial IRGB (Korean independent): pilot cluster on most models, thermocouple year 4-6. Wolf Challenger Commercial (ITW, separate from Wolf residential and Wolf Outdoor brands): premium duty cycle, gas valve year 7-9 typical. Montague Legend (independent Hayward CA): legacy duty, pilot orifice clog year 3-5 common. South Bend (Welbilt): mid-tier duty, spark module year 4-6."
  },
  {
    q: "Hot-top vs even-heat plate ranges. Different diagnostics?",
    a: "Hot-top range (legacy design, common on Vulcan VHP, Garland Sentry HT) has a thick steel plate with under-plate burner cluster firing all under it. Even-heat plate range (newer design, common on Vulcan VEH, Garland Master EH) uses zone-controlled burners under a more sophisticated plate that distributes heat more evenly. Both fail similarly: under-plate burner failure rather than visible burner. Diagnostic requires plate removal to access the burner cluster, more labor than open-burner work, $260-680 typical repair scope plus parts."
  },
  {
    q: "Range-top with integrated charbroiler module. Same as charbroiler page?",
    a: "Some Vulcan VR models include integrated charbroiler module replacing 2 to 4 burner positions. Repair scope mostly matches our <a href='/commercial/charbroiler-repair/burner-not-lighting/'>charbroiler burner-not-lighting page</a>: same burner-port carbon buildup pattern, same spark/pilot diagnostic, same brand-failure pattern. The only difference is access (the charbroiler module on a range top is sometimes harder to remove than a standalone charbroiler). Pricing is similar to standalone charbroiler service."
  },
  {
    q: "What's your warranty?",
    a: "90 days SDAR labor and parts on every repair. Brand component warranties (Vulcan ITW, Garland Welbilt, Imperial, Wolf Range ITW, Montague, South Bend Welbilt) processed separately through manufacturer authorized service network. BHGS #A49573, BBB A+ accredited, EPA 608 Universal certified #1346255700410."
  }
];

const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair", "url": canonical, "telephone": phone, "priceRange": "$$",
    "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "08:00", "closes": "20:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "00:00", "closes": "00:00" }
      ],
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },{ "@type": "AdministrativeArea", "name": "Orange County" },{ "@type": "AdministrativeArea", "name": "Ventura County" },{ "@type": "AdministrativeArea", "name": "San Bernardino County" },{ "@type": "AdministrativeArea", "name": "Riverside County" }
    ]
  },
