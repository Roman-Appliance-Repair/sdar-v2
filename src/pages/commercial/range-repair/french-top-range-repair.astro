        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "00:00", "closes": "00:00" }
      ],
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": canonical + "#service",
    "serviceType": "French Top Range Repair",
    "name": "French Top Range Repair Service",
    "url": canonical,
    "description": "French top range repair across all five SoCal counties. Solid steel plate cooking surface with multiple underneath burners providing radiant heat zones. Vulcan VR-FT 36/48, Wolf Challenger XL FT 48 (Wolf Industrial commercial), Garland Master FT 36, Montague Legend FT 36. Underneath burner igniter and thermocouple service, multi-burner heat distribution diagnostic, plate warping coordination with specialty fabricators. Specialty trade, fewer LA shops handle. BHGS #A49573. EPA 608 Universal certified (#1346255700410).  scope.",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
