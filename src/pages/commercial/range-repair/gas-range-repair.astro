const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/commercial/range-repair/gas-range-repair/";

const title = "Commercial Gas Range Repair LA | Vulcan VR, Garland Master, Wolf, $120 Diagnostic";
const description = "Commercial gas range repair across LA, OC, Ventura. Vulcan, Garland, Imperial, Wolf, Montague. 6-burner, 10-burner, with oven. BHGS #A49573. $120 dx.";

const faqs = [
  {
    q: "My commercial gas range won't ignite on multiple burners. What's wrong?",
    a: "Multi-burner ignition failure usually points to upstream issues, not coincidental simultaneous failures. Most likely: gas pressure low at the manifold (LA commercial kitchens often have 1\" gas line that's undersized for full BTU load), pilot system failure on older models, or main gas valve degradation. We diagnose with manometer pressure check at the manifold first, single-burner igniter test second. Single-burner igniter failures cluster at year 4 to 7 and are individual replacements ($260 to $440 per burner)."
  },
  {
    q: "How often should commercial gas ranges be serviced?",
    a: "Annual service minimum; quarterly for high-volume operations (12-16 hour service days, continuous high-heat). Annual service includes burner head deep cleaning (carbon and grease buildup affects flame quality), igniter testing, thermocouple millivolt measurement, gas pressure check at the manifold, oven thermostat calibration. Quarterly contracts run $280 to $440 per visit; annual maintenance contracts cost less than the average single emergency repair."
  },
  {
    q: "Vulcan VR vs Garland Master vs Wolf Challenger XL, which is more reliable?",
    a: "Honest answer. Vulcan VR Series (ITW Food Equipment Group) has the broadest LA install base, most accessible parts pipeline, and is dominant in mid-tier commercial. Garland Master Series M (Welbilt) is competitive in similar tier with slightly different burner geometry. Wolf Challenger XL (Wolf Industrial / Sub-Zero Group commercial division, separate from residential Wolf) sits at premium tier with heavier-duty stainless construction. All three are repairable through year 15+ with proper maintenance. American Range Performer ARTGS (Cypress, CA local manufacturer) is competitive with Vulcan VR at slightly lower price point."
  },
  {
    q: "What gas line size do I need for a commercial range?",
    a: "Depends on total BTU load. A 6-burner commercial range (each burner 25,000 to 35,000 BTU vs 12,000 to 18,000 residential) plus oven below requires roughly 200,000+ BTU total capacity. That typically needs 1\" gas line minimum from the meter, often 1-1/4\" for larger units (8-burner with double oven). Many LA commercial kitchens run undersized lines that worked for previous lighter equipment and now starve the new range. We diagnose with manometer at the manifold; line resizing is plumber trade, we coordinate."
  },
  {
    q: "Wolf commercial vs residential Wolf, what's the difference?",
    a: "Different product lines under the same parent (Sub-Zero Group). Wolf Challenger XL CHSC60 and similar commercial models equal institutional and restaurant equipment, separate parts catalog from residential Wolf cooking. Different authorized service networks. We service both. Critical because aftermarket parts and online sources sometimes mismatch the two; we verify by serial number and model prefix before sourcing parts."
  },
  {
    q: "Why do my burner igniters keep failing?",
    a: "Three common causes. (1) Carbon and grease buildup on the spark electrode pits the contact surface, intermittent spark eventually fails. Annual burner head cleaning prevents. (2) Moisture from cleaning practices (water sprayed near electrode area) corrodes contacts. (3) Gas pressure fluctuation creates incomplete combustion which leaves carbon residue on the electrode. Diagnostic order: clean and test, then pressure test, then replace. Year 4 to 7 igniter life is typical with proper maintenance; worse than 4 years usually points to one of these underlying issues."
  },
  {
    q: "What's your warranty?",
    a: "90 days SDAR labor warranty on every repair. Component manufacturer warranties (Vulcan, Garland, Wolf, American Range, Southbend, Imperial, Montague) processed separately through the manufacturer's authorized network. BHGS #A49573. EPA 608 Universal certified (#1346255700410).  scope. BBB A+ accredited."
  }
];

