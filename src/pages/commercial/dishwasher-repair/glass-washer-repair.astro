const title = "Commercial Glass Washer Repair Los Angeles — Same Day";
const description = "Commercial bar glass washer repair across SoCal. Spinning wash arms, dispensers, drain pumps. BHGS #A49573.";

const faqs = [
  {
    q: "What's different about a glass washer vs an undercounter dishwasher?",
    a: "Glass washers run lower temp (130 to 140°F) to preserve etched and hand-blown glassware that high-temp dishwashers would etch. Cycles are faster (60 to 90 seconds vs 90 seconds to 4 minutes). Wash arms typically spin (rotational) rather than fixed-spray. Detergent and rinse aid concentrations are different. Different machine, different repair scope."
  },
  {
    q: "Do you service Hoshizaki HG-100, CMA Glass Mizer, and Champion CG series?",
    a: "Yes. These three platforms cover the LA bar glass washer market. Hoshizaki HG-100 (Hoshizaki commercial line), CMA Glass Mizer (Cleveland-based specialist), Champion CG-2 (Ali Group, sister brand to Scotsman ice and Beverage-Air refrigeration). We carry common dispenser solenoids, drain pumps, and water inlet valves on the van."
  },
  {
    q: "My glass washer's wash arms aren't spinning. What's wrong?",
    a: "Most common cause: jets clogged with bar residue (sugar syrup, citrus pulp, beer foam protein). Spinning relies on jet thrust, clogged jets means no rotation. Solution: deep clean of wash arm jets and inlet manifold. $200 to $340 service typical. If arm bearing has seized from sustained jet imbalance, replacement is $360 to $540."
  },
  {
    q: "Glass washer cycle is too short to actually clean glasses. Is that normal?",
    a: "Glass washers are designed for fast cycles (60 to 90 seconds) because bar service needs throughput. The trade-off is that pre-rinsing matters more, detergent feed rate must be calibrated, and rinse aid concentration controls spotting. If glassware is coming out dirty, the issue is typically detergent dispenser feed rate or jet clog, not cycle length."
  },
  {
    q: "How fast can you respond to a bar emergency?",
    a: "Same-day across LA, Orange, Ventura. Phones answered 24/7. Friday and Saturday evenings are our highest bar dispatch volume. No emergency surcharge, $120 anytime."
  },
  {
    q: "What's your warranty?",
    a: "90 days SDAR labor warranty on every repair. BHGS #A49573, EPA 608 Universal certified (#1346255700410), BBB A+ accredited."
  }
];

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": canonical + "#business",
    "name": "Same Day Appliance Repair",
    "url": canonical,
    "telephone": phone,
    "priceRange": "$$$",
    "description": "Commercial bar glass washer repair across all five SoCal counties. Hoshizaki HG-100, CMA Glass Mizer, Champion CG-2 specialists. BHGS #A49573. EPA 608 Universal certified #1346255700410. BBB A+ accredited. Phones answered 24/7.",
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": canonical + "#service",
    "serviceType": "Bar Glass Washer Repair",
    "name": "Commercial Bar Glass Washer Repair Service",
    "url": canonical,
    "description": "Commercial bar glass washer repair across all five SoCal counties. Lower-temp (130 to 140°F) machines designed to preserve etched and hand-blown glassware. 60 to 90 second cycle times. Brands: Hoshizaki HG-100, CMA Glass Mizer, Champion CG-2, Lamb LM, Moyer Diebel. Spinning wash arm jet cleaning, detergent and rinse aid dispenser solenoids, drain pump, door switch, water inlet valve. BHGS #A49573. EPA 608 Universal #1346255700410.",
    "provider": { "@id": canonical + "#business" },
