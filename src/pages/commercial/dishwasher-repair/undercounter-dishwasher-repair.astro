  .num-list { padding-left: 22px; margin: 14px 0 0; }
  .num-list li { font-size: 0.98rem; line-height: 1.7; color: var(--text); margin-bottom: 12px; }
  .num-list strong { color: var(--text); }
  .story { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 22px 26px; margin-bottom: 14px; }
  .story h3 { font-size: 1rem; font-weight: 800; margin: 0 0 10px; color: var(--text); line-height: 1.35; }
  .story p { font-size: 0.95rem; margin: 0; line-height: 1.7; }
  .price-table { width: 100%; border-collapse: collapse; margin: 24px 0 16px; font-size: 0.95rem; background: #fff; }
  .price-table th { text-align: left; background: var(--black); color: #fff; padding: 12px 16px; font-weight: 700; font-size: 0.85rem; }
  .price-table td { padding: 12px 16px; border-bottom: 1px solid var(--border); }
  .price-table tr:nth-child(even) td { background: #fafafa; }
  .price-table tr:last-child td { font-weight: 700; }
  .price-note { font-size: 0.92rem; color: var(--muted); margin-top: 16px; padding: 14px 18px; background: #fff; border-left: 3px solid var(--red); border-radius: 4px; }
  .why-list { margin: 18px 0; padding-left: 22px; }
  .why-list li { margin-bottom: 14px; line-height: 1.7; font-size: 0.98rem; }
  .why-list strong { color: var(--text); }
  .faq-list { margin-top: 24px; }
  .faq-item { background: #fff; border: 1px solid var(--border); border-radius: 6px; padding: 16px 22px; margin-bottom: 10px; }
  .faq-item summary { font-weight: 700; cursor: pointer; font-size: 0.98rem; color: var(--text); list-style: none; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::before { content: "+ "; color: var(--red); font-weight: 800; margin-right: 6px; }
  .faq-item[open] summary::before { content: "− "; }
  .faq-item p { font-size: 0.93rem; color: var(--text); line-height: 1.7; margin: 12px 0 0; }
  .bottom-cta { background: var(--red); padding: 64px 24px; text-align: center; color: #fff; }
  .bottom-cta h2 { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; margin: 0 0 14px; color: #fff; }
  .bottom-cta p { color: rgba(255,255,255,0.92); margin: 0 0 26px; font-size: 1.05rem; }
  .cta-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: #fff; color: var(--red); padding: 14px 28px; border-radius: 5px; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 14px 28px; border-radius: 5px; border: 2px solid rgba(255,255,255,0.5); font-weight: 600; text-decoration: none; }
</style>
