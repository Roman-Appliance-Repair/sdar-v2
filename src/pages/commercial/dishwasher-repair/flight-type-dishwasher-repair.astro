    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": canonical + "#business",
    "name": "Same Day Appliance Repair",
    "url": canonical,
    "telephone": phone,
    "priceRange": "$$$",
    "description": "Flight type institutional dishwasher repair across all five SoCal counties. Hobart FT-900, FT-1000, FT-1500 specialists. Hospitals, universities, large cafeterias. BHGS #A49573. EPA 608 Universal certified #1346255700410. BBB Accredited Business. Phones answered 24/7.",
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": canonical + "#service",
    "serviceType": "Flight Type Dishwasher Repair",
    "name": "Commercial Flight Type Dishwasher Repair Service",
    "url": canonical,
    "description": "Flight type institutional dishwasher repair across all five SoCal counties. Hobart FT-900, FT-1000, FT-1500 institutional flight type with continuous peg flight, throughput 1,000+ pieces per hour. Pre-rinse spray nozzles, wash tank heater (electric or steam-injected), conveyor motor, scrap collector, multi-zone door switches, final-rinse booster (NSF 180°F compliance), drain solenoid. BHGS #A49573. EPA 608 Universal #1346255700410.",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "offers": {
      "@type": "Offer",
      "priceRange": "$120-$3000",
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "120.00",
        "priceCurrency": "USD",
        "description": "Commercial-tier diagnostic fee, applied toward repair. No emergency surcharge."
      }
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map((f) => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Commercial", "item": "https://samedayappliance.repair/commercial/" },
      { "@type": "ListItem", "position": 3, "name": "Dishwasher Repair", "item": "https://samedayappliance.repair/commercial/dishwasher-repair/" },
