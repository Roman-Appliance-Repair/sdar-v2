---
// src/pages/commercial/dishwasher-repair/flight-type-dishwasher-repair.astro
// Phase B-1 — sub-service under commercial dishwasher pillar.
// Architecture: institutional 1,000+ dishes/hour. Hobart FT dominant.
// Hospitals, universities, large cafeterias. Steam-injected or electric tanks.
// $120 commercial diagnostic. BHGS #A49573 + EPA 608 Universal #1346255700410.
import Layout from '../../../layouts/Layout.astro';
import CommercialHero from '../../../components/CommercialHero.astro';
import { MAIN_PHONE } from '../../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/commercial/dishwasher-repair/flight-type-dishwasher-repair/";

const title = "Commercial Flight-Type Dishwasher Repair LA — Same Day";
const description = "Flight type dishwasher repair across SoCal. Hobart FT-900, FT-1000, FT-1500 institutional. Hospitals, universities, cafeterias. BHGS #A49573. (424) 325-0520.";

const faqs = [
  {
    q: "What's the difference between flight type and rack conveyor?",
    a: "Rack conveyor moves racks of dishes through wash zones, throughput 200 to 400 racks per hour, restaurant scale. Flight type uses a continuous flight of pegs (no racks) that carries individual plates and trays through pre-wash, wash, rinse, and final-rinse zones, throughput 1,000+ pieces per hour, hospital and university scale. Different drive system, different repair playbook."
  },
  {
    q: "Do you service Hobart FT-900, FT-1000, and FT-1500?",
    a: "Yes. The Hobart FT line dominates institutional installs in LA hospitals and universities. We carry common conveyor motors, scrap collector parts, multi-zone door switches, and tank heater elements for these models. FT-900 (smaller institutional), FT-1000 (mid), FT-1500 (large hospital and university scale)."
  },
  {
    q: "My flight type's pre-rinse spray nozzles are clogged. What's the fix?",
    a: "Hard-water mineral scale buildup on spray nozzles is the most common pre-rinse issue. Solution: deep descale of pre-rinse manifold and nozzles. We use food-safe descaler, run a cleaning cycle, verify spray pattern, document. $360 to $580 typical. If nozzle ports are heavily corroded past cleaning, replacement is required."
  },
  {
    q: "Tank heater is steam-injected. Do you do steam line work?",
    a: "We do the dishwasher-side steam injection (steam control valve, steam coil cleaning, condensate trap servicing). We don't do upstream steam supply line work, that's a steam plumbing trade. If your steam supply pressure is off, we identify it and refer to a steam contractor."
  },
  {
    q: "What's the typical service call cost on a Hobart FT?",
    a: "$120 commercial diagnostic, applied toward repair. Most flight type repairs run $980 to $2,400 all-in due to scale and complexity. Conveyor motor, tank heater, multi-zone door switch chain, scrap collector. We provide HACCP temperature documentation post-repair for institutional records."
  },
  {
    q: "What's your warranty?",
    a: "90 days SDAR labor warranty on every repair. BHGS #A49573, EPA 608 Universal certified (#1346255700410), BBB Accredited Business."
  }
];

const schemaJsons = [
