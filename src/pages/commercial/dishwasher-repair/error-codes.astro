---
// src/pages/commercial/dishwasher-repair/error-codes.astro
// Wave 12a — Cluster 04 dishwashers, failure-mode sub.
// Error code reference table for top brands: Hobart (CRS, AM), Champion (86, DH-6000),
// Jackson (AJ, Tempstar, DishStar), CMA, Meiko, Insinger. Code-to-cause translation.
// Pre-call info: model + serial + full code = faster repair. $120 commercial.
// BHGS #A49573 + EPA 608 #1346255700410. Em-dash budget ≤2.

import Layout from '../../../layouts/Layout.astro';
import CommercialHero from '../../../components/CommercialHero.astro';
import { MAIN_PHONE } from '../../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/commercial/dishwasher-repair/error-codes/";

const title = "Commercial Dishwasher Error Codes LA | Hobart, Champion, Jackson Reference | $120";
const description = "Hobart, Champion, Jackson, CMA, Meiko error code reference. E1 supply, E2 drain, F1/F2/F3 board, A1-A6 booster faults. Code-to-cause translation. $120 dx.";

const faqs = [
  {
    q: "What information do you need when I call about an error code?",
    a: "Three things: brand and model number (visible on the rating plate inside the door or on the side panel), serial number, and the full error code as it displays. Bonus: how long has it been displaying, and does the unit complete cycles or stop. With model + serial + code, we localize the actual fault before arrival, often skip parts of the diagnostic, and arrive with the right replacement on the truck. Calls without these details take longer and cost more in diagnostic time."
  },
  {
    q: "Why does the same error code mean different things on Hobart vs Jackson?",
    a: "Manufacturers use proprietary code architectures. Hobart E codes are different from Jackson E codes are different from Champion F codes. We cross-reference each manufacturer's service manual at the diagnostic. The code is a starting point; the fault is what the code routes us to test. Same code letter and number can mean booster heater on one brand and door switch on another."
  },
  {
    q: "My Hobart CRS-66A is throwing E1. What is it?",
    a: "Hobart E1 typically means low water level in the wash tank. Three common causes: water supply shut off (check building valve), supply solenoid failed (replacement $180 to $340), or water level sensor fouled with mineral scale (clean at $120 dx, no parts). We test supply pressure first because it is the cheapest fault to confirm."
  },
  {
    q: "Champion 86 series displaying F2. Critical?",
    a: "Champion F2 typically points to wash tank temperature fault (heater element or thermostat). Not immediately food-safety critical because the dishwasher will not run a sanitizing cycle without temp; the unit fails safe. But it is a same-day repair because the unit is offline. Element replacement $440 to $780 pro-tier; thermostat $180 to $340."
  },
  {
    q: "Jackson AJ-66 showing A4 booster fault. Cost?",
    a: "Jackson A-series codes are booster-heater specific. A4 typically indicates booster element failure or thermostat fault on AJ-66 platform. Element replacement $440 to $780 plus labor; thermostat $180 to $340. We test both at the diagnostic before quoting. Final rinse temperature documentation on the service report supports your Health Department records."
  },
  {
    q: "CMA Dishmachines or Meiko showing a code I don't recognize. Do you service those too?",
    a: "Yes. We service CMA Dishmachines (Welbilt subsidiary, mid-tier door-type and undercounter), Meiko (independent German pro-tier), Insinger (ITW family), Stero (Welbilt subsidiary), and Fagor Industrial (Onnera Group, Spanish). Each has its own code architecture; we keep service-manual references on hand for all of them. Volunteer the model number and code when you call and we localize."
  },
  {
    q: "What's your warranty?",
    a: "90 days SDAR labor warranty on every repair. BHGS #A49573 and EPA 608 Universal certified (#1346255700410). BBB A+ accredited."
  }
];

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": canonical + "#business",
    "name": "Same Day Appliance Repair",
    "url": canonical,
    "telephone": phone,
    "priceRange": "$$",
    "address": {
      "@type": "PostalAddress",
      
      "addressLocality": "Los Angeles",
      "addressRegion": "CA",
      "postalCode": "90048",
      "addressCountry": "US"
    },
    "openingHoursSpecification": [
      { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"], "opens": "00:00", "closes": "23:59" }
    ],
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": canonical + "#service",
    "serviceType": "Commercial Dishwasher Error Code Diagnostic",
    "name": "Commercial Dishwasher Error Code Diagnostic and Repair",
    "url": canonical,
    "description": "Commercial dishwasher error code diagnostic across all five SoCal counties. Hobart CRS, AM platform error codes (E1 through E9). Champion 86 and DH-6000 F-series codes. Jackson AJ, Tempstar, DishStar A-series and E-series codes. CMA Dishmachines, Meiko, Insinger, Stero, Fagor Industrial code references. Code-to-cause translation, model + serial + code pre-call info accelerates repair. BHGS #A49573 and EPA 608 Universal certified (#1346255700410). $120 commercial diagnostic.",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "offers": {
      "@type": "Offer",
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "120.00",
        "priceCurrency": "USD",
        "description": "Commercial diagnostic fee, applied toward repair"
      }
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Commercial", "item": "https://samedayappliance.repair/commercial/" },
      { "@type": "ListItem", "position": 3, "name": "Commercial Dishwasher Repair", "item": "https://samedayappliance.repair/commercial/dishwasher-repair/" },
      { "@type": "ListItem", "position": 4, "name": "Error Codes", "item": canonical }
    ]
