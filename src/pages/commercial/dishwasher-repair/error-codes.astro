  .bullet-list { padding-left: 22px; margin: 14px 0; }
  .bullet-list li { font-size: 0.98rem; line-height: 1.7; color: var(--text); margin-bottom: 10px; }
  .bullet-list strong { color: var(--text); font-weight: 700; }
