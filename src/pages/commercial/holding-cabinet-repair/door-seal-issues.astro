---
// src/pages/commercial/holding-cabinet-repair/door-seal-issues.astro
// Wave 17 — Holding cabinet door seal issues failure-mode sub-service.
import Layout from '../../../layouts/Layout.astro';
import CommercialHero from '../../../components/CommercialHero.astro';
import { MAIN_PHONE } from '../../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/commercial/holding-cabinet-repair/door-seal-issues/";

const title = "Holding Cabinet Door Seal Issues LA | Gasket, Hinge, Latch | $120 Diagnostic";
const description = `Holding cabinet door not sealing? LA same-day. Alto-Shaam, Cres Cor, Hatco, Metro, Vollrath. $120 commercial.`;

const faqs = [
  {
    q: "Door doesn't seal fully. Single most common cause?",
    a: "Door gasket compression and hardening, year 5-8 typical. Holding cabinet gaskets are silicone or EPDM rubber rated for sustained heat exposure but compress and harden over years of thermal cycling plus mechanical compression at every door close. Symptom: visible gap between door and cabinet face, heat escaping (you can feel warm air at the gap), cabinet element cycles more frequently because heat loss accelerates. Replacement gasket runs $180-280 part plus labor. We measure compression with feeler gauges or thumb-pressure test at the diagnostic; quality gasket compresses slightly and springs back, degraded gasket is hardened or visibly cracked."
  },
  {
    q: "Hinge sag on year-7 cabinet. Repair or replace?",
    a: "Usually repair. Door hinges sag from years of full-weight door cycles, especially on heavy-duty stainless doors with insulated cores (Cres Cor, premium Alto-Shaam). Symptom: door sits slightly off square, doesn't close fully against gasket even with good gasket. Hinge service runs $120-220 (adjustment, lubrication, sometimes shimming); hinge replacement $260-380 if mechanism is worn beyond adjustment. About 70 percent of hinge calls resolve at adjustment + lubrication without parts. We carry common Alto-Shaam, Cres Cor, Metro hinge sets on the truck."
  },
  {
    q: "Latch wear from heavy use. Replacement frequency?",
    a: "Year 4-7 on heavy-use operations (banquet, hospital meal-tray service, school nutrition central kitchens with multiple cabinets). Latch wear presents as door not staying closed, latch slipping under load, or latch release becoming stiff. Replacement runs $120-200 typical. We see latch wear most on Cres Cor banquet roll-ins (transport vibration accelerates wear) and Metro C5 series (frequent open-close on busy kitchens). Less common on Alto-Shaam stationary cabinets where latch sees lower duty cycle."
  },
  {
    q: "Door alignment after gasket replacement. Common follow-up issue?",
    a: "Yes, common. New gasket sometimes affects door close geometry — old compressed gasket allowed the door to close at slightly off-square angle, but new gasket (full thickness) causes the door to sit differently. Symptom after gasket replacement: door doesn't close as easily, latch needs adjustment, hinge needs minor shimming. We re-verify door alignment as part of every gasket replacement service, adjust as needed, included in the original service price. About 30 percent of gasket-replacement jobs need follow-up alignment in our experience."
  },
  {
    q: "Door seal failure causing food safety issue. Health Department angle?",
    a: "Direct compliance issue. Failed door seal causes cabinet temperature drift below 135°F (CA Retail Food Code minimum on hot-held foods). LA County DPH and equivalent agencies cite this on routine inspection. Operations should not run cabinets with failed door seals during food service. We document service work for HD compliance file: gasket condition before, gasket replacement scope, post-service temperature verification at multiple chamber points. Annual PM contract recommended for restaurants and catering operations under regular HD inspection."
  },
  {
    q: "Multi-door cabinets. Different gasket pricing?",
    a: "Yes. Single-door cabinets (most Alto-Shaam, Hatco countertop, Metro C5) have one gasket per door, $180-280 typical. Multi-door cabinets (some Cres Cor banquet roll-ins, larger Alto-Shaam 1200-S models) have multiple gaskets, typically $180-280 per gasket. We replace all gaskets simultaneously when the customer prefers (multiple gaskets often age together; replacing one and not others means we'll be back in 6-12 months for the next). Bundled multi-gasket replacement runs $280-480 for two gaskets or $380-680 for three gaskets."
  },
  {
    q: "What's your warranty?",
    a: "90 days SDAR labor and parts on every repair, including gasket and hinge work. Brand component warranties (Alto-Shaam, Cres Cor, Hatco, Metro Ali Group, Vollrath) processed separately. BHGS #A49573, BBB A+ accredited, EPA 608 Universal certified #1346255700410."
  }
];

const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair", "url": canonical, "telephone": phone, "priceRange": "$$",
    "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "08:00", "closes": "20:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "00:00", "closes": "00:00" }
      ],
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },{ "@type": "AdministrativeArea", "name": "Orange County" },{ "@type": "AdministrativeArea", "name": "Ventura County" },{ "@type": "AdministrativeArea", "name": "San Bernardino County" },{ "@type": "AdministrativeArea", "name": "Riverside County" }
    ]
  },
  { "@context": "https://schema.org", "@type": "Service", "@id": canonical + "#service",
    "serviceType": "Commercial Holding Cabinet Door Seal Repair", "name": "Holding Cabinet Door Gasket and Hinge Service", "url": canonical,
    "description": "Commercial holding cabinet door seal diagnostic and repair across all five SoCal counties. Door gasket compression and hardening (year 5-8 typical), hinge sag (year 5+), latch wear (year 4-7 heavy duty), door alignment after gasket replacement, multi-door cabinet bundled gasket service. Health Department 135°F+ holding compliance under California Retail Food Code. Alto-Shaam, Cres Cor, Hatco, Metro, Vollrath. $120 commercial diagnostic, applied toward repair. BHGS #A49573, EPA 608 Universal certified #1346255700410.",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },{ "@type": "AdministrativeArea", "name": "Orange County" },{ "@type": "AdministrativeArea", "name": "Ventura County" },{ "@type": "AdministrativeArea", "name": "San Bernardino County" },{ "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "120.00", "priceCurrency": "USD", "description": "Commercial diagnostic fee, applied toward repair" } }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Commercial", "item": "https://samedayappliance.repair/commercial/" },
      { "@type": "ListItem", "position": 3, "name": "Holding Cabinet Repair", "item": "https://samedayappliance.repair/commercial/holding-cabinet-repair/" },
      { "@type": "ListItem", "position": 4, "name": "Door Seal Issues", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>
<Fragment slot="head-scripts">
  {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
</Fragment>

<CommercialHero
  title="Holding Cabinet Door Seal Issues, Same-Day Diagnostic"
  subtitle={`Door not sealing? Gasket compression, hinge sag, latch wear, alignment. Alto-Shaam, Cres Cor, Hatco, Metro, Vollrath. $120 commercial. ${phone}`}
  heroImageTitle="Holding Cabinet Door Seal Issues"
  showBranches={true}
/>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Door seal diagnostic</p>
    <h2>Failed door seal is a Health Department issue, not just a heat-loss issue. Cabinet drift below 135°F is a violation.</h2>

    <p>Door seal failures cluster around four mechanisms. (1) Gasket compression and hardening, year 5-8 typical, $180-280 replacement (single most common cause). (2) Hinge sag, year 5+, $120-220 adjustment service or $260-380 hinge replacement. (3) Latch wear, year 4-7 heavy-use operations, $120-200 replacement. (4) Door alignment issues, often as follow-up after gasket replacement (about 30 percent of gasket jobs need re-alignment).</p>

    <p>Beyond heat-loss economics, this is a Health Department compliance issue. Failed door seal causes cabinet temperature drift below 135°F (CA Retail Food Code minimum on hot-held foods). Operations should not continue using cabinets with failed door seals during food service. We document service work for HD compliance file with post-service temperature verification at multiple chamber points.</p>

    <p>$120 commercial diagnostic, waived with repair. <strong>BHGS #A49573</strong>. <strong>EPA 608 Universal certified #1346255700410</strong>. BBB A+. Phones answered 24/7. Parent: <a href="/commercial/holding-cabinet-repair/">commercial holding cabinet repair</a>.</p>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">Field observations</p>
    <h2 class="section-title">Top causes by frequency.</h2>
    <ol class="num-list">
      <li><strong>Gasket compression and hardening (year 5-8).</strong> Single most common cause. Visible gap, hardened or cracked silicone/EPDM. $180-280 replacement.</li>
      <li><strong>Hinge sag (year 5+).</strong> Door sits off-square. $120-220 adjustment, $260-380 replacement.</li>
      <li><strong>Latch wear (year 4-7 heavy use).</strong> Door doesn't stay closed. $120-200 replacement.</li>
      <li><strong>Door alignment after gasket replacement.</strong> ~30 percent of gasket jobs need follow-up. Included in service.</li>
      <li><strong>Door corner damage from forklift / dolly impact.</strong> Banquet roll-in installs (Cres Cor) most affected. $260-480 corner repair.</li>
      <li><strong>Door window seal failure (window-equipped models).</strong> $260-380 reseal service.</li>
      <li><strong>Gasket adhesive failure (heavy commercial duty).</strong> Edge separating from cabinet face. $180-280 reset + reseal.</li>
      <li><strong>Hinge spring weakening (Alto-Shaam soft-close models).</strong> $180-280 spring service.</li>
    </ol>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Diagnostic walkthrough</p>
    <h2 class="section-title">Practitioner sequence.</h2>
    <ol class="num-list">
      <li><strong>Visual gasket inspection.</strong> Hardness, cracks, edge separation, visible gap when door closed.</li>
      <li><strong>Compression test.</strong> Thumb pressure or feeler gauge; quality gasket compresses and springs back.</li>
      <li><strong>Door alignment check.</strong> Door sits square against cabinet face? No daylight gaps along edge?</li>
      <li><strong>Hinge inspection.</strong> Sag, wear, lubrication, mounting hardware tight.</li>
      <li><strong>Latch operation.</strong> Smooth release, secure close, no slippage under load.</li>
      <li><strong>Heat loss verification.</strong> Hand at door edge during operation; hot air escape indicates seal failure.</li>
      <li><strong>Multi-point chamber temperature.</strong> Door-side vs far-side; uneven cooling indicates seal-side heat loss.</li>
      <li><strong>Window seal test (if equipped).</strong> Visible condensation between glass panes or rubber seal degradation.</li>
    </ol>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">Honest opinion</p>
    <h2 class="section-title">Door gasket replacement is the highest ROI maintenance on holding equipment.</h2>
    <p>The single most cost-effective preventive action on commercial holding cabinets is door gasket replacement on schedule (year 5-8 typical lifespan). Cost: $180-280 per gasket. Avoided cost: heating element burnout from over-cycling due to heat loss ($480-720), HD compliance violation, food-quality degradation. We see operations skip gasket replacement until the heating element fails (because gasket failure was driving over-cycling), then pay for both gasket AND element replacement. Schedule the gasket, save the element. Some operations adopt this only after one expensive reactive failure; the math is obvious in retrospect.</p>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Pricing</p>
    <h2 class="section-title">Door seal repair costs.</h2>
    <p class="lead">$120 commercial diagnostic, waived with repair.</p>
    <table class="price-table">
      <thead><tr><th>Repair</th><th>Typical Cost</th></tr></thead>
      <tbody>
        <tr><td>Diagnostic</td><td>$120, waived with repair</td></tr>
        <tr><td>Door gasket replacement (single door)</td><td>$180 to $280</td></tr>
        <tr><td>Multi-gasket bundled replacement (2 doors)</td><td>$280 to $480</td></tr>
        <tr><td>Multi-gasket bundled replacement (3 doors)</td><td>$380 to $680</td></tr>
        <tr><td>Hinge adjustment service</td><td>$120 to $220</td></tr>
        <tr><td>Hinge replacement</td><td>$260 to $380</td></tr>
        <tr><td>Latch replacement</td><td>$120 to $200</td></tr>
        <tr><td>Door corner damage repair (transport impact)</td><td>$260 to $480</td></tr>
        <tr><td>Door window seal replacement</td><td>$260 to $380</td></tr>
        <tr><td>Hinge spring service (soft-close)</td><td>$180 to $280</td></tr>
        <tr><td>Annual PM (gasket inspection + door alignment)</td><td>$120 to $200</td></tr>
        <tr><td>Warranty</td><td>90 days parts and labor</td></tr>
      </tbody>
    </table>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">FAQ</p>
    <h2 class="section-title">Door seal questions.</h2>
    <div class="faq-list">
