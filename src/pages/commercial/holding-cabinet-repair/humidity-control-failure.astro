    "serviceType": "Commercial Holding Cabinet Humidity Control Repair", "name": "Humidity Control System Diagnostic and Repair", "url": canonical,
    "description": "Commercial holding cabinet humidity control system diagnostic and repair across all five SoCal counties. Winston CVap (Controlled Vapor) HBB / CHV programmable holding (KFC heritage technology), Alto-Shaam Cook & Hold humidity option (CT Express -H, 1000-Th -H, 1750-Th -H), Hatco FSHC humidified models (FSHC-7-1-H, FSHC-12-1-H). Water reservoir scaling (LA hard water year 2-4 PM), evaporator water-bath element (year 6-9), humidity sensor (year 7-10), control board (year 9-13), steam exit valve scaling. Annual descaling PM critical. $120 commercial diagnostic, applied toward repair. BHGS #A49573, EPA 608 Universal certified #1346255700410.",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },{ "@type": "AdministrativeArea", "name": "Orange County" },{ "@type": "AdministrativeArea", "name": "Ventura County" },{ "@type": "AdministrativeArea", "name": "San Bernardino County" },{ "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "120.00", "priceCurrency": "USD", "description": "Commercial diagnostic fee, applied toward repair" } }
