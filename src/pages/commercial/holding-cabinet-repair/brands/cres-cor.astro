---
// src/pages/commercial/holding-cabinet-repair/brands/cres-cor.astro
// Wave 17 — Cres Cor holding cabinet brand page. Insulated heated cabinets.
// Independent Mentor Ohio, founded 1936.
import Layout from '../../../../layouts/Layout.astro';
import CommercialHero from '../../../../components/CommercialHero.astro';
import { MAIN_PHONE } from '../../../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/commercial/holding-cabinet-repair/brands/cres-cor/";

const title = "Cres Cor Holding Cabinet Repair LA | Roll-In, Banquet, Stack-Sterilize | $120";
const description = `Cres Cor heated holding cabinet repair. LA same-day. Roll-In banquet, insulated heated cabinets, dish dollies, stack-sterilize. Independent Ohio since 1936. $120 commercial. ${phone}.`;

const faqs = [
  {
    q: "Why Cres Cor over Alto-Shaam or Hatco?",
    a: "Banquet and high-volume heated transport. Cres Cor's flagship is the insulated roll-in heated holding cabinet, designed to roll directly from kitchen to banquet floor maintaining safe-serve temperatures. Hotel banquet operations, hospital meal-tray service, school nutrition programs, and large catering use Cres Cor more than Alto-Shaam because the value is in the roll-in transport architecture rather than the heat-distribution technology. Alto-Shaam excels at stationary holding with Halo Heat; Cres Cor excels at heated transport. Different specialties.",
  },
  {
    q: "Roll-In banquet cabinet won't heat. Diagnostic?",
    a: "Standard sequence. (1) Power supply at the unit (cord, plug, dedicated 208/240V circuit on full-size models). (2) Heating element continuity test (year 8-12 typical burnout, $480-720 element replacement on insulated cabinet). (3) Thermostat drift (year 6-9, $260-440). (4) Control board failure (year 10-15, $480-680). About 60 percent of Cres Cor 'won't heat' calls resolve at element or thermostat. The insulated chassis itself is very long-lived — we've serviced 25+ year old Cres Cor cabinets where the chassis is original and only the working components have been replaced over the decades.",
  },
  {
    q: "Insulated banquet cabinet vs non-insulated. Different parts patterns?",
    a: "Yes. Insulated cabinets (Cres Cor's specialty) have a vacuum-insulated or foam-insulated double-wall construction that maintains temperature through transport. Failure pattern: lower thermal stress on heating element due to insulated retention (year 10-14 element life vs year 8-12 non-insulated), but vulnerability to insulation breakdown if punctured during transport. We see insulated wall damage in busy banquet operations from forklift collisions, dolly impacts, etc. Insulation repair is specialty work; minor punctures can be sealed ($120-220) but major damage typically means cabinet replacement.",
  },
  {
    q: "Casters and roll-in mobility issues on banquet carts?",
    a: "Common service item we handle. Heavy-duty casters on Cres Cor banquet cabinets wear from years of rolling on commercial kitchen flooring (epoxy, quarry tile, sealed concrete). Symptom: caster won't roll smoothly, locks intermittently, or visibly damaged. Replacement runs $80-180 per caster, typically 4-6 casters per cabinet. We carry common Cres Cor caster sizes on the truck. Minor issue but operations-critical for banquet teams that need cabinets moving smoothly during service.",
  },
  {
    q: "Stack-Sterilize utility cabinets. Different from heated holding?",
    a: "Different equipment category. Stack-Sterilize is Cres Cor's heated dish dolly line, not food holding. Used for sanitization holding of clean dishes at temperature post-dishwasher. Failure pattern is similar (heating element, thermostat, casters) but the temperatures, capacities, and Health Department compliance requirements are different. We service both Stack-Sterilize and food-holding cabinet lines. On a single service call we can address both if your operation runs them adjacent.",
  },
  {
    q: "Health Department 140°F compliance for banquet transport?",
    a: "Critical. CA Retail Food Code requires 135°F minimum on hot-held foods (FDA Food Code 3-501.16 says 140°F but California aligns with 135°F minimum); some local LA County DPH inspectors enforce 140°F as best practice. Banquet transport cabinets must hold safe-serve temperature throughout transport from kitchen to event location. Cres Cor cabinets are designed for this; failures present as cabinet drift below 135°F during transport, food safety violation. Diagnostic on every Cres Cor call includes calibrated thermometer verification at multiple points; if drifting low we identify the cause (thermostat drift, gasket failure, heating element weakening) and quote repair. We document service for HD compliance file.",
  },
  {
    q: "What's your warranty?",
    a: "90 days SDAR labor and parts on every repair. Cres Cor component warranties (heating element, thermostat, casters, control board) processed separately through Cres Cor authorized service network in Mentor Ohio. BHGS #A49573, BBB A+ accredited, EPA 608 Universal certified #1346255700410.",
  },
];

const brandSchema = {
  "@context": "https://schema.org", "@type": "Brand", "@id": canonical + "#brand",
  "name": "Cres Cor",
  "url": "https://www.crescor.com",
  "description": "Cres Cor manufactures insulated heated holding cabinets, banquet roll-in cabinets, dish dollies, and stack-sterilize equipment from Mentor, Ohio. Founded 1936. Independent ownership. Specialty in heated transport for banquet, hotel, and institutional foodservice.",
  "foundingDate": "1936",
  "foundingLocation": { "@type": "Place", "name": "Mentor, Ohio" },
};

const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair", "url": canonical, "telephone": phone, "priceRange": "$$",
    "openingHoursSpecification": [{ "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "08:00", "closes": "20:00" }],
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },{ "@type": "AdministrativeArea", "name": "Orange County" },{ "@type": "AdministrativeArea", "name": "Ventura County" },{ "@type": "AdministrativeArea", "name": "San Bernardino County" },{ "@type": "AdministrativeArea", "name": "Riverside County" },
    ],
  },
  { "@context": "https://schema.org", "@type": "Service", "@id": canonical + "#service",
    "serviceType": "Cres Cor Holding Cabinet Repair", "name": "Cres Cor Insulated Heated Cabinet Repair Service", "url": canonical,
    "description": "Cres Cor heated holding cabinet repair across all five SoCal counties. Roll-In banquet cabinets, insulated heated cabinets, dish dollies (Stack-Sterilize line), banquet carts. Heating element burnout (year 10-14 insulated), thermostat drift (year 6-9), heavy-duty caster wear, control board (year 10-15), insulation damage from transport impact. Hotel banquet, hospital meal-tray, school nutrition, large catering operations. Health Department 135°F+ banquet transport compliance. $120 commercial diagnostic, applied toward repair. BHGS #A49573, EPA 608 Universal certified #1346255700410.",
    "provider": { "@id": canonical + "#business" }, "brand": { "@id": canonical + "#brand" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },{ "@type": "AdministrativeArea", "name": "Orange County" },{ "@type": "AdministrativeArea", "name": "Ventura County" },{ "@type": "AdministrativeArea", "name": "San Bernardino County" },{ "@type": "AdministrativeArea", "name": "Riverside County" },
    ],
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "120.00", "priceCurrency": "USD", "description": "Commercial diagnostic fee, applied toward repair" } },
  },
  brandSchema,
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Commercial", "item": "https://samedayappliance.repair/commercial/" },
      { "@type": "ListItem", "position": 3, "name": "Holding Cabinet Repair", "item": "https://samedayappliance.repair/commercial/holding-cabinet-repair/" },
      { "@type": "ListItem", "position": 4, "name": "Cres Cor", "item": canonical },
    ],
  },
];
---

<Layout title={title} description={description} canonical={canonical}>
<Fragment slot="head-scripts">
  {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
</Fragment>

<CommercialHero
  title="Cres Cor Holding Cabinet & Banquet Roll-In Repair, Same-Day Across LA"
  subtitle={`Insulated heated banquet cabinets, dish dollies, stack-sterilize equipment. Hotel banquet, hospital, school nutrition. $120 commercial diagnostic. ${phone}`}
  heroImageTitle="Cres Cor Holding Cabinet Repair"
  showBranches={true}
/>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Banquet transport specialty</p>
    <h2>Cres Cor owns the heated banquet roll-in market. Insulated transport is the core specialty.</h2>

    <p>Cres Cor is independent (Mentor, Ohio), founded 1936. The flagship specialty is insulated heated holding cabinets designed for banquet roll-in transport from kitchen to event location while maintaining safe-serve temperatures. Hotel banquet operations, hospital meal-tray service, school nutrition programs, and large catering use Cres Cor for the transport architecture; Alto-Shaam owns stationary holding through Halo Heat technology, but Cres Cor owns mobile heated banquet.</p>

    <p>We service the full Cres Cor line across LA, Orange, Ventura, San Bernardino, Riverside. Roll-In banquet cabinets, insulated heated holding cabinets, dish dollies (Stack-Sterilize line for sanitization holding of clean dishes), banquet carts. Common operations: hotel rooftop banquet (Beverly Hilton, Four Seasons LA, Beverly Hills Hotel), hospital meal-tray service (Cedars-Sinai, UCLA Medical, Hoag), school nutrition central kitchens (LAUSD, OUSD), large catering (LACMA events, USC events).</p>

    <p>$120 commercial diagnostic, waived with repair. <strong>BHGS #A49573</strong>. <strong>EPA 608 Universal certified #1346255700410</strong>. BBB A+. Phones answered 24/7. Parent: <a href="/commercial/holding-cabinet-repair/">commercial holding cabinet repair</a>.</p>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">Top failure modes</p>
    <h2 class="section-title">What we see most on Cres Cor.</h2>
    <ol class="num-list">
      <li><strong>Heating element burnout (year 10-14 insulated cabinets).</strong> Insulated chassis extends element life vs non-insulated. $480-720 replacement.</li>
      <li><strong>Thermostat drift (year 6-9).</strong> $260-440 replacement.</li>
      <li><strong>Heavy-duty caster wear (year 4-7 banquet operations).</strong> $80-180 per caster, typically 4-6 per cabinet.</li>
      <li><strong>Control board failure (year 10-15 premium models).</strong> $480-680 replacement.</li>
      <li><strong>Insulation damage from transport impact.</strong> Forklift collisions, dolly impacts. Minor sealing $120-220, major = cabinet replacement.</li>
      <li><strong>Door gasket compression (year 5-8).</strong> $180-280.</li>
      <li><strong>Door latch wear from heavy use (year 4-7).</strong> $120-200.</li>
      <li><strong>Power cord wear from transport flexing (year 6+).</strong> $180-280 cord replacement.</li>
    </ol>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Models we service</p>
    <h2 class="section-title">Full Cres Cor product line.</h2>
    <h3 class="series-h3">Heated Holding Cabinets</h3>
    <ul class="bullet-list">
      <li><strong>Roll-In</strong> banquet cabinets (full-height roll-in for hotel banquet)</li>
      <li><strong>H-138</strong>, <strong>H-238</strong>, <strong>H-339</strong> insulated heated cabinets (mid-volume)</li>
      <li>Insulated banquet carts and chafer cabinets</li>
    </ul>
    <h3 class="series-h3">Dish Dolly + Stack-Sterilize</h3>
    <ul class="bullet-list">
      <li>Stack-Sterilize heated dish dolly (sanitization holding post-dishwasher)</li>
      <li>Heated plate dispensers</li>
      <li>Heated cup dispensers</li>
    </ul>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">Honest opinion</p>
    <h2 class="section-title">Cres Cor cabinets often outlive the kitchen they were installed in.</h2>
    <p>The insulated chassis on a Cres Cor banquet cabinet is built to outlast the original kitchen. We've serviced 25+ year old Cres Cor cabinets where the chassis is original and only the heating element, thermostat, and casters have been replaced over the decades. On year 12+ Cres Cor cabinets we typically recommend continued repair rather than replacement — the chassis is still sound, working components are cheap to replace, and a new equivalent unit costs $4,500 to $9,500. Replacement is rarely the right answer on Cres Cor unless the insulation has been compromised.</p>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Pricing</p>
    <h2 class="section-title">Cres Cor repair costs.</h2>
    <p class="lead">$120 commercial diagnostic, waived with repair.</p>
    <table class="price-table">
      <thead><tr><th>Repair</th><th>Typical Cost</th></tr></thead>
      <tbody>
        <tr><td>Diagnostic</td><td>$120, waived with repair</td></tr>
        <tr><td>Thermostat replacement</td><td>$260 to $440</td></tr>
        <tr><td>Heating element burnout (insulated cabinet)</td><td>$480 to $720</td></tr>
        <tr><td>Heavy-duty caster replacement (per caster)</td><td>$80 to $180</td></tr>
        <tr><td>Door gasket replacement</td><td>$180 to $280</td></tr>
        <tr><td>Door latch wear</td><td>$120 to $200</td></tr>
        <tr><td>Power cord replacement</td><td>$180 to $280</td></tr>
        <tr><td>Control board replacement</td><td>$480 to $680</td></tr>
        <tr><td>Minor insulation seal repair</td><td>$120 to $220</td></tr>
        <tr><td>Annual PM contract (banquet cabinet, single)</td><td>$280 to $480</td></tr>
        <tr><td>Warranty</td><td>90 days parts and labor</td></tr>
      </tbody>
    </table>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">FAQ</p>
    <h2 class="section-title">Cres Cor questions.</h2>
    <div class="faq-list">
      {faqs.map(f => (<details class="faq-item"><summary>{f.q}</summary><p>{f.a}</p></details>))}
    </div>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Related</p>
    <h2 class="section-title">Other holding cabinet brands.</h2>
    <ul class="bullet-list">
      <li><a href="/commercial/holding-cabinet-repair/">Holding cabinet repair (parent pillar)</a></li>
      <li><a href="/commercial/holding-cabinet-repair/brands/alto-shaam/">Alto-Shaam</a> · <a href="/commercial/holding-cabinet-repair/brands/hatco/">Hatco</a> · <a href="/commercial/holding-cabinet-repair/brands/metro/">Metro</a> · <a href="/commercial/holding-cabinet-repair/brands/vollrath/">Vollrath</a></li>
      <li><a href="/commercial/holding-cabinet-repair/not-heating/">Not heating</a> · <a href="/commercial/holding-cabinet-repair/temperature-fluctuating/">Temperature fluctuating</a> · <a href="/commercial/holding-cabinet-repair/door-seal-issues/">Door seal issues</a> · <a href="/commercial/holding-cabinet-repair/humidity-control-failure/">Humidity control failure</a></li>
    </ul>
  </div>
</section>

<section class="bottom-cta">
  <div class="container">
    <h2>Cres Cor banquet cabinet down? Same-day priority.</h2>
    <p>Roll-In, insulated holding, dish dollies across LA, OC, Ventura. $120 commercial diagnostic, waived with repair. BHGS #A49573, EPA 608 Universal #1346255700410.</p>
    <div class="cta-row">
      <a href={phoneHref} class="btn-primary">☎ Call {phone}</a>
      <a href="/contact/" class="btn-secondary">Book Online</a>
    </div>
  </div>
</section>

</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .section { padding: 72px 24px; }
  .section-gray { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; }
  .container.narrow { max-width: 820px; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  .section h2 { font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 800; margin: 0 0 18px; color: var(--text); line-height: 1.2; }
  .section p { font-size: 1rem; line-height: 1.75; margin: 0 0 16px; color: var(--text); }
  .section a { color: var(--red); font-weight: 600; text-decoration: none; }
  .section a:hover { text-decoration: underline; }
  .lead { font-size: 1.05rem; line-height: 1.75; color: var(--text); margin-bottom: 22px; }
  .num-list { padding-left: 22px; margin: 14px 0 0; }
  .num-list li { font-size: 0.98rem; line-height: 1.7; color: var(--text); margin-bottom: 10px; }
  .bullet-list { padding-left: 22px; margin: 14px 0 18px; }
  .bullet-list li { font-size: 1rem; line-height: 1.65; color: var(--text); margin-bottom: 6px; }
  .series-h3 { font-size: 1.1rem; font-weight: 800; margin: 28px 0 10px; }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 22px; background: #fff; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
  .price-table th, .price-table td { padding: 12px 16px; text-align: left; border-bottom: 1px solid var(--border); font-size: 0.95rem; }
  .price-table th { background: var(--gray); font-weight: 700; color: var(--text); }
  .price-table tr:last-child td { border-bottom: none; }
  .faq-list { margin-top: 24px; }
  .faq-item { background: #fff; border: 1px solid var(--border); border-radius: 6px; padding: 18px 22px; margin-bottom: 12px; }
  .faq-item summary { font-weight: 700; cursor: pointer; font-size: 1rem; color: var(--text); list-style: none; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::before { content: "+ "; color: var(--red); font-weight: 800; margin-right: 6px; }
  .faq-item[open] summary::before { content: "− "; }
  .faq-item p { font-size: 0.95rem; color: var(--text); line-height: 1.75; margin: 14px 0 0; }
  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { color: #fff; margin: 0 0 14px; font-size: 1.7rem; }
  .bottom-cta p { color: #c9c9c9; margin: 0 0 26px; max-width: 720px; margin-left: auto; margin-right: auto; }
  .cta-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 14px 28px; border-radius: 5px; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 14px 28px; border-radius: 5px; border: 2px solid rgba(255,255,255,0.35); font-weight: 600; text-decoration: none; }
</style>
