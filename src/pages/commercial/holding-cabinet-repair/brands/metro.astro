---
// src/pages/commercial/holding-cabinet-repair/brands/metro.astro
// Wave 17 — Metro C5 holding cabinet brand page. Ali Group ownership.
import Layout from '../../../../layouts/Layout.astro';
import CommercialHero from '../../../../components/CommercialHero.astro';
import { MAIN_PHONE } from '../../../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/commercial/holding-cabinet-repair/brands/metro/";

const title = "Metro Holding Cabinet Repair Los Angeles — Same Day";
const description = `Metro C5 heated holding cabinet repair. LA same-day. C509, C535, C589 mobile insulated cabinets. $120 commercial.`;

const faqs = [
  {
    q: "Metro vs Cres Cor for banquet operations?",
    a: "Both compete in the heated transport space, different positioning. Metro C5 series is mid-tier insulated heated cabinet, common at hospital meal-tray service, school nutrition, mid-volume catering. Cres Cor is premium-tier insulated heated, common at hotel banquet operations and high-volume catering. Pricing: Metro C509 mobile heated cabinet retails $3,800-5,200 vs Cres Cor Roll-In $5,500-8,500. Service life: Metro C5 year 12-16 typical, Cres Cor year 15-20. Both are good products; Metro at lower-tier price point, Cres Cor at premium tier. Some operations choose Metro for fleet reasons (operations running multiple cabinets prefer Metro pricing for the fleet)."
  },
  {
    q: "C509 mobile heated cabinet not heating. Standard diagnostic?",
    a: "Standard sequence. (1) Power supply (cord, plug, dedicated 120V or 208/240V circuit depending on model). (2) Heating element continuity test, year 8-12 typical burnout, $480-680 element replacement. (3) Thermostat drift year 6-9, $260-440. (4) Control board failure year 10-13, $480-680. About 60 percent of C5 'won't heat' calls resolve at element or thermostat. The C509 specifically uses Metro's signature C5 heating element design which is widely stocked through Ali Group distribution; typical same-day or next-day on the part."
  },
  {
    q: "Metro shelving + holding cabinet integration. Common for our operations?",
    a: "Yes. Metro's heritage is industrial shelving (since 1929 in Wilkes-Barre PA), and the C5 holding cabinet line integrates with Metro's broader shelving and transport equipment ecosystem. Common operational pattern: hospital food service uses Metro Lifestor stainless shelving + Metro Open Grid + Metro C5 heated cabinets as a unified system. Replacement and parts compatibility benefits from staying within the Metro ecosystem. Diagnostic on integrated systems sometimes requires understanding the broader equipment context (e.g., a heated cabinet that won't roll smoothly may have a Metro-specific caster sized for Metro shelving compatibility)."
  },
  {
    q: "Caster wear on banquet cabinets. Metro-specific or generic?",
    a: "Metro C5 cabinets use Metro-specific casters with proprietary mounting compatible with Metro shelving and transport equipment. Generic casters can be substituted but reduce future-fleet compatibility. For operations standardized on Metro fleet, we recommend Metro OEM casters ($120-220 per caster vs $80-180 generic). For operations not concerned with Metro-fleet integration, generic heavy-duty casters work fine. Caster wear year 4-7 typical heavy banquet operations, 4-6 casters per cabinet."
  },
  {
    q: "Health Department compliance documentation for Metro C5?",
    a: "We provide standard documented service work for HD compliance file: scope of repair, parts replaced, calibrated thermometer verification at multiple chamber points, sanitization verification per LA County DPH protocols. Metro C5 cabinets typically meet 135-140°F holding compliance when operating to spec. On year 8+ units we sometimes find drift below 135°F under normal load; we identify the root cause (thermostat, element, gasket) and quote repair to bring back to compliance. Annual PM contract recommended for hospital and school nutrition operations under regular HD inspection."
  },
  {
    q: "Metro is owned by Ali Group. Does that affect parts and service?",
    a: "Ali Group acquired Metro in 2019 (consolidation of foodservice equipment brands; Ali Group also owns Beverage-Air, Champion, and many other commercial foodservice brands). Practically, Metro maintains its identity, manufacturing, and parts catalog; service work is done through Metro authorized service network with Ali Group corporate support. Parts availability has actually improved post-acquisition due to broader Ali Group distribution. We service Metro the same way pre-acquisition, with parts via the Metro service network."
  },
  {
    q: "What's your warranty?",
    a: "90 days SDAR labor and parts on every repair. Metro component warranties (heating element, thermostat, control board, casters) processed separately through Metro authorized service network (Ali Group ownership). BHGS #A49573, BBB Accredited Business, EPA 608 Universal certified #1346255700410."
  }
];

const brandSchema = {
  "@context": "https://schema.org", "@type": "Brand", "@id": canonical + "#brand",
  "name": "Metro",
  "url": "https://www.metro.com",
  "description": "Metro manufactures heated holding cabinets, industrial shelving, and foodservice transport equipment. Heritage in Wilkes-Barre, Pennsylvania since 1929. Acquired by Ali Group 2019. Product line includes C5 series heated holding cabinets, Lifestor shelving, transport carts.",
  "foundingDate": "1929",
  "foundingLocation": { "@type": "Place", "name": "Wilkes-Barre, Pennsylvania" },
  "parentOrganization": { "@type": "Organization", "name": "Ali Group" }
};

const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair", "url": canonical, "telephone": phone, "priceRange": "$$",
    "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "08:00", "closes": "20:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "00:00", "closes": "00:00" }
      ],
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },{ "@type": "AdministrativeArea", "name": "Orange County" },{ "@type": "AdministrativeArea", "name": "Ventura County" },{ "@type": "AdministrativeArea", "name": "San Bernardino County" },{ "@type": "AdministrativeArea", "name": "Riverside County" }
    ]
  },
  { "@context": "https://schema.org", "@type": "Service", "@id": canonical + "#service",
    "serviceType": "Metro C5 Holding Cabinet Repair", "name": "Metro Heated Holding Cabinet Repair Service", "url": canonical,
    "description": "Metro C5 heated holding cabinet repair across all five SoCal counties. C509, C535, C589 mobile insulated heated cabinets. Heating element burnout (year 8-12), thermostat drift (year 6-9), heavy-duty caster wear (year 4-7 banquet duty), control board (year 10-13). Hospital meal-tray service, school nutrition, mid-volume catering. Metro shelving + holding cabinet integrated systems. Ali Group ownership since 2019. $120 commercial diagnostic, applied toward repair. BHGS #A49573, EPA 608 Universal certified #1346255700410.",
    "provider": { "@id": canonical + "#business" }, "brand": { "@id": canonical + "#brand" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },{ "@type": "AdministrativeArea", "name": "Orange County" },{ "@type": "AdministrativeArea", "name": "Ventura County" },{ "@type": "AdministrativeArea", "name": "San Bernardino County" },{ "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "120.00", "priceCurrency": "USD", "description": "Commercial diagnostic fee, applied toward repair" } }
  },
  brandSchema,
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Commercial", "item": "https://samedayappliance.repair/commercial/" },
      { "@type": "ListItem", "position": 3, "name": "Holding Cabinet Repair", "item": "https://samedayappliance.repair/commercial/holding-cabinet-repair/" },
      { "@type": "ListItem", "position": 4, "name": "Metro", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>
<Fragment slot="head-scripts">
  {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
</Fragment>

<CommercialHero
  title="Metro C5 Heated Holding Cabinet Repair, Same-Day Across LA"
  subtitle={`C509, C535, C589 mobile insulated heated cabinets. Hospital meal-tray, school nutrition, mid-volume catering. Ali Group brand. $120 commercial diagnostic. ${phone}`}
  heroImageTitle="Metro C5 Holding Cabinet Repair"
  showBranches={true}
/>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Mid-tier mobile insulated holding</p>
    <h2>Metro C5 series owns mid-tier mobile heated holding. Hospital, school, mid-volume catering.</h2>

    <p>Metro is part of Ali Group (acquired 2019) with manufacturing heritage in Wilkes-Barre Pennsylvania since 1929 (originally industrial shelving). The <strong>C5 series</strong> is the heated holding cabinet flagship: C509, C535, C589 mobile insulated cabinets at the mid-tier price point between premium Cres Cor and entry-level alternatives.</p>

    <p>Common LA installs: hospital meal-tray service (Cedars-Sinai, UCLA Medical, Kaiser, Hoag), school nutrition central kitchens (LAUSD, OUSD, SMMUSD), mid-volume catering operations, hotel ballroom service (mid-tier hotels). Metro's integrated ecosystem with Lifestor shelving and transport equipment makes it the natural choice for operations standardized on the Metro fleet.</p>

    <p>$120 commercial diagnostic, waived with repair. <strong>BHGS #A49573</strong>. <strong>EPA 608 Universal certified #1346255700410</strong>. BBB Accredited. Phones answered 24/7. Parent: <a href="/commercial/holding-cabinet-repair/">commercial holding cabinet repair</a>.</p>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">Top failure modes</p>
    <h2 class="section-title">What we see most on Metro C5.</h2>
    <ol class="num-list">
      <li><strong>Heating element burnout (year 8-12).</strong> $480-680 element replacement. Single most common cause.</li>
      <li><strong>Thermostat drift (year 6-9).</strong> $260-440 replacement.</li>
      <li><strong>Heavy-duty caster wear (year 4-7 banquet duty).</strong> Metro-specific casters $120-220 each, generic alternatives $80-180.</li>
      <li><strong>Control board (year 10-13).</strong> $480-680 replacement.</li>
      <li><strong>Door gasket compression (year 5-8).</strong> $180-280.</li>
      <li><strong>Door latch wear (year 4-7 heavy duty).</strong> $120-200.</li>
      <li><strong>Power cord wear (year 6+ frequent transport).</strong> $180-280.</li>
      <li><strong>Insulation damage from impact.</strong> Minor sealing $120-220.</li>
    </ol>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Models we service</p>
    <h2 class="section-title">Full Metro C5 product line.</h2>
    <h3 class="series-h3">C5 Heated Holding Cabinets</h3>
    <ul class="bullet-list">
      <li><strong>C509</strong> mid-volume mobile heated</li>
      <li><strong>C535</strong> larger capacity mobile heated</li>
      <li><strong>C589</strong> full-height heated transport cabinet</li>
      <li>C5 Open Body proofing variants</li>
    </ul>
    <h3 class="series-h3">Integrated Metro Equipment</h3>
    <ul class="bullet-list">
      <li>Lifestor stainless shelving (parts compatibility benefits)</li>
      <li>Metro transport carts and dollies</li>
      <li>Open Grid wire shelving</li>
    </ul>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">Honest opinion</p>
    <h2 class="section-title">Metro fleet ecosystem matters more than people realize.</h2>
    <p>Operations standardized on Metro shelving and transport equipment benefit from staying with Metro on heated holding too. The reason: parts compatibility, fleet management consistency, single-vendor service relationship. We've seen operations switch one heated cabinet to a competitor brand for a cost saving and end up with two parts catalogs, two service vendors, two different caster sizes — net cost is higher despite the lower upfront price. For operations not running a Metro fleet, alternatives (Cres Cor, Alto-Shaam) may pencil out better. We tell operators this distinction at quoting time so the decision is informed.</p>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Pricing</p>
    <h2 class="section-title">Metro C5 repair costs.</h2>
    <p class="lead">$120 commercial diagnostic, waived with repair.</p>
    <table class="price-table">
      <thead><tr><th>Repair</th><th>Typical Cost</th></tr></thead>
      <tbody>
        <tr><td>Diagnostic</td><td>$120, waived with repair</td></tr>
        <tr><td>Heating element replacement (C5 series)</td><td>$480 to $680</td></tr>
        <tr><td>Thermostat replacement</td><td>$260 to $440</td></tr>
        <tr><td>Heavy-duty caster (Metro OEM, per caster)</td><td>$120 to $220</td></tr>
        <tr><td>Caster (generic alternative, per caster)</td><td>$80 to $180</td></tr>
        <tr><td>Door gasket replacement</td><td>$180 to $280</td></tr>
        <tr><td>Door latch service</td><td>$120 to $200</td></tr>
        <tr><td>Power cord replacement</td><td>$180 to $280</td></tr>
        <tr><td>Control board replacement</td><td>$480 to $680</td></tr>
        <tr><td>Annual PM contract (Metro fleet, per cabinet)</td><td>$240 to $480</td></tr>
        <tr><td>Warranty</td><td>90 days parts and labor</td></tr>
      </tbody>
    </table>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">FAQ</p>
    <h2 class="section-title">Metro C5 questions.</h2>
    <div class="faq-list">
      {faqs.map(f => (<details class="faq-item"><summary>{f.q}</summary><p>{f.a}</p></details>))}
    </div>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Related</p>
    <h2 class="section-title">Other holding cabinet brands.</h2>
    <ul class="bullet-list">
      <li><a href="/commercial/holding-cabinet-repair/">Holding cabinet repair (parent pillar)</a></li>
      <li><a href="/commercial/holding-cabinet-repair/brands/alto-shaam/">Alto-Shaam</a> · <a href="/commercial/holding-cabinet-repair/brands/cres-cor/">Cres Cor</a> · <a href="/commercial/holding-cabinet-repair/brands/hatco/">Hatco</a> · <a href="/commercial/holding-cabinet-repair/brands/vollrath/">Vollrath</a></li>
      <li><a href="/commercial/holding-cabinet-repair/not-heating/">Not heating</a> · <a href="/commercial/holding-cabinet-repair/temperature-fluctuating/">Temperature fluctuating</a> · <a href="/commercial/holding-cabinet-repair/door-seal-issues/">Door seal issues</a> · <a href="/commercial/holding-cabinet-repair/humidity-control-failure/">Humidity control failure</a></li>
    </ul>
  </div>
</section>

<section class="bottom-cta">
  <div class="container">
    <h2>Metro C5 cabinet down? Same-day priority.</h2>
    <p>C509, C535, C589 across LA, OC, Ventura. $120 commercial diagnostic, waived with repair. BHGS #A49573, EPA 608 Universal #1346255700410.</p>
    <div class="cta-row">
      <a href={phoneHref} class="btn-primary">☎ Call {phone}</a>
      <a href="/contact/" class="btn-secondary">Book Online</a>
    </div>
  </div>
</section>

</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .section { padding: 72px 24px; }
  .section-gray { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; }
  .container.narrow { max-width: 820px; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  .section h2 { font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 800; margin: 0 0 18px; color: var(--text); line-height: 1.2; }
  .section p { font-size: 1rem; line-height: 1.75; margin: 0 0 16px; color: var(--text); }
  .section a { color: var(--red); font-weight: 600; text-decoration: none; }
  .section a:hover { text-decoration: underline; }
  .lead { font-size: 1.05rem; line-height: 1.75; color: var(--text); margin-bottom: 22px; }
  .num-list { padding-left: 22px; margin: 14px 0 0; }
  .num-list li { font-size: 0.98rem; line-height: 1.7; color: var(--text); margin-bottom: 10px; }
  .bullet-list { padding-left: 22px; margin: 14px 0 18px; }
  .bullet-list li { font-size: 1rem; line-height: 1.65; color: var(--text); margin-bottom: 6px; }
  .series-h3 { font-size: 1.1rem; font-weight: 800; margin: 28px 0 10px; }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 22px; background: #fff; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
  .price-table th, .price-table td { padding: 12px 16px; text-align: left; border-bottom: 1px solid var(--border); font-size: 0.95rem; }
  .price-table th { background: var(--gray); font-weight: 700; color: var(--text); }
  .price-table tr:last-child td { border-bottom: none; }
  .faq-list { margin-top: 24px; }
  .faq-item { background: #fff; border: 1px solid var(--border); border-radius: 6px; padding: 18px 22px; margin-bottom: 12px; }
  .faq-item summary { font-weight: 700; cursor: pointer; font-size: 1rem; color: var(--text); list-style: none; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::before { content: "+ "; color: var(--red); font-weight: 800; margin-right: 6px; }
  .faq-item[open] summary::before { content: "− "; }
  .faq-item p { font-size: 0.95rem; color: var(--text); line-height: 1.75; margin: 14px 0 0; }
  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { color: #fff; margin: 0 0 14px; font-size: 1.7rem; }
  .bottom-cta p { color: #c9c9c9; margin: 0 0 26px; max-width: 720px; margin-left: auto; margin-right: auto; }
  .cta-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 14px 28px; border-radius: 5px; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 14px 28px; border-radius: 5px; border: 2px solid rgba(255,255,255,0.35); font-weight: 600; text-decoration: none; }
</style>
