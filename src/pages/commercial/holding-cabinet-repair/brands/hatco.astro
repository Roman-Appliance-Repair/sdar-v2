---
// src/pages/commercial/holding-cabinet-repair/brands/hatco.astro
// Wave 17 — Hatco countertop holding + drawer warmer brand page.
// Independent Milwaukee, founded 1950.
import Layout from '../../../../layouts/Layout.astro';
import CommercialHero from '../../../../components/CommercialHero.astro';
import { MAIN_PHONE } from '../../../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/commercial/holding-cabinet-repair/brands/hatco/";

const title = "Hatco Holding Cabinet Repair Los Angeles — Same Day";
const description = `Hatco countertop heated holding repair across LA + OC. Independent Milwaukee since 1950. Heat lamps, drawers. BHGS #A49573. $120 commercial dx.`;

const faqs = [
  {
    q: "Why Hatco for countertop holding?",
    a: "Broadest countertop product line. Hatco specializes in countertop and undercounter holding equipment — different category from Alto-Shaam stationary cabinets and Cres Cor banquet roll-ins. The Hatco product family covers heat lamps (Glo-Ray strip warmers), heated countertop cabinets (FSHC series), soup wells (HW series), drawer warmers (HDW), pizza display warmers, and decorative shelves. If your operation needs heated holding at the line — pass-through window, plate warming station, soup-and-salad bar, drawer holding under the cooking line — Hatco is usually the brand. For larger stationary or banquet cabinets, Alto-Shaam or Cres Cor."
  },
  {
    q: "Glo-Ray strip warmer not heating. Most common cause?",
    a: "Heating element burnout, year 5 to 8 typical depending on duty cycle. Glo-Ray strip warmers run continuously during service hours, accumulating thousands of cycles per year on busy operations. Element replacement runs $260 to $440 part plus install on standard GRA-24, GRA-36, GRA-48 sizes. Less common: bulb burnout on Glo-Ray Designer (the decorative ribbon-light variant) which uses different heating-source architecture, $180 to $280 bulb replacement. About 70 percent of Glo-Ray failures resolve at element or bulb. Switch and thermostat year 6-9 typical, $180-280."
  },
  {
    q: "FSHC heated countertop cabinet vs FSHC humidified. Different?",
    a: "Yes. FSHC standard models (FSHC-7-1, FSHC-7-2) are heated holding only. FSHC humidified models (FSHC-7-1-H, FSHC-12-1-H) include water reservoir and humidity control for moisture-sensitive products (rolls, sandwiches, breaded items). Failure pattern differs: humidified models add water reservoir issues (scaling year 2-4 LA hard water, $120-220 descaling), water level sensor failures ($180-280), humidity control board failures ($380-580). On year 5+ humidified FSHC we recommend annual descaling PM as part of standard service."
  },
  {
    q: "Soup well not heating evenly. Single zone or multi-zone?",
    a: "Depends on model. Hatco soup wells come in single-well (HW-1, HW-2, HW-3) and multi-well configurations (HWB-2, HWB-3, HWB-4 with separate temp controls per well). Single-well failure is straightforward: heating element burnout ($260-440) or thermostat ($220-340). Multi-well diagnostic is more nuanced: each well has its own thermostat and element, partial failure (one well cold, others fine) means that well's components. About 60 percent of multi-well calls resolve at single-zone repair without affecting other wells. Calibration test with reference thermometer at each well per zone."
  },
  {
    q: "Drawer warmer HDW-1, HDW-2 service patterns?",
    a: "Drawer warmers (HDW-1 single drawer, HDW-2 double, HDW-3 triple) are common at hot-line cooking stations holding bread, plates, or batch-cooked product between service rushes. Failure pattern: heating element year 7-10 ($380-580), drawer slide wear year 4-7 ($180-280), thermostat year 6-9 ($220-340), drawer gasket year 5-8 ($120-200). Drawer slides see surprising wear from continuous open-close cycles in busy operations; we keep common HDW slide kits on the truck for in-place service."
  },
  {
    q: "Pizza display warmer (Hatco GRPWS) or decorative shelf service?",
    a: "Yes. Hatco's pizza display warmer line (GRPWS series) is common at counter-service pizza operations and chain pizza locations. Heat lamp year 4-7 typical replacement, $180-280 per lamp. Glass shelf damage from grease accumulation or thermal stress, $260-440 shelf replacement. Decorative shelf line (GRS, GRSD) at upscale buffet operations: similar repair patterns. Hotel buffet operations particularly use Hatco for visible heated display because the design aesthetics are presentation-grade."
  },
  {
    q: "What's your warranty?",
    a: "90 days SDAR labor and parts on every repair. Hatco component warranties (heating element, thermostat, water-reservoir components on humidified models) processed separately through Hatco authorized service network in Milwaukee Wisconsin. BHGS #A49573, BBB A+ accredited, EPA 608 Universal certified #1346255700410."
  }
];

const brandSchema = {
  "@context": "https://schema.org", "@type": "Brand", "@id": canonical + "#brand",
  "name": "Hatco",
  "url": "https://www.hatcocorp.com",
  "description": "Hatco manufactures countertop and undercounter heated holding equipment from Milwaukee, Wisconsin. Founded 1950. Independent ownership. Product line: Glo-Ray heat lamps and strip warmers, FSHC heated cabinets, HW soup wells, HDW drawer warmers, pizza display warmers, decorative heated shelves.",
  "foundingDate": "1950",
  "foundingLocation": { "@type": "Place", "name": "Milwaukee, Wisconsin" }
};

const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair", "url": canonical, "telephone": phone, "priceRange": "$$",
    "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "08:00", "closes": "20:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "00:00", "closes": "00:00" }
      ],
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },{ "@type": "AdministrativeArea", "name": "Orange County" },{ "@type": "AdministrativeArea", "name": "Ventura County" },{ "@type": "AdministrativeArea", "name": "San Bernardino County" },{ "@type": "AdministrativeArea", "name": "Riverside County" }
    ]
  },
  { "@context": "https://schema.org", "@type": "Service", "@id": canonical + "#service",
    "serviceType": "Hatco Heated Holding Repair", "name": "Hatco Countertop Heated Equipment Repair Service", "url": canonical,
    "description": "Hatco countertop and undercounter heated holding equipment repair across all five SoCal counties. Glo-Ray heat lamp / strip warmer (GRA-24, GRA-36, GRA-48, GRA-Designer), FSHC heated cabinet (FSHC-7-1, FSHC-7-2 standard + FSHC-H humidified variants), HW soup wells (single + multi-well), HDW drawer warmer (HDW-1, HDW-2, HDW-3), pizza display warmer (GRPWS), decorative shelves (GRS, GRSD). Heating element burnout (year 5-8 strip warmers, year 7-10 drawer warmers), thermostat drift, drawer slide wear, water reservoir scaling on humidified models (LA hard water year 2-4 PM). $120 commercial diagnostic, applied toward repair. BHGS #A49573, EPA 608 Universal certified #1346255700410.",
    "provider": { "@id": canonical + "#business" }, "brand": { "@id": canonical + "#brand" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },{ "@type": "AdministrativeArea", "name": "Orange County" },{ "@type": "AdministrativeArea", "name": "Ventura County" },{ "@type": "AdministrativeArea", "name": "San Bernardino County" },{ "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "120.00", "priceCurrency": "USD", "description": "Commercial diagnostic fee, applied toward repair" } }
  },
  brandSchema,
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Commercial", "item": "https://samedayappliance.repair/commercial/" },
      { "@type": "ListItem", "position": 3, "name": "Holding Cabinet Repair", "item": "https://samedayappliance.repair/commercial/holding-cabinet-repair/" },
      { "@type": "ListItem", "position": 4, "name": "Hatco", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>
<Fragment slot="head-scripts">
  {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
</Fragment>

<CommercialHero
  title="Hatco Countertop Heated Holding Repair, Same-Day Across LA"
  subtitle={`Glo-Ray strip warmers, FSHC heated cabinets, soup wells, drawer warmers, pizza display, decorative shelves. $120 commercial diagnostic. ${phone}`}
  heroImageTitle="Hatco Heated Holding Repair"
  showBranches={true}
/>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Countertop holding specialty</p>
    <h2>Hatco owns the countertop holding category. Glo-Ray, FSHC, drawer warmers, soup wells.</h2>

    <p>Hatco is independent (Milwaukee, Wisconsin), founded 1950. Different category from stationary cabinets (Alto-Shaam, Cres Cor): Hatco specializes in countertop and undercounter heated holding equipment for use at the line — pass-through window, plate warming, soup-and-salad bar, drawer holding under the cooking line. The product family is broad: <strong>Glo-Ray</strong> heat lamps and strip warmers (most-installed line), <strong>FSHC</strong> heated countertop cabinets (standard + humidified variants), <strong>HW</strong> soup wells (single + multi-well), <strong>HDW</strong> drawer warmers, pizza display warmers (GRPWS), decorative heated shelves (GRS, GRSD).</p>

    <p>Common LA installs: hotel buffet hot-line operations, restaurant pass-through windows, chain pizza counter-service, café and deli counter holding, hospital meal-tray hot-stations, school nutrition serving lines. We service the full Hatco line across LA, Orange, Ventura, San Bernardino, Riverside.</p>

    <p>$120 commercial diagnostic, waived with repair. <strong>BHGS #A49573</strong>. <strong>EPA 608 Universal certified #1346255700410</strong>. BBB A+. Phones answered 24/7. Parent: <a href="/commercial/holding-cabinet-repair/">commercial holding cabinet repair</a>.</p>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">Top failure modes</p>
    <h2 class="section-title">What we see most on Hatco.</h2>
    <ol class="num-list">
      <li><strong>Glo-Ray heating element burnout (year 5-8 strip warmers).</strong> Continuous service operation accelerates element wear. $260-440 replacement on standard GRA-24, GRA-36, GRA-48.</li>
      <li><strong>Glo-Ray Designer bulb burnout (year 4-7 ribbon-light variants).</strong> $180-280 bulb replacement.</li>
      <li><strong>HDW drawer warmer element (year 7-10).</strong> $380-580 replacement.</li>
      <li><strong>FSHC humidified water reservoir scaling (LA hard water year 2-4).</strong> $120-220 descaling service. Annual PM recommended.</li>
      <li><strong>Soup well multi-well partial failure.</strong> Single-zone diagnostic, $260-440 element or $220-340 thermostat for affected well.</li>
      <li><strong>Drawer slide wear (HDW year 4-7 busy operations).</strong> $180-280 slide kit replacement.</li>
      <li><strong>Switch and thermostat (year 6-9).</strong> $180-280 switch, $220-340 thermostat.</li>
      <li><strong>Pizza display heat lamp (GRPWS year 4-7).</strong> $180-280 per lamp.</li>
    </ol>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Models we service</p>
    <h2 class="section-title">Full Hatco product line.</h2>
    <h3 class="series-h3">Glo-Ray Heat Lamps + Strip Warmers</h3>
    <ul class="bullet-list">
      <li>GRA-24, GRA-36, GRA-48 standard strip warmers</li>
      <li>Glo-Ray Designer (GRAH, GRAH-D ribbon-light variants)</li>
      <li>GRSDH heated displays</li>
    </ul>
    <h3 class="series-h3">FSHC Heated Cabinets</h3>
    <ul class="bullet-list">
      <li>FSHC-7-1, FSHC-7-2 standard countertop</li>
      <li>FSHC-7-1-H, FSHC-12-1-H humidified variants</li>
    </ul>
    <h3 class="series-h3">Soup Wells + Drawer Warmers + Pizza Display</h3>
    <ul class="bullet-list">
      <li>HW soup wells (HW-1, HW-2, HW-3 single + HWB multi-well)</li>
      <li>HDW drawer warmers (HDW-1, HDW-2, HDW-3)</li>
      <li>GRPWS pizza display warmers</li>
      <li>GRS, GRSD decorative heated shelves</li>
    </ul>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">Honest opinion</p>
    <h2 class="section-title">FSHC humidified scale buildup is overdue PM, not warranty issue.</h2>
    <p>About 30 percent of LA Hatco service calls on FSHC humidified models come from operators who think the unit is failing when the actual issue is water reservoir scaling from LA's notoriously hard water (San Fernando Valley, Pasadena, Inland Empire especially). Year 2 to 4 typical onset on humidified models without annual PM. Symptom: humidity control inconsistent, water level sensor reads incorrectly, unit cycles unusually. The fix is descaling service ($120 to $220), not parts replacement. Some shops will quote a $580 humidity control board on a unit that just needs descaling. We test descaling first because that's the actual issue 30 percent of the time. Annual descaling PM is the right move on any year-2+ humidified FSHC.</p>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Pricing</p>
    <h2 class="section-title">Hatco repair costs.</h2>
    <p class="lead">$120 commercial diagnostic, waived with repair.</p>
    <table class="price-table">
      <thead><tr><th>Repair</th><th>Typical Cost</th></tr></thead>
      <tbody>
        <tr><td>Diagnostic</td><td>$120, waived with repair</td></tr>
        <tr><td>Glo-Ray strip warmer element (GRA standard)</td><td>$260 to $440</td></tr>
        <tr><td>Glo-Ray Designer bulb replacement</td><td>$180 to $280</td></tr>
        <tr><td>FSHC humidified descaling service</td><td>$120 to $220</td></tr>
        <tr><td>FSHC heating element replacement</td><td>$340 to $580</td></tr>
        <tr><td>FSHC humidity control board</td><td>$380 to $580</td></tr>
        <tr><td>Soup well element / thermostat (per well)</td><td>$220 to $440</td></tr>
        <tr><td>HDW drawer warmer element</td><td>$380 to $580</td></tr>
        <tr><td>HDW drawer slide replacement</td><td>$180 to $280</td></tr>
        <tr><td>Pizza display heat lamp (GRPWS)</td><td>$180 to $280 per lamp</td></tr>
        <tr><td>Annual PM (single Hatco unit including descaling)</td><td>$240 to $480</td></tr>
        <tr><td>Warranty</td><td>90 days parts and labor</td></tr>
      </tbody>
    </table>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">FAQ</p>
    <h2 class="section-title">Hatco questions.</h2>
    <div class="faq-list">
      {faqs.map(f => (<details class="faq-item"><summary>{f.q}</summary><p>{f.a}</p></details>))}
    </div>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Related</p>
    <h2 class="section-title">Other holding cabinet brands.</h2>
    <ul class="bullet-list">
      <li><a href="/commercial/holding-cabinet-repair/">Holding cabinet repair (parent pillar)</a></li>
      <li><a href="/commercial/holding-cabinet-repair/brands/alto-shaam/">Alto-Shaam</a> · <a href="/commercial/holding-cabinet-repair/brands/cres-cor/">Cres Cor</a> · <a href="/commercial/holding-cabinet-repair/brands/metro/">Metro</a> · <a href="/commercial/holding-cabinet-repair/brands/vollrath/">Vollrath</a></li>
      <li><a href="/commercial/holding-cabinet-repair/not-heating/">Not heating</a> · <a href="/commercial/holding-cabinet-repair/temperature-fluctuating/">Temperature fluctuating</a> · <a href="/commercial/holding-cabinet-repair/door-seal-issues/">Door seal issues</a> · <a href="/commercial/holding-cabinet-repair/humidity-control-failure/">Humidity control failure</a></li>
    </ul>
  </div>
</section>

<section class="bottom-cta">
  <div class="container">
    <h2>Hatco countertop holding equipment down? Same-day priority.</h2>
    <p>Glo-Ray, FSHC, soup wells, drawer warmers, pizza display, decorative shelves across LA, OC, Ventura. $120 commercial diagnostic, waived with repair. BHGS #A49573, EPA 608 Universal #1346255700410.</p>
    <div class="cta-row">
      <a href={phoneHref} class="btn-primary">☎ Call {phone}</a>
      <a href="/contact/" class="btn-secondary">Book Online</a>
    </div>
  </div>
</section>

</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .section { padding: 72px 24px; }
  .section-gray { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; }
  .container.narrow { max-width: 820px; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  .section h2 { font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 800; margin: 0 0 18px; color: var(--text); line-height: 1.2; }
  .section p { font-size: 1rem; line-height: 1.75; margin: 0 0 16px; color: var(--text); }
  .section a { color: var(--red); font-weight: 600; text-decoration: none; }
  .section a:hover { text-decoration: underline; }
  .lead { font-size: 1.05rem; line-height: 1.75; color: var(--text); margin-bottom: 22px; }
  .num-list { padding-left: 22px; margin: 14px 0 0; }
  .num-list li { font-size: 0.98rem; line-height: 1.7; color: var(--text); margin-bottom: 10px; }
  .bullet-list { padding-left: 22px; margin: 14px 0 18px; }
  .bullet-list li { font-size: 1rem; line-height: 1.65; color: var(--text); margin-bottom: 6px; }
  .series-h3 { font-size: 1.1rem; font-weight: 800; margin: 28px 0 10px; }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 22px; background: #fff; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
  .price-table th, .price-table td { padding: 12px 16px; text-align: left; border-bottom: 1px solid var(--border); font-size: 0.95rem; }
  .price-table th { background: var(--gray); font-weight: 700; color: var(--text); }
  .price-table tr:last-child td { border-bottom: none; }
  .faq-list { margin-top: 24px; }
  .faq-item { background: #fff; border: 1px solid var(--border); border-radius: 6px; padding: 18px 22px; margin-bottom: 12px; }
  .faq-item summary { font-weight: 700; cursor: pointer; font-size: 1rem; color: var(--text); list-style: none; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::before { content: "+ "; color: var(--red); font-weight: 800; margin-right: 6px; }
  .faq-item[open] summary::before { content: "− "; }
  .faq-item p { font-size: 0.95rem; color: var(--text); line-height: 1.75; margin: 14px 0 0; }
  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { color: #fff; margin: 0 0 14px; font-size: 1.7rem; }
  .bottom-cta p { color: #c9c9c9; margin: 0 0 26px; max-width: 720px; margin-left: auto; margin-right: auto; }
  .cta-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 14px 28px; border-radius: 5px; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 14px 28px; border-radius: 5px; border: 2px solid rgba(255,255,255,0.35); font-weight: 600; text-decoration: none; }
</style>
