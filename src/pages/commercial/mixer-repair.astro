// src/pages/commercial/mixer-repair.astro
// Cluster 11 — NEW commercial mixer repair pillar.
// Same template family. $120 commercial diagnostic. Em-dash ≤2. NO C-38, NO C-20.
// BHGS #A49573 + EPA 608 #1346255700410.
//
// Brand factual: Hobart (ITW Food Equipment) Legacy series planetary, Univex
// (independent), Varimixer (Danish premium spiral), KitchenAid Commercial
// (Whirlpool subsidiary, NSF/NHL approved), Globe (Edgecraft).
// OSHA pinch-point safety angle for bowl-lift mixers.

import Layout from '../../layouts/Layout.astro';
import CommercialHero from '../../components/CommercialHero.astro';
import { MAIN_PHONE } from '../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/commercial/mixer-repair/";

const title = "Commercial Mixer Repair LA | Hobart Legacy, Univex, Varimixer Spiral, KitchenAid Commercial";
const description = "Commercial mixer repair across SoCal. Hobart Legacy, Univex, Varimixer spiral, KitchenAid Commercial. Bowl lift, motor, gear transmission. $120 diagnostic. (424) 325-0520.";

const faqs = [
  {
    q: "Do you service Hobart, Univex, Varimixer, and KitchenAid Commercial mixers?",
    a: "Yes. Hobart (ITW Food Equipment) Legacy series planetary mixers are the dominant US market and the bulk of our service volume; HL120, HL200, HL400, HL600, HL800, HL1400 by capacity. Univex (independent) is common in pizzerias and mid-volume bakeries. Varimixer (Danish) is the premium spiral mixer for artisan bakeries and high-hydration dough operations. KitchenAid Commercial (Whirlpool subsidiary, NSF/NSF-listed) covers the smaller-capacity countertop commercial segment."
  },
  {
    q: "My Hobart Legacy mixer won't turn on. What's wrong?",
    a: "Common causes in order: (1) safety interlock fault on the bowl lift (year 5 to 9), (2) motor overload trip from heavy dough cycle without proper rest, (3) main contactor failure, (4) on/off switch worn. Hobart Legacy mixers are robust; complete electrical death is rare. We diagnose with multimeter and contactor inspection."
  },
  {
    q: "What does OSHA require for commercial mixer safety?",
    a: "OSHA mandates bowl-lift safety interlocks (mixer must stop when bowl is lowered or guard is open), pinch-point guards in the planetary head and bowl interface, and emergency-stop access. Failed bowl-lift interlocks are the most common compliance failure; pinch-point injuries on commercial mixers are well-documented OSHA citation cases. We service interlocks correctly, test through full lift cycle, and provide service documentation for OSHA records."
  },
  {
    q: "My mixer gear transmission is making noise. How urgent?",
    a: "Urgent. Hobart Legacy gear transmissions are heavy-duty cast-iron designs that are quiet when properly lubricated. Noise indicates oil seal failure (oil leaking, gears running dry) or worn gear teeth (advanced wear). Continued operation accelerates damage; a failed gear set on a Legacy HL400 runs $1,400 to $2,400 to rebuild. Catching it at oil seal stage runs $440 to $720 plus oil refill."
  },
  {
    q: "Why do bowl lifts on commercial mixers fail?",
    a: "Three causes: (1) safety interlock wear (year 5 to 9 typical, OSHA-critical), (2) bowl-lift motor capacitor or motor itself (year 8 to 12), (3) lift mechanism gear wear (year 10 to 15 on heavy-use units). On Hobart Legacy, the bowl-lift motor is a separate motor from the planetary drive motor; both can fail independently. Replacement bowl-lift motor runs $580 to $880 depending on mixer size."
  },
  {
    q: "What does commercial mixer repair cost in LA?",
    a: "$120 commercial diagnostic, waived with repair. Common repairs: bowl-lift safety interlock $260 to $440 (OSHA compliance), motor capacitor or contactor $200 to $360, planetary drive motor $880 to $1,400, bowl-lift motor $580 to $880, gear transmission oil seal $440 to $720, gear transmission rebuild $1,400 to $2,400, drive belt (some smaller models) $180 to $320, on/off switch replacement $140 to $260. Multi-component repair on aged units $1,200 to $2,800."
  },
  {
    q: "What's your warranty?",
    a: "90 days SDAR labor warranty on every repair. Hobart, Univex, Varimixer, and KitchenAid Commercial component warranties (where applicable) processed separately through manufacturer authorized networks. BHGS #A49573 and BBB A+. EPA 608 Universal #1346255700410."
  }
];

