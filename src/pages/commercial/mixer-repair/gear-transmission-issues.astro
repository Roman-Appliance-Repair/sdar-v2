---
import Layout from '../../../layouts/Layout.astro';
import CommercialHero from '../../../components/CommercialHero.astro';
import { MAIN_PHONE } from '../../../data/branches';
const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/commercial/mixer-repair/gear-transmission-issues/";
const title = "Commercial Mixer Gear / Transmission Issues LA — Same Day";
const description = `Commercial mixer gear or transmission issues? LA same-day. Speed selector, worm gear, planetary transmission, lubrication. $120 commercial. ${phone}.`;
const faqs = [
  { q: "Speed selector grinds when changing speeds. Repair?", a: "Yes. Speed selector mechanism wear is year 6-9 typical; grinding indicates internal gear damage starting. Service $280-540 catches it before full failure. Continued operation with grinding selector accelerates damage and may require full transmission rebuild ($880-1,800) instead of selector-only service ($280-540)." },
  { q: "Transmission oil leak — when do I worry?", a: "Now. Transmission oil loss damages internal gears within months. Leak source ($180-380 seal replacement) is much cheaper than rebuild ($880-1,800). We address transmission oil leaks priority on every mixer service call." },
  { q: "Annual lubrication PM — actually critical?", a: "Yes. Hobart published manufacturer recommendations call for annual lubrication on H600, A200, M802. Operations skipping PM see worm gear wear at year 6-7 (vs year 10-12 with PM). The math is obvious: $120-180 annual lubrication vs $580-980 reactive worm gear replacement." },
  { q: "Spiral mixer bowl-rotation gear — different from planetary transmission?", a: "Yes. Spiral mixers (Univex SRMF, Varimixer V-Series) have a separate bowl-rotation gear that drives the bowl rotation while spiral hook spins. Year 6-10 typical wear, $580-980. Different component than planetary transmission." },
  { q: "Worm gear vs planetary transmission — different?", a: "Worm gear is one specific component within the planetary transmission. Some failures localize to worm gear only ($580-980 service); others involve full planetary set requiring rebuild ($880-1,800). Diagnostic determines scope." },
  { q: "Hobart H600 transmission rebuild — worth it on year 15 unit?", a: "Often yes. Hobart H600 chassis is built for 20-year service life. Year-15 rebuild $880-1,400 on retail-$10K-15K mixer extends 5-7 more years of service. Math works." },
  { q: "What's your warranty?", a: "90 days SDAR labor and parts. Brand warranties through manufacturer authorized service. BHGS #A49573, BBB A+, EPA 608 Universal #1346255700410." }
];
const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business", "name": "Same Day Appliance Repair", "url": canonical, "telephone": phone, "priceRange": "$$",
    "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "08:00", "closes": "20:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "00:00", "closes": "00:00" }
      ],
    "areaServed": [{ "@type": "AdministrativeArea", "name": "Los Angeles County" },{ "@type": "AdministrativeArea", "name": "Orange County" },{ "@type": "AdministrativeArea", "name": "Ventura County" },{ "@type": "AdministrativeArea", "name": "San Bernardino County" },{ "@type": "AdministrativeArea", "name": "Riverside County" }]
  },
  { "@context": "https://schema.org", "@type": "Service", "@id": canonical + "#service", "serviceType": "Commercial Mixer Transmission Repair", "name": "Mixer Gear and Transmission Diagnostic", "url": canonical,
    "description": "Commercial mixer gear and transmission diagnostic across all five SoCal counties. Speed selector mechanism, worm gear (year 8-12 premium Hobart, year 6-9 mid-tier), planetary transmission, gear lubrication PM, transmission oil change schedule. $120 commercial diagnostic. BHGS #A49573, EPA 608 Universal #1346255700410.",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [{ "@type": "AdministrativeArea", "name": "Los Angeles County" },{ "@type": "AdministrativeArea", "name": "Orange County" },{ "@type": "AdministrativeArea", "name": "Ventura County" },{ "@type": "AdministrativeArea", "name": "San Bernardino County" },{ "@type": "AdministrativeArea", "name": "Riverside County" }],
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "120.00", "priceCurrency": "USD", "description": "Commercial diagnostic fee, applied toward repair" } }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
    { "@type": "ListItem", "position": 2, "name": "Commercial", "item": "https://samedayappliance.repair/commercial/" },
    { "@type": "ListItem", "position": 3, "name": "Mixer Repair", "item": "/commercial/mixer-repair/" },
    { "@type": "ListItem", "position": 4, "name": "Gear and Transmission Issues", "item": canonical }
  ]}
];
---
<Layout title={title} description={description} canonical={canonical}>
<Fragment slot="head-scripts">{schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}</Fragment>
<CommercialHero title="Commercial Mixer Gear & Transmission Issues, Same-Day"
  subtitle={`Speed selector, worm gear, planetary transmission, lubrication PM. $120 commercial. ${phone}`}
  heroImageTitle="Commercial Mixer Gear and Transmission" showBranches={true} />

<section class="section"><div class="container narrow">
  <p class="section-number">Transmission diagnostic</p>
  <h2>Lubrication PM extends gear life dramatically. Reactive transmission rebuilds are expensive.</h2>
  <p>Commercial mixer gear and transmission failures cluster around three areas. (1) Speed selector mechanism (gear engagement at speed change) wear year 6-9, $280-540 service. (2) Worm gear wear (premium Hobart H600, A200) year 8-12, $580-980; mid-tier year 6-9, $480-720. (3) Planetary transmission gear set year 10-15 premium, year 7-10 mid-tier, $880-1,800 rebuild. Annual lubrication PM ($120-180) extends gear life dramatically; reactive transmission rebuild without PM is the expensive scenario.</p>
  <p>$120 commercial diagnostic, waived with repair. <strong>BHGS #A49573</strong>. <strong>EPA 608 Universal certified #1346255700410</strong>. BBB A+. Phones answered 24/7. Parent: <a href="/commercial/mixer-repair/">mixer repair</a>.</p>
</div></section>

<section class="section section-gray"><div class="container narrow">
  <p class="section-number">Field observations</p>
  <ol class="num-list">
    <li><strong>Speed selector mechanism wear (year 6-9).</strong> $280-540.</li>
    <li><strong>Worm gear wear (Hobart premium year 8-12).</strong> $580-980.</li>
    <li><strong>Worm gear wear (mid-tier year 6-9).</strong> $480-720.</li>
    <li><strong>Planetary transmission rebuild (year 10-15 premium).</strong> $880-1,800.</li>
    <li><strong>Transmission oil leak.</strong> $180-380 seal replacement + oil refill.</li>
    <li><strong>Bowl-rotation gear (spiral mixers, year 6-10).</strong> $580-980.</li>
    <li><strong>Speed selector linkage adjustment.</strong> $120-220.</li>
    <li><strong>Lubrication overdue (no PM history).</strong> $120-180 annual lubrication catch-up.</li>
  </ol>
</div></section>

<section class="section"><div class="container narrow">
  <p class="section-number">Pricing</p>
  <table class="price-table"><thead><tr><th>Repair</th><th>Typical Cost</th></tr></thead><tbody>
        <tr><td>Diagnostic</td><td>$120, waived with repair</td></tr>
        <tr><td>Speed selector mechanism service</td><td>$280 to $540</td></tr>
        <tr><td>Worm gear (Hobart premium)</td><td>$580 to $980</td></tr>
        <tr><td>Worm gear (mid-tier)</td><td>$480 to $720</td></tr>
        <tr><td>Planetary transmission rebuild</td><td>$880 to $1,800</td></tr>
        <tr><td>Transmission oil + seal service</td><td>$180 to $380</td></tr>
        <tr><td>Bowl-rotation gear (spiral)</td><td>$580 to $980</td></tr>
        <tr><td>Speed selector linkage adjustment</td><td>$120 to $220</td></tr>
        <tr><td>Annual lubrication PM</td><td>$120 to $180</td></tr>
        <tr><td>Warranty</td><td>90 days parts and labor</td></tr>
  </tbody></table>
</div></section>

<section class="section section-gray"><div class="container narrow">
  <p class="section-number">FAQ</p>
  <div class="faq-list">{faqs.map(f => (<details class="faq-item"><summary>{f.q}</summary><p>{f.a}</p></details>))}</div>
</div></section>

<section class="section"><div class="container narrow">
  <p class="section-number">Related</p>
  <ul class="bullet-list">
    <li><a href="/commercial/mixer-repair/">Mixer Repair (parent)</a></li>
    <li><a href="/commercial/mixer-repair/motor-issues/">Motor issues</a> · <a href="/commercial/mixer-repair/bowl-lift-issues/">Bowl lift</a></li>
    <li><a href="/commercial/mixer-repair/brands/hobart/">Hobart</a> · <a href="/commercial/mixer-repair/brands/univex/">Univex</a> · <a href="/commercial/mixer-repair/brands/varimixer/">Varimixer</a> · <a href="/commercial/mixer-repair/brands/kitchenaid-commercial/">KitchenAid Commercial</a></li>
  </ul>
</div></section>

<section class="bottom-cta"><div class="container">
  <h2>Mixer transmission issues? Same-day diagnostic.</h2>
  <p>Speed selector, worm gear, planetary rebuild service across LA, OC, Ventura. $120 commercial. BHGS #A49573, EPA 608 Universal #1346255700410.</p>
  <div class="cta-row"><a href={phoneHref} class="btn-primary">☎ Call {phone}</a><a href="/contact/" class="btn-secondary">Book Online</a></div>
</div></section>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .section { padding: 72px 24px; } .section-gray { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; } .container.narrow { max-width: 820px; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  .section h2 { font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 800; margin: 0 0 18px; color: var(--text); line-height: 1.2; }
  .section p { font-size: 1rem; line-height: 1.75; margin: 0 0 16px; color: var(--text); }
  .section a { color: var(--red); font-weight: 600; text-decoration: none; } .section a:hover { text-decoration: underline; }
  .num-list { padding-left: 22px; margin: 14px 0 0; } .num-list li { font-size: 0.98rem; line-height: 1.7; color: var(--text); margin-bottom: 10px; }
  .bullet-list { padding-left: 22px; margin: 14px 0 18px; } .bullet-list li { font-size: 1rem; line-height: 1.65; color: var(--text); margin-bottom: 6px; }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 22px; background: #fff; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
  .price-table th, .price-table td { padding: 12px 16px; text-align: left; border-bottom: 1px solid var(--border); font-size: 0.95rem; }
  .price-table th { background: var(--gray); font-weight: 700; color: var(--text); } .price-table tr:last-child td { border-bottom: none; }
  .faq-list { margin-top: 24px; } .faq-item { background: #fff; border: 1px solid var(--border); border-radius: 6px; padding: 18px 22px; margin-bottom: 12px; }
  .faq-item summary { font-weight: 700; cursor: pointer; font-size: 1rem; color: var(--text); list-style: none; }
  .faq-item summary::-webkit-details-marker { display: none; } .faq-item summary::before { content: "+ "; color: var(--red); font-weight: 800; margin-right: 6px; } .faq-item[open] summary::before { content: "− "; }
  .faq-item p { font-size: 0.95rem; color: var(--text); line-height: 1.75; margin: 14px 0 0; }
  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { color: #fff; margin: 0 0 14px; font-size: 1.7rem; } .bottom-cta p { color: #c9c9c9; margin: 0 0 26px; max-width: 720px; margin-left: auto; margin-right: auto; }
  .cta-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 14px 28px; border-radius: 5px; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 14px 28px; border-radius: 5px; border: 2px solid rgba(255,255,255,0.35); font-weight: 600; text-decoration: none; }
</style>
