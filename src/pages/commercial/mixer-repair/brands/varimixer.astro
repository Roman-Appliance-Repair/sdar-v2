---
import Layout from '../../../../layouts/Layout.astro';
import CommercialHero from '../../../../components/CommercialHero.astro';
import { MAIN_PHONE } from '../../../../data/branches';
const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/commercial/mixer-repair/brands/varimixer/";
const title = "Varimixer Mixer Repair Los Angeles — Same Day";
const description = `Varimixer Danish premium spiral mixer repair. LA same-day. V-Series, V40, V60. Independent Danish since 1923. $120 commercial. ${phone}.`;
const faqs = [
  { q: "Varimixer vs Univex SRMF for spiral mixers?", a: "Varimixer V-Series is premium tier above Univex SRMF — Danish engineering, longer service life year 15-20 vs year 12-15. Higher upfront cost ($8,500-22,000 V40-V80 vs $4,500-9,500 Univex SRMF) but lower total cost of ownership for high-volume daily-use pizza operations. Common LA: Neapolitan pizza cluster, artisan bakeries." },
  { q: "V-Series sizes — V20 to V80 capacity?", a: "V20 = 20 quart bowl (small pizza shop, café), V40 = 40 quart (mid-volume restaurant pizza), V60 = 60 quart (high-volume), V80 = 80 quart (industrial bakery). Same architecture across line, larger models add hydraulic bowl lift on V60+." },
  { q: "Spiral mixer dough hook longevity?", a: "Spiral hook itself rarely fails; bearing supporting hook does. Year 8-11 typical bearing replacement, $480-680. Hook can run 15+ years." },
  { q: "Annual PM importance for Varimixer?", a: "Strongly recommended. Annual PM ($240-380) covers gear lubrication, bearing inspection, motor brush check, drive belt tension. Premium equipment investment justifies premium PM cadence." },
  { q: "Health Department compliance?", a: "Standard LA County DPH requirements. We document service for HD compliance file." },
  { q: "Parts logistics for LA?", a: "Common parts via Varimixer USA distribution (typically same-day or next-day). Specialty parts on legacy pre-2005 V-Series may require 1-2 week order from Danish factory." },
  { q: "What's your warranty?", a: "90 days SDAR labor and parts. Varimixer warranties through Varimixer USA authorized service. BHGS #A49573, BBB A+, EPA 608 Universal #1346255700410." }
];
const brandSchema = { "@context": "https://schema.org", "@type": "Brand", "@id": canonical + "#brand", "name": "Varimixer", "description": "Varimixer manufactures premium spiral and planetary mixers from Brondby Denmark. Independent. Founded 1923. V-Series spiral, planetary, dough dividers.", "foundingDate": "1923", "foundingLocation": { "@type": "Place", "name": "Brondby, Denmark" } };
const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business", "name": "Same Day Appliance Repair", "url": canonical, "telephone": phone, "priceRange": "$$",
    "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "08:00", "closes": "20:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "00:00", "closes": "00:00" }
      ],
    "areaServed": [{ "@type": "AdministrativeArea", "name": "Los Angeles County" },{ "@type": "AdministrativeArea", "name": "Orange County" },{ "@type": "AdministrativeArea", "name": "Ventura County" },{ "@type": "AdministrativeArea", "name": "San Bernardino County" },{ "@type": "AdministrativeArea", "name": "Riverside County" }]
  },
  { "@context": "https://schema.org", "@type": "Service", "@id": canonical + "#service", "serviceType": "Varimixer Mixer Repair", "name": "Varimixer Premium Mixer Repair Service", "url": canonical,
    "description": "Varimixer Danish premium commercial mixer repair across all five SoCal counties. V-Series spiral mixers (V20, V40, V60, V80) for pizza-dough operations + bakeries, planetary mixers, dough dividers. Premium tier service life year 15-20. Independent Brondby Denmark. $120 commercial diagnostic. BHGS #A49573, EPA 608 Universal #1346255700410.",
    "provider": { "@id": canonical + "#business" }, "brand": { "@id": canonical + "#brand" },
    "areaServed": [{ "@type": "AdministrativeArea", "name": "Los Angeles County" },{ "@type": "AdministrativeArea", "name": "Orange County" },{ "@type": "AdministrativeArea", "name": "Ventura County" },{ "@type": "AdministrativeArea", "name": "San Bernardino County" },{ "@type": "AdministrativeArea", "name": "Riverside County" }],
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "120.00", "priceCurrency": "USD", "description": "Commercial diagnostic fee, applied toward repair" } }
  },
  brandSchema,
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
    { "@type": "ListItem", "position": 2, "name": "Commercial", "item": "https://samedayappliance.repair/commercial/" },
    { "@type": "ListItem", "position": 3, "name": "Mixer Repair", "item": "/commercial/mixer-repair/" },
    { "@type": "ListItem", "position": 4, "name": "Varimixer", "item": canonical }
  ]}
];
---
<Layout title={title} description={description} canonical={canonical}>
<Fragment slot="head-scripts">{schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}</Fragment>
<CommercialHero title="Varimixer Danish Premium Spiral Mixer Repair, Same-Day Across LA"
  subtitle={`V-Series spiral, planetary, dough dividers. Premium pizza + bakery standard. Independent Denmark since 1923. $120 commercial. ${phone}`}
  heroImageTitle="Varimixer Mixer Repair" showBranches={true} />

<section class="section"><div class="container narrow">
  <p class="section-number">Danish premium spiral specialty</p>
  <h2>Varimixer is the premium tier on spiral mixers. Danish engineering year 15-20 service life.</h2>
  <p>Varimixer is independent Danish manufacturing (Brondby Denmark, since 1923). Premium tier above Univex SRMF on spiral mixers. The V-Series (V20, V40, V60, V80) is the workhorse for high-end pizza operations and artisan bakeries. Common LA installs: Neapolitan pizza cluster (Pizzana, Mozza, Bestia, Mother Dough, 800 Degrees, L'Antica Pizzeria), artisan bakeries, hotel banquet pastry kitchens.</p>
  <p>$120 commercial diagnostic, waived with repair. <strong>BHGS #A49573</strong>. <strong>EPA 608 Universal certified #1346255700410</strong>. BBB A+. Phones answered 24/7. Parent: <a href="/commercial/mixer-repair/">mixer repair</a>.</p>
</div></section>

<section class="section section-gray"><div class="container narrow">
  <p class="section-number">Top failure modes</p>
  <ol class="num-list">
    <li><strong>Bowl-rotation gear (V-Series spiral, year 7-10).</strong> $680-980 (premium Danish parts).</li>
    <li><strong>Spiral hook bearing (year 8-11).</strong> $480-680.</li>
    <li><strong>Motor brushes (year 7-10).</strong> $120-220.</li>
    <li><strong>Drive belt wear (year 4-7).</strong> $120-220.</li>
    <li><strong>Safety interlock (year 5-8).</strong> $180-280.</li>
    <li><strong>Transmission gear (year 10-14).</strong> $680-980.</li>
    <li><strong>Capacitor (year 7-10).</strong> $80-180.</li>
    <li><strong>Specialty parts (legacy V-Series pre-2005).</strong> 1-2 week Danish factory order.</li>
  </ol>
</div></section>

<section class="section"><div class="container narrow">
  <p class="section-number">Pricing</p>
  <table class="price-table"><thead><tr><th>Repair</th><th>Typical Cost</th></tr></thead><tbody>
        <tr><td>Diagnostic</td><td>$120, waived with repair</td></tr>
        <tr><td>Bowl-rotation gear (V-Series)</td><td>$680 to $980</td></tr>
        <tr><td>Spiral hook bearing</td><td>$480 to $680</td></tr>
        <tr><td>Motor brushes</td><td>$120 to $220</td></tr>
        <tr><td>Drive belt</td><td>$120 to $220</td></tr>
        <tr><td>Safety interlock</td><td>$180 to $280</td></tr>
        <tr><td>Transmission gear</td><td>$680 to $980</td></tr>
        <tr><td>Annual PM contract</td><td>$240 to $380</td></tr>
        <tr><td>Warranty</td><td>90 days parts and labor</td></tr>
  </tbody></table>
</div></section>

<section class="section section-gray"><div class="container narrow">
  <p class="section-number">FAQ</p>
  <div class="faq-list">{faqs.map(f => (<details class="faq-item"><summary>{f.q}</summary><p>{f.a}</p></details>))}</div>
</div></section>

<section class="section"><div class="container narrow">
  <p class="section-number">Related</p>
  <ul class="bullet-list">
    <li><a href="/commercial/mixer-repair/">Mixer Repair (parent)</a></li>
    <li><a href="/commercial/mixer-repair/brands/hobart/">Hobart</a> · <a href="/commercial/mixer-repair/brands/univex/">Univex</a> · <a href="/commercial/mixer-repair/brands/kitchenaid-commercial/">KitchenAid Commercial</a></li>
    <li><a href="/commercial/mixer-repair/motor-issues/">Motor issues</a> · <a href="/commercial/mixer-repair/gear-transmission-issues/">Gear/transmission</a> · <a href="/commercial/mixer-repair/bowl-lift-issues/">Bowl lift</a></li>
  </ul>
</div></section>

<section class="bottom-cta"><div class="container">
  <h2>Varimixer V-Series down? Same-day priority.</h2>
  <p>V20, V40, V60, V80 across LA, OC, Ventura. $120 commercial. BHGS #A49573, EPA 608 Universal #1346255700410.</p>
  <div class="cta-row"><a href={phoneHref} class="btn-primary">☎ Call {phone}</a><a href="/contact/" class="btn-secondary">Book Online</a></div>
</div></section>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .section { padding: 72px 24px; } .section-gray { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; } .container.narrow { max-width: 820px; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  .section h2 { font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 800; margin: 0 0 18px; color: var(--text); line-height: 1.2; }
  .section p { font-size: 1rem; line-height: 1.75; margin: 0 0 16px; color: var(--text); }
  .section a { color: var(--red); font-weight: 600; text-decoration: none; } .section a:hover { text-decoration: underline; }
  .num-list { padding-left: 22px; margin: 14px 0 0; } .num-list li { font-size: 0.98rem; line-height: 1.7; color: var(--text); margin-bottom: 10px; }
  .bullet-list { padding-left: 22px; margin: 14px 0 18px; } .bullet-list li { font-size: 1rem; line-height: 1.65; color: var(--text); margin-bottom: 6px; }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 22px; background: #fff; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
  .price-table th, .price-table td { padding: 12px 16px; text-align: left; border-bottom: 1px solid var(--border); font-size: 0.95rem; }
  .price-table th { background: var(--gray); font-weight: 700; color: var(--text); } .price-table tr:last-child td { border-bottom: none; }
  .faq-list { margin-top: 24px; } .faq-item { background: #fff; border: 1px solid var(--border); border-radius: 6px; padding: 18px 22px; margin-bottom: 12px; }
  .faq-item summary { font-weight: 700; cursor: pointer; font-size: 1rem; color: var(--text); list-style: none; }
  .faq-item summary::-webkit-details-marker { display: none; } .faq-item summary::before { content: "+ "; color: var(--red); font-weight: 800; margin-right: 6px; } .faq-item[open] summary::before { content: "− "; }
  .faq-item p { font-size: 0.95rem; color: var(--text); line-height: 1.75; margin: 14px 0 0; }
  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { color: #fff; margin: 0 0 14px; font-size: 1.7rem; } .bottom-cta p { color: #c9c9c9; margin: 0 0 26px; max-width: 720px; margin-left: auto; margin-right: auto; }
  .cta-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 14px 28px; border-radius: 5px; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 14px 28px; border-radius: 5px; border: 2px solid rgba(255,255,255,0.35); font-weight: 600; text-decoration: none; }
</style>
