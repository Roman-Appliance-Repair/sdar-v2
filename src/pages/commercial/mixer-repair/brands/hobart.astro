  {
    "@context": "https://schema.org",
    "@type": "Brand",
    "@id": canonical + "#brand",
    "name": "Hobart",
    "alternateName": "Hobart Food Equipment",
    "url": "https://www.hobartcorp.com/",
    "description": "Hobart is the dominant US commercial foodservice equipment manufacturer, headquartered in Troy, Ohio. Now part of ITW Food Equipment Group. Sister brands include Vulcan, Stero, Baxter, and Traulsen. The Hobart Legacy series planetary mixer family (HL120 through HL1400) is the dominant US market for commercial mixer applications across bakeries, pizzerias, restaurants, schools, and institutional kitchens. Cast-iron gear transmissions and 20 to 30+ year service life are the Legacy hallmarks.",
    "parentOrganization": {
      "@type": "Organization",
      "name": "ITW Food Equipment Group"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Commercial", "item": "https://samedayappliance.repair/commercial/" },
