---
// src/pages/commercial/mixer-repair/brands/hobart.astro
// Cluster 11 Tier 2 — Hobart Legacy series planetary mixer brand page.
// Same template as Hobart slicer brand: 5 schemas (LocalBusiness + Service +
// Brand[parentOrganization: ITW Food Equipment Group] + FAQPage + BreadcrumbList).
// $120 commercial diagnostic. Em-dash ≤6. NO C-38, NO C-20.
// BHGS #A49573 + EPA 608 Universal #1346255700410.

import Layout from '../../../../layouts/Layout.astro';
import CommercialHero from '../../../../components/CommercialHero.astro';
import { MAIN_PHONE } from '../../../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/commercial/mixer-repair/brands/hobart/";

const title = "Hobart Mixer Repair Los Angeles — Same Day";
const description = "Hobart Legacy series planetary mixer repair across SoCal. HL120, HL200, HL400, HL600, HL800, HL1400. ITW Food Equipment. OSHA bowl-lift compliance.";

const faqs = [
  {
    q: "Do you service Hobart Legacy HL120, HL200, HL400, HL600, HL800, HL1400?",
    a: "Yes. The full Hobart Legacy planetary mixer family is our most common mixer service call across LA-area bakeries, pizzerias, restaurants, and institutional kitchens. HL120 (12 quart), HL200 (20 quart), HL400 (40 quart), HL600 (60 quart), HL800 (80 quart), HL1400 (140 quart). Cast-iron gear transmissions, bowl-lift architecture (separate motor on HL200 and larger), OSHA-compliant safety interlocks. OEM Hobart parts via ITW Food Equipment authorized distribution."
  },
  {
    q: "How long do Hobart Legacy mixers last?",
    a: "Properly maintained, 20 to 30+ years is normal. Hobart Legacy mixers from the 1990s are still in active service across LA bakeries with periodic component replacement. The cast-iron gear transmission and base outlast components by decades; service items (motor, contactor, bowl-lift interlock, gear oil seal) cycle through periodic replacement while the structural cabinet remains. Heritage HL400 and HL600 units common in longstanding bakeries."
  },
  {
    q: "OSHA bowl-lift safety on Hobart Legacy: what's required?",
    a: "OSHA mandates the bowl-lift safety interlock that stops the mixer when the bowl is lowered or the safety guard is opened. Hobart Legacy uses an electromechanical interlock at the bowl-cradle interface; failure mode is interlock contact wear at year 5 to 9 typical. Replacement runs $260 to $440. Failed interlock means mixer keeps running with bowl lowered, which is direct OSHA pinch-point citation territory and a documented injury risk pattern. We service interlocks with OEM Hobart parts and provide service documentation for OSHA records."
  },
  {
    q: "My Hobart Legacy gear transmission is making noise. How urgent?",
    a: "Urgent. Hobart Legacy gear transmissions are heavy-duty cast-iron designs that run quiet when properly lubricated. Noise indicates oil seal failure (oil leaking, gears running progressively dry) or worn gear teeth (advanced wear). Continued operation accelerates damage exponentially; a failed gear set on an HL400 runs $1,400 to $2,400 to rebuild on-site. Catching the problem at the oil seal stage runs $440 to $720 plus oil refill. Don't let it run with a slow leak."
  },
  {
    q: "Bowl-lift won't lift on my HL400. What's wrong?",
    a: "Three causes in order of frequency: (1) bowl-lift safety interlock fault preventing the bowl-lift motor from engaging (interlock has to be satisfied in both directions), (2) bowl-lift motor capacitor or bowl-lift motor itself (HL200 and larger have a separate bowl-lift motor distinct from the planetary drive motor), (3) bowl-lift mechanism gear wear in the lift gearbox. We diagnose with multimeter and visual inspection; replacement bowl-lift motor runs $580 to $880 depending on mixer size."
  },
  {
    q: "What does Hobart Legacy mixer repair cost in LA?",
    a: "$120 commercial diagnostic, waived with repair. Common Legacy repairs: bowl-lift safety interlock $260 to $440, motor contactor or capacitor $200 to $360, planetary drive motor $880 to $1,400, bowl-lift motor $580 to $880, gear transmission oil seal $440 to $720, gear transmission rebuild $1,400 to $2,400, on/off switch $140 to $260. Multi-component repair on aged HL units $1,200 to $2,800. Heritage Legacy refurbishment $1,800 to $3,400."
  },
  {
    q: "What's your warranty?",
    a: "90 days SDAR labor warranty. Hobart component warranties (where applicable through ITW Food Equipment) processed separately. BHGS #A49573 and BBB Accredited. EPA 608 Universal #1346255700410."
  }
];

const schemaJsons = [
