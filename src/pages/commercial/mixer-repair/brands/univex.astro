---
import Layout from '../../../../layouts/Layout.astro';
import CommercialHero from '../../../../components/CommercialHero.astro';
import { MAIN_PHONE } from '../../../../data/branches';
const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/commercial/mixer-repair/brands/univex/";
const title = "Univex Commercial Mixer Repair LA | SRMF, M-Series, Spiral | $120 Commercial";
const description = `Univex commercial mixer repair. LA same-day. SRMF spiral, M-Series planetary, dough divider. Independent New Hampshire since 1948. $120 commercial. ${phone}.`;
const faqs = [
  { q: "Univex positioning vs Hobart?", a: "Univex is independent (Salem New Hampshire since 1948), positioned as Hobart alternative at lower price point on planetary mixers, plus specialty in spiral mixers (SRMF series) and dough dividers. Hobart owns the planetary market via brand recognition; Univex is the value-tier alternative for operations not requiring Hobart-tier longevity. Common LA installs: pizza shops (spiral mixers for dough), bakeries, mid-volume catering kitchens." },
  { q: "SRMF spiral mixer service patterns?", a: "Univex SRMF spiral mixer is the workhorse for pizza dough operations. Failure pattern: bowl-rotation gear year 6-9 ($580-880), spiral hook bearing year 7-10 ($380-580), motor brushes year 6-9 ($120-220), safety interlock year 5-8 ($180-280). Annual PM ($180-280) recommended for daily-use pizza operations." },
  { q: "Planetary M-Series vs Hobart competing models?", a: "Univex M-Series planetary mixers compete directly with Hobart H600, A200 planetary lines. Service patterns similar (bowl lift gear, motor brushes, transmission, safety interlock); Univex parts often cheaper than Hobart equivalent. Trade-off: shorter chassis service life year 12-15 vs Hobart year 20+." },
  { q: "Dough divider service?", a: "Univex makes pizza/bakery dough dividers (DV series) — high-volume operations. Service pattern: divider blade year 6-9 ($340-540), hopper bearing year 7-10 ($280-440), motor brushes year 6-9 ($120-220)." },
  { q: "Health Department compliance?", a: "Standard LA County DPH requirements for commercial mixers: cleaning, sanitization, blade-guard verification. We document service for HD compliance file." },
  { q: "Annual PM for Univex?", a: "Recommended for restaurants and pizza operations using Univex daily. Annual PM ($180-280) covers gear lubrication, motor brush inspection, safety interlock test, bowl lift mechanism check (planetary models)." },
  { q: "What's your warranty?", a: "90 days SDAR labor and parts. Univex component warranties through Univex Salem NH authorized service network. BHGS #A49573, BBB A+, EPA 608 Universal #1346255700410." }
];
const brandSchema = { "@context": "https://schema.org", "@type": "Brand", "@id": canonical + "#brand", "name": "Univex", "description": "Univex manufactures commercial mixers from Salem New Hampshire. Independent. Founded 1948. SRMF spiral, M-Series planetary, dough dividers." };
const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business", "name": "Same Day Appliance Repair", "url": canonical, "telephone": phone, "priceRange": "$$",
    "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "08:00", "closes": "20:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "00:00", "closes": "00:00" }
      ],
    "areaServed": [{ "@type": "AdministrativeArea", "name": "Los Angeles County" },{ "@type": "AdministrativeArea", "name": "Orange County" },{ "@type": "AdministrativeArea", "name": "Ventura County" },{ "@type": "AdministrativeArea", "name": "San Bernardino County" },{ "@type": "AdministrativeArea", "name": "Riverside County" }]
  },
  { "@context": "https://schema.org", "@type": "Service", "@id": canonical + "#service", "serviceType": "Univex Mixer Repair", "name": "Univex Commercial Mixer Repair Service", "url": canonical,
    "description": "Univex commercial mixer repair across all five SoCal counties. SRMF spiral mixers (pizza dough), M-Series planetary, DV dough dividers. Independent Salem NH brand. $120 commercial diagnostic. BHGS #A49573, EPA 608 Universal #1346255700410.",
    "provider": { "@id": canonical + "#business" }, "brand": { "@id": canonical + "#brand" },
    "areaServed": [{ "@type": "AdministrativeArea", "name": "Los Angeles County" },{ "@type": "AdministrativeArea", "name": "Orange County" },{ "@type": "AdministrativeArea", "name": "Ventura County" },{ "@type": "AdministrativeArea", "name": "San Bernardino County" },{ "@type": "AdministrativeArea", "name": "Riverside County" }],
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "120.00", "priceCurrency": "USD", "description": "Commercial diagnostic fee, applied toward repair" } }
  },
  brandSchema,
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList", "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
    { "@type": "ListItem", "position": 2, "name": "Commercial", "item": "https://samedayappliance.repair/commercial/" },
    { "@type": "ListItem", "position": 3, "name": "Mixer Repair", "item": "https://samedayappliance.repair/commercial/mixer-repair/" },
    { "@type": "ListItem", "position": 4, "name": "Univex", "item": canonical }
  ]}
];
---
<Layout title={title} description={description} canonical={canonical}>
<Fragment slot="head-scripts">{schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}</Fragment>
<CommercialHero title="Univex Commercial Mixer Repair, Same-Day Across LA"
  subtitle={`SRMF spiral, M-Series planetary, DV dough dividers. Independent New Hampshire since 1948. $120 commercial. ${phone}`}
  heroImageTitle="Univex Mixer Repair" showBranches={true} />

<section class="section"><div class="container narrow">
  <p class="section-number">Independent value-tier alternative</p>
  <h2>Univex is the value-tier Hobart alternative + spiral mixer specialty for pizza operations.</h2>
  <p>Univex is independent (Salem New Hampshire, since 1948). Positioned as value-tier planetary mixer alternative to Hobart, plus specialty in spiral mixers (SRMF series) for pizza-dough operations. Common LA installs: pizza shops (Pizzana, Mozza, Bestia, Mother Dough, 800 Degrees, chain pizza), bakeries, mid-volume catering.</p>
  <p>$120 commercial diagnostic, waived with repair. <strong>BHGS #A49573</strong>. <strong>EPA 608 Universal certified #1346255700410</strong>. BBB A+. Phones answered 24/7. Parent: <a href="/commercial/mixer-repair/">commercial mixer repair</a>.</p>
</div></section>

<section class="section section-gray"><div class="container narrow">
  <p class="section-number">Top failure modes</p>
  <ol class="num-list">
    <li><strong>Bowl-rotation gear (SRMF spiral, year 6-9).</strong> $580-880.</li>
    <li><strong>Spiral hook bearing (year 7-10).</strong> $380-580.</li>
    <li><strong>Bowl lift mechanism (M-Series planetary, year 7-10).</strong> $480-720.</li>
    <li><strong>Motor brushes (year 6-9).</strong> $120-220.</li>
    <li><strong>Safety interlock (year 5-8).</strong> $180-280.</li>
    <li><strong>Transmission gear (year 8-12).</strong> $580-880.</li>
    <li><strong>Drive belt wear (year 4-7).</strong> $120-220.</li>
    <li><strong>Capacitor (year 6-9).</strong> $80-180.</li>
  </ol>
</div></section>

<section class="section"><div class="container narrow">
  <p class="section-number">Pricing</p>
  <table class="price-table"><thead><tr><th>Repair</th><th>Typical Cost</th></tr></thead><tbody>
    <tr><td>Diagnostic</td><td>$120, waived with repair</td></tr>
    <tr><td>Bowl-rotation gear (SRMF spiral)</td><td>$580 to $880</td></tr>
    <tr><td>Spiral hook bearing</td><td>$380 to $580</td></tr>
    <tr><td>Bowl lift mechanism</td><td>$480 to $720</td></tr>
    <tr><td>Motor brushes</td><td>$120 to $220</td></tr>
    <tr><td>Safety interlock</td><td>$180 to $280</td></tr>
    <tr><td>Transmission gear</td><td>$580 to $880</td></tr>
    <tr><td>Drive belt</td><td>$120 to $220</td></tr>
    <tr><td>Annual PM contract</td><td>$180 to $280</td></tr>
    <tr><td>Warranty</td><td>90 days parts and labor</td></tr>
  </tbody></table>
</div></section>

<section class="section section-gray"><div class="container narrow">
  <p class="section-number">FAQ</p>
  <div class="faq-list">{faqs.map(f => (<details class="faq-item"><summary>{f.q}</summary><p>{f.a}</p></details>))}</div>
</div></section>

<section class="section"><div class="container narrow">
  <p class="section-number">Related</p>
  <ul class="bullet-list">
    <li><a href="/commercial/mixer-repair/">Mixer repair (parent)</a></li>
    <li><a href="/commercial/mixer-repair/brands/hobart/">Hobart</a> · <a href="/commercial/mixer-repair/brands/varimixer/">Varimixer</a> · <a href="/commercial/mixer-repair/brands/kitchenaid-commercial/">KitchenAid Commercial</a></li>
    <li><a href="/commercial/mixer-repair/motor-issues/">Motor issues</a> · <a href="/commercial/mixer-repair/gear-transmission-issues/">Gear/transmission</a> · <a href="/commercial/mixer-repair/bowl-lift-issues/">Bowl lift</a></li>
  </ul>
</div></section>

<section class="bottom-cta"><div class="container">
  <h2>Univex mixer down? Same-day priority.</h2>
  <p>SRMF spiral, M-Series planetary across LA, OC, Ventura. $120 commercial. BHGS #A49573, EPA 608 Universal #1346255700410.</p>
  <div class="cta-row"><a href={phoneHref} class="btn-primary">☎ Call {phone}</a><a href="/contact/" class="btn-secondary">Book Online</a></div>
</div></section>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .section { padding: 72px 24px; } .section-gray { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; } .container.narrow { max-width: 820px; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  .section h2 { font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 800; margin: 0 0 18px; color: var(--text); line-height: 1.2; }
  .section p { font-size: 1rem; line-height: 1.75; margin: 0 0 16px; color: var(--text); }
  .section a { color: var(--red); font-weight: 600; text-decoration: none; } .section a:hover { text-decoration: underline; }
  .num-list { padding-left: 22px; margin: 14px 0 0; } .num-list li { font-size: 0.98rem; line-height: 1.7; color: var(--text); margin-bottom: 10px; }
  .bullet-list { padding-left: 22px; margin: 14px 0 18px; } .bullet-list li { font-size: 1rem; line-height: 1.65; color: var(--text); margin-bottom: 6px; }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 22px; background: #fff; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
  .price-table th, .price-table td { padding: 12px 16px; text-align: left; border-bottom: 1px solid var(--border); font-size: 0.95rem; }
  .price-table th { background: var(--gray); font-weight: 700; color: var(--text); } .price-table tr:last-child td { border-bottom: none; }
  .faq-list { margin-top: 24px; } .faq-item { background: #fff; border: 1px solid var(--border); border-radius: 6px; padding: 18px 22px; margin-bottom: 12px; }
  .faq-item summary { font-weight: 700; cursor: pointer; font-size: 1rem; color: var(--text); list-style: none; }
  .faq-item summary::-webkit-details-marker { display: none; } .faq-item summary::before { content: "+ "; color: var(--red); font-weight: 800; margin-right: 6px; } .faq-item[open] summary::before { content: "− "; }
  .faq-item p { font-size: 0.95rem; color: var(--text); line-height: 1.75; margin: 14px 0 0; }
  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { color: #fff; margin: 0 0 14px; font-size: 1.7rem; } .bottom-cta p { color: #c9c9c9; margin: 0 0 26px; max-width: 720px; margin-left: auto; margin-right: auto; }
  .cta-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 14px 28px; border-radius: 5px; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 14px 28px; border-radius: 5px; border: 2px solid rgba(255,255,255,0.35); font-weight: 600; text-decoration: none; }
</style>
