---
// src/pages/commercial/fryer-repair.astro
// Wave 5 — /commercial/ — PAGE 15 of 15 — ФИНАЛЬНАЯ
// GSC GIANT: "commercial deep fryer repair" 332 imp pos 64 — massive capture opportunity
//            "commercial fryer repair" 237 imp pos 73
//            "commercial gas fryer repair" 196 imp pos 68
//            "electric fryer repair" 140 imp pos 71
//            fryer-related total: 1,800+ impressions/quarter, 0 clicks
// Unique angles:
// 1. Hi-limit reset diagnostic — free self-fix before calling us
// 2. LA fried food culture — Korean fried chicken, carnitas, food trucks, churros
// 3. Oil quality + fire safety as preventive service

import Layout from '../../layouts/Layout.astro';
import CommercialHero from '../../components/CommercialHero.astro';
import { MAIN_PHONE } from '../../data/branches';

const title = "Commercial Fryer Repair — Same-Day Service Across Southern California";
const description = "Same-day commercial fryer repair across LA, Orange, Ventura, San Bernardino & Riverside counties. Gas and electric deep fryers — Frymaster, Pitco, Henny Penny, Vulcan, Dean. Gas-certified, BHGS Licensed #A49573. $120 diagnostic.";
const phone = MAIN_PHONE.display;
const phoneRaw = MAIN_PHONE.raw;
const phoneHref = MAIN_PHONE.href;
---

<Layout title={title} description={description}>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Commercial Deep Fryer Repair",
  "serviceType": "Commercial Fryer Repair",
  "description": "Same-day commercial deep fryer repair across Southern California — gas and electric tube-type, open-pot, immersion-element, pressure, and floor fryers. Frymaster, Pitco, Henny Penny, Vulcan, Dean, Imperial, Keating. Gas-certified technicians. BHGS Licensed #A49573. $120 commercial diagnostic.",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Same Day Appliance Repair",
    "telephone": phone,
    "url": "https://samedayappliance.repair/",
    "priceRange": "$$"
  },
  "areaServed": [
    {"@type":"AdministrativeArea","name":"Los Angeles County"},
    {"@type":"AdministrativeArea","name":"Orange County"},
    {"@type":"AdministrativeArea","name":"Ventura County"},
    {"@type":"AdministrativeArea","name":"San Bernardino County"},
    {"@type":"AdministrativeArea","name":"Riverside County"}
  ],
  "offers": {
    "@type": "Offer",
    "priceSpecification": {
      "@type": "PriceSpecification",
      "price": "120.00",
      "priceCurrency": "USD",
      "description": "Commercial diagnostic fee, applied toward the repair when approved."
    }
  }
})} />
</script>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much does commercial fryer repair cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Our commercial diagnostic fee is $120, applied toward the repair once you approve the work. Most commercial fryer repairs run between $150 and $500. Igniter, thermostat, hi-limit thermostat, gas valve, drain valve, or pilot assembly replacement is toward the lower end. Heat exchanger or significant gas system work runs higher. We provide a full written estimate before any work begins."
      }
    },
    {
      "@type": "Question",
      "name": "Which areas of Southern California do you cover for commercial fryer repair?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Same-day across Los Angeles, Orange, Ventura, San Bernardino, and Riverside counties — Koreatown, Alhambra, Boyle Heights, Hollywood LA-side; Anaheim, Garden Grove, Westminster OC; Thousand Oaks and Oxnard Ventura; Rancho Cucamonga, Riverside, Ontario IE. Eight service territories total. Frymaster, Pitco, Henny Penny — gas-certified across the entire footprint. BHGS Licensed #A49573."
      }
    },
    {
      "@type": "Question",
      "name": "My commercial fryer stopped heating — should I check anything before calling?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Check the hi-limit reset button first. Commercial fryers have a safety hi-limit thermostat that trips if the fryer exceeds its maximum safe temperature — from a power surge, an empty vat run-on, or excessive oil temperature. When it trips, the fryer stops heating and won't restart until the hi-limit is manually reset. The reset button is typically located on the back panel or behind an access cover, marked 'Reset' or 'Hi-Limit Reset.' Press it firmly and try the fryer again. If it trips again immediately, there's an underlying issue that needs diagnosis — call us."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between gas and electric commercial fryer repair?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Gas fryers use a burner system with a gas valve, igniter (or standing pilot), thermocouple, and hi-limit thermostat. Failures are most often in the ignition system or gas valve. Electric fryers use immersion heating elements and a separate thermostat and hi-limit system. Electric fryer element failure is more predictable but also more expensive per repair than gas igniter work. We repair both types — gas certified technicians for all gas fryer work."
      }
    },
    {
      "@type": "Question",
      "name": "My fryer is reaching temperature but the oil looks dark and smells off — is that a repair issue?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Not primarily a mechanical repair issue — that's an oil quality issue. Fryer oil degrades over time through oxidation and contamination from food particles. When the oil is past its usable life, it smokes at lower temperatures, imparts off-flavors to food, and produces more acrolein — a combustion byproduct with both flavor and safety implications. The solution is an oil change combined with a fryer cleaning. However, if your thermostat is running higher than its set point, that accelerates oil degradation significantly — we calibrate thermostat output on every fryer service call."
      }
    },
    {
      "@type": "Question",
      "name": "Do you repair Frymaster, Pitco, and Henny Penny commercial fryers?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Frymaster, Pitco, and Henny Penny are the three most common commercial fryer brands in SoCal restaurants — across all five counties. We also service Vulcan, Dean (Frymaster), Imperial, Keating, and Waring. Gas-certified technicians for all gas fryer work. Parts for Frymaster and Pitco sourced through same-day commercial kitchen equipment distributors."
      }
    },
    {
      "@type": "Question",
      "name": "How often should a commercial fryer be serviced?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Every 6 months for high-volume operations — more frequently for fryers running 12+ hours per day. A service visit includes thermostat calibration, hi-limit function test, igniter and gas valve condition check, drain valve operation, heat exchanger inspection, and oil filtration system check. Fryers with clogged or damaged drain valves that prevent proper filtration degrade oil faster and create both food quality and fire safety concerns."
      }
    }
  ]
})} />
</script>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .hero { background: var(--black); color: #fff; padding: 80px 24px 64px; text-align: center; }
  .hero-eyebrow { display: inline-block; background: var(--red); color: #fff; font-size: 0.78rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 5px 14px; border-radius: 3px; margin-bottom: 20px; }
  .hero h1 { font-size: clamp(1.9rem, 4vw, 2.9rem); font-weight: 800; line-height: 1.15; margin: 0 0 20px; max-width: 860px; margin-left: auto; margin-right: auto; }
  .hero-sub { font-size: 1.1rem; color: #ccc; max-width: 640px; margin: 0 auto 32px; line-height: 1.6; }
