  .hl-step { background: #050400; border: 1px solid #301800; border-radius: 6px; padding: 12px 14px; display: flex; gap: 10px; align-items: flex-start; }
  .hl-step .sn { min-width: 24px; height: 24px; background: #301800; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 0.78rem; font-weight: 800; color: #e09020; flex-shrink: 0; }
  .hl-step p { font-size: 0.82rem; color: #806030; line-height: 1.5; margin: 0; }
  /* Fryer types */
