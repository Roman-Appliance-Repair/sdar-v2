---
// src/pages/commercial/oven-repair.astro
// Phase 3 Tier 2 (2026-04-28) — neutral multi-county hub.
// title/H1/description/phone neutralized to 5 SoCal counties; Service schema with 5-county
// areaServed (was LocalBusiness with 8 LA cities); aggregateRating absent (already clean);
// Gas-safety SoCalGas-first protocol preserved; combi oven scope-boundary (refer to factory)
// preserved; Cities-served block → 5-county Counties block.

import Layout from '../../layouts/Layout.astro';
import CommercialHero from '../../components/CommercialHero.astro';
import { MAIN_PHONE } from '../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;

const title = "Commercial Oven Repair — Same-Day Service Across Southern California | Same Day Appliance Repair";
const description = "Same-day commercial oven repair across LA, Orange, Ventura, San Bernardino & Riverside counties. Convection, deck, pizza, gas range — Vulcan, Garland, Southbend, Blodgett, Imperial. Gas certified. BHGS #A49573, $120 diagnostic. Call (424) 325-0520.";
const canonical = "https://samedayappliance.repair/commercial/oven-repair/";
---

<Layout title={title} description={description}>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Commercial Oven Repair",
  "name": "Commercial Oven Repair — Same Day Appliance Repair",
  "url": canonical,
  "description": "Same-day commercial oven repair across Los Angeles, Orange, Ventura, San Bernardino, and Riverside counties. Convection, deck, pizza, conveyor, rack, gas range — Vulcan, Garland, Southbend, Blodgett, Imperial, Baker's Pride.",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Same Day Appliance Repair",
    "url": "https://samedayappliance.repair/",
    "telephone": phone,
    "priceRange": "$$",
    "openingHoursSpecification": [
      { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"], "opens": "07:00", "closes": "21:00" }
    ]
  },
  "areaServed": [
    { "@type": "AdministrativeArea", "name": "Los Angeles County" },
    { "@type": "AdministrativeArea", "name": "Orange County" },
    { "@type": "AdministrativeArea", "name": "Ventura County" },
    { "@type": "AdministrativeArea", "name": "San Bernardino County" },
    { "@type": "AdministrativeArea", "name": "Riverside County" }
  ],
  "offers": {
    "@type": "Offer",
    "priceSpecification": {
      "@type": "PriceSpecification",
      "price": "120.00",
      "priceCurrency": "USD",
      "description": "Commercial diagnostic fee, applied toward repair"
    }
  }
})} />

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much does commercial oven repair cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Our commercial diagnostic fee is $120, applied toward the repair once you approve the work. Most commercial oven repairs run between $180 and $550. Igniter replacement, thermostat, door gasket, or gas valve is toward the lower end. Control board replacement or sealed burner assembly runs higher. We provide a full written estimate before any work begins — no surprises."
      }
    },
    {
      "@type": "Question",
      "name": "Which areas of Southern California do you cover?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "All five SoCal counties: Los Angeles, Orange, Ventura, San Bernardino, and Riverside. We dispatch from 8 service territories so the technician on your commercial call is coming from the closest one. Same-day commercial priority dispatch across all 5 counties — oven down = closed kitchen, so we treat it as urgent."
      }
    },
    {
      "@type": "Question",
      "name": "My commercial oven smells like gas — what should I do first?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Call SoCalGas at 1-800-427-2200 first, not an appliance repair company. SoCalGas serves LA, Ventura, parts of Orange and San Bernardino counties — they'll respond quickly, safely shut off gas supply to the oven, and verify the source of the smell at no charge. (For Riverside County and Anaheim/Long Beach, the gas utility is Southwest Gas: 1-877-860-6020.) Once the gas is secured and the area is safe, then call us for the mechanical diagnosis and repair. This is the right sequence: gas utility first, appliance repair second. Never attempt to operate a gas appliance that smells of gas."
      }
    },
    {
      "@type": "Question",
      "name": "My commercial convection oven is not heating to temperature — what causes that?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "For gas convection ovens: failed igniter (most common), faulty gas valve, or a thermostat that's drifted and is cutting the gas circuit prematurely. For electric convection ovens: failed heating element or a control board fault. If the oven heats but cooking is uneven, the convection fan motor is often the issue — the fan circulates heat, and without it the oven becomes an inefficient static oven."
      }
    },
    {
      "@type": "Question",
      "name": "What types of commercial ovens do you repair?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We repair commercial convection ovens (gas and electric), commercial gas ranges, deck ovens, pizza ovens, conveyor ovens, and rack ovens. For Rational and Alto-Shaam combi ovens, we refer to factory-authorized service — combi oven systems are complex enough that factory certification matters. We'll tell you this upfront rather than attempt a repair we're not the best option for."
      }
    },
    {
      "@type": "Question",
      "name": "My commercial oven pilot light won't stay lit — can I fix this myself?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "On standing pilot systems: check for drafts near the oven that might be extinguishing the pilot, and try relighting per the manufacturer procedure. If the pilot consistently won't hold, the thermocouple or thermopile that senses the pilot flame has likely failed — this is a $80–$150 repair that requires a technician. Do not attempt to bypass or tape the thermocouple. If you smell gas when the pilot is out, follow the gas safety protocol above — gas utility first."
      }
    },
    {
      "@type": "Question",
      "name": "Do you repair Vulcan, Garland, and Southbend commercial ovens?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Vulcan, Garland, Southbend, Imperial, Blodgett, and Baker's Pride are the brands we service most across SoCal commercial kitchens. We carry parts for Vulcan and Garland specifically and source parts for others same-day through commercial kitchen equipment distributors."
      }
    },
    {
      "@type": "Question",
      "name": "How often should commercial ovens be serviced?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Every 6 months minimum for preventive service. A service visit includes burner inspection and cleaning, thermostat calibration, door gasket check, igniter condition check, and vent cleaning. In high-volume kitchens running ovens 16+ hours per day, quarterly service is the right interval. Regular maintenance catches the igniter degradation and thermostat drift that cause failures — usually at a point where they're a $150 fix rather than a $500 emergency repair."
      }
    },
    {
      "@type": "Question",
      "name": "When does it make sense to repair vs replace a commercial oven?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Commercial ovens (Vulcan, Garland, Southbend) are built for 15-20 year service lives with proper maintenance. Repair almost always makes sense. Replacement runs $4,000–$15,000+ for a new unit plus installation, gas line work, and ventilation hood adjustment — a major capital outlay. We give you an honest assessment during the diagnostic, including whether it's worth investing in a major repair on a unit pushing 20 years."
      }
    }
  ]
})} />

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .hero { background: var(--black); color: #fff; padding: 80px 24px 64px; text-align: center; }
  .hero-eyebrow { display: inline-block; background: var(--red); color: #fff; font-size: 0.78rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 5px 14px; border-radius: 3px; margin-bottom: 20px; }
  .hero h1 { font-size: clamp(1.9rem, 4vw, 2.9rem); font-weight: 800; line-height: 1.15; margin: 0 0 20px; max-width: 860px; margin-left: auto; margin-right: auto; }
  .hero-sub { font-size: 1.1rem; color: #ccc; max-width: 640px; margin: 0 auto 32px; line-height: 1.6; }
  .cta-row { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 16px 34px; border-radius: 5px; font-size: 1rem; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 16px 34px; border-radius: 5px; font-size: 1rem; font-weight: 600; text-decoration: none; border: 2px solid rgba(255,255,255,0.35); }
  .hero-meta { margin-top: 28px; color: #aaa; font-size: 0.9rem; display: flex; gap: 24px; justify-content: center; flex-wrap: wrap; }
  .trust-bar { background: var(--red); padding: 18px 24px; }
  .trust-inner { max-width: 1100px; margin: 0 auto; display: flex; justify-content: center; flex-wrap: wrap; gap: 10px 32px; }
  .trust-item { color: #fff; font-size: 0.88rem; font-weight: 600; }
  .section { padding: 64px 24px; }
  .section-gray { background: var(--gray); }
  .section-black { background: var(--black); color: #fff; }
  .container { max-width: 1100px; margin: 0 auto; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  h2.section-title { font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 800; margin: 0 0 16px; line-height: 1.2; }
  .section-black h2.section-title { color: #fff; }
  .lead { font-size: 1.05rem; line-height: 1.75; color: var(--text); max-width: 760px; }
  .section-black .lead { color: #ccc; }
  .intro-grid { display: grid; grid-template-columns: 1fr 320px; gap: 48px; align-items: start; }
  @media (max-width: 768px) { .intro-grid { grid-template-columns: 1fr; } }
  .intro-body p { margin: 0 0 18px; font-size: 1.05rem; line-height: 1.8; color: var(--text); }
  .alert-gas { background: #0a0800; border: 2px solid #c08000; border-radius: 8px; padding: 20px 22px; margin-top: 24px; }
  .alert-gas .ag-label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #e0a000; margin-bottom: 10px; }
  .alert-gas p { font-size: 0.93rem; color: #b09050; margin: 0; line-height: 1.65; }
  .sticky-cta { position: sticky; top: 24px; background: var(--black); border-radius: 10px; padding: 28px 24px; color: #fff; text-align: center; }
  .sticky-cta .cta-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: #aaa; margin-bottom: 14px; }
  .sticky-cta .cta-phone { font-size: 1.5rem; font-weight: 800; color: #fff; text-decoration: none; display: block; margin-bottom: 12px; }
  .sticky-cta .btn-cta { display: block; background: var(--red); color: #fff; padding: 14px; border-radius: 5px; font-weight: 700; text-decoration: none; font-size: 0.95rem; margin-bottom: 10px; }
  .sticky-cta .cta-sub { font-size: 0.82rem; color: #888; }
  .cta-divider { border: none; border-top: 1px solid #222; margin: 18px 0; }
  .cta-detail { font-size: 0.85rem; color: #aaa; text-align: left; }
  .cta-detail li { margin-bottom: 6px; list-style: none; padding-left: 18px; position: relative; }
  .cta-detail li::before { content: "✓"; position: absolute; left: 0; color: var(--red); font-weight: 700; }
  /* Oven types */
  .type-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 16px; margin-top: 32px; }
  .type-card { background: #111; border: 1px solid #222; border-radius: 8px; padding: 20px 18px; }
  .type-card.refer { border-color: #2a2a3a; opacity: 0.75; }
  .type-badge { display: inline-block; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; padding: 3px 10px; border-radius: 3px; margin-bottom: 10px; }
  .badge-yes { background: #1a2a1a; color: #80d080; }
  .badge-refer { background: #1a1a2a; color: #8080c0; }
  .type-card h3 { font-size: 0.9rem; font-weight: 700; color: #fff; margin: 0 0 8px; }
  .type-card p { font-size: 0.82rem; color: #888; line-height: 1.6; margin: 0; }
  /* Problems */
  .problems-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 18px; margin-top: 36px; }
  .problem-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 22px 18px; }
  .problem-card h3 { font-size: 1rem; font-weight: 700; margin: 0 0 10px; color: var(--text); }
  .problem-card p { font-size: 0.9rem; color: var(--muted); line-height: 1.6; margin: 0; }
  /* Gas safety block */
  .gas-block { background: #100a00; border: 2px solid #604000; border-radius: 10px; padding: 34px 30px; margin-top: 36px; }
  .gas-block .g-label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: #d09030; margin-bottom: 12px; }
  .gas-block h3 { font-size: 1.2rem; font-weight: 800; color: #fff; margin: 0 0 12px; }
  .gas-block p { font-size: 0.93rem; color: #a07030; line-height: 1.7; margin: 0 0 12px; }
  .gas-steps { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 10px; margin-top: 16px; }
  .gas-step { background: #080500; border: 1px solid #301800; border-radius: 6px; padding: 14px; display: flex; gap: 10px; align-items: flex-start; }
  .gas-step .step-num { font-size: 1.2rem; font-weight: 900; color: #d09030; line-height: 1; flex-shrink: 0; }
  .gas-step p { font-size: 0.82rem; color: #806030; line-height: 1.5; margin: 0; }
  /* Brands */
  .brands-grid { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 28px; }
  .brand-chip { background: #fff; border: 1px solid var(--border); border-radius: 4px; padding: 8px 18px; font-size: 0.88rem; font-weight: 600; color: var(--text); }
  .brand-chip.dark { background: #1a1a1a; color: #ddd; border-color: #333; }
  .brand-chip.refer { background: #111; color: #555; border-color: #222; font-style: italic; }
  /* LA neighborhoods */
  .neigh-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(195px, 1fr)); gap: 14px; margin-top: 28px; }
  .neigh-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 18px 16px; }
  .neigh-card h3 { font-size: 0.9rem; font-weight: 700; margin: 0 0 6px; color: var(--text); }
  .neigh-card p { font-size: 0.82rem; color: var(--muted); line-height: 1.5; margin: 0; }
  /* Repairs */
  .repairs-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(255px, 1fr)); gap: 22px; margin-top: 36px; }
  .repair-card { background: #111; border: 1px solid #222; border-radius: 8px; padding: 22px 18px; }
  .repair-card .repair-title { font-size: 0.82rem; font-weight: 700; color: #aaa; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 8px; }
  .repair-card h3 { font-size: 0.98rem; font-weight: 700; color: #fff; margin: 0 0 10px; line-height: 1.3; }
  .repair-card p { font-size: 0.87rem; color: #888; line-height: 1.6; margin: 0 0 12px; }
  .repair-card .repair-detail { font-size: 0.78rem; color: #555; border-top: 1px solid #1e1e1e; padding-top: 10px; }
  /* Pricing */
  .pricing-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 18px; margin-top: 32px; }
  .price-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 22px 18px; text-align: center; }
  .price-card .price-label { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); margin-bottom: 8px; }
  .price-card .price-amount { font-size: 1.8rem; font-weight: 800; color: var(--text); line-height: 1; margin-bottom: 8px; }
  .price-card .price-desc { font-size: 0.84rem; color: var(--muted); line-height: 1.5; }
  .price-note { margin-top: 18px; font-size: 0.9rem; color: var(--muted); line-height: 1.6; }
  .faq-list { margin-top: 36px; }
  .faq-item { border-bottom: 1px solid var(--border); padding: 20px 0; }
  .faq-item:first-child { border-top: 1px solid var(--border); }
  .faq-item h3 { font-size: 1rem; font-weight: 700; color: var(--text); margin: 0 0 10px; }
  .faq-item p { font-size: 0.95rem; color: var(--muted); line-height: 1.7; margin: 0; }
  .nearby-links { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 24px; }
  .nearby-links a { background: #fff; border: 1px solid var(--border); border-radius: 4px; padding: 8px 16px; font-size: 0.87rem; color: var(--text); text-decoration: none; font-weight: 500; }
  .nearby-links a:hover { border-color: var(--red); color: var(--red); }
  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; margin: 0 0 16px; }
  .bottom-cta p { color: #aaa; margin: 0 0 32px; font-size: 1.05rem; }
</style>

<!-- HERO + TRUST BAR (unified CommercialHero) -->
<CommercialHero
  title="Commercial Oven Repair Across Southern California"
  subtitle="Convection oven down before dinner service, gas range not lighting, deck oven losing temperature — we dispatch commercial oven calls same-day across LA, Orange, Ventura, San Bernardino & Riverside counties. Vulcan, Garland, Southbend, Blodgett, Imperial."
  heroImageTitle="Commercial Oven Repair"
/>

<!-- INTRO -->
<section class="section">
  <div class="container">
    <div class="intro-grid">
      <div class="intro-body">
        <p class="section-number">01 — About This Service</p>
        <h2 class="section-title">A commercial oven failure mid-service isn't a maintenance issue — it's a kitchen shutdown.</h2>

        <p>A commercial convection oven that goes cold at 4pm on a Friday kills the dinner service. A gas range that won't light at 10am shuts down prep. Restaurants on the East Hollywood corridor, along the Wilshire Park stretch, and throughout Koreatown run equipment hard — 14–18 hour days, high-BTU loads, and door cycles that accumulate wear faster than any residential or light commercial schedule accounts for.</p>

        <p>We dispatch commercial oven calls as same-day priority because we understand the business impact. An igniter, gas valve, or thermostat issue caught in the morning can be resolved before the lunch rush. The same issue escalating through a lunch service until the oven quits during dinner prep is a different — and much worse — outcome for the operator.</p>

        <p>We repair commercial convection ovens, gas ranges, deck ovens, pizza ovens, and conveyor ovens. For Rational and Alto-Shaam combi ovens, we refer to factory-authorized service — these systems are complex enough that factory certification is the honest recommendation. We'll tell you this upfront rather than attempt a repair we're not the best option for.</p>

        <div class="alert-gas">
          <div class="ag-label">⚠️ Gas Smell? Call SoCalGas First — Not Us.</div>
          <p>If you smell gas near your commercial oven: <strong>call SoCalGas at 1-800-427-2200</strong>, not an appliance company. SoCalGas responds quickly, shuts off gas at the source safely, and verifies the leak — at no charge. Once the gas is secured and the area is safe, then call us at {phone} for the mechanical diagnosis and repair. Gas utility first, appliance repair second. Never operate an oven that smells of gas.</p>
        </div>
      </div>

      <aside class="sticky-cta">
        <div class="cta-label">Same Day Commercial Priority</div>
        <a href={`tel:${phoneRaw}`} class="cta-phone">{phone}</a>
        <a href={`tel:${phoneRaw}`} class="btn-cta">Call Now — Priority Dispatch</a>
        <a href="/book" class="btn-cta" style="background:#222; margin-top:-4px;">Schedule Online</a>
        <div class="cta-sub">Mon–Sun 7am–9pm · Oven calls dispatched same day</div>
        <hr class="cta-divider" />
        <ul class="cta-detail">
          <li>Commercial diagnostic: $120</li>
          <li>Applied to repair if approved</li>
          <li>Gas certified technicians</li>
          <li>Vulcan, Garland, Southbend parts</li>
          <li>90-day warranty on all repairs</li>
          <li>Preventive maintenance available</li>
        </ul>
      </aside>
    </div>
  </div>
</section>

<!-- OVEN TYPES -->
<section class="section section-black">
  <div class="container">
    <p class="section-number">02 — Oven Types We Service</p>
    <h2 class="section-title">What we repair — and where we refer when factory certification matters</h2>
    <p class="lead">Different oven types have different failure modes and repair requirements. We come prepared for the specific equipment at your location.</p>

    <div class="type-grid">
      <div class="type-card">
        <div class="type-badge badge-yes">✓ We Repair</div>
        <h3>Convection Ovens</h3>
        <p>Gas and electric convection ovens — the most common type in SoCal commercial kitchens. Igniter, gas valve, heating element, convection fan motor, thermostat, control board, door gasket and seal.</p>
      </div>
      <div class="type-card">
        <div class="type-badge badge-yes">✓ We Repair</div>
        <h3>Commercial Gas Ranges</h3>
        <p>Full commercial ranges with oven section — open burners, pilot systems, igniters, gas valves, oven thermostat, broiler section. Vulcan, Garland, Southbend, Imperial, and Montague.</p>
      </div>
      <div class="type-card">
        <div class="type-badge badge-yes">✓ We Repair</div>
        <h3>Deck Ovens</h3>
        <p>Single and double-deck baking ovens for pizzerias and bakeries. Heating elements, thermostat, door seal and hinge, steam injection systems on equipped models.</p>
      </div>
      <div class="type-card">
        <div class="type-badge badge-yes">✓ We Repair</div>
        <h3>Pizza Ovens</h3>
        <p>Gas and electric pizza ovens — stone deck and conveyor types. Igniter, gas valve, thermostat, conveyor belt motor and drive system, temperature controller.</p>
      </div>
      <div class="type-card">
        <div class="type-badge badge-yes">✓ We Repair</div>
        <h3>Conveyor Ovens</h3>
        <p>Lincoln Impinger, Middleby Marshall, and similar conveyor pizza and baking ovens. Belt drive motor, heating elements, finger fan motors, control board, temperature sensor.</p>
      </div>
      <div class="type-card">
        <div class="type-badge badge-yes">✓ We Repair</div>
        <h3>Rack Ovens &amp; Proofers</h3>
        <p>Commercial roll-in rack ovens and proofer/retarder cabinets for bakeries. Heating system, fan, humidity control, door seal. Common in SoCal's expanding bakery markets — Koreatown bakeries, Anaheim Korean/Vietnamese bakeries, Persian bakeries (Westwood/Tarzana), Inland Empire ethnic-market bakery clusters.</p>
      </div>
      <div class="type-card refer">
        <div class="type-badge badge-refer">→ We Refer</div>
        <h3>Rational &amp; Alto-Shaam Combi Ovens</h3>
        <p>Combi oven systems require factory-authorized certification for proper service. We'll refer you to the right specialist — this is honest service, not a limitation.</p>
      </div>
      <div class="type-card refer">
        <div class="type-badge badge-refer">→ We Refer</div>
        <h3>Convotherm &amp; Complex Steam Systems</h3>
        <p>Factory-certified service is the right call for complex combi steam systems. We'll connect you with the appropriate specialist rather than attempt a repair we're not best positioned for.</p>
      </div>
    </div>
  </div>
</section>

<!-- PROBLEMS -->
<section class="section section-gray">
  <div class="container">
    <p class="section-number">03 — Common Failures</p>
    <h2 class="section-title">What our technicians diagnose most often in SoCal commercial ovens</h2>

    <div class="problems-grid">
      <div class="problem-card">
        <h3>Not Heating / Won't Reach Temperature</h3>
        <p>Gas ovens: failed igniter (most common, most replaceable) or faulty gas valve. Electric ovens: failed heating element. Both types: thermostat calibrated incorrectly or drifted beyond spec — oven cycles off before reaching set temperature. We test igniter draw current before condemning it, since weak igniters that still spark don't always light reliably.</p>
      </div>
      <div class="problem-card">
        <h3>Uneven Cooking / Hot Spots</h3>
        <p>Convection oven with a failed fan motor — without air circulation the oven reverts to radiant heat only, causing hot spots near the elements and cold zones away from them. Also: blocked air circulation baffles from grease buildup, or a warped rack creating uneven airflow. We check fan motor amperage draw to catch motors that run but are losing torque before they fail completely.</p>
      </div>
      <div class="problem-card">
        <h3>Pilot Light Won't Stay Lit</h3>
        <p>On standing pilot systems, a pilot that lights but won't hold almost always means a failed thermocouple or thermopile — the safety sensor that detects the pilot flame and allows the gas valve to stay open. This is a $80–$150 repair. If the pilot won't light at all, the pilot orifice may be blocked with grease or carbon — a cleaning service resolves it.</p>
      </div>
      <div class="problem-card">
        <h3>Temperature Fluctuation / Inconsistent Heat</h3>
        <p>A thermostat that cycles the oven on and off at incorrect intervals causes inconsistent temperature. In SoCal high-use commercial kitchens, thermostats drift over time — an oven "running at 350°F" may actually oscillate between 310°F and 390°F. We calibrate against a certified reference thermometer and replace if outside acceptable range.</p>
      </div>
      <div class="problem-card">
        <h3>Door Won't Seal / Heat Escaping</h3>
        <p>Door gasket compression failure or a warped door allowing heat to escape. Beyond wasted energy, heat escaping from the door changes the oven's thermal profile — front products cook faster than back products. Door gasket replacement is typically a same-visit repair. Warped doors require assessment for repair vs. replacement.</p>
      </div>
      <div class="problem-card">
        <h3>Control Board Fault</h3>
        <p>Digital control boards on modern commercial ovens fail from heat cycling stress, grease contamination, and power surges. A board fault can present as temperature errors, display failures, or non-responsive controls. We assess whether the fault is the board itself or a sensor feeding incorrect data to it — sensors are usually cheaper to replace.</p>
      </div>
    </div>
  </div>
</section>

<!-- GAS SAFETY BLOCK -->
<section class="section">
  <div class="container">
    <p class="section-number">04 — Gas Safety Protocol</p>
    <h2 class="section-title">What to do when your commercial oven smells like gas — the correct sequence</h2>

    <div class="gas-block">
      <div class="g-label">⚠️ Gas Safety — Follow This Sequence</div>
      <h3>SoCalGas first. Appliance repair second. This order matters.</h3>
      <p>Most appliance repair companies don't tell you this, but the correct response to a gas smell near commercial kitchen equipment is to call the gas utility, not a repair company. SoCalGas (1-800-427-2200) will dispatch a technician who can safely locate the leak, shut off gas supply, and confirm the area is safe — and they do this at no charge. An appliance repair technician arriving in this situation without the gas isolated is working in an unsafe environment.</p>
      <p>Once SoCalGas has secured the gas supply and confirmed the area is safe, the mechanical repair — finding which component has failed and replacing it — is where we come in. Gas valve replacement, fitting repair, or igniter system issues are our work. The sequence simply matters for safety.</p>

      <div class="gas-steps">
        <div class="gas-step">
          <div class="step-num">1</div>
          <p><strong>Turn off the oven</strong> and move everyone away from the area. Don't operate switches that could create a spark.</p>
        </div>
        <div class="gas-step">
          <div class="step-num">2</div>
          <p><strong>Call SoCalGas: 1-800-427-2200.</strong> They respond quickly, at no charge, and will shut off the gas supply safely.</p>
        </div>
        <div class="gas-step">
          <div class="step-num">3</div>
          <p><strong>Ventilate the space</strong> — open doors and windows once you're sure there's no ignition source.</p>
        </div>
        <div class="gas-step">
          <div class="step-num">4</div>
          <p><strong>Call us at {phone}</strong> once gas is secured. We'll diagnose the component failure and repair it same day.</p>
        </div>
      </div>
    </div>
  </div>
</section>

