---
// Wave 22a — Vulcan steamer brand page (steamer-repair/brands/ — distinct from /brands/vulcan.astro main brand hub).
import Layout from '../../../../layouts/Layout.astro';
import CommercialHero from '../../../../components/CommercialHero.astro';
import { MAIN_PHONE } from '../../../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/commercial/steamer-repair/brands/vulcan/";

const title = "Vulcan Steamer Repair Los Angeles — Same Day";
const description = `Vulcan commercial steamer repair across LA + OC. ITW Food Equipment Group brand since 1986. Pressure + pressureless. BHGS #A49573. $120 commercial dx.`;

const faqs = [
  { q: "Vulcan steamers vs Vulcan ranges/fryers — same parts logistics?", a: "Same parent (ITW Food Equipment Group, Vulcan brand) but separate product lines and parts catalogs. Steamer-specific parts come through ITW's Vulcan steamer service network; range and fryer parts through their respective sub-networks. Practical effect: dispatching a single tech for one Vulcan visit covering steamer + range + fryer is supported because we have ITW master parts access, but specific parts may have different stock levels per product line." },
  { q: "VS Series boiler steamer service patterns?", a: "Vulcan VS Series is the workhorse boiler steamer at restaurant kitchens, hospital cafeterias, school nutrition. Boiler heating element year 7-10 ($480-820), low-water cutoff sensor year 6-9 ($260-380), blowdown valve scaling year 2-4 LA hard water ($120-220 service), water-feed valve year 6-9 ($260-440). Boiler architecture has more components than pressureless but is mechanically robust — VS Series at 15+ years still in service is common." },
  { q: "C24EA convection electric vs MSC convection?", a: "C24EA is countertop electric convection steamer, common at smaller restaurants and high-end concepts. MSC is floor-model convection. Same architecture (electric heating + convection fan) at different capacities. Heating element year 6-8 ($480-680), convection fan motor year 7-10 ($385-625), thermostat year 6-9 ($260-440)." },
  { q: "ITW Food Equipment Group cross-brand service?", a: "Yes. ITW owns Vulcan, Wolf Industrial commercial, Hobart, Traulsen, Bonnet, and several others. Single service vendor relationship covers Vulcan steamers + Wolf Range commercial + Hobart dishwashers + Traulsen refrigeration. Operations standardized on ITW family benefit from unified parts logistics and service consistency." },
  { q: "Annual descaling for LA Vulcan steamers?", a: "Boiler steamers (VS Series) need annual descaling on boiler tubes plus blowdown valve service ($160-280 PM). Pressureless and convection electric (C24EA, MSC) need annual descaling on heating element and steam exit valves ($120-220). LA hard water makes this PM critical." },
  { q: "Health Department compliance documentation?", a: "Steamers must reach 165°F+ on cooked product (CA Retail Food Code). We document service for HD compliance file with calibrated thermometer verification. Restaurant operations under regular HD inspection benefit from annual PM contracts." },
  { q: "What's your warranty?", a: "90 days SDAR labor and parts. Vulcan component warranties processed separately through ITW Food Equipment Group authorized service network. BHGS #A49573, BBB A+, EPA 608 Universal #1346255700410." }
];

const brandSchema = {
  "@context": "https://schema.org", "@type": "Brand", "@id": canonical + "#brand",
  "name": "Vulcan", "url": "https://www.vulcanequipment.com",
  "description": "Vulcan manufactures commercial cooking equipment including steamers (VS Series boiler, C24EA convection, MSC). ITW Food Equipment Group brand since 1986. Founded 1865 Baltimore Maryland.",
  "foundingDate": "1865", "foundingLocation": { "@type": "Place", "name": "Baltimore, Maryland" },
  "parentOrganization": { "@type": "Organization", "name": "ITW Food Equipment Group" }
};

const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair", "url": canonical, "telephone": phone, "priceRange": "$$",
    "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "08:00", "closes": "20:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "00:00", "closes": "00:00" }
      ],
    "areaServed": [{ "@type": "AdministrativeArea", "name": "Los Angeles County" },{ "@type": "AdministrativeArea", "name": "Orange County" },{ "@type": "AdministrativeArea", "name": "Ventura County" },{ "@type": "AdministrativeArea", "name": "San Bernardino County" },{ "@type": "AdministrativeArea", "name": "Riverside County" }]
  },
  { "@context": "https://schema.org", "@type": "Service", "@id": canonical + "#service",
    "serviceType": "Vulcan Commercial Steamer Repair", "name": "Vulcan Steamer Repair Service", "url": canonical,
    "description": "Vulcan commercial steamer repair across all five SoCal counties. VS Series boiler steamers, C24EA countertop convection electric, MSC floor convection. Boiler heating element (year 7-10), low-water cutoff (year 6-9), blowdown valve scaling (LA hard water year 2-4 PM), convection fan motor (year 7-10). ITW Food Equipment Group brand. $120 commercial diagnostic, applied toward repair. BHGS #A49573, EPA 608 Universal certified #1346255700410.",
    "provider": { "@id": canonical + "#business" }, "brand": { "@id": canonical + "#brand" },
    "areaServed": [{ "@type": "AdministrativeArea", "name": "Los Angeles County" },{ "@type": "AdministrativeArea", "name": "Orange County" },{ "@type": "AdministrativeArea", "name": "Ventura County" },{ "@type": "AdministrativeArea", "name": "San Bernardino County" },{ "@type": "AdministrativeArea", "name": "Riverside County" }],
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "120.00", "priceCurrency": "USD", "description": "Commercial diagnostic fee, applied toward repair" } }
  },
  brandSchema,
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Commercial", "item": "https://samedayappliance.repair/commercial/" },
      { "@type": "ListItem", "position": 3, "name": "Steamer Repair", "item": "https://samedayappliance.repair/commercial/steamer-repair/" },
      { "@type": "ListItem", "position": 4, "name": "Vulcan", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>
<Fragment slot="head-scripts">
  {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
</Fragment>

<CommercialHero title="Vulcan Commercial Steamer Repair, Same-Day Across LA"
  subtitle={`VS Series boiler, C24EA convection, MSC. ITW Food Equipment Group brand. $120 commercial diagnostic. ${phone}`}
  heroImageTitle="Vulcan Commercial Steamer Repair" showBranches={true} />

<section class="section">
  <div class="container narrow">
    <p class="section-number">ITW commercial steamer line</p>
    <h2>Vulcan brings the workhorse VS Series boiler steamer plus C24EA convection to commercial kitchens.</h2>
    <p>Vulcan is part of ITW Food Equipment Group (since 1986; Vulcan founded 1865 Baltimore). The steamer product line covers <strong>VS Series</strong> boiler steamers (the workhorse for restaurant, hospital, school nutrition operations), <strong>C24EA</strong> countertop convection electric (smaller operations and high-end concepts), and <strong>MSC</strong> floor convection. Cross-brand service through ITW family covers Vulcan steamers + Wolf Range commercial + Hobart dishwashers + Traulsen refrigeration on a single service vendor relationship.</p>
    <p>$120 commercial diagnostic, waived with repair. <strong>BHGS #A49573</strong>. <strong>EPA 608 Universal certified #1346255700410</strong>. BBB A+. Phones answered 24/7. Parent: <a href="/commercial/steamer-repair/">commercial steamer repair</a>. Sister brand pages: <a href="/brands/vulcan/">Vulcan brand hub</a>, <a href="/brands/vulcan-range-repair/">Vulcan ranges</a>, <a href="/brands/vulcan-fryer-repair/">Vulcan fryers</a>.</p>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">Top failure modes</p>
    <ol class="num-list">
      <li><strong>Boiler heating element burnout (VS Series, year 7-10).</strong> $480-820.</li>
      <li><strong>Low-water cutoff sensor (boiler, year 6-9).</strong> $260-380.</li>
      <li><strong>Blowdown valve scaling (LA hard water year 2-4).</strong> $120-220 service. Annual PM critical.</li>
      <li><strong>Convection fan motor (C24EA, MSC, year 7-10).</strong> $385-625.</li>
      <li><strong>Heating element (C24EA convection electric, year 6-8).</strong> $480-680.</li>
      <li><strong>Thermostat drift (year 6-9).</strong> $260-440.</li>
      <li><strong>Door gasket compression (year 5-8).</strong> $180-280.</li>
      <li><strong>Water-feed valve (year 6-9).</strong> $260-440.</li>
    </ol>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Pricing</p>
    <table class="price-table">
      <thead><tr><th>Repair</th><th>Typical Cost</th></tr></thead>
      <tbody>
        <tr><td>Diagnostic</td><td>$120, waived with repair</td></tr>
        <tr><td>Boiler heating element (VS)</td><td>$480 to $820</td></tr>
        <tr><td>Heating element (C24EA convection)</td><td>$480 to $680</td></tr>
        <tr><td>Low-water cutoff sensor</td><td>$260 to $380</td></tr>
        <tr><td>Blowdown valve descaling</td><td>$120 to $220</td></tr>
        <tr><td>Convection fan motor</td><td>$385 to $625</td></tr>
        <tr><td>Thermostat replacement</td><td>$260 to $440</td></tr>
        <tr><td>Door gasket replacement</td><td>$180 to $280</td></tr>
        <tr><td>Annual PM (boiler descaling + sensor check)</td><td>$160 to $280</td></tr>
        <tr><td>Warranty</td><td>90 days parts and labor</td></tr>
      </tbody>
    </table>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">FAQ</p>
    <div class="faq-list">{faqs.map(f => (<details class="faq-item"><summary>{f.q}</summary><p>{f.a}</p></details>))}</div>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Related</p>
    <ul class="bullet-list">
      <li><a href="/commercial/steamer-repair/">Steamer repair (parent)</a></li>
      <li><a href="/commercial/steamer-repair/brands/cleveland-range/">Cleveland Range</a> · <a href="/commercial/steamer-repair/brands/groen/">Groen</a> · <a href="/commercial/steamer-repair/brands/market-forge/">Market Forge</a> · <a href="/commercial/steamer-repair/brands/accutemp/">AccuTemp</a></li>
      <li><a href="/brands/vulcan/">Vulcan brand hub</a> · <a href="/brands/vulcan-range-repair/">Vulcan ranges</a> · <a href="/brands/vulcan-fryer-repair/">Vulcan fryers</a></li>
    </ul>
  </div>
</section>

<section class="bottom-cta">
  <div class="container">
    <h2>Vulcan steamer down? Same-day priority.</h2>
    <p>VS Series, C24EA, MSC across LA, OC, Ventura. $120 commercial. BHGS #A49573, EPA 608 Universal #1346255700410.</p>
    <div class="cta-row"><a href={phoneHref} class="btn-primary">☎ Call {phone}</a><a href="/contact/" class="btn-secondary">Book Online</a></div>
  </div>
</section>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .section { padding: 72px 24px; } .section-gray { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; } .container.narrow { max-width: 820px; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  .section h2 { font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 800; margin: 0 0 18px; color: var(--text); line-height: 1.2; }
  .section p { font-size: 1rem; line-height: 1.75; margin: 0 0 16px; color: var(--text); }
  .section a { color: var(--red); font-weight: 600; text-decoration: none; } .section a:hover { text-decoration: underline; }
  .num-list { padding-left: 22px; margin: 14px 0 0; } .num-list li { font-size: 0.98rem; line-height: 1.7; color: var(--text); margin-bottom: 10px; }
  .bullet-list { padding-left: 22px; margin: 14px 0 18px; } .bullet-list li { font-size: 1rem; line-height: 1.65; color: var(--text); margin-bottom: 6px; }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 22px; background: #fff; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
  .price-table th, .price-table td { padding: 12px 16px; text-align: left; border-bottom: 1px solid var(--border); font-size: 0.95rem; }
  .price-table th { background: var(--gray); font-weight: 700; color: var(--text); } .price-table tr:last-child td { border-bottom: none; }
  .faq-list { margin-top: 24px; } .faq-item { background: #fff; border: 1px solid var(--border); border-radius: 6px; padding: 18px 22px; margin-bottom: 12px; }
  .faq-item summary { font-weight: 700; cursor: pointer; font-size: 1rem; color: var(--text); list-style: none; }
  .faq-item summary::-webkit-details-marker { display: none; } .faq-item summary::before { content: "+ "; color: var(--red); font-weight: 800; margin-right: 6px; } .faq-item[open] summary::before { content: "− "; }
  .faq-item p { font-size: 0.95rem; color: var(--text); line-height: 1.75; margin: 14px 0 0; }
  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { color: #fff; margin: 0 0 14px; font-size: 1.7rem; } .bottom-cta p { color: #c9c9c9; margin: 0 0 26px; max-width: 720px; margin-left: auto; margin-right: auto; }
  .cta-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 14px 28px; border-radius: 5px; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 14px 28px; border-radius: 5px; border: 2px solid rgba(255,255,255,0.35); font-weight: 600; text-decoration: none; }
</style>
