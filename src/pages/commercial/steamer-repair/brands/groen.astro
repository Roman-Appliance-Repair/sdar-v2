---
// Wave 22a — Groen steamer brand page. Ali Group ownership. (Sister to /kettle-repair/brands/groen.astro)
import Layout from '../../../../layouts/Layout.astro';
import CommercialHero from '../../../../components/CommercialHero.astro';
import { MAIN_PHONE } from '../../../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/commercial/steamer-repair/brands/groen/";

const title = "Groen Commercial Steamer Repair LA | HyperSteam, ConvectionSteamer, Smart-Steam | $120";
const description = `Groen commercial steamer repair. LA same-day. HyperSteam pressureless, ConvectionSteamer, Smart-Steam, SSB-series. Ali Group brand. $120 commercial. ${phone}.`;

const faqs = [
  { q: "Groen vs Cleveland Range for steamer service?", a: "Both Ali Group brands with overlap. Groen specializes in compact and convection steamers (HyperSteam, ConvectionSteamer countertop and floor models, SSB) plus the Smart-Steam programmable line. Cleveland Range covers full-size pressure and pressureless steamers (CSE, OEB, KGL boiler-based). Same parent company, same parts network, similar service patterns. We service both lines with the same diagnostic baseline." },
  { q: "HyperSteam pressureless. Different from boiler steamers?", a: "Yes, fundamentally. HyperSteam uses direct steam injection without a separate boiler — water injected onto a heating element, vapor produced on demand. Faster startup (under 90 seconds vs 8-15 minutes for boiler steamers), lower maintenance (no boiler scaling, no blowdown valve service), but tighter water-quality requirements. LA hard-water operations using HyperSteam need annual descaling on the heating element and steam exit ports. Failure pattern: heating element burnout year 5-7, $480-720 replacement; steam exit valve scaling year 2-4 LA hard water, $120-220 PM." },
  { q: "Smart-Steam programmable controls. Common failures?", a: "Year 6-8 typical control board, $580-880 replacement. Smart-Steam adds programmable cook cycles for batch operations (batch overnight cook, breakfast steam, lunch reheat). Operators sometimes mis-program the controls; about 20 percent of Smart-Steam calls resolve at programming verification, no parts replacement. We carry programming guides on the truck." },
  { q: "Boiler-based vs pressureless steamer service patterns?", a: "Boiler-based (Cleveland Range CSE, OEB; older Groen) accumulates scaling on boiler heating elements, requires periodic blowdown service, has more components (boiler, water-feed valve, blowdown valve, low-water cutoff). Pressureless (Groen HyperSteam, newer Cleveland Range Convotherm) is mechanically simpler, fewer components but tighter water-quality dependency. We service both architectures." },
  { q: "Annual descaling for LA operations?", a: "Strongly recommended for San Fernando Valley, Pasadena, Inland Empire (high TDS water). Annual descaling PM ($120-260) prevents scaling damage on heating elements (extends element life year 7-10 vs year 4-6 without PM) and steam exit valves. Coastal LA (Santa Monica, MdR) sees softer water; biennial PM acceptable." },
  { q: "Health Department food-safety compliance for steamers?", a: "Steamers must reach 165°F+ on cooked product (CA Retail Food Code). Calibration drift can cause undercooking. Diagnostic on every steamer call includes calibrated thermometer verification. We document service for HD compliance file." },
  { q: "What's your warranty?", a: "90 days SDAR labor and parts. Groen component warranties processed separately through Ali Group authorized service network. BHGS #A49573, BBB A+, EPA 608 Universal #1346255700410." },
];

const brandSchema = {
  "@context": "https://schema.org", "@type": "Brand", "@id": canonical + "#brand",
  "name": "Groen", "url": "https://www.groen.com",
  "description": "Groen manufactures commercial steamers and kettles. Specialty in HyperSteam pressureless steamers, ConvectionSteamer, Smart-Steam programmable. Ali Group brand.",
  "parentOrganization": { "@type": "Organization", "name": "Ali Group" },
};

const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair", "url": canonical, "telephone": phone, "priceRange": "$$",
    "openingHoursSpecification": [{ "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "08:00", "closes": "20:00" }],
    "areaServed": [{ "@type": "AdministrativeArea", "name": "Los Angeles County" },{ "@type": "AdministrativeArea", "name": "Orange County" },{ "@type": "AdministrativeArea", "name": "Ventura County" },{ "@type": "AdministrativeArea", "name": "San Bernardino County" },{ "@type": "AdministrativeArea", "name": "Riverside County" }],
  },
  { "@context": "https://schema.org", "@type": "Service", "@id": canonical + "#service",
    "serviceType": "Groen Commercial Steamer Repair", "name": "Groen Steamer Repair Service", "url": canonical,
    "description": "Groen commercial steamer repair across all five SoCal counties. HyperSteam pressureless, ConvectionSteamer countertop and floor, Smart-Steam programmable, SSB-series. Heating element burnout (year 5-7 pressureless), steam exit valve scaling (LA hard water year 2-4), control board (year 6-8). Ali Group brand. $120 commercial diagnostic, applied toward repair. BHGS #A49573, EPA 608 Universal certified #1346255700410.",
    "provider": { "@id": canonical + "#business" }, "brand": { "@id": canonical + "#brand" },
    "areaServed": [{ "@type": "AdministrativeArea", "name": "Los Angeles County" },{ "@type": "AdministrativeArea", "name": "Orange County" },{ "@type": "AdministrativeArea", "name": "Ventura County" },{ "@type": "AdministrativeArea", "name": "San Bernardino County" },{ "@type": "AdministrativeArea", "name": "Riverside County" }],
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "120.00", "priceCurrency": "USD", "description": "Commercial diagnostic fee, applied toward repair" } },
  },
  brandSchema,
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Commercial", "item": "https://samedayappliance.repair/commercial/" },
      { "@type": "ListItem", "position": 3, "name": "Steamer Repair", "item": "https://samedayappliance.repair/commercial/steamer-repair/" },
      { "@type": "ListItem", "position": 4, "name": "Groen", "item": canonical },
    ],
  },
];
---

<Layout title={title} description={description} canonical={canonical}>
<Fragment slot="head-scripts">
  {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
</Fragment>

<CommercialHero title="Groen Commercial Steamer Repair, Same-Day Across LA"
  subtitle={`HyperSteam pressureless, ConvectionSteamer, Smart-Steam programmable. Ali Group brand. $120 commercial diagnostic. ${phone}`}
  heroImageTitle="Groen Commercial Steamer Repair" showBranches={true} />

<section class="section">
  <div class="container narrow">
    <p class="section-number">Pressureless steamer specialty</p>
    <h2>Groen owns the pressureless steamer market with HyperSteam. Smart-Steam adds programmable batch cooking.</h2>
    <p>Groen is part of the Ali Group portfolio (sister brand to Cleveland Range, Beverage-Air, Champion, Metro). The flagship is <strong>HyperSteam</strong> pressureless technology — direct steam injection without separate boiler, faster startup (under 90 seconds vs 8-15 minutes for boiler steamers), lower mechanical complexity. Smart-Steam adds programmable cook cycles for batch operations.</p>
    <p>We service the full Groen line across LA, Orange, Ventura, San Bernardino, Riverside. HyperSteam compact, ConvectionSteamer countertop and floor models, Smart-Steam programmable, SSB-series boiler-based, plus legacy Groen models still in service at LA hospital and school nutrition operations.</p>
    <p>$120 commercial diagnostic, waived with repair. <strong>BHGS #A49573</strong>. <strong>EPA 608 Universal certified #1346255700410</strong>. BBB A+. Phones answered 24/7. Parent: <a href="/commercial/steamer-repair/">commercial steamer repair</a>. Sister product line: <a href="/commercial/kettle-repair/brands/groen/">Groen kettles</a>.</p>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">Top failure modes</p>
    <h2 class="section-title">What we see most on Groen.</h2>
    <ol class="num-list">
      <li><strong>Heating element burnout (HyperSteam year 5-7).</strong> $480-720 replacement.</li>
      <li><strong>Steam exit valve scaling (LA hard water year 2-4).</strong> $120-220 descaling. Annual PM recommended.</li>
      <li><strong>Smart-Steam control board (year 6-8).</strong> $580-880 replacement.</li>
      <li><strong>Programming verification (~20 percent of Smart-Steam calls).</strong> Operator-side education, no parts.</li>
      <li><strong>Door gasket compression (year 5-8).</strong> $180-280.</li>
      <li><strong>Water inlet valve (year 6-9).</strong> $260-440.</li>
      <li><strong>Boiler heating element (SSB series, year 7-10).</strong> $480-820.</li>
      <li><strong>Low-water cutoff sensor (boiler models).</strong> $260-380.</li>
    </ol>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Pricing</p>
    <h2 class="section-title">Groen steamer repair costs.</h2>
    <table class="price-table">
      <thead><tr><th>Repair</th><th>Typical Cost</th></tr></thead>
      <tbody>
        <tr><td>Diagnostic</td><td>$120, waived with repair</td></tr>
        <tr><td>Heating element (HyperSteam pressureless)</td><td>$480 to $720</td></tr>
        <tr><td>Boiler heating element (SSB)</td><td>$480 to $820</td></tr>
        <tr><td>Steam exit valve descaling</td><td>$120 to $220</td></tr>
        <tr><td>Smart-Steam control board</td><td>$580 to $880</td></tr>
        <tr><td>Door gasket replacement</td><td>$180 to $280</td></tr>
        <tr><td>Water inlet valve</td><td>$260 to $440</td></tr>
        <tr><td>Low-water cutoff sensor (boiler)</td><td>$260 to $380</td></tr>
        <tr><td>Annual PM (descaling + element check)</td><td>$160 to $280</td></tr>
        <tr><td>Warranty</td><td>90 days parts and labor</td></tr>
      </tbody>
    </table>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">FAQ</p>
    <div class="faq-list">{faqs.map(f => (<details class="faq-item"><summary>{f.q}</summary><p>{f.a}</p></details>))}</div>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Related</p>
    <ul class="bullet-list">
      <li><a href="/commercial/steamer-repair/">Steamer repair (parent)</a> · <a href="/commercial/kettle-repair/brands/groen/">Groen kettles</a></li>
      <li><a href="/commercial/steamer-repair/brands/cleveland-range/">Cleveland Range</a> · <a href="/commercial/steamer-repair/brands/market-forge/">Market Forge</a> · <a href="/commercial/steamer-repair/brands/accutemp/">AccuTemp</a> · <a href="/commercial/steamer-repair/brands/vulcan/">Vulcan</a></li>
      <li><a href="/commercial/steamer-repair/water-issues/">Water issues</a> · <a href="/commercial/steamer-repair/door-seal-issues/">Door seal</a> · <a href="/commercial/steamer-repair/not-steaming/">Not steaming</a> · <a href="/commercial/steamer-repair/scale-buildup/">Scale buildup</a></li>
    </ul>
  </div>
</section>

<section class="bottom-cta">
  <div class="container">
    <h2>Groen steamer down? Same-day priority.</h2>
    <p>HyperSteam, ConvectionSteamer, Smart-Steam across LA, OC, Ventura. $120 commercial. BHGS #A49573, EPA 608 Universal #1346255700410.</p>
    <div class="cta-row"><a href={phoneHref} class="btn-primary">☎ Call {phone}</a><a href="/contact/" class="btn-secondary">Book Online</a></div>
  </div>
</section>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .section { padding: 72px 24px; }
  .section-gray { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; }
  .container.narrow { max-width: 820px; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  .section h2 { font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 800; margin: 0 0 18px; color: var(--text); line-height: 1.2; }
  .section p { font-size: 1rem; line-height: 1.75; margin: 0 0 16px; color: var(--text); }
  .section a { color: var(--red); font-weight: 600; text-decoration: none; }
  .section a:hover { text-decoration: underline; }
  .num-list { padding-left: 22px; margin: 14px 0 0; }
  .num-list li { font-size: 0.98rem; line-height: 1.7; color: var(--text); margin-bottom: 10px; }
  .bullet-list { padding-left: 22px; margin: 14px 0 18px; }
  .bullet-list li { font-size: 1rem; line-height: 1.65; color: var(--text); margin-bottom: 6px; }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 22px; background: #fff; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
  .price-table th, .price-table td { padding: 12px 16px; text-align: left; border-bottom: 1px solid var(--border); font-size: 0.95rem; }
  .price-table th { background: var(--gray); font-weight: 700; color: var(--text); }
  .price-table tr:last-child td { border-bottom: none; }
  .faq-list { margin-top: 24px; }
  .faq-item { background: #fff; border: 1px solid var(--border); border-radius: 6px; padding: 18px 22px; margin-bottom: 12px; }
  .faq-item summary { font-weight: 700; cursor: pointer; font-size: 1rem; color: var(--text); list-style: none; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::before { content: "+ "; color: var(--red); font-weight: 800; margin-right: 6px; }
  .faq-item[open] summary::before { content: "− "; }
  .faq-item p { font-size: 0.95rem; color: var(--text); line-height: 1.75; margin: 14px 0 0; }
  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { color: #fff; margin: 0 0 14px; font-size: 1.7rem; }
  .bottom-cta p { color: #c9c9c9; margin: 0 0 26px; max-width: 720px; margin-left: auto; margin-right: auto; }
  .cta-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 14px 28px; border-radius: 5px; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 14px 28px; border-radius: 5px; border: 2px solid rgba(255,255,255,0.35); font-weight: 600; text-decoration: none; }
</style>
