---
// Wave 22a — Market Forge steamer brand page. Welbilt ownership.
import Layout from '../../../../layouts/Layout.astro';
import CommercialHero from '../../../../components/CommercialHero.astro';
import { MAIN_PHONE } from '../../../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/commercial/steamer-repair/brands/market-forge/";

const title = "Market Forge Steamer Repair LA | M24, M36, ETP, EnergyMizer | $120 Commercial";
const description = `Market Forge commercial steamer repair. LA same-day. M24, M36, ETP electric, EnergyMizer pressureless. Welbilt brand since 1893. $120 commercial. ${phone}.`;

const faqs = [
  { q: "Market Forge positioning vs Cleveland Range?", a: "Both Welbilt brands now (Cleveland Range acquired by Welbilt; Market Forge has been Welbilt for years). Market Forge specializes in countertop and convection steamers — M24, M36, ETP electric line. Cleveland Range covers full-size pressure steamers. Same parent company, similar parts logistics through Welbilt distribution. Service patterns overlap heavily." },
  { q: "EnergyMizer pressureless steamer service?", a: "EnergyMizer is Market Forge's pressureless line, similar architecture to Groen HyperSteam. Faster startup, simpler mechanically. LA hard-water descaling annual PM ($120-260). Heating element year 5-7 ($480-720). Steam exit valve scaling year 2-4 ($120-220)." },
  { q: "Heritage of Market Forge — does that matter for parts?", a: "Founded 1893 Everett Massachusetts. Brand has gone through several ownership transitions, currently Welbilt. Parts availability is good through Welbilt distribution; legacy Market Forge models from earlier ownership eras (pre-2000) sometimes need parts via specialty distributors. We service most pre-2000 Market Forge equipment but parts logistics on year 25+ legacy units may add 3-5 day delays." },
  { q: "ETP electric steamer common failures?", a: "ETP electric line uses resistance heating elements rather than gas burner — common at California operations preferring all-electric kitchens. Failure pattern: heating element burnout year 6-8 ($480-680), thermostat year 6-9 ($260-440), control board year 8-11 ($480-720). About 60 percent of ETP calls resolve at element or thermostat." },
  { q: "Annual descaling for LA operations?", a: "Recommended for high TDS water areas (San Fernando Valley, Pasadena, Inland Empire). Without PM, scaling damages heating elements faster (year 4-6 element life vs year 7-10 with PM)." },
  { q: "Health Department compliance for steamers?", a: "Steamers must reach 165°F+ on cooked product (CA Retail Food Code). Calibration drift can cause undercooking violations. We document service for HD compliance file with calibrated thermometer verification." },
  { q: "What's your warranty?", a: "90 days SDAR labor and parts. Market Forge component warranties processed through Welbilt authorized service network. BHGS #A49573, BBB A+, EPA 608 Universal #1346255700410." }
];

const brandSchema = {
  "@context": "https://schema.org", "@type": "Brand", "@id": canonical + "#brand",
  "name": "Market Forge", "url": "https://www.mfii.com",
  "description": "Market Forge manufactures commercial steamers. Founded 1893 Everett Massachusetts. Welbilt ownership.",
  "foundingDate": "1893", "foundingLocation": { "@type": "Place", "name": "Everett, Massachusetts" },
  "parentOrganization": { "@type": "Organization", "name": "Welbilt" }
};

const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair", "url": canonical, "telephone": phone, "priceRange": "$$",
    "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "08:00", "closes": "20:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "00:00", "closes": "00:00" }
      ],
    "areaServed": [{ "@type": "AdministrativeArea", "name": "Los Angeles County" },{ "@type": "AdministrativeArea", "name": "Orange County" },{ "@type": "AdministrativeArea", "name": "Ventura County" },{ "@type": "AdministrativeArea", "name": "San Bernardino County" },{ "@type": "AdministrativeArea", "name": "Riverside County" }]
  },
  { "@context": "https://schema.org", "@type": "Service", "@id": canonical + "#service",
    "serviceType": "Market Forge Steamer Repair", "name": "Market Forge Steamer Repair Service", "url": canonical,
    "description": "Market Forge commercial steamer repair across all five SoCal counties. M24, M36 countertop, ETP electric line, EnergyMizer pressureless. Heating element burnout (year 6-8 ETP, year 5-7 EnergyMizer), thermostat drift, scale buildup (LA hard water year 2-4 PM), control board. Welbilt brand. $120 commercial diagnostic, applied toward repair. BHGS #A49573, EPA 608 Universal certified #1346255700410.",
    "provider": { "@id": canonical + "#business" }, "brand": { "@id": canonical + "#brand" },
    "areaServed": [{ "@type": "AdministrativeArea", "name": "Los Angeles County" },{ "@type": "AdministrativeArea", "name": "Orange County" },{ "@type": "AdministrativeArea", "name": "Ventura County" },{ "@type": "AdministrativeArea", "name": "San Bernardino County" },{ "@type": "AdministrativeArea", "name": "Riverside County" }],
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "120.00", "priceCurrency": "USD", "description": "Commercial diagnostic fee, applied toward repair" } }
  },
  brandSchema,
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Commercial", "item": "https://samedayappliance.repair/commercial/" },
      { "@type": "ListItem", "position": 3, "name": "Steamer Repair", "item": "https://samedayappliance.repair/commercial/steamer-repair/" },
      { "@type": "ListItem", "position": 4, "name": "Market Forge", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>
<Fragment slot="head-scripts">
  {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
</Fragment>

<CommercialHero title="Market Forge Commercial Steamer Repair, Same-Day Across LA"
  subtitle={`M24, M36 countertop, ETP electric, EnergyMizer pressureless. Welbilt brand since 1893. $120 commercial diagnostic. ${phone}`}
  heroImageTitle="Market Forge Steamer Repair" showBranches={true} />

<section class="section">
  <div class="container narrow">
    <p class="section-number">Welbilt steamer specialty</p>
    <h2>Market Forge brings 130+ years of countertop and convection steamer manufacturing depth.</h2>
    <p>Market Forge was founded 1893 in Everett Massachusetts and is currently part of the Welbilt portfolio (sister brands include Cleveland Range, Manitowoc, Convotherm, Frymaster). The product specialty is countertop and convection steamers: <strong>M24, M36</strong> countertop, <strong>ETP</strong> electric line, <strong>EnergyMizer</strong> pressureless. Common LA installs at restaurants, hospital cafeterias, school nutrition operations, hotel banquet kitchens.</p>
    <p>$120 commercial diagnostic, waived with repair. <strong>BHGS #A49573</strong>. <strong>EPA 608 Universal certified #1346255700410</strong>. BBB A+. Phones answered 24/7. Parent: <a href="/commercial/steamer-repair/">commercial steamer repair</a>.</p>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">Top failure modes</p>
    <ol class="num-list">
      <li><strong>Heating element burnout (ETP year 6-8, EnergyMizer year 5-7).</strong> $480-720.</li>
      <li><strong>Steam exit valve scaling (LA hard water year 2-4).</strong> $120-220 descaling.</li>
      <li><strong>Thermostat drift (year 6-9).</strong> $260-440.</li>
      <li><strong>Control board (year 8-11).</strong> $480-720.</li>
      <li><strong>Door gasket compression (year 5-8).</strong> $180-280.</li>
      <li><strong>Water inlet valve (year 6-9).</strong> $260-440.</li>
      <li><strong>Legacy parts logistics (pre-2000 models).</strong> 3-5 day delays via specialty distributors.</li>
    </ol>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Pricing</p>
    <table class="price-table">
      <thead><tr><th>Repair</th><th>Typical Cost</th></tr></thead>
      <tbody>
        <tr><td>Diagnostic</td><td>$120, waived with repair</td></tr>
        <tr><td>Heating element (ETP electric)</td><td>$480 to $680</td></tr>
        <tr><td>Heating element (EnergyMizer pressureless)</td><td>$480 to $720</td></tr>
        <tr><td>Steam exit valve descaling</td><td>$120 to $220</td></tr>
        <tr><td>Thermostat replacement</td><td>$260 to $440</td></tr>
        <tr><td>Control board replacement</td><td>$480 to $720</td></tr>
        <tr><td>Door gasket replacement</td><td>$180 to $280</td></tr>
        <tr><td>Annual descaling PM</td><td>$120 to $260</td></tr>
        <tr><td>Warranty</td><td>90 days parts and labor</td></tr>
      </tbody>
    </table>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">FAQ</p>
    <div class="faq-list">{faqs.map(f => (<details class="faq-item"><summary>{f.q}</summary><p>{f.a}</p></details>))}</div>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Related</p>
    <ul class="bullet-list">
      <li><a href="/commercial/steamer-repair/">Steamer repair (parent)</a></li>
      <li><a href="/commercial/steamer-repair/brands/cleveland-range/">Cleveland Range</a> · <a href="/commercial/steamer-repair/brands/groen/">Groen</a> · <a href="/commercial/steamer-repair/brands/accutemp/">AccuTemp</a> · <a href="/commercial/steamer-repair/brands/vulcan/">Vulcan</a></li>
      <li><a href="/commercial/steamer-repair/water-issues/">Water issues</a> · <a href="/commercial/steamer-repair/door-seal-issues/">Door seal</a> · <a href="/commercial/steamer-repair/not-steaming/">Not steaming</a></li>
    </ul>
  </div>
</section>

<section class="bottom-cta">
  <div class="container">
    <h2>Market Forge steamer down? Same-day priority.</h2>
    <p>M24, M36, ETP, EnergyMizer across LA, OC, Ventura. $120 commercial. BHGS #A49573, EPA 608 Universal #1346255700410.</p>
    <div class="cta-row"><a href={phoneHref} class="btn-primary">☎ Call {phone}</a><a href="/contact/" class="btn-secondary">Book Online</a></div>
  </div>
</section>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .section { padding: 72px 24px; } .section-gray { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; } .container.narrow { max-width: 820px; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  .section h2 { font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 800; margin: 0 0 18px; color: var(--text); line-height: 1.2; }
  .section p { font-size: 1rem; line-height: 1.75; margin: 0 0 16px; color: var(--text); }
  .section a { color: var(--red); font-weight: 600; text-decoration: none; } .section a:hover { text-decoration: underline; }
  .num-list { padding-left: 22px; margin: 14px 0 0; } .num-list li { font-size: 0.98rem; line-height: 1.7; color: var(--text); margin-bottom: 10px; }
  .bullet-list { padding-left: 22px; margin: 14px 0 18px; } .bullet-list li { font-size: 1rem; line-height: 1.65; color: var(--text); margin-bottom: 6px; }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 22px; background: #fff; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
  .price-table th, .price-table td { padding: 12px 16px; text-align: left; border-bottom: 1px solid var(--border); font-size: 0.95rem; }
  .price-table th { background: var(--gray); font-weight: 700; color: var(--text); } .price-table tr:last-child td { border-bottom: none; }
  .faq-list { margin-top: 24px; } .faq-item { background: #fff; border: 1px solid var(--border); border-radius: 6px; padding: 18px 22px; margin-bottom: 12px; }
  .faq-item summary { font-weight: 700; cursor: pointer; font-size: 1rem; color: var(--text); list-style: none; }
  .faq-item summary::-webkit-details-marker { display: none; } .faq-item summary::before { content: "+ "; color: var(--red); font-weight: 800; margin-right: 6px; } .faq-item[open] summary::before { content: "− "; }
  .faq-item p { font-size: 0.95rem; color: var(--text); line-height: 1.75; margin: 14px 0 0; }
  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { color: #fff; margin: 0 0 14px; font-size: 1.7rem; } .bottom-cta p { color: #c9c9c9; margin: 0 0 26px; max-width: 720px; margin-left: auto; margin-right: auto; }
  .cta-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 14px 28px; border-radius: 5px; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 14px 28px; border-radius: 5px; border: 2px solid rgba(255,255,255,0.35); font-weight: 600; text-decoration: none; }
</style>
