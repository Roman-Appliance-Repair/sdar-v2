// src/pages/commercial/charbroiler-repair/grease-trap-issues.astro
// Wave 13 — Charbroiler grease trap and drain issues failure-mode sub-service.
// Grease pan overflow, drain clog, trap door mechanism, fire suppression code.
import Layout from '../../../layouts/Layout.astro';
import CommercialHero from '../../../components/CommercialHero.astro';
import { MAIN_PHONE } from '../../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/commercial/charbroiler-repair/grease-trap-issues/";

const title = "Charbroiler Grease Trap Issues LA | Pan Overflow, Drain Clog, Fire Code | $120";
const description = `Commercial charbroiler grease pan overflow or drain clog? LA same-day dispatch. Vulcan, Imperial, Bakers Pride. BHGS #A49573. $120 commercial dx.`;

const faqs = [
  {
    q: "Our grease pan overflows during dinner rush. Is this a repair issue?",
    a: "Usually a scheduling issue, not an appliance failure. Commercial charbroiler grease pans are sized to handle a typical service window (4 to 6 hours of continuous cooking) before needing emptying. If your pan is overflowing during dinner rush, the most common cause is the pan wasn't emptied at the appropriate point in the service cycle. We see this often: operators empty the pan only at end of service, miss that the pan was 80 percent full at the start of the shift, then dinner rush fills it the rest of the way mid-service. Establish a mid-service pan check protocol. If the pan is still overflowing on a fresh-empty start, then the issue is real (drain channel clogged sending grease out the wrong path) and we diagnose at $120."
  },
  {
    q: "Grease drain channel clogged, won't drain into pan. Repair?",
    a: "Yes, real repair issue. Grease drain channels under the cooking surface accumulate carbon deposits and grease solidification over time, especially on units running 8 to 14 hours daily restaurant duty. Channel clog redirects grease overflow to the wrong place (firebox, gas valve area, or cooking surface), creating fire risk and combustion problems. Cleaning service runs $180 to $340 depending on access and severity. On year 5+ units we sometimes find heat-cracked drain channel walls that need spot welding or section replacement, $260 to $480 additional repair."
  },
  {
    q: "Trap door mechanism on auto-clean models. What goes wrong?",
    a: "Premium commercial charbroilers (specific Wolf Range Commercial models, premium Garland MGM Master, premium MagiKitch'n) include auto-clean grease management with a motorized trap door that opens to dump accumulated grease into a remote collection tank between cooking cycles. Failure modes: motor burnout (year 5-8, $260-440 motor replacement), trap door seal failure (heat-warped or grease-coated, $180-280 reseal service), control board failure for the auto-clean cycle ($480-680 replacement). The auto-clean systems are nice when working but expensive to repair. Manual systems are simpler, cheaper to maintain, and most commercial restaurants we serve run manual."
  },
  {
    q: "Health Department flagged us on grease management. What do we need?",
    a: "LA County Department of Public Health requires documented grease management protocols on commercial cooking equipment. A flagged inspection typically requires (1) cleaning service of the grease management components (drain channels, trap door mechanism, pan), (2) documented cleaning schedule going forward, (3) possible follow-up inspection. We document our service work for the customer's HD compliance file: scope of cleaning, before/after photos, parts replaced, sanitization-grade cleaning verification. Most LA County HDs accept our documentation directly into the compliance file."
  },
  {
    q: "LA Fire Marshal requirements. How does grease management connect to fire code?",
    a: "California Fire Code (CFC) Chapter 6 plus LA County Fire Department local amendments require commercial cooking equipment grease management to be functional and current as part of the Ansul or equivalent fire suppression system compliance. A non-functional grease management system creates fire risk that voids the fire suppression certification, which voids your CO (certificate of occupancy) for the kitchen. We've seen restaurants get red-tagged because the grease management on a charbroiler was failing and Fire Marshal inspection caught it. Annual PM with documented grease management service is the cheap fix. Reactive emergency repair when Fire Marshal red-tags you is the expensive one."
  },
  {
    q: "Annual PM contract for grease management. What's included?",
    a: "Standard restaurant PM contract grease-management coverage includes (1) quarterly drain channel cleaning, (2) trap door mechanism service every 6 months on auto-clean units, (3) annual grease pan replacement if needed (year 5+ pans tend to develop corrosion or warping), (4) documented service file for HD and Fire Marshal compliance. Pricing depends on unit count and complexity; a 6-burner Vulcan VCCB-36 with manual grease management runs $480 to $680 annual; a Wolf Range Commercial auto-clean runs $880 to $1,400 annual due to mechanical complexity. Operations with 4+ pieces of grease-producing equipment (charbroiler + range + griddle + grill) typically save 30-40 percent on bundled multi-equipment PM vs single-unit pricing."
  },
  {
    q: "What's your warranty?",
    a: "90 days SDAR labor and parts on every repair. Brand component warranties (Vulcan ITW, Imperial, Garland Welbilt, MagiKitch'n Middleby, Wolf Range ITW, Bakers Pride Middleby) processed separately. PM contract terms run annual with documented service file. BHGS #A49573, BBB A+ accredited, EPA 608 Universal certified #1346255700410."
  }
];

const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair", "url": canonical, "telephone": phone, "priceRange": "$$",
    "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "08:00", "closes": "20:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "00:00", "closes": "00:00" }
      ],
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },{ "@type": "AdministrativeArea", "name": "Orange County" },{ "@type": "AdministrativeArea", "name": "Ventura County" },{ "@type": "AdministrativeArea", "name": "San Bernardino County" },{ "@type": "AdministrativeArea", "name": "Riverside County" }
    ]
  },
  { "@context": "https://schema.org", "@type": "Service", "@id": canonical + "#service",
    "serviceType": "Commercial Charbroiler Grease Trap Repair", "name": "Charbroiler Grease Management Diagnostic and Service", "url": canonical,
    "description": "Commercial charbroiler grease trap and drain service across all five SoCal counties. Grease pan overflow scheduling, drain channel clogs (carbon deposits), trap door mechanism repair (auto-clean models Wolf Range Commercial, premium Garland MGM, premium MagiKitch'n), grease management code compliance (LA County DPH, LA Fire Marshal CFC Chapter 6). Annual PM contracts for documented service files. $120 commercial diagnostic, applied toward repair. BHGS #A49573, EPA 608 Universal certified #1346255700410.",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },{ "@type": "AdministrativeArea", "name": "Orange County" },{ "@type": "AdministrativeArea", "name": "Ventura County" },{ "@type": "AdministrativeArea", "name": "San Bernardino County" },{ "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "120.00", "priceCurrency": "USD", "description": "Commercial diagnostic fee, applied toward repair" } }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Commercial", "item": "https://samedayappliance.repair/commercial/" },
      { "@type": "ListItem", "position": 3, "name": "Charbroiler Repair", "item": "https://samedayappliance.repair/commercial/charbroiler-repair/" },
      { "@type": "ListItem", "position": 4, "name": "Grease Trap Issues", "item": canonical }
    ]
  }
];
