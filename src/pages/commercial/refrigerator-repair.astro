---
// src/pages/commercial/refrigerator-repair.astro
// Phase 3 Tier 2 (2026-04-28) — neutral multi-county hub.
// title/H1/description/phone neutralized to 5 SoCal counties; Service schema with 5-county
// areaServed (was LocalBusiness with 8 LA neighborhoods); aggregateRating absent (already clean);
// Recent Repairs distributed 2 LA + 1 OC + 1 Ventura; Cities-served block → 5-county Counties block;
// LA-neighborhoods restaurant-density section preserved + extended to OC/Ventura/IE clusters.

import Layout from '../../layouts/Layout.astro';
import CommercialHero from '../../components/CommercialHero.astro';
import { MAIN_PHONE } from '../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;

const title = "Commercial Refrigerator Repair — Same-Day Service Across Southern California";
const description = "Same-day commercial refrigerator repair across LA, Orange, Ventura, San Bernardino & Riverside counties. EPA 608 + C-38 certified. BHGS #A49573, $120 dx.";
const canonical = "https://samedayappliance.repair/commercial/refrigerator-repair/";
---

<Layout title={title} description={description}>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Commercial Refrigerator Repair",
  "name": "Commercial Refrigerator Repair — Same Day Appliance Repair",
  "url": canonical,
  "description": "Same-day commercial refrigerator repair across Los Angeles, Orange, Ventura, San Bernardino, and Riverside counties. Reach-in coolers, display cases, prep tables, back-bar — True, Hoshizaki, Turbo Air, Beverage-Air. EPA 608 + California C-38 licensed.",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Same Day Appliance Repair",
    "url": "https://samedayappliance.repair/",
    "telephone": phone,
    "priceRange": "$$",
    "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "08:00", "closes": "20:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "00:00", "closes": "00:00" }
      ]
  },
  "areaServed": [
    { "@type": "AdministrativeArea", "name": "Los Angeles County" },
    { "@type": "AdministrativeArea", "name": "Orange County" },
    { "@type": "AdministrativeArea", "name": "Ventura County" },
    { "@type": "AdministrativeArea", "name": "San Bernardino County" },
    { "@type": "AdministrativeArea", "name": "Riverside County" }
  ],
  "offers": {
    "@type": "Offer",
    "priceSpecification": {
      "@type": "PriceSpecification",
      "price": "120.00",
      "priceCurrency": "USD",
      "description": "Commercial diagnostic fee, applied toward repair"
    }
  }
})} />

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How much does commercial refrigerator repair cost?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Our commercial diagnostic fee is $120, applied toward the repair once you approve the work. Most commercial refrigerator repairs run between $180 and $550. A door gasket, evaporator fan motor, thermostat, or condenser coil cleaning is toward the lower end. Compressor replacement or sealed system work runs higher. We provide a full written estimate before any work begins."
      }
    },
    {
      "@type": "Question",
      "name": "Which areas of Southern California do you cover?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "All five SoCal counties: Los Angeles, Orange, Ventura, San Bernardino, and Riverside. We dispatch from 8 service territories — West Hollywood (HQ), Los Angeles, Beverly Hills, Pasadena, Thousand Oaks, Irvine, Rancho Cucamonga, and Temecula — so the technician on your commercial call is coming from the closest one. Restaurant, grocery, and retail commercial calls get same-day priority across all 5 counties."
      }
    },
    {
      "@type": "Question",
      "name": "My commercial reach-in refrigerator is not cooling — what should I do?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Check door gaskets first — a compromised seal on a high-traffic commercial door is the most common and most overlooked cause of temperature drift. If gaskets are intact, the most likely causes are: frosted evaporator coils from a failed defrost system, a refrigerant leak, or a failing condenser fan. If product temperature is approaching 41°F, move your most temperature-sensitive inventory and call us immediately. We treat commercial refrigerator calls as priority same-day dispatches."
      }
    },
    {
      "@type": "Question",
      "name": "Why do commercial refrigerators fail more often than residential fridges?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Commercial refrigerators run 24 hours a day, 7 days a week — unlike a residential unit that cycles off and rests. In a busy restaurant or bar, the door may be opened 50–100 times per hour. Every door open admits warm, humid air that the refrigeration system must reject. The compressor, condenser fan, evaporator fan, and door gaskets all accumulate wear at a rate 3–5x faster than residential equipment. This is why professional maintenance every 6 months is standard practice in commercial kitchens, not an upsell."
      }
    },
    {
      "@type": "Question",
      "name": "Do you repair display cases and open-air merchandisers?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Open display cases, glass door merchandisers, deli cases, and meat cases are a significant part of what we repair for SoCal grocery stores and specialty food retailers. These units have unique challenges: they're open to the ambient environment, meaning condenser coils clog faster in SoCal's dusty conditions (especially Inland Empire) and any refrigerant loss is quickly evident in product quality. We service Hussmann, Tyler, Hill Phoenix, and other display case brands common in SoCal retail environments."
      }
    },
    {
      "@type": "Question",
      "name": "How often should commercial refrigerators be serviced?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Every 6 months minimum for equipment in active commercial use. High-traffic operations — busy restaurants, bars, ghost kitchens — benefit from quarterly service. Each visit includes condenser coil cleaning (the single most important commercial refrigeration maintenance task), door gasket inspection, evaporator check, refrigerant level verification, and temperature calibration. Regular service prevents the sudden failures that happen at the worst possible times."
      }
    },
    {
      "@type": "Question",
      "name": "When does it make sense to repair vs replace a commercial refrigerator?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Commercial refrigerators last 10–15 years with proper maintenance. Under 8 years old, repair almost always makes sense unless the compressor has failed on a poorly maintained system. Over 12 years and the failure is the compressor or sealed system, we'll give you an honest remaining-life assessment — replacement on a unit pushing 15 years often makes more economic sense given installation costs. We tell you straight which side of that line your unit falls on."
      }
    },
    {
      "@type": "Question",
      "name": "Do you repair True, Hoshizaki, and Turbo Air commercial refrigerators?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. True, Hoshizaki, Turbo Air, Beverage-Air, Traulsen, and Victory are the brands we service most across SoCal commercial markets. We carry OEM parts for True specifically and source parts for the others through same-day commercial parts distributors. All refrigerant work is performed by EPA 608 Universal certified (#1346255700410) technicians."
      }
    },
    {
      "@type": "Question",
      "name": "What does the 90-day warranty cover on commercial refrigerator repairs?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Every commercial refrigerator repair we complete carries a 90-day warranty on both parts and labor. For sealed system repairs (compressor, condenser, evaporator), we extend to 1 year. If the same issue returns within the warranty window, we come back at no charge. That's in writing before we leave."
      }
    }
  ]
})} />

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .hero { background: var(--black); color: #fff; padding: 80px 24px 64px; text-align: center; }
  .hero-eyebrow { display: inline-block; background: var(--red); color: #fff; font-size: 0.78rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 5px 14px; border-radius: 3px; margin-bottom: 20px; }
  .hero h1 { font-size: clamp(1.9rem, 4vw, 2.9rem); font-weight: 800; line-height: 1.15; margin: 0 0 20px; max-width: 860px; margin-left: auto; margin-right: auto; }
  .hero-sub { font-size: 1.1rem; color: #ccc; max-width: 640px; margin: 0 auto 32px; line-height: 1.6; }
  .cta-row { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 16px 34px; border-radius: 5px; font-size: 1rem; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 16px 34px; border-radius: 5px; font-size: 1rem; font-weight: 600; text-decoration: none; border: 2px solid rgba(255,255,255,0.35); }
  .hero-meta { margin-top: 28px; color: #aaa; font-size: 0.9rem; display: flex; gap: 24px; justify-content: center; flex-wrap: wrap; }
  .trust-bar { background: var(--red); padding: 18px 24px; }
  .trust-inner { max-width: 1100px; margin: 0 auto; display: flex; justify-content: center; flex-wrap: wrap; gap: 10px 32px; }
  .trust-item { color: #fff; font-size: 0.88rem; font-weight: 600; }
  .section { padding: 64px 24px; }
  .section-gray { background: var(--gray); }
  .section-black { background: var(--black); color: #fff; }
  .container { max-width: 1100px; margin: 0 auto; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  h2.section-title { font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 800; margin: 0 0 16px; line-height: 1.2; }
  .section-black h2.section-title { color: #fff; }
  .lead { font-size: 1.05rem; line-height: 1.75; color: var(--text); max-width: 760px; }
  .section-black .lead { color: #ccc; }
  .intro-grid { display: grid; grid-template-columns: 1fr 320px; gap: 48px; align-items: start; }
  @media (max-width: 768px) { .intro-grid { grid-template-columns: 1fr; } }
  .intro-body p { margin: 0 0 18px; font-size: 1.05rem; line-height: 1.8; color: var(--text); }
  .alert-red { background: #1a0000; border: 1px solid var(--red); border-radius: 8px; padding: 18px 20px; margin-top: 24px; }
  .alert-red .al-label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--red); margin-bottom: 8px; }
  .alert-red p { font-size: 0.93rem; color: #c08080; margin: 0; line-height: 1.65; }
  .sticky-cta { position: sticky; top: 24px; background: var(--black); border-radius: 10px; padding: 28px 24px; color: #fff; text-align: center; }
  .sticky-cta .cta-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: #aaa; margin-bottom: 14px; }
  .sticky-cta .cta-phone { font-size: 1.5rem; font-weight: 800; color: #fff; text-decoration: none; display: block; margin-bottom: 12px; }
  .sticky-cta .btn-cta { display: block; background: var(--red); color: #fff; padding: 14px; border-radius: 5px; font-weight: 700; text-decoration: none; font-size: 0.95rem; margin-bottom: 10px; }
  .sticky-cta .cta-sub { font-size: 0.82rem; color: #888; }
  .cta-divider { border: none; border-top: 1px solid #222; margin: 18px 0; }
  .cta-detail { font-size: 0.85rem; color: #aaa; text-align: left; }
  .cta-detail li { margin-bottom: 6px; list-style: none; padding-left: 18px; position: relative; }
  .cta-detail li::before { content: "✓"; position: absolute; left: 0; color: var(--red); font-weight: 700; }
  /* Unit type grid */
  .type-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(230px, 1fr)); gap: 18px; margin-top: 32px; }
  .type-card { background: #111; border: 1px solid #222; border-radius: 8px; padding: 22px 18px; }
  .type-card .type-badge { display: inline-block; background: var(--red); color: #fff; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; padding: 3px 10px; border-radius: 3px; margin-bottom: 10px; }
  .type-card h3 { font-size: 0.92rem; font-weight: 700; color: #fff; margin: 0 0 8px; }
  .type-card p { font-size: 0.82rem; color: #888; line-height: 1.6; margin: 0 0 8px; }
  .type-card .where { font-size: 0.78rem; color: #555; font-style: italic; }
  /* Problems */
  .problems-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 18px; margin-top: 36px; }
  .problem-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 22px 18px; }
  .problem-card h3 { font-size: 1rem; font-weight: 700; margin: 0 0 10px; color: var(--text); }
  .problem-card p { font-size: 0.9rem; color: var(--muted); line-height: 1.6; margin: 0; }
  /* 24/7 wear spotlight */
  .wear-block { background: #08100a; border: 1px solid #182818; border-radius: 10px; padding: 34px 30px; margin-top: 36px; }
  .wear-block .w-label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: #60c080; margin-bottom: 12px; }
  .wear-block h3 { font-size: 1.2rem; font-weight: 800; color: #fff; margin: 0 0 12px; }
  .wear-block p { font-size: 0.93rem; color: #80a880; line-height: 1.7; margin: 0 0 12px; }
  .w-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(185px, 1fr)); gap: 10px; margin-top: 16px; }
  .w-item { background: #040a06; border: 1px solid #102010; border-radius: 6px; padding: 12px 14px; }
  .w-item strong { display: block; font-size: 0.85rem; color: #80e0a0; margin-bottom: 3px; }
  .w-item span { font-size: 0.8rem; color: #305030; line-height: 1.4; }
  /* LA neighborhoods */
  .neigh-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 14px; margin-top: 28px; }
  .neigh-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 18px 16px; }
  .neigh-card h3 { font-size: 0.9rem; font-weight: 700; margin: 0 0 6px; color: var(--text); }
  .neigh-card p { font-size: 0.82rem; color: var(--muted); line-height: 1.5; margin: 0; }
  /* Brands */
  .brands-grid { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 28px; }
  .brand-chip { background: #fff; border: 1px solid var(--border); border-radius: 4px; padding: 8px 18px; font-size: 0.88rem; font-weight: 600; color: var(--text); }
  .brand-chip.dark { background: #1a1a1a; color: #ddd; border-color: #333; }
  /* Repairs */
  .repairs-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(255px, 1fr)); gap: 22px; margin-top: 36px; }
  .repair-card { background: #111; border: 1px solid #222; border-radius: 8px; padding: 22px 18px; }
  .repair-card .repair-title { font-size: 0.82rem; font-weight: 700; color: #aaa; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 8px; }
  .repair-card h3 { font-size: 0.98rem; font-weight: 700; color: #fff; margin: 0 0 10px; line-height: 1.3; }
  .repair-card p { font-size: 0.87rem; color: #888; line-height: 1.6; margin: 0 0 12px; }
  .repair-card .repair-detail { font-size: 0.78rem; color: #555; border-top: 1px solid #1e1e1e; padding-top: 10px; }
  /* Maintenance */
  .maint-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 14px; margin-top: 28px; }
  .maint-card { background: #111; border: 1px solid #222; border-radius: 8px; padding: 16px; }
  .maint-card h3 { font-size: 0.87rem; font-weight: 700; color: #fff; margin: 0 0 6px; }
  .maint-card p { font-size: 0.8rem; color: #777; line-height: 1.5; margin: 0; }
  /* Pricing */
  .pricing-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(210px, 1fr)); gap: 18px; margin-top: 32px; }
  .price-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 22px 18px; text-align: center; }
  .price-card .price-label { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); margin-bottom: 8px; }
  .price-card .price-amount { font-size: 1.8rem; font-weight: 800; color: var(--text); line-height: 1; margin-bottom: 8px; }
  .price-card .price-desc { font-size: 0.84rem; color: var(--muted); line-height: 1.5; }
  .price-note { margin-top: 18px; font-size: 0.9rem; color: var(--muted); line-height: 1.6; }
  .faq-list { margin-top: 36px; }
  .faq-item { border-bottom: 1px solid var(--border); padding: 20px 0; }
  .faq-item:first-child { border-top: 1px solid var(--border); }
  .faq-item h3 { font-size: 1rem; font-weight: 700; color: var(--text); margin: 0 0 10px; }
  .faq-item p { font-size: 0.95rem; color: var(--muted); line-height: 1.7; margin: 0; }
  .nearby-links { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 24px; }
  .nearby-links a { background: #fff; border: 1px solid var(--border); border-radius: 4px; padding: 8px 16px; font-size: 0.87rem; color: var(--text); text-decoration: none; font-weight: 500; }
  .nearby-links a:hover { border-color: var(--red); color: var(--red); }
  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; margin: 0 0 16px; }
  .bottom-cta p { color: #aaa; margin: 0 0 32px; font-size: 1.05rem; }
</style>

<!-- HERO + TRUST BAR (unified CommercialHero) -->
<CommercialHero
  title="Commercial Refrigerator Repair Across Southern California"
  subtitle="Reach-in coolers, display cases, prep tables, back-bar units — every commercial refrigerator type in SoCal restaurants, bars, grocery stores, ghost kitchens, and food service. Same-day across LA, Orange, Ventura, San Bernardino & Riverside counties. Parts for True, Hoshizaki, and Turbo Air on the van."
  heroImageTitle="Commercial Refrigerator Repair"
/>

<!-- INTRO -->
<section class="section">
  <div class="container">
    <div class="intro-grid">
      <div class="intro-body">
        <p class="section-number">01 — About This Service</p>
        <h2 class="section-title">Commercial refrigerators run 24/7 — they wear out 3–5x faster than residential units and need professional service to match.</h2>

        <p>A residential refrigerator cycles on and off, rests, and sees perhaps 20 door openings per day in a typical household. A commercial reach-in cooler in a busy Koreatown restaurant never rests — it runs continuously, 24 hours a day, with the door opened dozens of times per hour during service. Every door opening admits warm, humid air. The compressor, condenser fan, evaporator fan, and door gaskets accumulate wear at a pace that makes residential equipment maintenance schedules completely inadequate for commercial use.</p>

        <p>This is why we see commercial refrigerator failures across Southern California at a consistent rate regardless of brand or age — the wear is simply faster. A True T-49 in a busy East Hollywood taqueria, a Newport Beach coastal restaurant, a Thousand Oaks family eatery, or a Riverside Inland-Empire restaurant will all need condenser coils cleaned every 3–4 months; the same coils would last a year in a residential unit. A door gasket that lasts 5 years on a home refrigerator lasts 18 months on a commercial unit in high service.</p>

        <p>We carry parts for the brands running most SoCal commercial kitchens: True, Hoshizaki, Turbo Air, and Beverage-Air. For Traulsen, Victory, and Atosa, we source parts same-day through our commercial distributors. All refrigerant work is performed by EPA 608 certified technicians (California C-38 licensed).</p>

        <div class="alert-red">
          <div class="al-label">🌡️ Product Temperature Approaching 41°F?</div>
          <p>Move your most temperature-sensitive inventory to backup cold storage immediately and call <strong>{phone}</strong>. Document the temperature — you may need this for health department records. We dispatch commercial refrigerator calls as same-day priority. Check door gaskets while you wait — a compromised gasket is the most common cause of temperature drift in high-traffic commercial units.</p>
        </div>
      </div>

      <aside class="sticky-cta">
        <div class="cta-label">Commercial Priority Dispatch</div>
        <a href={phoneHref} class="cta-phone">{phone}</a>
        <a href={phoneHref} class="btn-cta">Call Now — Same Day</a>
        <a href="/book" class="btn-cta" style="background:#222; margin-top:-4px;">Schedule Online</a>
        <div class="cta-sub">Mon–Sun 7am–9pm · Commercial calls prioritized</div>
        <hr class="cta-divider" />
        <ul class="cta-detail">
          <li>Commercial diagnostic: $120</li>
          <li>Applied to repair if approved</li>
          <li>EPA 608 + C-38 licensed</li>
          <li>True, Hoshizaki, Turbo Air parts</li>
          <li>90-day warranty (1-yr sealed system)</li>
          <li>Maintenance contracts available</li>
        </ul>
      </aside>
    </div>
  </div>
</section>

<!-- UNIT TYPES -->
<section class="section section-black">
  <div class="container">
    <p class="section-number">02 — Unit Types We Service</p>
    <h2 class="section-title">Every commercial refrigerator configuration in SoCal kitchens and retail</h2>
    <p class="lead">The failure modes, access requirements, and repair approach differ by unit type. We come prepared for the specific equipment at your location.</p>

    <div class="type-grid">
      <div class="type-card">
        <div class="type-badge">Reach-In</div>
        <h3>Reach-In Coolers</h3>
        <p>1–3 door upright units — the most common commercial refrigerator in SoCal restaurants and bars. True and Turbo Air are the most common brands. High-traffic door use accelerates gasket and hinge wear.</p>
        <div class="where">Restaurants · Bars · Cafes · Ghost Kitchens</div>
      </div>
      <div class="type-card">
        <div class="type-badge">Under-Counter</div>
        <h3>Under-Counter &amp; Back-Bar</h3>
        <p>Compact units built into counters or behind bars. Common in beverage stations, prep lines, and bar setups. Condenser location varies — often in tight spaces that restrict airflow and accelerate coil fouling.</p>
        <div class="where">Bars · Coffee Shops · Hotel Bars · Prep Lines</div>
      </div>
      <div class="type-card">
        <div class="type-badge">Display</div>
        <h3>Display Cases &amp; Glass Door Merchandisers</h3>
        <p>Open-front or glass-door display units for retail — beverage coolers, grab-and-go cases, beer coolers. Open to ambient air continuously, which means faster coil fouling and higher refrigeration load.</p>
        <div class="where">Grocery Stores · Convenience Stores · Specialty Food</div>
      </div>
      <div class="type-card">
        <div class="type-badge">Prep Table</div>
        <h3>Refrigerated Prep Tables</h3>
        <p>Sandwich prep tables, salad prep stations, pizza prep coolers — combination work surface and refrigeration. The refrigeration unit and the prep surface share a cabinet. Compressor location under the unit in high-heat kitchen environments.</p>
        <div class="where">Restaurants · Pizzerias · Delis · Sandwich Shops</div>
      </div>
      <div class="type-card">
        <div class="type-badge">Deli / Meat</div>
        <h3>Deli Cases &amp; Meat Cases</h3>
        <p>Specialty display cases for deli meats, cheeses, and fresh protein. Open-top or glass-front. Critical temperature precision for food safety and display quality. Common in SoCal specialty food markets, Korean grocery stores (Koreatown, Garden Grove), and Persian markets (Westwood, Tarzana).</p>
        <div class="where">Koreatown · Garden Grove · Specialty Grocers · Delis</div>
      </div>
      <div class="type-card">
        <div class="type-badge">Keg / Beer</div>
        <h3>Keg Coolers &amp; Draft Beer Systems</h3>
        <p>Walk-in or reach-in keg storage coolers with draft line connections. Temperature precision critical for pour quality and CO2 efficiency. Common in SoCal bar-dense corridors — Los Feliz/Silver Lake/Echo Park in LA, Costa Mesa/Newport craft beer scene in OC, Temecula wine country tasting rooms.</p>
        <div class="where">Bars · Taprooms · Brewpubs · Restaurants</div>
      </div>
    </div>
  </div>
</section>

<!-- PROBLEMS -->
<section class="section section-gray">
  <div class="container">
    <p class="section-number">03 — Common Failures</p>
    <h2 class="section-title">What our technicians diagnose most often in SoCal commercial refrigerators</h2>

    <div class="problems-grid">
      <div class="problem-card">
        <h3>Not Cooling / Temperature Drift</h3>
        <p>Refrigerant leak, frosted evaporator coils from a failed defrost system, dirty condenser coils causing compressor overload, or a door gasket failure admitting warm air faster than the system can reject it. In SoCal's ambient conditions (especially Inland Empire summer heat), degraded condenser performance is often the hidden cause of gradual temperature drift.</p>
      </div>
      <div class="problem-card">
        <h3>Temperature Fluctuation</h3>
        <p>A thermostat or temperature controller that's cycling incorrectly, or a door that's being held open or not sealing consistently. In display cases, temperature fluctuation from inconsistent door sealing is often visible as condensation or frost forming on product near the door edges.</p>
      </div>
      <div class="problem-card">
        <h3>Frost / Ice Buildup on Evaporator</h3>
        <p>Defrost system failure — heater, timer, or thermostat. The evaporator coils frost over progressively until airflow is blocked. In high-humidity environments like open display cases, frost buildup is faster. The unit runs continuously but can't circulate cold air through frozen coils.</p>
      </div>
      <div class="problem-card">
        <h3>Evaporator &amp; Condenser Fan Failure</h3>
        <p>Evaporator fan failure stops air circulation — the back of the unit stays cold while the front warms. Condenser fan failure causes compressor overheating. Both fan motors are consumable parts in high-usage commercial equipment. We carry fan motors for True, Hoshizaki, and Turbo Air on the van.</p>
      </div>
      <div class="problem-card">
        <h3>Door Gasket Wear</h3>
        <p>The most frequently replaced component on high-traffic commercial refrigerators. A gasket that's torn, compressed flat, or has lost elasticity allows warm air infiltration that undermines all other refrigeration performance. On a unit opened 50+ times per hour, gaskets need checking every 6 months.</p>
      </div>
      <div class="problem-card">
        <h3>Water Leaking onto Floor</h3>
        <p>Blocked condensate drain or drain pan overflow. In display cases, excessive condensation from ambient humidity can overwhelm drain capacity. In reach-in coolers, debris accumulation in the drain pan is common in busy kitchen environments. We clear and sanitize drains on every service call.</p>
      </div>
      <div class="problem-card">
        <h3>Compressor Failure</h3>
        <p>The most expensive repair — but not always the diagnosis when temperature fails. We test evaporator function, refrigerant charge, and condenser performance before concluding the compressor is the issue. A significant share of "compressor failures" are actually refrigerant leaks or frosted evaporators that cleared on the same visit.</p>
      </div>
      <div class="problem-card">
        <h3>Lighting / Interior Issues</h3>
        <p>Interior lighting failures in display cases directly impact product visibility and sales. LED board failure on modern units, ballast failure on older fluorescent units. We carry replacement lighting components for the major display case brands common in SoCal retail environments.</p>
      </div>
    </div>
  </div>
</section>

<!-- 24/7 WEAR SPOTLIGHT -->
<section class="section">
  <div class="container">
    <p class="section-number">04 — Why Commercial Equipment Wears Differently</p>
    <h2 class="section-title">24 hours a day, 7 days a week — the math on commercial wear vs. residential</h2>

    <div class="wear-block">
      <div class="w-label">⚙️ Commercial vs. Residential Wear Rate</div>
      <h3>A commercial reach-in in a busy SoCal restaurant ages 3–5x faster than a home refrigerator</h3>
      <p>This isn't a generalization — it's physics and usage math. A home refrigerator runs its compressor approximately 8 hours per day in a stable ambient environment. A commercial reach-in in an East Hollywood restaurant, a Newport Beach coastal kitchen, or a Riverside Inland-Empire taco shop runs its compressor 18–22 hours per day in a 90–105°F kitchen (Inland Empire kitchens push higher), with the door opened 30–50 times per service shift. The thermal load, mechanical stress, and wear accumulation are fundamentally different.</p>
      <p>The practical implication: maintenance schedules, parts replacement intervals, and the useful life of components are all compressed compared to residential equipment. The businesses that call us least often for emergency repairs are the ones running quarterly or bi-annual maintenance — not because they're lucky, but because they're replacing worn gaskets, cleaning coils, and checking refrigerant levels before failures happen.</p>

      <div class="w-grid">
        <div class="w-item"><strong>Compressor runtime</strong><span>8 hrs/day residential vs. 20+ hrs/day commercial — 2.5x more cycles, 2.5x faster wear</span></div>
        <div class="w-item"><strong>Door openings</strong><span>20/day residential vs. 300–500/day commercial — gaskets wear in 18 months vs. 5 years</span></div>
        <div class="w-item"><strong>Condenser fouling</strong><span>Commercial kitchen grease + dust clogs coils 4x faster than residential environment</span></div>
        <div class="w-item"><strong>Ambient kitchen temp</strong><span>90–100°F commercial kitchen vs. 72°F home — compressor works harder every cycle</span></div>
        <div class="w-item"><strong>Maintenance intervals</strong><span>Every 6 months commercial vs. annual residential — because wear rate demands it</span></div>
        <div class="w-item"><strong>Expected unit life</strong><span>10–15 years with proper commercial maintenance vs. 5–8 years without</span></div>
      </div>
    </div>
  </div>
</section>

