---
// src/pages/commercial/refrigeration/prep-table-repair.astro
// 5-niche architecture stub — Refrigerated Prep Table Repair.
import Layout from '../../../layouts/Layout.astro';
import CommercialHero from '../../../components/CommercialHero.astro';
import { MAIN_PHONE } from '../../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;

const title = "Refrigerated Prep Table Repair — Sandwich · Pizza · Mega Top | Same Day Appliance Repair";
const description = `Same-day refrigerated prep table repair across LA, Orange, Ventura, San Bernardino & Riverside counties. True TSSU, Turbo Air, Beverage-Air, Delfield mega-tops. Pan rail temperature compliance, refrigeration circuit. $120 commercial diagnostic. Call ${phone}.`;
const canonical = "https://samedayappliance.repair/commercial/refrigeration/prep-table-repair/";

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Refrigerated Prep Table Repair",
  "name": "Refrigerated Prep Table Repair — Same Day Appliance Repair",
  "url": canonical,
  "description": "Same-day refrigerated prep table repair across all five SoCal counties. Sandwich units, pizza prep, mega-tops, salad bars. True TSSU, Turbo Air, Beverage-Air, Delfield, Randell.",
  "provider": { "@type": "LocalBusiness", "name": "Same Day Appliance Repair", "url": "https://samedayappliance.repair/", "telephone": phone, "priceRange": "$$" },
  "areaServed": [
    { "@type": "AdministrativeArea", "name": "Los Angeles County" },
    { "@type": "AdministrativeArea", "name": "Orange County" },
    { "@type": "AdministrativeArea", "name": "Ventura County" },
    { "@type": "AdministrativeArea", "name": "San Bernardino County" },
    { "@type": "AdministrativeArea", "name": "Riverside County" },
  ],
  "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "120.00", "priceCurrency": "USD", "description": "Commercial diagnostic fee, applied toward repair" } },
};
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <CommercialHero
    title="Refrigerated Prep Table Repair"
    subtitle="Sandwich, pizza, salad bar, mega-top units. True TSSU, Turbo Air, Beverage-Air, Delfield, Randell. Pan rail temperature compliance, refrigeration circuit, drain line. $120 diagnostic across five SoCal counties."
    heroImageTitle="Prep Table Repair"
    showBranches={true}
  />

  <section class="section">
    <div class="container">
      <h2>Refrigerated Prep Table Repair Across Southern California</h2>
      <p>Refrigerated prep tables are the most temperature-sensitive equipment in any commercial kitchen — pan rails carrying open ingredients during lunch and dinner service must hold below 41°F (the FDA / California Health Code threshold). When the pan rail drifts above that line during service, you're on a HACCP critical control point clock. Our techs prioritize prep table calls accordingly: same-day dispatch from the nearest of our 8 service territories with parts on the truck for the most-installed brands.</p>

      <p>Common prep table failures: pan rail temperature drift (refrigeration system can't keep up with constant lid opening and direct sun exposure), drain line clog (condensate backing into the pan rail base), evaporator fan motor wear, drawer gasket failure on under-counter prep units, and refrigeration circuit issues on mega-top configurations with extended pan rails. Brands we service most: True TSSU, Turbo Air PST / TST, Beverage-Air SPE / DPL, Delfield N-series mega-tops, Randell 9000 worktops.</p>

      <p>For reach-in coolers, see <a href="/commercial/refrigeration/reach-in-cooler-repair/">reach-in cooler repair</a>. For walk-ins, see <a href="/commercial/refrigeration/walk-in-cooler-repair/">walk-in cooler repair</a>. For undercounter units, see <a href="/commercial/refrigeration/undercounter-refrigerator-repair/">undercounter refrigerator repair</a>.</p>
    </div>
  </section>

  <section class="bottom-cta">
    <div class="container">
      <h2>Prep table not holding temp? We respond today.</h2>
      <p>$120 commercial diagnostic. Same-day across all five SoCal counties.</p>
      <div class="cta-row">
        <a href={phoneHref} class="btn-primary">☎ Call {phone}</a>
        <a href="/contact/" class="btn-secondary">Schedule Service</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; }
  .section { padding: 72px 24px; max-width: 1100px; margin: 0 auto; }
  .section h2 { font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 800; margin: 0 0 18px; color: var(--text); }
  .section p { font-size: 1rem; line-height: 1.75; margin: 0 0 16px; color: var(--text); }
  .section a { color: var(--red); font-weight: 600; text-decoration: none; }
  .section a:hover { text-decoration: underline; }
  .container { max-width: 1100px; margin: 0 auto; }
  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { color: #fff; margin: 0 0 14px; font-size: 1.7rem; }
  .bottom-cta p { color: #c9c9c9; margin: 0 0 26px; }
  .cta-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 14px 28px; border-radius: 5px; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 14px 28px; border-radius: 5px; border: 2px solid rgba(255,255,255,0.35); font-weight: 600; text-decoration: none; }
</style>
