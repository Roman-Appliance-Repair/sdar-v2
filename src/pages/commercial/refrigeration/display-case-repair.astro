        <tr><td>Evaporator fan motor</td><td>$260 to $450</td></tr>
        <tr><td>LED lighting harness section</td><td>$260 to $480</td></tr>
        <tr><td>Door gasket (per door)</td><td>$200 to $380</td></tr>
        <tr><td>Defrost timer / control board</td><td>$300 to $580</td></tr>
        <tr><td>Refrigerant leak repair (self-contained)</td><td>$600 to $1,200</td></tr>
        <tr><td>Refrigerant leak repair (remote-condensed line set)</td><td>$900 to $1,800</td></tr>
        <tr><td>Sliding door track replacement</td><td>$400 to $680</td></tr>
        <tr><td>Compressor replacement (self-contained)</td><td>$1,400 to $2,400</td></tr>
        <tr><td>Multi-component repair</td><td>$1,200 to $2,800</td></tr>
        <tr><td>Warranty</td><td>90 days parts and labor</td></tr>
