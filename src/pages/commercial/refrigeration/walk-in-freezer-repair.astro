  .biz-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 18px 16px; }
  .biz-card h3 { font-size: 0.9rem; font-weight: 700; margin: 0 0 6px; color: var(--text); }
  .biz-card p { font-size: 0.82rem; color: var(--muted); line-height: 1.5; margin: 0; }
  /* Repairs */
