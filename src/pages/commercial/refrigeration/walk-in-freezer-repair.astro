  .summer-block .s-label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: #e08030; margin-bottom: 12px; }
  .summer-block h3 { font-size: 1.2rem; font-weight: 800; color: #fff; margin: 0 0 12px; }
  .summer-block p { font-size: 0.93rem; color: #c09060; line-height: 1.7; margin: 0 0 12px; }
  .s-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(190px, 1fr)); gap: 10px; margin-top: 16px; }
