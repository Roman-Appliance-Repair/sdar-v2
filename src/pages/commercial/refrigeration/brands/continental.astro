// $120 commercial diagnostic. BHGS #A49573, EPA 608 Universal #1346255700410.
// 5 schemas (LocalBusiness + Service + Brand + FAQPage + BreadcrumbList).

import Layout from '../../../../layouts/Layout.astro';
import { MAIN_PHONE, MAIN_PHONE_TEL } from '../../../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE_TEL;
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/commercial/refrigeration/brands/continental/";

const title = "Continental Refrigerator Repair LA | Reach-In, Prep Table, Undercounter, Merchandiser";
const description = `Continental Refrigerator commercial repair across SoCal. Independent American brand, Pennsylvania since 1965. $120 commercial. BHGS + EPA 608.`;

const faqs = [
  {
    q: "Who owns Continental Refrigerator?",
    a: "Continental Refrigerator is independent. Founded 1965 in Pennsylvania, family-owned American manufacturer focused on commercial refrigeration. Continental is not part of Ali Group, Welbilt, ITW Food Equipment Group, or any of the major foodservice equipment holding companies. The independent ownership has positioned Continental as a mid-premium alternative to True Manufacturing in the restaurant reach-in and prep table segment, with a focus on durable construction and accessible parts pricing."
  },
  {
    q: "How does Continental compare to True Manufacturing?",
    a: "Both are American independents focused on commercial refrigeration. True Manufacturing is the larger of the two and has the broader distribution network in California, while Continental has positioned itself as a value-engineered alternative with similar build quality at a slightly lower price point. From a service standpoint, both brands use industry-standard refrigeration components (compressor, condenser, evaporator, defrost system) with brand-specific control architectures. We service both, parts availability is good for both, and we don't push customers toward one or the other on the basis of brand alone."
  },
  {
    q: "Which Continental product lines do you service?",
    a: "Full Continental commercial line: 1R/2R/3R reach-in refrigerators (single, two, three-door), 1F/2F/3F reach-in freezers, SW prep tables (sandwich and salad prep), SWF prep table freezer, DL undercounter refrigerators, MBC merchandiser bottle coolers, and the BB back-bar series. Plus glass-door merchandisers and the specialty units (chef base, refrigerated drawers, narrow-depth reach-ins for tight kitchens)."
  },
  {
    q: "What does Continental repair typically cost?",
    a: "$120 commercial diagnostic, applied to the repair. Most Continental repairs run $200-680 all-in including parts and labor: condenser cleaning ($200-280), evaporator fan motor replacement ($360-540), thermostat or controller replacement ($240-380), defrost timer or termination switch ($260-440), door gasket replacement ($200-360 per door), refrigerant leak repair plus recharge ($480-820). Compressor replacement on year-10-to-12 units runs $1,400-2,400. We quote in writing before any parts are ordered."
  },
  {
    q: "Are Continental parts hard to source?",
    a: "No. Continental maintains a robust parts network through authorized distributors with 3-7 day standard ship on common service items. Common parts (thermostats, evaporator fan motors, door gaskets, defrost components) we carry on the van for the major Continental model lines. Specialty parts (compressors, full controller boards) are dealer-order with typical 5-7 day ship from Continental's eastern US distribution. We confirm part availability during the diagnostic and don't quote a part we can't source quickly."
  },
  {
    q: "Do you service Continental units in restaurants and commercial kitchens?",
    a: "Yes. Continental is a common brand in SoCal restaurant kitchens, particularly mid-tier independent restaurants and small chains. We service Continental reach-ins, prep tables, undercounters, and merchandisers in restaurants across LA, Orange, Ventura, San Bernardino, and Riverside counties. HACCP temperature log documentation provided on every commercial service call. Same-day response across LA, OC, Ventura; next-day for Riverside and San Bernardino."
  },
  {
    q: "What's your warranty?",
    a: "90 days SDAR labor and parts warranty on the work we perform. Continental component warranties (compressor, electronic components) where applicable are processed separately through Continental's authorized service network. BHGS #A49573, EPA 608 Universal certified #1346255700410, CSLB C-38 Refrigeration Contractor scope, BBB A+ accredited."
  }
];

