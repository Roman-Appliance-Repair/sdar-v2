        <tr><td>Refrigerant leak repair plus recharge</td><td>$700 to $1,400</td></tr>
        <tr><td>Compressor replacement (M3R)</td><td>$1,400 to $2,200</td></tr>
        <tr><td>Multi-component repair</td><td>$900 to $2,200</td></tr>
        <tr><td>Warranty (SDAR labor)</td><td>90 days parts and labor</td></tr>
