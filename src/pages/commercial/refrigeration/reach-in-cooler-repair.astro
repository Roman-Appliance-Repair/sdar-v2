---
// src/pages/commercial/refrigeration/reach-in-cooler-repair.astro
// 5-niche architecture stub — Reach-In Cooler Repair (commercial refrigeration sub-page).
import Layout from '../../../layouts/Layout.astro';
import CommercialHero from '../../../components/CommercialHero.astro';
import { MAIN_PHONE } from '../../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;

const title = "Reach-In Cooler Repair — Commercial Refrigeration | Same Day Appliance Repair";
const description = `Same-day reach-in cooler repair across LA, Orange, Ventura, San Bernardino & Riverside counties. True, Turbo Air, Beverage-Air, Traulsen, Delfield. $120 commercial diagnostic. Call ${phone}.`;
const canonical = "https://samedayappliance.repair/commercial/refrigeration/reach-in-cooler-repair/";

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Reach-In Cooler Repair",
  "name": "Reach-In Cooler Repair — Same Day Appliance Repair",
  "url": canonical,
  "description": "Same-day reach-in cooler repair across all five SoCal counties. True, Turbo Air, Beverage-Air, Traulsen, Delfield, Continental.",
  "provider": { "@type": "LocalBusiness", "name": "Same Day Appliance Repair", "url": "https://samedayappliance.repair/", "telephone": phone, "priceRange": "$$" },
  "areaServed": [
    { "@type": "AdministrativeArea", "name": "Los Angeles County" },
    { "@type": "AdministrativeArea", "name": "Orange County" },
    { "@type": "AdministrativeArea", "name": "Ventura County" },
    { "@type": "AdministrativeArea", "name": "San Bernardino County" },
    { "@type": "AdministrativeArea", "name": "Riverside County" },
  ],
  "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "120.00", "priceCurrency": "USD", "description": "Commercial diagnostic fee, applied toward repair" } },
};
---

<Layout title={title} description={description} canonical={canonical}>
  <Fragment slot="head-scripts">
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </Fragment>

  <CommercialHero
    title="Reach-In Cooler Repair"
    subtitle="Single-, two-, and three-door commercial reach-in coolers. True, Turbo Air, Beverage-Air, Traulsen, Delfield. Same-day across all five SoCal counties. $120 diagnostic, applied toward repair."
    heroImageTitle="Reach-In Cooler Repair"
    showBranches={true}
  />

  <section class="section">
    <div class="container">
      <h2>Reach-In Cooler Repair Across Southern California</h2>
      <p>The reach-in cooler is the workhorse of every commercial kitchen — restaurant prep stations, bar back coolers, deli counters, sandwich shops. When it fails during service hours, the inventory clock starts. Our techs respond same-day across LA, Orange, Ventura, San Bernardino, and Riverside counties with parts on the truck for the most-installed brands: True T-series, Turbo Air M3 / PRO, Beverage-Air SP, Traulsen G-series, Delfield N-series.</p>

      <p>Common reach-in failures we diagnose: thermostat drift (interior temp climbing above 41°F — health-code threshold), evaporator fan motor wear (whirring noise from the back wall), defrost system failure (frost coating the rear panel), door gasket compression loss (front-edge condensation), and condenser coil fouling (most common preventable cause of compressor stress). $120 commercial diagnostic, applied toward repair.</p>

      <p>For walk-in cold storage, see <a href="/commercial/refrigeration/walk-in-cooler-repair/">walk-in cooler repair</a>. For freezer reach-ins, see <a href="/commercial/refrigeration/reach-in-freezer-repair/">reach-in freezer repair</a>. For prep tables, see <a href="/commercial/refrigeration/prep-table-repair/">prep table repair</a>.</p>
    </div>
  </section>

  <section class="bottom-cta">
    <div class="container">
      <h2>Reach-in cooler down? We respond today.</h2>
      <p>$120 commercial diagnostic. Same-day across all five SoCal counties.</p>
      <div class="cta-row">
        <a href={phoneHref} class="btn-primary">☎ Call {phone}</a>
        <a href="/contact/" class="btn-secondary">Schedule Service</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; }
  .section { padding: 72px 24px; max-width: 1100px; margin: 0 auto; }
  .section h2 { font-size: clamp(1.5rem, 3vw, 2rem); font-weight: 800; margin: 0 0 18px; color: var(--text); }
  .section p { font-size: 1rem; line-height: 1.75; margin: 0 0 16px; color: var(--text); }
  .section a { color: var(--red); font-weight: 600; text-decoration: none; }
  .section a:hover { text-decoration: underline; }
  .container { max-width: 1100px; margin: 0 auto; }
  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { color: #fff; margin: 0 0 14px; font-size: 1.7rem; }
  .bottom-cta p { color: #c9c9c9; margin: 0 0 26px; }
  .cta-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 14px 28px; border-radius: 5px; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 14px 28px; border-radius: 5px; border: 2px solid rgba(255,255,255,0.35); font-weight: 600; text-decoration: none; }
</style>
