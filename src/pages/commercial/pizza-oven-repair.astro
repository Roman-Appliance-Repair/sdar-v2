import Layout from '../../layouts/Layout.astro';

const title = "Commercial Pizza Oven Repair Los Angeles, Deck, Conveyor, Wood-Fired";
const description = "Commercial pizza oven repair across LA. Lincoln + Middleby Marshall conveyor, Bakers Pride + Blodgett deck, Wood Stone + Forno Bravo wood-fired. $120 diagnostic waived. (424) 325-0520.";
const canonical = "https://samedayappliance.repair/commercial/pizza-oven-repair/";

const faqs = [
  { q: "What types of commercial pizza ovens do you service?", a: "All major pizza oven categories: conveyor belt ovens (Lincoln Impinger, Middleby Marshall PS/WOW series, TurboChef Fire), deck ovens (Bakers Pride Y-600, Marsal SD series, Blodgett 1048/1060, Peerless legacy), wood-fired ovens (Wood Stone Mt Adams/Fire Deck/Bistro, Forno Bravo Modena/Napolino/Professionale, Marra Forni rotator, Mugnaini Valoriani distributor), and brick-lined artisan specialty ovens. Gas-fired, electric, and wood-fired configurations across all three categories. Call (424) 325-0520 with your brand and model." },
  { q: "What does commercial pizza oven repair typically cost in LA?", a: "$120 flat commercial diagnostic, waived with repair. Typical service ranges: thermostat replacement $200–$340, door gasket / hinge $180–$320, burner ignitor $240–$400, gas valve $280–$480, conveyor belt service (Lincoln/Middleby Marshall) $320–$560, deck thermocouple (Bakers Pride Y-600, Blodgett 1048) $220–$380, wood-fired flame-impingement calibration (Wood Stone) $320–$560, pizza stone replacement $380–$680, air-flow sensor (conveyor) $280–$460, control board $650–$1,200. Most pizza oven calls land $350–$750 parts-and-labor." },
  { q: "Which LA pizza restaurants do you service?", a: "Across LA's Neapolitan and artisan pizza cluster: Pizzana (West Hollywood + Brentwood), Mozza (Hancock Park), Bestia (Arts District), Jon & Vinny's, Mother Dough, L'Antica Pizzeria da Michele, 800 Degrees Pizza, Gjelina (Venice), and comparable operations. We also service chain pizza franchise locations across LA County, Domino's, Pizza Hut, Papa John's, Little Caesars, Marco's Pizza run Middleby Marshall and Lincoln Impinger conveyor ovens. Italian restaurants (Felix Trattoria, Valentino, Piccolo Paradiso, Bottega Louie) often run Forno Bravo or Marra Forni. Any pizza operation running commercial gas, electric, or wood-fired equipment, call us." },
  { q: "Are you BHGS-licensed for California commercial gas pizza ovens?", a: "Yes. California commercial gas-equipment service requires proper licensing, CARB (California Air Resources Board) emissions compliance, and LADBS (Los Angeles Department of Building and Safety) permitting in most commercial install contexts. Our techs carry BHGS #A49573 licensing, CARB compliance documentation, and LADBS coordination experience on gas-equipment service. Uncalibrated gas regulators on pizza ovens cause both cook-consistency problems (under-pressure runs cold, over-pressure burns out components) and safety risks. We verify regulator calibration on every gas pizza oven service call." },
  { q: "Do you service wood-fired pizza ovens?", a: "Yes, wood-fired pizza ovens are a distinct service specialty from gas/electric. LA's Neapolitan pizza cluster runs substantial Wood Stone and Forno Bravo wood-fired installations. Wood-fired service covers flame-impingement calibration, oven-door thermocouple and seal, wood-loading mechanism wear (on hybrid models with gas-boost plus wood-fired primary), refractory lining inspection, and chimney/venting compliance with LADBS requirements. Not all competitor LA appliance service providers handle wood-fired work; it's a niche specialization we maintain because LA's artisan pizza cluster depends on it." },
  { q: "How fast can you respond to a pizza oven failure during dinner service?", a: "Same-day emergency response across LA, Orange County, Ventura, San Bernardino, and Riverside. Call (424) 325-0520, the phone tree routes directly to emergency dispatch. For pizza operations, oven failure during dinner rush has hard revenue consequences; our dispatch prioritizes restaurant-equipment emergency calls accordingly. Typical emergency response: 60–120 minutes from call to technician on-site for core LA County, longer for outlying Ventura/San Bernardino/Riverside zones." }
];

const schema = { "@context": "https://schema.org", "@graph": [
  { "@type": "LocalBusiness", "@id": canonical + "#business", "name": "Same Day Appliance Repair, Commercial Pizza Oven Repair", "image": "https://samedayappliance.repair/images/logo.png", "url": canonical, "telephone": "(424) 325-0520", "areaServed": ["Los Angeles County", "Orange County", "Ventura County", "San Bernardino County", "Riverside County"] },
  { "@type": "Service", "serviceType": "Commercial Pizza Oven Repair", "provider": { "@id": canonical + "#business" }, "areaServed": "Los Angeles", "description": "Commercial pizza oven repair across Los Angeles, conveyor belt (Lincoln Impinger, Middleby Marshall), deck (Bakers Pride, Marsal, Blodgett, Peerless), wood-fired (Wood Stone, Forno Bravo, Marra Forni), and brick-lined artisan. Gas-fired, electric, and wood-fired configurations. CARB compliant. $120 commercial diagnostic waived with repair." },
  { "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  { "@type": "BreadcrumbList", "itemListElement": [ { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" }, { "@type": "ListItem", "position": 2, "name": "Commercial", "item": "https://samedayappliance.repair/commercial/" }, { "@type": "ListItem", "position": 3, "name": "Pizza Oven Repair", "item": canonical } ] }
] };
