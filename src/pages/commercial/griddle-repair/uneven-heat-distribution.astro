<CommercialHero
  title="Commercial Griddle Uneven Heat Distribution, Same-Day Diagnostic"
  subtitle={`Cold spots, hot zones, half-cold electric griddle? Burner spacing, element burnout, sensor location, surface warpage. Vulcan, Garland, Star, Wells, Keating. $120 commercial. ${phone}`}
  heroImageTitle="Commercial Griddle Uneven Heat"
