import Layout from '../../../layouts/Layout.astro';
import CommercialHero from '../../../components/CommercialHero.astro';
import { MAIN_PHONE } from '../../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/commercial/washer-repair/coin-laundry-repair/";

const title = "Coin & Vended Laundry Repair LA | Speed Queen, Huebsch, Maytag — Laundromat Service — $120 Diagnostic";
const description = `Coin laundry / vended laundromat repair across LA, OC, Ventura. Speed Queen, Huebsch, Maytag commercial. Coin mech + card system service. $120 diagnostic. ${phone}.`;

const faqs = [
  {
    q: "What's the difference between coin laundry and OPL?",
    a: "Coin laundry (also called vended laundry) is the public self-service laundromat where customers pay per cycle with coins or, increasingly, with card-tap and mobile app systems. OPL is on-premise laundry where a single facility (hotel, hospital, senior care) processes its own linens in-house. Different equipment, different service profiles, different brands. Vended runs 24/7 with high abuse and vandalism exposure; OPL runs on facility schedule with controlled operation.",
  },
  {
    q: "Speed Queen, Huebsch, Maytag Commercial: which dominates LA laundromats?",
    a: "Speed Queen and Huebsch (both Alliance Laundry Systems) dominate the LA vended-laundry market. Speed Queen sits at the premium tier, Huebsch is the value tier from the same parent. Maytag Commercial Laundry (Whirlpool Corp) is the third major brand, common at chain laundromats. Continental Girbau Vended Series shows up in higher-end laundromats. We service all four.",
  },
  {
    q: "My card reader stopped accepting taps. Can you fix it?",
    a: "Yes. Modern card-tap and mobile-app systems (Speed Queen Quantum Touch, Huebsch eCommerce, integrated CCI / Card Concepts and ESD systems) integrate the payment terminal with the machine controller via serial or Ethernet. Diagnostic order: cable, terminal firmware, machine controller integration. Common service item at year 4 to 6. Replacement runs $640 to $1,100 depending on the system.",
  },
  {
    q: "Coin mechanism jammed by foreign object: standard repair?",
    a: "Yes. Coin mechanism jams from foreign objects (paper clips, washers, tokens, sometimes deliberate vandalism) are routine in vended laundry service. We clear the jam, inspect the slide and acceptor, and replace components if damaged. Typical repair $200 to $440 depending on whether the slide or acceptor needs replacement.",
