---
// Wave 20, Commercial washer leaking-water failure-mode sub-service.
// Practitioner angle: drain pump, drain hose, tub seal, door gasket, supply.
import Layout from '../../../layouts/Layout.astro';
import CommercialHero from '../../../components/CommercialHero.astro';
import { MAIN_PHONE } from '../../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/commercial/washer-repair/leaking-water/";

const title = "Commercial Washer Leaking Water LA — Same Day";
const description = "Commercial washer leaking water? LA same-day. Speed Queen, UniMac, Continental Girbau, Dexter, Maytag Commercial. BHGS #A49573, EPA 608. $120 dx.";

const faqs = [
  {
    q: "My commercial washer is leaking water. Where do I start?",
    a: "Three leak categories ranked by frequency. (1) Drain-side: drain pump failed, drain hose connection loose, drain line clogged with lint. About 45% of leak calls. (2) Door / gasket: door gasket compressed, drum gasket failed, door seal worn. About 30%. (3) Supply or tub: water inlet hose fitting, tub seal failure, internal hose connection. About 25%. We dry the machine completely and run a cycle to identify the leak point at the diagnostic visit."
  },
  {
    q: "How urgent is a commercial washer leak?",
    a: "Treat-as-urgent in most cases. Standing water on a laundromat floor is a slip hazard and a Health Department flag during inspections. On-premise installations create cabinet rot, electrical risk, and damage to adjacent equipment. Multi-machine laundromat floor space typically has shared drainage, so a leak from one machine can mask underlying drainage issues affecting others. We dispatch leak calls same-day priority."
  },
  {
    q: "Why does the drain pump keep failing?",
    a: "Three reasons in commercial laundry. (1) Lint accumulation from heavy-duty cycles binds the impeller. Annual lint trap cleaning extends pump life from 5 years to 8+ years. (2) Foreign objects, coins, buttons, hair clips, occasionally underwire from bras, bypass the lint trap and damage the impeller. (3) Capacitor on pumps with start capacitor degrades. Diagnose by listening for impeller spin during drain cycle. Replacement runs $385 to $585 on coin-op, $585 to $785 on industrial."
  },
  {
    q: "What's the tub seal and how does it fail?",
    a: "On front-load washer-extractors, the tub seal is the rubber/composite seal between the rotating drum (inner tub) and the stationary outer tub. As the seal wears (year 8 to 12 typical), water leaks from the drum into the cabinet space below. Symptom: leak appears at the bottom of the cabinet during wash cycle, accelerates during spin extract. Replacement is part of the major bearing and seal kit service ($1,485 to $2,485) because the seal lives behind the bearing assembly."
  },
  {
    q: "Door gasket vs drum gasket, what's the difference?",
    a: "Two different parts. Door gasket (also called door boot) is the rubber seal around the door opening that creates the water seal when door is closed. Drum gasket seals the drum to the cabinet internally. Door gasket failures are more common (year 6 to 10 typical) and produce visible leaks at the door perimeter. Drum gasket failures (year 8 to 12) produce internal leaks not visible from outside until water reaches the bottom of the cabinet. Door gasket replacement $485 to $685; drum gasket $485 to $785."
  },
  {
    q: "What's the typical cost?",
    a: "Drain pump replacement: $385 to $785. Drain hose / connection repair: $185 to $385. Tub seal (part of bearing service): $1,485 to $2,485. Door gasket replacement: $485 to $685. Drum gasket: $485 to $785. Water inlet hose: $185 to $285. Internal hose connection repair: $245 to $385. Tub-to-pump hose: $245 to $385. The $120 commercial diagnostic is waived with repair."
  },
  {
    q: "What's your warranty?",
    a: "90 days SDAR labor and parts. BHGS #A49573, EPA 608 Universal #1346255700410, BBB A+ accredited."
  }
];

const schemaJsons = [
  {
    "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair", "url": canonical, "telephone": phone, "priceRange": "$$",
    "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "08:00", "closes": "20:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "00:00", "closes": "00:00" }
      ],
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ]
  },
  {
    "@context": "https://schema.org", "@type": "Service", "@id": canonical + "#service",
    "serviceType": "Commercial Washer Water Leak Repair",
    "name": "Commercial Washer Leak Diagnostic",
    "url": canonical,
    "description": "Commercial washer water leak diagnostic across all five SoCal counties. Drain pump, drain hose, tub seal (part of bearing service), door gasket, drum gasket, water inlet hose, internal hose connections, tub-to-pump hose. Speed Queen, UniMac, Continental Girbau, Pellerin Milnor, Dexter, Wascomat, Fagor Industrial. $120 commercial diagnostic, applied toward repair. BHGS #A49573, EPA 608 Universal #1346255700410.",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "120.00", "priceCurrency": "USD", "description": "Commercial diagnostic fee, applied toward repair" } }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  {
    "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Commercial", "item": "https://samedayappliance.repair/commercial/" },
      { "@type": "ListItem", "position": 3, "name": "Washer Repair", "item": "https://samedayappliance.repair/commercial/washer-repair/" },
      { "@type": "ListItem", "position": 4, "name": "Water Leaking", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>

<Fragment slot="head-scripts">
  {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
</Fragment>

<CommercialHero
  title="Commercial Washer Leaking Water Repair Los Angeles"
  subtitle={`Pooling water on the floor or inside the cabinet? Drain pump, tub seal, gasket, supply line. Speed Queen, UniMac, Continental Girbau, Dexter. ${phone}`}
  heroImageTitle="Commercial Washer Water Leak Repair"
  showBranches={true}
/>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Leak diagnostic</p>
    <h2>Three leak categories. Location determines the repair tier.</h2>

    <p>Commercial washer leaks fall into three categories that determine the repair tier. Drain-side leaks (drain pump failure, drain hose connection, drain line clog) account for about 45% of leak calls and run $185 to $785 typical. Door / gasket leaks (door gasket, drum gasket, door seal) account for about 30% and run $485 to $785. Supply or tub leaks (water inlet hose, tub seal, internal hose connections) account for the remaining 25% and run $185 to $2,485 depending on whether the tub seal is involved.</p>

    <p>Leak urgency is high in most commercial cases. Standing water on a laundromat floor is a slip hazard and Health Department flag. On-premise installations create cabinet rot and electrical risk. Multi-machine laundromat floor space with shared drainage means leaks from one machine can mask drainage issues affecting others. We dispatch leak calls same-day priority.</p>

    <p>$120 commercial diagnostic, waived with repair. BHGS #A49573 + EPA 608 Universal #1346255700410. We service Speed Queen, UniMac, Continental Girbau, Pellerin Milnor, Dexter, Wascomat, and Fagor Industrial across LA, Orange, Ventura, San Bernardino, and Riverside counties.</p>
  </div>
</section>

<section class="section section-gray">
  <div class="container">
    <p class="section-number">Three leak categories</p>
    <h2>Drain-side, gasket, supply.</h2>

    <h3 class="series-h3">Drain-side (45% of calls)</h3>
    <p>Three sub-causes:</p>
    <ul class="reasons-list">
      <li><strong>Drain pump failed</strong>, impeller bound by lint accumulation, foreign object damage (coins, buttons, occasionally underwire), capacitor degraded on capacitor-start pumps. Replacement $385 to $785.</li>
      <li><strong>Drain hose connection loose</strong>, clamp at pump or tub connection loosens with vibration. Re-tighten or replace clamp. $185 to $285.</li>
      <li><strong>Drain line clogged</strong>, lint accumulation in the building drain line backs water up into the machine. Clear the building drain (often shared with adjacent machines on multi-machine floors). $185 to $385.</li>
    </ul>

    <h3 class="series-h3">Door / gasket (30% of calls)</h3>
    <ul class="reasons-list">
      <li><strong>Door gasket (also called door boot)</strong>, rubber seal around door opening. Year 6 to 10 typical. Symptom: leak at door perimeter during wash. Replacement $485 to $685.</li>
      <li><strong>Drum gasket</strong>, internal seal between drum and cabinet. Year 8 to 12. Symptom: leak appears at bottom of cabinet, not visible at door. Replacement $485 to $785.</li>
      <li><strong>Door seal hardened or torn</strong>, accelerated wear from chemical exposure (bleach, sour) or impact damage from foreign objects. Replacement timing same as gasket.</li>
    </ul>

    <h3 class="series-h3">Supply or tub (25% of calls)</h3>
    <ul class="reasons-list">
      <li><strong>Water inlet hose fitting</strong>, supply connection at machine inlet. Compression fitting loosens with vibration. Re-seat or replace washer. $185 to $285.</li>
      <li><strong>Tub seal failure</strong>, seal between rotating drum and stationary outer tub on front-load washer-extractors. Year 8 to 12. Replacement is part of the major bearing and seal kit service ($1,485 to $2,485) because the seal lives behind the bearing assembly.</li>
      <li><strong>Internal hose connections</strong>, air dome hose, pressure switch hose, fill hose internal. Various year 8 to 12 failures. $245 to $385.</li>
      <li><strong>Tub-to-pump hose</strong>, flexible hose between outer tub and drain pump. Cracks or perforates with age. $245 to $385.</li>
    </ul>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Pricing</p>
    <h2>Leak repair costs.</h2>

    <table class="price-table">
      <thead><tr><th>Repair</th><th>Typical Cost</th></tr></thead>
      <tbody>
        <tr><td>Diagnostic (waived with repair)</td><td>$120</td></tr>
        <tr><td>Drain pump replacement (coin-op)</td><td>$385 to $585</td></tr>
        <tr><td>Drain pump replacement (industrial)</td><td>$585 to $785</td></tr>
        <tr><td>Drain hose / connection</td><td>$185 to $385</td></tr>
        <tr><td>Drain line clearing</td><td>$185 to $385</td></tr>
        <tr><td>Door gasket replacement</td><td>$485 to $685</td></tr>
        <tr><td>Drum gasket replacement</td><td>$485 to $785</td></tr>
        <tr><td>Tub seal (part of bearing service)</td><td>$1,485 to $2,485</td></tr>
        <tr><td>Water inlet hose</td><td>$185 to $285</td></tr>
        <tr><td>Internal hose connection</td><td>$245 to $385</td></tr>
        <tr><td>Tub-to-pump hose</td><td>$245 to $385</td></tr>
        <tr><td>Warranty</td><td>90 days parts and labor</td></tr>
      </tbody>
    </table>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">FAQ</p>
    <h2>Leak questions.</h2>
    <div class="faq-list">
      {faqs.map(f => (<details class="faq-item"><summary>{f.q}</summary><p set:html={f.a}></p></details>))}
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <p class="section-number">Related</p>
    <h2>Commercial laundry across the catalog.</h2>
    <div class="related-grid">
      <a href="/commercial/washer-repair/" class="related-card"><h3>Washer Repair Hub</h3><p>Parent pillar.</p></a>
      <a href="/commercial/washer-repair/not-spinning/" class="related-card"><h3>Not Spinning</h3><p>Drive belt, motor, bearing, door switch.</p></a>
      <a href="/commercial/washer-repair/error-codes/" class="related-card"><h3>Error Codes</h3><p>Brand-specific code interpretation.</p></a>
      <a href="/commercial/washer-repair/coin-laundry-repair/" class="related-card"><h3>Coin-Op Laundry</h3><p>Vended laundromat service.</p></a>
      <a href="/commercial/washer-repair/brands/speed-queen/" class="related-card"><h3>Speed Queen</h3><p>Premium coin-op + on-premise.</p></a>
    </div>
  </div>
</section>

<section class="bottom-cta">
  <div class="container">
    <h2>Commercial washer leaking? Same-day priority across LA.</h2>
    <p>All major commercial brands. Drain pump through tub seal service. $120 commercial, waived with repair. BHGS #A49573 + EPA 608.</p>
    <div class="cta-row">
      <a href={phoneHref} class="btn-primary">☎ Call {phone}</a>
      <a href="/contact/" class="btn-secondary">Book Online</a>
    </div>
  </div>
</section>

</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .section { padding: 72px 24px; }
  .section-gray { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; }
  .container.narrow { max-width: 820px; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  .section h2 { font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 800; margin: 0 0 18px; line-height: 1.2; }
  .section p { font-size: 1rem; line-height: 1.75; margin: 0 0 16px; }
  .section a { color: var(--red); font-weight: 600; text-decoration: none; }
  .section a:hover { text-decoration: underline; }
  .series-h3 { font-size: 1.1rem; font-weight: 800; margin: 28px 0 10px; }
  .reasons-list { padding-left: 22px; margin: 12px 0 16px; }
  .reasons-list li { font-size: 1rem; line-height: 1.75; margin-bottom: 8px; }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 22px; background: #fff; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
  .price-table th, .price-table td { padding: 12px 16px; text-align: left; border-bottom: 1px solid var(--border); font-size: 0.95rem; }
  .price-table th { background: var(--gray); font-weight: 700; }
  .price-table tr:last-child td { border-bottom: none; }
  .faq-list { margin-top: 24px; }
  .faq-item { background: #fff; border: 1px solid var(--border); border-radius: 6px; padding: 18px 22px; margin-bottom: 12px; }
  .faq-item summary { font-weight: 700; cursor: pointer; font-size: 1rem; list-style: none; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::before { content: "+ "; color: var(--red); font-weight: 800; margin-right: 6px; }
  .faq-item[open] summary::before { content: "− "; }
  .faq-item p { font-size: 0.95rem; line-height: 1.75; margin: 14px 0 0; }
  .related-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 18px; margin-top: 22px; }
  .related-card { display: block; background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 22px; text-decoration: none; color: var(--text); transition: all 0.2s; }
  .related-card:hover { border-color: var(--red); transform: translateY(-2px); box-shadow: 0 4px 14px rgba(0,0,0,0.06); }
  .related-card h3 { font-size: 1rem; font-weight: 800; margin: 0 0 8px; }
  .related-card p { font-size: 0.85rem; color: var(--muted); margin: 0; line-height: 1.6; }
  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { color: #fff; margin: 0 0 14px; font-size: 1.7rem; }
  .bottom-cta p { color: #c9c9c9; margin: 0 0 26px; max-width: 720px; margin-left: auto; margin-right: auto; }
  .cta-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 14px 28px; border-radius: 5px; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 14px 28px; border-radius: 5px; border: 2px solid rgba(255,255,255,0.35); font-weight: 600; text-decoration: none; }
</style>
