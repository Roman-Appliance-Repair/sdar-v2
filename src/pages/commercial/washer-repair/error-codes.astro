---
// Wave 20, Commercial washer error-codes failure-mode sub-service.
// Brand-specific code maps: Speed Queen Quantum, UniMac, Continental Inwave, Wascomat.
import Layout from '../../../layouts/Layout.astro';
import CommercialHero from '../../../components/CommercialHero.astro';
import { MAIN_PHONE } from '../../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/commercial/washer-repair/error-codes/";

const title = "Commercial Washer Error Codes LA | Speed Queen, Continental, Wascomat, $120 Diagnostic";
const description = "Commercial washer showing error code? LA same-day. Speed Queen Quantum Touch + Gold, UniMac, Continental Inwave, Wascomat, Dexter, Milnor MILtouch. EPA 608.";

const faqs = [
  {
    q: "Speed Queen Quantum Touch error codes, what do they mean?",
    a: "Quantum Touch displays alphanumeric codes on the touchscreen. Most common: E DR (door not detected closed/locked), E FL (fill timeout, water didn't reach level in expected time), E DL (drain timeout, water didn't drain in expected time), E nF (no fill, water inlet valve), E SP (spin timeout, didn't reach extract speed), E hE (heater error, temperature didn't rise on heated cycles), E UB (unbalanced load detected). Code reading shortens diagnostic time 30-50% versus blind diagnosis. Quantum Gold (legacy LED + button) uses similar code logic with different display format.",
  },
  {
    q: "Continental Girbau Inwave codes?",
    a: "Continental Inwave touchscreen displays named errors plus numeric codes. Common: 'Door' (door safety circuit), 'Fill' (water fill timeout), 'Drain' (drain timeout), 'Heat' (heating element or thermostat), 'Spin' (extract speed not reached), 'Imbalance' (load distribution). Older Logi Pro on legacy Continental units uses simpler LED indicator codes, typically 2-flash water issue, 3-flash heat, 4-flash drain, 5-flash spin. Different code set on E-Series, G-Flex, EH platforms.",
  },
  {
    q: "What about Wascomat error codes?",
    a: "Wascomat current-generation Crossover and Encore use Electrolux Professional control system with named alerts and numeric codes. Common: F (fault) prefix codes, F1 fill, F2 drain, F3 heat, F4 motor, F5 control. Legacy Wascomat platforms use simpler error-LED indicators. We pull the specific service manual at the visit to interpret correctly because Wascomat code maps vary across model years and firmware.",
  },
  {
    q: "Pellerin Milnor MILtouch and MILnet codes?",
    a: "Milnor MILtouch displays numeric error codes. Common: EE (programming error in cycle), Er (cycle error generic), F (component failure with sub-code). MILnet (the building-level laundry management system) adds inter-machine communication errors and aggregate fault reporting. CBW tunnel-washer codes are more specialized (tunnel transfer errors, press cycle errors, conveyor errors) and require Milnor-specific service knowledge. We maintain current Milnor service documentation for the platforms we encounter on LA service calls.",
  },
  {
    q: "Can I reset commercial washer codes myself?",
    a: "Yes for most platforms, but the underlying problem persists. Reset clears the displayed code; if the fault condition is still present, the code returns within minutes (faster on persistent faults like a stuck drain valve, slower on intermittent faults like brief water pressure dips). Reset procedures vary: Speed Queen Quantum Touch through service menu, UniMac through programming key sequence, Continental Inwave through touchscreen menu. Resetting without diagnosing is OK as a temporary workaround if you want the machine to attempt operation while you wait for service, but don't ignore a code that returns repeatedly.",
  },
  {
    q: "What's the typical cost when an error code is involved?",
    a: "The error code itself doesn't change the repair cost, what matters is what the underlying fault turns out to be. Code-only diagnostic: $120. Most code-related repairs run $245 to $785 depending on the actual component (drain valve, water inlet, door switch, heater, control board). Bearing-related codes (long spin time, vibration alarms) can lead to bearing service at $1,485 to $2,485. Multi-component codes on year 10+ machines: $1,485 to $2,485 typical.",
  },
  {
    q: "What's your warranty?",
    a: "90 days SDAR labor and parts. BHGS #A49573, EPA 608 Universal #1346255700410, BBB A+ accredited.",
  },
];

const schemaJsons = [
  {
    "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair", "url": canonical, "telephone": phone, "priceRange": "$$",
    "openingHoursSpecification": [{ "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "08:00", "closes": "20:00" }],
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" },
    ],
  },
  {
    "@context": "https://schema.org", "@type": "Service", "@id": canonical + "#service",
    "serviceType": "Commercial Washer Error Code Diagnostic",
    "name": "Commercial Washer Error Code Interpretation",
    "url": canonical,
    "description": "Commercial washer error code diagnostic across all five SoCal counties. Speed Queen Quantum Touch + Quantum Gold, UniMac UniLinc, Continental Girbau Inwave + Logi Pro, Wascomat Electrolux Professional control, Pellerin Milnor MILtouch + MILnet, Dexter electronic controls, Fagor Industrial European-spec controls. Code-driven diagnostic shortens troubleshooting time. $120 commercial diagnostic, applied toward repair. BHGS #A49573, EPA 608 Universal #1346255700410.",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" },
    ],
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "120.00", "priceCurrency": "USD", "description": "Commercial diagnostic fee, applied toward repair" } },
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  {
    "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Commercial", "item": "https://samedayappliance.repair/commercial/" },
      { "@type": "ListItem", "position": 3, "name": "Washer Repair", "item": "https://samedayappliance.repair/commercial/washer-repair/" },
      { "@type": "ListItem", "position": 4, "name": "Error Codes", "item": canonical },
    ],
  },
];
---

<Layout title={title} description={description} canonical={canonical}>

<Fragment slot="head-scripts">
  {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
</Fragment>

<CommercialHero
  title="Commercial Washer Error Codes, Brand-Specific Diagnostic"
  subtitle={`Speed Queen Quantum, Continental Inwave, Wascomat, UniMac, Milnor MILtouch, Dexter. Code-driven diagnostic shortens troubleshooting. ${phone}`}
  heroImageTitle="Commercial Washer Error Code Diagnostic"
  showBranches={true}
/>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Code-driven diagnostic</p>
    <h2>The code points us at a category. The test confirms the component.</h2>

    <p>Modern commercial washers display error codes that point to specific failure categories. Code reading is the start of the diagnostic, not the end: a Speed Queen Quantum Touch E FL "fill timeout" tells us water didn't reach level in expected time, but the actual cause could be water inlet valve failed closed, partially closed shut-off valve in supply, low water pressure at the supply line, or a failed pressure switch. The code narrows the search; the test confirms the component.</p>

    <p>This page is a reference for the major commercial washer code systems we encounter on LA service calls. Brand-specific code maps change with firmware revisions, so we maintain current service documentation for each platform. If your machine is showing a code, jot it down before calling so the dispatcher can pre-route the call to a tech with current code-set knowledge for your platform.</p>

    <p>$120 commercial diagnostic, waived with repair. BHGS #A49573 + EPA 608 Universal #1346255700410.</p>
  </div>
</section>

<section class="section section-gray">
  <div class="container">
    <p class="section-number">Speed Queen + UniMac (Alliance)</p>
    <h2>Quantum Touch and Quantum Gold codes.</h2>

    <p>Alliance Laundry Systems (Speed Queen, UniMac) shares the Quantum control architecture with platform-specific variations. Quantum Touch is current-generation touchscreen; Quantum Gold is legacy LED + button.</p>

    <table class="price-table">
      <thead><tr><th>Code</th><th>Meaning</th><th>Common Causes</th></tr></thead>
      <tbody>
        <tr><td>E DR</td><td>Door not detected closed/locked</td><td>Door switch, lock mechanism, wiring</td></tr>
        <tr><td>E FL</td><td>Fill timeout</td><td>Water inlet valve, supply line, low pressure</td></tr>
        <tr><td>E DL</td><td>Drain timeout</td><td>Drain pump, drain hose clog, drain line</td></tr>
        <tr><td>E nF</td><td>No fill</td><td>Water inlet valve fully failed closed</td></tr>
        <tr><td>E SP</td><td>Spin timeout</td><td>Drive belt, motor, drum brake stuck</td></tr>
        <tr><td>E hE</td><td>Heater error</td><td>Heating element, thermostat, scale buildup</td></tr>
        <tr><td>E UB</td><td>Unbalanced load detected</td><td>Load distribution, suspension components, drum bearing</td></tr>
      </tbody>
    </table>
  </div>
</section>

<section class="section">
  <div class="container">
    <p class="section-number">Continental Girbau + Wascomat (European)</p>
    <h2>Inwave + Electrolux Professional codes.</h2>

    <h3 class="series-h3">Continental Girbau Inwave</h3>
    <p>Touchscreen displays named errors. Common: 'Door' (door safety circuit), 'Fill' (water fill timeout), 'Drain' (drain timeout), 'Heat' (heating element or thermostat), 'Spin' (extract speed not reached), 'Imbalance' (load distribution). Older Logi Pro uses simpler LED indicators (2-flash water, 3-flash heat, 4-flash drain, 5-flash spin).</p>

    <h3 class="series-h3">Wascomat Electrolux Professional</h3>
    <p>F-prefix numeric codes: F1 fill, F2 drain, F3 heat, F4 motor, F5 control. Older Wascomat uses simpler error-LED indicators. We pull the specific service manual at the visit because Wascomat code maps vary across model years and firmware.</p>
  </div>
</section>

<section class="section section-gray">
  <div class="container">
    <p class="section-number">Other major platforms</p>
    <h2>Milnor, Dexter, Fagor Industrial.</h2>

    <h3 class="series-h3">Pellerin Milnor MILtouch and MILnet</h3>
    <p>MILtouch displays numeric error codes: EE (programming error in cycle), Er (cycle error generic), F (component failure with sub-code). MILnet adds inter-machine communication errors and aggregate fault reporting across multiple Milnor units. CBW tunnel-washer codes are more specialized (tunnel transfer, press cycle, conveyor) and require Milnor-specific service knowledge.</p>

    <h3 class="series-h3">Dexter electronic controls</h3>
    <p>Simpler control architecture than electronic-heavy competitors. LED-based error indicators on most current Dexter T-Series and C-Series, with newer touchscreen models on premium configurations. We diagnose by LED pattern combined with mechanical observation. Fewer code-only failures than Speed Queen Quantum Touch because Dexter relies more on mechanical sensing.</p>

    <h3 class="series-h3">Fagor Industrial European-spec controls</h3>
    <p>Fagor Industrial control system uses European service documentation. Codes are typically alphanumeric with letter-prefix indicating category (E error, A alarm, S service notification). We pull the model-specific service manual at the visit because Fagor code maps differ from American competitors.</p>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Pricing</p>
    <h2>Code-driven diagnostic costs.</h2>

    <table class="price-table">
      <thead><tr><th>Service</th><th>Typical Cost</th></tr></thead>
      <tbody>
        <tr><td>Diagnostic with code reading (waived with repair)</td><td>$120</td></tr>
        <tr><td>Code reset only (temporary)</td><td>$120</td></tr>
        <tr><td>Door circuit repair (E DR, Door, F door codes)</td><td>$245 to $385</td></tr>
        <tr><td>Water-side repair (E FL, E nF, Fill, F1)</td><td>$185 to $385</td></tr>
        <tr><td>Drain-side repair (E DL, Drain, F2)</td><td>$385 to $785</td></tr>
        <tr><td>Heater repair (E hE, Heat, F3)</td><td>$385 to $585</td></tr>
        <tr><td>Spin / motor repair (E SP, Spin, F4)</td><td>$385 to $1,485</td></tr>
        <tr><td>Control board (recurring multiple codes)</td><td>$585 to $985</td></tr>
        <tr><td>Bearing service (long spin / unbalance codes)</td><td>$1,485 to $2,485</td></tr>
        <tr><td>Warranty</td><td>90 days parts and labor</td></tr>
      </tbody>
    </table>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">FAQ</p>
    <h2>Error code questions.</h2>
    <div class="faq-list">
      {faqs.map(f => (<details class="faq-item"><summary>{f.q}</summary><p set:html={f.a}></p></details>))}
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <p class="section-number">Related</p>
    <h2>Commercial laundry across the catalog.</h2>
    <div class="related-grid">
      <a href="/commercial/washer-repair/" class="related-card"><h3>Washer Repair Hub</h3><p>Parent pillar.</p></a>
      <a href="/commercial/washer-repair/not-spinning/" class="related-card"><h3>Not Spinning</h3><p>Drive belt, motor, bearing, door switch.</p></a>
      <a href="/commercial/washer-repair/leaking-water/" class="related-card"><h3>Water Leaking</h3><p>Drain pump, tub seal, gasket diagnostic.</p></a>
      <a href="/commercial/washer-repair/brands/speed-queen/" class="related-card"><h3>Speed Queen</h3><p>Quantum Touch + Gold platform.</p></a>
      <a href="/commercial/washer-repair/brands/continental-girbau/" class="related-card"><h3>Continental Girbau</h3><p>Inwave + Logi Pro platforms.</p></a>
    </div>
  </div>
</section>

<section class="bottom-cta">
  <div class="container">
    <h2>Showing an error code? Brand-specific diagnostic, same-day.</h2>
    <p>All major commercial brands. Code reading shortens troubleshooting 30-50%. $120 commercial, waived with repair. BHGS #A49573 + EPA 608.</p>
    <div class="cta-row">
      <a href={phoneHref} class="btn-primary">☎ Call {phone}</a>
      <a href="/contact/" class="btn-secondary">Book Online</a>
    </div>
  </div>
</section>

</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .section { padding: 72px 24px; }
  .section-gray { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; }
  .container.narrow { max-width: 820px; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  .section h2 { font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 800; margin: 0 0 18px; line-height: 1.2; }
  .section p { font-size: 1rem; line-height: 1.75; margin: 0 0 16px; }
  .section a { color: var(--red); font-weight: 600; text-decoration: none; }
  .section a:hover { text-decoration: underline; }
  .series-h3 { font-size: 1.1rem; font-weight: 800; margin: 28px 0 10px; }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 22px; background: #fff; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
  .price-table th, .price-table td { padding: 12px 16px; text-align: left; border-bottom: 1px solid var(--border); font-size: 0.95rem; }
  .price-table th { background: var(--gray); font-weight: 700; }
  .price-table tr:last-child td { border-bottom: none; }
  .faq-list { margin-top: 24px; }
  .faq-item { background: #fff; border: 1px solid var(--border); border-radius: 6px; padding: 18px 22px; margin-bottom: 12px; }
  .faq-item summary { font-weight: 700; cursor: pointer; font-size: 1rem; list-style: none; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::before { content: "+ "; color: var(--red); font-weight: 800; margin-right: 6px; }
  .faq-item[open] summary::before { content: "− "; }
  .faq-item p { font-size: 0.95rem; line-height: 1.75; margin: 14px 0 0; }
  .related-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 18px; margin-top: 22px; }
  .related-card { display: block; background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 22px; text-decoration: none; color: var(--text); transition: all 0.2s; }
  .related-card:hover { border-color: var(--red); transform: translateY(-2px); box-shadow: 0 4px 14px rgba(0,0,0,0.06); }
  .related-card h3 { font-size: 1rem; font-weight: 800; margin: 0 0 8px; }
  .related-card p { font-size: 0.85rem; color: var(--muted); margin: 0; line-height: 1.6; }
  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { color: #fff; margin: 0 0 14px; font-size: 1.7rem; }
  .bottom-cta p { color: #c9c9c9; margin: 0 0 26px; max-width: 720px; margin-left: auto; margin-right: auto; }
  .cta-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 14px 28px; border-radius: 5px; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 14px 28px; border-radius: 5px; border: 2px solid rgba(255,255,255,0.35); font-weight: 600; text-decoration: none; }
</style>
