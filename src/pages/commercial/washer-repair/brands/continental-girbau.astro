---
// Wave 20, Continental Girbau brand page (Spanish Girbau parent, founded 1958).
// ProSeries on-premise + industrial. Wisconsin US headquarters, Spanish manufacturing.
import Layout from '../../../../layouts/Layout.astro';
import CommercialHero from '../../../../components/CommercialHero.astro';
import { MAIN_PHONE } from '../../../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/commercial/washer-repair/brands/continental-girbau/";

const title = "Continental Washer Repair Los Angeles — Same Day";
const description = "Continental Girbau commercial laundry repair across SoCal. Spanish Girbau parent. Hard-mount + soft-mount washers. BHGS #A49573, EPA 608. $120 dx.";

const faqs = [
  {
    q: "Who owns Continental Girbau?",
    a: "Continental Girbau is the US subsidiary of Girbau, a Spanish commercial laundry equipment manufacturer founded in 1958 in Vic, Spain. Continental Girbau handles US distribution and service from Oshkosh, Wisconsin. The product line is engineered in Spain with Continental adapting some configurations for the US market. The Spanish parent gives Girbau a strong industrial laundry pedigree (European hospital and hospitality markets) that translates into US on-premise positioning."
  },
  {
    q: "What product lines do you service?",
    a: "Full Continental Girbau commercial line. ProSeries E-Series soft-mount washer-extractors (E-Series capacities 20 to 90 lb, on-premise focus). G-Flex industrial soft-mount (90 to 255 lb, large hospital/hospitality). EH industrial hard-mount extractors. Vended ED-Series for coin-op installations. ED4 and ED7 stack washer-dryers. Plus Inwave control system on current models, Logi Pro on legacy. Common parts in 2 to 5 days through Continental Girbau Wisconsin distribution."
  },
  {
    q: "ProSeries E-Series, what's the on-premise advantage?",
    a: "Continental ProSeries E-Series is a soft-mount washer-extractor designed for on-premise hotels, healthcare, and hospitality. The soft-mount spring suspension absorbs spin-extraction loads without requiring a concrete foundation pad with anchor bolts (which most hard-mount industrial machines need). For LA second-floor laundry rooms or retrofits where pad construction isn't feasible, soft-mount is often the only viable option. E-Series capacities range from 20 to 90 lb, covers small-to-medium on-premise operations."
  },
  {
    q: "G-Flex industrial, when is it the right specification?",
    a: "G-Flex covers 90 to 255 lb capacity with the same soft-mount architecture as E-Series, scaled up for large hospital laundry, premium hospitality, and industrial uniform services. The economic argument vs hard-mount competitors: G-Flex eliminates concrete foundation work which can run $5,000 to $20,000 per installation depending on access and existing structure. For new installations in older LA buildings, the savings are real. For new construction with foundation as part of the build, hard-mount competitors (UniMac UW, Speed Queen SC) may be more cost-effective."
  },
  {
    q: "What's the typical Continental Girbau service profile?",
    a: "Common service items: spring suspension components on E-Series and G-Flex (year 10 to 15 typical wear), drum bearing (year 8 to 12 major service, less frequent than hard-mount due to softer load profile on bearings), drain valve assembly, hot-water heating element (LA hard water), Inwave touchscreen module on current models, control board on Logi Pro legacy units, drum gasket. Soft-mount machines have less aggressive bearing wear but require periodic spring suspension service."
  },
  {
    q: "What's the typical cost?",
    a: "Drain valve assembly: $585 to $785. Drum bearing service (E-Series): $1,485 to $1,985. Drum bearing service (G-Flex large): $1,985 to $2,985. Spring suspension component: $385 to $785. Hot-water heating element: $385 to $585. Inwave touchscreen module: $585 to $885. Inverter drive: $785 to $1,485. The $120 commercial diagnostic is waived with repair."
  },
  {
    q: "What's your warranty?",
    a: "90 days SDAR labor and parts. Continental Girbau factory parts warranties processed separately through Wisconsin distribution. BHGS #A49573, EPA 608 Universal #1346255700410, BBB Accredited Business."
  }
];

const schemaJsons = [
  {
    "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair", "url": canonical, "telephone": phone, "priceRange": "$$",
    "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "08:00", "closes": "20:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "00:00", "closes": "00:00" }
      ],
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ]
  },
  {
    "@context": "https://schema.org", "@type": "Service", "@id": canonical + "#service",
    "serviceType": "Continental Girbau Commercial Laundry Repair",
    "name": "Continental Girbau ProSeries Service",
    "url": canonical,
    "description": "Continental Girbau commercial laundry repair across all five SoCal counties. ProSeries E-Series soft-mount washer-extractors (20-90 lb on-premise), G-Flex industrial soft-mount (90-255 lb large hospital/hospitality), EH hard-mount industrial extractors, ED-Series vended coin-op, ED4/ED7 stack washer-dryers. Inwave touchscreen and Logi Pro controls. Spanish Girbau parent (founded 1958 Vic Spain), US headquarters Oshkosh Wisconsin. $120 commercial diagnostic. BHGS #A49573, EPA 608 Universal #1346255700410.",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "120.00", "priceCurrency": "USD", "description": "Commercial diagnostic fee, applied toward repair" } }
  },
  {
    "@context": "https://schema.org", "@type": "Brand", "@id": canonical + "#brand",
    "name": "Continental Girbau", "url": "https://www.continentalgirbau.com/",
    "description": "US subsidiary of Spanish commercial laundry manufacturer Girbau (founded 1958, Vic Spain). US distribution and service from Oshkosh Wisconsin. Specializes in ProSeries soft-mount washer-extractors for on-premise and industrial laundry.",
    "parentOrganization": { "@type": "Organization", "name": "Girbau" }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  {
    "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Commercial", "item": "https://samedayappliance.repair/commercial/" },
      { "@type": "ListItem", "position": 3, "name": "Washer Repair", "item": "https://samedayappliance.repair/commercial/washer-repair/" },
      { "@type": "ListItem", "position": 4, "name": "Continental Girbau", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>

<Fragment slot="head-scripts">
  {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
</Fragment>

<CommercialHero
  title="Continental Girbau Commercial Laundry Repair Los Angeles"
  subtitle={`ProSeries E-Series + G-Flex + EH industrial. Spanish Girbau parent. Soft-mount and hard-mount across LA, OC, Ventura, IE. ${phone}`}
  heroImageTitle="Continental Girbau Commercial Laundry Repair"
  showBranches={true}
/>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Continental Girbau commercial laundry</p>
    <h2>US subsidiary of Spanish Girbau. Soft-mount specialist for on-premise and industrial.</h2>

    <p>Continental Girbau is the US subsidiary of Girbau, a Spanish commercial laundry equipment manufacturer founded in 1958 in Vic, Spain. Continental handles US distribution and service from Oshkosh, Wisconsin. The product line is engineered in Spain with Continental adapting some configurations for the US market. The Spanish parent gives Girbau a strong industrial laundry pedigree, particularly in European hospital and hospitality markets, that translates into US on-premise positioning. In LA's commercial laundry landscape, Continental Girbau is what we see at premium hospitality on-premise installations, second-floor hotel laundry rooms where soft-mount eliminates foundation work, and mid-tier hospital systems.</p>

    <p>We service the full Continental Girbau commercial line: ProSeries E-Series soft-mount washer-extractors (20 to 90 lb on-premise), G-Flex industrial soft-mount (90 to 255 lb large hospital/hospitality), EH hard-mount industrial extractors, ED-Series vended coin-op, ED4 and ED7 stack washer-dryers, plus Inwave touchscreen on current models and Logi Pro on legacy. Common parts arrive in 2 to 5 days through Wisconsin distribution.</p>

    <p>$120 commercial diagnostic, waived with repair. BHGS #A49573 + EPA 608 Universal #1346255700410. We service Continental Girbau across LA, Orange, Ventura, San Bernardino, and Riverside counties.</p>
  </div>
</section>

<section class="section section-gray">
  <div class="container">
    <p class="section-number">Soft-mount advantage</p>
    <h2>Why soft-mount matters for LA installations.</h2>

    <p>The defining feature of the Continental ProSeries lineup is soft-mount architecture. Hard-mount industrial machines (UniMac UW, Speed Queen SC, Milnor V-Series) require concrete foundation pads with anchor bolts to absorb the spin-extraction loads. Soft-mount machines use spring suspension internal to the frame to absorb those loads, eliminating the foundation requirement. For LA second-floor laundry rooms, retrofits in older buildings, or installations where pad construction isn't feasible, soft-mount is often the only viable option.</p>

    <p>The economic argument: foundation work for hard-mount installations runs $5,000 to $20,000 per machine depending on access, existing structure, and required structural reinforcement. Soft-mount eliminates that. The trade-off is slightly higher up-front equipment cost and periodic spring suspension service (year 10 to 15 typical), but for retrofit installations the math usually favors soft-mount. New construction with foundation as part of the build can go either way.</p>

    <h3 class="series-h3">ProSeries E-Series (20 to 90 lb on-premise)</h3>
    <p>Soft-mount E-Series covers small-to-medium on-premise operations: boutique hotels, smaller healthcare facilities, mid-tier hospitality. The 20 lb model fits in tight LA boutique-hotel laundry rooms where larger industrial doesn't. The 90 lb model handles full hotel-housekeeping volumes for properties up to about 200 rooms.</p>

    <h3 class="series-h3">G-Flex industrial (90 to 255 lb)</h3>
    <p>Same soft-mount architecture scaled up for large hospital laundry, premium hospitality, and industrial uniform services. Spring suspension scaled accordingly; service patterns mirror E-Series with larger-format parts. We see G-Flex at full-service downtown LA hotels and mid-tier hospital linen-services.</p>

    <h3 class="series-h3">EH hard-mount industrial extractors</h3>
    <p>The hard-mount option for installations where soft-mount isn't required. Same Girbau engineering as ProSeries but with conventional hard-mount foundation requirements. Used when foundation construction is part of new builds and the cost-savings of soft-mount aren't relevant.</p>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Common Continental Girbau failures</p>
    <h2>What we see on service calls.</h2>

    <ul class="reasons-list">
      <li><strong>Spring suspension component (year 10 to 15)</strong>, the defining soft-mount maintenance item. Springs lose tension or develop fatigue cracks. Replacement runs $385 to $785 per spring; full set service on E-Series typically runs $1,485 to $2,485.</li>
      <li><strong>Drum bearing (year 8 to 12 major)</strong>, less aggressive wear than hard-mount due to softer load profile, but still the major mid-life service. Replacement $1,485 to $2,985 depending on capacity.</li>
      <li><strong>Drain valve assembly</strong>, solenoid coil or seat failure. $585 to $785.</li>
      <li><strong>Hot-water heating element (year 6 to 9 in LA hard water)</strong>, calcium scale builds up. Annual descaling extends life. Replacement $385 to $585.</li>
      <li><strong>Inwave touchscreen module (year 6 to 10)</strong>, touch input degrades on current-generation control. Module replacement $585 to $885.</li>
      <li><strong>Logi Pro control board (legacy units year 8 to 12)</strong>, main control board fails, triggering miscellaneous error states. Replacement $585 to $885.</li>
      <li><strong>Drum gasket</strong>, seals drum to cabinet. Year 8 to 12. Replacement $485 to $785.</li>
      <li><strong>Inverter drive</strong>, VFD that drives drum motor. Year 8 to 12. Replacement $785 to $1,485.</li>
    </ul>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">Pricing</p>
    <h2>Continental Girbau service costs.</h2>
    <table class="price-table">
      <thead><tr><th>Repair</th><th>Typical Cost</th></tr></thead>
      <tbody>
        <tr><td>Diagnostic (waived with repair)</td><td>$120</td></tr>
        <tr><td>Spring suspension component (single)</td><td>$385 to $785</td></tr>
        <tr><td>Spring suspension full set (E-Series)</td><td>$1,485 to $2,485</td></tr>
        <tr><td>Drum bearing service (E-Series)</td><td>$1,485 to $1,985</td></tr>
        <tr><td>Drum bearing service (G-Flex large)</td><td>$1,985 to $2,985</td></tr>
        <tr><td>Drain valve assembly</td><td>$585 to $785</td></tr>
        <tr><td>Hot-water heating element</td><td>$385 to $585</td></tr>
        <tr><td>Inwave touchscreen module</td><td>$585 to $885</td></tr>
        <tr><td>Logi Pro control board</td><td>$585 to $885</td></tr>
        <tr><td>Drum gasket</td><td>$485 to $785</td></tr>
        <tr><td>Inverter drive</td><td>$785 to $1,485</td></tr>
        <tr><td>Warranty</td><td>90 days parts and labor</td></tr>
      </tbody>
    </table>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">FAQ</p>
    <h2>Continental Girbau questions.</h2>
    <div class="faq-list">
      {faqs.map(f => (<details class="faq-item"><summary>{f.q}</summary><p set:html={f.a}></p></details>))}
    </div>
  </div>
</section>

<section class="section section-gray">
  <div class="container">
    <p class="section-number">Related</p>
    <h2>Commercial laundry across the catalog.</h2>
    <div class="related-grid">
      <a href="/commercial/washer-repair/" class="related-card"><h3>Washer Repair Hub</h3><p>Parent pillar.</p></a>
      <a href="/commercial/washer-repair/brands/speed-queen/" class="related-card"><h3>Speed Queen</h3><p>Alliance hard-mount + coin-op.</p></a>
      <a href="/commercial/washer-repair/brands/unimac/" class="related-card"><h3>UniMac</h3><p>Alliance on-premise hard-mount.</p></a>
      <a href="/commercial/washer-repair/brands/wascomat/" class="related-card"><h3>Wascomat</h3><p>European industrial competitor.</p></a>
      <a href="/commercial/washer-repair/on-premise-laundry-repair/" class="related-card"><h3>On-Premise Laundry</h3><p>Hospitality + healthcare service.</p></a>
    </div>
  </div>
</section>

<section class="bottom-cta">
  <div class="container">
    <h2>Continental Girbau down? Soft-mount + industrial across LA.</h2>
    <p>ProSeries E-Series + G-Flex + EH. Spanish Girbau parent, Wisconsin distribution. $120 commercial, waived with repair. BHGS #A49573 + EPA 608.</p>
    <div class="cta-row">
      <a href={phoneHref} class="btn-primary">☎ Call {phone}</a>
      <a href="/contact/" class="btn-secondary">Book Online</a>
    </div>
  </div>
</section>

</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .section { padding: 72px 24px; }
  .section-gray { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; }
  .container.narrow { max-width: 820px; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  .section h2 { font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 800; margin: 0 0 18px; line-height: 1.2; }
  .section p { font-size: 1rem; line-height: 1.75; margin: 0 0 16px; }
  .section a { color: var(--red); font-weight: 600; text-decoration: none; }
  .section a:hover { text-decoration: underline; }
  .series-h3 { font-size: 1.1rem; font-weight: 800; margin: 28px 0 10px; }
  .reasons-list { padding-left: 22px; margin: 18px 0 0; }
  .reasons-list li { font-size: 1rem; line-height: 1.75; margin-bottom: 10px; }
  .reasons-list strong { font-weight: 700; }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 22px; background: #fff; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
  .price-table th, .price-table td { padding: 12px 16px; text-align: left; border-bottom: 1px solid var(--border); font-size: 0.95rem; }
  .price-table th { background: var(--gray); font-weight: 700; }
  .price-table tr:last-child td { border-bottom: none; }
  .faq-list { margin-top: 24px; }
  .faq-item { background: #fff; border: 1px solid var(--border); border-radius: 6px; padding: 18px 22px; margin-bottom: 12px; }
  .faq-item summary { font-weight: 700; cursor: pointer; font-size: 1rem; list-style: none; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::before { content: "+ "; color: var(--red); font-weight: 800; margin-right: 6px; }
  .faq-item[open] summary::before { content: "− "; }
  .faq-item p { font-size: 0.95rem; line-height: 1.75; margin: 14px 0 0; }
  .related-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 18px; margin-top: 22px; }
  .related-card { display: block; background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 22px; text-decoration: none; color: var(--text); transition: all 0.2s; }
  .related-card:hover { border-color: var(--red); transform: translateY(-2px); box-shadow: 0 4px 14px rgba(0,0,0,0.06); }
  .related-card h3 { font-size: 1rem; font-weight: 800; margin: 0 0 8px; }
  .related-card p { font-size: 0.85rem; color: var(--muted); margin: 0; line-height: 1.6; }
  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { color: #fff; margin: 0 0 14px; font-size: 1.7rem; }
  .bottom-cta p { color: #c9c9c9; margin: 0 0 26px; max-width: 720px; margin-left: auto; margin-right: auto; }
  .cta-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 14px 28px; border-radius: 5px; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 14px 28px; border-radius: 5px; border: 2px solid rgba(255,255,255,0.35); font-weight: 600; text-decoration: none; }
</style>
