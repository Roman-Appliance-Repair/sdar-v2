---
// Wave 20, Fagor Industrial brand page (Onnera Group, Spanish).
// KEY: replaces Fagor washing-machine temp redirect target deferred from Wave 16.
// IMPORTANT: Fagor Industrial ≠ Fagor residential consumer brand (different companies).
import Layout from '../../../../layouts/Layout.astro';
import CommercialHero from '../../../../components/CommercialHero.astro';
import { MAIN_PHONE } from '../../../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/commercial/washer-repair/brands/fagor-industrial/";

const title = "Fagor Industrial Washer Repair Los Angeles — Same Day";
const description = "Fagor Industrial commercial laundry repair across SoCal. Onnera Group Spanish parent. Front-load + barrier washers. BHGS #A49573, EPA 608. $120 dx.";

const faqs = [
  {
    q: "Is Fagor Industrial the same as Fagor home appliance brand?",
    a: "No. This is one of the most common confusions in the Fagor world. Fagor Industrial is owned by Onnera Group (Spanish), focused exclusively on commercial and industrial equipment for foodservice, laundry, and refrigeration. Fagor's residential consumer brand has had a separate corporate history, Fagor Electrodomésticos (the residential consumer business) entered Spanish bankruptcy proceedings in 2013, with brand rights and operations subsequently restructured. The residential and industrial brands are distinct companies with distinct ownership, distinct product lines, distinct parts networks. We service Fagor Industrial commercial equipment; the residential consumer brand has separate service channels."
  },
  {
    q: "What Fagor Industrial laundry models do you service?",
    a: "Full Fagor Industrial commercial laundry line. LA-series washer-extractors (LA-11, LA-13, LA-18, LA-25, LA-35, LA-60, LA-90, capacities 11 to 90 kg / 24 to 198 lb). LR-series rigid-mount extractors. LN-series soft-mount extractors. SR-series drying tumblers (matching dryer side). Plus PS-series ironers and folders for full-laundry-train operations. Onnera Group parts come through their US distribution network; common items in 5 to 10 days because the European supply chain runs longer than American-manufactured competitors."
  },
  {
    q: "Why do operators specify Fagor Industrial?",
    a: "Three reasons we hear in LA. (1) Hospital-grade engineering, Fagor Industrial has strong European hospital laundry market share and the engineering carries to US installations. (2) Onnera Group bundle, operations specifying Fagor commercial dishwashing or refrigeration sometimes specify Fagor Industrial laundry as a single-brand procurement. (3) Capacity options, the LA-series covers 24 to 198 lb in metric increments that don't exactly match American competitor capacity points, sometimes fitting an operational requirement better."
  },
  {
    q: "Are parts available for Fagor Industrial in LA?",
    a: "Common parts come through Onnera Group US distribution and arrive in 5 to 10 days, longer than American-manufactured competitors but workable for scheduled service. Less common parts can take 2 to 4 weeks via international supply chain from Spain. We pre-confirm parts availability and timeline at the diagnostic visit. For operations where rapid parts turnaround matters more than the brand-specific advantages, an American-manufactured alternative (Speed Queen, UniMac, Dexter) may be the better fit."
  },
  {
    q: "What's the typical Fagor Industrial service profile?",
    a: "Common service items: drum bearing service (year 8 to 12 major), drain valve assembly, door lock and switch, drum gasket, inverter drive, hot water heating element (LA hard water), control board on current-generation electronic models. Fagor Industrial machines tend to use European-spec components throughout, which means familiarity with European service documentation rather than American service documentation. Our techs are equipped for both."
  },
  {
    q: "What's the typical cost?",
    a: "Drain valve assembly: $585 to $785. Door lock + switch: $245 to $385. Drum bearing service: $1,485 to $2,485. Drum gasket: $485 to $785. Inverter drive: $785 to $1,485. Hot water heating element: $385 to $585. Control board: $585 to $985. Spring suspension service (LN-series soft-mount): $385 to $885. The $120 commercial diagnostic is waived with repair."
  },
  {
    q: "What's your warranty?",
    a: "90 days SDAR labor and parts. Onnera Group factory parts warranties processed separately. BHGS #A49573, EPA 608 Universal #1346255700410, BBB A+ accredited."
  }
];

const schemaJsons = [
  {
    "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair", "url": canonical, "telephone": phone, "priceRange": "$$",
    "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "08:00", "closes": "20:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "00:00", "closes": "00:00" }
      ],
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ]
  },
  {
    "@context": "https://schema.org", "@type": "Service", "@id": canonical + "#service",
    "serviceType": "Fagor Industrial Commercial Laundry Repair",
    "name": "Fagor Industrial LA, LR, LN, SR Service",
    "url": canonical,
    "description": "Fagor Industrial commercial laundry repair across all five SoCal counties. LA-series washer-extractors (LA-11, LA-13, LA-18, LA-25, LA-35, LA-60, LA-90, 11-90 kg / 24-198 lb), LR-series rigid-mount extractors, LN-series soft-mount extractors, SR-series drying tumblers, PS-series ironers and folders. Onnera Group Spanish parent. NOT same company as Fagor residential consumer brand. $120 commercial diagnostic. BHGS #A49573, EPA 608 Universal #1346255700410.",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "120.00", "priceCurrency": "USD", "description": "Commercial diagnostic fee, applied toward repair" } }
  },
  {
    "@context": "https://schema.org", "@type": "Brand", "@id": canonical + "#brand",
    "name": "Fagor Industrial", "url": "https://www.fagorindustrial.com/",
    "description": "Commercial and industrial equipment manufacturer for foodservice, laundry, and refrigeration. Owned by Onnera Group (Spanish). Distinct corporate entity from the Fagor residential consumer appliance brand.",
    "parentOrganization": { "@type": "Organization", "name": "Onnera Group" }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  {
    "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Commercial", "item": "https://samedayappliance.repair/commercial/" },
      { "@type": "ListItem", "position": 3, "name": "Washer Repair", "item": "https://samedayappliance.repair/commercial/washer-repair/" },
      { "@type": "ListItem", "position": 4, "name": "Fagor Industrial", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>

<Fragment slot="head-scripts">
  {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
</Fragment>

<CommercialHero
  title="Fagor Industrial Commercial Laundry Repair Los Angeles"
  subtitle={`LA-series washer-extractors, LR rigid-mount, LN soft-mount, SR drying tumblers. Onnera Group Spanish parent. NOT same company as Fagor residential. ${phone}`}
  heroImageTitle="Fagor Industrial Commercial Laundry Repair"
  showBranches={true}
/>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Fagor Industrial commercial laundry</p>
    <h2>Onnera Group Spanish manufacturer. Distinct from the Fagor residential consumer brand.</h2>

    <p><strong>Important disambiguation:</strong> Fagor Industrial is a commercial and industrial equipment manufacturer owned by Onnera Group (Spanish), focused exclusively on commercial foodservice, commercial laundry, and commercial refrigeration. The Fagor residential consumer appliance brand (washing machines, dishwashers, refrigerators for home use) has had a separate corporate history, Fagor Electrodomésticos, the residential consumer business, entered Spanish bankruptcy proceedings in 2013, with brand rights and operations subsequently restructured. The residential and industrial brands are distinct companies with distinct ownership, distinct product lines, and distinct parts networks. This page covers Fagor Industrial commercial laundry; if you have a Fagor residential consumer washing machine, that's a separate service category.</p>

    <p>We service the full Fagor Industrial commercial laundry line: LA-series washer-extractors (LA-11, LA-13, LA-18, LA-25, LA-35, LA-60, LA-90, covering 11 to 90 kg or 24 to 198 lb capacity), LR-series rigid-mount extractors, LN-series soft-mount extractors, SR-series drying tumblers (the matching dryer side), and PS-series ironers and folders for full-laundry-train operations. Onnera Group parts come through their US distribution; common items in 5 to 10 days, longer than American-manufactured competitors but workable for scheduled service.</p>

    <p>$120 commercial diagnostic, waived with repair. BHGS #A49573 + EPA 608 Universal #1346255700410. We service Fagor Industrial across LA, Orange, Ventura, San Bernardino, and Riverside counties.</p>
  </div>
</section>

<section class="section section-gray">
  <div class="container">
    <p class="section-number">Why Fagor Industrial</p>
    <h2>Three reasons LA operations specify Fagor Industrial.</h2>

    <h3 class="series-h3">1. Hospital-grade engineering pedigree</h3>
    <p>Fagor Industrial has strong European hospital laundry market share. The engineering carries to US installations, chemical injection plumbing, sanitization cycle programming, hot-water capacity sizing, all reflect European hospital laundry requirements that translate well to LA hospital, dialysis, and assisted-living installations.</p>

    <h3 class="series-h3">2. Onnera Group single-brand procurement bundle</h3>
    <p>Operations that already specify Fagor commercial dishwashing or refrigeration sometimes specify Fagor Industrial laundry as part of a single-brand procurement strategy. The procurement simplification (single vendor, single warranty management, consistent service relationship) has real operational value for larger operations. We see this most often in LA hospital systems where the procurement team standardizes on Onnera Group across multiple equipment categories.</p>

    <h3 class="series-h3">3. Capacity points that don't match American competitors</h3>
    <p>Fagor Industrial LA-series uses metric capacity increments (11, 13, 18, 25, 35, 60, 90 kg) that don't exactly match American competitor capacity points (typically 25, 40, 60, 80 lb tiers). For operations with specific capacity requirements that fall between American tiers, the Fagor metric tiering can fit better.</p>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Common Fagor Industrial failures</p>
    <h2>What we see on service calls.</h2>

    <ul class="reasons-list">
      <li><strong>Drum bearing service (year 8 to 12 major)</strong>, major mid-life service. $1,485 to $2,485.</li>
      <li><strong>Drain valve assembly</strong>, solenoid coil burnout. $585 to $785.</li>
      <li><strong>Door lock + switch</strong>, high-cycle wear. $245 to $385.</li>
      <li><strong>Drum gasket (year 8 to 12)</strong>, seals drum to cabinet. $485 to $785.</li>
      <li><strong>Inverter drive (year 8 to 12)</strong>, VFD failure. $785 to $1,485.</li>
      <li><strong>Hot water heating element</strong>, LA hard water scales the element. $385 to $585.</li>
      <li><strong>Control board on current-generation</strong>, main board failure. $585 to $985.</li>
      <li><strong>LN-series spring suspension service (year 10 to 15)</strong>, soft-mount spring component replacement. $385 to $885.</li>
      <li><strong>Chemical injection plumbing</strong>, solenoid valve or check valve in chemical inlet manifold. $245 to $385.</li>
    </ul>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">Pricing</p>
    <h2>Fagor Industrial service costs.</h2>
    <table class="price-table">
      <thead><tr><th>Repair</th><th>Typical Cost</th></tr></thead>
      <tbody>
        <tr><td>Diagnostic (waived with repair)</td><td>$120</td></tr>
        <tr><td>Drain valve assembly</td><td>$585 to $785</td></tr>
        <tr><td>Door lock + switch</td><td>$245 to $385</td></tr>
        <tr><td>Drum bearing service</td><td>$1,485 to $2,485</td></tr>
        <tr><td>Drum gasket</td><td>$485 to $785</td></tr>
        <tr><td>Inverter drive</td><td>$785 to $1,485</td></tr>
        <tr><td>Hot water heating element</td><td>$385 to $585</td></tr>
        <tr><td>Control board</td><td>$585 to $985</td></tr>
        <tr><td>LN spring suspension service</td><td>$385 to $885</td></tr>
        <tr><td>Chemical injection valve</td><td>$245 to $385</td></tr>
        <tr><td>Warranty</td><td>90 days parts and labor</td></tr>
      </tbody>
    </table>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">FAQ</p>
    <h2>Fagor Industrial questions.</h2>
    <div class="faq-list">
      {faqs.map(f => (<details class="faq-item"><summary>{f.q}</summary><p set:html={f.a}></p></details>))}
    </div>
  </div>
</section>

<section class="section section-gray">
  <div class="container">
    <p class="section-number">Related</p>
    <h2>Commercial laundry across the catalog.</h2>
    <div class="related-grid">
      <a href="/commercial/washer-repair/" class="related-card"><h3>Washer Repair Hub</h3><p>Parent pillar.</p></a>
      <a href="/commercial/washer-repair/brands/wascomat/" class="related-card"><h3>Wascomat</h3><p>Electrolux Professional European competitor.</p></a>
      <a href="/commercial/washer-repair/brands/continental-girbau/" class="related-card"><h3>Continental Girbau</h3><p>Spanish Girbau commercial.</p></a>
      <a href="/commercial/washer-repair/brands/milnor/" class="related-card"><h3>Pellerin Milnor</h3><p>Independent Louisiana industrial.</p></a>
      <a href="/commercial/washer-repair/on-premise-laundry-repair/" class="related-card"><h3>On-Premise Laundry</h3><p>Hospitality + healthcare service.</p></a>
    </div>
  </div>
</section>

<section class="bottom-cta">
  <div class="container">
    <h2>Fagor Industrial down? Onnera Group commercial laundry across LA.</h2>
    <p>LA-series + LR + LN extractors, SR dryers, PS ironers. NOT same as Fagor residential. $120 commercial, waived with repair. BHGS #A49573 + EPA 608.</p>
    <div class="cta-row">
      <a href={phoneHref} class="btn-primary">☎ Call {phone}</a>
      <a href="/contact/" class="btn-secondary">Book Online</a>
    </div>
  </div>
</section>

</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .section { padding: 72px 24px; }
  .section-gray { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; }
  .container.narrow { max-width: 820px; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  .section h2 { font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 800; margin: 0 0 18px; line-height: 1.2; }
  .section p { font-size: 1rem; line-height: 1.75; margin: 0 0 16px; }
  .section a { color: var(--red); font-weight: 600; text-decoration: none; }
  .section a:hover { text-decoration: underline; }
  .series-h3 { font-size: 1.1rem; font-weight: 800; margin: 28px 0 10px; }
  .reasons-list { padding-left: 22px; margin: 18px 0 0; }
  .reasons-list li { font-size: 1rem; line-height: 1.75; margin-bottom: 10px; }
  .reasons-list strong { font-weight: 700; }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 22px; background: #fff; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
  .price-table th, .price-table td { padding: 12px 16px; text-align: left; border-bottom: 1px solid var(--border); font-size: 0.95rem; }
  .price-table th { background: var(--gray); font-weight: 700; }
  .price-table tr:last-child td { border-bottom: none; }
  .faq-list { margin-top: 24px; }
  .faq-item { background: #fff; border: 1px solid var(--border); border-radius: 6px; padding: 18px 22px; margin-bottom: 12px; }
  .faq-item summary { font-weight: 700; cursor: pointer; font-size: 1rem; list-style: none; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::before { content: "+ "; color: var(--red); font-weight: 800; margin-right: 6px; }
  .faq-item[open] summary::before { content: "− "; }
  .faq-item p { font-size: 0.95rem; line-height: 1.75; margin: 14px 0 0; }
  .related-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 18px; margin-top: 22px; }
  .related-card { display: block; background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 22px; text-decoration: none; color: var(--text); transition: all 0.2s; }
  .related-card:hover { border-color: var(--red); transform: translateY(-2px); box-shadow: 0 4px 14px rgba(0,0,0,0.06); }
  .related-card h3 { font-size: 1rem; font-weight: 800; margin: 0 0 8px; }
  .related-card p { font-size: 0.85rem; color: var(--muted); margin: 0; line-height: 1.6; }
  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { color: #fff; margin: 0 0 14px; font-size: 1.7rem; }
  .bottom-cta p { color: #c9c9c9; margin: 0 0 26px; max-width: 720px; margin-left: auto; margin-right: auto; }
  .cta-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 14px 28px; border-radius: 5px; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 14px 28px; border-radius: 5px; border: 2px solid rgba(255,255,255,0.35); font-weight: 600; text-decoration: none; }
</style>
