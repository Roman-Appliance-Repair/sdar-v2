---
// Wave 20, UniMac brand page (Alliance Laundry Systems sister to Speed Queen).
// Founded as separate UniMac brand under Alliance for on-premise laundry focus.
// Hospitals, hotels, healthcare, prisons, large hospitality.
import Layout from '../../../../layouts/Layout.astro';
import CommercialHero from '../../../../components/CommercialHero.astro';
import { MAIN_PHONE } from '../../../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/commercial/washer-repair/brands/unimac/";

const title = "UniMac Washer Repair Los Angeles — Same Day";
const description = "UniMac on-premise laundry repair across SoCal. Alliance Laundry Systems Ripon WI. Hotels, hospitals, healthcare. EPA 608.";

const faqs = [
  {
    q: "Is UniMac the same company as Speed Queen?",
    a: "Same parent (Alliance Laundry Systems, Ripon, Wisconsin), same manufacturing facility, but positioned for different markets. UniMac focuses on on-premise laundry, hotels, hospitals, healthcare facilities, prisons, large hospitality operations. Speed Queen serves coin-op laundromats and lighter on-premise. Many components cross-fit between equivalent UniMac and Speed Queen models. We service both with the same diagnostic approach and parts network."
  },
  {
    q: "What UniMac product lines do you service?",
    a: "Full UniMac on-premise line. UW-series hard-mount washer-extractors (60 to 275 lb capacity), UY-series soft-mount washer-extractors (35 to 200 lb capacity), UC-series industrial washer-extractors, plus matching UniLinc tumble dryers for the laundry train. We carry common parts and access Alliance Laundry Systems regional distribution for less common items in 1 to 3 days."
  },
  {
    q: "Why does on-premise laundry favor UniMac over coin-op brands?",
    a: "On-premise operations (hospital, hotel, healthcare) run different load patterns than coin-op laundromats, fewer cycles per day per machine but heavier loads, hot water requirements, and integration with chemical injection systems. UniMac's UW and UY platforms are designed for that load profile with heavier-duty motors, higher-capacity heating elements, and chemical injection plumbing standard. Coin-op machines can be installed on-premise but they wear faster under continuous heavy load."
  },
  {
    q: "What's the typical UniMac service profile?",
    a: "On-premise UniMac in LA hotels and hospitals typically runs 8 to 14 hours per day with heavier loads than coin-op. Common service items: bearing and seal kit on washer-extractor tubs (year 8 to 12, major service), drain valve assembly (year 5 to 8), chemical injection plumbing seals (year 5 to 7), hot-water heating element (year 6 to 9 in LA hard water), inverter drive (year 8 to 12), drum gasket (year 6 to 10). Bearing service is the major mid-life expense."
  },
  {
    q: "Do you service the chemical injection systems on UniMac washers?",
    a: "Yes. UniMac on-premise washers integrate with chemical injection systems (Ecolab, Diversey, Hydro Systems and others) for detergent, bleach, sour, softener auto-dispensing. Common service: solenoid valves on each chemical line, check valves preventing back-flow, plumbing fittings at the chemical inlet manifold. Most chemical injection failures present as cycle running normally but linen quality degrading because chemistry isn't being delivered. We diagnose at the cycle level and repair the failed component."
  },
  {
    q: "What's the typical cost?",
    a: "Drain valve assembly: $585 to $785. Door lock + switch: $245 to $385. Bearing + seal kit major service: $1,485 to $2,485. Chemical injection valve replacement: $245 to $385. Hot-water heating element: $385 to $585. Inverter drive: $785 to $1,285. UniLinc dryer service items run separately. The $120 commercial diagnostic is waived with repair."
  },
  {
    q: "What's your warranty?",
    a: "90 days SDAR labor and parts. Alliance Laundry Systems parts warranties processed separately. BHGS #A49573, EPA 608 Universal #1346255700410, BBB Accredited Business."
  }
];

const schemaJsons = [
  {
    "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair", "url": canonical, "telephone": phone, "priceRange": "$$",
    "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "08:00", "closes": "20:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "00:00", "closes": "00:00" }
      ],
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ]
  },
  {
    "@context": "https://schema.org", "@type": "Service", "@id": canonical + "#service",
    "serviceType": "UniMac Commercial Laundry Repair",
    "name": "UniMac On-Premise Laundry Service",
    "url": canonical,
    "description": "UniMac on-premise commercial laundry repair across all five SoCal counties. UW-series hard-mount washer-extractors (60-275 lb), UY-series soft-mount (35-200 lb), UC-series industrial, UniLinc tumble dryers. Hotels, hospitals, healthcare, prisons, large hospitality. Chemical injection system service. Alliance Laundry Systems Ripon WI parts network. $120 commercial diagnostic. BHGS #A49573, EPA 608 Universal #1346255700410.",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "120.00", "priceCurrency": "USD", "description": "Commercial diagnostic fee, applied toward repair" } }
  },
  {
    "@context": "https://schema.org", "@type": "Brand", "@id": canonical + "#brand",
    "name": "UniMac", "url": "https://www.unimac.com/",
    "description": "On-premise commercial laundry equipment brand under Alliance Laundry Systems. Sister brand to Speed Queen. Manufactured in Ripon, Wisconsin. Specializes in on-premise hospitality, healthcare, and institutional laundry.",
    "parentOrganization": { "@type": "Organization", "name": "Alliance Laundry Systems" }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  {
    "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Commercial", "item": "https://samedayappliance.repair/commercial/" },
      { "@type": "ListItem", "position": 3, "name": "Washer Repair", "item": "https://samedayappliance.repair/commercial/washer-repair/" },
      { "@type": "ListItem", "position": 4, "name": "UniMac", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>

<Fragment slot="head-scripts">
  {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
</Fragment>

<CommercialHero
  title="UniMac On-Premise Laundry Repair Los Angeles"
  subtitle={`UW + UY + UC washer-extractors, UniLinc dryers. Hotels, hospitals, healthcare, prisons. Alliance Laundry Systems Ripon WI. Same-day across LA, OC, Ventura. ${phone}`}
  heroImageTitle="UniMac On-Premise Laundry Repair"
  showBranches={true}
/>

<section class="section">
  <div class="container narrow">
    <p class="section-number">UniMac on-premise laundry</p>
    <h2>Alliance Laundry Systems' on-premise specialist. Sister brand to Speed Queen.</h2>

    <p>UniMac and Speed Queen share a parent (Alliance Laundry Systems) and a Ripon, Wisconsin manufacturing facility, but they're positioned for different markets. UniMac focuses on on-premise laundry: hotels, hospitals, healthcare facilities, prisons, large hospitality operations. The product lines are engineered for the load profile that on-premise operations actually run, fewer cycles per day per machine but heavier loads with hot water and chemical injection integration. In LA's hospitality and healthcare landscape, UniMac is what we see at most full-service hotel laundry rooms, hospital linen-services, and large assisted-living facilities.</p>

    <p>We service the full UniMac line: UW-series hard-mount washer-extractors (60 to 275 lb capacity), UY-series soft-mount washer-extractors (35 to 200 lb capacity), UC-series industrial washer-extractors, plus matching UniLinc tumble dryers for the complete laundry train. Common parts on the truck; less common arrive in 1 to 3 days through Alliance regional distribution. $120 commercial diagnostic, waived with repair. BHGS #A49573 + EPA 608 Universal #1346255700410.</p>
  </div>
</section>

<section class="section section-gray">
  <div class="container">
    <p class="section-number">Product lines we service</p>
    <h2>Hard-mount, soft-mount, industrial.</h2>

    <h3 class="series-h3">UW-series hard-mount washer-extractors (60 to 275 lb)</h3>
    <p>The on-premise workhorse. Hard-mount means foundation requirements (concrete pad with anchor bolts) but eliminates the suspension complexity of soft-mount machines. Standard for hospital linen-services and hotel laundry rooms in LA. Common service: bearing and seal kit (year 8 to 12 major), drain valve assembly, hot-water heating element (year 6 to 9 in LA hard water), inverter drive (year 8 to 12), chemical injection valves, drum gasket.</p>

    <h3 class="series-h3">UY-series soft-mount washer-extractors (35 to 200 lb)</h3>
    <p>Soft-mount equivalent of UW. Spring suspension absorbs spin-extraction loads, eliminates foundation requirement. Used in second-floor laundry installations or where new concrete pads aren't feasible. Common service: spring suspension components (year 10 to 15), drum bearing (year 8 to 12), inverter drive, drain valve. Slightly more service-intensive than hard-mount over equivalent service life.</p>

    <h3 class="series-h3">UC-series industrial washer-extractors</h3>
    <p>The largest UniMac platform, 200+ lb capacity industrial washers for prison laundry, large hospital systems, and industrial uniform services. Tunnel-washer competitor at the bigger end of the line. Service items mirror UW with industrial-grade parts and the same Alliance distribution network.</p>

    <h3 class="series-h3">UniLinc tumble dryers (paired with UW/UY/UC)</h3>
    <p>The dryer half of the UniMac laundry train. 30 to 200 lb capacity. Common service: gas valve assembly, igniter, blower motor, lint accumulation in the burner box (annual cleaning prevents fire risk), drum bearing (year 10 to 15), control board.</p>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">On-premise specifics</p>
    <h2>What's different about on-premise laundry vs coin-op.</h2>

    <p>On-premise laundry equipment runs a different load profile than coin-op laundromat equipment. Three differences matter for service.</p>

    <h3 class="series-h3">Hot-water requirements</h3>
    <p>Hospital and hotel laundry needs hot water for sanitization, sour rinse, and stain removal protocols. UniMac UW and UY include hot-water heating elements that coin-op vended machines typically don't have. The heating element is a major LA service item because municipal water at 300 to 400 mg/L TDS scales the element rapidly. Annual descaling extends element life from 5 years to 8+. Replacement runs $385 to $585.</p>

    <h3 class="series-h3">Chemical injection integration</h3>
    <p>On-premise washers integrate with chemical injection systems (Ecolab, Diversey, Hydro Systems, others) for detergent, bleach, sour, softener auto-dispensing. The plumbing on the back of UniMac UW and UY units has multiple chemical inlet ports, each with a check valve and solenoid. Failures in the chemical injection plumbing present as cycle running normally but linen quality degrading because chemistry isn't being delivered. We diagnose at the cycle level.</p>

    <h3 class="series-h3">Continuous duty cycle</h3>
    <p>On-premise equipment runs 8 to 14 hours per day in LA hospital and large hotel operations, versus coin-op which sees variable use. Bearing wear, motor wear, and drum gasket degradation timing is shifted earlier on heavy on-premise use. The major mid-life service (bearing + seal kit) typically arrives at year 8 to 10 on heavily used UW machines vs year 10 to 12 on lighter use.</p>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">Pricing</p>
    <h2>UniMac service costs.</h2>
    <table class="price-table">
      <thead><tr><th>Repair</th><th>Typical Cost</th></tr></thead>
      <tbody>
        <tr><td>Diagnostic (waived with repair)</td><td>$120</td></tr>
        <tr><td>Drain valve assembly</td><td>$585 to $785</td></tr>
        <tr><td>Door lock + switch</td><td>$245 to $385</td></tr>
        <tr><td>Hot-water heating element</td><td>$385 to $585</td></tr>
        <tr><td>Bearing + seal kit (major service)</td><td>$1,485 to $2,485</td></tr>
        <tr><td>Chemical injection valve</td><td>$245 to $385</td></tr>
        <tr><td>Inverter drive</td><td>$785 to $1,285</td></tr>
        <tr><td>Drum gasket</td><td>$485 to $785</td></tr>
        <tr><td>UniLinc dryer gas valve</td><td>$385 to $585</td></tr>
        <tr><td>Warranty</td><td>90 days parts and labor</td></tr>
      </tbody>
    </table>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">FAQ</p>
    <h2>UniMac questions.</h2>
    <div class="faq-list">
      {faqs.map(f => (<details class="faq-item"><summary>{f.q}</summary><p set:html={f.a}></p></details>))}
    </div>
  </div>
</section>

<section class="section section-gray">
  <div class="container">
    <p class="section-number">Related</p>
    <h2>Commercial laundry across the catalog.</h2>
    <div class="related-grid">
      <a href="/commercial/washer-repair/" class="related-card"><h3>Washer Repair Hub</h3><p>Parent pillar.</p></a>
      <a href="/commercial/washer-repair/brands/speed-queen/" class="related-card"><h3>Speed Queen</h3><p>Alliance sister brand, coin-op flagship.</p></a>
      <a href="/commercial/washer-repair/brands/milnor/" class="related-card"><h3>Milnor</h3><p>Independent industrial tunnel washers.</p></a>
      <a href="/commercial/washer-repair/on-premise-laundry-repair/" class="related-card"><h3>On-Premise Laundry</h3><p>Hospitality + healthcare service.</p></a>
      <a href="/commercial/washer-repair/industrial-laundry-repair/" class="related-card"><h3>Industrial Laundry</h3><p>Large-capacity service.</p></a>
    </div>
  </div>
</section>

<section class="bottom-cta">
  <div class="container">
    <h2>UniMac down? Same-day across LA, OC, Ventura.</h2>
    <p>UW + UY + UC washer-extractors, UniLinc dryers. Alliance Laundry Systems parts. $120 commercial, waived with repair. BHGS #A49573 + EPA 608.</p>
    <div class="cta-row">
      <a href={phoneHref} class="btn-primary">☎ Call {phone}</a>
      <a href="/contact/" class="btn-secondary">Book Online</a>
    </div>
  </div>
</section>

</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .section { padding: 72px 24px; }
  .section-gray { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; }
  .container.narrow { max-width: 820px; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  .section h2 { font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 800; margin: 0 0 18px; line-height: 1.2; }
  .section p { font-size: 1rem; line-height: 1.75; margin: 0 0 16px; }
  .section a { color: var(--red); font-weight: 600; text-decoration: none; }
  .section a:hover { text-decoration: underline; }
  .series-h3 { font-size: 1.1rem; font-weight: 800; margin: 28px 0 10px; }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 22px; background: #fff; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
  .price-table th, .price-table td { padding: 12px 16px; text-align: left; border-bottom: 1px solid var(--border); font-size: 0.95rem; }
  .price-table th { background: var(--gray); font-weight: 700; }
  .price-table tr:last-child td { border-bottom: none; }
  .faq-list { margin-top: 24px; }
  .faq-item { background: #fff; border: 1px solid var(--border); border-radius: 6px; padding: 18px 22px; margin-bottom: 12px; }
  .faq-item summary { font-weight: 700; cursor: pointer; font-size: 1rem; list-style: none; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::before { content: "+ "; color: var(--red); font-weight: 800; margin-right: 6px; }
  .faq-item[open] summary::before { content: "− "; }
  .faq-item p { font-size: 0.95rem; line-height: 1.75; margin: 14px 0 0; }
  .related-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 18px; margin-top: 22px; }
  .related-card { display: block; background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 22px; text-decoration: none; color: var(--text); transition: all 0.2s; }
  .related-card:hover { border-color: var(--red); transform: translateY(-2px); box-shadow: 0 4px 14px rgba(0,0,0,0.06); }
  .related-card h3 { font-size: 1rem; font-weight: 800; margin: 0 0 8px; }
  .related-card p { font-size: 0.85rem; color: var(--muted); margin: 0; line-height: 1.6; }
  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { color: #fff; margin: 0 0 14px; font-size: 1.7rem; }
  .bottom-cta p { color: #c9c9c9; margin: 0 0 26px; max-width: 720px; margin-left: auto; margin-right: auto; }
  .cta-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 14px 28px; border-radius: 5px; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 14px 28px; border-radius: 5px; border: 2px solid rgba(255,255,255,0.35); font-weight: 600; text-decoration: none; }
</style>
