---
// src/pages/commercial/washer-repair/brands/speed-queen.astro
// Wave 20 Cluster 10, Speed Queen brand page (Alliance Laundry Systems flagship).
// Founded 1908 Wisconsin (Barlow & Seelig), Ripon WI. Alliance Laundry Systems parent.
// Coin-op + on-premise + industrial. Premium commercial laundry standard.
// $120 commercial. BHGS #A49573 + EPA 608 Universal #1346255700410. NO C-38.

import Layout from '../../../../layouts/Layout.astro';
import CommercialHero from '../../../../components/CommercialHero.astro';
import { MAIN_PHONE } from '../../../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/commercial/washer-repair/brands/speed-queen/";

const title = "Speed Queen Commercial Washer Repair LA | Coin-Op, On-Premise, Industrial, $120";
const description = "Speed Queen commercial washer repair across SoCal. Top load, front load, stack, vended coin-op, on-premise laundry. Alliance Laundry Systems Ripon WI. EPA 608. (424) 325-0520.";

const faqs = [
  {
    q: "Is Speed Queen the same as Maytag Commercial?",
    a: "No. Speed Queen is owned by Alliance Laundry Systems (Ripon, Wisconsin). Maytag Commercial is owned by Whirlpool Corporation. Both compete in the commercial laundry segment but they are separate companies with separate parts catalogs and separate distribution networks. Speed Queen is generally considered the premium commercial laundry brand for coin-op and on-premise applications; Maytag Commercial competes on price.",
  },
  {
    q: "What Speed Queen models do you service?",
    a: "Full Speed Queen commercial line. SC-series and FC-series washer-extractors (industrial 25 to 200 lb capacity). TR-series and SF-series soft-mount washer-extractors. SX-series stack washer-dryers. SCN coin-op top-load (laundromat workhorse). TRW front-load coin-op. Quantum Touch and Quantum Gold control electronics. We carry common parts on the truck and stock less common parts within 1 to 3 days through Alliance Laundry Systems distribution.",
  },
  {
    q: "Why do laundromats prefer Speed Queen?",
    a: "Three reasons. (1) Mechanical reliability, Speed Queen designs prioritize 12 to 15 year service life over feature density, which matters when downtime per unit is direct revenue loss. (2) Quantum Touch coin-op control system has solid uptime and good vending integration with credit card and mobile app systems. (3) Alliance Laundry Systems parts distribution is fast in California, most common parts arrive next-day from regional distribution. The premium price pencils out over the operational lifetime of a vended unit.",
  },
  {
    q: "Quantum Touch and Quantum Gold, what's the difference for repair?",
    a: "Quantum Touch is the newer touchscreen control system on current Speed Queen commercial machines. Quantum Gold is the legacy LED + button control on machines from roughly 2010-2017. Both store fault history and allow technician access via service codes. We carry the diagnostic procedures for both. Common Quantum Touch failures: touchscreen sensor module (year 6 to 9), main control board (year 8 to 12). Common Quantum Gold failures: keypad membrane, display LED bank.",
  },
  {
    q: "What's the typical Speed Queen repair on a year 8+ machine?",
    a: "Top common service items by failure frequency: (1) drain valve assembly (year 5 to 8), (2) door lock and door switch (year 4 to 7 on coin-op high-cycle units), (3) drive belt and motor pulley (year 6 to 10), (4) bearing and seal kit on washer-extractor tubs (year 8 to 12, major service), (5) coin acceptor or card reader on vended models, (6) heating element on hot-water on-premise units. We give a written estimate before parts are ordered.",
  },
  {
    q: "Are Speed Queen and UniMac the same?",
    a: "Sister brands under Alliance Laundry Systems (same parent, same Ripon WI manufacturing). UniMac is positioned for on-premise laundry (hospitals, hotels, healthcare, prisons) while Speed Queen serves coin-op laundromats and lighter on-premise. Many components cross-fit between Speed Queen and UniMac equivalents. Our techs service both with the same diagnostic approach.",
  },
  {
    q: "What's your warranty?",
    a: "90 days SDAR labor and parts on every repair. Speed Queen factory parts warranties processed separately through Alliance Laundry Systems. We help with warranty claim documentation when applicable. BHGS #A49573, EPA 608 Universal #1346255700410, BBB A+ accredited.",
  },
];

const schemaJsons = [
  {
    "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair", "url": canonical, "telephone": phone, "priceRange": "$$",
    "openingHoursSpecification": [{ "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "08:00", "closes": "20:00" }],
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" },
    ],
  },
  {
    "@context": "https://schema.org", "@type": "Service", "@id": canonical + "#service",
    "serviceType": "Speed Queen Commercial Washer Repair",
    "name": "Speed Queen Commercial Laundry Service",
    "url": canonical,
    "description": "Speed Queen commercial washer repair across all five SoCal counties. SC-series and FC-series washer-extractors, TR-series and SF-series soft-mount, SX-series stack, SCN coin-op top-load, TRW front-load coin-op, Quantum Touch and Quantum Gold controls. Coin-op laundromats, hotels, multi-family, healthcare, hospitality on-premise. Alliance Laundry Systems Ripon WI parts network. $120 commercial diagnostic. BHGS #A49573, EPA 608 Universal #1346255700410.",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" },
    ],
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "120.00", "priceCurrency": "USD", "description": "Commercial diagnostic fee, applied toward repair" } },
  },
  {
    "@context": "https://schema.org", "@type": "Brand", "@id": canonical + "#brand",
    "name": "Speed Queen", "url": "https://www.speedqueen.com/",
    "description": "American commercial laundry equipment manufacturer founded 1908 in Wisconsin (originally Barlow & Seelig Manufacturing). Premium coin-op laundromat and on-premise laundry equipment. Manufactured in Ripon, Wisconsin.",
    "parentOrganization": { "@type": "Organization", "name": "Alliance Laundry Systems" },
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  {
    "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Commercial", "item": "https://samedayappliance.repair/commercial/" },
      { "@type": "ListItem", "position": 3, "name": "Washer Repair", "item": "https://samedayappliance.repair/commercial/washer-repair/" },
      { "@type": "ListItem", "position": 4, "name": "Speed Queen", "item": canonical },
    ],
  },
];
---

<Layout title={title} description={description} canonical={canonical}>

<Fragment slot="head-scripts">
  {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
</Fragment>

<CommercialHero
  title="Speed Queen Commercial Washer Repair Los Angeles"
  subtitle={`Coin-op laundromats, on-premise hospitality, healthcare, multi-family, industrial. SC-series, FC-series, SX stack, TRW coin-op, Quantum Touch + Gold controls. ${phone}`}
  heroImageTitle="Speed Queen Commercial Washer Repair"
  showBranches={true}
/>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Speed Queen commercial laundry</p>
    <h2>The premium American commercial laundry brand. Manufactured in Wisconsin since 1908.</h2>

    <p>Speed Queen is the flagship commercial laundry brand of Alliance Laundry Systems, headquartered in Ripon, Wisconsin. The brand traces back to 1908 as Barlow & Seelig Manufacturing and has built commercial laundry equipment continuously since then. In LA's commercial laundry landscape, Speed Queen is the brand we see most often in vended coin-op laundromats across the city, in apartment-building common laundry rooms, and in mid-tier hospitality on-premise laundry installations. The premium price point pencils out over a 12 to 15 year service life that's longer than most competing platforms.</p>

    <p>We service the full Speed Queen commercial line: SC-series and FC-series washer-extractors (industrial 25 to 200 lb capacity), TR-series and SF-series soft-mount washer-extractors, SX-series stack washer-dryers, SCN top-load coin-op (the laundromat workhorse), TRW front-load coin-op, plus Quantum Touch and Quantum Gold control electronics. Common parts on the truck; less common parts arrive in 1 to 3 days through Alliance Laundry Systems regional distribution.</p>

    <p>$120 commercial diagnostic, waived with repair. BHGS #A49573 + EPA 608 Universal #1346255700410. We service Speed Queen across LA, Orange, Ventura, San Bernardino, and Riverside counties.</p>
  </div>
</section>

<section class="section section-gray">
  <div class="container">
    <p class="section-number">Product lines we service</p>
    <h2>Coin-op, on-premise, industrial, different lines for different operations.</h2>

    <h3 class="series-h3">SCN top-load coin-op (laundromat workhorse)</h3>
    <p>The vended top-load that dominates LA laundromats. Heavy-duty mechanical agitator with commercial-grade transmission. Common service items: drain valve assembly (year 5 to 8), drive belt (year 6 to 10), agitator dogs (year 7 to 10), coin acceptor or card reader, lid switch, water inlet valve. We typically see SCN units running 8 to 12 years of vended service before major work, longer with regular preventive maintenance.</p>

    <h3 class="series-h3">TRW front-load coin-op</h3>
    <p>The premium vended front-load on the Speed Queen lineup. Higher water and energy efficiency than top-load, larger capacity, faster cycle times. Quantum Touch control on current models, Quantum Gold on legacy. Common service items: door lock and switch (year 4 to 7 on high-cycle units), drain pump, motor brushes (on brushed-motor models), bearing and seal kit (year 8 to 12, major service).</p>

    <h3 class="series-h3">SX-series stack washer-dryer</h3>
    <p>Stacked washer-over-dryer or dryer-over-washer for space-constrained installations: apartment building common laundry, hotel guest floors, smaller on-premise applications. Vibration isolation matters because both halves operate over a single floor footprint. Common service: dryer vent restriction (most common dryer-side complaint), washer drain valve, door lock on either half.</p>

    <h3 class="series-h3">SC-series and FC-series washer-extractors (industrial)</h3>
    <p>25 to 200 lb capacity hard-mount industrial washer-extractors. Hospital, hotel, healthcare, prison, large-volume on-premise. Common service items: bearing and seal kit (the major service on this tier), inverter drive (year 8 to 12), drain valve assembly, control board, hot water inlet on heated-water units.</p>

    <h3 class="series-h3">TR-series and SF-series soft-mount washer-extractors</h3>
    <p>Soft-mount equivalent of the SC/FC line, eliminates the foundation requirements of hard-mount industrial machines. Spring suspension absorbs the spin extraction loads. Common service: spring suspension components (year 10 to 15), drum bearing (year 8 to 12), inverter, drain valve.</p>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Common Speed Queen failures</p>
    <h2>What we see on Speed Queen service calls.</h2>

    <ul class="reasons-list">
      <li><strong>Drain valve assembly (year 5 to 8 typical)</strong>, solenoid coil burnout or mechanical seat failure. Symptoms: water won't drain, drain leak around valve. Replacement $385 to $585 on coin-op, $585 to $785 on industrial.</li>
      <li><strong>Door lock and door switch (year 4 to 7 on high-cycle vended units)</strong>, lock mechanism wears or switch fails. Cycle won't start because safety circuit doesn't confirm door closed. Replacement $245 to $385.</li>
      <li><strong>Drive belt and motor pulley (year 6 to 10)</strong>, belt stretches and slips. Drum doesn't reach extract speed or doesn't agitate properly. Replacement $185 to $385.</li>
      <li><strong>Bearing and seal kit on washer-extractor tubs (year 8 to 12)</strong>, major service. Tear-down required to access. Replacement $1,485 to $2,485 on industrial sizes; less on smaller capacity.</li>
      <li><strong>Coin acceptor or card reader on vended models</strong>, mechanical wear on mechanical coin acceptors, card reader head wear or RFID antenna failure on payment-card models. Replacement $245 to $585 depending on payment system.</li>
      <li><strong>Quantum Touch touchscreen sensor (year 6 to 9)</strong>, touch input becomes intermittent or loses sensitivity. Module replacement $485 to $685.</li>
      <li><strong>Heating element on hot-water on-premise units (year 6 to 9)</strong>, calcium scale builds up on element from LA hard water (300 to 400 mg/L TDS), eventually fails. Replacement $385 to $585.</li>
    </ul>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">Pricing</p>
    <h2>Speed Queen service costs.</h2>

    <table class="price-table">
      <thead><tr><th>Repair</th><th>Typical Cost</th></tr></thead>
      <tbody>
        <tr><td>Diagnostic (waived with repair)</td><td>$120</td></tr>
        <tr><td>Drain valve assembly (coin-op)</td><td>$385 to $585</td></tr>
        <tr><td>Drain valve assembly (industrial)</td><td>$585 to $785</td></tr>
        <tr><td>Door lock + switch</td><td>$245 to $385</td></tr>
        <tr><td>Drive belt + motor pulley</td><td>$185 to $385</td></tr>
        <tr><td>Bearing + seal kit (washer-extractor major)</td><td>$1,485 to $2,485</td></tr>
        <tr><td>Coin acceptor / card reader</td><td>$245 to $585</td></tr>
        <tr><td>Quantum Touch touchscreen module</td><td>$485 to $685</td></tr>
        <tr><td>Heating element (hot-water on-premise)</td><td>$385 to $585</td></tr>
        <tr><td>Inverter drive (industrial)</td><td>$785 to $1,285</td></tr>
        <tr><td>Warranty</td><td>90 days parts and labor</td></tr>
      </tbody>
    </table>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">FAQ</p>
    <h2>Speed Queen questions.</h2>
    <div class="faq-list">
      {faqs.map(f => (<details class="faq-item"><summary>{f.q}</summary><p set:html={f.a}></p></details>))}
    </div>
  </div>
</section>

<section class="section section-gray">
  <div class="container">
    <p class="section-number">Related</p>
    <h2>Commercial laundry across the catalog.</h2>
    <div class="related-grid">
      <a href="/commercial/washer-repair/" class="related-card"><h3>Washer Repair Hub</h3><p>Parent pillar.</p></a>
      <a href="/commercial/washer-repair/brands/unimac/" class="related-card"><h3>UniMac</h3><p>Alliance sister brand, on-premise focus.</p></a>
      <a href="/commercial/washer-repair/brands/dexter/" class="related-card"><h3>Dexter</h3><p>Independent Iowa coin-op specialist.</p></a>
      <a href="/commercial/washer-repair/coin-laundry-repair/" class="related-card"><h3>Coin-Op Laundry</h3><p>Vended laundromat service.</p></a>
      <a href="/commercial/washer-repair/on-premise-laundry-repair/" class="related-card"><h3>On-Premise Laundry</h3><p>Hospitality + healthcare on-premise.</p></a>
    </div>
  </div>
</section>

<section class="bottom-cta">
  <div class="container">
    <h2>Speed Queen down? Same-day across LA, OC, Ventura.</h2>
    <p>Coin-op + on-premise + industrial. Alliance Laundry Systems parts network. $120 commercial, waived with repair. BHGS #A49573 + EPA 608.</p>
    <div class="cta-row">
      <a href={phoneHref} class="btn-primary">☎ Call {phone}</a>
      <a href="/contact/" class="btn-secondary">Book Online</a>
    </div>
  </div>
</section>

</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .section { padding: 72px 24px; }
  .section-gray { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; }
  .container.narrow { max-width: 820px; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  .section h2 { font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 800; margin: 0 0 18px; line-height: 1.2; }
  .section p { font-size: 1rem; line-height: 1.75; margin: 0 0 16px; }
  .section a { color: var(--red); font-weight: 600; text-decoration: none; }
  .section a:hover { text-decoration: underline; }
  .series-h3 { font-size: 1.1rem; font-weight: 800; margin: 28px 0 10px; }
  .reasons-list { padding-left: 22px; margin: 18px 0 0; }
  .reasons-list li { font-size: 1rem; line-height: 1.75; margin-bottom: 10px; }
  .reasons-list strong { font-weight: 700; }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 22px; background: #fff; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
  .price-table th, .price-table td { padding: 12px 16px; text-align: left; border-bottom: 1px solid var(--border); font-size: 0.95rem; }
  .price-table th { background: var(--gray); font-weight: 700; }
  .price-table tr:last-child td { border-bottom: none; }
  .faq-list { margin-top: 24px; }
  .faq-item { background: #fff; border: 1px solid var(--border); border-radius: 6px; padding: 18px 22px; margin-bottom: 12px; }
  .faq-item summary { font-weight: 700; cursor: pointer; font-size: 1rem; list-style: none; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::before { content: "+ "; color: var(--red); font-weight: 800; margin-right: 6px; }
  .faq-item[open] summary::before { content: "− "; }
  .faq-item p { font-size: 0.95rem; line-height: 1.75; margin: 14px 0 0; }
  .related-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 18px; margin-top: 22px; }
  .related-card { display: block; background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 22px; text-decoration: none; color: var(--text); transition: all 0.2s; }
  .related-card:hover { border-color: var(--red); transform: translateY(-2px); box-shadow: 0 4px 14px rgba(0,0,0,0.06); }
  .related-card h3 { font-size: 1rem; font-weight: 800; margin: 0 0 8px; }
  .related-card p { font-size: 0.85rem; color: var(--muted); margin: 0; line-height: 1.6; }
  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { color: #fff; margin: 0 0 14px; font-size: 1.7rem; }
  .bottom-cta p { color: #c9c9c9; margin: 0 0 26px; max-width: 720px; margin-left: auto; margin-right: auto; }
  .cta-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 14px 28px; border-radius: 5px; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 14px 28px; border-radius: 5px; border: 2px solid rgba(255,255,255,0.35); font-weight: 600; text-decoration: none; }
</style>
