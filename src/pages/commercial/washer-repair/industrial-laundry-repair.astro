import { MAIN_PHONE } from '../../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/commercial/washer-repair/industrial-laundry-repair/";

const title = "Industrial Laundry Repair Los Angeles — Same Day";
const description = `Industrial contract laundry repair across LA, OC, Ventura. Braun tunnel systems. PLC + steam injection service. $120 dx.`;

const faqs = [
  {
    q: "What's the difference between industrial laundry and OPL or coin laundry?",
    a: "Industrial laundry is contract throughput operation: a single industrial laundry plant processes linens for multiple client facilities (hotel chains, hospital networks, restaurant linen services). Capacity 100 to 400+ lb per machine, OR continuous batch tunnel washers running 1,000+ lb/hour. 24/7 production with contract SLA uptime requirements. OPL is single-facility in-house; coin laundry is public self-service. Industrial is high-throughput, high-stakes, and the parts logistics and service depth are different."
  },
  {
    q: "Milnor, Continental Girbau industrial, Wascomat: which is most common in LA?",
    a: "Milnor (Pellerin Milnor, Louisiana independent) dominates the LA industrial laundry market. Continental Girbau industrial (Spanish, premium) shows up in healthcare and hospitality contract laundries. Wascomat (Electrolux Professional, Swedish) is third. Jensen (Danish premium institutional) and G.A. Braun (Syracuse NY, continuous batch tunnel specialist) are present but less common."
