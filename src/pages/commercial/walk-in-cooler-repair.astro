---
// src/pages/commercial/walk-in-cooler-repair.astro
// Wave 5 — /commercial/ section — PAGE 1 of 15
// GSC: "walk-in refrigerator repair" 121 impressions pos 11.8 — TARGET TOP 5
// Vector gaps: evaporator/condenser coil, door heater, defrost system, drain pan,
// ice buildup, frost buildup, not holding temp, running constantly, water on floor,
// health code, 40°F food safety, EPA/C-38, coil cleaning, repair vs replace 15yr,
// Hoshizaki, Traulsen, Master-Bilt, Norlake, preventive maintenance
// Unique angles: $3,000–$8,000 inventory at stake framing; LA health inspection
// pressure (LADPH); flower shops + specialty coolers; ghost kitchen density

import Layout from '../../layouts/Layout.astro';
import CommercialHero from '../../components/CommercialHero.astro';
import { MAIN_PHONE } from '../../data/branches';

// Phase 3 batch 3 (2026-04-27) — neutral multi-county hub. Per audit-output/rewrite-plans/walk-in-cooler.md:
// title/H1/sub neutralized; areaServed = 5 counties; aggregateRating omitted per
// wiki/decisions/nap-rating-policy-ssot.md. Industries grid expanded 6→12. Recent Repairs redistributed
// 4 LA → 2 LA + 1 OC (Newport Beach) + 1 Ventura (Thousand Oaks). Cooler+freezer co-mention added in intro.
const title = "Walk-In Cooler Repair — Commercial Refrigeration Service | Same Day Appliance Repair";
const description = "Same-day walk-in cooler repair across LA, Orange, Ventura, San Bernardino & Riverside counties. EPA 608 + C-38 licensed. True, Turbo Air, Hoshizaki, Traulsen, Master-Bilt, Kolpak. Restaurants, grocery, agricultural, healthcare, schools. $120 diagnostic. Call (424) 325-0520.";
