---
// src/pages/commercial/exhaust-hood-repair.astro
// Wave 5 — /commercial/ — PAGE 16 of 16 — BONUS (found in Notion DB)
// GSC EXCEPTIONAL:
//   "commercial exhaust hood repair cost" 662 imp pos 6.6 — TOP 7 WITHOUT PAGE
//   "kitchen range hood repair" 857 imp pos 8.3
//   "range hood repair service near me" 274 imp pos 9.0
//   "range hood repair" 470 imp pos 34.2
//   Total: 2,500+ impressions/quarter, near-zero clicks — massive capture play
// Unique angles:
// 1. Type I vs Type II hood — critical distinction for LA operators
// 2. NFPA 96 + LAFD + LADBS compliance — hood failure = fire code violation
// 3. Detailed pricing (662 imp pos 6.6 for repair cost — make it central)

import Layout from '../../layouts/Layout.astro';
import CommercialHero from '../../components/CommercialHero.astro';
import { MAIN_PHONE } from '../../data/branches';

// Phase 3 batch 3 (2026-04-27) — neutral multi-county hub. Per audit-output/rewrite-plans/exhaust-hood.md:
// title/H1/sub neutralized; areaServed = 5 counties; aggregateRating omitted per
// wiki/decisions/nap-rating-policy-ssot.md. Added: MUA dedicated section, Fan Repair discrete block,
// NFPA 96 cadence table. Brands +Loren Cook +Twin City Fan. Recent Repairs redistributed
// 4 LA → 2 LA (Hollywood + Koreatown) + 1 OC (Newport Beach) + 1 Ventura (Thousand Oaks).
const title = "Commercial Exhaust Hood Repair — Type I & II, NFPA 96, MUA | Same Day Appliance Repair";
const description = "Same-day commercial kitchen exhaust hood repair across LA, Orange, Ventura, San Bernardino & Riverside counties. Type I & II hoods, fan motors, blowers, MUA units. Captive-Aire, Gaylord, Halton, Greenheck. NFPA 96 compliant. BHGS #A49573, $120 diagnostic. Call (424) 325-0520.";
const canonical = "https://samedayappliance.repair/commercial/exhaust-hood-repair/";
const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
---

