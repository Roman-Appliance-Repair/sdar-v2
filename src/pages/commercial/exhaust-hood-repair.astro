          <tr style="background:var(--gray);"><td style="padding:10px 14px; border-bottom:1px solid var(--border);">High-volume cooking</td><td style="padding:10px 14px; border-bottom:1px solid var(--border); font-weight:700; color:var(--red);">Quarterly (every 90 days)</td><td style="padding:10px 14px; border-bottom:1px solid var(--border); color:var(--muted);">Wok-heavy Asian kitchens, steakhouse charbroilers, busy fryers</td></tr>
          <tr><td style="padding:10px 14px; border-bottom:1px solid var(--border);">Moderate-volume full-service</td><td style="padding:10px 14px; border-bottom:1px solid var(--border); font-weight:700; color:var(--red);">Semi-annually (every 180 days)</td><td style="padding:10px 14px; border-bottom:1px solid var(--border); color:var(--muted);">Most full-service restaurants, hotel banquet kitchens</td></tr>
