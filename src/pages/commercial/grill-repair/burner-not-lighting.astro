        <tr><td>Hot surface igniter replacement (HSI)</td><td>$280 to $440</td></tr>
        <tr><td>Thermocouple replacement (standing pilot)</td><td>$220 to $340</td></tr>
        <tr><td>Gas valve safety reset</td><td>$120</td></tr>
        <tr><td>Gas valve replacement (full)</td><td>$480 to $680</td></tr>
        <tr><td>Gas pressure / regulator referral (plumber-side)</td><td>$120 plus plumber-side $200-600</td></tr>
        <tr><td>Burner head replacement (year 6+ heavy duty)</td><td>$340 to $480 per head</td></tr>
        <tr><td>Multi-burner full service (year 8+)</td><td>$880 to $1,400</td></tr>
        <tr><td>Warranty</td><td>90 days parts and labor</td></tr>
      </tbody>
    </table>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">FAQ</p>
    <h2 class="section-title">Burner-not-lighting questions.</h2>
    <div class="faq-list">
      {faqs.map(f => (<details class="faq-item"><summary>{f.q}</summary><p set:html={f.a}></p></details>))}
