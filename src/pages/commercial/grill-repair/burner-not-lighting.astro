const faqs = [
  {
    q: "How is commercial grill different from residential outdoor grill?",
    a: "Commercial outdoor grills run higher BTU (35,000 to 80,000 BTU per burner vs 12,000 to 25,000 residential), heavier-duty construction (304 stainless heavy-gauge vs 430 mid-grade on residential), continuous-service rated, and typically installed at restaurant patios, hotel buffet stations, catering operations, country club outdoor kitchens. The repair patterns are different: commercial duty cycle (8 to 14 hours daily during operating season) accelerates parts wear roughly 5 to 10x residential. For residential outdoor grill repair (Lynx home, Wolf Outdoor home, Fire Magic, Twin Eagles home, Kalamazoo home) see <a href='/outdoor/grill-repair/'>residential outdoor grill repair</a>.",
  },
  {
    q: "Restaurant patio grill won't light. What's the diagnostic order?",
    a: "Five-step order, cheapest first. (1) Gas supply and pressure: shut-off valve open, manometer at unit inlet under load (commercial grills often share supply with kitchen equipment, peak-demand drops are common). About 25 percent of restaurant grill 'won't light' calls resolve at gas-supply diagnostic. (2) Spark ignition or hot surface igniter test (electronic ignition models, most premium commercial). $260-440 if failed. (3) Pilot light or thermocouple (standing pilot models, more common on legacy commercial). $220-340. (4) Burner port carbon and grease buildup, $120-260 cleaning per burner. (5) Gas valve safety lockout or mechanical failure, $120 reset to $680 valve replacement.",
  },
  {
    q: "Brand factual: Wolf Outdoor commercial vs Wolf residential vs Wolf Range Commercial?",
    a: "Three different companies under Wolf branding, often confused. (1) Wolf Outdoor commercial: Middleby brand for commercial outdoor BBQ grills used in restaurant patios, hotel installations, country clubs. (2) Wolf Outdoor residential: also Middleby, separate product line for residential luxury outdoor kitchens. (3) Wolf residential indoor: Sub-Zero Group Inc. brand for residential ranges and ovens (entirely separate company). (4) Wolf Range Commercial: ITW Food Equipment Group brand for indoor commercial cooking ranges (yet another separate company). Four Wolf product lines, three companies. We identify which at dispatch by serial and model. Parts networks are completely different.",
  },
  {
    q: "Lynx Pro Sear commercial vs Lynx residential. Different?",
    a: "Same parent company (Lynx Grills, independent Compton CA), different product lines. Lynx Pro Sear and Lynx commercial L-Series are commercial duty-rated, heavier construction, higher BTU, longer warranty for commercial use. Lynx residential (regular Lynx, Lynx Sedona, Lynx outdoor entertainment) are residential-rated; running them in commercial duty voids warranty and accelerates wear. Failure patterns differ: commercial Lynx Pro Sear sees burner port carbon at year 2-3 (commercial duty), residential Lynx at year 6-8 (residential duty). $260-440 spark module replacement common across both lines.",
  },
  {
    q: "Twin Eagles commercial models we see in LA?",
    a: "Twin Eagles (Camarillo CA, since 2003, now part of Dometic Group) makes commercial outdoor grill lines for restaurant and hotel patio installations: 30/36/42-inch built-in commercial grills, the Eagle One series, the Salamander Pro broiler. Common LA installs: hotel rooftop patios in DTLA and West Hollywood, restaurant courtyard installations across Beverly Hills and Calabasas, country club outdoor cooking stations across the Westside. Failure patterns: thermocouple year 4-7 standing pilot models, spark module year 5-8 electronic models, burner head erosion year 6-9 heavy duty. Parts via Dometic distribution, typically same-day or next-day in LA.",
  },
  {
    q: "MagiKitch'n outdoor commercial. Where do you see this brand?",
    a: "MagiKitch'n (Middleby, Wolf Industrial commercial line) makes heavy-duty institutional outdoor grills for catering, hotel banquet, restaurant patio, sports venue concession installations. Common LA: stadium concession kitchens (LA Memorial Coliseum, Crypto.com Arena outdoor concessions), hotel banquet outdoor cooking stations (Beverly Hills Hotel, Four Seasons LA), high-volume catering operations. MK series outdoor commercial. Built like a tank, rare to see complete failure; common service: spark module year 4-6, gas valve year 7-9, burner head erosion year 8-12 even on heavy duty.",
  },
  {
    q: "What's your warranty?",
    a: "90 days SDAR labor and parts on every repair. Brand component warranties (Wolf Outdoor commercial Middleby, Lynx Pro Sear, Twin Eagles Dometic, MagiKitch'n outdoor Middleby) processed separately through manufacturer authorized service network. BHGS #A49573, BBB A+ accredited, EPA 608 Universal certified #1346255700410.",
  },
];

const schemaJsons = [
  { "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair", "url": canonical, "telephone": phone, "priceRange": "$$",
    "openingHoursSpecification": [{ "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "08:00", "closes": "20:00" }],
    "areaServed": [
