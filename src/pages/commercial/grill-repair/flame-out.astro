<CommercialHero
  title="Commercial Outdoor Grill Flame Out, Same-Day Diagnostic"
  subtitle={`Commercial grill lights then dies? Wind, thermocouple, gas pressure, LP tank cold. Wolf Outdoor, Lynx Pro Sear, Twin Eagles, MagiKitch'n. $120 commercial. ${phone}`}
  heroImageTitle="Commercial Grill Flame Out"
