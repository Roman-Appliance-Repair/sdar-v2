// high-end fried foods. Henny Penny PFE-500/PFE-561 (DOMINANT US market), BKI LPF, Winston.
// Safety-critical: pressure relief valve, lid gasket pressure-rated, door interlock system.
// Annual safety inspection emphasis. $120 commercial diagnostic, BHGS #A49573,
// EPA 608 #1346255700410. 4 schema entities. Em-dash budget: visible body ≤6.

import Layout from '../../../layouts/Layout.astro';
