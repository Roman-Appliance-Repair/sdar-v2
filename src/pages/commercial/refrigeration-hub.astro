---
// src/pages/commercial/refrigeration.astro
import BaseLayout from '../../layouts/BaseLayout.astro';

const phone = "(323) 870-4790";
const phoneRaw = "3238704790";

const title = `Commercial Refrigeration Repair Los Angeles & SoCal — All Brands | ${phone}`;
const description = `Expert commercial refrigeration repair in Los Angeles, Orange County & SoCal. Walk-ins, reach-ins, prep tables, display cases, ice machines. All brands. EPA-certified. Same-day response. Call ${phone}.`;

const featuredBrands = [
  { name: "Hoshizaki", path: "/brands/commercial/hoshizaki-repair/", desc: "Ice machines (KM, KML, F, DCM), reach-ins, sushi cases" },
  { name: "True Refrigeration", path: "/brands/commercial/true-refrigeration-repair/", desc: "T-series reach-ins, GDM merchandisers, TSSU prep tables, R-290" },
  { name: "Traulsen", path: "/brands/commercial/traulsen-repair/", desc: "G-series, RHT half-door, blast chillers, INTELA-TRAUL" },
  { name: "Beverage-Air", path: "/brands/commercial/beverage-air-repair/", desc: "SP reach-ins, HR back bar, UCR undercounter, DR display" },
  { name: "Perlick", path: "/brands/commercial/perlick-repair/", desc: "Glycol draft beer systems, HC back bar, HP luxury, dual-zone wine" },
  { name: "Delfield", path: "/brands/commercial/delfield-repair/", desc: "N-series reach-ins, mega tops, drop-in cold pans, salad bars" },
];

const additionalBrands = [
  {
    name: "Turbo Air",
    category: "Reach-In / Display",
    notes: "M3 and M3F series reach-ins. PRO series. Common in Asian restaurants and mid-market food service. Compressor overload in SoCal summer heat is the most frequent call. Condenser cleaning every 4–5 months recommended.",
  },
  {
    name: "Hussmann",
    category: "Grocery / Retail Display",
    notes: "Open-air and glass door reach-in display cases standard in LA grocery stores and markets. Hussmann serves the supermarket and convenience store segment. Mullion heater and anti-sweat heater failures are common in display case work.",
  },
  {
    name: "Victory Refrigeration",
    category: "Reach-In / Specialty",
    notes: "VS and VR series reach-ins. Victory undercounters are common in QSR and fast casual kitchens throughout SoCal. Door gasket and thermostat failures are the primary service calls. Strong parts availability from their ITW lineage.",
  },
  {
    name: "Continental Refrigerator",
    category: "Reach-In / Worktop",
    notes: "SWF and SW series worktops. Continental reach-ins are common in school cafeterias and institutional kitchens — often alongside Delfield. Built to similar commercial standards. Thermostat and fan motor failures are the primary calls.",
  },
  {
    name: "Randell",
    category: "Prep Table / Worktop",
    notes: "9000 series worktops and prep tables. Randell is particularly common in hospital and healthcare foodservice — they make USDA-compliant refrigerated patient tray systems. Pan rail temperature compliance is the critical service issue.",
  },
  {
    name: "Migali",
    category: "Reach-In / Back Bar",
    notes: "C-series reach-ins and back bar coolers. Migali fills the budget commercial tier below Beverage-Air — common in new restaurant openings and small operators. Compressor and thermostat failures are the most common calls.",
  },
  {
    name: "Avantco",
    category: "Budget Commercial",
    notes: "Avantco reach-ins and sandwich units are standard in startup and small-format food service. Chinese-manufactured to US-market specs. OEM parts availability varies by vintage — we source through verified channels.",
  },
  {
    name: "Kool-It",
    category: "Back Bar / Undercounter",
    notes: "KSM and KBB back bar and undercounter units. Kool-It serves the value bar equipment market. Condenser cleaning and thermostat service are the typical calls.",
  },
  {
    name: "Maxx Cold",
    category: "Reach-In / Display",
    notes: "MXR and MXCR series. Maxx Cold reach-ins are common in growing food service operations transitioning from residential to commercial equipment. Fan motor and thermostat service.",
  },
  {
    name: "Arctic Air",
    category: "Budget Reach-In",
    notes: "AR and AF series reach-ins. Arctic Air is the entry point for commercial refrigeration in small restaurants and food trucks throughout SoCal. Door gasket and thermostat failures are primary calls.",
  },
  {
    name: "Frigoglass",
    category: "Beverage Display",
    notes: "European-spec glass door merchandisers common in beverage distribution accounts and specialty retailers. Anti-sweat heater service and condenser maintenance.",
  },
  {
    name: "AHT Cooling Systems",
    category: "Open Display",
    notes: "Open-air horizontal display freezers standard in LA's ethnic grocery and convenience store markets. Defrost system service and evaporator fan maintenance are the primary calls.",
  },
  {
    name: "Coldline",
    category: "Italian Reach-In",
    notes: "Stainless reach-ins and worktops designed to European standards. Common in Italian and European restaurant operations in LA. Parts sourcing through European channels when needed.",
  },
  {
    name: "Felix Storch / Summit",
    category: "Specialty / Undercounter",
    notes: "Summit undercounter and ADA-compliant refrigerators. Felix Storch brands are common in healthcare environments requiring ADA-compliant reach. Thermostat and fan motor service.",
  },
  {
    name: "Southbend",
    category: "Commercial Kitchen",
    notes: "Southbend primarily manufactures commercial ranges and ovens, but their refrigerated base units and undercounters appear in commercial kitchens alongside Southbend cooking equipment.",
  },
  {
    name: "Everest Refrigeration",
    category: "Glass Door Display",
    notes: "EBGR and EBB series glass door reach-ins. Everest serves the value commercial display segment. Anti-sweat heater and door seal service are common calls in the SoCal market.",
  },
  {
    name: "Turbo Air (Refrigerated Display)",
    category: "Open Display / Deli",
    notes: "TOM and TOMD open deli cases. Turbo Air's open display refrigeration is standard in LA's deli and prepared food counter segment. Defrost and fan motor service.",
  },
];

const serviceTypes = [
  { icon: "🧊", name: "Reach-In Refrigerators & Freezers", desc: "One, two, and three-door commercial reach-ins across all major brands. Thermostat, defrost system, door gasket, fan motor, and compressor service." },
  { icon: "🥗", name: "Prep Tables & Mega Tops", desc: "Pan rail temperature compliance, cutting board, worktop, and refrigeration circuit service for sandwich, pizza, and prep stations." },
  { icon: "🍺", name: "Back Bar Coolers & Undercounters", desc: "Back bar, undercounter, and direct draw beer coolers. Door heater wire, condenser cleaning, and thermostat service for bar environments." },
  { icon: "🏪", name: "Glass Door Display Cases", desc: "Glass door reach-in merchandisers, open-air display, and deli cases. Anti-sweat heater, mullion heater, and display lighting service." },
  { icon: "🏭", name: "Walk-In Coolers & Freezers", desc: "Walk-in refrigeration system service including evaporator units, condensing units, door gaskets, and temperature control systems." },
  { icon: "❄️", name: "Drop-In Cold Pans & Salad Bars", desc: "Remote condensing cold food tables, ingredient bins, and salad bar refrigeration. Institutional cafeteria specialists." },
  { icon: "🍺", name: "Draft Beer & Glycol Systems", desc: "Glycol power packs, trunk line systems, and font coolers for multi-tap draft beer installations. Perlick and custom glycol systems." },
  { icon: "🧊", name: "Ice Machines", desc: "Hoshizaki, Manitowoc, Scotsman, and Ice-O-Matic ice machine repair, cleaning, and preventive maintenance." },
];

const schema = {
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  "name": "Same Day Appliance Repair — Commercial Refrigeration",
  "telephone": phone,
  "email": "info@samedayappliance.repair",
  "areaServed": ["Los Angeles", "Orange County", "Ventura County", "San Bernardino County", "Riverside County"],
  "priceRange": "$$",
};
---

<BaseLayout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <!-- HERO -->
  <section class="hub-hero">
    <div class="container hero-inner">
      <div class="hero-text">
        <p class="eyebrow">Commercial Refrigeration — Los Angeles &amp; Southern California</p>
        <h1>Commercial Refrigeration<br><span class="accent">Repair &amp; Service</span></h1>
        <p class="hero-sub">All commercial refrigeration brands. All equipment types. EPA-certified technicians. Same-day emergency response throughout Los Angeles, Orange County, Ventura County, and the Inland Empire.</p>
        <div class="hero-ctas">
          <a href={`tel:${phoneRaw}`} class="btn btn-primary btn-lg">{phone}</a>
          <a href="/book" class="btn btn-outline btn-lg">Request Service</a>
        </div>
        <div class="hero-trust">
          <span>EPA 608 Certified</span>
          <span>$120 Commercial Diagnostic</span>
          <span>HACCP Documentation</span>
          <span>Same-Day Response</span>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <div class="trust-bar">
    <div class="container trust-bar-inner">
      <div class="trust-item"><span class="ti-icon">⚡</span><span>Same-Day Emergency Response</span></div>
      <div class="trust-item"><span class="ti-icon">🔬</span><span>EPA 608 Certified</span></div>
      <div class="trust-item"><span class="ti-icon">📋</span><span>HACCP Documentation</span></div>
      <div class="trust-item"><span class="ti-icon">🔧</span><span>OEM Parts Only</span></div>
      <div class="trust-item"><span class="ti-icon">📄</span><span>PM Contracts Available</span></div>
    </div>
  </div>

  <!-- INTRO -->
  <section class="intro-section container">
    <div class="intro-content">
      <h2>Commercial Refrigeration Repair Throughout Southern California</h2>
      <p>When commercial refrigeration fails, the clock starts immediately. A walk-in cooler in a Los Angeles restaurant holds $3,000–$15,000 of perishable inventory. A prep table above 41°F during lunch service is a HACCP critical control point event. A hospital cafeteria reach-in failure before breakfast service requires documented corrective action. The commercial refrigeration service we provide is built around these realities — same-day dispatch, EPA 608 certified technicians, OEM parts stocked on the truck for the most common brands and failure modes in the SoCal market.</p>
      <p>We service the full spectrum of commercial refrigeration equipment: from Hoshizaki KM-series ice machines in LA's sushi restaurant density to Traulsen blast chillers in hotel production kitchens to Perlick glycol draft beer systems in craft bars to Delfield drop-in cold pans in LAUSD school cafeterias. This is not general appliance work — commercial refrigeration requires EPA 608 certification, R-290 capability for current-generation equipment, and the diagnostic knowledge to distinguish a compressor failure from a condenser coil problem from a defrost system issue before recommending parts.</p>
      <p>$120 commercial diagnostic, applied to the repair. Call {phone}.</p>
    </div>
    <aside class="sticky-cta-box">
      <p class="scb-label">Commercial Refrigeration</p>
      <p class="scb-phone">{phone}</p>
      <a href={`tel:${phoneRaw}`} class="btn btn-primary btn-block">Emergency Call</a>
      <a href="/book" class="btn btn-outline btn-block">Schedule Service</a>
      <ul class="scb-list">
        <li>✓ $120 Diagnostic → Applied to Repair</li>
        <li>✓ EPA 608 + R-290 Certified</li>
        <li>✓ All Major Brands</li>
        <li>✓ HACCP Documentation</li>
        <li>✓ PM Contracts Available</li>
        <li>✓ LA, OC, Ventura, IE Coverage</li>
      </ul>
    </aside>
  </section>

  <!-- SERVICE TYPES -->
  <section class="services-section">
    <div class="container">
      <h2>Equipment We Service</h2>
      <div class="services-grid">
        {serviceTypes.map(s => (
          <div class="service-card">
            <span class="svc-icon">{s.icon}</span>
            <div class="svc-body">
              <h3>{s.name}</h3>
              <p>{s.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FEATURED BRANDS -->
  <section class="featured-section container">
    <h2>Featured Brand Specialists</h2>
    <p class="section-sub">Deep technical coverage for the six most common commercial refrigeration brands in SoCal. Full diagnostic guides, product line breakdowns, and SoCal-specific failure analysis.</p>
    <div class="featured-grid">
      {featuredBrands.map(b => (
        <a href={b.path} class="featured-card">
          <span class="fc-name">{b.name}</span>
          <span class="fc-desc">{b.desc}</span>
          <span class="fc-cta">View Service →</span>
        </a>
      ))}
    </div>
  </section>

  <!-- ADDITIONAL BRANDS -->
  <section class="brands-section">
    <div class="container">
      <h2>All Commercial Refrigeration Brands We Service</h2>
      <p class="section-sub">We service every commercial refrigeration brand operating in the SoCal market. Below is our technical summary for brands beyond our six featured specialists.</p>
      <div class="brands-grid">
        {additionalBrands.map(b => (
          <div class="brand-card">
            <div class="brand-header">
              <span class="brand-name">{b.name}</span>
              <span class="brand-cat">{b.category}</span>
            </div>
            <p class="brand-notes">{b.notes}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- INDUSTRIES -->
  <section class="industries-section container">
    <h2>Industries We Serve in SoCal</h2>
    <div class="industries-grid">
      <div class="ind-card">
        <h3>Restaurants &amp; Fine Dining</h3>
        <p>From neighborhood taquerias to Michelin-starred kitchens. Reach-in, prep table, and walk-in service with same-day priority for service-hour failures.</p>
      </div>
      <div class="ind-card">
        <h3>Hotels &amp; Hospitality</h3>
        <p>Beverly Hills and Santa Monica resort kitchens, banquet prep, grab-and-go, and bar service. Multi-unit PM contracts for facility managers.</p>
      </div>
      <div class="ind-card">
        <h3>Healthcare &amp; Institutional</h3>
        <p>Cedars-Sinai, UCLA, Kaiser, and affiliated facilities. HACCP documentation provided. Patient care food service treated with appropriate urgency.</p>
      </div>
      <div class="ind-card">
        <h3>Schools &amp; Universities</h3>
        <p>LAUSD, UC and CSU campus dining, culinary programs. Institutional prep table and reach-in service with HACCP compliance documentation.</p>
      </div>
      <div class="ind-card">
        <h3>Bars &amp; Craft Beverage</h3>
        <p>Back bar coolers, undercounters, glycol draft beer systems, and taproom equipment. Friday and weekend emergency priority — bar downtime is revenue loss.</p>
      </div>
      <div class="ind-card">
        <h3>Grocery &amp; Convenience</h3>
        <p>Display case, open-air reach-in, and walk-in service for grocery stores, delis, and convenience stores throughout the SoCal corridor.</p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="faq-section container">
    <h2>Commercial Refrigeration Service — FAQ</h2>
    <div class="faq-list">
      <details class="faq-item">
        <summary class="faq-q">What is your response time for commercial refrigeration emergencies?</summary>
        <p class="faq-a">Same-day response for commercial refrigeration failures throughout Los Angeles and Orange County. Call {phone} immediately — we dispatch from the nearest location with commercial parts stocked. For walk-in failures and HACCP-critical equipment, we treat every call as time-sensitive. Ventura County and Inland Empire coverage is typically same-day with morning calls.</p>
      </details>
      <details class="faq-item">
        <summary class="faq-q">What is your commercial diagnostic fee?</summary>
        <p class="faq-a">$120 commercial diagnostic, applied directly to the repair cost when you proceed. No hidden trip charge throughout SoCal. We quote on-site after diagnosis — what we quote is what appears on the invoice.</p>
      </details>
      <details class="faq-item">
        <summary class="faq-q">Do you service R-290 propane refrigerant equipment?</summary>
        <p class="faq-a">Yes. Current-production True THAC, Perlick HP, and select Hoshizaki models run R-290 propane refrigerant. R-290 requires EPA 608 certified technicians with specific hydrocarbon training. We are fully certified and equipped. Never allow an uncertified technician to work on R-290 equipment.</p>
      </details>
      <details class="faq-item">
        <summary class="faq-q">Do you provide HACCP temperature documentation with service calls?</summary>
        <p class="faq-a">Yes. For institutional operators — schools, hospitals, corporate cafeterias — we provide temperature log documentation appropriate for HACCP compliance records. When we respond to a CCP exceedance event, the documentation covers the equipment failure, corrective action taken, and temperature verification post-repair.</p>
      </details>
      <details class="faq-item">
        <summary class="faq-q">Do you offer preventive maintenance contracts?</summary>
        <p class="faq-a">Yes. PM contracts are available for restaurants, hotels, healthcare facilities, and institutional operators running multiple commercial refrigeration units. Contracts are structured by equipment count and service frequency — typically monthly, quarterly, or semi-annual depending on equipment type and use intensity. Call {phone} for a quote.</p>
      </details>
      <details class="faq-item">
        <summary class="faq-q">What areas do you cover for commercial refrigeration service?</summary>
        <p class="faq-a">Los Angeles County (all cities), Orange County, Ventura County, San Bernardino County, and Riverside County. No travel surcharge within these service areas. Same-day availability varies by location and time of call — call before noon for best same-day availability.</p>
      </details>
    </div>
  </section>

  <!-- BOTTOM CTA -->
  <section class="bottom-cta">
    <div class="container">
      <h2>Commercial Refrigeration Down? We Respond Today.</h2>
      <p>Same-day emergency service for all commercial refrigeration equipment throughout Los Angeles, Orange County, Ventura County, and the Inland Empire. EPA 608 certified. OEM parts. HACCP documentation.</p>
      <div class="cta-buttons">
        <a href={`tel:${phoneRaw}`} class="btn btn-primary btn-lg">{phone}</a>
        <a href="/book" class="btn btn-outline btn-lg">Schedule Service</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
.hub-hero{background:var(--color-bg);padding:5rem 0 4rem;border-bottom:1px solid var(--color-border)}
.hero-inner{max-width:760px}
.eyebrow{font-size:.75rem;letter-spacing:.12em;text-transform:uppercase;color:var(--color-accent);margin-bottom:.75rem}
h1{font-size:clamp(2rem,4vw,3rem);font-weight:800;line-height:1.1;margin-bottom:1rem}
.accent{color:var(--color-accent)}
.hero-sub{font-size:1.05rem;color:var(--color-text-muted);margin-bottom:2rem;max-width:52ch}
.hero-ctas{display:flex;gap:1rem;flex-wrap:wrap;margin-bottom:1.5rem}
.hero-trust{display:flex;gap:1.5rem;flex-wrap:wrap;font-size:.8rem;color:var(--color-text-muted)}
.trust-bar{background:var(--color-accent);padding:1rem 0}
.trust-bar-inner{display:flex;gap:2rem;justify-content:center;flex-wrap:wrap}
.trust-item{display:flex;align-items:center;gap:.5rem;color:#fff;font-size:.875rem;font-weight:600}
.intro-section{display:grid;grid-template-columns:1fr 300px;gap:4rem;padding-top:4rem;padding-bottom:4rem}
.intro-content h2{font-size:1.6rem;margin-bottom:1.25rem}
.intro-content p{margin-bottom:1.25rem;line-height:1.75;color:var(--color-text-body)}
.sticky-cta-box{background:var(--color-surface);border:1px solid var(--color-border);border-radius:.75rem;padding:1.75rem;position:sticky;top:5rem;height:fit-content}
.scb-label{font-size:.75rem;text-transform:uppercase;letter-spacing:.1em;color:var(--color-accent);margin-bottom:.25rem}
.scb-phone{font-size:1.4rem;font-weight:800;margin-bottom:1.25rem}
.btn-block{display:block;width:100%;text-align:center;margin-bottom:.75rem}
.scb-list{list-style:none;padding:0;margin:1.25rem 0;font-size:.8rem}
.scb-list li{padding:.3rem 0;border-bottom:1px solid var(--color-border);color:var(--color-text-body)}
.services-section{background:var(--color-surface);padding:4rem 0;border-top:1px solid var(--color-border)}
.services-section h2{text-align:center;font-size:1.6rem;margin-bottom:2rem}
.services-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem}
.service-card{background:var(--color-bg);border:1px solid var(--color-border);border-radius:.5rem;padding:1.25rem;display:flex;gap:1rem;align-items:start}
.svc-icon{font-size:1.5rem;flex-shrink:0}
.svc-body h3{font-size:.9rem;font-weight:700;margin-bottom:.3rem}
.svc-body p{font-size:.8rem;color:var(--color-text-muted);line-height:1.5}
.featured-section{padding:4rem 0}
.featured-section h2{font-size:1.6rem;margin-bottom:.75rem}
.section-sub{color:var(--color-text-muted);margin-bottom:2rem;font-size:.9rem;max-width:65ch}
.featured-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.25rem}
.featured-card{background:var(--color-surface);border:1px solid var(--color-border);border-radius:.75rem;padding:1.5rem;text-decoration:none;color:var(--color-text);display:flex;flex-direction:column;gap:.4rem;transition:border-color .2s,transform .2s}
.featured-card:hover{border-color:var(--color-accent);transform:translateY(-2px)}
.fc-name{font-size:1rem;font-weight:800;color:var(--color-accent)}
.fc-desc{font-size:.825rem;color:var(--color-text-muted);line-height:1.5;flex:1}
.fc-cta{font-size:.8rem;font-weight:600;color:var(--color-accent)}
.brands-section{background:var(--color-surface);border-top:1px solid var(--color-border);padding:4rem 0}
.brands-section h2{font-size:1.6rem;margin-bottom:.75rem}
.brands-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-top:2rem}
.brand-card{background:var(--color-bg);border:1px solid var(--color-border);border-radius:.5rem;padding:1.25rem}
.brand-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:.6rem}
.brand-name{font-weight:700;font-size:.95rem}
.brand-cat{font-size:.75rem;color:var(--color-accent);background:rgba(var(--color-accent-rgb),.1);padding:.2rem .5rem;border-radius:.25rem}
.brand-notes{font-size:.825rem;color:var(--color-text-muted);line-height:1.6}
.industries-section{padding:4rem 0}
.industries-section h2{font-size:1.6rem;margin-bottom:2rem}
.industries-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.25rem}
.ind-card{background:var(--color-surface);border:1px solid var(--color-border);border-radius:.5rem;padding:1.5rem}
.ind-card h3{font-size:.95rem;margin-bottom:.6rem;color:var(--color-accent)}
.ind-card p{font-size:.875rem;color:var(--color-text-body);line-height:1.65}
.faq-section{padding:4rem 0}
.faq-section h2{font-size:1.6rem;margin-bottom:2rem}
.faq-list{display:flex;flex-direction:column;gap:.75rem}
.faq-item{border:1px solid var(--color-border);border-radius:.5rem;background:var(--color-surface)}
.faq-q{padding:1.25rem 1.5rem;font-weight:600;cursor:pointer;list-style:none}
.faq-a{padding:0 1.5rem 1.25rem;font-size:.9rem;line-height:1.7;color:var(--color-text-body)}
.bottom-cta{background:var(--color-accent);padding:4rem 0;text-align:center}
.bottom-cta h2{font-size:1.75rem;margin-bottom:.75rem;color:#fff}
.bottom-cta>div>p{color:rgba(255,255,255,.85);margin-bottom:2rem}
.cta-buttons{display:flex;gap:1rem;justify-content:center;flex-wrap:wrap}
@media(max-width:1024px){.intro-section{grid-template-columns:1fr}.sticky-cta-box{position:static}.services-grid{grid-template-columns:repeat(2,1fr)}.featured-grid{grid-template-columns:1fr 1fr}.brands-grid{grid-template-columns:1fr 1fr}.industries-grid{grid-template-columns:1fr 1fr}}
@media(max-width:768px){.services-grid,.featured-grid,.brands-grid,.industries-grid{grid-template-columns:1fr}}
</style>
