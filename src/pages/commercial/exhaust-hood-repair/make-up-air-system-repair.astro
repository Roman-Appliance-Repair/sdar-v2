// MUA = make-up air, replaces air exhausted by Type I hoods. Critical for kitchen
// pressure balance. Heating + cooling functions on climate-controlled units.
// Brands: Greenheck (dominant; RVE indirect-fired, direct-fired variants), CaptiveAire
// DOAS series, Reznor, Modine.

import Layout from '../../../layouts/Layout.astro';
import CommercialHero from '../../../components/CommercialHero.astro';
import { MAIN_PHONE } from '../../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
