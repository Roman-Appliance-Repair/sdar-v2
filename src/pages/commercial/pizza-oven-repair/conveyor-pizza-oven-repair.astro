const faqs = [
  {
    q: "My Lincoln Impinger isn't cooking pizza evenly. What's wrong?",
    a: "Almost always an air-flow finger issue. Lincoln Impinger uses hot-air impingement technology, with shaped 'fingers' that direct heated air onto the pizza as it travels through the chamber. When fingers shift, deform, or get partially blocked, cooking becomes uneven. Solution: finger inspection and replacement, $1,200 to $1,800 typical for full-set replacement on a 1132 or 1100 series.",
  },
  {
    q: "Conveyor belt is running uneven or stalling. Belt or motor?",
