---
// src/pages/commercial/pizza-oven-repair/deck-pizza-oven-repair.astro
// Phase B-6 — Sub-service under commercial pizza oven pillar.
// Architecture: traditional stone-deck pizza ovens. Bakers Pride Y series, Marsal,
// Cuppone, Vulcan, Montague. 1-4 deck levels, 500-650°F continuous.
// $120 commercial diagnostic. BHGS #A49573 + EPA 608 Universal #1346255700410.
//  scope.
// SSOT: NO aggregateRating, NO streetAddress.
import Layout from '../../../layouts/Layout.astro';
import CommercialHero from '../../../components/CommercialHero.astro';
import { MAIN_PHONE } from '../../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/commercial/pizza-oven-repair/deck-pizza-oven-repair/";

const title = "Commercial Deck Pizza Oven Repair Los Angeles — Same Day";
const description = "Deck pizza oven repair across SoCal: Bakers Pride Y-602/Y-600, Marsal MB-866, Cuppone Tiziano. Stone deck, igniter, thermostat. BHGS #A49573. (424) 325-0520.";

const faqs = [
  {
    q: "My deck oven temperature is uneven across the deck. What's wrong?",
    a: "Most common cause is thermostat drift (year 4 to 7 typical) or burner head clog (gas decks have bottom firing pattern that fouls with grease and flour over time). We test deck temp at multiple points with a calibrated probe, diagnose whether it's thermostat or burner. Calibration $290 to $440, thermostat replacement $440 to $720, burner head cleaning $200 to $340."
  },
  {
    q: "Do you service Bakers Pride Y-600, Y-602, and Marsal MB-866?",
    a: "Yes. Bakers Pride Y series (Y-600 single deck, Y-602 double deck) is the dominant US deck oven, Standex Food Service brand. Marsal MB-866 is independent NY-style deck oven brand, premium pizzeria standard. Cuppone Tiziano (Italian, Naples-style) electric deck also serviced. We carry common igniters, thermostats, and thermocouples for these platforms on the van."
  },
  {
    q: "My deck is cracked. Can you replace it?",
    a: "Yes. Stone deck cracking is typical at year 8 to 15 from thermal cycling fatigue (continuous 500 to 650°F operation). We replace the deck stone with manufacturer-spec refractory, document the install, and verify thermal recovery. Major repair, $1,800 to $2,800 typical depending on deck size and brand."
  },
  {
    q: "Gas deck or electric deck, which is better?",
    a: "Different applications. Gas decks (Bakers Pride Y series, Marsal) are the LA standard, higher BTU output, faster recovery between bakes, lower operating cost, requires gas line and Type I hood. Electric decks (Cuppone Tiziano) give more precise temperature control, no gas line requirement, slightly higher operating cost, often used for specialty Naples-style operations. Most LA volume pizzerias run gas."
  },
  {
    q: "What's a typical deck oven service call cost?",
    a: "$120 commercial diagnostic, applied toward repair. Most deck oven repairs run $440 to $980 all-in. Igniter replacement, thermostat calibration or replacement, thermocouple, burner head cleaning, door gasket. Major repairs (deck stone replacement, multi-component) run $1,800 to $2,800."
  },
  {
    q: "What's your warranty?",
    a: "90 days SDAR labor warranty. Brand component warranties processed separately. BHGS #A49573, EPA 608 Universal certified #1346255700410, BBB Accredited Business."
  }
];

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": canonical + "#business",
    "name": "Same Day Appliance Repair",
    "url": canonical,
    "telephone": phone,
    "priceRange": "$$$",
    "description": "Deck pizza oven repair across all five SoCal counties. Bakers Pride Y series, Marsal MB, Cuppone Tiziano, Vulcan, Montague. BHGS #A49573. EPA 608 Universal certified #1346255700410. BBB Accredited Business. Phones answered 24/7.",
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": canonical + "#service",
    "serviceType": "Deck Pizza Oven Repair",
    "name": "Commercial Deck Pizza Oven Repair Service",
    "url": canonical,
    "description": "Commercial deck pizza oven repair across all five SoCal counties. Traditional stone-deck pizza ovens with 1 to 4 deck levels. Brands: Bakers Pride Y-600, Y-602, Y-800 series (Standex Food Service); Marsal MB-866, MB-60 (independent NY-style); Cuppone Tiziano electric deck (Italian, Naples-style); Vulcan deck variants; Montague deck (Welbilt). Igniter replacement, thermostat calibration and replacement, thermocouple, burner head cleaning, stone deck replacement, door gasket, heating element on electric models. Operating profile 500 to 650°F continuous. BHGS #A49573. EPA 608 Universal #1346255700410.  scope.",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "offers": {
      "@type": "Offer",
      "priceRange": "$120-$2800",
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "120.00",
        "priceCurrency": "USD",
        "description": "Commercial-tier diagnostic fee, applied toward repair. No emergency surcharge."
      }
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map((f) => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Commercial", "item": "https://samedayappliance.repair/commercial/" },
      { "@type": "ListItem", "position": 3, "name": "Pizza Oven Repair", "item": "https://samedayappliance.repair/commercial/pizza-oven-repair/" },
      { "@type": "ListItem", "position": 4, "name": "Deck Pizza Oven Repair", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>

<Fragment slot="head-scripts">
  {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
</Fragment>

<CommercialHero
  eyebrow="Bakers Pride Y · Marsal MB · Cuppone Tiziano · Vulcan · Montague"
  title="Deck Pizza Oven Repair Los Angeles"
  subtitle="Traditional stone-deck pizza ovens across LA, OC, Ventura, Riverside. $120 commercial diagnostic, waived with repair. Same-day dispatch."
  heroImageTitle="Deck Pizza Oven Repair"
  showBranches={true}
/>

<section class="section">
  <div class="container narrow">
    <p class="section-number">01 · What we service</p>
    <h2 class="section-title">Traditional stone-deck pizza ovens, 500 to 650°F continuous service.</h2>

    <p>Deck pizza ovens are the traditional pizzeria platform. Stone deck cooking surface, gas (most common in LA) or electric heating, 1 to 4 deck levels (single, double, triple deck most common). 8 to 16 hour service days, continuous deck temp 500 to 650°F.</p>

    <p>Five brands cover most LA pizzeria and Italian-restaurant installs: <strong>Bakers Pride Y series</strong> (Y-600 single deck, Y-602 double deck, Y-800 large, Standex Food Service), <strong>Marsal MB-866 and MB-60</strong> (independent, NY-style premium), <strong>Cuppone Tiziano</strong> (Italian independent, Naples-style electric deck), <strong>Vulcan deck variants</strong> (ITW Food Equipment, less common deck configuration), <strong>Montague</strong> (Welbilt heritage deck).</p>

    <p>This is not a conveyor pizza oven (Lincoln Impinger, Middleby Marshall, completely different drive system, see <a href="/commercial/pizza-oven-repair/conveyor-pizza-oven-repair/">conveyor pizza oven repair</a>) and not a wood-fired oven (Forno Bravo, Wood Stone, refractory dome architecture, see <a href="/commercial/pizza-oven-repair/wood-fired-pizza-oven-repair/">wood-fired pizza oven repair</a>).</p>

    <p>$120 commercial diagnostic, waived with repair. <strong>BHGS #A49573</strong>. <strong>EPA 608 Universal #1346255700410</strong>.  scope. BBB Accredited. Phones answered 24/7, no emergency surcharge.</p>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">02 · Typical deck oven failures</p>
    <h2 class="section-title">Seven failure modes account for nearly every deck oven service call.</h2>

    <ol class="num-list">
      <li><strong>Igniter wear on gas decks (year 4 to 7).</strong> Continuous high-heat cycling wears the ignition module and electrode. Per-deck replacement $260 to $440.</li>
      <li><strong>Thermostat drift.</strong> Deck temp accuracy is critical for consistent pizza, customer can taste a 25°F drop. Calibration $290 to $440, replacement $440 to $720.</li>
      <li><strong>Stone deck cracking (year 8 to 15).</strong> Thermal cycling fatigue. Major repair, $1,800 to $2,800 with manufacturer-spec refractory replacement.</li>
      <li><strong>Door gasket compression.</strong> Heat-resistant gasket flattens at the hinge side first, hot air leaks during bake. $240 to $380 per door.</li>
      <li><strong>Burner head clog (gas, bottom-firing pattern).</strong> Grease and flour foul the burner over time, flame distribution uneven. Cleaning $200 to $340.</li>
      <li><strong>Thermocouple wear.</strong> Gas safety, drops millivolt output below valve threshold. $220 to $340.</li>
      <li><strong>Heating element burnout (electric models, Cuppone Tiziano).</strong> Year 7 to 10 typical. Per-element replacement $480 to $780.</li>
    </ol>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">03 · Recent jobs</p>
    <h2 class="section-title">Real repair stories from the last few weeks.</h2>

    <p class="lead">Composite examples; model numbers, ages, and prices are accurate to typical scope.</p>

    <div class="story">
      <h3>Hollywood · Bakers Pride Y-602 double-deck gas, 7 years old</h3>
      <p>Pizzeria. Top deck not maintaining temp, lower deck igniter intermittent. Diagnosed: top-deck thermostat drifted 30°F low, lower-deck igniter at end of life. Replaced top thermostat, replaced lower igniter. Total: $120 plus $440 thermostat plus $260 igniter = $720 plus 1.5 hours.</p>
    </div>

    <div class="story">
      <h3>Beverly Hills · Cuppone Tiziano electric deck, 9 years old</h3>
      <p>Italian restaurant. Right-side heating element burned out, thermostat reading 40°F low. Replaced heating element, replaced thermostat (year 9 typical drift past calibration recovery). Total: $120 plus $580 element plus $280 thermostat = $980.</p>
    </div>

    <div class="story">
      <h3>West Hollywood · Marsal MB-866 stone deck, 12 years old</h3>
      <p>NY pizzeria. Visible crack across deck stone, hot spots changing pie quality. Replaced deck stone with manufacturer-spec refractory, replaced thermostat (drifted past tolerance after deck thermal stress). Significant repair. Total: $120 plus $1,980 stone plus $300 thermostat = $2,400.</p>
    </div>

    <div class="story">
      <h3>Pasadena · Bakers Pride Y-600 single deck gas, 5 years old</h3>
      <p>Catering kitchen. Burner pattern uneven, flame yellow tipping (incomplete combustion). Cleaned burner head (grease + flour load), replaced thermocouple. Total: $120 plus $260 thermocouple plus 1.5 hours = $440.</p>
    </div>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">04 · Honest scope</p>
    <h2 class="section-title">What we do for deck ovens, and what we don't.</h2>

    <p><strong>We service:</strong> Bakers Pride Y-600, Y-602, Y-800; Marsal MB-866, MB-60; Cuppone Tiziano electric; Vulcan deck variants; Montague deck. Single, double, triple deck configurations. Gas and electric heating. Igniter, thermostat, thermocouple, burner head, door gasket, heating element, stone deck replacement.</p>

    <p><strong>We don't do:</strong> conveyor pizza ovens on this page (see <a href="/commercial/pizza-oven-repair/conveyor-pizza-oven-repair/">conveyor pizza oven repair</a>); wood-fired refractory dome ovens (see <a href="/commercial/pizza-oven-repair/wood-fired-pizza-oven-repair/">wood-fired pizza oven repair</a>); new deck oven installation (specialty installer trade with gas line plus electrical engineering); Type I hood work above the oven (see <a href="/commercial/exhaust-hood-repair/">commercial exhaust hood repair</a>).</p>
  </div>
</section>

