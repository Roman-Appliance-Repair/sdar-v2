  .section a { color: var(--red); font-weight: 600; text-decoration: none; }
  .section a:hover { text-decoration: underline; }

  .failure-list { padding-left: 22px; margin: 14px 0; }
  .failure-list li { font-size: 0.98rem; line-height: 1.7; color: var(--text); margin-bottom: 12px; }
  .failure-list strong { color: var(--text); font-weight: 700; }

  .bullet-list { padding-left: 22px; margin: 14px 0; }
  .bullet-list li { font-size: 0.98rem; line-height: 1.7; color: var(--text); margin-bottom: 8px; }

  .brand-list { padding-left: 22px; margin: 14px 0; }
  .brand-list li { font-size: 0.98rem; line-height: 1.7; color: var(--text); margin-bottom: 12px; }
  .brand-list strong { color: var(--text); font-weight: 700; }

  .story-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 22px; margin-top: 28px; }
  .story-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 22px 22px; }
  .story-card h3 { font-size: 0.98rem; font-weight: 800; margin: 0 0 12px; color: var(--text); line-height: 1.35; }
  .story-card p { font-size: 0.93rem; color: var(--text); line-height: 1.7; margin: 0; }

  .price-table { width: 100%; border-collapse: collapse; margin-top: 22px; background: #fff; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
