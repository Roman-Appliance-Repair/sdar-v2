  .story-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 22px; margin-top: 28px; }
  .story-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 22px 22px; }
  .story-card h3 { font-size: 0.98rem; font-weight: 800; margin: 0 0 12px; color: var(--text); line-height: 1.35; }
