  .problem-block p { font-size: 0.96rem; line-height: 1.7; margin: 0 0 10px; }
  .problem-block p:last-child { margin-bottom: 0; }

  .proc-list { padding-left: 22px; margin: 14px 0 0; }
  .proc-list li { font-size: 0.98rem; line-height: 1.7; color: var(--text); margin-bottom: 14px; }
