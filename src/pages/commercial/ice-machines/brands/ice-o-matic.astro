// src/pages/commercial/ice-machines/brands/ice-o-matic.astro
// T36 v2.1, Ice-O-Matic brand page in /commercial/ice-machines/brands/.
// Sister brand to Scotsman within Ali Group. Mid-tier value positioning vs
// Scotsman mid-premium. Same horizontal-evaporator + spray-pump architecture
// as Scotsman (Ali Group component sharing). Founded 1953, acquired by Ali
// Group ~2002, US ops Denver Colorado, Italian parent Ali Group Milan.
// Brand schema parentOrganization: Ali Group.
// EPA 608 Universal + R-290 (post-2020 transition).
// 9-block structure matched to manitowoc.astro / hoshizaki.astro siblings.
// SSOT compliant: no aggregateRating, no streetAddress.

import Layout from '../../../../layouts/Layout.astro';
import CommercialHero from '../../../../components/CommercialHero.astro';
import { MAIN_PHONE } from '../../../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/commercial/ice-machines/brands/ice-o-matic/";

const title = "Ice-O-Matic Ice Machine Repair Los Angeles — Same Day";
const description = `Ice-O-Matic ice machine repair across SoCal. ICE0250, ICE0320, ICE0500, ICE0606 cube + Pearl Ice nugget. Ali Group. EPA 608 + R-290 certified. ${phone}.`;

const faqs = [
  {
    q: "Ice-O-Matic vs Scotsman: same company?",
    a: "Sister brands within Ali Group, the Italian privately-held foodservice holding company. Same parent corporation. Different product lineups, different price tiers. Ice-O-Matic is mid-tier value, Scotsman is mid-premium. Some component architecture is shared (Ali Group efficiency), but they are separate brands with separate parts catalogs and service paths."
  },
  {
    q: "My Ice-O-Matic ICE0500 isn't making ice. What's wrong?",
    a: "Most likely spray pump wear. Ali Group horizontal evaporator plus spray pump architecture, the same architecture as sister brand Scotsman. Spray pump wear at year 5 to 8 means uneven spray, uneven ice formation, and production drops. Replacement runs $360 to $520. Other causes: scale buildup, water inlet valve, refrigerant low."
  },
  {
    q: "Do you service ICE0250, ICE0320, ICE0500, ICE0606, ICE0806?",
    a: "Yes. These ICE Series sizes cover roughly 80% of our Ice-O-Matic service calls. Common parts on the van: spray pumps, water inlet valves, harvest sensors, condenser fan motors."
  },
  {
    q: "What's AlpineAir?",
    a: "Ice-O-Matic's built-in air filtration system. Reduces airborne contaminants entering the ice machine. Periodic filter replacement required ($80 to $160). Distinctive Ice-O-Matic feature on newer ICE Series machines."
  },
  {
    q: "How long do Ice-O-Matic units last?",
    a: "Mid-tier value tier service life: 8 to 12 years inland, 6 to 10 years coastal. Slightly shorter than Scotsman premium (10 to 13 years inland) due to cost-optimized components. Cleaning compliance is the limiting factor: properly maintained machines reach 12 to 15 years even at this tier."
  },
  {
    q: "My Ice-O-Matic uses R-290. What's that?",
    a: "R-290 is propane, the hydrocarbon refrigerant Ice-O-Matic transitioned to post-2020 for environmental compliance. Different service procedures than R-134a or R-404A: smaller charges, specific leak detection, separate recovery procedure. Requires R-290 certification beyond standard EPA 608 Universal (#1346255700410). We have it."
  },
  {
    q: "What's your warranty?",
    a: "90 days SDAR labor warranty on every repair. Ice-O-Matic component warranties (where applicable through Ali Group North American distribution) are processed separately. BHGS #A49573, EPA 608 Universal plus R-290 certified, BBB Accredited Business."
  }
];

const schemaJsons = [
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": canonical + "#business",
    "name": "Same Day Appliance Repair",
    "url": canonical,
    "telephone": phone,
    "priceRange": "$$$",
    "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "08:00", "closes": "20:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "00:00", "closes": "00:00" }
      ],
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": canonical + "#service",
    "serviceType": "Ice-O-Matic Commercial Ice Machine Repair",
    "name": "Ice-O-Matic Ice Machine Repair Service",
    "url": canonical,
    "description": "Ice-O-Matic commercial ice machine repair across all five SoCal counties. ICE Series cube ice machines (ICE0250, ICE0320, ICE0500, ICE0500HA, ICE0606, ICE0806, ICE1006, ICE1407 in air-cooled, water-cooled, and remote-condensed configurations), Pearl Ice nugget machines (GEMU090, GEMU450), EF Series flake. AlpineAir filtered air system service. AgION antimicrobial coating maintenance. Smart Connect IoT diagnostic platform. Refrigerants: R-22 legacy, R-134a, R-404A, R-290 hydrocarbon (post-2020 transition). EPA 608 Universal plus R-290 certification. BHGS #A49573.",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "offers": {
      "@type": "Offer",
      "priceRange": "$120-$2600",
      "priceSpecification": {
        "@type": "PriceSpecification",
        "price": "120.00",
        "priceCurrency": "USD",
        "description": "Commercial-tier diagnostic fee, applied toward repair. No emergency surcharge."
      }
    },
    "brand": { "@id": canonical + "#brand" }
  },
  {
    "@context": "https://schema.org",
    "@type": "Brand",
    "@id": canonical + "#brand",
    "name": "Ice-O-Matic",
    "url": "https://www.iceomatic.com/",
    "description": "Ice-O-Matic is a mid-tier value commercial ice machine manufacturer founded in 1953. US operations headquartered in Denver, Colorado. Sister brand to Scotsman within Ali Group, the Italian privately-held foodservice holding company that owns roughly 25 commercial foodservice brands including Scotsman ice machines, Beverage-Air refrigeration, Champion dishwashers, and Carpigiani gelato equipment. Acquired by Ali Group in approximately 2002. Product lines: ICE Series cube ice machines (ICE0250, ICE0320, ICE0500, ICE0606, ICE0806, ICE1006, ICE1407), Pearl Ice nugget machines (GEMU090, GEMU450), EF Series flake. Distinctive features: AlpineAir filtered air system, AgION antimicrobial coating, Smart Connect IoT diagnostic platform, Pure Ice Filtration. Shares horizontal evaporator plus spray pump architecture with sister brand Scotsman.",
    "parentOrganization": {
      "@type": "Organization",
      "name": "Ali Group"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } }))
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Commercial", "item": "https://samedayappliance.repair/commercial/" },
      { "@type": "ListItem", "position": 3, "name": "Ice Machines", "item": "https://samedayappliance.repair/commercial/ice-machines/" },
      { "@type": "ListItem", "position": 4, "name": "Ice-O-Matic Repair", "item": canonical }
    ]
