---
// src/pages/commercial/ice-machines/water-leaking.astro
// Wave 9a, failure-mode sub-service. Water leak diagnostic.
// Practitioner angle: drain pump, water curtain, sump, supply line, condensate.
// $120 commercial. BHGS #A49573 + EPA 608 Universal #1346255700410.
import Layout from '../../../layouts/Layout.astro';
import CommercialHero from '../../../components/CommercialHero.astro';
import { MAIN_PHONE } from '../../../data/branches';

const phone = MAIN_PHONE;
const phoneRaw = MAIN_PHONE.replace(/\D/g, '');
const phoneHref = `tel:+1${phoneRaw}`;
const canonical = "https://samedayappliance.repair/commercial/ice-machines/water-leaking/";

const title = "Commercial Ice Machine Water Leaking LA — Same Day";
const description = "Restaurant ice machine leaking water? LA same-day. Hoshizaki, Manitowoc, Scotsman. BHGS #A49573, $120.";

const faqs = [
  {
    q: "My ice machine is leaking water. Where do I start?",
    a: "Three leak sources, ranked by frequency. (1) Drain side: drain pump failed, drain line clogged with scale, or condensate pan overflow. About 50% of leak calls. (2) Supply side: water inlet line connection failed, supply tube cracked, water filter housing leaking. About 25% of calls. (3) Internal: water curtain not seating, sump tank crack, evaporator coil distribution tube leak. About 25%. We dry the machine completely and run a cycle to identify the leak point at the diagnostic visit."
  },
  {
    q: "What's the most urgent leak situation?",
    a: "Water pooling on the floor near electrical components or under the equipment is treat-as-urgent because it creates slip hazard and equipment damage risk. Health Department inspections (LA County DPH and equivalent OC, Ventura, Riverside, San Bernardino agencies) flag standing water near food production equipment. We dispatch leak calls same-day priority over non-leak ice machine service. If the leak is severe enough that water is reaching the cabinet electricals, shut down the unit at the breaker before we arrive."
  },
  {
    q: "Why does my drain pump keep failing?",
    a: "Two reasons. (1) Scale buildup from LA water hardness (300 to 400 mg/L TDS on LADWP supply, higher on Inland Empire wells) coats the impeller and seizes the pump bearing. Annual descaling extends drain pump life from 5 years to 8+ years. (2) Restaurant grease, fish fines, and food particles from contaminated drain runs back-track through the drain pump. The fix is upstream: dedicated drain run, no shared drainage with food prep sinks. We diagnose at the visit and recommend the upstream fix when found."
  },
  {
    q: "Is the water curtain a real failure point?",
    a: "Yes, and a commonly missed one. The water curtain is the flexible flap on Hoshizaki KM-Edge, Manitowoc Indigo, Scotsman Prodigy, and most cube ice machines that closes the freeze chamber during the freeze cycle and opens during harvest. When it doesn't seal correctly (warped, stretched, or has lost its lower-edge gasket), water sprays past the curtain into the bin or out the front of the machine during freeze cycle. Symptom: leak only happens during freeze, not during harvest or off-cycle. Replacement runs $185 to $285."
  },
  {
    q: "What's the typical cost?",
    a: "Drain pump replacement: $385 to $585. Drain line cleanout / descaling: $185 to $285. Water curtain replacement: $185 to $285. Sump tank replacement (rare, year 12+ on cube units): $585 to $885. Water inlet supply line / connection repair: $185 to $285. Condensate pan replacement: $245 to $385. Evaporator coil distribution tube repair (rare, EPA 608 sealed-system if coil is involved): $585 to $985. The $120 commercial diagnostic is waived with repair."
  },
  {
    q: "How does Health Department compliance factor in?",
    a: "Standing water near commercial ice production equipment is a sanitation flag during routine inspections. LA County DPH inspectors note water on the floor under the ice machine in the inspection log. A leak that's been ignored for weeks or months produces sanitation violations. We document every leak repair with date, scope of work, and parts replaced specifically so operators have a paper trail showing the leak was addressed promptly when it was identified. Keep the invoice with the operations records the inspector reviews."
  },
  {
    q: "What's your warranty?",
    a: "90 days SDAR labor and parts on every repair. Sealed-system work documented under EPA 608 Universal #1346255700410. BHGS #A49573, BBB A+ accredited."
  }
];

const schemaJsons = [
  {
    "@context": "https://schema.org", "@type": "LocalBusiness", "@id": canonical + "#business",
    "name": "Same Day Appliance Repair", "url": canonical, "telephone": phone, "priceRange": "$$",
    "openingHoursSpecification": [
        { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"], "opens": "08:00", "closes": "20:00" },
        { "@type": "OpeningHoursSpecification", "dayOfWeek": "Sunday", "opens": "00:00", "closes": "00:00" }
      ],
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ]
  },
  {
    "@context": "https://schema.org", "@type": "Service", "@id": canonical + "#service",
    "serviceType": "Commercial Ice Machine Water Leak Repair",
    "name": "Ice Machine Leak Diagnostic and Repair",
    "url": canonical,
    "description": "Commercial ice machine water leak diagnostic across all five SoCal counties. Drain pump replacement, drain line scale clearing, water curtain replacement, sump tank repair, supply line connection repair, condensate pan replacement, evaporator coil distribution leak. Hoshizaki, Manitowoc, Scotsman, Ice-O-Matic, Follett. Health Department compliance documentation. EPA 608 Universal certified for sealed-system work. $120 commercial diagnostic, applied toward repair. BHGS #A49573, EPA 608 Universal #1346255700410.",
    "provider": { "@id": canonical + "#business" },
    "areaServed": [
      { "@type": "AdministrativeArea", "name": "Los Angeles County" },
      { "@type": "AdministrativeArea", "name": "Orange County" },
      { "@type": "AdministrativeArea", "name": "Ventura County" },
      { "@type": "AdministrativeArea", "name": "San Bernardino County" },
      { "@type": "AdministrativeArea", "name": "Riverside County" }
    ],
    "offers": { "@type": "Offer", "priceSpecification": { "@type": "PriceSpecification", "price": "120.00", "priceCurrency": "USD", "description": "Commercial diagnostic fee, applied toward repair" } }
  },
  { "@context": "https://schema.org", "@type": "FAQPage", "mainEntity": faqs.map(f => ({ "@type": "Question", "name": f.q, "acceptedAnswer": { "@type": "Answer", "text": f.a } })) },
  {
    "@context": "https://schema.org", "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://samedayappliance.repair/" },
      { "@type": "ListItem", "position": 2, "name": "Commercial", "item": "https://samedayappliance.repair/commercial/" },
      { "@type": "ListItem", "position": 3, "name": "Ice Machines", "item": "https://samedayappliance.repair/commercial/ice-machines/" },
      { "@type": "ListItem", "position": 4, "name": "Water Leaking", "item": canonical }
    ]
  }
];
---

<Layout title={title} description={description} canonical={canonical}>

<Fragment slot="head-scripts">
  {schemaJsons.map((schema) => (<script type="application/ld+json" set:html={JSON.stringify(schema)} />))}
</Fragment>

<CommercialHero
  title="Commercial Ice Machine Water Leaking, Same-Day Diagnostic"
  subtitle={`Pooling water on the floor or inside the cabinet? Drain pump, water curtain, sump, supply line. Health Department compliance documentation included. ${phone}`}
  heroImageTitle="Commercial Ice Machine Water Leak"
  showBranches={true}
/>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Leak diagnostic</p>
    <h2>Three leak sources. The location tells us almost everything before we open the cabinet.</h2>

    <p>Commercial ice machine water leaks fall into three categories that determine the repair tier. Drain-side leaks (drain pump failure, drain line clogged with scale, condensate pan overflow) account for about 50% of leak calls and run $185 to $585 typical. Supply-side leaks (water inlet connection failed, supply tube cracked, filter housing leaking) account for about 25% and run $185 to $385. Internal leaks (water curtain not seating, sump tank crack, evaporator coil distribution tube) account for the remaining 25% and run $185 to $885 depending on which component failed.</p>

    <p>The leak point determines the urgency tier. Water pooling on the floor near electrical components is treat-as-urgent: shut down the unit at the breaker before we arrive. Standing water under the cabinet but not reaching electricals is high-priority but not emergency. Slow drips into the catch tray or rear drainage are scheduled-priority. We dispatch leak calls same-day priority over non-leak ice machine service because the secondary damage from extended leaks (cabinet rot, electrical corrosion, Health Department flagging) compounds.</p>

    <p>$120 commercial diagnostic, waived with repair. BHGS #A49573 + EPA 608 Universal #1346255700410. We service Hoshizaki KM-Edge, F-Series, DCM Cubelet; Manitowoc Indigo NXT, Q-Model, RFS Flake; Scotsman Prodigy ELITE, NS-Series Nugget, Brilliance; Ice-O-Matic ICE-series, GEM, MFI; Follett Chewblet across all five SoCal counties.</p>
  </div>
</section>

<section class="section section-gray">
  <div class="container">
    <p class="section-number">Three leak categories</p>
    <h2>Drain-side, supply-side, internal.</h2>

    <h3 class="series-h3">Drain-side (50% of calls)</h3>
    <p>Most common leak source. Three sub-causes:</p>
    <ul class="reasons-list">
      <li><strong>Drain pump failure</strong>, pump impeller seized from scale or food debris, motor windings burned out, or thermal overload tripped repeatedly. Year 5 to 8 typical lifespan in LA water hardness conditions. Replacement $385 to $585.</li>
      <li><strong>Drain line clogged with scale</strong>, LA municipal water at 300 to 400 mg/L TDS deposits calcium and magnesium on drain line interior walls. Annual descaling prevents; restoration of clogged drain runs $185 to $285.</li>
      <li><strong>Condensate pan overflow</strong>, pan crack, drain port clog, or installation slope error. Replacement $245 to $385.</li>
    </ul>

    <h3 class="series-h3">Supply-side (25% of calls)</h3>
    <ul class="reasons-list">
      <li><strong>Water inlet connection</strong>, compression fitting at the water inlet valve loosens with vibration, or the rubber gasket compresses and loses seal. Re-seat or replace gasket. $185 to $285.</li>
      <li><strong>Supply tubing cracked</strong>, typically at a kink point or where the tube enters the cabinet. Replace section or full supply line. $185 to $285.</li>
      <li><strong>Water filter housing leak</strong>, Cuno, 3M, or Everpure filter housing seal degraded. Replace seal or full housing. $185 to $285.</li>
    </ul>

    <h3 class="series-h3">Internal (25% of calls)</h3>
    <ul class="reasons-list">
      <li><strong>Water curtain not seating</strong>, flexible flap on Hoshizaki KM-Edge, Manitowoc Indigo, Scotsman Prodigy, Ice-O-Matic ICE-series. Warped, stretched, or torn. Symptom: leaks only during freeze cycle, dry during harvest. Replacement $185 to $285.</li>
      <li><strong>Sump tank crack</strong>, rare, year 12+ on cube units. Hairline crack in the sump that holds recirculated water. Replacement $585 to $885.</li>
      <li><strong>Evaporator distribution tube</strong>, water distribution to the freeze plate develops a small leak. EPA 608 sealed-system work if any refrigerant tubing is involved. $585 to $985.</li>
    </ul>
  </div>
</section>

<section class="section">
  <div class="container narrow">
    <p class="section-number">Pricing</p>
    <h2>Leak repair costs.</h2>

    <table class="price-table">
      <thead><tr><th>Repair</th><th>Typical Cost</th></tr></thead>
      <tbody>
        <tr><td>Diagnostic (waived with repair)</td><td>$120</td></tr>
        <tr><td>Drain pump replacement</td><td>$385 to $585</td></tr>
        <tr><td>Drain line scale clearing / descaling</td><td>$185 to $285</td></tr>
        <tr><td>Water curtain replacement</td><td>$185 to $285</td></tr>
        <tr><td>Sump tank replacement</td><td>$585 to $885</td></tr>
        <tr><td>Water inlet supply line repair</td><td>$185 to $285</td></tr>
        <tr><td>Water filter housing replacement</td><td>$185 to $285</td></tr>
        <tr><td>Condensate pan replacement</td><td>$245 to $385</td></tr>
        <tr><td>Evaporator distribution leak (EPA 608)</td><td>$585 to $985</td></tr>
        <tr><td>Health Department documentation (included)</td><td>$0</td></tr>
        <tr><td>Warranty</td><td>90 days parts and labor</td></tr>
      </tbody>
    </table>
  </div>
</section>

<section class="section section-gray">
  <div class="container narrow">
    <p class="section-number">FAQ</p>
    <h2>Water leak questions.</h2>
    <div class="faq-list">
      {faqs.map(f => (<details class="faq-item"><summary>{f.q}</summary><p set:html={f.a}></p></details>))}
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <p class="section-number">Related</p>
    <h2>Ice machine service across the catalog.</h2>
    <div class="related-grid">
      <a href="/commercial/ice-machines/" class="related-card"><h3>Ice Machines Hub</h3><p>Parent pillar.</p></a>
      <a href="/commercial/ice-machines/not-making-ice/" class="related-card"><h3>Not Making Ice</h3><p>Production-failure five-step diagnostic.</p></a>
      <a href="/commercial/ice-machines/error-codes/" class="related-card"><h3>Error Codes</h3><p>Brand-specific code interpretation guides.</p></a>
      <a href="/commercial/ice-machines/cleaning-service/" class="related-card"><h3>Cleaning + Sanitization</h3><p>Annual descaling prevents drain pump failure.</p></a>
      <a href="/commercial/ice-machines/brands/follett/" class="related-card"><h3>Follett</h3><p>Healthcare + chewable ice specialty.</p></a>
    </div>
  </div>
</section>

<section class="bottom-cta">
  <div class="container">
    <h2>Ice machine leaking? Same-day priority, Health Department documentation included.</h2>
    <p>All five major brands across LA, OC, Ventura. $120 commercial diagnostic, waived with repair. BHGS #A49573 + EPA 608 #1346255700410.</p>
    <div class="cta-row">
      <a href={phoneHref} class="btn-primary">☎ Call {phone}</a>
      <a href="/contact/" class="btn-secondary">Book Online</a>
    </div>
  </div>
</section>

</Layout>

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .section { padding: 72px 24px; }
  .section-gray { background: var(--gray); }
  .container { max-width: 1100px; margin: 0 auto; }
  .container.narrow { max-width: 820px; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  .section h2 { font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 800; margin: 0 0 18px; line-height: 1.2; }
  .section p { font-size: 1rem; line-height: 1.75; margin: 0 0 16px; }
  .section a { color: var(--red); font-weight: 600; text-decoration: none; }
  .section a:hover { text-decoration: underline; }
  .series-h3 { font-size: 1.1rem; font-weight: 800; margin: 28px 0 10px; }
  .reasons-list { padding-left: 22px; margin: 12px 0 16px; }
  .reasons-list li { font-size: 1rem; line-height: 1.75; margin-bottom: 8px; }
  .price-table { width: 100%; border-collapse: collapse; margin-top: 22px; background: #fff; border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
  .price-table th, .price-table td { padding: 12px 16px; text-align: left; border-bottom: 1px solid var(--border); font-size: 0.95rem; }
  .price-table th { background: var(--gray); font-weight: 700; }
  .price-table tr:last-child td { border-bottom: none; }
  .faq-list { margin-top: 24px; }
  .faq-item { background: #fff; border: 1px solid var(--border); border-radius: 6px; padding: 18px 22px; margin-bottom: 12px; }
  .faq-item summary { font-weight: 700; cursor: pointer; font-size: 1rem; list-style: none; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::before { content: "+ "; color: var(--red); font-weight: 800; margin-right: 6px; }
  .faq-item[open] summary::before { content: "− "; }
  .faq-item p { font-size: 0.95rem; line-height: 1.75; margin: 14px 0 0; }
  .related-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 18px; margin-top: 22px; }
  .related-card { display: block; background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 22px; text-decoration: none; color: var(--text); transition: all 0.2s; }
  .related-card:hover { border-color: var(--red); transform: translateY(-2px); box-shadow: 0 4px 14px rgba(0,0,0,0.06); }
  .related-card h3 { font-size: 1rem; font-weight: 800; margin: 0 0 8px; }
  .related-card p { font-size: 0.85rem; color: var(--muted); margin: 0; line-height: 1.6; }
  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { color: #fff; margin: 0 0 14px; font-size: 1.7rem; }
  .bottom-cta p { color: #c9c9c9; margin: 0 0 26px; max-width: 720px; margin-left: auto; margin-right: auto; }
  .cta-row { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 14px 28px; border-radius: 5px; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 14px 28px; border-radius: 5px; border: 2px solid rgba(255,255,255,0.35); font-weight: 600; text-decoration: none; }
</style>
