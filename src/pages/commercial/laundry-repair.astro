---
// src/pages/commercial/laundry-repair.astro
// Wave 5, /commercial/, PAGE 11 of 15
// GSC: "commercial laundry repair" 69 imp pos 20.9
//      "commercial laundry repair service" 23 imp pos 16.4, with 1 click!
//      "commercial laundry repair near me" 1 imp pos 6.0, already top-10
// STRATEGY: Hub page for washer + dryer combined intent
// KEY: Most SERP results are laundry SERVICE (pickup/delivery) not EQUIPMENT REPAIR
// Unique angles: repair vs service disambiguation; LA multifamily property managers;
// hub to washer/dryer deep pages; multi-machine visits; coin-op focus

import Layout from '../../layouts/Layout.astro';
import CommercialHero from '../../components/CommercialHero.astro';
import { MAIN_PHONE } from '../../data/branches';

const title = "Commercial Laundry Repair Los Angeles — Same Day";
const description = "Same-day commercial laundry equipment repair across LA, Orange, Ventura, San Bernardino & Riverside counties. BHGS #A49573. EPA 608. $120 dx.";
const phone = MAIN_PHONE.display;
const phoneRaw = MAIN_PHONE.raw;
const phoneHref = MAIN_PHONE.href;
---

<Layout title={title} description={description}>

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Commercial Laundry Equipment Repair",
  "serviceType": "Commercial Laundry Repair",
  "description": "Same-day commercial laundry equipment repair across Southern California, washers and dryers for laundromats, apartment buildings, hotels, gyms, care facilities. Speed Queen, Dexter, Huebsch, Maytag Commercial, Continental Girbau. BHGS #A49573. $120 commercial diagnostic.",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Same Day Appliance Repair",
    "telephone": phone,
    "url": "https://samedayappliance.repair/",
    "priceRange": "$$"
  },
  "areaServed": [
    {"@type":"AdministrativeArea","name":"Los Angeles County"},
    {"@type":"AdministrativeArea","name":"Orange County"},
    {"@type":"AdministrativeArea","name":"Ventura County"},
    {"@type":"AdministrativeArea","name":"San Bernardino County"},
    {"@type":"AdministrativeArea","name":"Riverside County"}
  ],
  "offers": {
    "@type": "Offer",
    "priceSpecification": {
      "@type": "PriceSpecification",
      "price": "120.00",
      "priceCurrency": "USD",
      "description": "Commercial diagnostic fee, applied toward the repair when approved."
    }
  }
})} />

<script type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the difference between commercial laundry repair and laundry service?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Commercial laundry repair means fixing the washing and drying machines themselves, when a washer won't drain, a dryer won't heat, or a coin-op unit stops working. Commercial laundry service (or linen service) means picking up dirty laundry and returning it clean. We do equipment repair, we fix your machines so they work again. We don't pick up or clean laundry."
      }
    },
    {
      "@type": "Question",
      "name": "Which areas of Southern California do you cover for commercial laundry repair?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Same-day across Los Angeles, Orange, Ventura, San Bernardino, and Riverside counties, Koreatown, Hollywood, Long Beach LA-side laundromats and apartment buildings; Anaheim, Garden Grove, Costa Mesa OC laundromats; Thousand Oaks and Oxnard Ventura; Rancho Cucamonga, Riverside, and Ontario IE laundromats and multi-unit residential. Eight service territories total. Speed Queen, Dexter, Huebsch, Maytag Commercial. BHGS #A49573."
      }
    },
    {
      "@type": "Question",
      "name": "How quickly can you repair commercial laundry equipment?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Same day for most commercial laundry calls across all five SoCal counties. Call before noon and we typically dispatch that day. For apartment buildings with tenant complaints, we prioritize to minimize the time tenants are without laundry access. For laundromats where down machines mean lost coin revenue, we route as priority. When you call, describe all machines needing service so we can bring the right parts for multiple repairs in one visit."
      }
    },
    {
      "@type": "Question",
      "name": "Do you service all commercial laundry brands?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Speed Queen, Dexter, Huebsch, Maytag Commercial, Continental Girbau, UniMac, Wascomat, Electrolux Professional, and Milnor are the brands we service most across SoCal laundromats and apartment buildings, all five counties. Speed Queen parts are carried on service vehicles, Speed Queen is the dominant brand in SoCal's multi-family laundry market."
      }
    },
    {
      "@type": "Question",
      "name": "Can you service multiple washers and dryers on the same visit?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. For laundromats and apartment buildings with multiple machines, we prioritize servicing all affected units on the same trip. When you call, describe every machine needing service and the symptoms, this lets us bring appropriate parts for multiple repairs and minimize the number of visits needed."
      }
    },
    {
      "@type": "Question",
      "name": "Do you repair coin-operated washers and dryers in laundromats?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, the mechanical and electrical systems. Drain pump, motor, bearings, door lock, water inlet valve, heating element, drive belt, and control board. For coin acceptor and card reader payment system electronics specifically, we assess on-site and let you know whether it's within our scope or requires the payment system vendor. Most coin-op failures are the machine, not the payment system."
      }
    },
    {
      "@type": "Question",
      "name": "Do you offer maintenance contracts for laundromats and apartment buildings?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. For laundromats and multi-machine apartment buildings across all five SoCal counties, we offer scheduled maintenance visits, drain pump inspection, door gasket check, bearing condition assessment, dryer vent cleaning, water inlet valve test, and control board error code scan. Regular maintenance prevents the simultaneous multi-machine failures that happen without it. Call to discuss your machine inventory and service interval."
      }
    }
  ]
})} />

<style>
  :root { --red: #C8102E; --black: #0a0a0a; --gray: #f5f5f5; --border: #e2e2e2; --text: #1a1a1a; --muted: #6b6b6b; }
  .hero { background: var(--black); color: #fff; padding: 80px 24px 64px; text-align: center; }
  .hero-eyebrow { display: inline-block; background: var(--red); color: #fff; font-size: 0.78rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 5px 14px; border-radius: 3px; margin-bottom: 20px; }
  .hero h1 { font-size: clamp(1.9rem, 4vw, 2.9rem); font-weight: 800; line-height: 1.15; margin: 0 0 20px; max-width: 860px; margin-left: auto; margin-right: auto; }
  .hero-sub { font-size: 1.1rem; color: #ccc; max-width: 640px; margin: 0 auto 32px; line-height: 1.6; }
  .cta-row { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; }
  .btn-primary { background: var(--red); color: #fff; padding: 16px 34px; border-radius: 5px; font-size: 1rem; font-weight: 700; text-decoration: none; }
  .btn-secondary { background: transparent; color: #fff; padding: 16px 34px; border-radius: 5px; font-size: 1rem; font-weight: 600; text-decoration: none; border: 2px solid rgba(255,255,255,0.35); }
  .hero-meta { margin-top: 28px; color: #aaa; font-size: 0.9rem; display: flex; gap: 24px; justify-content: center; flex-wrap: wrap; }
  .trust-bar { background: var(--red); padding: 18px 24px; }
  .trust-inner { max-width: 1100px; margin: 0 auto; display: flex; justify-content: center; flex-wrap: wrap; gap: 10px 32px; }
  .trust-item { color: #fff; font-size: 0.88rem; font-weight: 600; }
  .section { padding: 64px 24px; }
  .section-gray { background: var(--gray); }
  .section-black { background: var(--black); color: #fff; }
  .container { max-width: 1100px; margin: 0 auto; }
  .section-number { font-size: 0.75rem; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: var(--red); margin-bottom: 10px; }
  h2.section-title { font-size: clamp(1.5rem, 3vw, 2.1rem); font-weight: 800; margin: 0 0 16px; line-height: 1.2; }
  .section-black h2.section-title { color: #fff; }
  .lead { font-size: 1.05rem; line-height: 1.75; color: var(--text); max-width: 760px; }
  .section-black .lead { color: #ccc; }
  .intro-grid { display: grid; grid-template-columns: 1fr 320px; gap: 48px; align-items: start; }
  @media (max-width: 768px) { .intro-grid { grid-template-columns: 1fr; } }
  .intro-body p { margin: 0 0 18px; font-size: 1.05rem; line-height: 1.8; color: var(--text); }
  .clarity-box { background: #f0f5ff; border: 1px solid #c0d0f0; border-radius: 8px; padding: 20px 22px; margin-top: 24px; }
  .clarity-box .cb-label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #4060b0; margin-bottom: 10px; }
  .clarity-box p { font-size: 0.93rem; color: #304080; margin: 0; line-height: 1.65; }
  .sticky-cta { position: sticky; top: 24px; background: var(--black); border-radius: 10px; padding: 28px 24px; color: #fff; text-align: center; }
  .sticky-cta .cta-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.1em; color: #aaa; margin-bottom: 14px; }
  .sticky-cta .cta-phone { font-size: 1.5rem; font-weight: 800; color: #fff; text-decoration: none; display: block; margin-bottom: 12px; }
  .sticky-cta .btn-cta { display: block; background: var(--red); color: #fff; padding: 14px; border-radius: 5px; font-weight: 700; text-decoration: none; font-size: 0.95rem; margin-bottom: 10px; }
  .sticky-cta .cta-sub { font-size: 0.82rem; color: #888; }
  .cta-divider { border: none; border-top: 1px solid #222; margin: 18px 0; }
  .cta-detail { font-size: 0.85rem; color: #aaa; text-align: left; }
  .cta-detail li { margin-bottom: 6px; list-style: none; padding-left: 18px; position: relative; }
  .cta-detail li::before { content: "✓"; position: absolute; left: 0; color: var(--red); font-weight: 700; }
  /* Services hub cards */
  .hub-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-top: 32px; }
  @media (max-width: 640px) { .hub-grid { grid-template-columns: 1fr; } }
  .hub-card { background: #111; border: 1px solid #2a1a1a; border-radius: 10px; padding: 28px 24px; text-decoration: none; transition: border-color 0.2s; display: block; }
  .hub-card:hover { border-color: var(--red); }
  .hub-card .hc-icon { font-size: 2rem; margin-bottom: 12px; display: block; }
  .hub-card h3 { font-size: 1.1rem; font-weight: 800; color: #fff; margin: 0 0 10px; }
  .hub-card p { font-size: 0.88rem; color: #888; line-height: 1.6; margin: 0 0 14px; }
  .hub-card .hc-issues { font-size: 0.82rem; color: #555; line-height: 1.6; }
  .hub-card .hc-brands { font-size: 0.78rem; color: #444; margin-top: 10px; font-style: italic; }
  .hub-card .hc-link { display: inline-block; font-size: 0.85rem; font-weight: 700; color: var(--red); margin-top: 14px; }
  /* Who we serve */
  .biz-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(210px, 1fr)); gap: 14px; margin-top: 28px; }
  .biz-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 18px 16px; }
  .biz-card h3 { font-size: 0.9rem; font-weight: 700; margin: 0 0 6px; color: var(--text); }
  .biz-card p { font-size: 0.82rem; color: var(--muted); line-height: 1.5; margin: 0; }
  /* Property manager block */
  .pm-block { background: #05080f; border: 1px solid #101830; border-radius: 10px; padding: 30px 26px; margin-top: 32px; }
  .pm-block .pm-label { font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: #6090d0; margin-bottom: 12px; }
  .pm-block h3 { font-size: 1.1rem; font-weight: 800; color: #fff; margin: 0 0 12px; }
  .pm-block p { font-size: 0.91rem; color: #406080; line-height: 1.7; margin: 0 0 12px; }
  .pm-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 10px; margin-top: 14px; }
  .pm-item { background: #020508; border: 1px solid #0a1020; border-radius: 6px; padding: 12px 14px; }
  .pm-item strong { display: block; font-size: 0.85rem; color: #5080c0; margin-bottom: 3px; }
  .pm-item span { font-size: 0.8rem; color: #203040; line-height: 1.4; }
  /* Brands */
  .brands-grid { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 28px; }
  .brand-chip { background: #fff; border: 1px solid var(--border); border-radius: 4px; padding: 8px 18px; font-size: 0.88rem; font-weight: 600; color: var(--text); }
  .brand-chip.dark { background: #1a1a1a; color: #ddd; border-color: #333; }
  /* Pricing */
  .pricing-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 18px; margin-top: 32px; }
  .price-card { background: #fff; border: 1px solid var(--border); border-radius: 8px; padding: 22px 18px; text-align: center; }
  .price-card .price-label { font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--muted); margin-bottom: 8px; }
  .price-card .price-amount { font-size: 1.8rem; font-weight: 800; color: var(--text); line-height: 1; margin-bottom: 8px; }
  .price-card .price-desc { font-size: 0.84rem; color: var(--muted); line-height: 1.5; }
  .price-note { margin-top: 18px; font-size: 0.9rem; color: var(--muted); line-height: 1.6; }
  .faq-list { margin-top: 36px; }
  .faq-item { border-bottom: 1px solid var(--border); padding: 20px 0; }
  .faq-item:first-child { border-top: 1px solid var(--border); }
  .faq-item h3 { font-size: 1rem; font-weight: 700; color: var(--text); margin: 0 0 10px; }
  .faq-item p { font-size: 0.95rem; color: var(--muted); line-height: 1.7; margin: 0; }
  .nearby-links { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 24px; }
  .nearby-links a { background: #fff; border: 1px solid var(--border); border-radius: 4px; padding: 8px 16px; font-size: 0.87rem; color: var(--text); text-decoration: none; font-weight: 500; }
  .nearby-links a:hover { border-color: var(--red); color: var(--red); }
  .bottom-cta { background: var(--black); color: #fff; padding: 64px 24px; text-align: center; }
  .bottom-cta h2 { font-size: clamp(1.6rem, 3vw, 2.2rem); font-weight: 800; margin: 0 0 16px; }
  .bottom-cta p { color: #aaa; margin: 0 0 32px; font-size: 1.05rem; }
</style>

<!-- HERO + TRUST BAR (unified CommercialHero) -->
<CommercialHero
  title="Commercial Laundry Repair Across Southern California"
  subtitle="Same-day across LA, Orange, Ventura, San Bernardino & Riverside counties. Washers and dryers for laundromats, apartment buildings, hotels, and gyms, we fix the equipment. Speed Queen, Dexter, Huebsch, Maytag Commercial, Continental Girbau. BHGS #A49573."
  heroImageTitle="Commercial Laundry Repair"
/>

<!-- INTRO -->
<section class="section">
  <div class="container">
    <div class="intro-grid">
      <div class="intro-body">
        <p class="section-number">01, About This Service</p>
        <h2 class="section-title">We fix laundry machines. We don't pick up laundry.</h2>

        <p>Searching for "commercial laundry repair" across SoCal returns a mix of results, laundry pickup and delivery services, linen service companies, and actual equipment repair. We're the last category. When your washers and dryers stop working, we come to your location and fix them.</p>

        <p>Southern California has the highest density of multi-unit apartment buildings in the western US, and each one with a shared laundry room depends on commercial washers and dryers functioning reliably. For property managers across LA's Koreatown/Silver Lake/Echo Park/Westside, OC's Anaheim/Garden Grove/Costa Mesa, Ventura's Thousand Oaks/Oxnard, and the IE's Rancho Cucamonga/Riverside/Ontario corridors, a down machine means tenant complaints within hours. For laundromat operators, it means immediate coin revenue loss. We understand both contexts and dispatch accordingly across all five counties, eight service territories total. BHGS #A49573.</p>

        <p>This page covers commercial laundry equipment repair broadly. For deep-dive information on specific equipment, see our dedicated pages:</p>
        <ul style="margin:0 0 18px; padding-left:20px; font-size:1.05rem; color:var(--text); line-height:2;">
          <li><a href="/commercial/washer-repair/" style="color:var(--red); font-weight:600;">Commercial Washer Repair →</a> drain pump, motor coupling, bearings, door lock, all washer brands</li>
          <li><a href="/commercial/" style="color:var(--red); font-weight:600;">Commercial Dryer Repair →</a> heating element, vent cleaning, fire safety, Speed Queen, Huebsch</li>
        </ul>

        <div class="clarity-box">
          <div class="cb-label">📋 What "Commercial Laundry Repair" Means</div>
          <p><strong>We repair:</strong> washers, dryers, stacked washer-dryer units, coin-operated laundry equipment, on-site, same day, at your laundromat or building. <strong>We do not:</strong> pick up laundry, provide linen service, or do off-site washing. If your machines are broken, call <strong>{phone}</strong>.</p>
        </div>
      </div>

      <aside class="sticky-cta">
        <div class="cta-label">Equipment Repair, Same Day</div>
        <a href={phoneHref} class="cta-phone">{phone}</a>
        <a href={phoneHref} class="btn-cta">Call Now, Same Day</a>
        <a href="/book" class="btn-cta" style="background:#222; margin-top:-4px;">Schedule Online</a>
        <div class="cta-sub">Mon–Sun 7am–9pm · Commercial calls prioritized</div>
        <hr class="cta-divider" />
        <ul class="cta-detail">
          <li>Commercial diagnostic: $120/machine</li>
          <li>BHGS #A49573</li>
          <li>Speed Queen parts on van</li>
          <li>Multi-machine same visit</li>
          <li>5-county SoCal coverage</li>
          <li>Maintenance contracts available</li>
        </ul>
      </aside>
    </div>
  </div>
</section>

<!-- HUB: WASHER + DRYER -->
<section class="section section-black">
  <div class="container">
    <p class="section-number">02, What We Fix</p>
    <h2 class="section-title">Washers and dryers, separate systems, dedicated pages</h2>
    <p class="lead">Commercial washers and dryers have different failure modes and repair requirements. Click through for detailed information on each.</p>

    <div class="hub-grid">
      <a href="/commercial/washer-repair/" class="hub-card">
        <span class="hc-icon">🫧</span>
        <h3>Commercial Washer Repair</h3>
        <p>Not draining, not spinning, water leak, door lock failure, error codes. Coin-operated and card-reader equipped machines. Multi-machine laundry rooms, apartment buildings, laundromats, hotels.</p>
        <div class="hc-issues">Common: drain pump · motor coupling · drum bearing · door gasket · water inlet valve · control board</div>
        <div class="hc-brands">Speed Queen · Dexter · Maytag Commercial · Continental Girbau · UniMac · Wascomat</div>
        <span class="hc-link">Commercial Washer Repair Details →</span>
      </a>
      <a href="/commercial/" class="hub-card">
        <span class="hc-icon">🌬️</span>
