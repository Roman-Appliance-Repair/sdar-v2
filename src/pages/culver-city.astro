---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import CustomNarrative from '../components/cities/v2/CustomNarrative.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

const citySlug = 'culver-city';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = 'Culver City';
const zips = ['90230', '90232'];

const phoneRaw = `+1${branch.phone.replace(/\D/g, '')}`;

const title = `Appliance Repair Culver City CA — Same Day | Hayden Tract · Fox Hills · ${branch.phone}`;
const description = `Same-day appliance repair in Culver City, CA 90230 & 90232. Hayden Tract, Arts District, Fox Hills, Blair Hills, Sony Pictures area. DCS, Fisher & Paykel specialists. Licensed, OEM parts, 90-day warranty. Call ${branch.phone}.`;
const canonical = 'https://samedayappliance.repair/culver-city/';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { '@type': 'City', name: 'Culver City', sameAs: 'https://en.wikipedia.org/wiki/Culver_City,_California' },
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$',
  license: 'CA CSLB #1138898',
  aggregateRating: {
    '@type': 'AggregateRating',
    ratingValue: '4.6',
    reviewCount: '37',
    bestRating: '5',
  },
};

const introParagraphs = [
  "Culver City went through a real transformation when Amazon, Apple, and a wave of tech companies moved into the Hayden Tract. What used to be a quiet studio town is now a mix of creative offices, production facilities, and a housing market that followed the money — new construction condos with Samsung French doors and Bosch dishwashers sitting a few blocks from 1940s bungalows where the kitchen has been updated one appliance at a time.",
  "A lot of our Culver City calls come from people who work from home — creative professionals, tech workers with hybrid schedules. When the washer breaks or the fridge stops cooling, it's not just inconvenient — it's happening in a home that's also a workspace. Getting same-day same day appliance repair in Culver City isn't a luxury for these customers, it's a practical need.",
  "One thing that makes Culver City specific for us: the area has a higher-than-average concentration of DCS and Fisher & Paykel appliances — partly from the entertainment industry connection, partly from the design-conscious renovations in the older housing stock. We service both brands and carry OEM parts for them on our trucks.",
  `Diagnostic fee: <strong>$89</strong> — waived with repair. Written estimate before we start. <strong>90-day warranty</strong> on parts and labor. Call <a href="tel:${phoneRaw}">${branch.phone}</a>.`,
];

const services = [
  { icon: '🧊', name: 'Refrigerator Repair', slug: 'refrigerator', issues: 'Not cooling · Ice maker · Fan motor · Leaking · French door', brands: 'Samsung · LG · GE · Whirlpool · Sub-Zero · Fisher & Paykel' },
  { icon: '🫧', name: 'Washer Repair', slug: 'washer', issues: 'Not draining · Not spinning · Shaking · Error codes · Stackable', brands: 'LG · Samsung · Whirlpool · Bosch · Miele · Maytag' },
  { icon: '♨️', name: 'Dryer Repair', slug: 'dryer', issues: 'Not heating · Takes too long · Dryer vent cleaning · Gas & electric', brands: 'LG · Samsung · GE · Maytag · Whirlpool · Electrolux' },
  { icon: '🍽️', name: 'Dishwasher Repair', slug: 'dishwasher', issues: 'Not draining · Not cleaning · Leaking · Error codes', brands: 'Bosch · KitchenAid · Samsung · LG · Fisher & Paykel · GE' },
  { icon: '🔥', name: 'Oven, Range & DCS Repair', slug: 'oven', issues: 'DCS indoor/outdoor · Not heating · Igniter · Gas valve · Calibration', brands: 'DCS · Fisher & Paykel · Wolf · Thermador · GE · Samsung' },
  { icon: '❄️', name: 'Freezer Repair', slug: 'freezer', issues: 'Not freezing · Temperature off · Frost buildup · Ice maker', brands: 'GE · Samsung · LG · Whirlpool · Sub-Zero · True' },
  { icon: '🔆', name: 'Cooktop & Range Hood Repair', slug: 'cooktop', issues: 'Burner issues · Induction · Hood motor · DCS outdoor', brands: 'DCS · Dacor · Wolf · Thermador · Samsung · Bosch' },
  { icon: '🍷', name: 'Wine & Beverage Cooler Repair', slug: 'wine-cooler', issues: 'Not cooling · Temperature off · Compressor · Beverage center', brands: 'Sub-Zero · True · Liebherr · Dacor · Jenn-Air · Marvel' },
];

const dcsNarrative = {
  eyebrow: 'DCS & FISHER & PAYKEL SPECIALISTS',
  headline: 'DCS and Fisher & Paykel Appliance Repair in Culver City',
  paragraphs: [
    "Fisher & Paykel — the New Zealand brand behind both F&P appliances and the DCS professional cooking line — shows up in Culver City kitchens more often than in most LA neighborhoods. The entertainment industry connection runs deep here: production designers and set decorators who know quality appliances, combined with the design-forward renovations that happen when creative professionals buy the older Culver City housing stock.",
    "DCS ranges, cooktops, and outdoor cooking units are a different animal than standard American brands. The commercial-grade gas valve systems, the specific burner configurations, and the DCS ignition design require technicians who have actually worked on them — not guesswork from someone who's only seen a Wolf. Our technicians carry OEM Fisher & Paykel and DCS parts and are trained on the full product line.",
    "We also service the broader Fisher & Paykel range: their drawer dishwashers (a F&P specialty), their refrigerators, and their laundry appliances.",
    "DCS & F&P product lines we service: DCS Ranges & Cooktops · Fisher & Paykel · F&P Drawer Dishwashers · DCS Outdoor Kitchen · F&P Refrigerators · F&P Laundry.",
  ],
};

const neighborhoods = [
  { name: 'Hayden Tract', zip: '90232', featured: true },
  { name: 'Arts District', zip: '90232', featured: true },
  { name: 'Downtown Culver City', zip: '90230', featured: true },
  { name: 'Fox Hills', zip: '90232' },
  { name: 'Blair Hills', zip: '90232' },
  { name: 'Culver Crest', zip: '90230' },
  { name: 'McManus', zip: '90232' },
  { name: 'Lucerne-Higuera', zip: '90230' },
  { name: 'Sony Pictures area', zip: '90232' },
  { name: 'Amazon / Apple campus', zip: '90232' },
  { name: 'Baldwin Hills adj.', zip: '90230' },
  { name: 'Clarkdale', zip: '90230' },
];

const recentJobs = [
  {
    appliance: 'DCS Range',
    location: 'Hayden Tract, 90232',
    quote: '"Two burners won\'t ignite, oven running low"',
    description: 'DCS 48-inch dual-fuel in a renovated commercial conversion near the Hayden Tract. Two surface igniter modules had failed — DCS-specific components that require the correct OEM parts and the right disassembly procedure for the DCS chassis. Replaced both igniters, calibrated the oven (running 18°F low), tested all eight burners and the broiler. The owner had been told by two other companies they "don\'t work on DCS." We do.',
    outcome: '✓ Same day · OEM DCS parts · Oven calibrated',
  },
  {
    appliance: 'LG Front-Load Washer',
    location: 'Fox Hills, 90232',
    quote: '"LE error constantly, won\'t complete a cycle"',
    description: 'LG LE error — motor or rotor sensor fault. Found a hairpin lodged in the rotor position sensor, causing intermittent motor stall. Removed the obstruction, tested sensor function, ran four full cycles including heavy load and spin-only. Working perfectly. Call came in at 9am from someone working from home who needed laundry done before a 2pm video call. We were there and done by noon.',
    outcome: '✓ Same day · Done before noon · Laundry in time',
  },
  {
    appliance: 'Samsung French Door',
    location: 'Downtown Culver City, 90230',
    quote: '"Ice maker stopped, fridge section getting warm at the top"',
    description: 'Classic Samsung dual-evaporator failure — upper refrigerator fan motor seized, causing warm spots at the top while the lower section and freezer stayed cold. Ice maker had also stopped because the inlet valve had partially clogged. Replaced the fan motor and inlet valve, both OEM Samsung parts, cleared the drain, confirmed even temperatures throughout. New construction condo — brand-new kitchen, appliance hadn\'t even been registered for warranty yet.',
    outcome: '✓ Same day · OEM Samsung parts · Warranty unaffected',
  },
  {
    appliance: 'Fisher & Paykel Drawer Dishwasher',
    location: 'Arts District, 90232',
    quote: '"Bottom drawer error code, leaking from front"',
    description: 'Fisher & Paykel DishDrawer — fault code on the bottom drawer with a slow leak from the door seal. The seal had compressed unevenly from heavy use, and the drawer latch mechanism had a worn spring allowing slight door flex under pressure. Replaced the door seal and latch spring with OEM F&P parts, rebalanced the drawer, ran three full cycles per drawer. No leak, no fault code. The homeowner appreciated that we actually had the parts and knew the product.',
    outcome: '✓ Same day · OEM Fisher & Paykel parts · Both drawers tested',
  },
];

const whyReasons = [
  {
    iconKey: 'parts' as const,
    title: 'We Actually Know DCS & F&P',
    body: 'DCS and Fisher & Paykel are common in Culver City and almost nobody services them. We carry OEM parts, know the product line, and don\'t tell you we "don\'t work on that brand."',
  },
  {
    iconKey: 'team' as const,
    title: 'Old Houses, New Appliances — All of It',
    body: "Culver City's 1940s bungalows often have kitchens updated one appliance at a time. New condos have brand-new tech appliances. We work on both ends of the spectrum and everything in between.",
  },
  {
    iconKey: 'clock' as const,
    title: 'WFH Scheduling',
    body: 'A lot of Culver City residents work from home. When the washer breaks during your workday, you need someone who actually shows up on time and gets it done — not a 4-hour window that stretches to 6.',
  },
  {
    iconKey: 'shield' as const,
    title: '90-Day Warranty, OEM Only',
    body: 'Every repair backed by 90 days on parts and labor. Genuine OEM parts — no aftermarket. $89 diagnostic waived with repair. Written estimate before we start. California licensed, BBB A+ rated.',
  },
];

const testimonials = [
  {
    stars: 5,
    text: '"Had a DCS range in our Hayden Tract home that two companies refused to touch. Same Day Appliance came out same day, had the OEM DCS parts, fixed both burners and calibrated the oven. First repair company I\'ve found in LA that actually knows the brand."',
    author: '— Chris M., Hayden Tract, Culver City',
  },
  {
    stars: 5,
    text: '"Work from home and my washer broke mid-morning. Called Same Day Appliance Repair, they were there by noon, fixed the LG error on the spot. Done in time for my afternoon calls. This is exactly the kind of quick, reliable service I needed. Will definitely use again."',
    author: '— Sarah K., Fox Hills, Culver City',
  },
  {
    stars: 5,
    text: '"Fisher & Paykel DishDrawer was leaking and showing a fault code. Technician came same afternoon, had OEM Fisher & Paykel parts, replaced the seal and latch spring, tested both drawers thoroughly. No more leak, no more code. Really impressive that they knew this product."',
    author: '— Amanda L., Arts District, Culver City',
  },
];

const pricingTiers = [
  { appliance: 'Refrigerator', range: '$200–$450', note: 'Fan motor, ice maker, compressor relay, thermostat' },
  { appliance: 'DCS / Fisher & Paykel', range: '$200–$500', note: 'OEM parts · All F&P and DCS product lines', featured: true },
  { appliance: 'Washer / Dryer', range: '$150–$350', note: 'Drain pump, heating element, thermal fuse, drum' },
  { appliance: 'Oven / Range', range: '$175–$420', note: 'Igniter, element, gas valve, calibration' },
  { appliance: 'Dishwasher', range: '$150–$320', note: 'Drain pump, door seal, control board, spray arm' },
  { appliance: 'Diagnostic Fee', range: '$89', note: 'Waived when you proceed with the repair' },
];

const faqs = [
  {
    question: 'Do you offer same-day appliance repair in Culver City, CA?',
    answer: 'Yes. Our technicians cover all of Culver City — Downtown, Hayden Tract, Arts District, Fox Hills, Blair Hills, Culver Crest, McManus, Lucerne-Higuera, Clarkdale, and the Sony Pictures area. We serve both 90230 and 90232 ZIP codes. Call before noon for same-day afternoon service.',
  },
  {
    question: 'Do you repair DCS and Fisher & Paykel appliances in Culver City?',
    answer: 'Yes. DCS and Fisher & Paykel appliances appear in Culver City homes more often than in most LA neighborhoods — partly because of the area\'s design-forward housing stock and proximity to the entertainment industry. Our technicians are trained on both brands and carry OEM Fisher & Paykel and DCS parts on our service vehicles.',
  },
  {
    question: 'Do you work on both older homes and new construction in Culver City?',
    answer: 'Yes. Culver City has everything from 1940s bungalows to brand-new construction along the Hayden Tract and in the Arts District area. The older homes often have kitchens that have been updated piece by piece — one newer appliance brand sitting next to an older one. Our technicians work on all of it, all brands, all ages.',
  },
  {
    question: 'What is your diagnostic fee in Culver City?',
    answer: 'Our diagnostic fee is $89, waived when you proceed with the repair. We give you a complete written estimate before starting any work. No hidden fees — the price we quote is the price on the invoice.',
  },
  {
    question: 'Do you repair commercial appliances in Culver City?',
    answer: "Yes. Culver City's restaurant corridor along Washington Blvd and Culver Blvd, plus the studio commissaries and corporate cafeterias in the Hayden Tract, generate regular commercial appliance repair calls. We repair commercial refrigerators, commercial ovens, and restaurant kitchen equipment. Call us for commercial pricing.",
  },
  {
    question: 'What warranty do you offer on appliance repairs in Culver City?',
    answer: 'All repairs come with a 90-day warranty on parts and labor. If the same issue returns within 90 days, we come back at no charge. We use genuine OEM parts only.',
  },
  {
    question: 'Do you also serve Mar Vista, Venice, and Playa del Rey from Culver City?',
    answer: 'Yes. Our Culver City service area extends to Mar Vista, Venice, Playa del Rey, Marina del Rey, Westchester, Baldwin Hills, and Ladera Heights. All are within our regular coverage area from Culver City.',
  },
];

const nearbyCities = [
  { name: 'Santa Monica', slug: 'santa-monica' },
  { name: 'Los Angeles', slug: 'los-angeles' },
  { name: 'Beverly Hills', slug: 'beverly-hills' },
  { name: 'West Hollywood', slug: 'west-hollywood' },
  { name: 'Brentwood', slug: 'brentwood' },
  { name: 'Marina del Rey', slug: 'marina-del-rey' },
  { name: 'West Los Angeles', slug: 'west-los-angeles' },
  { name: 'Malibu', slug: 'malibu' },
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair"
    headlineCity="Culver City, CA"
    subheadline="Culver City's mix of tech offices, studio lots, 1940s bungalows, and new construction means every appliance repair call here is different. Our technicians work across all of it — and we're one of the few in the area that services DCS and Fisher & Paykel. Same-day service, OEM parts, 90-day warranty."
    zips={zips}
    tier={1}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance Repair in Culver City — Why This City Is Different"
    paragraphs={introParagraphs}
    bookingTitle="Culver City Service Team"
    bookingSub="90230 · 90232 · Same day"
  />

  <ServicesGrid
    cityName={cityName}
    headline="What We Repair in Culver City"
    subhead="All brands · All ages of housing · Residential & commercial · 90230 & 90232"
    services={services}
  />

  <ServiceArea
    cityName={cityName}
    headline="We Cover All of Culver City — 90230 & 90232"
    subheadline="Studio town, tech hub, classic bungalows — every corner of the city"
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={['Washington Blvd corridor', 'Culver Blvd', 'Sepulveda Blvd', 'Jefferson Blvd area']}
  />

  <CustomNarrative
    eyebrow={dcsNarrative.eyebrow}
    headline={dcsNarrative.headline}
    paragraphs={dcsNarrative.paragraphs}
    background="black"
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Jobs Our Team Did in Culver City"
    jobs={recentJobs}
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="Why Culver City Customers Call Us"
    reasons={whyReasons}
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What Culver City Customers Are Saying"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Appliance Repair Costs in Culver City"
    subhead="Written estimate before we start. $89 diagnostic — waived with repair."
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="Questions Culver City Customers Ask"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby Areas"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance broken in Culver City?"
    body="DCS · Fisher & Paykel · All brands · Old houses & new condos. $89 diagnostic waived with repair. 90-day warranty. Same day in 90230 & 90232."
  />
</CityLayoutV2>
