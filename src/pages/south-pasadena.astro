---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

const citySlug = 'south-pasadena';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = 'South Pasadena';
const zips = ['91030'];

const phoneRaw = `+1${branch.phone.replace(/\D/g, '')}`;

const title = `Appliance Repair South Pasadena CA 91030 — Same Day | Craftsman Homes · Vintage Stoves | ${branch.phone}`;
const description = `Same-day appliance repair in South Pasadena, CA 91030. Craftsman bungalows, vintage O'Keefe & Merritt and Wedgewood ranges welcome. Mission Street, Marengo Ave, Meridian Ave. Licensed, OEM parts, 90-day warranty. Weekends available. Call ${branch.phone}.`;
const canonical = 'https://samedayappliance.repair/south-pasadena/';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { '@type': 'City', name: 'South Pasadena', sameAs: 'https://en.wikipedia.org/wiki/South_Pasadena,_California' },
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$',
  license: 'CA BHGS #A49573'

};

const introParagraphs = [
  "South Pasadena is one of the best-preserved small cities in the San Gabriel Valley. The Craftsman bungalows along Marengo, Meridian, and Fairview Avenues, the Spanish Colonials and Victorians throughout the historic district — these homes have been maintained and loved for decades, and their kitchens reflect that.",
  "A meaningful number of those kitchens still have vintage ranges — O'Keefe & Merritt, Wedgewood, Roper — running alongside modern dishwashers and refrigerators. We don't turn these away. If a vintage range can be repaired economically, we do it. If it can't, we'll tell you that directly rather than waste your time and money.",
  "Hard water is a real factor in South Pasadena. LADWP water in this area runs 230–310 mg/L hardness, and older galvanized pipes in the 1920s–40s homes add iron. Ice maker inlet valves and dishwasher spray arms scale up faster than the national average — we test for this on every relevant South Pasadena call. It consistently matters here.",
  "Diagnostic fee: <strong>$89</strong> — waived with repair. Written estimate before we start. <strong>90-day warranty</strong>. We're available <strong>Saturdays and Sundays</strong> — unlike some South Pasadena competitors who close on weekends.",
  "<strong>Vintage range tip for South Pasadena:</strong> If you have an O'Keefe & Merritt, Wedgewood, or Roper still running in your Craftsman kitchen — these are worth keeping. Parts are still available for most common failures (burner igniters, pilot assemblies, oven thermostats). A $150–$250 repair on a range that cooks beautifully is almost always the right call. We assess vintage ranges honestly and won't push you toward unnecessary replacement.",
];

const services = [
  { icon: '🧊', name: 'Refrigerator Repair', slug: 'refrigerator', issues: 'Not cooling · Hard water ice maker · Fan motor · Temperature off', brands: 'Samsung · LG · GE · Whirlpool · Sub-Zero · Bosch' },
  { icon: '🔥', name: 'Oven, Range & Vintage Stove', slug: 'oven', issues: "O'Keefe & Merritt · Wedgewood · Roper · Gas igniter · Oven thermostat", brands: 'Vintage brands · GE · Samsung · Bosch · Wolf · Viking' },
  { icon: '🫧', name: 'Washer Repair', slug: 'washer', issues: 'Hard water inlet screens · Not draining · Not spinning · Error codes', brands: 'LG · Samsung · Whirlpool · Maytag · Bosch · Speed Queen' },
  { icon: '♨️', name: 'Dryer Repair + Vent Cleaning', slug: 'dryer', issues: 'Not heating · Older vent runs · Thermal fuse · Lint buildup', brands: 'LG · Samsung · GE · Maytag · Whirlpool · Electrolux' },
  { icon: '🍽️', name: 'Dishwasher Repair', slug: 'dishwasher', issues: 'Hard water spray arm scale · Not draining · Spots · Error codes', brands: 'Bosch · KitchenAid · Samsung · LG · GE · Miele' },
  { icon: '❄️', name: 'Freezer & Ice Maker Repair', slug: 'freezer', issues: 'Hard water valve · Not freezing · Ice stopped · Frost buildup', brands: 'Samsung · LG · GE · Whirlpool · Sub-Zero · Frigidaire' },
  { icon: '🔆', name: 'Cooktop & Range Hood', slug: 'cooktop', issues: 'Igniter issues · Gas burner · Induction not heating · Hood motor', brands: 'GE · Bosch · Samsung · Wolf · Thermador · Broan' },
  { icon: '🍷', name: 'Wine Cooler Repair', slug: 'wine-cooler', issues: 'Temperature off · Compressor · Under-counter · Built-in', brands: 'Sub-Zero · True · U-Line · Liebherr · Dacor' },
];

const neighborhoods = [
  { name: 'Mission Street corridor', zip: '91030', featured: true },
  { name: 'Historic District', zip: '91030', featured: true },
  { name: 'Marengo Avenue', zip: '91030', featured: true },
  { name: 'Meridian Avenue', zip: '91030' },
  { name: 'El Centro Street', zip: '91030' },
  { name: 'Fairview Avenue', zip: '91030' },
  { name: 'Diamond Avenue', zip: '91030' },
  { name: 'Arroyo Seco adjacent', zip: '91030' },
];

const keyStreets = ['Fair Oaks Ave', 'Mission St', 'Huntington Drive', 'Fremont Ave', 'Mound Ave', 'Garfield Ave'];

const recentJobs = [
  {
    appliance: "O'Keefe & Merritt Range",
    location: 'Marengo Ave, 91030',
    quote: "Two burners not lighting, oven pilot out",
    description: "1952 O'Keefe & Merritt in a Craftsman bungalow — the homeowners had kept it in beautiful condition and were determined to keep it running. Two surface burner igniters had corroded contacts; the oven pilot had gone out and the thermocouple was weak. Our tech cleaned and adjusted the igniter contacts, relit and adjusted the oven pilot, tested the thermocouple, and ran all four burners plus the oven. Everything working perfectly — and a range this well-maintained absolutely deserves to keep cooking.",
    outcome: '✓ Same day · Vintage range restored · Worth every dollar to keep'
  },
  {
    appliance: 'Samsung Dishwasher',
    location: 'Meridian Ave, 91030',
    quote: 'Glasses coming out spotty, spray arm barely spinning',
    description: 'Classic South Pasadena hard water situation — spray arm ports almost completely blocked by mineral scale. LADWP 230–310 mg/L plus the older supply pipes in this 1930s bungalow. Descaled both spray arms, cleaned the filter trap, ran a full citric acid maintenance cycle, confirmed full spray arm rotation. Advised a monthly dishwasher cleaning tablet routine specifically for hard water — small habit, big difference in a house like this.',
    outcome: '✓ Same day · Scale cleared · Hard water routine explained'
  },
  {
    appliance: 'LG Refrigerator',
    location: 'El Centro, 91030',
    quote: 'Ice maker stopped — barely any ice for two months',
    description: 'LG French door — gradual ice production decline is textbook mineral deposit buildup on the water inlet valve. The galvanized pipes in this 1940s South Pasadena home had added iron to the LADWP water hardness, leaving significant scale on the valve orifice. Replaced the inlet valve with an OEM LG part, flushed the water line, replaced the in-door filter (over a year old). Full ice production restored within 24 hours. Owner now on 6-month filter replacement cycle.',
    outcome: '✓ Same day · OEM LG inlet valve · Filter replaced · Full production'
  },
  {
    appliance: 'Maytag Dryer',
    location: 'Fairview Ave, 91030',
    quote: 'Saturday morning — dryer dead before family visiting',
    description: 'Called Saturday at 8:30am — Maytag electric dryer completely dead, no heat at all, and family coming for the weekend. Arrived by 11am. Thermal fuse blown from a partially blocked vent run — the duct ran through the original 1920s wall cavity and had a 90-degree elbow that had accumulated significant lint. Replaced the thermal fuse, cleared the vent run completely, confirmed exterior airflow. Single cycle working before noon. Homeowner very relieved.',
    outcome: '✓ Saturday same day · Done by noon · Vent cleared · Family visit saved'
  },
];

const whyReasons = [
  {
    iconKey: 'parts' as const,
    title: 'Vintage Range Friendly',
    body: "O'Keefe & Merritt, Wedgewood, Roper — we assess these honestly. If parts are available and the repair makes economic sense, we do it. South Pasadena's Craftsman kitchens deserve technicians who understand vintage appliances."
  },
  {
    iconKey: 'team' as const,
    title: 'Hard Water Aware',
    body: "LADWP 230–310 mg/L plus older galvanized pipes means ice makers and dishwashers scale up faster than average. We test inlet valves and check for mineral deposits on every relevant South Pasadena call — it's that consistently a factor here."
  },
  {
    iconKey: 'clock' as const,
    title: 'Open Weekends',
    body: "Saturday 8am–7pm, Sunday 9am–5pm — available when some South Pasadena competitors aren't. If your appliance breaks Friday evening or Saturday morning, you can call us and get it fixed the same day."
  },
  {
    iconKey: 'shield' as const,
    title: '90-Day Warranty, OEM Only',
    body: 'Every repair backed by 90 days on parts and labor. Genuine OEM parts only. $89 diagnostic waived with repair. Written estimate before we start. California licensed, BBB A+ rated.'
  },
];

const testimonials = [
  {
    stars: 5,
    text: '"We have a 1952 O\'Keefe & Merritt that we absolutely love. Two companies told us to just get a new stove. Same Day actually came out, knew exactly what was wrong, fixed it in an hour, and the range works perfectly. Someone who understands why these old stoves are worth keeping — that\'s hard to find."',
    author: '— Carol W., Marengo Ave, South Pasadena'
  },
  {
    stars: 5,
    text: '"Refrigerator ice maker had been dying slowly for months. Same Day came out, immediately identified the mineral buildup from our hard water and older pipes, replaced the inlet valve, showed me the scale on the old one. Ice maker fully working again and I finally understand why it kept failing. Very knowledgeable."',
    author: '— James T., El Centro, South Pasadena'
  },
  {
    stars: 5,
    text: '"Called Saturday morning with a dead dryer and family coming. Tech was here by 11, found the blocked vent and blown fuse, had everything fixed before noon. Most companies around here are closed weekends — Same Day was there and got it done fast. Exactly what I needed."',
    author: '— Maria L., Fairview Ave, South Pasadena'
  },
];

const pricingTiers = [
  { appliance: "Vintage Range (O'Keefe, Wedgewood)", range: '$150 – $300', note: 'Igniter contacts, pilot, thermocouple, oven thermostat', featured: true },
  { appliance: 'Refrigerator / Ice Maker', range: '$150 – $400', note: 'Fan motor, hard water inlet valve, mineral flush' },
  { appliance: 'Dishwasher', range: '$150 – $320', note: 'Hard water descaling + drain pump + spray arm' },
  { appliance: 'Washer / Dryer', range: '$150 – $350', note: 'Drain pump, heating element, thermal fuse, vent' },
  { appliance: 'Modern Oven / Range', range: '$150 – $400', note: 'Igniter, bake element, gas valve, calibration' },
  { appliance: 'Diagnostic Fee', range: '$89', note: 'Waived when you proceed with the repair' },
];

const faqs = [
  {
    question: 'Do you offer same-day appliance repair in South Pasadena, CA?',
    answer: "Yes. Our technicians cover all of South Pasadena 91030 — Mission Street corridor, Marengo Avenue, Meridian Avenue, El Centro, Fairview Avenue, Diamond Avenue, and all streets through the historic bungalow neighborhoods. Call before noon for same-day afternoon service. We're also available Saturdays and Sundays."
  },
  {
    question: "Do you repair vintage ranges and O'Keefe & Merritt stoves in South Pasadena?",
    answer: "Yes. South Pasadena's Craftsman bungalows and Spanish Colonial homes often have vintage ranges — O'Keefe & Merritt, Wedgewood, Roper — that have been running for decades. We assess these honestly. If the parts are available and the repair makes economic sense, we do it. We won't turn away a vintage stove just because it's not a modern brand."
  },
  {
    question: 'Does hard water in South Pasadena affect appliances?',
    answer: 'Yes. LADWP water hardness in the South Pasadena area runs 230–310 mg/L, and older homes with galvanized supply pipes can add iron on top of that. This means ice maker inlet valves, dishwasher spray arms, and washing machine inlet hoses accumulate mineral deposits faster than the national average. We check and test for this on every South Pasadena call involving ice makers and dishwashers.'
  },
  {
    question: 'Are you available on weekends in South Pasadena?',
    answer: "Yes. We're available Saturday 8am–7pm and Sunday 9am–5pm — unlike some South Pasadena appliance companies that close on weekends. If your appliance breaks Friday evening or Saturday morning, you don't have to wait until Monday."
  },
  {
    question: 'What is your diagnostic fee in South Pasadena?',
    answer: 'Our diagnostic fee is $89, waived when you proceed with the repair. We give you a complete written estimate before starting any work. Most South Pasadena repairs run $150–$400 depending on the appliance.'
  },
  {
    question: 'What warranty do you offer on appliance repairs in South Pasadena?',
    answer: 'All repairs come with a 90-day warranty on parts and labor. We use genuine OEM parts only. If the same issue returns within 90 days, we come back at no charge.'
  },
  {
    question: 'Do you also serve Pasadena, San Marino, and Alhambra?',
    answer: "Yes. Our South Pasadena service extends to Pasadena, San Marino, Alhambra, San Gabriel, Arcadia, and Monrovia. We're the closest team for all 91030 calls and cover the surrounding SGV cities as well."
  },
];

const nearbyCities = [
  { name: 'Pasadena', slug: 'pasadena' },
  { name: 'Glendale', slug: 'glendale' },
  { name: 'Burbank', slug: 'burbank' },
  { name: 'Los Feliz', slug: 'los-feliz' },
  { name: 'Silver Lake', slug: 'silver-lake' },
  { name: 'Los Angeles', slug: 'los-angeles' },
  { name: 'San Marino', slug: 'san-marino' },
  { name: 'Alhambra', slug: 'alhambra' },
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair"
    headlineCity="South Pasadena, CA"
    subheadline="Craftsman bungalows, Spanish Colonials, vintage kitchens — and all the modern appliances living alongside them. We cover all of South Pasadena 91030. Vintage stoves welcome. Same-day service, weekends available. OEM parts, 90-day warranty."
    zips={zips}
    tier={3}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance Repair in South Pasadena — What Makes This City Different"
    paragraphs={introParagraphs}
    bookingTitle="South Pasadena Service"
    bookingSub="91030 · Vintage stoves welcome · Weekends ok"
  />

  <ServicesGrid
    cityName={cityName}
    headline="What We Repair in South Pasadena"
    subhead="Modern & vintage · All brands · Hard water aware · 91030"
    services={services}
  />

  <ServiceArea
    cityName={cityName}
    headline="All of South Pasadena — 91030"
    subheadline="Every neighborhood and street in the city"
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={keyStreets}
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Jobs in South Pasadena"
    subhead="Real calls from 91030 — bungalows, vintage kitchens, and modern appliances alike."
    jobs={recentJobs}
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="Why South Pasadena Calls Us Back"
    reasons={whyReasons}
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What South Pasadena Customers Are Saying"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Appliance Repair Costs in South Pasadena"
    subhead="Written estimate before we start. $89 diagnostic — waived with repair."
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="Questions South Pasadena Customers Ask"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby Areas"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance broken in South Pasadena?"
    body="Craftsman bungalows · Vintage stoves welcome · Hard water aware · Weekends available. $89 diagnostic waived with repair. 90-day warranty."
  />
</CityLayoutV2>
