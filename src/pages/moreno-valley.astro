---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import CustomNarrative from '../components/cities/v2/CustomNarrative.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES, MAIN_PHONE, isPlaceholderPhone } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

const citySlug = 'moreno-valley';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = 'Moreno Valley';
const zips = ['92551', '92553', '92555', '92557'];

const phone = branch.phone;
const phoneRaw = `+1${phone.replace(/\D/g, '')}`;

const title = `Appliance Repair Moreno Valley CA — Same Day | All Brands | ${phone}`;
const description = `Same-day appliance repair in Moreno Valley CA. Refrigerator, washer, dryer, oven, dishwasher & more. Sunnymead, Towngate, March ARB area. Licensed. OEM parts. Call ${phone}.`;
const canonical = 'https://samedayappliance.repair/moreno-valley/';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { '@type': 'City', name: 'Moreno Valley' },
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$',
  license: 'CA CSLB #1138898'

};

const introParagraphs = [
  "Moreno Valley is the second-largest city in Riverside County — a sprawling, diverse, working-class community anchored by March Air Reserve Base, two hospital systems, and a large school district. The housing stock built out rapidly through the 1980s and 1990s, and those appliances are now 15–25 years into their lifespan. Whirlpool, GE, and Maytag from the original installations have given way to Samsung, LG, and KitchenAid in renovated homes and newer developments, but a huge portion of Moreno Valley's residential calls involve machines that are simply old and hitting their first major failure.",
  "March Air Reserve Base creates a specific service dynamic we don't see in many other cities. Military families PCS in and out regularly, and the homes they move into have maintenance histories that are often unknown — vents never cleaned, filters never replaced, coils never touched. We treat military household calls with this in mind: we inspect the full maintenance picture when we're there, not just the presenting failure.",
  "The climate is standard Inland Valley: 100–108°F summers, dry and dusty, hard water throughout Riverside County. Condenser coil cleaning in May — before the heat arrives — is the single most effective preventive step Moreno Valley homeowners can take. We recommend it on every applicable service call, and we perform it as part of every summer refrigerator diagnosis.",
  `Same-day coverage across all Moreno Valley ZIP codes. Call <a href="tel:${phoneRaw}">${phone}</a>.`,
];

const services = [
  { icon: '❄️', name: 'Refrigerator Repair', slug: 'refrigerator' },
  { icon: '🌀', name: 'Washer Repair', slug: 'washer' },
  { icon: '💨', name: 'Dryer Repair', slug: 'dryer' },
  { icon: '🔥', name: 'Oven & Range Repair', slug: 'oven' },
  { icon: '🫧', name: 'Dishwasher Repair', slug: 'dishwasher' },
  { icon: '🍳', name: 'Stove & Cooktop Repair', slug: 'stove' },
  { icon: '🧊', name: 'Freezer Repair', slug: 'freezer' },
  { icon: '🧊', name: 'Ice Maker Repair', slug: 'ice-maker' },
];

const morenoValleyContextNarrative = {
  headline: "Moreno Valley's Appliance Profile — What We Find and Why",
  subSections: [
    {
      title: '1980s–1990s Tract Housing — The Dominant Stock',
      paragraphs: [
        "The majority of Moreno Valley's residential neighborhoods — Sunnymead, Towngate, the corridors along Nason Street, Frederick Street, and Cactus Avenue — were developed rapidly during the 1980s and '90s. These are the homes driving most of our call volume: tract houses with 15–25 year old appliances hitting their first serious mechanical failures. The pattern is consistent — drive coupling wear on Whirlpool top-loaders, thermal fuse failures on GE and Maytag dryers from restricted vent runs, compressor strain on refrigerators that have never had condenser coil cleaning.",
        "These machines are almost always worth repairing. A 1998 Whirlpool top-loader with a worn drive coupling costs $120–$140 to fix and has years of life left. A 2002 GE refrigerator with summer coil failure costs $89–$130 to service. Replacement costs $800–$1,200. We give honest numbers after diagnosis and let homeowners make informed decisions.",
      ]
    },
    {
      title: 'March Air Reserve Base — Military Household Specifics',
      paragraphs: [
        "March ARB is one of the largest Air Force Reserve installations on the West Coast, and the surrounding neighborhoods house active duty and reserve families who rotate through on a regular basis. When a new family PCS's into base-adjacent housing, the appliances in that home may have had 3–4 previous occupants — with no maintenance history. Vents are blocked with lint from 5 years of use. Condenser coils are loaded from 3 families of opening and closing the refrigerator. Water filters haven't been replaced in 2 years.",
        "We look at the full maintenance picture when we service a military household call in Moreno Valley. If the presenting problem is a blown thermal fuse and we find an 18-foot vent run packed solid, we fix both. If we're there for an ice maker and the filter is 22 months old, we note it. Military families deserve an appliance service that accounts for their specific circumstances.",
      ]
    },
    {
      title: 'Newer Developments — Highland Hills, El Sobrante',
      paragraphs: [
        "Highland Hills and El Sobrante represent Moreno Valley's newer residential growth — 2000s–2010s development with Samsung, LG, and KitchenAid appliances now 10–15 years old. These are squarely in their first failure window: LG linear inverter compressor relay failures, Samsung ice maker issues, KitchenAid E1/F9 flooding errors from scale-blocked pump impellers. We carry OEM parts for all of these on the truck.",
      ]
    },
    {
      title: 'Hard Water and Summer Heat',
      paragraphs: [
        "Riverside County water is consistently hard, and Moreno Valley is no exception. Dishwasher filter cleaning every 3 months, ice maker descaling every 18 months, refrigerator water filter every 4 months. In summer heat that regularly reaches 105–108°F, condenser coils need cleaning in May before the heat stress begins — not in October after something breaks. We include these recommendations as a matter of course on every applicable service call.",
      ]
    },
  ]
};

const neighborhoods = [
  { name: 'Sunnymead', zip: '92553' },
  { name: 'Towngate', zip: '92553' },
  { name: 'Highland Hills', zip: '92555' },
  { name: 'El Sobrante', zip: '92555' },
  { name: 'March ARB Area', zip: '92551' },
  { name: 'Edgemont', zip: '92557' },
  { name: 'Mead Valley', zip: '92553' },
  { name: 'Nason St Corridor', zip: '92553' },
  { name: 'Frederick St Area', zip: '92553' },
  { name: 'Box Springs Area', zip: '92557' },
  { name: 'Cactus Ave Corridor', zip: '92555' },
  { name: 'Perris Border', zip: '92551' },
];

const recentJobs = [
  {
    appliance: 'Samsung RF28R7551SR',
    location: 'Towngate, 92553',
    quote: 'warm, 22E error, Towngate home',
    description: "2018 Samsung French-door, 22E ice room sensor error. Root cause: failed defrost heater had allowed the evaporator to frost completely solid. Replaced the defrost heater assembly with OEM Samsung parts, manually defrosted the coil, confirmed 38°F recovery within 40 minutes. Also found condenser coils loaded with dust — 16 months since last cleaning. In Moreno Valley's summer heat this coil condition would have caused an independent failure even without the defrost issue. Cleaned the coils and briefed the homeowner on a 6-month maintenance schedule.",
    outcome: '✓ In Moreno Valley heat, 6-month coil cleaning is the right interval. Annual is not enough.'
  },
  {
    appliance: 'Whirlpool WTW5000DW top-loader',
    location: 'Sunnymead, 92553',
    quote: 'clicking, no agitation, 14 years old',
    description: '14-year-old Whirlpool top-loader, agitator clicking and failing to engage. Classic shift actuator failure — the motor and transmission were both solid. Replaced the actuator assembly with an OEM Whirlpool part. Repair: $89 diagnostic + $95 parts and labor. Total: $184. The homeowner had been quoted $650–$750 for a replacement machine by two other companies. Machine is mechanically sound and running cleanly. We told them to expect another 5+ years from it.',
    outcome: '✓ 14-year-old Whirlpool with a bad actuator: $184 repair vs $700 replacement. Always diagnose first.'
  },
  {
    appliance: 'LG DLEX3700V dryer',
    location: 'March ARB area, 92551',
    quote: 'no heat, thermal fuse blown, March ARB area',
    description: "Military family, LG dryer no heat. Blown thermal fuse — confirmed. Traced the root cause to a 17-foot vent run through the garage interior with a lint trap that had never been cleaned. Cleared the full vent, replaced the thermal fuse and high-limit thermostat together (on LG dryers, always replace both), confirmed airflow at exterior. Also found the heating element operating at 82% capacity — replaced it while open. Family had recently PCS'd to the area and the previous occupants had clearly never maintained the vent.",
    outcome: '✓ Military PCS homes: always check vent history. Previous occupants may have never maintained it.'
  },
  {
    appliance: 'GE GFE28GYNFS',
    location: 'El Sobrante, 92555',
    quote: 'ice maker not producing, water fine, 2020 model',
    description: '4-year-old GE French-door, ice maker silent, water dispenser fine. Isolated to the ice maker inlet valve secondary solenoid — independent failure from the water solenoid. Also found significant mineral scale in the ice maker mold from Riverside County hard water — 4 years without any descaling, unusual for such a new machine but not uncommon in areas with hard water. Replaced the valve assembly with OEM GE parts, descaled the mold, replaced the water filter (13 months old), adjusted the freezer set point to +2°F. Ice production restored same visit.',
    outcome: "✓ Even new appliances need ice maker descaling in Riverside County hard water. Don't wait for failure."
  },
];

const whyReasons = [
  {
    iconKey: 'shield' as const,
    title: 'Honest repair vs. replace',
    body: "Moreno Valley has a lot of 15–25 year old appliances that are worth repairing. We don't push replacement when repair is the right call. After diagnosis, we give you the real numbers and let you decide."
  },
  {
    iconKey: 'team' as const,
    title: 'Military families — we get it',
    body: 'March ARB families PCS into homes with unknown maintenance histories. We inspect the full picture when we service a military household — not just the presenting failure. If the vent has never been cleaned, we note it. If the filter is overdue, we say so.'
  },
  {
    iconKey: 'parts' as const,
    title: 'Root cause, not just the symptom',
    body: "A blown thermal fuse means something caused it. A Samsung error code points to a system. A dishwasher that doesn't clean is scale until proven otherwise. We find the actual cause before recommending parts — saving you from callbacks."
  },
  {
    iconKey: 'clock' as const,
    title: 'Summer heat expertise',
    body: "105°F summers in Moreno Valley mean condenser coil cleaning isn't optional — it's preventive. We recommend it on every applicable call and do it as part of every summer refrigerator diagnosis. Clean in May, not October."
  },
];

const testimonials = [
  {
    stars: 5,
    text: '"Old Whirlpool washer stopped agitating. Every other company said replace it. Same Day diagnosed a bad actuator for $95. 14-year-old machine running perfectly. Really grateful they actually tried to fix it."',
    author: '— Patricia M., Sunnymead'
  },
  {
    stars: 5,
    text: '"Military family at March ARB — new to the area. LG dryer not heating. Tech found the vent completely blocked from previous tenants and replaced the fuse and thermostat together. Checked everything else too. Exactly the thorough service we needed."',
    author: '— SSgt James R., March ARB area'
  },
  {
    stars: 5,
    text: '"Samsung fridge in our Towngate home failed in July with a 22E error. Same Day came same afternoon — defrost heater failure plus loaded coils. Fixed both. Explained the summer maintenance schedule. Very knowledgeable."',
    author: '— Linda & Carlos V., Towngate'
  },
];

const pricingTiers = [
  { appliance: 'Refrigerator Repair', range: '$120–$420', note: 'Compressor relay · Coil cleaning · Inlet valve · Fan motor' },
  { appliance: 'Washer Repair', range: '$120–$360', note: 'Bearing + seal set · Drain pump · Shock absorbers · Hall sensor' },
  { appliance: 'Dryer Repair', range: '$120–$300', note: 'Thermal fuse + limiter set · Heating element · Vent path' },
  { appliance: 'Dishwasher Repair', range: '$89–$340', note: 'Drain pump · Spray arm · Filter · E24 / F9 errors' },
  { appliance: 'Oven / Range Repair', range: '$130–$380', note: 'Igniter · Bake element · Gas valve · Calibration' },
  { appliance: 'Ice Maker Repair', range: '$120–$260', note: 'Inlet valve · Mold descaling · Filter · Set point' },
  { appliance: 'Condenser Coil Cleaning', range: '$89–$140', note: 'Summer heat preventive · 6-month interval' },
  { appliance: 'Dryer Vent Cleaning', range: '$89–$140', note: 'Long runs · Lint clearance · Airflow check' },
];

const faqs = [
  {
    question: 'Do you offer same-day appliance repair in Moreno Valley?',
    answer: `Yes — same-day service is available throughout Moreno Valley including Sunnymead, Towngate, Highland Hills, El Sobrante, the March ARB area, and Edgemont. Call ${phone} before noon for same-day scheduling. We cover all Moreno Valley ZIP codes — 92551, 92553, 92555, and 92557 — without a trip surcharge.`
  },
  {
    question: 'Do you service appliances for military families near March Air Reserve Base?',
    answer: 'Yes. March ARB is one of our regular service areas in Moreno Valley. We understand the specific dynamics of military households — PCS moves that leave appliances in varying condition, base-adjacent housing with consistent appliance profiles, and the reliability expectations that come with active duty life. We treat military family calls with the same priority we give all occupied-property repairs.'
  },
  {
    question: 'My appliances are 10-15 years old — is it worth fixing them?',
    answer: "Usually yes for mechanically sound machines. Moreno Valley's housing stock from the 1980s and 1990s has appliances now in the 10–20 year range. A Whirlpool or GE with a worn actuator, thermal fuse, or pump is almost always worth repairing — these are simple mechanical failures on machines with life left in them. We give honest numbers after diagnosis and never push replacement when repair makes sense."
  },
  {
    question: 'What brands do you repair in Moreno Valley?',
    answer: "All major brands. Moreno Valley's 1980s–1990s housing stock runs Whirlpool, GE, and Maytag heavily. Newer developments and renovated homes have Samsung, LG, and KitchenAid. We carry OEM parts for all generations on the truck."
  },
  {
    question: 'What is your diagnostic fee?',
    answer: '$89, applied directly to the repair cost when you proceed. No hidden trip charge to Moreno Valley. We quote on-site after diagnosis — what we quote is what appears on the invoice.'
  },
  {
    question: 'Why does my refrigerator fail every summer in Moreno Valley?',
    answer: "Moreno Valley's summers regularly hit 100–108°F, and that heat stress is the primary cause of refrigerator failures from June through September. Condenser coils that were managing fine in April fail when the ambient temperature climbs 30 degrees. In MV's dry, dusty environment, coils load up faster than coastal cities. Every summer refrigerator call we make here starts with coil inspection and cleaning before anything else. Annual cleaning should be done in May — before the heat arrives."
  },
  {
    question: 'Our family does a lot of laundry — washer breaks more than expected?',
    answer: "Heavy-use households run washers at 2–3x the manufacturer's assumed rate. Moreno Valley has a significant proportion of large family households running 10+ loads per week. Bearing wear, door gasket deterioration, and drum seal failures all show up earlier under heavy use. A front-loader in a large household needs bearing inspection by year 7–8, not year 10–12. We account for use intensity when advising on repair versus replace."
  },
];

const nearbyCities = [
  { name: 'Riverside', slug: 'riverside' },
  { name: 'Hemet', slug: 'hemet' },
  { name: 'Menifee', slug: 'menifee' },
  { name: 'Corona', slug: 'corona' },
  { name: 'Redlands', slug: 'redlands' },
  { name: 'Murrieta', slug: 'murrieta' },
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair"
    headlineCity="Moreno Valley"
    subheadline="Same-day service in Sunnymead, Towngate, Highland Hills, El Sobrante, March ARB area, and throughout Moreno Valley. All brands, OEM parts, licensed."
    zips={zips}
    tier={3}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance Repair in Moreno Valley — The IE's Second-Largest City Has Its Own Profile"
    paragraphs={introParagraphs}
    bookingTitle="Moreno Valley"
    bookingSub="Same-Day Service"
  />

  <ServicesGrid
    cityName={cityName}
    headline="What We Repair in Moreno Valley"
    services={services}
  />

  <CustomNarrative
    headline={morenoValleyContextNarrative.headline}
    subSections={morenoValleyContextNarrative.subSections}
    background="white"
  />

  <ServiceArea
    cityName={cityName}
    headline="Neighborhoods We Service in Moreno Valley"
    subheadline="We cover all of Moreno Valley — Sunnymead, Towngate, Highland Hills, El Sobrante, March ARB area, and every neighborhood in between. No travel surcharge to any Moreno Valley ZIP code."
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={[]}
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Repairs in Moreno Valley"
    jobs={recentJobs}
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="Why Moreno Valley Residents Call Us"
    reasons={whyReasons}
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What Moreno Valley Customers Are Saying"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Typical Repair Pricing in Moreno Valley"
    subhead="Every repair is quoted on-site after diagnosis. The $89 diagnostic is applied when you proceed."
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="Moreno Valley Appliance Repair — FAQ"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby Cities"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Need Appliance Repair in Moreno Valley Today?"
    body="Same-day service in Sunnymead, Towngate, Highland Hills, El Sobrante, March ARB area, and all Moreno Valley neighborhoods."
  />
</CityLayoutV2>
