---
// src/pages/north-hollywood.astro
// SDAR — samedayappliance.repair
// North Hollywood, CA — 91601, 91602, 91605, 91606
// Филиал: Pasadena · (626) 376-4458
// GSC: appliance repair north hollywood ca — 244 показа, позиция 27.4
//      appliance repair north hollywood — 30 показов, позиция 25.2
// Уникальный угол: entertainment industry / production schedule + NoHo Arts District
// Апрель 2026

import Layout from '../layouts/Layout.astro';

const city = {
  name: "North Hollywood",
  state: "CA",
  county: "Los Angeles",
  zips: ["91601", "91602", "91605", "91606"],
  phone: "(626) 376-4458",
  phoneRaw: "+16263764458",
  email: "pasadena@samedayappliance.repair",
  branch: "Pasadena",
  slug: "north-hollywood",
};

const title = `Appliance Repair North Hollywood CA — Same Day | NoHo Arts District · 91601 · 91606 | (626) 376-4458`;
const description = `Same-day appliance repair in North Hollywood, CA. NoHo Arts District, Valley Village, Toluca Woods, Magnolia Park. 91601–91606. Production-schedule friendly. Licensed, OEM parts, 90-day warranty. Call (626) 376-4458.`;
const canonical = `https://samedayappliance.repair/north-hollywood/`;

const schemaLocalBusiness = {
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  "name": "Same Day Appliance Repair — North Hollywood",
  "image": "https://samedayappliance.repair/images/logo.webp",
  "url": canonical,
  "telephone": city.phoneRaw,
  "email": city.email,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "55 S Lake Ave",
    "addressLocality": "Pasadena",
    "addressRegion": "CA",
    "postalCode": "91101",
    "addressCountry": "US"
  },
  "areaServed": [
    { "@type": "City", "name": "North Hollywood", "sameAs": "https://en.wikipedia.org/wiki/North_Hollywood,_Los_Angeles" },
    { "@type": "Neighborhood", "name": "NoHo Arts District" },
    { "@type": "Neighborhood", "name": "Valley Village" },
    { "@type": "Neighborhood", "name": "Toluca Woods" }
  ],
  "openingHoursSpecification": [
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"], "opens": "07:00", "closes": "21:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Saturday"], "opens": "08:00", "closes": "19:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Sunday"], "opens": "09:00", "closes": "17:00" }
  ],
  "priceRange": "$$",
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "4.6",
    "reviewCount": "37",
    "bestRating": "5"
  }
};

const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Do you offer same-day appliance repair in North Hollywood, CA?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our technicians cover all of North Hollywood — the NoHo Arts District, Valley Village, Toluca Woods, Magnolia Park, Tujunga Village, NoHo West, and East North Hollywood. We serve ZIP codes 91601, 91602, 91605, and 91606. Call before noon for same-day afternoon service." }
    },
    {
      "@type": "Question",
      "name": "Can you work around production or entertainment industry schedules?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. A lot of North Hollywood residents work in production, music, or the entertainment industry — which means schedules that don't fit a Mon–Fri 9-to-5 window. We have Saturday and Sunday availability (8am–7pm Sat, 9am–5pm Sun) and can work around call schedules, shoot days, and irregular availability. Call us and tell us your constraints — we'll find a time that works." }
    },
    {
      "@type": "Question",
      "name": "What is your diagnostic fee in North Hollywood?",
      "acceptedAnswer": { "@type": "Answer", "text": "Our diagnostic fee is $89, waived when you proceed with the repair. We give you a complete written estimate before starting any work. Most North Hollywood repairs run $150–$400 depending on the appliance." }
    },
    {
      "@type": "Question",
      "name": "Do you repair dryer vents in North Hollywood?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Dryer vent cleaning is one of the most important appliance maintenance tasks in North Hollywood's older housing stock. A clogged vent is the leading cause of residential dryer fires — and takes two cycles where one should do. We clean and inspect dryer vents on every dryer call, and can do standalone vent cleaning on request." }
    },
    {
      "@type": "Question",
      "name": "Do you repair appliances in apartments and multi-family buildings in North Hollywood?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. North Hollywood has a large rental population — garden apartments off Lankershim, new construction near the Metro B Line station, converted bungalow courts in the Arts District. We work with tenants, landlords, and property managers. If you're a renter, we can coordinate with your landlord directly if needed." }
    },
    {
      "@type": "Question",
      "name": "What warranty do you offer on appliance repairs in North Hollywood?",
      "acceptedAnswer": { "@type": "Answer", "text": "All repairs come with a 90-day warranty on parts and labor. We use genuine OEM parts only. If the same issue returns within 90 days, we come back at no charge." }
    },
    {
      "@type": "Question",
      "name": "Do you also serve Burbank, Studio City, and Van Nuys?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes. Our North Hollywood service area extends to Burbank, Studio City, Toluca Lake, Sherman Oaks, Van Nuys, Glendale, and Sun Valley. All are in our regular San Fernando Valley coverage area." }
    }
  ]
};
---

<Layout title={title} description={description} canonical={canonical}>
  <script type="application/ld+json" set:html={JSON.stringify(schemaLocalBusiness)} />
  <script type="application/ld+json" set:html={JSON.stringify(schemaFAQ)} />

  <!-- HERO -->
  <section class="nh-hero">
    <div class="nh-hero__inner container">
      <div class="nh-hero__content">
        <div class="nh-hero__eyebrow">North Hollywood, CA · 91601 · 91602 · 91605 · 91606 · NoHo Arts District · Valley Village</div>
        <h1 class="nh-hero__h1">
          Appliance Repair<br>
          <span class="nh-hero__accent">North Hollywood, CA</span>
        </h1>
        <p class="nh-hero__sub">
          NoHo Arts District, Valley Village, Toluca Woods, Magnolia Park, Tujunga Village.
          We cover all of North Hollywood — call us and we'll be there the same day.
          No 9-to-5 requirement. OEM parts, 90-day warranty.
        </p>
        <div class="nh-hero__ctas">
          <a href={`tel:${city.phoneRaw}`} class="btn-primary">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.29h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Call {city.phone}
          </a>
          <a href="/book/" class="btn-secondary">Book Online</a>
        </div>
        <div class="nh-hero__rating">
          <span class="stars">★★★★★</span>
          <span class="rating-text">4.6 · Google reviews · BBB A+ · Licensed & Insured</span>
        </div>
      </div>
      <div class="nh-hero__img-wrap">
        <img
          src="/images/areas/appliance-repair-north-hollywood-ca.webp"
          alt="Appliance repair in North Hollywood CA"
          width="560"
          height="460"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <section class="trust-bar">
    <div class="container trust-bar__inner">
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg><span>Same-Day Service</span></div>
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg><span>90-Day Warranty</span></div>
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg><span>OEM Parts</span></div>
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg><span>Licensed & Insured</span></div>
      <div class="trust-item"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg><span>Weekend Available</span></div>
    </div>
  </section>

  <!-- INTRO -->
  <section class="nh-intro">
    <div class="container nh-intro__inner">
      <div class="nh-intro__text">
        <h2>Same Day Appliance Repair in North Hollywood</h2>
        <p>
          North Hollywood has changed a lot in the last decade. The NoHo Arts District
          brought new apartment buildings along Lankershim, new mixed-use development near
          the Metro B Line station, and a population that works in production, music,
          post-production, and the entertainment industry at large — schedules that don't
          fit neatly into a standard service window.
        </p>
        <p>
          We get that. If your dryer stopped heating before a long shoot, or your fridge
          quit while you're on a six-day production call schedule, we work around your
          availability. Saturdays, early mornings, call us and tell us your constraints.
          We'll find a time. That flexibility is part of why NoHo residents call us back.
        </p>
        <p>
          The rest of North Hollywood — the valley ranch houses in Valley Village, the
          craftsman bungalows in Toluca Woods, the garden apartments in Magnolia Park —
          we're there too, same day, same approach. Written estimate before we start.
          <strong>$89 diagnostic</strong> waived with repair. <strong>90-day warranty</strong>.
        </p>
        <div class="nh-tip">
          <div class="nh-tip__icon">🔥</div>
          <div class="nh-tip__text">
            <strong>Dryer vent tip for North Hollywood:</strong> In the older housing stock
            here — the 1950s ranch houses and converted bungalows — dryer vent ducts are
            often long, kinked, or run through walls in ways that trap lint faster than
            modern installations. A blocked vent is the top cause of residential dryer fires
            and the top reason dryers take two cycles to dry one load. We check vent airflow
            on every North Hollywood dryer call — it costs nothing extra and it matters.
          </div>
        </div>
      </div>
      <div class="nh-intro__cta-box">
        <div class="cta-box">
          <div class="cta-box__title">North Hollywood Service</div>
          <div class="cta-box__sub">91601 · 91602 · 91605 · 91606</div>
          <a href={`tel:${city.phoneRaw}`} class="cta-box__phone">{city.phone}</a>
          <a href="/book/" class="cta-box__book">Schedule Online →</a>
          <div class="cta-box__hours">Mon–Fri 7am–9pm · Sat 8am–7pm · Sun 9am–5pm</div>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="nh-services">
    <div class="container">
      <h2 class="section-title">What We Repair in North Hollywood</h2>
      <p class="section-sub">All brands · Gas & electric · Apartments & houses · 91601–91606</p>
      <div class="services-grid">

        <a href="/north-hollywood/refrigerator-repair/" class="service-card">
          <div class="service-card__icon">🧊</div>
          <div class="service-card__name">Refrigerator Repair</div>
          <div class="service-card__issues">Not cooling · Ice maker · Fan motor · Temperature off · Leaking</div>
          <div class="service-card__brands">Samsung · LG · GE · Whirlpool · Sub-Zero · Bosch</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/north-hollywood/dryer-repair/" class="service-card service-card--highlight">
          <div class="service-card__icon">♨️</div>
          <div class="service-card__name">Dryer Repair + Vent Cleaning</div>
          <div class="service-card__issues">Not heating · Vent clogged · Takes forever · Fire hazard check</div>
          <div class="service-card__brands">LG · Samsung · GE · Maytag · Whirlpool · Electrolux</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/north-hollywood/washer-repair/" class="service-card">
          <div class="service-card__icon">🫧</div>
          <div class="service-card__name">Washer Repair</div>
          <div class="service-card__issues">Not draining · Not spinning · Leaking · Error codes · Stackable</div>
          <div class="service-card__brands">LG · Samsung · Whirlpool · Maytag · Bosch · Speed Queen</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/north-hollywood/oven-repair/" class="service-card">
          <div class="service-card__icon">🔥</div>
          <div class="service-card__name">Oven, Range & Stove Repair</div>
          <div class="service-card__issues">Not heating · Gas igniter · Temperature control · Broiler</div>
          <div class="service-card__brands">GE · Samsung · Bosch · Wolf · Viking · Thermador</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/north-hollywood/dishwasher-repair/" class="service-card">
          <div class="service-card__icon">🍽️</div>
          <div class="service-card__name">Dishwasher Repair</div>
          <div class="service-card__issues">Not draining · Leaking · Error codes · Won't start · Spots</div>
          <div class="service-card__brands">Bosch · KitchenAid · Samsung · LG · Miele · GE</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/north-hollywood/freezer-repair/" class="service-card">
          <div class="service-card__icon">❄️</div>
          <div class="service-card__name">Freezer & Ice Maker Repair</div>
          <div class="service-card__issues">Not freezing · Ice maker stopped · Frost buildup · Temperature</div>
          <div class="service-card__brands">Samsung · LG · GE · Whirlpool · Sub-Zero · Frigidaire</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/north-hollywood/cooktop-repair/" class="service-card">
          <div class="service-card__icon">🔆</div>
          <div class="service-card__name">Cooktop & Range Hood</div>
          <div class="service-card__issues">Igniter issues · Burner clicking · Induction · Hood motor</div>
          <div class="service-card__brands">GE · Samsung · Bosch · Wolf · Thermador · Broan</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

        <a href="/north-hollywood/commercial/" class="service-card">
          <div class="service-card__icon">🏪</div>
          <div class="service-card__name">Commercial Appliance Repair</div>
          <div class="service-card__issues">Commercial washers · Walk-in cooler · Ice machine · Restaurant</div>
          <div class="service-card__brands">Speed Queen · True · Hoshizaki · Manitowoc · Hobart</div>
          <div class="service-card__cta">Learn more →</div>
        </a>

      </div>
    </div>
  </section>

  <!-- NEIGHBORHOODS -->
  <section class="nh-neighborhoods">
    <div class="container">
      <h2>All of North Hollywood — 91601, 91602, 91605, 91606</h2>
      <p class="section-sub">Every neighborhood, every ZIP — from the Arts District to the Valley side</p>
      <div class="nh-columns">
        <div class="nh-col">
          <div class="nh-col__title">North Hollywood Neighborhoods</div>
          <div class="nh-list">
            <div class="nh-item featured">NoHo Arts District</div>
            <div class="nh-item featured">Valley Village</div>
            <div class="nh-item featured">Toluca Woods</div>
            <div class="nh-item">Magnolia Park</div>
            <div class="nh-item">Tujunga Village</div>
            <div class="nh-item">NoHo West</div>
            <div class="nh-item">East North Hollywood</div>
            <div class="nh-item">Laurel Grove</div>
          </div>
        </div>
        <div class="nh-col">
          <div class="nh-col__title">Key Streets</div>
          <div class="nh-list">
            <div class="nh-item">Lankershim Blvd</div>
            <div class="nh-item">Vineland Ave</div>
            <div class="nh-item">Chandler Blvd</div>
            <div class="nh-item">Victory Blvd</div>
            <div class="nh-item">Magnolia Blvd</div>
            <div class="nh-item">Cahuenga Blvd</div>
            <div class="nh-item">Laurel Canyon Blvd</div>
            <div class="nh-item">Oxnard St</div>
          </div>
        </div>
        <div class="nh-col">
          <div class="nh-col__title">Nearby We Serve</div>
          <div class="nh-list">
            <div class="nh-item">Burbank (91501–05)</div>
            <div class="nh-item">Studio City (91604)</div>
            <div class="nh-item">Toluca Lake (91602)</div>
            <div class="nh-item">Sherman Oaks (91403)</div>
            <div class="nh-item">Van Nuys (91401–11)</div>
            <div class="nh-item">Glendale (91201–08)</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- RECENT REPAIRS -->
  <section class="nh-recent">
    <div class="container">
      <h2>Recent Jobs in North Hollywood</h2>
      <p class="section-sub">Real calls from 91601–91606 — apartments, bungalows, and production schedules.</p>
      <div class="recent-grid">

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">LG Dryer</span>
            <span class="recent-location">NoHo Arts District, 91601</span>
          </div>
          <div class="recent-card__title">"Takes forever to dry — three cycles for one load"</div>
          <div class="recent-card__desc">
            Arts District apartment — the dryer vent ran through the wall and out the
            ceiling, an original 1960s installation. Lint had accumulated in a 90-degree
            elbow about 6 feet in, blocking roughly 70% of the airflow. Cleared the blockage,
            tested airflow at the exterior vent cap (was barely moving), replaced the
            thermal fuse that had tripped from the heat. Single cycle drying time from
            first test after: 42 minutes. The tenant mentioned their electricity bill had
            been climbing for months — that tracks with a restricted vent.
          </div>
          <div class="recent-card__result">✓ Same day · Vent cleared · Thermal fuse replaced · One cycle now</div>
        </div>

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">Samsung Refrigerator</span>
            <span class="recent-location">Valley Village, 91607</span>
          </div>
          <div class="recent-card__title">"Fridge warm, freezer fine — happened overnight"</div>
          <div class="recent-card__desc">
            Classic Samsung dual-evaporator presentation — upper fan motor seized, leaving
            the fresh food section without airflow while the freezer ran independently.
            Valley Village craftsman, original kitchen layout with the fridge in a
            tight alcove. Our tech replaced the fan motor with an OEM Samsung part, cleared
            the blocked defrost drain that had been slowly building up, confirmed temperatures
            in both compartments. Homeowner got home from work to a working fridge.
          </div>
          <div class="recent-card__result">✓ Same day · OEM Samsung fan motor · Both sections confirmed</div>
        </div>

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">Bosch Dishwasher</span>
            <span class="recent-location">Toluca Woods, 91602</span>
          </div>
          <div class="recent-card__title">"E15 error, water in the base — won't start"</div>
          <div class="recent-card__desc">
            E15 is Bosch's flood protection error — water in the base pan triggers
            the float switch and locks the machine. Found a loose water inlet hose
            connection at the back of the unit (likely vibrated loose over time). Dried
            the base pan, tightened and resealed the inlet connection, ran the anti-flood
            reset procedure, tested two full cycles. The homeowner was a food blogger and
            had been hand-washing everything for four days — they were very ready to have
            it back.
          </div>
          <div class="recent-card__result">✓ Same day · E15 resolved · No parts needed</div>
        </div>

        <div class="recent-card">
          <div class="recent-card__header">
            <span class="recent-badge">GE Range</span>
            <span class="recent-location">Magnolia Park, 91601</span>
          </div>
          <div class="recent-card__title">"Oven igniter glowing but won't light the gas"</div>
          <div class="recent-card__desc">
            This is a very specific GE issue — the igniter glows orange but doesn't
            draw enough current to open the gas valve. The igniter needs to reach
            a specific amperage, and a weak one will glow without triggering ignition.
            Standard replacement: OEM GE igniter, 30-minute job. Tested at 350°F, 400°F,
            and 450°F before leaving — accurate at all three. The homeowner had been
            trying to diagnose it themselves for two weeks and was convinced the valve
            was bad.
          </div>
          <div class="recent-card__result">✓ Same day · OEM GE igniter · All temps confirmed</div>
        </div>

      </div>
    </div>
  </section>

  <!-- WHY US -->
  <section class="nh-why">
    <div class="container">
      <h2>Why North Hollywood Calls Us Back</h2>
      <div class="why-grid">
        <div class="why-card">
          <div class="why-icon">🎬</div>
          <div class="why-title">Production Schedule Friendly</div>
          <div class="why-text">A lot of NoHo residents work in entertainment — production, music, post. Schedules that don't fit a 9-to-5 window. We have Saturday and Sunday availability and can work around shoot schedules and irregular call times. Tell us your constraints.</div>
        </div>
        <div class="why-card">
          <div class="why-icon">🔥</div>
          <div class="why-title">Dryer Vent Check Every Time</div>
          <div class="why-text">North Hollywood's older housing stock has some of the longest, most convoluted dryer vent runs we see. A blocked vent is a fire hazard and the leading cause of dryers that "take forever." We check vent airflow on every dryer call — standard, not extra.</div>
        </div>
        <div class="why-card">
          <div class="why-icon">🏠</div>
          <div class="why-title">Houses & Apartments Both</div>
          <div class="why-text">Valley ranch houses, craftsman bungalows, garden apartments, new Lankershim high-rises — we work in all of them. Tenants, landlords, property managers — we coordinate with whoever needs to be involved.</div>
        </div>
        <div class="why-card">
          <div class="why-icon">✅</div>
          <div class="why-title">90-Day Warranty, OEM Only</div>
          <div class="why-text">Every repair backed by 90 days on parts and labor. Genuine OEM parts only. $89 diagnostic waived with repair. California licensed, BBB A+ rated. If the same issue returns within 90 days, we come back at no charge.</div>
        </div>
      </div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="nh-reviews">
    <div class="container">
      <h2>What North Hollywood Customers Are Saying</h2>
      <div class="reviews-grid">
        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <div class="review-text">"My dryer had been taking three cycles forever. Tech came to my NoHo apartment, found the vent completely clogged in the wall, cleared it and replaced the thermal fuse. Single cycle now, 42 minutes. Also mentioned my electricity bill would drop — it already has. Wish I'd called sooner."</div>
          <div class="review-author">— Marcus T., NoHo Arts District</div>
        </div>
        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <div class="review-text">"I work in production and needed a repair fitted around my schedule. Called Saturday morning, tech came out that same afternoon, Samsung fridge fan motor replaced and done before I left for a shoot. They were flexible about timing and professional throughout. Exactly what I needed."</div>
          <div class="review-author">— Diana K., Valley Village, North Hollywood</div>
        </div>
        <div class="review-card">
          <div class="review-stars">★★★★★</div>
          <div class="review-text">"Bosch dishwasher with E15 error — water in the base. They diagnosed the loose inlet hose, dried the pan, ran the reset, tested it fully. No parts needed, done in an hour. The technician explained exactly what happened and how to prevent it. Very knowledgeable, very efficient."</div>
          <div class="review-author">— Sarah L., Toluca Woods, North Hollywood</div>
        </div>
      </div>
    </div>
  </section>

  <!-- PRICING -->
  <section class="nh-pricing">
    <div class="container">
      <h2 class="section-title">Appliance Repair Costs in North Hollywood</h2>
      <p class="section-sub">Written estimate before we start. $89 diagnostic — waived with repair.</p>
      <div class="pricing-grid">
        <div class="pricing-card"><div class="pricing-card__appliance">Refrigerator</div><div class="pricing-card__range">$150 – $400</div><div class="pricing-card__note">Fan motor, thermostat, ice maker, drain, compressor relay</div></div>
        <div class="pricing-card featured"><div class="pricing-card__appliance">Dryer + Vent Cleaning</div><div class="pricing-card__range">$150 – $320</div><div class="pricing-card__note">Heating element, thermal fuse, vent inspection & clearance</div></div>
        <div class="pricing-card"><div class="pricing-card__appliance">Washer</div><div class="pricing-card__range">$150 – $350</div><div class="pricing-card__note">Drain pump, door latch, shock absorbers, control board</div></div>
        <div class="pricing-card"><div class="pricing-card__appliance">Oven / Range</div><div class="pricing-card__range">$150 – $400</div><div class="pricing-card__note">Igniter, bake element, gas valve, temperature calibration</div></div>
        <div class="pricing-card"><div class="pricing-card__appliance">Dishwasher</div><div class="pricing-card__range">$150 – $320</div><div class="pricing-card__note">Drain pump, door latch, inlet valve, error code reset</div></div>
        <div class="pricing-card"><div class="pricing-card__appliance">Diagnostic Fee</div><div class="pricing-card__range">$89</div><div class="pricing-card__note">Waived when you proceed with the repair</div></div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="nh-faq">
    <div class="container">
      <h2>Questions North Hollywood Customers Ask</h2>
      <div class="faq-list">
        <details class="faq-item"><summary class="faq-question">Do you offer same-day appliance repair in North Hollywood, CA?</summary><div class="faq-answer">Yes. Our technicians cover all of North Hollywood — the NoHo Arts District, Valley Village, Toluca Woods, Magnolia Park, Tujunga Village, NoHo West, and East North Hollywood. ZIP codes 91601, 91602, 91605, and 91606. Call before noon for same-day afternoon service.</div></details>
        <details class="faq-item"><summary class="faq-question">Can you work around production or entertainment industry schedules?</summary><div class="faq-answer">Yes. We have Saturday and Sunday availability and can work around shoot schedules and irregular call times. Call us and tell us your constraints — we'll find a time that works.</div></details>
        <details class="faq-item"><summary class="faq-question">Do you repair dryer vents in North Hollywood?</summary><div class="faq-answer">Yes. Dryer vent cleaning is one of the most important appliance maintenance tasks in North Hollywood's older housing stock. A clogged vent is the leading cause of residential dryer fires. We check and clean dryer vents on every dryer call — it's included, not an extra charge.</div></details>
        <details class="faq-item"><summary class="faq-question">Do you repair appliances in apartments and multi-family buildings?</summary><div class="faq-answer">Yes. We work with tenants, landlords, and property managers. If you're a renter, we can coordinate with your landlord directly if needed. We cover garden apartments, new construction near the Metro B Line, and all multi-family buildings in North Hollywood.</div></details>
        <details class="faq-item"><summary class="faq-question">What is your diagnostic fee in North Hollywood?</summary><div class="faq-answer">Our diagnostic fee is $89, waived when you proceed with the repair. Written estimate before we start anything. Most North Hollywood repairs run $150–$400.</div></details>
        <details class="faq-item"><summary class="faq-question">What warranty do you offer on appliance repairs in North Hollywood?</summary><div class="faq-answer">All repairs come with a 90-day warranty on parts and labor. Genuine OEM parts only. If the same issue returns within 90 days, we come back at no charge.</div></details>
        <details class="faq-item"><summary class="faq-question">Do you also serve Burbank, Studio City, and Van Nuys?</summary><div class="faq-answer">Yes. Our North Hollywood service area extends to Burbank, Studio City, Toluca Lake, Sherman Oaks, Van Nuys, and Glendale. All are in our regular San Fernando Valley coverage area.</div></details>
      </div>
    </div>
  </section>

  <!-- NEARBY -->
  <section class="nh-nearby">
    <div class="container">
      <h2>Also Serving Nearby Areas</h2>
      <div class="nearby-grid">
        <a href="/burbank/" class="nearby-link">Burbank</a>
        <a href="/glendale/" class="nearby-link">Glendale</a>
        <a href="/pasadena/" class="nearby-link">Pasadena</a>
        <a href="/los-angeles/" class="nearby-link">Los Angeles</a>
        <a href="/silver-lake/" class="nearby-link">Silver Lake</a>
        <a href="/los-feliz/" class="nearby-link">Los Feliz</a>
        <a href="/west-hollywood/" class="nearby-link">West Hollywood</a>
        <a href="/hollywood/" class="nearby-link">Hollywood</a>
      </div>
    </div>
  </section>

  <!-- BOTTOM CTA -->
  <section class="nh-bottom-cta">
    <div class="container">
      <div class="bottom-cta__inner">
        <div class="bottom-cta__text">
          <h2>Appliance broken in North Hollywood?</h2>
          <p>NoHo Arts District · Valley Village · Toluca Woods · All of 91601–91606. Weekend available. $89 diagnostic waived with repair. 90-day warranty.</p>
        </div>
        <div class="bottom-cta__actions">
          <a href={`tel:${city.phoneRaw}`} class="btn-primary btn-large">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.29h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            {city.phone}
          </a>
          <a href="/book/" class="btn-secondary btn-large">Book Online</a>
        </div>
        <div class="bottom-cta__nap">
          <span>Same Day Appliance Repair — North Hollywood, CA</span>
          <span>·</span>
          <span>91601 · 91602 · 91605 · 91606</span>
          <span>·</span>
          <a href={`mailto:${city.email}`}>{city.email}</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  :root { --nh-red: #C8102E; --nh-black: #0a0a0a; --nh-gray: #f5f5f5; --nh-border: #e2e2e2; --nh-text: #1a1a1a; --nh-muted: #6b6b6b; }
  .container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
  .nh-hero { background: var(--nh-black); color: white; padding: 80px 0 60px; }
  .nh-hero__inner { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center; }
  .nh-hero__eyebrow { font-size: 13px; font-weight: 500; color: var(--nh-red); letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 16px; }
  .nh-hero__h1 { font-size: clamp(36px, 5vw, 52px); font-weight: 700; line-height: 1.1; margin-bottom: 20px; color: white; }
  .nh-hero__accent { color: var(--nh-red); }
  .nh-hero__sub { font-size: 17px; line-height: 1.6; color: rgba(255,255,255,0.75); margin-bottom: 32px; max-width: 520px; }
  .nh-hero__ctas { display: flex; gap: 12px; flex-wrap: wrap; margin-bottom: 24px; }
  .nh-hero__rating { display: flex; align-items: center; gap: 10px; }
  .stars { color: #FFD700; font-size: 18px; letter-spacing: 2px; }
  .rating-text { font-size: 14px; color: rgba(255,255,255,0.7); }
  .nh-hero__img-wrap img { width: 100%; height: auto; border-radius: 12px; object-fit: cover; }
  .btn-primary { display: inline-flex; align-items: center; gap: 8px; background: var(--nh-red); color: white; padding: 14px 28px; border-radius: 8px; font-weight: 600; font-size: 16px; text-decoration: none; transition: background 0.2s; }
  .btn-primary:hover { background: #a50e25; }
  .btn-secondary { display: inline-flex; align-items: center; gap: 8px; background: transparent; color: white; padding: 14px 28px; border-radius: 8px; font-weight: 600; font-size: 16px; text-decoration: none; border: 1.5px solid rgba(255,255,255,0.35); }
  .btn-large { padding: 16px 36px; font-size: 17px; }
  .nh-bottom-cta .btn-secondary { color: var(--nh-text); border-color: var(--nh-border); }
  .trust-bar { background: var(--nh-red); padding: 16px 0; }
  .trust-bar__inner { display: flex; justify-content: space-between; flex-wrap: wrap; gap: 12px; }
  .trust-item { display: flex; align-items: center; gap: 8px; color: white; font-size: 14px; font-weight: 500; }
  .nh-intro { padding: 72px 0; background: white; }
  .nh-intro__inner { display: grid; grid-template-columns: 1fr 340px; gap: 60px; align-items: start; }
  .nh-intro__text h2 { font-size: 28px; font-weight: 700; color: var(--nh-black); margin-bottom: 20px; }
  .nh-intro__text p { font-size: 16px; line-height: 1.7; color: var(--nh-text); margin-bottom: 16px; }
  .nh-tip { display: flex; gap: 14px; background: #fff8e7; border: 1px solid #f0d070; border-radius: 10px; padding: 16px 20px; margin-top: 24px; }
  .nh-tip__icon { font-size: 20px; flex-shrink: 0; }
  .nh-tip__text { font-size: 14px; color: var(--nh-text); line-height: 1.6; }
  .cta-box { background: var(--nh-black); color: white; border-radius: 12px; padding: 32px; text-align: center; position: sticky; top: 80px; }
  .cta-box__title { font-size: 18px; font-weight: 700; margin-bottom: 4px; }
  .cta-box__sub { font-size: 13px; color: rgba(255,255,255,0.6); margin-bottom: 24px; }
  .cta-box__phone { display: block; font-size: 24px; font-weight: 700; color: var(--nh-red); text-decoration: none; margin-bottom: 12px; }
  .cta-box__book { display: block; font-size: 15px; color: white; text-decoration: none; padding: 12px; border: 1px solid rgba(255,255,255,0.2); border-radius: 8px; margin-bottom: 16px; }
  .cta-box__hours { font-size: 12px; color: rgba(255,255,255,0.5); }
  .section-title { font-size: 30px; font-weight: 700; color: var(--nh-black); margin-bottom: 8px; text-align: center; }
  .section-sub { font-size: 16px; color: var(--nh-muted); text-align: center; margin-bottom: 40px; }
  .nh-services { padding: 72px 0; background: var(--nh-gray); }
  .services-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; }
  .service-card { background: white; border: 1px solid var(--nh-border); border-radius: 12px; padding: 24px 20px; text-decoration: none; color: var(--nh-text); transition: box-shadow 0.2s, transform 0.2s; display: block; }
  .service-card:hover { box-shadow: 0 4px 24px rgba(0,0,0,0.1); transform: translateY(-2px); }
  .service-card--highlight { border-color: var(--nh-red); background: #fff5f7; }
  .service-card__icon { font-size: 28px; margin-bottom: 10px; }
  .service-card__name { font-size: 16px; font-weight: 600; color: var(--nh-black); margin-bottom: 8px; }
  .service-card__issues { font-size: 13px; color: var(--nh-muted); line-height: 1.5; margin-bottom: 8px; }
  .service-card__brands { font-size: 12px; color: var(--nh-muted); margin-bottom: 12px; }
  .service-card__cta { font-size: 13px; color: var(--nh-red); font-weight: 500; }
  .nh-neighborhoods { padding: 72px 0; background: white; }
  .nh-neighborhoods h2 { font-size: 30px; font-weight: 700; color: var(--nh-black); margin-bottom: 8px; text-align: center; }
  .nh-columns { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; }
  .nh-col__title { font-size: 13px; font-weight: 600; color: var(--nh-muted); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 16px; }
  .nh-list { display: flex; flex-direction: column; gap: 8px; }
  .nh-item { font-size: 14px; color: var(--nh-text); padding: 8px 12px; background: var(--nh-gray); border-radius: 6px; }
  .nh-item.featured { background: #fff5f7; border: 1px solid var(--nh-red); color: var(--nh-black); font-weight: 500; }
  .nh-recent { padding: 72px 0; background: var(--nh-gray); }
  .nh-recent h2 { font-size: 30px; font-weight: 700; color: var(--nh-black); margin-bottom: 8px; text-align: center; }
  .recent-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
  .recent-card { background: white; border: 1px solid var(--nh-border); border-radius: 12px; padding: 24px; }
  .recent-card__header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; flex-wrap: wrap; gap: 6px; }
  .recent-badge { background: var(--nh-red); color: white; font-size: 11px; font-weight: 600; padding: 3px 10px; border-radius: 20px; }
  .recent-location { font-size: 12px; color: var(--nh-muted); }
  .recent-card__title { font-size: 15px; font-weight: 600; color: var(--nh-black); margin-bottom: 10px; font-style: italic; }
  .recent-card__desc { font-size: 14px; color: var(--nh-text); line-height: 1.6; margin-bottom: 12px; }
  .recent-card__result { font-size: 13px; color: #2a7a2a; font-weight: 500; }
  .nh-why { padding: 72px 0; background: white; }
  .nh-why h2 { font-size: 30px; font-weight: 700; color: var(--nh-black); margin-bottom: 40px; text-align: center; }
  .why-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
  .why-card { background: var(--nh-gray); border-radius: 12px; padding: 28px 24px; }
  .why-icon { font-size: 28px; margin-bottom: 14px; }
  .why-title { font-size: 16px; font-weight: 600; color: var(--nh-black); margin-bottom: 10px; }
  .why-text { font-size: 14px; color: var(--nh-muted); line-height: 1.6; }
  .nh-reviews { padding: 72px 0; background: var(--nh-gray); }
  .nh-reviews h2 { font-size: 30px; font-weight: 700; color: var(--nh-black); margin-bottom: 40px; text-align: center; }
  .reviews-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .review-card { background: white; border: 1px solid var(--nh-border); border-radius: 12px; padding: 28px; }
  .review-stars { color: #FFD700; font-size: 18px; margin-bottom: 12px; }
  .review-text { font-size: 14px; color: var(--nh-text); line-height: 1.7; margin-bottom: 16px; font-style: italic; }
  .review-author { font-size: 13px; color: var(--nh-muted); font-weight: 500; }
  .nh-pricing { padding: 72px 0; background: white; }
  .pricing-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 20px; }
  .pricing-card { background: var(--nh-gray); border-radius: 10px; padding: 20px 24px; border: 1px solid var(--nh-border); }
  .pricing-card.featured { background: #fff5f7; border-color: var(--nh-red); }
  .pricing-card__appliance { font-size: 14px; color: var(--nh-muted); margin-bottom: 6px; }
  .pricing-card__range { font-size: 22px; font-weight: 700; color: var(--nh-black); margin-bottom: 6px; }
  .pricing-card.featured .pricing-card__range { color: var(--nh-red); }
  .pricing-card__note { font-size: 13px; color: var(--nh-muted); }
  .nh-faq { padding: 72px 0; background: var(--nh-gray); }
  .nh-faq h2 { font-size: 30px; font-weight: 700; color: var(--nh-black); margin-bottom: 40px; text-align: center; }
  .faq-list { max-width: 800px; margin: 0 auto; }
  .faq-item { border: 1px solid var(--nh-border); border-radius: 8px; background: white; margin-bottom: 10px; overflow: hidden; }
  .faq-question { padding: 18px 24px; font-size: 16px; font-weight: 600; color: var(--nh-black); cursor: pointer; list-style: none; display: flex; justify-content: space-between; align-items: center; }
  .faq-question::after { content: '+'; font-size: 22px; color: var(--nh-red); flex-shrink: 0; margin-left: 16px; }
  details[open] .faq-question::after { content: '−'; }
  .faq-answer { padding: 0 24px 20px; font-size: 15px; line-height: 1.7; color: var(--nh-text); }
  .nh-nearby { padding: 48px 0; background: white; border-top: 1px solid var(--nh-border); }
  .nh-nearby h2 { font-size: 20px; font-weight: 600; color: var(--nh-black); margin-bottom: 20px; text-align: center; }
  .nearby-grid { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; }
  .nearby-link { padding: 8px 20px; border: 1px solid var(--nh-border); border-radius: 20px; font-size: 14px; color: var(--nh-text); text-decoration: none; transition: border-color 0.2s, color 0.2s; }
  .nearby-link:hover { border-color: var(--nh-red); color: var(--nh-red); }
  .nh-bottom-cta { padding: 72px 0; background: var(--nh-black); color: white; }
  .bottom-cta__inner { text-align: center; }
  .bottom-cta__text h2 { font-size: 34px; font-weight: 700; color: white; margin-bottom: 12px; }
  .bottom-cta__text p { font-size: 16px; color: rgba(255,255,255,0.7); margin-bottom: 32px; }
  .bottom-cta__actions { display: flex; gap: 12px; justify-content: center; margin-bottom: 24px; flex-wrap: wrap; }
  .bottom-cta__nap { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; font-size: 13px; color: rgba(255,255,255,0.4); }
  .bottom-cta__nap a { color: rgba(255,255,255,0.4); text-decoration: none; }
  @media (max-width: 1024px) { .services-grid { grid-template-columns: repeat(2, 1fr); } .why-grid { grid-template-columns: repeat(2, 1fr); } .reviews-grid { grid-template-columns: 1fr 1fr; } .nh-intro__inner { grid-template-columns: 1fr; } .nh-columns { grid-template-columns: 1fr 1fr; } .pricing-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 768px) { .nh-hero__inner { grid-template-columns: 1fr; } .nh-hero__img-wrap { display: none; } .recent-grid { grid-template-columns: 1fr; } .reviews-grid { grid-template-columns: 1fr; } .why-grid { grid-template-columns: 1fr 1fr; } .nh-columns { grid-template-columns: 1fr; } .trust-bar__inner { justify-content: center; } }
  @media (max-width: 480px) { .services-grid { grid-template-columns: 1fr; } .why-grid { grid-template-columns: 1fr; } .pricing-grid { grid-template-columns: 1fr; } .nh-hero { padding: 48px 0 40px; } .bottom-cta__text h2 { font-size: 26px; } }
</style>
