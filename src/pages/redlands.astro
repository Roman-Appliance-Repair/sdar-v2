---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import CustomNarrative from '../components/cities/v2/CustomNarrative.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES, MAIN_PHONE, isPlaceholderPhone } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

import { mergeCredentials } from '../data/credentials-schema';
const citySlug = 'redlands';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = 'Redlands';
const zips = ['92373', '92374'];

const phone = branch.phone;
const phoneRaw = `+1${phone.replace(/\D/g, '')}`;

const title = `Appliance Repair Redlands CA — Same Day | All Brands`;
const description = `Same-day appliance repair in Redlands CA. Smiley Heights, Downtown, University area. Licensed. OEM parts.`;
const canonical = 'https://samedayappliance.repair/redlands/';

const localBusinessSchema = mergeCredentials({
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { '@type': 'City', name: 'Redlands', sameAs: 'https://en.wikipedia.org/wiki/Redlands,_California' }
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$',
  license: 'BHGS #A49573'

});

const introParagraphs = [
  "Redlands is one of the most distinctive cities we service in Southern California. Known as the \"Jewel of the Inland Empire,\" it has a character unlike any other SB County city — Victorian and Craftsman homes in Smiley Heights and near Downtown that date to the 1890s and early 1900s, tree-lined streets, historic citrus groves, and the University of Redlands anchoring a college-town feel in the central neighborhoods. Then there's East Redlands and the newer developments pushing toward Loma Linda, with completely different appliance profiles. This is not a one-generation city.",
  "The historic neighborhoods create specific appliance service needs that most companies in this area aren't equipped for. Older GE and Whirlpool machines in 1920s Craftsman homes are often genuinely worth repairing — mechanically simpler than modern units, strong motors, parts still available. We approach these calls the same way we approach calls in Pasadena's historic neighborhoods: with patience, honest assessment, and a bias toward repair when the machine's core components are sound.",
  "The mountain proximity matters. Redlands sits at the base of the San Bernardino Mountains, and canyon winds carry fine particulate from the mountain faces into homes throughout the hillside neighborhoods. After major wildfire events in the San Bernardino National Forest, ash and smoke particles add to coil loading throughout the city. We account for this on every refrigerator call in hillside and upper Redlands neighborhoods.",
  `Same-day service across ZIP codes 92373 and 92374. Call <a href="tel:${phoneRaw}">${phone}</a>.`
];

const services = [
  { icon: '❄️', name: 'Refrigerator Repair', slug: 'refrigerator' },
  { icon: '🌀', name: 'Washer Repair', slug: 'washer' },
  { icon: '💨', name: 'Dryer Repair', slug: 'dryer' },
  { icon: '🔥', name: 'Oven & Range Repair', slug: 'oven' },
  { icon: '🫧', name: 'Dishwasher Repair', slug: 'dishwasher' },
  { icon: '🍳', name: 'Stove & Cooktop Repair', slug: 'stove' },
  { icon: '🧊', name: 'Freezer Repair', slug: 'freezer' },
  { icon: '🍷', name: 'Wine Cooler Repair', slug: 'wine-cooler' }
];

const housingNarrative = {
  headline: 'Redlands Housing Stock — From Victorian Estates to East Redlands New Builds',
  subSections: [
    {
      title: 'Smiley Heights & Historic Downtown — 1890s–1930s',
      paragraphs: [
        "Smiley Heights is the most distinctive neighborhood in Redlands — hilltop estates and Victorian homes built by prosperous citrus families in the late 1800s and early 1900s. The housing here is carefully maintained, and the appliances reflect the owners' investment in their properties. We service Sub-Zero and Wolf in the larger Smiley Heights estates, and older but well-maintained Whirlpool, GE, and KitchenAid in the historic homes closer to Downtown. The hillside location creates the mountain particulate issue we see throughout Redlands hillside areas — condenser coils in Smiley Heights homes need more frequent cleaning than flat neighborhoods.",
        "Downtown Redlands and the Orange Street corridor have a mix of historic commercial buildings, apartments, and craftsman homes from the 1900s–1930s. Rental properties here support both the University of Redlands student population and long-term residents. We work with landlords and property managers in this corridor regularly and understand the urgency of occupied rental repairs."
      ]
    },
    {
      title: 'University of Redlands Area — Rental Market',
      paragraphs: [
        "The University of Redlands generates substantial rental demand in the surrounding neighborhoods — primarily the streets within walking distance of campus. These properties run mid-range appliances in the 5–15 year range, and they see higher-than-average use. Washers and dryers in student rental properties run daily loads throughout the academic year. Refrigerators are opened constantly by multiple occupants. We see appliances in active rental properties need service significantly earlier than comparable owner-occupied homes. We work directly with landlords on priority scheduling and aim for same-day service on all occupied rental calls."
      ]
    },
    {
      title: 'Mid-Century Redlands — 1950s–1980s Neighborhoods',
      paragraphs: [
        "The streets south and north of Redlands Boulevard represent the city's post-war expansion — mid-century ranch homes and tract houses built from the 1950s through the 1980s. Appliances here span from 15-year-old replacements installed in the 2000s to older original machines still running strong. Whirlpool, GE, and Maytag dominate. Hard water from SB County supply is an issue throughout these neighborhoods — dishwasher filter cleaning every three months is our standard recommendation, and we include descaling on every applicable service call."
      ]
    },
    {
      title: 'East Redlands — 1990s–2010s Development',
      paragraphs: [
        "East Redlands toward the Loma Linda border represents the city's newer growth — planned subdivisions and tract homes from the 1990s through 2010s. Samsung, LG, and KitchenAid dominate here, now entering the 8–15 year failure window. Ice maker issues, evaporator fan failures, and front-load washer bearing wear are the common calls. The proximity to Loma Linda University Medical Center means this area has a higher-than-average concentration of healthcare workers — people with demanding schedules who need appliance problems resolved quickly."
      ]
    },
    {
      title: 'Mountain Proximity — Wildfire Ash and Canyon Particulate',
      paragraphs: [
        "Redlands sits directly below the San Bernardino Mountains, and the impact on appliances is real. Canyon winds carry decomposed granite particulate from the mountain faces into hillside neighborhoods year-round. During and after wildfire events in the San Bernardino National Forest — which have increased in frequency and severity — ash and smoke particles circulate throughout the region and accelerate condenser coil loading across all of Redlands. After the 2020 El Dorado Fire and subsequent events, we made more condenser cleaning calls in Redlands than in any comparable month. We recommend checking condenser coils after any significant fire event in the mountains, even if they were recently cleaned."
      ]
    }
  ]
};

// Audit fix #4: dropped "Highland Ave Corridor" entry (92346 not in city.zips).
const neighborhoods = [
  { name: 'Smiley Heights', zip: '92373' },
  { name: 'Downtown Redlands', zip: '92373' },
  { name: 'North Redlands', zip: '92374' },
  { name: 'South Redlands', zip: '92373' },
  { name: 'University Area', zip: '92374' },
  { name: 'Redlands Blvd Area', zip: '92373' },
  { name: 'East Redlands', zip: '92374' },
  { name: 'Citrus Valley', zip: '92373' },
  { name: 'Ford Park Area', zip: '92373' },
  { name: 'Orange Street', zip: '92373' },
  { name: 'Mentone Border', zip: '92374' }
];

const recentJobs = [
  {
    appliance: 'Sub-Zero 648PRO',
    location: 'Smiley Heights, 92373',
    quote: 'not cooling, compressor noise, Smiley Heights estate',
    description: "Historic 1920s estate in Smiley Heights, Sub-Zero 48-inch column refrigerator running constantly with audible compressor strain. Classic mountain proximity coil loading — the home sits on a ridge that channels canyon air from the San Bernardino Mountains, and the condenser coil pack had two years of fine grey particulate on it. Combined with late-summer ambient temperatures of 105°F, the coils were overwhelmed. Cleaned the condenser coils thoroughly, tested compressor load under ambient conditions — within normal range post-cleaning. Also found a hairline crack in the right door gasket from Redlands' dry heat. Replaced the gasket with an OEM Sub-Zero part. Unit restored to normal operation.",
    outcome: 'Smiley Heights hillside homes get mountain particulate year-round. Sub-Zero coils here need cleaning every 5 months.'
  },
  {
    appliance: 'GE GTW680BSJWS washer',
    location: 'Downtown Redlands, 92373',
    quote: "won't drain, F2 code, 2009 model",
    description: "15-year-old GE top-loader in a 1940s Craftsman home near Downtown. F2 is a drain error. Pump motor was drawing current but barely turning — the impeller had a piece of a sock lodged in it (classic). Cleared the obstruction, tested pump flow — adequate. While there, the customer asked about the machine's age and whether to keep it. Motor was strong, transmission solid. Only the pump impeller needed attention. $89 diagnostic + $65 labor. Machine running clean. We told the customer it had at least 5 more years in it.",
    outcome: 'Old GE top-loaders are among the most repairable machines we work on. Simple mechanics, strong motors.'
  },
  {
    appliance: 'Samsung RF28R7351SR',
    location: 'East Redlands, 92374',
    quote: 'ice maker dead, water dispenser works, 2020 build',
    description: "2020 Samsung French-door from an East Redlands newer development, 4 years old. Ice maker silent, water dispenser functioning normally. Isolated the issue to the ice maker inlet valve secondary solenoid — failed independently of the water solenoid. In Redlands' hard water, we also found mineral scale in the ice maker mold that had been accumulating since installation with no descaling. Replaced the inlet valve assembly (OEM Samsung), descaled the ice maker mold, adjusted the freezer set point from -1°F to +2°F to prevent fill tube freezing. Ice production restored within 8 hours.",
    outcome: 'Redlands hard water requires ice maker descaling every 12–18 months. Most owners never do it until something fails.'
  },
  {
    appliance: 'Whirlpool WED5000DW dryer',
    location: 'University area, 92374',
    quote: 'no heat, thermal fuse blown, University area rental',
    description: "Property manager called — tenant near University of Redlands reporting no heat in the dryer. Confirmed blown thermal fuse. As always, we investigated the root cause: a 19-foot vent run through the interior of the house with a 90-degree bend at the exit, partially blocked with lint. Cleared the full vent, replaced both the thermal fuse and the thermal limiter as a set (replacing fuse alone without the limiter on Whirlpool units often results in a repeat failure within weeks). Confirmed airflow at the exterior vent. Done in under two hours. Property manager had it fixed before the tenant came home.",
    outcome: 'Always replace thermal fuse and thermal limiter together on Whirlpool dryers. And always find the blockage first.'
  }
];

const whyReasons = [
  {
    iconKey: 'team' as const,
    title: 'We work on older appliances',
    body: "Historic Redlands homes deserve respect — and so do the appliances in them. If a 20-year-old GE or Whirlpool is mechanically sound, we'll fix it honestly and tell you how many more years it has in it. We don't push replacement on machines worth repairing."
  },
  {
    iconKey: 'parts' as const,
    title: 'Mountain proximity expertise',
    body: "Canyon particulate and wildfire ash are real factors in Redlands, particularly in Smiley Heights and hillside neighborhoods. We account for this in every refrigerator diagnosis and recommend the right post-fire cleaning schedule when it's relevant."
  },
  {
    iconKey: 'shield' as const,
    title: 'Rental & university area priority',
    body: "We work with University of Redlands area landlords and coordinate directly with tenants. Same-day service on occupied rentals isn't just a goal — it's a commitment. A tenant without a working appliance is a habitability problem we take seriously."
  },
  {
    iconKey: 'clock' as const,
    title: 'Diagnosis before the quote',
    body: "The $89 fee covers a real on-site diagnosis. A blown thermal fuse has a root cause — we find it before replacing parts. A Sub-Zero running warm usually has clean coils as the answer, not a compressor. We don't quote the expensive fix until the cheap one is ruled out."
  }
];

const testimonials = [
  {
    stars: 5,
    text: '"Sub-Zero in our Smiley Heights home was struggling in summer. Tech found the condenser coils completely packed — mountain dust, he said. Cleaned them thoroughly and replaced a door gasket. Unit running perfectly. Explained the 5-month cleaning schedule for our location. Very knowledgeable."',
    author: '— William & Carol M., Smiley Heights'
  },
  {
    stars: 5,
    text: '"Old GE washer in our 1940s Craftsman home — other companies said just buy a new one. Same Day found a piece of fabric stuck in the pump, cleared it in 30 minutes. $89 diagnostic and $65 service. Machine is 15 years old and they told me it has years left in it."',
    author: '— Patricia L., Downtown Redlands'
  },
  {
    stars: 5,
    text: '"Property manager for three rentals near the university. Called Same Day for a broken Whirlpool dryer — they were there the same afternoon, found a blocked vent AND a blown thermal fuse, fixed both. They always handle my tenants professionally. My go-to for all three properties."',
    author: '— David K., University area landlord'
  }
];

const pricingTiers = [
  { appliance: 'Refrigerator Repair', range: '$150–$450', note: 'Compressor relay · Coil cleaning · Inlet valve · Fan motor' },
  { appliance: 'Washer Repair', range: '$120–$380', note: 'Drain pump · Drive coupling · Bearing · Actuator' },
  { appliance: 'Dryer Repair', range: '$120–$320', note: 'Thermal fuse + limiter · Heating element · Vent path' },
  { appliance: 'Dishwasher Repair', range: '$89–$360', note: 'Drain pump · Filter · Spray arm · Hard water descaling' },
  { appliance: 'Oven / Range Repair', range: '$140–$400', note: 'Igniter · Bake element · Gas valve · Calibration' },
  { appliance: 'Sub-Zero Repair', range: '$250–$650', note: 'OEM Sub-Zero parts · Coil cleaning · Door gasket' },
  { appliance: 'Wine Cooler Repair', range: '$150–$450', note: 'Compressor · Thermistor · Door seal · Temperature swings' },
  { appliance: 'Condenser Coil Cleaning', range: '$89–$150', note: 'Hillside homes: every 5 months recommended' }
];

const faqs = [
  {
    question: 'Do you offer same-day appliance repair in Redlands?',
    answer: `Yes — same-day service is available throughout Redlands including Smiley Heights, Downtown, the University area, North and South Redlands, and East Redlands. Call ${phone} before noon for same-day scheduling. We cover ZIP codes 92373 and 92374 without a trip surcharge.`
  },
  {
    question: 'Can you repair older appliances in Redlands historic homes?',
    answer: "Yes, and it's one of the things that sets us apart from most IE appliance companies. Redlands has some of the oldest housing stock in San Bernardino County — Victorian and Craftsman homes in Smiley Heights and near Downtown that date to the 1890s through 1930s. The appliances in these homes range from 15-year-old replacements to original vintage units. If the machine is mechanically sound and parts are available, we quote the repair honestly. A 25-year-old Whirlpool or GE that a family has maintained well is often worth keeping — simpler mechanics, no control boards to fail."
  },
  {
    question: 'Do you service rental properties and student housing near University of Redlands?',
    answer: 'Yes. The University of Redlands generates significant rental demand in the surrounding neighborhoods, and we work with landlords and property managers throughout the university area. A broken washer or refrigerator in an occupied rental needs same-day attention — we coordinate with both landlords and tenants and aim to close every rental call the day we open it.'
  },
  {
    question: 'What brands do you repair in Redlands?',
    answer: 'All major brands. Historic Redlands homes tend to have older GE, Whirlpool, and Maytag. Mid-century and 1980s–1990s homes run updated mid-range appliances. Smiley Heights estates and larger historic properties sometimes have Sub-Zero, Wolf, or Thermador. East Redlands and newer developments run Samsung, LG, and KitchenAid. We carry OEM parts across all generations.'
  },
  {
    question: 'What is your diagnostic fee?',
    answer: '$89, applied directly to the repair cost when you proceed. No hidden trip charge to Redlands. We quote on-site after diagnosis — what we quote is what appears on the invoice.'
  },
  {
    question: 'Does living near the San Bernardino Mountains affect my appliances?',
    answer: 'Yes, in two ways. First, Redlands sits at the base of the San Bernardino Mountains, and canyon winds carry fine particulate from the mountain faces — similar to Upland near the San Gabriels. Condenser coils on refrigerators in hillside neighborhoods like Smiley Heights clog faster than average. Second, during wildfire season, ash and smoke particles circulate through the region and can accelerate coil loading. After major fire events in the San Bernardino Mountains, we recommend condenser cleaning for refrigerators in Redlands even if they were recently serviced.'
  },
  {
    question: 'Is it worth repairing a 15-year-old appliance in a historic Redlands home?',
    answer: 'Usually yes for mechanically sound machines. A $140 repair on a 15-year-old Whirlpool washer with a failed drive belt — if the motor and transmission are solid — is almost always better economics than a $700–$900 replacement. The calculus changes when the compressor on a refrigerator is failing at 15+ years in a hot climate, where repair cost versus expected remaining lifespan stops making sense. We give you honest numbers after diagnosis.'
  }
];

const nearbyCities = [
  { name: 'Loma Linda', slug: 'loma-linda' },
  { name: 'San Bernardino', slug: 'san-bernardino' },
  { name: 'Fontana', slug: 'fontana' },
  { name: 'Rancho Cucamonga', slug: 'rancho-cucamonga' },
  { name: 'Riverside', slug: 'riverside' },
  { name: 'Corona', slug: 'corona' }
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair"
    headlineCity="Redlands"
    subheadline="Same-day service in Smiley Heights, Downtown, University area, North and South Redlands, and East Redlands. Historic homes to new builds. All brands, OEM parts."
    zips={zips}
    tier={3}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance Repair in Redlands — The Jewel of the Inland Empire Has Unique Needs"
    paragraphs={introParagraphs}
    bookingTitle="Redlands"
    bookingSub="Same-Day Service"
  />

  <ServicesGrid
    cityName={cityName}
    headline="What We Repair in Redlands"
    services={services}
  />

  <CustomNarrative
    headline={housingNarrative.headline}
    subSections={housingNarrative.subSections}
    background="white"
  />

  <ServiceArea
    cityName={cityName}
    headline="Neighborhoods We Service in Redlands"
    subheadline="We cover all of Redlands — Smiley Heights, Downtown, the University area, East Redlands, and everything between. No travel surcharge to any address in 92373 or 92374."
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={[]}
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Repairs in Redlands"
    jobs={recentJobs}
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="Why Redlands Residents Call Us"
    reasons={whyReasons}
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What Redlands Customers Are Saying"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Typical Repair Pricing in Redlands"
    subhead="Every repair is quoted on-site after diagnosis. The $89 diagnostic is applied when you proceed."
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="Redlands Appliance Repair — FAQ"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby Cities"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Need Appliance Repair in Redlands Today?"
    body="Same-day service in Smiley Heights, Downtown, the University area, East Redlands, and all Redlands ZIP codes. Historic homes welcome."
  />
</CityLayoutV2>
