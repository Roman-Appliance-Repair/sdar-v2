---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import CustomNarrative from '../components/cities/v2/CustomNarrative.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

const citySlug = 'silver-lake';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = 'Silver Lake';
const zips = ['90026', '90039'];

const phoneRaw = `+1${branch.phone.replace(/\D/g, '')}`;

const title = `Appliance Repair Silver Lake CA — Same Day Service`;
const description = `Same-day appliance repair in Silver Lake, CA 90026 & 90039. Stackable units, vintage ranges, compact apartments. Licensed, OEM parts.`;
const canonical = 'https://samedayappliance.repair/silver-lake/';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { '@type': 'Neighborhood', name: 'Silver Lake' },
    { '@type': 'Neighborhood', name: 'Sunset Junction' },
    { '@type': 'Neighborhood', name: 'Ivanhoe' }
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$',
  license: 'BHGS #A49573'

};

const introParagraphs = [
  "Silver Lake calls look different from other parts of our territory. The hillside homes off Effie Street and Micheltorena have stackable laundry units tucked into closets that were never designed to be laundry rooms. The mid-century bungalows around the Reservoir still have vintage ranges that a lot of repair companies won't touch. The apartment buildings along Glendale Blvd and Hyperion have a dozen units each, and when the washer in apartment 4 goes down, it's the landlord's problem on a Saturday.",
  "Our technicians know this neighborhood. We've worked on the compact LG front-loads in the apartments off Rowena, the older O'Keefe & Merritt ranges in the Streamline Moderne houses near the Reservoir, the Bosch dishwashers in the renovated craftsmans around Sunset Junction. We don't show up and make it someone else's problem when the kitchen is tight or the appliance is older. We diagnose it and fix it.",
  "One more thing about Silver Lake: a significant chunk of the housing is rental. We work with renters, landlords, and property managers equally — whoever needs to call, whoever needs to approve the repair. No runaround about who's the customer.",
  "Diagnostic fee: <strong>$89</strong> — waived with repair. Written estimate before we start. <strong>90-day warranty</strong> on parts and labor."
];

const services = [
  { icon: '🫧', name: 'Washer Repair', slug: 'washer', issues: 'Stackable units · Compact front-load · Not draining · Error codes · Tight spaces', brands: 'LG · Samsung · Bosch · Miele · Whirlpool · Speed Queen' },
  { icon: '♨️', name: 'Dryer Repair', slug: 'dryer', issues: 'Not heating · Stackable · Vent cleaning · Gas & electric · Compact', brands: 'LG · Samsung · GE · Maytag · Whirlpool · Electrolux' },
  { icon: '🧊', name: 'Refrigerator Repair', slug: 'refrigerator', issues: 'Not cooling · Ice maker · Fan motor · Older models welcome', brands: 'Samsung · LG · GE · Whirlpool · Bosch · Sub-Zero' },
  { icon: '🔥', name: 'Oven, Stove & Vintage Range Repair', slug: 'oven', issues: "Vintage ranges welcome · Igniter · Gas valve · Not heating · O'Keefe & Merritt", brands: "GE · Samsung · Bosch · Wolf · Vintage brands · O'Keefe & Merritt" },
  { icon: '🍽️', name: 'Dishwasher Repair', slug: 'dishwasher', issues: 'Not draining · Not cleaning · Leaking · Error codes · Small kitchens', brands: 'Bosch · KitchenAid · Samsung · LG · GE · Miele' },
  { icon: '❄️', name: 'Freezer Repair', slug: 'freezer', issues: 'Not freezing · Temperature off · Ice maker · Frost buildup', brands: 'Samsung · LG · GE · Whirlpool · Sub-Zero' },
  { icon: '🔆', name: 'Cooktop Repair', slug: 'cooktop', issues: 'Burner issues · Induction · Gas igniter · Older cooktops', brands: 'GE · Bosch · Samsung · Thermador · Wolf · Viking' },
  { icon: '🍷', name: 'Wine & Beverage Cooler', slug: 'wine-cooler', issues: 'Not cooling · Temperature off · Compact under-counter units', brands: 'Sub-Zero · True · Liebherr · U-Line · Dacor' }
];

const housingNarrative = {
  eyebrow: 'SILVER LAKE HOUSING REALITY',
  headline: 'The Appliances We Actually Work On Here',
  paragraphs: [
    "Silver Lake isn't a luxury appliance market — it's a real neighborhood with a wide range of housing ages, layouts, and situations. Understanding that context changes how we show up."
  ],
  subSections: [
    {
      title: 'Mid-Century Homes',
      paragraphs: [
        "The Streamline Moderne and California Ranch homes near the Reservoir often have older appliances — vintage ranges that still work but need specific parts, older refrigerator compressors, and infrastructure that a newer technician won't know how to read. We work on older machines honestly."
      ]
    },
    {
      title: 'Apartments & Rentals',
      paragraphs: [
        'Silver Lake is heavily rented. The buildings along Glendale Blvd and Hyperion have compact kitchens and stacked laundry closets. We coordinate with landlords and property managers, come prepared for tight spaces, and don\'t tell renters we "can\'t access" because the closet is small.'
      ]
    },
    {
      title: 'Renovated Craftsmans & New Builds',
      paragraphs: [
        'The renovated homes around Sunset Junction and the newer infill construction on the hillsides have modern Bosch, Samsung, and LG appliances. Same-day service, OEM parts — the standard approach for these newer systems.'
      ]
    }
  ]
};

const neighborhoods = [
  { name: 'Sunset Junction', zip: '90026', featured: true },
  { name: 'Ivanhoe', zip: '90026', featured: true },
  { name: 'Micheltorena Hill', zip: '90026', featured: true },
  { name: 'Moreno Highlands', zip: '90039' },
  { name: 'Silver Lake Reservoir area', zip: '90039' },
  { name: 'Effie Street corridor', zip: '90026' }
];

const keyStreets = ['Glendale Blvd', 'Hyperion Ave', 'Rowena Ave', 'Silver Lake Blvd', 'Sunset Blvd (east)'];

const recentJobs = [
  {
    appliance: 'LG Stackable Washer',
    location: 'Effie Street area, 90026',
    quote: 'UE error, shaking the whole wall',
    description: 'Second-floor apartment, stacked LG unit in a closet with about six inches of clearance on three sides. UE (unbalanced) errors that consistent mean worn shock absorbers. Our tech worked within the closet constraints — correct disassembly sequence for the tight space — replaced both shock absorbers with OEM LG parts, recalibrated the drum, ran four test cycles. Neighbor downstairs had started lodging complaints about the shaking. Problem solved.',
    outcome: '✓ Same day · OEM LG parts · Tight space handled cleanly'
  },
  {
    appliance: "Vintage O'Keefe & Merritt Range",
    location: 'Silver Lake Reservoir area, 90039',
    quote: "Two burners won't light, oven pilot keeps going out",
    description: "1950s O'Keefe & Merritt — the original range still in the original kitchen. These are not uncommon in Silver Lake's older housing stock and almost nobody will work on them. Our tech diagnosed corroded igniter contacts on the surface burners, cleaned and restored the connections, and adjusted the standing pilot in the oven that had shifted from vibration over decades. All burners lit, oven held temperature. Homeowner was emphatic about keeping the original range. We were too.",
    outcome: '✓ Same day · Vintage range restored · No replacement needed'
  },
  {
    appliance: 'Bosch Dishwasher',
    location: 'Sunset Junction, 90026',
    quote: 'E24 error, rental unit — tenant calling landlord daily',
    description: 'Property manager called for a rental unit near Sunset Junction. Bosch E24 — drainage fault. Found a blocked drain hose at the disposal knockout (prior tenant had replaced the disposal but forgot to punch the plug). Cleared it, tested the drain pump which was still functional, ran three cycles. Took 35 minutes. Sent the property manager a photo report. The tenant stopped calling.',
    outcome: '✓ Same day · Fixed in 35 min · Photo report to landlord'
  },
  {
    appliance: 'Samsung Refrigerator',
    location: 'Micheltorena Hill, 90026',
    quote: 'Top of fridge warm, freezer fine, ice maker dead',
    description: 'Samsung French door on Micheltorena — the hillside access made the driveway interesting but the repair itself was straightforward. Classic Samsung dual evaporator failure: upper fan motor seized, ice maker inlet valve clogged. Replaced both with OEM Samsung parts, cleared the drain, defrosted the upper coils. Confirmed even temperature throughout before leaving. The homeowner had a dinner party that weekend — they made it.',
    outcome: '✓ Same day · OEM Samsung · Dinner party saved'
  }
];

const whyReasons = [
  {
    iconKey: 'parts' as const,
    title: 'We Work on Older Appliances',
    body: "Vintage O'Keefe & Merritt ranges, older Frigidaires, pre-digital appliances — Silver Lake has them and most companies won't touch them. We assess each one honestly and repair what's repairable."
  },
  {
    iconKey: 'team' as const,
    title: 'Tight Spaces Are Normal',
    body: "Stacked laundry in a closet, dishwasher in a galley kitchen, refrigerator behind a door that barely opens — our technicians work in these setups constantly. We don't charge extra for access difficulty."
  },
  {
    iconKey: 'clock' as const,
    title: 'Renters, Landlords, Both',
    body: 'We work with whoever needs to schedule and approve the repair. Renter calls, landlord pays — fine. Property manager coordinates access — fine. We send photo reports when requested.'
  },
  {
    iconKey: 'shield' as const,
    title: '90-Day Warranty, $89 Diagnostic',
    body: 'Every repair backed by 90 days on parts and labor. OEM parts only. $89 diagnostic fee waived when you proceed with the repair. California licensed, BBB A+ rated.'
  }
];

const testimonials = [
  {
    stars: 5,
    text: '"My LG stackable in a tiny closet on Effie Street was shaking the wall. Same Day Appliance came out, worked within the tight space no problem, replaced the shock absorbers, and the machine runs quietly now. They clearly know how to work in Silver Lake apartments."',
    author: '— Jamie R., Effie Street, Silver Lake'
  },
  {
    stars: 5,
    text: `"I have a vintage O'Keefe & Merritt range from the 1950s and nobody would work on it. Same Day Appliance Repair came out same day, knew exactly what to do, fixed the burners and the pilot. The range is perfect now. Really glad someone still knows how to service these."`,
    author: '— Marcus T., Reservoir area, Silver Lake'
  },
  {
    stars: 5,
    text: '"I manage several rentals in Silver Lake. Called about a Bosch dishwasher with an E24 error. Tech came same afternoon, fixed it in under an hour, sent me a photo report for my files. This is exactly the kind of responsive property management service I need. Already saved their number."',
    author: '— Diana K., Property Manager, Silver Lake'
  }
];

const pricingTiers = [
  { appliance: 'Refrigerator', range: '$200 – $400', note: 'Fan motor, ice maker, thermostat, compressor relay' },
  { appliance: 'Washer / Dryer', range: '$150 – $350', note: 'Drain pump, shock absorbers, heating element, gasket' },
  { appliance: 'Oven / Range', range: '$175 – $400', note: 'Igniter, element, pilot, gas valve · Vintage OK' },
  { appliance: 'Dishwasher', range: '$150 – $320', note: 'Drain pump, door latch, control board, spray arm' },
  { appliance: 'Stackable Units', range: '$150 – $350', note: 'Compact & stackable — no extra access charge' },
  { appliance: 'Diagnostic Fee', range: '$89', note: 'Waived when you proceed with the repair', featured: true }
];

const faqs = [
  {
    question: 'Do you offer same-day appliance repair in Silver Lake, CA?',
    answer: 'Yes. Our technicians cover all of Silver Lake — Sunset Junction, Ivanhoe, Micheltorena Hill, Moreno Highlands, the Reservoir area, and surrounding streets including Glendale Blvd, Hyperion Ave, Rowena Ave, and Effie Street. We serve ZIP codes 90026 and 90039. Call before noon for same-day afternoon service.'
  },
  {
    question: 'Do you repair stackable and compact washers and dryers in Silver Lake?',
    answer: 'Yes. Silver Lake has a high concentration of apartments and hillside homes with compact and stackable laundry setups. Our technicians are experienced with stackable units, all-in-one combo washers/dryers, and compact front-load machines in tight laundry closets — without damaging surrounding cabinetry or flooring.'
  },
  {
    question: 'Do you repair vintage and older appliances in Silver Lake?',
    answer: "Yes. Silver Lake's mid-century housing stock means we regularly work on older appliances — vintage ranges, older refrigerators, and appliances that most companies won't touch because parts are harder to find. Our technicians assess each repair honestly: if a part is available and the repair makes economic sense, we do it. If not, we'll tell you."
  },
  {
    question: 'Do you work in rental apartments in Silver Lake?',
    answer: "Yes. A large portion of Silver Lake is rental housing. We work with renters, landlords, and property managers — whoever needs to schedule and approve the repair. No hassle about who's paying upfront. Call us and we'll figure out the logistics."
  },
  {
    question: 'What is your diagnostic fee in Silver Lake?',
    answer: "Our diagnostic fee is $89, waived when you proceed with the repair. We give you a complete written estimate before starting any work. Most Silver Lake repairs run $150–$350 depending on the appliance and what's wrong."
  },
  {
    question: 'What warranty do you offer on appliance repairs in Silver Lake?',
    answer: 'All repairs come with a 90-day warranty on parts and labor. If the same issue returns within 90 days, we come back at no charge. We use genuine OEM parts only.'
  },
  {
    question: 'Do you also serve Echo Park, Atwater Village, and Los Feliz?',
    answer: "Yes. Our Silver Lake service area extends to Echo Park, Atwater Village, Los Feliz, Glassell Park, Highland Park, and East Hollywood. If you're in the 90026, 90039, or adjacent ZIP codes, we're your closest team."
  }
];

const nearbyCities = [
  { name: 'Los Feliz', slug: 'los-feliz' },
  { name: 'Hollywood', slug: 'hollywood' },
  { name: 'West Hollywood', slug: 'west-hollywood' },
  { name: 'Glendale', slug: 'glendale' },
  { name: 'Los Angeles', slug: 'los-angeles' },
  { name: 'Burbank', slug: 'burbank' },
  { name: 'Pasadena', slug: 'pasadena' },
  { name: 'Atwater Village', slug: 'atwater-village' }
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair"
    headlineCity="Silver Lake, CA"
    subheadline="Silver Lake's mix of hillside homes, mid-century bungalows, and apartment buildings means compact stackables, vintage ranges, and everything in between. Our technicians cover all of it — 90026 and 90039, same-day, honest pricing, 90-day warranty."
    zips={zips}
    tier={3}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance Repair in Silver Lake — What Actually Shows Up Here"
    paragraphs={introParagraphs}
    bookingTitle="Silver Lake Service Team"
    bookingSub="90026 · 90039 · Same day"
  />

  <ServicesGrid
    cityName={cityName}
    headline="What We Repair in Silver Lake"
    subhead="Stackable, compact, vintage, modern — all of it · 90026 & 90039"
    services={services}
  />

  <ServiceArea
    cityName={cityName}
    headline="All of Silver Lake — 90026 & 90039"
    subheadline="From the Reservoir to Sunset Junction — every street and hillside"
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={keyStreets}
  />

  <CustomNarrative
    eyebrow={housingNarrative.eyebrow}
    headline={housingNarrative.headline}
    paragraphs={housingNarrative.paragraphs}
    subSections={housingNarrative.subSections}
    background="black"
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Jobs Our Team Did in Silver Lake"
    subhead="Real calls from real streets. All three types of Silver Lake housing."
    jobs={recentJobs}
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="Why Silver Lake Calls Us Back"
    reasons={whyReasons}
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What Silver Lake Customers Are Saying"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Appliance Repair Costs in Silver Lake"
    subhead="Written estimate before we start. $89 diagnostic — waived with repair."
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="Questions Silver Lake Customers Ask"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby Areas"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance broken in Silver Lake?"
    body="Stackable · Vintage · Compact apartment · All of 90026 & 90039. $89 diagnostic waived with repair. 90-day warranty. Renters & landlords welcome."
  />
</CityLayoutV2>
