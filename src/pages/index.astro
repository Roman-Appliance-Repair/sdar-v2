---
// src/pages/index.astro — Homepage
//
// Sprint 2026-04-26: Full luxury homepage rebuild.
// Section components in src/components/homepage/ are scaffolds (Step 3) — real
// content fills in during Steps 4–6. CountyMap is already implemented (Step 2).

import Layout from '../layouts/Layout.astro';
import HomepageSchema from '../components/homepage/HomepageSchema.astro';
import Hero from '../components/homepage/Hero.astro';
import Diagnostics from '../components/homepage/Diagnostics.astro';
import Services from '../components/homepage/Services.astro';
import ServiceArea from '../components/homepage/ServiceArea.astro';
import Credentials from '../components/homepage/Credentials.astro';
import Reviews from '../components/homepage/Reviews.astro';
import Pricing from '../components/homepage/Pricing.astro';
import FAQ from '../components/homepage/FAQ.astro';
// HomepageFooter is intentionally NOT imported here — Layout.astro provides the
// standard <Footer />. Step 6 decides whether to swap in HomepageFooter.

const title = 'Same Day Appliance Repair — Los Angeles & Southern California';
const description =
  'Same-day appliance repair across 5 SoCal counties. Headquartered in West Hollywood. Licensed C-20, BBB A+, EPA 608. 90-day warranty on parts and labor.';
---

<Layout title={title} description={description}>
  <HomepageSchema slot="head-scripts" />
  <Hero />
  <Diagnostics />
  <Services />
  <ServiceArea />
  <Credentials />
  <Reviews />
  <Pricing />
  <FAQ />
</Layout>
