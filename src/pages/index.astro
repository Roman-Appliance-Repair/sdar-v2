---
import Layout from '../layouts/Layout.astro';
import AiDiagnostic from '../components/AiDiagnostic.astro';
---

<Layout
  title="Same Day Appliance Repair — Los Angeles, Orange, Ventura County"
  description="Licensed C-20 appliance & HVAC repair across SoCal. BBB A+, fully insured. $89 diagnostic waived with repair. Same-day service, 7 days a week (phone 24/7)."
>
  <!-- HERO (black) -->
  <section class="section section-black hero">
    <div class="container">
      <p class="eyebrow">Layout skeleton · swap with real homepage next</p>
      <h1>Same-day repair that actually shows up the same day.</h1>
      <p class="lede">
        Licensed C-20 technicians across Los Angeles, Orange County, and Ventura County.
        $89 diagnostic — waived with repair. BBB A+ accredited.
      </p>
      <div class="hero-cta">
        <a href="tel:+13238704790" class="btn btn-red">Call (323) 870-4790</a>
        <a href="#ai-diagnostic" class="btn btn-outline" style="border-color: var(--white); color: var(--white);">Try AI Diagnosis ↓</a>
      </div>
    </div>
  </section>

  <!-- Intro (white) — placeholder -->
  <section class="section">
    <div class="container" style="max-width: 820px;">
      <h2>Placeholder: Intro section</h2>
      <p>
        This is where the real Luxury Editorial intro copy lives — "we walk into
        1,200 kitchens a year across SoCal…" — to be written in the next pass.
      </p>
    </div>
  </section>

  <!-- Services grid (gray) — placeholder -->
  <section class="section section-gray">
    <div class="container" style="max-width: 820px;">
      <h2>Placeholder: Services grid</h2>
      <p>Services overview with 6 tiles (Refrigerator, Washer, Dryer, Oven, Dishwasher, HVAC).</p>
    </div>
  </section>

  <!-- Context (black) — placeholder -->
  <section class="section section-black">
    <div class="container" style="max-width: 820px;">
      <h2>Placeholder: Service area context</h2>
      <p>Neighborhood-level copy with specific street names, building types, local context.</p>
    </div>
  </section>

  <!-- Neighborhoods (white) — placeholder -->
  <section class="section">
    <div class="container" style="max-width: 820px;">
      <h2>Placeholder: Neighborhood list</h2>
      <p>Links to top 15 neighborhood pages across LA/OC/Ventura.</p>
    </div>
  </section>

  <!-- ===== SPECIAL BLOCK: AI Diagnostic ===== -->
  <AiDiagnostic />

  <!-- Recent Repairs (white) — placeholder -->
  <section class="section">
    <div class="container" style="max-width: 820px;">
      <h2>Placeholder: Recent Repairs</h2>
      <p>5-6 case studies in the client-voice headline style.</p>
    </div>
  </section>

  <!-- Why Us (gray) — placeholder -->
  <section class="section section-gray">
    <div class="container" style="max-width: 820px;">
      <h2>Placeholder: Why Us</h2>
    </div>
  </section>

  <!-- Reviews (white) — placeholder -->
  <section class="section">
    <div class="container" style="max-width: 820px;">
      <h2>Placeholder: Reviews</h2>
    </div>
  </section>

  <!-- Pricing (gray) — placeholder -->
  <section class="section section-gray">
    <div class="container" style="max-width: 820px;">
      <h2>Placeholder: Pricing table</h2>
    </div>
  </section>

  <!-- FAQ (white) — placeholder -->
  <section class="section">
    <div class="container" style="max-width: 820px;">
      <h2>Placeholder: FAQ</h2>
    </div>
  </section>

  <!-- Bottom CTA (black) -->
  <section class="section section-black">
    <div class="container" style="max-width: 820px; text-align: center;">
      <h2>Call now or book online — dispatcher 24/7</h2>
      <p style="color: rgba(255,255,255,0.72); margin-bottom: 28px;">
        Tech answers your call in under 30 seconds.
      </p>
      <a href="tel:+13238704790" class="btn btn-red" style="padding: 18px 36px; font-size: 17px;">Call (323) 870-4790</a>
    </div>
  </section>

  <style>
    .hero { padding: clamp(80px, 12vw, 160px) 0; }
    .eyebrow {
      font-size: 12px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.18em;
      color: var(--red);
      margin-bottom: 24px;
    }
    .hero h1 { max-width: 900px; margin-bottom: 24px; }
    .lede {
      font-size: clamp(17px, 2vw, 20px);
      line-height: 1.6;
      color: rgba(255,255,255,0.85);
      max-width: 680px;
      margin-bottom: 36px;
    }
    .hero-cta { display: flex; gap: 14px; flex-wrap: wrap; }
  </style>
</Layout>
