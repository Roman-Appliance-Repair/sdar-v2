---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import CustomNarrative from '../components/cities/v2/CustomNarrative.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

const citySlug = 'santa-monica';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = 'Santa Monica';
const zips = ['90401', '90402', '90403', '90404', '90405'];

const phoneRaw = `+1${branch.phone.replace(/\D/g, '')}`;

const title = `Appliance Repair Santa Monica CA — Same Day Service | ${branch.phone}`;
const description = `Same-day appliance repair in Santa Monica, CA. Our technicians serve North of Montana, Ocean Park, Pico, Sunset Park. Refrigerator, washer, dryer, oven. Licensed, OEM parts, 90-day warranty. Call ${branch.phone}.`;
const canonical = 'https://samedayappliance.repair/santa-monica/';

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'HomeAndConstructionBusiness',
  name: branch.fullName,
  image: 'https://samedayappliance.repair/images/logo.webp',
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { '@type': 'City', name: 'Santa Monica', sameAs: 'https://en.wikipedia.org/wiki/Santa_Monica,_California' },
    { '@type': 'City', name: 'Venice' },
    { '@type': 'City', name: 'Culver City' },
    { '@type': 'City', name: 'Brentwood' },
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: '$$',
  license: 'CA BHGS #A49573'

};

const introParagraphs = [
  "Santa Monica is one of the more interesting cities we work in. The housing stock runs the full range — brand-new luxury condos on Ocean Avenue where the kitchens have Sub-Zero and Wolf, craftsman homes north of Montana with appliances that have been running for 15 years and just need someone who knows how to work on them, smaller apartments in Ocean Park and Pico where every dollar of the repair matters. Our technicians cover all of it, and we show up with parts for all of it.",
  "One thing Santa Monica has that most of LA doesn't — salt air. It comes off the ocean and it's relentless on metal components. We see condenser coil corrosion on refrigerators that are only 5–6 years old, dishwasher door gaskets that fail faster than they should, and rust on dryer components that wouldn't show up in Pasadena until the appliance was twice as old. When you call us for same day appliance repair Santa Monica, our technicians factor in the coastal environment and check for those failure patterns proactively.",
  "Diagnostic fee is <strong>$89</strong> — gone when you go ahead with the repair. Full written estimate before we start anything. <strong>90-day warranty</strong> on parts and labor when we finish.",
  "<strong>Coastal appliance tip from our techs:</strong> If you live within a mile of the ocean in Santa Monica, pull your refrigerator out and inspect the condenser coils every 4–6 months — not 12. Salt air deposits on coils twice as fast as in inland LA. Clean coils, vacuum around the compressor area, and check the door gasket seal. These three things extend appliance life significantly in a coastal climate.",
];

const services = [
  { icon: '🧊', name: 'Refrigerator Repair', slug: 'refrigerator', issues: 'Not cooling · Leaking · Ice maker broken · Coil corrosion · Salt air damage', brands: 'Sub-Zero · Samsung · LG · GE · Whirlpool · Wolf' },
  { icon: '🫧', name: 'Washer Repair', slug: 'washer', issues: 'Not spinning · Not draining · Agitation issues · Vibration · Front & top-load', brands: 'LG · Samsung · Whirlpool · Maytag · Bosch · Miele' },
  { icon: '♨️', name: 'Dryer Repair', slug: 'dryer', issues: 'Not heating · Vent issues · Drum not spinning · Dryer vent cleaning', brands: 'LG · Samsung · GE · Maytag · Whirlpool · Electrolux' },
  { icon: '🔥', name: 'Oven, Stove & Range Repair', slug: 'oven', issues: 'Not heating · Igniter issues · Relay problems · Gas & electric', brands: 'Viking · Thermador · Wolf · GE · Bosch · Dacor' },
  { icon: '🍽️', name: 'Dishwasher Repair', slug: 'dishwasher', issues: 'Not draining · Cloudy glassware · Float switch · Pump assembly · Gasket', brands: 'Bosch · Miele · KitchenAid · Samsung · LG · GE' },
  { icon: '🍷', name: 'Wine Cooler Repair', slug: 'wine-cooler', issues: 'Not cooling · Temperature swings · Compressor issues · Coastal corrosion', brands: 'Sub-Zero · Monogram · EuroCave · Liebherr · Thermador' },
  { icon: '💨', name: 'Range Hood Repair', slug: 'range-hood', issues: 'Fan not working · Lights out · Control panel · Under-cabinet & island hoods', brands: 'Broan · Zephyr · Wolf · Viking · KitchenAid · Thermador' },
  { icon: '❄️', name: 'Freezer & Ice Maker Repair', slug: 'freezer', issues: 'Not freezing · Ice maker not working · Temperature off · Frost buildup', brands: 'Sub-Zero · GE · Samsung · LG · Whirlpool · Frigidaire' },
];

const coastalNarrative = {
  eyebrow: 'COASTAL CLIMATE & APPLIANCES',
  headline: 'Living Next to the Ocean Does Things to Your Appliances',
  paragraphs: [
    "Most appliance repair companies in LA treat Santa Monica like any other suburb. Our technicians don't. Salt air from the Pacific — especially in homes west of Lincoln Boulevard and on Ocean Park's beachfront — corrodes metal components differently than inland conditions. Condenser coils rust faster. Door gaskets on dishwashers and refrigerators crack sooner. Control board connections oxidize. We factor this into every diagnostic we run in Santa Monica.",
    "The homes north of Montana Ave are a different story — larger properties, luxury appliances, Sub-Zero refrigerators, Wolf ranges, Thermador cooktops. Our technicians are trained on these brands and carry OEM parts for them. Meanwhile in Ocean Park and Pico, it's a mix of older stock and newer condos — Whirlpool, Samsung, LG, Bosch — and we carry parts for those too.",
    "One practical thing we do on every Santa Monica refrigerator call that we don't always do further inland: we check the condenser coil condition as part of the standard diagnostic. Salt-accelerated buildup is common enough here that it's worth looking at every time, even if coil corrosion isn't the presenting symptom.",
  ]
};

const repairOrReplaceNarrative = {
  eyebrow: 'HONEST ADVICE',
  headline: 'Should You Repair or Replace Your Appliance?',
  paragraphs: [
    "Our technicians get asked this on almost every call in Santa Monica. Here's how we actually think about it — not as a script, but as people who've seen thousands of appliances at every stage of life.",
    "The simple version: if the repair costs less than 50% of a new unit and the appliance is under 10 years old, repairing is almost always the better call financially. A $250 drain pump on a 6-year-old dishwasher is a no-brainer. A $600 compressor on a 14-year-old refrigerator is a harder conversation.",
    "For Santa Monica specifically, coastal climate accelerates wear on some components — which means some appliances here age faster than the national averages suggest. Our technicians factor that in when they give you a recommendation. If the same part is likely to fail again in 18 months because of where you live, we'll tell you that rather than take your money.",
    "<strong>Appliance lifespan averages:</strong> Dishwasher ~10 years · Washer ~11 years · Dryer ~13 years · Refrigerator ~14 years · Gas Range ~15 years · Electric Oven ~15 years.",
    "Coastal climate note: in Santa Monica, refrigerators and dishwashers near the ocean often show major component wear 2–3 years earlier than these national averages.",
  ]
};

const neighborhoods = [
  { name: 'North of Montana', zip: '90402', featured: true },
  { name: 'Ocean Park', zip: '90405', featured: true },
  { name: 'Pico Neighborhood', zip: '90405', featured: true },
  { name: 'Sunset Park', zip: '90405' },
  { name: 'Mid-City Santa Monica', zip: '90403' },
  { name: 'Downtown Santa Monica', zip: '90401' },
  { name: 'Wilshire-Montana', zip: '90403' },
  { name: 'Beachfront / Ocean Ave', zip: '90401' },
];

const keyStreets = ['Montana Ave', 'Santa Monica Blvd', 'Lincoln Blvd', 'Pico Blvd'];

const recentJobs = [
  {
    appliance: 'Sub-Zero Refrigerator',
    location: 'North of Montana, 90402',
    quote: 'Not holding temperature, running all the time',
    description: "Called it before we even pulled the unit: condenser coil corrosion from salt air. The coils were so coated they'd basically stopped dissipating heat — the compressor was running continuously and overheating. Our tech cleaned the coils thoroughly, replaced a corroded capacitor relay that had started to fail, and checked the door gaskets which were also showing salt-accelerated wear. Advised the homeowner on a 4-month cleaning schedule for homes this close to the water. Back to temperature within 2 hours.",
    outcome: '✓ Same day · Coil cleaning + relay replaced · Coastal maintenance plan'
  },
  {
    appliance: 'Bosch Dishwasher',
    location: 'Ocean Park, 90405',
    quote: 'Dishes coming out cloudy and the machine smells bad',
    description: "Cloudy glassware plus odor usually means one of two things: a failing pump assembly or a blocked filter that's been sitting. In this case — both. The filter trap had months of buildup, and the impeller on the pump was worn down enough to not fully circulate the water. Cleaned and replaced, ran a maintenance cycle, showed the tenant how to clean the filter monthly. The landlord had apparently never mentioned it was a thing that needed doing.",
    outcome: '✓ Same day · Pump assembly replaced · OEM Bosch part'
  },
  {
    appliance: 'LG Washer',
    location: 'Pico Neighborhood, 90405',
    quote: 'UE error and shaking the whole apartment',
    description: 'LG front-load in a second-floor apartment — when it goes off-balance, the whole unit shakes. UE (unbalanced) errors can be a load issue, but when it happens consistently it usually means worn shock absorbers. Replaced both absorbers with OEM LG parts, recalibrated the drum, and ran three test cycles. The downstairs neighbors, apparently, were relieved.',
    outcome: '✓ Same day · OEM LG shock absorbers · Three test cycles'
  },
  {
    appliance: 'Wolf Range',
    location: 'Sunset Park, 90405',
    quote: 'Oven not getting up to temperature, two burners not lighting',
    description: 'Wolf dual-fuel — oven igniter was weak and not drawing enough current to open the gas valve reliably, and two surface burners had failed igniters from normal wear. Replaced the oven igniter and both surface igniters with OEM Wolf parts. Calibrated the oven temperature against a probe thermometer before leaving — it was running 25°F cool even before the igniter failed. Recalibrated to factory spec.',
    outcome: '✓ Same day · OEM Wolf parts · Oven recalibrated'
  },
];

const testimonials = [
  {
    stars: 5,
    text: '"Our Sub-Zero had been running constantly and our electricity bill was through the roof. The technician came to our place north of Montana, diagnosed salt air coil corrosion immediately, cleaned and repaired it, and explained exactly what was happening and how to prevent it. This is the kind of knowledgeable service I was hoping to find."',
    author: '— Claire F., North of Montana, Santa Monica'
  },
  {
    stars: 5,
    text: '"Wolf range in my Sunset Park home — oven not heating right and two burners dead. Called Same Day Appliance Repair, technician came out same afternoon, had all the OEM Wolf parts on his truck, replaced the igniters, recalibrated the oven. Everything works better than it has in years. Honest and professional."',
    author: '— Michael T., Sunset Park, Santa Monica'
  },
  {
    stars: 5,
    text: '"LG washer in our Ocean Park apartment was shaking the entire unit every cycle. Tech diagnosed worn shock absorbers, replaced them with OEM parts, recalibrated the drum. The whole repair took about an hour. No drama, fair price, exactly what was described on the phone."',
    author: '— Anya K., Ocean Park, Santa Monica'
  },
];

const pricingTiers = [
  { appliance: 'Refrigerator', range: '$200 – $450', note: 'Fan motor, coil cleaning, ice maker, compressor relay, gasket' },
  { appliance: 'Washer', range: '$150 – $350', note: 'Drain pump, shock absorbers, control board, door seal' },
  { appliance: 'Dryer', range: '$150 – $320', note: 'Heating element, thermal fuse, drum roller, vent cleaning' },
  { appliance: 'Oven / Range', range: '$175 – $420', note: 'Igniter, bake element, relay, gas valve, calibration' },
  { appliance: 'Dishwasher', range: '$150 – $320', note: 'Pump assembly, float switch, door gasket, solenoid' },
  { appliance: 'Diagnostic Fee', range: '$89', note: 'Waived when you proceed with the repair', featured: true },
];

const faqs = [
  {
    question: 'Do you offer same-day appliance repair in Santa Monica, CA?',
    answer: 'Yes. Our technicians cover all Santa Monica neighborhoods — North of Montana, Ocean Park, Pico, Sunset Park, Mid-City, and the beachfront corridors. Call before noon and we can typically be there the same afternoon. We serve all Santa Monica ZIP codes: 90401, 90402, 90403, 90404, and 90405.'
  },
  {
    question: 'What appliances do you repair in Santa Monica?',
    answer: 'We repair all major home and commercial appliances: refrigerators, washers, dryers, ovens, stoves, ranges, dishwashers, cooktops, freezers, wine coolers, microwaves, range hoods, ice makers, and walk-in coolers. We service all brands — from Samsung and LG to Sub-Zero, Viking, Thermador, Wolf, and Monogram.'
  },
  {
    question: 'Does the coastal climate affect appliances in Santa Monica?',
    answer: 'It absolutely does. Ocean salt air accelerates corrosion on metal components, especially refrigerator coils and dishwasher door gaskets. We see more condenser coil issues, faster gasket wear, and rust-related failures in Santa Monica than in inland areas. Our technicians know what to look for and what preventive steps actually help in a coastal environment.'
  },
  {
    question: 'Do you repair Sub-Zero and Viking appliances in Santa Monica?',
    answer: "Yes. Santa Monica's beachfront condos and homes north of Montana Ave often have high-end appliances — Sub-Zero refrigerators, Wolf ranges, Thermador cooktops, Viking dishwashers. Our technicians are trained on these brands and carry OEM parts for them on every service vehicle."
  },
  {
    question: 'Should I repair or replace my appliance in Santa Monica?',
    answer: "It depends on the appliance's age and the repair cost. Our general guideline: if the repair costs less than 50% of a new unit and the appliance is under 10 years old, repairing usually makes more sense. We'll always give you an honest assessment — if it's not worth fixing, we'll tell you directly rather than take your money on a repair that won't hold."
  },
  {
    question: 'What is your diagnostic fee in Santa Monica?',
    answer: 'Our diagnostic fee is $89, waived when you proceed with the repair. We give you a complete written estimate before starting any work. No hidden fees — the price we quote is the price you pay.'
  },
  {
    question: 'Do you also serve Venice, Culver City, and Brentwood?',
    answer: "Yes. Our Santa Monica service area extends to Venice, Culver City, Brentwood, West LA, Mar Vista, and Marina del Rey. If you're within a few miles of Santa Monica and need a technician, call us — we're likely in the area."
  },
];

const nearbyCities = [
  { name: 'Culver City', slug: 'culver-city' },
  { name: 'Brentwood', slug: 'brentwood' },
  { name: 'West Hollywood', slug: 'west-hollywood' },
  { name: 'Beverly Hills', slug: 'beverly-hills' },
  { name: 'Los Angeles', slug: 'los-angeles' },
  { name: 'Pacific Palisades', slug: 'pacific-palisades' },
  { name: 'Marina Del Rey', slug: 'marina-del-rey' },
  { name: 'Malibu', slug: 'malibu' },
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair"
    headlineCity="Santa Monica, CA"
    subheadline="Our technicians work across all of Santa Monica — the beachfront condos, the homes north of Montana, Ocean Park, Pico, Sunset Park. Same-day service, OEM parts, 90-day warranty. Licensed, insured, honest pricing."
    zips={zips}
    tier={2}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Same Day Appliance Repair in Santa Monica — From Our Technicians"
    paragraphs={introParagraphs}
    bookingTitle="Talk to Our Santa Monica Team"
    bookingSub="Same-day available · 90401–90405"
  />

  <ServicesGrid
    cityName={cityName}
    headline="What We Fix in Santa Monica"
    subhead="All major brands · Gas & electric · Residential & commercial"
    services={services}
  />

  <ServiceArea
    cityName={cityName}
    headline="We Cover All of Santa Monica"
    subheadline="Every neighborhood, every ZIP — from Montana Ave to the beachfront"
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={keyStreets}
  />

  <CustomNarrative
    eyebrow={coastalNarrative.eyebrow}
    headline={coastalNarrative.headline}
    paragraphs={coastalNarrative.paragraphs}
    background="black"
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Jobs Our Technicians Did in Santa Monica"
    subhead="Real calls. Real neighborhoods. What our week in Santa Monica looks like."
    jobs={recentJobs}
  />

  <CustomNarrative
    eyebrow={repairOrReplaceNarrative.eyebrow}
    headline={repairOrReplaceNarrative.headline}
    paragraphs={repairOrReplaceNarrative.paragraphs}
    background="white"
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What Santa Monica Customers Are Saying"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Appliance Repair Costs in Santa Monica"
    subhead="Written estimate before we start. $89 diagnostic — waived with repair."
    tiers={pricingTiers}
    footnote="Sub-Zero, Wolf, Viking, Thermador, Monogram and other luxury brands may cost more due to OEM part pricing. We always quote you in writing before starting."
  />

  <FAQAccordion
    cityName={cityName}
    headline="Questions Santa Monica Customers Ask Us"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby Areas"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance broken in Santa Monica? Call us now."
    body="Our team covers all of Santa Monica and the Westside. Diagnostic $89 waived with repair. 90-day warranty. We pick up the phone."
  />
</CityLayoutV2>
