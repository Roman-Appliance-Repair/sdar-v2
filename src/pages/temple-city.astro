---
import CityLayoutV2 from '../layouts/CityLayoutV2.astro';
import HeroSection from '../components/cities/v2/HeroSection.astro';
import TrustBadgesRow from '../components/cities/v2/TrustBadgesRow.astro';
import IntroNarrative from '../components/cities/v2/IntroNarrative.astro';
import ServicesGrid from '../components/cities/v2/ServicesGrid.astro';
import ServiceArea from '../components/cities/v2/ServiceArea.astro';
import RecentRepairs from '../components/cities/v2/RecentRepairs.astro';
import WhyCallsUsBack from '../components/cities/v2/WhyCallsUsBack.astro';
import ReviewsBlock from '../components/cities/v2/ReviewsBlock.astro';
import PricingCards from '../components/cities/v2/PricingCards.astro';
import FAQAccordion from '../components/cities/v2/FAQAccordion.astro';
import AlsoServingNearby from '../components/cities/v2/AlsoServingNearby.astro';
import FinalCTA from '../components/cities/v2/FinalCTA.astro';
import { CITIES } from '../data/cities';
import { BRANCHES } from '../data/branches';
import { OPENING_HOURS_SCHEMA } from '../data/business-hours';

const citySlug = 'temple-city';
const city = CITIES.find((c) => c.slug === citySlug)!;
const branch = BRANCHES.find((b) => b.slug === city.primaryBranch)!;

const cityName = "Temple City";
const zips = ["91780"];

const phone = branch.phone;
const phoneRaw = `+1${phone.replace(/\D/g, '')}`;

const title = `Appliance Repair Temple City CA 91780 — Same Day | Rosemead Blvd · Live Oak Ave | ${phone}`;
const description = `Same-day appliance repair in Temple City, CA 91780. Live Oak Ave, Rosemead Blvd, Longden Ave, all neighborhoods. Samsung, LG, GE, Whirlpool, all brands. Licensed, OEM parts, 90-day warranty. Weekends available. Call ${phone}.`;
const canonical = "https://samedayappliance.repair/temple-city/";

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "HomeAndConstructionBusiness",
  name: branch.fullName,
  image: "https://samedayappliance.repair/images/logo.webp",
  url: canonical,
  telephone: phoneRaw,
  email: branch.email,
  areaServed: [
    { "@type": "City", name: "Temple City", sameAs: "https://en.wikipedia.org/wiki/Temple_City,_California" },
  ],
  openingHoursSpecification: OPENING_HOURS_SCHEMA,
  priceRange: "$$",
  license: "CA CSLB #1138898"

};

const introParagraphs = [
  "Temple City is one of the quieter, more residential cities in the San Gabriel Valley — predominantly single-family homes, well-maintained, family-oriented. The appliance calls here are straightforward: a refrigerator not cooling on Live Oak Avenue, a dishwasher leaving spots on Longden, a dryer that stopped heating on a Saturday morning before family plans. Nothing complicated about what you need — same-day, done right, no surprises on the invoice.",
  "Hard water is a consistent factor. Temple City is served by the San Gabriel Valley Municipal Water District, drawing from the mineral-rich SGV groundwater basin. Ice maker inlet valves and dishwasher spray arms accumulate scale faster here than in softer-water cities. We test for this on every relevant Temple City call involving ice makers and dishwashers — it's a recurring pattern throughout the SGV, and Temple City is no exception.",
  "Diagnostic fee: <strong>$89</strong> — waived with repair. Written estimate before we start. <strong>90-day warranty</strong> on parts and labor. Available <strong>Saturdays and Sundays</strong>.",
  "<strong>Hard water tip for Temple City:</strong> SGVMWD groundwater accelerates mineral scale on refrigerator ice maker inlet valves and dishwasher spray arms. If your ice output has been declining gradually — not a sudden stop, but a slow decrease over months — the inlet valve is almost certainly the cause. Replacing your refrigerator's in-door filter every 6 months instead of 12 makes a meaningful difference in SGV hard water cities like Temple City.",
];

const services = [
  { icon: '🧊', name: 'Refrigerator Repair', slug: 'refrigerator', issues: 'Hard water ice maker · Not cooling · Fan motor · Temperature off', brands: 'Samsung · LG · GE · Whirlpool · Sub-Zero · Bosch' },
  { icon: '🍽️', name: 'Dishwasher Repair', slug: 'dishwasher', issues: 'Hard water spray arm · Not draining · Spots on glasses · Error codes', brands: 'Bosch · KitchenAid · Samsung · LG · GE · Miele' },
  { icon: '🫧', name: 'Washer Repair', slug: 'washer', issues: 'Hard water inlet screens · Not draining · Not spinning · Error codes', brands: 'LG · Samsung · Whirlpool · Maytag · Bosch · Speed Queen' },
  { icon: '♨️', name: 'Dryer Repair + Vent Cleaning', slug: 'dryer', issues: 'Not heating · Thermal fuse · Vent lint buildup · Gas & electric', brands: 'LG · Samsung · GE · Maytag · Whirlpool · Electrolux' },
  { icon: '🔥', name: 'Oven, Range & Stove', slug: 'oven', issues: 'Not heating · Gas igniter · Temperature off · Gas & electric', brands: 'GE · Samsung · Bosch · Wolf · Viking · KitchenAid' },
  { icon: '❄️', name: 'Freezer & Ice Maker Repair', slug: 'freezer', issues: 'Hard water inlet valve · Not freezing · Ice stopped · Frost', brands: 'Samsung · LG · GE · Whirlpool · Sub-Zero · Frigidaire' },
  { icon: '🍷', name: 'Wine Cooler Repair', slug: 'wine-cooler', issues: 'Temperature off · Compressor · Under-counter · Built-in', brands: 'True · U-Line · Liebherr · Dacor · Sub-Zero' },
  { icon: '🔆', name: 'Cooktop & Range Hood', slug: 'cooktop', issues: 'Igniter · Gas burner · Induction not heating · Hood motor', brands: 'GE · Bosch · Samsung · Wolf · Thermador · Broan' },
];

const neighborhoods = [
  { name: 'Live Oak Ave corridor', zip: '91780', featured: true },
  { name: 'Las Tunas Drive', zip: '91780', featured: true },
  { name: 'Longden Ave neighborhood', zip: '91780', featured: true },
  { name: 'Lower Azusa Rd area', zip: '91780' },
  { name: 'Broadway corridor', zip: '91780' },
  { name: 'North Temple City', zip: '91780' },
  { name: 'South Temple City', zip: '91780' },
];

const keyStreets = ['Live Oak Ave', 'Rosemead Blvd', 'Las Tunas Dr', 'Longden Ave', 'Lower Azusa Rd', 'Broadway'];

const recentJobs = [
  {
    appliance: 'LG Refrigerator',
    location: 'Live Oak Ave, 91780',
    quote: '"Ice maker slowed to almost nothing — maybe 6 cubes a day"',
    description: "LG French door on Live Oak — gradual ice decline over about four months, the consistent SGVMWD hard water pattern. Inlet valve orifice restricted to roughly 15% of normal capacity by mineral scale. Replaced the inlet valve with an OEM LG part, flushed the water line, replaced the in-door filter (16 months old). Full production within 24 hours. Explained the SGV water quality situation and set a 6-month filter calendar reminder. Owner hadn't realized the filter should be changed more than once a year with this water supply.",
    outcome: '✓ Same day · OEM LG inlet valve · SGV water explained · 6-month plan'
  },
  {
    appliance: 'Samsung Dishwasher',
    location: 'Longden Ave, 91780',
    quote: '"White film on glasses, smells a bit musty after cycles"',
    description: "Samsung DW80 — both spray arm ports blocked by SGVMWD mineral deposits, filter trap with significant scale buildup creating the musty odor. Descaled both spray arms completely, deep-cleaned the filter assembly, ran a full citric acid cycle. Showed the homeowner the extracted scale — both were surprised at the amount from just under two years of use. Confirmed full spray arm rotation and clean drain. Monthly maintenance tablet routine explained. Glasses came out clear from the first load.",
    outcome: '✓ Same day · Scale cleared · Odor gone · Maintenance routine set'
  },
  {
    appliance: 'Whirlpool Dryer',
    location: 'Las Tunas corridor, 91780',
    quote: '"No heat at all, clothes come out the same as they went in"',
    description: "Whirlpool electric dryer — thermal fuse blown from a partially obstructed vent run that terminated with a plastic flap vent cap partially folded inward. The cap had been that way for an unknown period — likely years. Replaced the thermal fuse, replaced the compromised plastic vent cap with a proper metal backdraft damper, confirmed strong airflow at the termination. Single-cycle drying from the first test load. Also inspected the heating element — still good, no replacement needed.",
    outcome: '✓ Same day · Thermal fuse · Metal vent cap installed · Single cycle'
  },
  {
    appliance: 'GE Range',
    location: 'Broadway area, 91780',
    quote: '"Oven igniter glowing but not lighting — been three weeks"',
    description: "GE freestanding range — oven igniter glowing orange but not drawing enough current to open the gas valve. This is the standard GE igniter failure mode: the element heats visually but is electrically weak. Standard repair: OEM GE igniter, roughly 25 minutes. Tested at 325°F, 375°F, and 450°F before leaving — accurate at all three. The homeowner had been convinced the issue was the gas valve itself. Explained the igniter amperage requirement — they were relieved it was a simpler fix.",
    outcome: '✓ Same day · OEM GE igniter · All temps confirmed · Cause explained'
  },
];

const whyReasons = [
  {
    iconKey: 'parts' as const,
    title: 'SGVMWD Hard Water',
    body: "San Gabriel Valley Municipal Water District groundwater accelerates mineral scale on ice makers and dishwashers throughout Temple City. We test inlet valves and check for deposits on every relevant call — it comes up regularly in 91780 and across the SGV."
  },
  {
    iconKey: 'clock' as const,
    title: 'Actually Same Day',
    body: 'Call before noon and we\'re typically there that afternoon. Temple City is a regular part of our SGV route from Pasadena — not a special trip. Same-day means same day, not "we\'ll try our best for next-day."'
  },
  {
    iconKey: 'team' as const,
    title: 'Weekends Available',
    body: 'Saturday 8am–7pm and Sunday 9am–5pm. When your appliance breaks before a weekend with family plans, we\'re there. Not every Temple City appliance company offers weekend service — we do.'
  },
  {
    iconKey: 'shield' as const,
    title: '90-Day Warranty, OEM Only',
    body: 'Every repair backed by 90 days on parts and labor. Genuine OEM parts only — never aftermarket. $89 diagnostic waived with repair. Written estimate before we start. California licensed, BBB A+ rated.'
  },
];

const testimonials = [
  {
    stars: 5,
    text: '"LG refrigerator had been barely making ice for months. Tech came to our Live Oak home, found the hard water mineral blockage right away, replaced the inlet valve, and explained the SGV water quality situation — I had no idea the filter needed changing every 6 months here. Full ice production by next morning. Very professional."',
    author: '— Kevin L., Live Oak Ave, Temple City'
  },
  {
    stars: 5,
    text: '"Samsung dishwasher leaving white film and smelling odd. Tech showed me the mineral scale on both spray arms — in less than two years. Cleared everything, gave me a monthly maintenance routine for our water quality. Completely clean and odor-free from the first load. This is the level of service I wanted."',
    author: '— Sandra T., Longden Ave, Temple City'
  },
  {
    stars: 5,
    text: '"GE oven igniter glowing but not lighting for three weeks. Called Same Day, tech came that afternoon, had the OEM GE igniter on the truck, done in 25 minutes. Tested all three temperatures before leaving. Explained why the igniter fails this way — genuinely helpful. Would recommend without any hesitation."',
    author: '— Patricia C., Broadway area, Temple City'
  },
];

const pricingTiers = [
  { appliance: 'Refrigerator / Ice Maker', range: '$150 – $400', note: 'SGVMWD hard water inlet valve · Fan motor · OEM parts', featured: true },
  { appliance: 'Dishwasher', range: '$150 – $320', note: 'Hard water descaling · Drain pump · Spray arm · Filter', featured: true },
  { appliance: 'Washer / Dryer', range: '$150 – $350', note: 'Drain pump · Thermal fuse · Vent cleaning · Gas & electric' },
  { appliance: 'Oven / Range', range: '$150 – $400', note: 'Gas igniter · Bake element · Temperature calibration' },
  { appliance: 'Sub-Zero / Wolf', range: '$300 – $700+', note: 'OEM parts only · Luxury brand expertise' },
  { appliance: 'Diagnostic Fee', range: '$89', note: 'Waived when you proceed with the repair' },
];

const faqs = [
  {
    question: "Do you offer same-day appliance repair in Temple City, CA?",
    answer: "Yes. Our technicians cover all of Temple City 91780 — Live Oak Avenue, Rosemead Boulevard, Longden Avenue, Las Tunas Drive, Broadway, and every residential street in the city. Call before noon for same-day afternoon service."
  },
  {
    question: "Does hard water in Temple City affect appliances?",
    answer: "Yes. Temple City is served by the San Gabriel Valley Municipal Water District's mineral-rich groundwater. Ice maker inlet valves and dishwasher spray arms scale up faster than in softer-water cities. We check for this proactively on every relevant Temple City call."
  },
  {
    question: "Are you available on weekends in Temple City?",
    answer: "Yes. Saturday 8am–7pm and Sunday 9am–5pm. If your appliance breaks on a weekend, you don't have to wait until Monday."
  },
  {
    question: "What appliance brands do you repair in Temple City?",
    answer: "All major brands: Samsung, LG, GE, Whirlpool, KitchenAid, Bosch, Maytag, Sub-Zero, Wolf, Viking, Thermador, and more. OEM parts on every vehicle."
  },
  {
    question: "What is your diagnostic fee in Temple City?",
    answer: "Our diagnostic fee is $89, waived when you proceed with the repair. Written estimate before we start. Most Temple City repairs run $150–$400."
  },
  {
    question: "What warranty do you offer on appliance repairs in Temple City?",
    answer: "All repairs come with a 90-day warranty on parts and labor. Genuine OEM parts only. If the same issue returns within 90 days, we come back at no charge."
  },
  {
    question: "Do you also serve Arcadia, San Gabriel, and Rosemead?",
    answer: "Yes. Our Temple City service extends to Arcadia, San Gabriel, Rosemead, El Monte, Alhambra, Monrovia, and South Pasadena. All within our regular SGV route."
  },
];

const nearbyCities = [
  { name: 'Pasadena', slug: 'pasadena' },
  { name: 'Arcadia', slug: 'arcadia' },
  { name: 'Alhambra', slug: 'alhambra' },
  { name: 'Monrovia', slug: 'monrovia' },
  { name: 'South Pasadena', slug: 'south-pasadena' },
  { name: 'San Marino', slug: 'san-marino' },
  { name: 'Glendale', slug: 'glendale' },
  { name: 'Los Angeles', slug: 'los-angeles' },
];
---

<CityLayoutV2
  title={title}
  description={description}
  canonical={canonical}
  localBusinessSchema={localBusinessSchema}
>
  <HeroSection
    citySlug={citySlug}
    headlineTop="Appliance Repair"
    headlineCity="Temple City, CA"
    subheadline="Quiet, family-oriented SGV community with well-kept homes — and appliances that need the same care. Samsung, LG, GE, Whirlpool, Sub-Zero, all brands. Same-day service, OEM parts, 90-day warranty. Weekends available."
    zips={zips}
    tier={3}
  />

  <TrustBadgesRow />

  <IntroNarrative
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance Repair in Temple City — Straightforward and Same Day"
    paragraphs={introParagraphs}
    bookingTitle="Temple City Service Team"
    bookingSub="91780 · Same day · Weekends ok"
  />

  <ServicesGrid
    cityName={cityName}
    headline="What We Repair in Temple City"
    subhead="All brands · SGVMWD hard water aware · Single-family homes · 91780"
    services={services}
  />

  <ServiceArea
    cityName={cityName}
    headline="All of Temple City — 91780"
    subheadline="Every neighborhood and street in the city"
    zips={zips}
    neighborhoods={neighborhoods}
    keyStreets={keyStreets}
  />

  <RecentRepairs
    citySlug={citySlug}
    cityName={cityName}
    headline="Recent Jobs in Temple City"
    subhead="Real calls from 91780 — single-family homes, SGVMWD hard water, weekend service."
    jobs={recentJobs}
  />

  <WhyCallsUsBack
    cityName={cityName}
    headline="Why Temple City Calls Us Back"
    reasons={whyReasons}
  />

  <ReviewsBlock
    cityName={cityName}
    headline="What Temple City Customers Are Saying"
    testimonials={testimonials}
  />

  <PricingCards
    cityName={cityName}
    headline="Appliance Repair Costs in Temple City"
    subhead="Written estimate before we start. $89 diagnostic — waived with repair."
    tiers={pricingTiers}
    footnote={false}
  />

  <FAQAccordion
    cityName={cityName}
    headline="Questions Temple City Customers Ask"
    faqs={faqs}
  />

  <AlsoServingNearby
    nearbyCities={nearbyCities}
    headline="Also Serving Nearby Areas"
  />

  <FinalCTA
    citySlug={citySlug}
    cityName={cityName}
    headline="Appliance broken in Temple City?"
    body="SGVMWD hard water specialists · All brands · Weekends available. 91780. $89 diagnostic waived with repair. 90-day warranty. OEM parts."
  />
</CityLayoutV2>
