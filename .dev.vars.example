# ============================================================
# Local development secrets for Cloudflare Pages Functions
# ============================================================
# 1. Copy this file to `.dev.vars` (same folder, same name minus .example)
# 2. Fill in the real values below
# 3. NEVER commit .dev.vars (already in .gitignore)
#
# To run locally with Functions:
#   npm run build
#   npx wrangler pages dev ./dist --compatibility-date=2024-01-01
#
# `npm run dev` alone does NOT run Functions — use wrangler.
# ============================================================

# Anthropic API key — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# Telegram — same group as lgdryer (per current setup)
# Get TOKEN from @BotFather
# Get CHAT_ID by: send message to group → open
#   https://api.telegram.org/bot<TOKEN>/getUpdates → look for "chat":{"id":-100...}
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Resend — https://resend.com/api-keys
# RESEND_FROM must be on a domain you've verified in Resend
RESEND_API_KEY=re_...
RESEND_FROM="Same Day Appliance Repair <noreply@samedayappliance.repair>"
RESEND_TO=abysov@gmail.com
